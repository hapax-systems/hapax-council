# Hapax Imagination production build orchestration.
# Production builds use an isolated CARGO_TARGET_DIR to prevent
# stomping dev builds (which use the default ./target/).
#
# The Tauri/WebKit hapax-logos runtime is decommissioned as a production
# surface. Its build target remains explicit for local inspection only; the
# default production build/install path handles hapax-imagination only.

set dotenv-load := false

prod_target := env("HOME") / ".cache/hapax/build-target"
bin_dir     := env("HOME") / ".local/bin"
state_dir   := env("HOME") / ".cache/hapax/rebuild"
repo_root   := justfile_directory() / ".."

export CARGO_TARGET_DIR := prod_target

# ── Info ──────────────────────────────────────────────────────────

# Show version of installed production binaries
version:
    @{{bin_dir}}/hapax-imagination --version 2>/dev/null || echo "hapax-imagination: not installed"
    @echo "hapax-logos: production runtime decommissioned"

# ── Build ─────────────────────────────────────────────────────────

# Build frontend (Vite)
frontend:
    pnpm install --frozen-lockfile
    pnpm build

# Build imagination binary
imagination:
    cargo build --release -p hapax-imagination

# Build Tauri logos binary with bundled frontend.
# Dev-only: not part of production install/rebuild.
logos: frontend
    cargo build --release -p hapax-logos --features tauri/custom-protocol

# Build production binaries
build: imagination

# ── Install ───────────────────────────────────────────────────────

# Pre-flight checks for production binary install
check:
    #!/usr/bin/env bash
    set -euo pipefail
    cd {{repo_root}}
    SHA=$(git rev-parse HEAD)
    MAIN_SHA=$(git rev-parse origin/main 2>/dev/null || echo "unknown")
    if [ "$SHA" != "$MAIN_SHA" ]; then
        echo "WARNING: HEAD (${SHA:0:8}) != origin/main (${MAIN_SHA:0:8})"
    fi
    IMAG="{{prod_target}}/release/hapax-imagination"
    [ -f "$IMAG" ] || { echo "ERROR: $IMAG not found — run 'just build' first"; exit 1; }
    echo "OK: $(git log --oneline -1)"

# Production install alias
install: install-imagination

# Build, check, and install hapax-imagination with rollback backup
install-imagination: build check
    #!/usr/bin/env bash
    set -euo pipefail
    IMAG_SRC="{{prod_target}}/release/hapax-imagination"
    IMAG_DST="{{bin_dir}}/hapax-imagination"

    # Backup current binary
    [ -f "$IMAG_DST" ] && cp "$IMAG_DST" "$IMAG_DST.prev"

    # Install binary — DO NOT restart services.
    # Restarting imagination opens a new window on the operator's workspace.
    # The operator restarts services manually when ready (mod+Q or systemctl).
    # Use rename trick to handle "text file busy" (can't overwrite running binary).
    cp "$IMAG_SRC" "$IMAG_DST.new" && mv -f "$IMAG_DST.new" "$IMAG_DST"

    echo "Installed hapax-imagination (not restarted - restart manually when ready)."
    echo "  systemctl --user restart hapax-imagination.service"
    $IMAG_DST --version 2>/dev/null || true

# ── Rollback ──────────────────────────────────────────────────────

# Restore previous binaries
rollback:
    #!/usr/bin/env bash
    set -euo pipefail
    IMAG="{{bin_dir}}/hapax-imagination"
    [ -f "$IMAG.prev" ] || { echo "No imagination backup found"; exit 1; }
    systemctl --user stop hapax-imagination.service 2>/dev/null || true
    mv "$IMAG.prev" "$IMAG"
    systemctl --user start hapax-imagination.service 2>/dev/null || true
    echo "Rolled back."
    $IMAG --version 2>/dev/null || true

# ── Clean ─────────────────────────────────────────────────────────

# Remove production build cache (does not affect dev target/)
clean:
    rm -rf {{prod_target}}
    echo "Cleaned {{prod_target}}"
