[Unit]
Description=Hapax Watch Backup — daily rsync of wear-OS state from workstation
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/bin/bash %h/hapax-edge/hapax-watch-backup.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hapax-watch-backup

[Install]
WantedBy=default.target
