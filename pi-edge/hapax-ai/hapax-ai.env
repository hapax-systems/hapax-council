# hapax-ai environment — sourced by systemd user units and by /opt/hapax-ai venv activate
# Canonical location on the Pi: /etc/hapax-ai.env or ~/.config/hapax-ai.env
# Pre-staged 2026-04-15 (epsilon). Update after Thursday first boot with actual IPs.

# --- Network identity ---
HAPAX_AI_HOSTNAME="hapax-ai"
HAPAX_AI_IP="192.168.68.79"                    # DHCP-reserved, see dhcp-reservation-notes.md
HAPAX_WORKSTATION_IP="192.168.68.80"

# --- Hailo ---
HAILO_DEVICE="/dev/hailo0"
HAPAX_AI_MODEL_DIR="/opt/hapax-ai/models"

# --- SHM output paths ---
HAPAX_AI_SHM_ROOT="/dev/shm/hapax-ai"
HAPAX_AI_OUTPUT_DETECTIONS="${HAPAX_AI_SHM_ROOT}/detections.json"
HAPAX_AI_OUTPUT_TRANSCRIPTS="${HAPAX_AI_SHM_ROOT}/transcripts.jsonl"
HAPAX_AI_OUTPUT_PRESENCE="${HAPAX_AI_SHM_ROOT}/presence.json"
HAPAX_AI_OUTPUT_ROOM_VAD="${HAPAX_AI_SHM_ROOT}/room-vad.json"

# --- Input mounts ---
# SHM frame source from workstation (rsync-pull daemon or NFS mount; TBD)
HAPAX_AI_INPUT_FRAMES="/mnt/workstation-shm/hapax-visual"
# PipeWire ROC source name for operator audio (published by workstation's module-roc-sink)
HAPAX_ASR_INPUT="roc-source.operator-yeti"

# --- Logging ---
HAPAX_AI_LOG_DIR="/var/log/hapax-ai"
HAPAX_AI_LOG_LEVEL="INFO"

# --- Python runtime ---
HAPAX_AI_VENV="/opt/hapax-ai/venv"
PATH="${HAPAX_AI_VENV}/bin:${PATH}"

# --- Workload tuning ---
HAPAX_AI_COPROC_TARGET_FPS=100
HAPAX_ASR_TARGET_LATENCY_MS=250
HAPAX_ASR_LANGUAGE="en"
