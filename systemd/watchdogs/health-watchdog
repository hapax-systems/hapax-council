#!/usr/bin/env bash
# health-watchdog — Scheduled health check with auto-remediation and notifications.
# Runs via systemd timer. Fixes safe issues automatically, notifies on remaining problems.
# Sends to ntfy (mobile push) + notify-send (desktop) via shared.notify.
set -euo pipefail

SOURCE_ACTIVATION_STATE_DIR="${HAPAX_SOURCE_ACTIVATION_STATE_DIR:-/home/hapax/.cache/hapax/source-activation}"
SOURCE_ACTIVATION_RELEASES_DIR="${HAPAX_SOURCE_ACTIVATION_RELEASES_DIR:-$SOURCE_ACTIVATION_STATE_DIR/releases}"
SOURCE_ACTIVATION_REPO="${HAPAX_SOURCE_ACTIVATION_WORKTREE:-$SOURCE_ACTIVATION_STATE_DIR/worktree}"
HEALTH_MONITOR_REPO=""

is_source_activation_release() {
    local candidate="$1"
    [[ -n "$candidate" && -e "$candidate/.git" ]] || return 1
    [[ -d "$SOURCE_ACTIVATION_RELEASES_DIR" ]] || return 1

    local candidate_real releases_real
    candidate_real="$(realpath "$candidate" 2>/dev/null || true)"
    releases_real="$(realpath "$SOURCE_ACTIVATION_RELEASES_DIR" 2>/dev/null || true)"
    [[ -n "$candidate_real" && -n "$releases_real" ]] || return 1
    case "$candidate_real" in
        "$releases_real"/*) return 0 ;;
        *) return 1 ;;
    esac
}

if [[ -e "$SOURCE_ACTIVATION_REPO/.git" ]]; then
    HEALTH_MONITOR_REPO="$SOURCE_ACTIVATION_REPO"
elif is_source_activation_release "${HAPAX_HEALTH_MONITOR_REPO:-}"; then
    echo "WARN: source activation checkout missing at $SOURCE_ACTIVATION_REPO; using explicit HAPAX_HEALTH_MONITOR_REPO override" >&2
    HEALTH_MONITOR_REPO="$HAPAX_HEALTH_MONITOR_REPO"
elif [[ -n "${HAPAX_HEALTH_MONITOR_REPO:-}" ]]; then
    echo "WARN: ignoring HAPAX_HEALTH_MONITOR_REPO=${HAPAX_HEALTH_MONITOR_REPO}; override must be a source-activation release under $SOURCE_ACTIVATION_RELEASES_DIR" >&2
fi

if [[ -z "$HEALTH_MONITOR_REPO" ]]; then
    echo "ERROR: no health-monitor activation checkout available at $SOURCE_ACTIVATION_REPO" >&2
    echo "NEXT ACTION: run source activation or set HAPAX_SOURCE_ACTIVATION_WORKTREE/HAPAX_HEALTH_MONITOR_REPO to a valid source-activation checkout" >&2
    notify-send --urgency=critical --app-name="Health Monitor" --icon=dialog-error \
        "Health Monitor Failed" "No activation checkout available; run source activation or set HAPAX_SOURCE_ACTIVATION_WORKTREE" 2>/dev/null || true
    exit 1
fi
cd "$HEALTH_MONITOR_REPO"
export HAPAX_HEALTH_MONITOR_ACTIVE_REPO="$HEALTH_MONITOR_REPO"

UV="${HAPAX_UV:-/home/hapax/.local/bin/uv}"

# Validate uv exists
if [[ ! -x "$UV" ]]; then
    echo "ERROR: uv not found at $UV" >&2
    notify-send --urgency=critical --app-name="Health Monitor" --icon=dialog-error \
        "Health Monitor Failed" "uv not found at $UV" 2>/dev/null || true
    exit 1
fi

# Load credentials from the central tmpfs secret boundary.
SECRETS_ENV="${HAPAX_SECRETS_ENV:-/run/user/1000/hapax-secrets.env}"
if [[ ! -r "$SECRETS_ENV" ]]; then
    echo "ERROR: missing $SECRETS_ENV; hapax-secrets.service must materialize runtime credentials" >&2
    exit 1
fi
set -a
# shellcheck source=/run/user/1000/hapax-secrets.env
source "$SECRETS_ENV"
set +a
: "${LITELLM_API_KEY:?missing LITELLM_API_KEY in $SECRETS_ENV}"

# Run health check with timeout (exit codes: 0=healthy, 1=degraded, 2=failed — all valid)
REPORT=""
REPORT=$(timeout 100 $UV run python -m agents.health_monitor --json 2>/dev/null) || true

if [[ -z "$REPORT" ]]; then
    $UV run python -c "
from shared.notify import send_notification, nudges_uri
send_notification('Health Monitor Failed', 'Could not run health check — uv or Python crashed', priority='urgent', tags=['skull'], click_url=nudges_uri())
" 2>/dev/null || notify-send --urgency=critical --app-name="Health Monitor" --icon=dialog-error \
        "Health Monitor Failed" "Could not run health check" 2>/dev/null || \
        echo "CRITICAL: Health check failed and all notification channels unavailable" >&2
    exit 1
fi

# Parse status with validation
STATUS=""
if ! STATUS=$(echo "$REPORT" | python3 -c "import sys,json; print(json.load(sys.stdin)['overall_status'])" 2>/dev/null); then
    echo "ERROR: Could not parse health report JSON" >&2
    exit 1
fi

if [[ -z "$STATUS" || ! "$STATUS" =~ ^(healthy|degraded|failed)$ ]]; then
    echo "ERROR: Invalid status value: '$STATUS'" >&2
    exit 1
fi

# If there are actual failures (not just degraded), run LLM-evaluated fix pipeline
REPORT2=""
if [[ "$STATUS" == "failed" ]]; then
    timeout 260 $UV run python -m agents.health_monitor --apply 2>&1 || true

    # Re-check after fix
    if REPORT2=$(timeout 100 $UV run python -m agents.health_monitor --json 2>/dev/null) && [[ -n "$REPORT2" ]]; then
        STATUS2=""
        if STATUS2=$(echo "$REPORT2" | python3 -c "import sys,json; print(json.load(sys.stdin)['overall_status'])" 2>/dev/null); then
            if [[ "$STATUS2" == "healthy" ]]; then
                echo "$REPORT" | $UV run python -c "
import sys, json
from shared.notify import send_notification, nudges_uri
r = json.load(sys.stdin)
send_notification('Auto-Fixed', f\"{r['summary']} -> All healthy\nLLM-evaluated fix applied\", tags=['white_check_mark'], click_url=nudges_uri())
" 2>/dev/null || true
            fi
            STATUS="$STATUS2"
        fi
    fi
fi

# Notify based on final status — pass JSON via stdin to avoid shell injection
FINAL_REPORT="${REPORT2:-$REPORT}"
case "$STATUS" in
    healthy)
        # Silent on healthy — no notification spam
        ;;
    degraded|failed)
        echo "$FINAL_REPORT" | $UV run python -c "
import sys, json, os
from shared.notify import send_notification, send_webhook, nudges_uri
r = json.load(sys.stdin)
status = r['overall_status']
summary = r['summary']
failed = r['failed_count']

if status == 'failed':
    # Route through the selected checkout's P0 intake so the alert coalesces
    # into one governed incident. Any CLI failure falls back to raw notify
    # instead of silently suppressing the failed-stack alert.
    import subprocess
    active_repo = os.environ.get('HAPAX_HEALTH_MONITOR_ACTIVE_REPO', '')
    default_cli = os.path.join(active_repo, 'scripts', 'hapax-p0-incident-intake')
    cli = os.path.expanduser(os.environ.get('HAPAX_P0_INTAKE_CLI') or default_cli)
    intake_timeout_raw = os.environ.setdefault('HAPAX_P0_INTAKE_TIMEOUT_SECONDS', '20')
    try:
        intake_timeout_s = float(intake_timeout_raw)
    except ValueError:
        intake_timeout_s = 20.0
    try:
        rc = subprocess.run([
            cli, 'notification', '--title', 'Stack Failed',
            '--message', f'{summary}\nRun: uv run python -m agents.health_monitor --verbose',
            '--technical', '--priority', 'high', '--tag', 'rotating_light',
        ], check=False, timeout=intake_timeout_s).returncode
    except (OSError, subprocess.TimeoutExpired):
        rc = 1
    if rc != 0:
        send_notification('Stack Failed', f'{summary}\nRun: uv run python -m agents.health_monitor --verbose', priority='high', tags=['rotating_light'], click_url=nudges_uri())
else:
    send_notification('Stack Degraded', summary, priority='default', tags=['warning'], click_url=nudges_uri())

webhook = os.environ.get('N8N_HEALTH_WEBHOOK_URL', '')
if webhook:
    send_webhook(webhook, {'status': status, 'summary': summary, 'failed': failed})
" 2>/dev/null || echo "WARN: Could not send health notification" >&2
        ;;
esac

# Append to health history (atomic via temp file + rename)
HISTORY_FILE="${HAPAX_HEALTH_HISTORY_FILE:-$HEALTH_MONITOR_REPO/profiles/health-history.jsonl}"
HISTORY_DIR="$(dirname "$HISTORY_FILE")"
if ! mkdir -p "$HISTORY_DIR"; then
    echo "WARN: Could not create history directory: $HISTORY_DIR" >&2
fi
ENTRY=$(echo "$FINAL_REPORT" | python3 -c "
import sys, json
r = json.load(sys.stdin)
entry = {
    'timestamp': r['timestamp'],
    'status': r['overall_status'],
    'healthy': r['healthy_count'],
    'degraded': r['degraded_count'],
    'failed': r['failed_count'],
    'duration_ms': r['duration_ms'],
    'failed_checks': [
        c['name'] for g in r['groups'] for c in g['checks']
        if c['status'] != 'healthy'
    ],
}
print(json.dumps(entry))
" 2>/dev/null) || true

if [[ -n "$ENTRY" ]]; then
    if ! WRITE_ERR=$( { echo "$ENTRY" >> "$HISTORY_FILE"; } 2>&1 ); then
        echo "WARN: Could not write history: $WRITE_ERR" >&2
    fi
fi

# Exit code matches status
case "$STATUS" in
    healthy)  exit 0 ;;
    degraded) exit 1 ;;
    failed)   exit 2 ;;
esac
