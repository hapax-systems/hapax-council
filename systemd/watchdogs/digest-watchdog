#!/usr/bin/env bash
set -euo pipefail

# Content digest generator — saves to profiles/ + vault and sends notification
SOURCE_ROOT="${HAPAX_SOURCE_ACTIVATION_WORKTREE:-/home/hapax/.cache/hapax/source-activation/worktree}"
cd "$SOURCE_ROOT"

# Load credentials from pass store (systemd sets PASSWORD_STORE_DIR + GNUPGHOME)
export LITELLM_API_KEY=$(pass show litellm/master-key 2>/dev/null || echo "changeme")
export LANGFUSE_PUBLIC_KEY=$(pass show langfuse/public-key 2>/dev/null || true)
export LANGFUSE_SECRET_KEY=$(pass show langfuse/secret-key 2>/dev/null || true)
export HAPAX_BACKGROUND_CAPABILITY_LANE=${HAPAX_BACKGROUND_CAPABILITY_LANE:-digest-watchdog}
export HAPAX_BACKGROUND_CAPABILITY_RECEIPTS=${HAPAX_BACKGROUND_CAPABILITY_RECEIPTS:-1}

UV=/home/hapax/.local/bin/uv
# agents.digest gates synthesis with admit_background_capability; without a
# task note and current route/resource/quota receipts, it degrades without LLM use.
REPORT=$($UV run python -m agents.digest --hours 24 --save --json 2>/dev/null)

# Notify via shared.notify (pass JSON via stdin)
echo "$REPORT" | $UV run python -c "
import sys, json
from shared.notify import send_notification
r = json.load(sys.stdin)
headline = r.get('headline', 'Digest generated')
new_docs = r.get('stats', {}).get('new_documents', 0)
body = headline
if new_docs > 0:
    body += f'\n{new_docs} new document(s) ingested'
    send_notification('Content Digest', body, tags=['books'])
" 2>/dev/null || true

# Append to history
echo "$REPORT" >> "$SOURCE_ROOT/profiles/digest-history.jsonl" 2>/dev/null || true
