#!/usr/bin/env bash
set -euo pipefail

# Content digest generator — saves to profiles/ + vault and sends notification
cd /home/hapax/projects/hapax-council

# Load credentials from the central tmpfs secret boundary.
SECRETS_ENV="${HAPAX_SECRETS_ENV:-/run/user/1000/hapax-secrets.env}"
if [[ ! -r "$SECRETS_ENV" ]]; then
    echo "ERROR: missing $SECRETS_ENV; hapax-secrets.service must materialize runtime credentials" >&2
    exit 1
fi
set -a
# shellcheck source=/run/user/1000/hapax-secrets.env
source "$SECRETS_ENV"
set +a
: "${LITELLM_API_KEY:?missing LITELLM_API_KEY in $SECRETS_ENV}"

UV=/home/hapax/.local/bin/uv
REPORT=$($UV run python -m agents.digest --hours 24 --save --json 2>/dev/null)

# Notify via shared.notify (pass JSON via stdin)
echo "$REPORT" | $UV run python -c "
import sys, json
from shared.notify import send_notification
r = json.load(sys.stdin)
headline = r.get('headline', 'Digest generated')
new_docs = r.get('stats', {}).get('new_documents', 0)
body = headline
if new_docs > 0:
    body += f'\n{new_docs} new document(s) ingested'
    send_notification('Content Digest', body, tags=['books'])
" 2>/dev/null || true

# Append to history
echo "$REPORT" >> /home/hapax/projects/hapax-council/profiles/digest-history.jsonl 2>/dev/null || true
