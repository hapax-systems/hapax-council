[Unit]
Description=Logos API — FastAPI backend on :8051
After=network.target llm-stack.service hapax-secrets.service
Wants=llm-stack.service
Requires=hapax-secrets.service
StartLimitIntervalSec=0
OnFailure=notify-failure@%n.service

[Service]
Type=simple
WorkingDirectory=%h/.cache/hapax/source-activation/worktree
EnvironmentFile=/run/user/1000/hapax-secrets.env
ExecStartPre=%h/.cache/hapax/source-activation/worktree/scripts/hapax-compositor-runtime-source-check --require-file logos/api/__main__.py
ExecStart=%h/.local/bin/uv --directory %h/.cache/hapax/source-activation/worktree run python -m logos.api --host 0.0.0.0 --port 8051
Restart=on-failure
RestartSec=5
SuccessExitStatus=SIGTERM
Environment=PATH=%h/.cache/hapax/source-activation/worktree/.venv/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=PYTHONPATH=%h/.cache/hapax/source-activation/worktree
Environment=HOME=%h
# logos-api is CPU-only w.r.t. embeddings (all nomic-embed-cpu). Never block on
# the GPU flock semaphore: on contention gpu_slot() runs the embed without a slot
# rather than wedging the asyncio event loop. Definitive fix for the recurring
# :8051 hang (reactive _handle_change -> embed -> gpu_slot blocking on the loop).
Environment=HAPAX_GPU_SEM_NONBLOCK=1
# Critical API surface. Live evidence on 2026-05-16 showed normal
# operation at ~0.93G under the old 1G cap while the host still had
# ~79G RAM available. Keep a hard ceiling for runaway protection, but
# do not let a stale small cap page or kill the API.
MemoryHigh=6G
MemoryMax=8G
SyslogIdentifier=logos-api
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
