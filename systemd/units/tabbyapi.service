[Unit]
Description=TabbyAPI — EXL3 inference engine on :5000
After=network.target
After=ollama.service

[Service]
Type=simple
WorkingDirectory=%h/projects/tabbyAPI
ExecStart=%h/projects/tabbyAPI/venv/bin/python3 main.py
Restart=on-failure
RestartSec=15
# LRR Phase 3 item 8: raised from 120 → 180 seconds. Qwen3.5-9B EXL3
# loads in ~40-50 s and would fit a 120 s timeout; the 180 s ceiling
# is held as conservative headroom for substrate swaps that load more
# safetensors shards from disk than the current Qwen 9B substrate.
TimeoutStartSec=180
Environment=PYTORCH_ALLOC_CONF=backend:cudaMallocAsync

[Install]
WantedBy=default.target
