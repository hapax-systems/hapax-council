[Unit]
Description=TabbyAPI — EXL3 inference engine on :5000
After=network.target
After=ollama.service

[Service]
Type=simple
WorkingDirectory=%h/projects/tabbyAPI
ExecStart=%h/projects/tabbyAPI/venv/bin/python3 main.py
Restart=on-failure
RestartSec=15
# Content-prep residency policy expects Command-R to stay loaded on :5000.
# Keep enough startup headroom for Command-R shard load and CUDA allocation;
# this is not a normal-path model swap or unload/reload mechanism.
TimeoutStartSec=180
Environment=PYTORCH_ALLOC_CONF=backend:cudaMallocAsync

[Install]
WantedBy=default.target
