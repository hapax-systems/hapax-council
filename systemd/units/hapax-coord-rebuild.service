# Hapax-Auto-Enable: true
[Unit]
Description=Hapax coord deploy - fetch main, refresh the activation worktree, restart the yard on change
Wants=network-online.target
After=network-online.target
OnFailure=notify-failure@%n.service

[Service]
Type=oneshot
ExecStart=%h/.local/lib/hapax-recovery/council/current/scripts/hapax-coord-deploy
