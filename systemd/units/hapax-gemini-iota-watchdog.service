[Unit]
Description=Retired Hapax Gemini iota lane watchdog compatibility unit
Documentation=file:///home/hapax/projects/hapax-council/scripts/hapax-gemini-watchdog
After=default.target
PartOf=hapax-control-plane.target

[Service]
Type=oneshot
ExecStart=/usr/bin/true
RemainAfterExit=yes

# Retained only so stale installs do not respawn the retired Gemini CLI lane.
MemoryMax=64M
CPUQuota=5%

[Install]
WantedBy=default.target
