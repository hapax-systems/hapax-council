# hapax-audio-health-inter-stage-corr
ExecStart=%h/.cache/hapax/rebuild/worktree/scripts/rebuild-service.sh --repo %h/.cache/hapax/rebuild/worktree --service hapax-audio-health-inter-stage-corr.service --watch "agents/audio_health/ shared/" --sha-key audio-health-inter-stage-corr

# hapax-audio-health-l12-usb
ExecStart=%h/.cache/hapax/rebuild/worktree/scripts/rebuild-service.sh --repo %h/.cache/hapax/rebuild/worktree --service hapax-audio-health-l12-usb.service --watch "agents/audio_health/ shared/" --sha-key audio-health-l12-usb

# hapax-audio-health-lufs-s
ExecStart=%h/.cache/hapax/rebuild/worktree/scripts/rebuild-service.sh --repo %h/.cache/hapax/rebuild/worktree --service hapax-audio-health-lufs-s.service --watch "agents/audio_health/ shared/" --sha-key audio-health-lufs-s

# hapax-audio-health-pipewire-xrun
ExecStart=%h/.cache/hapax/rebuild/worktree/scripts/rebuild-service.sh --repo %h/.cache/hapax/rebuild/worktree --service hapax-audio-health-pipewire-xrun.service --watch "agents/audio_health/ shared/" --sha-key audio-health-pipewire-xrun

# hapax-audio-health-topology-drift
ExecStart=%h/.cache/hapax/rebuild/worktree/scripts/rebuild-service.sh --repo %h/.cache/hapax/rebuild/worktree --service hapax-audio-health-topology-drift.service --watch "agents/audio_health/ shared/" --sha-key audio-health-topology-drift

