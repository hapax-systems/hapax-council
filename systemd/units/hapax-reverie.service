[Unit]
Description=Hapax Reverie — visual expression daemon
After=hapax-secrets.service hapax-dmn.service
Wants=hapax-dmn.service
PartOf=hapax-visual-stack.target

[Service]
Type=simple
WorkingDirectory=%h/.cache/hapax/source-activation/worktree
ExecStartPre=%h/.cache/hapax/source-activation/worktree/scripts/hapax-compositor-runtime-source-check --require-file agents/reverie/__main__.py --require-file shared/reverie_uniform_policy.py
ExecStart=%h/.cache/hapax/source-activation/worktree/.venv/bin/python -m agents.reverie
Restart=on-failure
RestartSec=10
EnvironmentFile=/run/user/1000/hapax-secrets.env
Environment=PATH=/home/hapax/.local/bin:/usr/local/bin:/usr/bin
Environment=PYTHONPATH=%h/.cache/hapax/source-activation/worktree
# Versioned replacement for the former local 3d-mode drop-in. Reverie has
# live readers for this flag and must not depend on shadow ~/.config state.
Environment=HAPAX_3D_COMPOSITOR=1
MemoryHigh=2G
MemoryMax=4G

[Install]
WantedBy=default.target
