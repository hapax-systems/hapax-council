[Unit]
Description=Hapax novelty-shift impingement emitter (cc-task u3)
Documentation=https://github.com/ryanklee/hapax-council/blob/main/agents/novelty_emitter/_emitter.py
After=hapax-daimonion.service hapax-secrets.service

[Service]
Type=oneshot
WorkingDirectory=%h/projects/hapax-council
ExecStart=/usr/bin/uv run python -m agents.novelty_emitter
TimeoutStartSec=10
SuccessExitStatus=0

[Install]
WantedBy=default.target
