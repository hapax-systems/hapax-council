[Unit]
Description=Hapax Quake in-world camera live texture source (%i)
PartOf=hapax-visual-stack.target hapax-darkplaces-v4l2.service
ConditionPathExists=%h/.config/hapax/enable-darkplaces-runtime
ConditionPathExists=%h/.cache/hapax/source-activation/worktree/config/quake-live-cameras/%i.env

[Service]
Type=simple
WorkingDirectory=%h/.cache/hapax/source-activation/worktree
EnvironmentFile=%h/.cache/hapax/source-activation/worktree/config/quake-live-cameras/%i.env
Environment=HAPAX_QUAKE_GPU_DRIFT=1
Environment=HAPAX_QUAKE_LIVE_TEXTURE_INPUT_FPS=10
ExecStart=%h/.cache/hapax/source-activation/worktree/scripts/quake-live-media-source.py --source camera --camera-role %i --fps ${HAPAX_QUAKE_LIVE_TEXTURE_FPS} --camera-fps ${HAPAX_QUAKE_LIVE_TEXTURE_INPUT_FPS} --width ${HAPAX_QUAKE_LIVE_TEXTURE_WIDTH} --height ${HAPAX_QUAKE_LIVE_TEXTURE_HEIGHT} --output ${HAPAX_QUAKE_LIVE_TEXTURE_OUTPUT} --meta ${HAPAX_QUAKE_LIVE_TEXTURE_META}
Restart=always
RestartSec=3

[Install]
WantedBy=hapax-visual-stack.target
