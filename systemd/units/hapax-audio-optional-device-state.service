[Unit]
Description=Hapax optional audio device state witness
After=pipewire.service wireplumber.service
Requires=pipewire.service
ConditionPathExists=%h/.cache/hapax/source-activation/worktree/scripts/hapax-audio-optional-device-state

[Service]
Type=oneshot
WorkingDirectory=%h/.cache/hapax/source-activation/worktree
ExecStart=%h/.cache/hapax/source-activation/worktree/scripts/hapax-audio-optional-device-state
Environment=PYTHONPATH=%h/.cache/hapax/source-activation/worktree
