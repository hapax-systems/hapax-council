[Unit]
Description=Hapax PR admission governor — auto-cycle (anti-pileup)
Documentation=file://%h/.cache/hapax/source-activation/worktree/scripts/hapax-pr-admission
# Run after the gh CLI dependencies are present; pipewire/network not required.
After=network-online.target
PartOf=hapax.target

[Service]
Type=oneshot
WorkingDirectory=%h/.cache/hapax/source-activation/worktree
Environment=CLAUDE_ROLE=auto
Environment=HOME=%h
Environment=PATH=%h/.cache/hapax/source-activation/worktree/.venv/bin:%h/.local/bin:/usr/local/bin:/usr/bin
Environment=PYTHONPATH=%h/.cache/hapax/source-activation/worktree
# Auto-cycle:
#   - if merge-group failure rate crosses the freeze threshold → freeze
#   - when the failure-rate throttle calms → clear to normal
# No-op (exit 0) for unrelated cases.
ExecStart=%h/.local/bin/uv --directory %h/.cache/hapax/source-activation/worktree run python scripts/hapax-pr-admission auto
TimeoutStartSec=30s
# Don't restart on failure — the timer drives cadence; one missed tick is harmless.
SuccessExitStatus=0

[Install]
WantedBy=default.target
