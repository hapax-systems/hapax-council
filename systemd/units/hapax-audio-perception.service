[Unit]
Description=Hapax audio perception daemon — CLAP + pyannote VAD + librosa to /dev/shm
After=pipewire.service pipewire-pulse.service
Requires=pipewire-pulse.service
ConditionPathExists=%h/.cache/hapax/rebuild/worktree/pyproject.toml

[Service]
Type=simple
Environment=CUDA_VISIBLE_DEVICES=
Environment=HAPAX_AUDIO_PERCEPTION_SOURCE=hapax-broadcast-normalized
WorkingDirectory=%h/.cache/hapax/rebuild/worktree
ExecStart=%h/.local/bin/uv run python -m agents.audio_perception
Restart=on-failure
RestartSec=10
MemoryMax=3G

[Install]
WantedBy=default.target
