[Unit]
Description=Local music player — plays operator-selected tracks via pw-cat (content-source-registry Phase 4a)
Documentation=file:///home/hapax/projects/hapax-council/docs/superpowers/plans/2026-04-23-content-source-registry-plan.md
After=hapax-secrets.service pipewire.service hapax-private-broadcast-leak-guard.service
Wants=pipewire.service hapax-private-broadcast-leak-guard.service
OnFailure=notify-failure@%n.service

[Service]
Type=simple
WorkingDirectory=%h/.cache/hapax/source-activation/worktree
ExecStartPre=%h/.cache/hapax/source-activation/worktree/scripts/hapax-compositor-runtime-source-check --require-file agents/local_music_player/__main__.py
ExecStart=%h/.local/bin/uv run --directory %h/.cache/hapax/source-activation/worktree python -m agents.local_music_player
Environment=PATH=%h/.cache/hapax/source-activation/worktree/.venv/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=PYTHONPATH=%h/.cache/hapax/source-activation/worktree
Environment=HOME=%h
Environment=XDG_RUNTIME_DIR=/run/user/1000
Environment=PYTHONUNBUFFERED=1
Restart=on-failure
RestartSec=5s
MemoryMax=512M
CPUQuota=25%
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hapax-music-player

[Install]
WantedBy=default.target
