[Unit]
Description=Rebuild deployed DarkPlaces live-texture binary after source activation
After=hapax-source-activate.service
ConditionPathExists=%h/.config/hapax/enable-darkplaces-runtime
ConditionPathExists=%h/.cache/hapax/source-activation/last-success-sha
ConditionPathExists=%h/.cache/hapax/source-activation/worktree/scripts/ensure-darkplaces-live-texture-build.sh
ConditionPathExists=%h/.cache/hapax/source-activation/worktree/assets/quake/darkplaces/hapax-live-texture.patch
OnFailure=notify-failure@%n.service
StartLimitIntervalSec=600
StartLimitBurst=3

[Service]
Type=oneshot
WorkingDirectory=%h/.cache/hapax/source-activation/worktree
Environment=HOME=%h
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.cache/hapax/source-activation/worktree/scripts/ensure-darkplaces-live-texture-build.sh
ExecStartPost=/usr/bin/systemctl --user try-restart hapax-darkplaces-v4l2.service
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hapax-darkplaces-live-texture-rebuild
TimeoutStartSec=900
MemoryHigh=2G
MemoryMax=6G
