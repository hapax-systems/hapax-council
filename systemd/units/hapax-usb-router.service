[Unit]
Description=Hapax audio link-map bootstrap (MPC Live III baseline)
After=pipewire.service wireplumber.service
Requires=pipewire.service wireplumber.service
BindsTo=pipewire.service

[Service]
Type=oneshot
WorkingDirectory=%h/.cache/hapax/source-activation/worktree
Environment=PATH=%h/.cache/hapax/source-activation/worktree/.venv/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=PYTHONPATH=%h/.cache/hapax/source-activation/worktree
ExecStartPre=/bin/sleep 3
ExecStartPre=%h/.cache/hapax/source-activation/worktree/scripts/hapax-compositor-runtime-source-check --require-file scripts/usb-router.py
ExecStart=%h/.cache/hapax/source-activation/worktree/.venv/bin/python %h/.cache/hapax/source-activation/worktree/scripts/usb-router.py
RemainAfterExit=yes

[Install]
WantedBy=default.target
