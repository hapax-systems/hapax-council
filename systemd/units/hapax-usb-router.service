[Unit]
Description=Hapax audio link-map bootstrap (MPC Live III baseline)
After=pipewire.service wireplumber.service
Requires=pipewire.service wireplumber.service
BindsTo=pipewire.service

[Service]
Type=oneshot
ExecStartPre=/bin/sleep 3
ExecStart=/usr/bin/python3 %h/projects/hapax-council/scripts/usb-router.py
RemainAfterExit=yes

[Install]
WantedBy=default.target
