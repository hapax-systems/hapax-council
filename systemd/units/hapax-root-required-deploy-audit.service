[Unit]
Description=Audit deferred root-required post-merge deploy actions
Documentation=file:%h/.cache/hapax/source-activation/worktree/systemd/README.md
ConditionPathExists=%h/.cache/hapax/source-activation/worktree/scripts/hapax-root-required-deploy-audit
OnFailure=notify-failure@%n.service

[Service]
Type=oneshot
WorkingDirectory=%h/.cache/hapax/source-activation/worktree
Environment=PATH=%h/.cache/hapax/source-activation/worktree/.venv/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.cache/hapax/source-activation/worktree/scripts/hapax-root-required-deploy-audit
SyslogIdentifier=hapax-root-required-deploy-audit
