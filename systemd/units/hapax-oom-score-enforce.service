[Unit]
# Hapax-Install-Scope: system
Description=Apply live Hapax OOM scores that require root authority
Documentation=file:/home/hapax/.cache/hapax/source-activation/worktree/systemd/README.md
ConditionPathExists=/usr/local/sbin/hapax-oom-score-enforce
OnFailure=hapax-root-failure-intake@%n.service

[Service]
Type=oneshot
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/local/sbin/hapax-oom-score-enforce --apply
SyslogIdentifier=hapax-oom-score-enforce
