[Unit]
Description=Hapax USB topology witness and repair
After=pipewire.service wireplumber.service pipewire-pulse.service
Wants=pipewire.service wireplumber.service pipewire-pulse.service

[Service]
Type=oneshot
ExecStart=%h/.local/bin/hapax-usb-topology-witness --repair

[Install]
WantedBy=default.target
