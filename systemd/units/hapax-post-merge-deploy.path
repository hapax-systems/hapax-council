[Unit]
Description=Watch canonical main ref for post-merge deploy auto-invocation
Documentation=file://%h/projects/hapax-council/docs/superpowers/specs/2026-04-13-claude-md-excellence-design.md
# Companion to hapax-rebuild-services.timer (every 5 min) — that timer pulls
# Python service code; this path unit picks up the systemd-units / pipewire
# confs / scripts side that hapax-post-merge-deploy classifies. Together they
# close the gap that surfaced in the deploy-pipeline-canonical-worktree-isolation
# audit: 25 systemd units canonical-but-not-installed because nothing fired
# hapax-post-merge-deploy after merges.
#
# Watching strategy: PathChanged on the canonical local main ref. That ref is
# advanced EXPLICITLY by rebuild-service.sh, which `git update-ref
# refs/heads/main origin/main`s the SHARED ref after fast-forwarding its
# detached rebuild worktree (git worktrees share refs/heads/). The chain:
# timer fetches origin/main → rebuild-service.sh update-refs refs/heads/main →
# refs/heads/main changes → path unit fires → service resolves origin/main and
# runs hapax-post-merge-deploy.
#
# ROOT-CAUSE NOTE (reform-deploy-chain-repair, 2026-06-01): before that explicit
# update-ref, NOTHING advanced refs/heads/main — the canonical worktree sits on
# a feature branch and the rebuild worktree only resets a DETACHED HEAD. The ref
# was frozen tens of commits behind origin/main AND packed-only (no loose
# .git/refs/heads/main file existed at all), so PathChanged could never fire and
# the systemd-units / pipewire-confs / scripts side of every merge silently
# never installed. The update-ref restores both the loose ref file and a live
# trigger; the .service resolves origin/main so it is correct even if the ref lags.
#
# Loop-safety: hapax-post-merge-deploy writes deploy destinations under
# ~/.config/systemd/user/, ~/.config/pipewire/, ~/.config/wireplumber/,
# ~/.config/hapax/, ~/.local/bin/, ~/.local/lib/hapax-recovery/council/,
# ~/.local/lib/hapax/hooks/, ~/.cache/hapax/post-merge-traces/, and
# ~/.cache/hapax/deploy-symlink-drift/. When it delegates coord staging before
# restarting hapax-coord.service, hapax-coord-deploy also writes
# ~/.cache/hapax/coord-activation/ and fetches refs inside hapax-coord. It never
# writes the watched council .git ref, so a fire cannot trigger another fire.
# Belt-and-braces guard: hapax-post-merge-deploy.service carries
# StartLimitIntervalSec=60 / StartLimitBurst=3.
#
# Migration note: rebuild-service.sh runs council deploy checks from the
# dedicated rebuild worktree at $HOME/.cache/hapax/rebuild/worktree/ and, after
# resetting it to origin/main, update-refs the shared refs/heads/main so this
# path trigger fires. The watched ref remains the shared .git/refs/heads/main
# file because git worktrees share refs/heads/.

[Path]
PathChanged=/home/hapax/projects/hapax-council/.git/refs/heads/main
Unit=hapax-post-merge-deploy.service

[Install]
WantedBy=default.target
