[Unit]
Description=Hapax segment-prep emit-health heartbeat
After=hapax-segment-prep.service
OnFailure=notify-failure@%n.service

[Service]
Type=oneshot
WorkingDirectory=%h/.cache/hapax/source-activation/worktree
Environment=PATH=%h/.cache/hapax/source-activation/worktree/.venv/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=PYTHONPATH=%h/.cache/hapax/source-activation/worktree
ExecStartPre=%h/.cache/hapax/source-activation/worktree/scripts/hapax-compositor-runtime-source-check --require-file scripts/hapax-segment-prep-emit-health
ExecStart=%h/.cache/hapax/source-activation/worktree/scripts/hapax-segment-prep-emit-health
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hapax-segment-prep-emit-health
