[Unit]
Description=Hapax private→broadcast echo probe (Auditor D leak detector)
Documentation=https://github.com/ryanklee/hapax-council/blob/main/docs/runbooks/audio-incidents.md#private-leak-l12
After=pipewire.service hapax-secrets.service

[Service]
Type=oneshot
WorkingDirectory=%h/.cache/hapax/source-activation/worktree
Environment=PATH=%h/.cache/hapax/source-activation/worktree/.venv/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=PYTHONPATH=%h/.cache/hapax/source-activation/worktree
ExecStartPre=%h/.cache/hapax/source-activation/worktree/scripts/hapax-compositor-runtime-source-check --require-file scripts/private-broadcast-echo-probe.py
ExecStart=%h/.cache/hapax/source-activation/worktree/.venv/bin/python %h/.cache/hapax/source-activation/worktree/scripts/private-broadcast-echo-probe.py
TimeoutStartSec=30
SuccessExitStatus=0 2
Nice=10

[Install]
WantedBy=default.target
