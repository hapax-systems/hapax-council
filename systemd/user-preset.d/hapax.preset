# Hapax user unit preset.
#
# This file documents which repo-owned user timers and path-triggered units
# should be enabled by default when systemd preset tooling is used. The
# canonical install path is still systemd/units/ via
# systemd/scripts/install-units.sh; this preset pins audit-discovered V5 timers
# and governed intake triggers so they cannot sit outside deployment visibility.

enable hapax-orcid-verifier.timer
enable hapax-self-federate-rss.timer
enable hapax-datacite-snapshot.timer
enable hapax-datacite-mirror.timer
enable hapax-cc-hygiene.timer
enable hapax-cc-pr-autoqueue.timer
enable hapax-cc-pr-merge-watcher.timer
enable hapax-request-intake-consumer.timer
enable hapax-request-intake-consumer.path
enable hapax-request-decompose.timer
enable hapax-cc-task-offer-ready.timer
enable hapax-security-signal-intake.timer
enable hapax-source-activate.timer
enable hapax-darkplaces-live-texture-rebuild.path
enable hapax-screwm-gpu-drift-rebuild.path
enable hapax-content-candidate-discovery.timer
enable hapax-private-monitor-recover.timer
enable hapax-mail-monitor-fallback.timer
enable hapax-daimonion-quarantine-watchdog.timer
enable hapax-audio-topology-verify.timer
enable hapax-s4-arm.timer
enable hapax-visual-pool-snapshot-harvester.timer
enable hapax-segment-prep.timer
enable hapax-segment-prep-emit-health.timer
enable hapax-obsidian-publish-sync.timer
enable hapax-worktree-gc.timer
enable hapax-backup-watchdog.timer
enable hapax-container-cleanup.timer
enable hapax-dataset-card-generator.timer
enable hapax-l12-critical-usb-guard.timer
enable hapax-omg-lol-fanout.timer
enable hapax-ram-allocation-audit.timer
enable hapax-v4l2-watchdog.timer
enable hapax-velocity-digest.timer
enable hapax-velocity-report.timer
enable codex-claim-audit.timer
