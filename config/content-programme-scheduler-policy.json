  "cooldowns": {
    "format_cooldown_s": 3600,
    "source_cooldown_s": 1800,
    "subject_cluster_cooldown_s": 7200,
    "public_mode_cooldown_s": 3600,
    "refusal_cooldown_s": 900
  },
  "audit_refs": [
    "schemas/content-programme-scheduler-policy.schema.json",
    "schemas/content-opportunity-model.schema.json",
    "schemas/content-candidate-discovery-daemon.schema.json",
    "schemas/content-programme-run-store-event-surface.schema.json",
    "schemas/content-programme-feedback-ledger.schema.json",
    "schemas/format-wcs-requirement-matrix.schema.json",
    "schemas/programme-scrim-profile-policy.schema.json"
  ]
}
