      "autonomous_public_allowed_by_default": true,
      "monetization_allowed_by_default": false,
      "required_evidence": ["license_ref", "attribution_ref", "sharealike_or_noncommercial_constraint_ref"]
    },
    {
      "rights_class": "licensed",
      "meaning": "The source has an explicit license or permission grant whose allowed surfaces are machine-readable.",
