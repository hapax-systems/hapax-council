      "autonomous_public_allowed_by_default": true,
      "monetization_allowed_by_default": true,
      "required_evidence": ["public_domain_basis_ref", "source_url", "date_checked", "attribution_ref"]
    },
    {
      "rights_class": "cc_compatible",
      "meaning": "The source license is Creative Commons or otherwise compatible with the intended public use and attribution is captured.",
