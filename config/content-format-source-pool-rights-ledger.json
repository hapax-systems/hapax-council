      "autonomous_public_allowed_by_default": false,
      "monetization_allowed_by_default": false,
      "required_evidence": ["rights_research_required", "date_checked", "hold_reason_ref"]
    }
  ],
  "source_posture_definitions": [
    {
      "posture": "link_along",
      "meaning": "The programme may link, cite, or synchronize commentary with a source while keeping the source media outside Hapax output.",
      "allowed_public_modes": ["private", "dry_run", "public_archive"]
    },
    {
      "posture": "metadata_first",
      "meaning": "The programme may use titles, creators, dates, citations, thumbnails only when separately cleared, and platform metadata without rebroadcasting media.",
      "allowed_public_modes": ["private", "dry_run", "public_archive"]
    },
    {
      "posture": "owned_cleared",
      "meaning": "The programme may use owned, public-domain, CC-compatible, or explicitly licensed media inside declared public surfaces after privacy and egress gates pass.",
      "allowed_public_modes": ["private", "dry_run", "public_live", "public_archive", "public_monetizable"]
    },
    {
      "posture": "archive_only",
      "meaning": "The source may support VOD, replay, dataset, card, or artifact evidence but not live public claims by default.",
      "allowed_public_modes": ["private", "dry_run", "public_archive"]
    },
    {
      "posture": "refusal_artifact",
      "meaning": "The blocked source shape may be converted into a safe refusal, correction, or failure artifact without laundering the blocked media.",
