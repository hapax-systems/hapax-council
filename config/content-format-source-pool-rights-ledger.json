      "autonomous_public_allowed_by_default": true,
      "monetization_allowed_by_default": true,
      "required_evidence": ["operator_controlled_source_ref", "privacy_public_safe_ref", "provenance_ref"]
    },
    {
      "rights_class": "public_domain",
      "meaning": "The source has source-specific public-domain evidence and attribution/provenance captured.",
