      "autonomous_public_allowed_by_default": false,
      "monetization_allowed_by_default": false,
      "required_evidence": ["platform_terms_ref", "source_url", "metadata_only_ref"]
    },
    {
      "rights_class": "fair_use_candidate",
      "meaning": "The source might support a later human/legal fair-use theory, but the autonomous system treats it as private or link-along only.",
