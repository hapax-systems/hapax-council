# Hapax Torso S-4 composite USB policy.
#
# The S-4 enumerates as a Linux multifunction gadget:
# cdc_ether + zero-byte mass storage + 10-in/10-out USB audio + MIDI.
# Keep the audio device awake, stop desktop/network probing of the non-audio
# functions, and wake the topology witness after re-enumeration.

ACTION!="remove", SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="1d6b", ATTR{idProduct}=="0104", ATTR{serial}=="fedcba9876543220", ATTR{power/control}="on", ENV{ID_MM_DEVICE_IGNORE}="1", TAG+="systemd", ENV{SYSTEMD_USER_WANTS}+="hapax-usb-topology-witness.service"

ACTION!="remove", SUBSYSTEM=="block", ENV{ID_BUS}=="usb", ENV{ID_VENDOR_ID}=="1d6b", ENV{ID_MODEL_ID}=="0104", ENV{ID_SERIAL_SHORT}=="fedcba9876543220", ENV{UDISKS_IGNORE}="1", ENV{UDISKS_PRESENTATION_HIDE}="1", ENV{ID_MM_DEVICE_IGNORE}="1"

ACTION!="remove", SUBSYSTEM=="net", ENV{ID_BUS}=="usb", ENV{ID_VENDOR_ID}=="1d6b", ENV{ID_MODEL_ID}=="0104", ENV{ID_SERIAL_SHORT}=="fedcba9876543220", ENV{NM_UNMANAGED}="1", ENV{ID_MM_DEVICE_IGNORE}="1"

# L-12 add/change events are also route-repair triggers. The existing ZOOM
# power policy lives in config/udev/rules.d/50-hapax-usb-audio-video-noautosuspend.rules.
ACTION!="remove", SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="1686", ATTR{idProduct}=="03d5", ATTR{serial}=="8253FFFFFFFFFFFF9B5FFFFFFFFFFFFF", TAG+="systemd", ENV{SYSTEMD_USER_WANTS}+="hapax-usb-topology-witness.service", ENV{SYSTEMD_USER_WANTS}+="hapax-l12-hotplug-recover.service"
