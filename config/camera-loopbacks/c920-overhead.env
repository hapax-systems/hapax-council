HAPAX_CAMERA_LOOPBACK_HEIGHT=720
HAPAX_CAMERA_LOOPBACK_FPS=30
HAPAX_CAMERA_LOOPBACK_INPUT_FORMAT=mjpeg
HAPAX_CAMERA_LOOPBACK_OUTPUT_PIXEL_FORMAT=yuyv422
