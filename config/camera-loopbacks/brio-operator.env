HAPAX_CAMERA_LOOPBACK_ENABLED=1
HAPAX_CAMERA_LOOPBACK_ROLE=brio-operator
HAPAX_CAMERA_LOOPBACK_SOURCE=/dev/video60
HAPAX_CAMERA_LOOPBACK_DEVICE=/dev/video70
