HAPAX_QUAKE_CAMERA_ROLE=brio-synths
HAPAX_QUAKE_CAMERA_DEVICE=/dev/v4l/by-id/usb-046d_Logitech_BRIO_9726C031-video-index0
HAPAX_QUAKE_CAMERA_FORMAT=mjpeg
HAPAX_QUAKE_CAMERA_SIZE=1280x720
HAPAX_QUAKE_CAMERA_FPS=10
# Local BRIO RGB and index2 IR cannot be streamed concurrently on this hardware.
# Keep this texture fresh and explicit while the CBIP IR ward owns the device.
HAPAX_QUAKE_CAMERA_RESERVED_FOR_IR=1
HAPAX_QUAKE_LIVE_TEXTURE_NAME=cam_bsy
HAPAX_QUAKE_LIVE_TEXTURE_OUTPUT=/dev/shm/hapax-compositor/quake-live-cam-brio-synths.bgra
HAPAX_QUAKE_LIVE_TEXTURE_META=/dev/shm/hapax-compositor/quake-live-cam-brio-synths.json
HAPAX_QUAKE_LIVE_TEXTURE_WIDTH=1280
HAPAX_QUAKE_LIVE_TEXTURE_HEIGHT=720
HAPAX_QUAKE_LIVE_TEXTURE_FPS=5

HAPAX_QUAKE_LIVE_TEXTURE_INPUT_FPS=10
