HAPAX_QUAKE_CAMERA_ROLE=brio-synths-ir
HAPAX_QUAKE_CAMERA_DEVICE=/dev/v4l/by-id/usb-046d_Logitech_BRIO_9726C031-video-index2
HAPAX_QUAKE_CAMERA_FORMAT=gray
HAPAX_QUAKE_CAMERA_SIZE=340x340
HAPAX_QUAKE_CAMERA_FPS=10
HAPAX_QUAKE_CAMERA_VISIBILITY_PROFILE=brio-ir-low-light
# 9726C031 index2 currently enumerates as GREY 340x340 but can wedge the whole
# UVC device during STREAMON/read. Keep that IR endpoint as the configured
# camera, but force the already-running c920-desk synths-area raw feed as a
# truthful live substitute until the BRIO IR endpoint/topology is repaired.
HAPAX_QUAKE_CAMERA_SUBSTITUTE_MODE=always
HAPAX_QUAKE_CAMERA_SUBSTITUTE_RAW_PATH=/dev/shm/hapax-compositor/quake-live-cam-c920-desk.raw.bgra
HAPAX_QUAKE_CAMERA_SUBSTITUTE_RAW_META=/dev/shm/hapax-compositor/quake-live-cam-c920-desk.raw.json
HAPAX_QUAKE_CAMERA_SUBSTITUTE_RAW_SIZE=1280x720
HAPAX_QUAKE_CAMERA_SUBSTITUTE_RAW_ROLE=c920-desk
HAPAX_QUAKE_CAMERA_SUBSTITUTE_RAW_MAX_AGE_S=8.0
HAPAX_QUAKE_CAMERA_SUBSTITUTE_REASON=ir_endpoint_unavailable:c920_desk_rgb_substitute
HAPAX_QUAKE_LIVE_TEXTURE_NAME=ir_bsy
HAPAX_QUAKE_LIVE_TEXTURE_OUTPUT=/dev/shm/hapax-compositor/quake-live-ir-brio-synths.bgra
HAPAX_QUAKE_LIVE_TEXTURE_META=/dev/shm/hapax-compositor/quake-live-ir-brio-synths.json
HAPAX_QUAKE_LIVE_TEXTURE_WIDTH=340
HAPAX_QUAKE_LIVE_TEXTURE_HEIGHT=340
HAPAX_QUAKE_LIVE_TEXTURE_FPS=6

HAPAX_QUAKE_LIVE_TEXTURE_INPUT_FPS=10
