HAPAX_QUAKE_CAMERA_ROLE=brio-operator
HAPAX_QUAKE_CAMERA_DEVICE=/dev/v4l/by-id/usb-046d_Logitech_BRIO_5342C819-video-index0
HAPAX_QUAKE_CAMERA_FORMAT=mjpeg
HAPAX_QUAKE_CAMERA_SIZE=1280x720
HAPAX_QUAKE_CAMERA_FPS=10
# Local BRIO RGB and index2 IR cannot be streamed concurrently on this hardware.
# Keep the large camera instrument live by proxying the matching BRIO IR feed.
HAPAX_QUAKE_CAMERA_RESERVED_FOR_IR=0
HAPAX_QUAKE_CAMERA_RESERVED_IR_PROXY_MAX_AGE_S=8.0
HAPAX_QUAKE_LIVE_TEXTURE_NAME=cam_bop
HAPAX_QUAKE_LIVE_TEXTURE_OUTPUT=/dev/shm/hapax-compositor/quake-live-cam-brio-operator.bgra
HAPAX_QUAKE_LIVE_TEXTURE_META=/dev/shm/hapax-compositor/quake-live-cam-brio-operator.json
HAPAX_QUAKE_LIVE_TEXTURE_WIDTH=1280
HAPAX_QUAKE_LIVE_TEXTURE_HEIGHT=720
HAPAX_QUAKE_LIVE_TEXTURE_FPS=5

HAPAX_QUAKE_LIVE_TEXTURE_INPUT_FPS=10
