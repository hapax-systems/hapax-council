# Managed by the Hapax P0 OOM containment package.
Cmnd_Alias HAPAX_OOM_SCORE_ENFORCE = \
    /usr/local/sbin/hapax-oom-score-enforce --apply-unit pipewire.service, \
    /usr/local/sbin/hapax-oom-score-enforce --apply-unit pipewire-pulse.service, \
    /usr/local/sbin/hapax-oom-score-enforce --apply-unit wireplumber.service, \
    /usr/local/sbin/hapax-oom-score-enforce --apply-unit hapax-daimonion.service, \
    /usr/local/sbin/hapax-oom-score-enforce --apply-unit studio-compositor.service, \
    /usr/local/sbin/hapax-oom-score-enforce --apply-unit hapax-imagination.service

hapax ALL=(root) NOPASSWD: HAPAX_OOM_SCORE_ENFORCE
