#!/bin/sh
if [ "${HAPAX_APCUPSD_TEST_MODE:-0}" = "1" ]; then
    HELPER="${HAPAX_APCUPSD_HELPER:-/etc/apcupsd/hapax-power-event.py}"
    TIMEOUT="${HAPAX_APCUPSD_TIMEOUT:-/usr/bin/timeout}"
else
    HELPER="/etc/apcupsd/hapax-power-event.py"
    TIMEOUT="/usr/bin/timeout"
fi

# Provenance must never suppress or indefinitely delay apccontrol's shutdown.
"$TIMEOUT" --signal=KILL 3s "$HELPER" doshutdown "$@" || :
exit 0
