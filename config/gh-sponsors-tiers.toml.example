schema_version = 1

[profile]
account = "hapax-systems"
legal_name = "Hapax Systems"
display_name = "Hapax Systems"
description = """
Public research infrastructure for single-operator AI governance,
refusal-as-data, and multimodal operating environments. Sponsorships support
compute, archive storage, rights-safe production, and publication plumbing.
No access, requests, private advice, priority, shoutouts, guarantees, client
service, deliverables, or control are sold. Work continues regardless of
support.
"""
profile_url_pass_key = "github-sponsors/profile-url"
tier_id_pass_key_prefix = "github-sponsors/tiers"

[[tiers]]
slug = "one-dollar"
kind = "monthly"
amount_usd_cents = 100
title = "Research support"
description = "Monthly support for public Hapax research infrastructure. No perks, access, requests, priority, deliverables, or control."
sponsorware_threshold = ""

[[tiers]]
slug = "five-dollar"
kind = "monthly"
amount_usd_cents = 500
title = "Research support"
description = "Monthly support for public Hapax research infrastructure. No perks, access, requests, priority, deliverables, or control."
sponsorware_threshold = ""

[[tiers]]
slug = "ten-dollar"
kind = "monthly"
amount_usd_cents = 1000
title = "Research support"
description = "Monthly support for public Hapax research infrastructure. No perks, access, requests, priority, deliverables, or control."
sponsorware_threshold = ""

[[tiers]]
slug = "twenty-five-dollar"
kind = "monthly"
amount_usd_cents = 2500
title = "Research support"
description = "Monthly support for public Hapax research infrastructure. No perks, access, requests, priority, deliverables, or control."
sponsorware_threshold = ""
