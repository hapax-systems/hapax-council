schema_version = 1

[profile]
account = "hapax-llc"
legal_name = "Hapax LLC"
display_name = "Hapax · Claude Code · Oudepode"
description = """
Operator-authored research infrastructure, public refusal artifacts, and
sponsorware-rotated field notes. Tier copy stays descriptive: no guarantees,
no delivery promises, and no private-supporter identity publication.
"""
profile_url_pass_key = "github-sponsors/profile-url"
tier_id_pass_key_prefix = "github-sponsors/tiers"

[[tiers]]
slug = "supporter"
kind = "monthly"
amount_usd_cents = 500
title = "Supporter"
description = "Monthly support for public Hapax research infrastructure."
sponsorware_threshold = "public-feed acknowledgement only; no gated promise"

[[tiers]]
slug = "studio"
kind = "monthly"
amount_usd_cents = 2500
title = "Studio"
description = "Monthly support for research-vehicle surfaces and field-note maintenance."
sponsorware_threshold = "rotating early-access artifact eligibility when operator-published"

[[tiers]]
slug = "lab"
kind = "monthly"
amount_usd_cents = 10000
title = "Lab"
description = "Monthly support for archival, citation-graph, and infrastructure costs."
sponsorware_threshold = "rotating sponsorware artifacts; no guaranteed cadence"

[[tiers]]
slug = "patron"
kind = "monthly"
amount_usd_cents = 50000
title = "Patron"
description = "High-signal monthly backing for public research operations."
sponsorware_threshold = "same artifact eligibility as Lab; no extra private influence"

[[tiers]]
slug = "one-time-field-note"
kind = "one_time"
amount_usd_cents = 2500
title = "One-time field note"
description = "One-time support for a public field-note or refusal-artifact cycle."
sponsorware_threshold = "one-time acknowledgement only"
