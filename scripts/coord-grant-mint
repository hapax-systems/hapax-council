#!/usr/bin/env python3
"""coord-grant-mint — write a signed, scoped, daemon-independent escape grant.

Reform Phase 4 (NEW-2 / INV-4). The operator — or, deliberately, a blocked lane —
mints a scoped ``EscapeGrant`` that the irreversible-harm shims read directly off
disk (a pure file read, never an RPC to a wedgeable kernel). The grant is signed
(HMAC), scoped to ONE gate (or ``*``), time-boxed, and ledgered when honored.

This is the sanctioned replacement for the deprecated, silent, unconditional
``HAPAX_*_OFF`` off-switch: escape becomes an authorized, scoped, recorded act
that works even with the coordination daemon down.

Usage:
    coord-grant-mint --scope cc-task-gate --reason "stale-worktree deadlock"
    coord-grant-mint --scope '*' --reason "kernel down" --ttl 1800

Paths (env-overridable; defaults match hooks/scripts/escape-grant.sh):
    grants   $HAPAX_COORD_GRANT_DIR   (~/.cache/hapax/coord/grants)
    key      $HAPAX_COORD_GRANT_KEY   (~/.cache/hapax/coord/grant-key)

The signing key is auto-created (32 random bytes, mode 0600) on first mint and
reused thereafter. Prints the absolute path of the grant file it wrote.
"""

from __future__ import annotations

import argparse
import sys
import time
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from shared.coord_event_log import default_grant_dir, default_grant_key  # noqa: E402
from shared.governance.coord_capabilities import (  # noqa: E402
    load_or_create_key,
    mint_escape_grant,
    write_grant_file,
)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog="coord-grant-mint", description="Mint a signed daemon-independent escape grant."
    )
    parser.add_argument(
        "--scope", required=True, help="gate the grant covers (e.g. cc-task-gate), or '*' for all"
    )
    parser.add_argument("--reason", default="", help="incident reason, recorded in the grant")
    parser.add_argument("--grantor", default="operator", help="who authorized the escape")
    parser.add_argument(
        "--ttl", type=float, default=3600.0, help="seconds until the grant expires (default 1h)"
    )
    parser.add_argument("--grant-dir", default=None, help="override the grant directory")
    parser.add_argument("--key-file", default=None, help="override the signing key path")
    args = parser.parse_args(argv)

    grant_dir = Path(args.grant_dir) if args.grant_dir else default_grant_dir()
    key_path = Path(args.key_file) if args.key_file else default_grant_key()
    grant_dir.mkdir(parents=True, exist_ok=True)
    key = load_or_create_key(key_path)

    grant = mint_escape_grant(
        grantor=args.grantor,
        scope=args.scope,
        reason=args.reason,
        ttl_s=args.ttl,
        key=key,
        now=time.time(),
    )
    out = grant_dir / f"{grant.grant_id}.grant"
    write_grant_file(grant, out)
    print(str(out))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
