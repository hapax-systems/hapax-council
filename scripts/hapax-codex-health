#!/usr/bin/env python3
"""Report live Hapax Codex lane health."""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import time
from datetime import datetime
from pathlib import Path
from typing import Any

DEFAULT_SESSIONS = (
    "cx-red",
    "cx-green",
    "cx-amber",
    "cx-blue",
    "cx-cyan",
    "cx-gold",
    "cx-teal",
    "cx-rose",
    "cx-violet",
)
DEFAULT_OBSIDIAN_PATH = (
    Path.home()
    / "Documents"
    / "Personal"
    / "20-projects"
    / "hapax-cc-tasks"
    / "_dashboard"
    / "codex-session-health.md"
)
ROLE_SUMMARY = {
    "cx-red": "parent/integrator, CI and merge authority",
    "cx-green": "coordination glue, lane health and refill candidates",
    "cx-violet": "protected research/design/spec backlog lane",
    "cx-amber": "production worker lane",
    "cx-blue": "production worker lane",
    "cx-cyan": "production worker lane",
    "cx-gold": "production worker lane",
    "cx-teal": "production worker lane",
    "cx-rose": "production worker lane",
}
SCREEN_REQUIRED = {"cx-red", "cx-violet"}


def _run(args: list[str]) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(args, capture_output=True, text=True, check=False)
    except FileNotFoundError as exc:
        return subprocess.CompletedProcess(args=args, returncode=127, stdout="", stderr=str(exc))


def _tmux_control_plane_targets(session: str) -> tuple[str, ...]:
    targets = [f"hapax-codex-{session}"]
    if session == "agy" or session.startswith("agy-"):
        targets.append(f"hapax-agy-{session}")
    return tuple(dict.fromkeys(targets))


def _tmux_control_plane(session: str) -> str | None:
    for target in _tmux_control_plane_targets(session):
        if _run(["tmux", "has-session", "-t", target]).returncode == 0:
            return target
    return None


def _tmux_exists(session: str) -> bool:
    return _tmux_control_plane(session) is not None


def _desktop_labels() -> tuple[str, ...]:
    labels: list[str] = []
    for key in ("XDG_CURRENT_DESKTOP", "DESKTOP_SESSION", "KDE_FULL_SESSION"):
        value = os.environ.get(key)
        if not value:
            continue
        labels.extend(part for part in re.split(r"[:;,]", value) if part)
    return tuple(dict.fromkeys(label.strip() for label in labels if label.strip()))


def _desktop_observation_note(mode: str) -> str:
    if mode == "kde_no_window_observer":
        return (
            "KDE/no-window-observer: hyprctl is absent; visible terminal windows are "
            "not observed, and health relies on tmux, relay YAML, and claim files."
        )
    if mode == "no_window_observer":
        return (
            "No window observer is available; visible terminal windows are not observed, "
            "and health relies on tmux, relay YAML, and claim files."
        )
    if mode == "hyprland_window_observer":
        return "Hyprland window observation is available through hyprctl clients."
    return "Window observer command exists but did not return usable Hyprland client data."


def _window_observation() -> tuple[list[dict[str, Any]], dict[str, Any]]:
    desktop_labels = _desktop_labels()
    is_kde = any("kde" in label.lower() or "plasma" in label.lower() for label in desktop_labels)
    hyprctl_path = shutil.which("hyprctl")
    if hyprctl_path is None:
        mode = "kde_no_window_observer" if is_kde else "no_window_observer"
        return [], {
            "mode": mode,
            "desktop": list(desktop_labels) or ["unknown"],
            "window_observer": "none",
            "hyprctl_available": False,
            "visible_windows_observed": False,
            "note": _desktop_observation_note(mode),
        }

    result = _run(["hyprctl", "clients", "-j"])
    if result.returncode != 0:
        mode = "hyprland_window_observer_error"
        return [], {
            "mode": mode,
            "desktop": list(desktop_labels) or ["unknown"],
            "window_observer": "hyprctl",
            "hyprctl_available": True,
            "visible_windows_observed": False,
            "note": _desktop_observation_note(mode),
            "error": result.stderr.strip() or result.stdout.strip(),
        }
    try:
        data = json.loads(result.stdout)
    except json.JSONDecodeError:
        mode = "hyprland_window_observer_invalid_json"
        return [], {
            "mode": mode,
            "desktop": list(desktop_labels) or ["unknown"],
            "window_observer": "hyprctl",
            "hyprctl_available": True,
            "visible_windows_observed": False,
            "note": _desktop_observation_note(mode),
        }
    clients = data if isinstance(data, list) else []
    return clients, {
        "mode": "hyprland_window_observer",
        "desktop": list(desktop_labels) or ["unknown"],
        "window_observer": "hyprctl",
        "hyprctl_available": True,
        "visible_windows_observed": True,
        "client_count": len(clients),
        "note": _desktop_observation_note("hyprland_window_observer"),
    }


def _relay_summary(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {"exists": False}
    text = path.read_text(encoding="utf-8", errors="replace")
    age_s = max(0.0, time.time() - path.stat().st_mtime)
    return {
        "exists": True,
        "age_s": round(age_s, 3),
        "status": _yaml_scalar(text, "status"),
        "task_id": _yaml_scalar(text, "task_id"),
        "current_claim": _yaml_scalar(text, "current_claim"),
        "current_pr": _yaml_scalar(text, "current_pr"),
        "branch": _yaml_scalar(text, "current_branch")
        or _yaml_scalar(text, "branch")
        or _nested_yaml_scalar(text, "worktree", "branch"),
        "why": _first_relay_note(text),
    }


def _yaml_scalar(text: str, key: str) -> str | None:
    match = re.search(rf"^{re.escape(key)}:\s*(.*)$", text, flags=re.MULTILINE)
    if not match:
        return None
    value = match.group(1).strip().strip("'\"")
    if value in {"", "null", "None"}:
        return None
    return value


def _nested_yaml_scalar(text: str, parent: str, key: str) -> str | None:
    parent_match = re.search(
        rf"^{re.escape(parent)}:\s*$((?:\n[ \t]+[^\n]*)*)",
        text,
        flags=re.MULTILINE,
    )
    if not parent_match:
        return None
    block = parent_match.group(1)
    match = re.search(rf"^[ \t]+{re.escape(key)}:\s*(.*)$", block, flags=re.MULTILINE)
    if not match:
        return None
    value = match.group(1).strip().strip("'\"")
    if value in {"", "null", "None"}:
        return None
    return value


def _first_relay_note(text: str) -> str | None:
    for key in ("why_current_status", "goal", "summary", "mode", "status"):
        value = _yaml_scalar(text, key)
        if value:
            return value

    notes_match = re.search(r"^notes:\s*$((?:\n[ \t]+[^\n]*)*)", text, flags=re.MULTILINE)
    if notes_match:
        match = re.search(
            r"^[ \t]+-\s*\"?([^\"\n].{12,})\"?\s*$", notes_match.group(1), flags=re.MULTILINE
        )
        if match:
            return match.group(1).strip().strip("'\"")
    return None


def _task_index(active_root: Path) -> dict[str, dict[str, str | None]]:
    tasks: dict[str, dict[str, str | None]] = {}
    if not active_root.exists():
        return tasks
    for path in active_root.glob("*.md"):
        text = path.read_text(encoding="utf-8", errors="replace")
        task_id = _yaml_scalar(text, "task_id")
        if not task_id:
            continue
        tasks[task_id] = {
            "path": str(path),
            "title": _yaml_scalar(text, "title"),
            "status": _yaml_scalar(text, "status"),
            "assigned_to": _yaml_scalar(text, "assigned_to"),
            "priority": _yaml_scalar(text, "priority"),
            "wsjf": _yaml_scalar(text, "wsjf"),
        }
    return tasks


def _protected_sessions(relay_dir: Path) -> set[str]:
    path = relay_dir / "session-protection.md"
    if not path.exists():
        return set()
    text = path.read_text(encoding="utf-8", errors="replace")
    return set(re.findall(r"\bcx-[a-z][a-z0-9-]*\b", text))


def collect(sessions: list[str]) -> dict[str, Any]:
    home = Path.home()
    cache = Path(os.environ.get("XDG_CACHE_HOME", home / ".cache"))
    relay_dir = cache / "hapax" / "relay"
    active_root = home / "Documents" / "Personal" / "20-projects" / "hapax-cc-tasks" / "active"
    tasks = _task_index(active_root)
    clients, desktop_observation = _window_observation()
    visible_windows_observed = bool(desktop_observation.get("visible_windows_observed"))
    protected = _protected_sessions(relay_dir)
    lanes: list[dict[str, Any]] = []
    for session in sessions:
        foot_matches = [item for item in clients if item.get("class") == f"hapax-codex-{session}"]
        tmux_control_plane = _tmux_control_plane(session)
        tmux = tmux_control_plane is not None
        claim_file = cache / "hapax" / f"cc-active-task-{session}"
        claim = claim_file.read_text(encoding="utf-8").strip() if claim_file.exists() else None
        relay = _relay_summary(relay_dir / f"{session}.yaml")
        task_id = claim or relay.get("current_claim") or relay.get("task_id")
        task = tasks.get(str(task_id), {}) if task_id else {}
        warnings: list[str] = []
        if foot_matches and not tmux:
            warnings.append("legacy_direct_foot_no_tmux_control_plane")
        if tmux and not foot_matches and session in SCREEN_REQUIRED and visible_windows_observed:
            warnings.append("screen_required_but_not_visible")
        if (
            tmux
            and not foot_matches
            and session in SCREEN_REQUIRED
            and not visible_windows_observed
        ):
            warnings.append("screen_required_visibility_not_observed")
        if not tmux and session not in SCREEN_REQUIRED and claim:
            warnings.append("worker_claim_without_tmux_control_plane")
        if claim and not relay.get("current_claim"):
            warnings.append("claim_file_without_relay_current_claim")
        if claim and relay.get("current_claim") and claim != relay.get("current_claim"):
            warnings.append("claim_file_relay_current_claim_mismatch")
        if claim and relay.get("task_id") and claim != relay.get("task_id"):
            warnings.append("claim_file_relay_task_id_mismatch")
        if session in protected:
            warnings.append("protected_do_not_relaunch_or_kill")
        lanes.append(
            {
                "session": session,
                "tmux": tmux,
                "tmux_control_plane": tmux_control_plane,
                "tmux_control_plane_targets": list(_tmux_control_plane_targets(session)),
                "foot_visible": bool(foot_matches),
                "foot_count": len(foot_matches),
                "foot_titles": [str(item.get("title") or "") for item in foot_matches],
                "active_claim": claim,
                "task_id": task_id,
                "task": task,
                "relay": relay,
                "role": ROLE_SUMMARY.get(session, "Codex lane"),
                "screen_required": session in SCREEN_REQUIRED,
                "protected": session in protected,
                "warnings": warnings,
            }
        )
    return {
        "checked_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "desktop_observation": desktop_observation,
        "observability": (
            "Obsidian dashboard plus relay/claim files; worker screen visibility is "
            f"optional. Desktop observation mode: {desktop_observation['mode']}."
        ),
        "lanes": lanes,
    }


def _cell(value: object) -> str:
    text = "-" if value is None or value == "" else str(value)
    return text.replace("|", "\\|").replace("\n", " ")


def render_obsidian(report: dict[str, Any]) -> str:
    checked = str(report["checked_at"])
    local = datetime.now().astimezone().isoformat(timespec="seconds")
    lines = [
        "---",
        "type: codex-session-health",
        "title: Codex session health",
        f"updated_at: {checked}",
        "tags: [codex, coordination, dashboard]",
        "---",
        "",
        "# Codex session health",
        "",
        f"Last generated: `{checked}` UTC / `{local}` local.",
        "",
        "Desktop observation: "
        f"`{report['desktop_observation']['mode']}` — {report['desktop_observation']['note']}",
        "",
        "Operator visibility contract: `cx-red` and `cx-violet` remain screen-visible. Worker lanes may run headless in tmux when this note, cc-task claims, relay YAML, and PR state stay current.",
        "",
        "| Session | Role | Control | Screen | Task | Task status | Branch | PR | Why / current status | Warnings |",
        "|---|---|---|---|---|---|---|---|---|---|",
    ]
    for lane in report["lanes"]:
        relay = lane["relay"]
        task = lane.get("task") or {}
        control = "tmux" if lane["tmux"] else "legacy-foot" if lane["foot_visible"] else "none"
        if lane["foot_visible"]:
            screen = "visible"
        elif lane["session"] == "cx-red":
            screen = "parent terminal"
        elif lane["screen_required"]:
            screen = "required-missing"
        else:
            screen = "not required"
        task_label = lane.get("task_id") or "-"
        title = task.get("title")
        if title:
            task_label = f"{task_label} — {title}"
        status = task.get("status") or (
            "claimed" if lane.get("active_claim") else relay.get("status")
        )
        why = relay.get("why") or relay.get("status") or "-"
        warnings = ", ".join(lane["warnings"]) if lane["warnings"] else "-"
        lines.append(
            "| "
            + " | ".join(
                [
                    _cell(lane["session"]),
                    _cell(lane["role"]),
                    _cell(control),
                    _cell(screen),
                    _cell(task_label),
                    _cell(status),
                    _cell(relay.get("branch")),
                    _cell(relay.get("current_pr")),
                    _cell(why),
                    _cell(warnings),
                ]
            )
            + " |"
        )
    lines.extend(
        [
            "",
            "## Sources",
            "",
            "- Active claims: `~/.cache/hapax/cc-active-task-cx-*`",
            "- Relays: `~/.cache/hapax/relay/*.yaml`",
            "- Tasks: `~/Documents/Personal/20-projects/hapax-cc-tasks/active/`",
            "- Regenerate: `scripts/hapax-codex-health --write-obsidian`",
            "",
        ]
    )
    return "\n".join(lines)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--json", action="store_true", help="emit JSON")
    parser.add_argument(
        "--write-obsidian",
        nargs="?",
        const=str(DEFAULT_OBSIDIAN_PATH),
        help="write the operator-facing Obsidian dashboard, optionally to PATH",
    )
    parser.add_argument("sessions", nargs="*", default=list(DEFAULT_SESSIONS))
    args = parser.parse_args()
    report = collect(args.sessions)
    if args.write_obsidian:
        path = Path(args.write_obsidian).expanduser()
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(render_obsidian(report), encoding="utf-8")
        print(path)
        return 0
    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        desktop = report["desktop_observation"]
        print(f"desktop_observation={desktop['mode']} note={desktop['note']}")
        for lane in report["lanes"]:
            warn = ",".join(lane["warnings"]) if lane["warnings"] else "-"
            print(
                f"{lane['session']}: tmux={lane['tmux']} foot={lane['foot_visible']} "
                f"claim={lane['active_claim'] or '-'} relay={lane['relay'].get('status') or '-'} "
                f"warnings={warn}"
            )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
