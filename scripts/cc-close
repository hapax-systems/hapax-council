#!/usr/bin/env bash
# cc-close <task_id> [--pr N] [--status done|withdrawn|superseded]
#
# Close out a vault cc-task: rewrite frontmatter (status: done by
# default; completed_at: now), move the note from active/ to closed/,
# and clear the session's claim file.
#
# Active blocked-with-evidence work is not a cc-close outcome. Keep the note in
# active/ with status: blocked, blocked_reason: <machine-code>, and
# blocked_witness: <current-witness-path>; cc-claim/cascade preserve that state.
#
# Symlink to ~/.local/bin/cc-close for quick access:
#   ln -sf ~/projects/hapax-council/scripts/cc-close ~/.local/bin/cc-close

set -euo pipefail

if [[ "$#" -eq 1 && "$1" == "--dispatch-protocol-version" ]]; then
  printf '%s\n' 'hapax-close-dispatch-v1'
  exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROLE_HELPER="$SCRIPT_DIR/../hooks/scripts/agent-role.sh"
if [[ -f "$ROLE_HELPER" ]]; then
  # shellcheck source=../hooks/scripts/agent-role.sh
  . "$ROLE_HELPER"
fi

if [[ $# -lt 1 ]]; then
  echo "usage: cc-close <task_id> [--pr N] [--status done|withdrawn|superseded]" >&2
  echo "       active blocked evidence stays in active/: status=blocked, blocked_reason, blocked_witness" >&2
  exit 1
fi

task_id="$1"; shift
pr=""
final_status="done"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --pr) pr="$2"; shift 2 ;;
    --status) final_status="$2"; shift 2 ;;
    --debt) debt_reason="$2"; shift 2 ;;
    --retroactive) retroactive=1; shift ;;
    *) echo "cc-close: unknown arg '$1'" >&2; exit 1 ;;
  esac
done

case "$final_status" in
  done|withdrawn|superseded) ;;
  *) echo "cc-close: --status must be done, withdrawn, or superseded (got '$final_status')" >&2; exit 1 ;;
esac

role="${HAPAX_AGENT_NAME:-${CODEX_THREAD_NAME:-${CODEX_SESSION_NAME:-${CODEX_SESSION:-${CODEX_ROLE:-${HAPAX_AGENT_ROLE:-${CLAUDE_ROLE:-}}}}}}}"
if [[ -z "$role" ]] && declare -F hapax_agent_identity >/dev/null 2>&1; then
  role="$(hapax_agent_identity 2>/dev/null || true)"
fi
if [[ -z "$role" ]]; then
  echo "cc-close: cannot determine caller identity; refusing task mutation" >&2
  exit 3
fi
platform="${HAPAX_AGENT_INTERFACE:-}"
case "$platform" in
  claude|codex|vibe) ;;
  *)
    if [[ -n "${CODEX_THREAD_NAME:-${CODEX_SESSION_NAME:-${CODEX_SESSION:-${CODEX_ROLE:-}}}}" || "$role" == cx-* ]]; then
      platform="codex"
    elif [[ "$role" == vbe-* ]]; then
      platform="vibe"
    elif [[ "$role" == alpha || "$role" == beta || "$role" == gamma || "$role" == delta || "$role" == epsilon || "$role" == zeta || "$role" == eta || "$role" == theta || "$role" == cc-* ]]; then
      platform="claude"
    elif [[ -n "${CLAUDE_ROLE:-${CLAUDECODE:-}}" ]]; then
      platform="claude"
    else
      platform=""
    fi
    ;;
esac
session_id=""
if declare -F hapax_session_id >/dev/null 2>&1; then
  session_id="$(hapax_session_id 2>/dev/null || true)"
fi
if [[ -n "$session_id" ]] && declare -F hapax_claim_keyable_session_id >/dev/null 2>&1 \
  && ! hapax_claim_keyable_session_id "$session_id"; then
  echo "cc-close: session id '$session_id' is not claim-keyable; refusing legacy-role downgrade" >&2
  exit 3
fi

command -v flock >/dev/null 2>&1 || {
  echo "cc-close: flock missing; refusing non-atomic close" >&2
  exit 3
}
mkdir -p "$HOME/.cache/hapax"
role_lock_key="$(printf '%s' "${role:-roleless}" | sha256sum | cut -d' ' -f1)"
task_lock_key="$(printf '%s' "$task_id" | sha256sum | cut -d' ' -f1)"
exec 8>"$HOME/.cache/hapax/cc-claim-role-lock-$role_lock_key"
flock -x 8
exec 9>"$HOME/.cache/hapax/cc-claim-task-lock-$task_lock_key"
flock -x 9

if ! command -v python3 &>/dev/null; then
  echo "cc-close: python3 missing; cannot rewrite frontmatter" >&2
  exit 3
fi

vault_root="$HOME/Documents/Personal/20-projects/hapax-cc-tasks"
transaction_journal="$HOME/.cache/hapax/cc-ownership-txn.json"
python3 - "$SCRIPT_DIR/.." "$transaction_journal" "$HOME/.cache/hapax" "$vault_root" <<'PYEOF'
import sys
from pathlib import Path

sys.path.insert(0, sys.argv[1])
from shared.sdlc_filesystem_transaction import (
    FilesystemTransactionError,
    recover_filesystem_transaction,
)

stable_journal = Path(sys.argv[2])
cache_dir = Path(sys.argv[3])
vault_root = Path(sys.argv[4])
legacy_journals = set(cache_dir.glob("cc-ownership-txn-*.json"))
for intent in cache_dir.glob(".cc-ownership-txn-*.json.intent"):
    legacy_journals.add(cache_dir / intent.name[1 : -len(".intent")])

try:
    for journal in sorted(legacy_journals):
        if journal != stable_journal:
            recover_filesystem_transaction(
                journal,
                allowed_roots=(cache_dir, vault_root),
            )
    recover_filesystem_transaction(
        stable_journal,
        allowed_roots=(cache_dir, vault_root),
    )
except FilesystemTransactionError as exc:
    print(f"cc-close: ownership transaction recovery failed: {exc}", file=sys.stderr)
    raise SystemExit(9)
PYEOF
if ! note_path="$(python3 - "$SCRIPT_DIR/.." "$vault_root" "$task_id" "$role" "$platform" "$session_id" "$HOME/.cache/hapax" <<'PYEOF'
import sys
from pathlib import Path

sys.path.insert(0, sys.argv[1])
from shared.sdlc_task_store import (
    TaskStoreError,
    assert_close_slot_owned,
    resolve_task_note,
)
from shared.sdlc_owner_identity import owner_matches

try:
    snapshot = resolve_task_note(Path(sys.argv[2]), sys.argv[3], state="active")
    owner = str(snapshot.frontmatter.get("assigned_to") or "").strip()
    if not owner_matches(owner, sys.argv[4], sys.argv[5] or None):
        raise TaskStoreError(
            "close_task_owner_mismatch",
            "only the exact assigned role/platform may close this task",
            f"assigned_to={owner or '<null>'} caller={sys.argv[5] or 'unknown'}/{sys.argv[4]}",
        )
    assert_close_slot_owned(
        cache_dir=Path(sys.argv[7]),
        role=sys.argv[4],
        session_id=sys.argv[6],
        task_id=sys.argv[3],
    )
    print(snapshot.path)
except TaskStoreError as exc:
    print(f"cc-close: {exc}", file=sys.stderr)
    raise SystemExit(2)
PYEOF
)"; then
  echo "cc-close: task '$task_id' not in $vault_root/active/ (already closed?)" >&2
  exit 2
fi
note_sha256="$(sha256sum "$note_path" | cut -d' ' -f1)"

frontmatter_task_id() {
  local file="$1"
  python3 - "$file" <<'PYEOF'
import re
import sys
from pathlib import Path

text = Path(sys.argv[1]).read_text(encoding="utf-8")
frontmatter = ""
if text.startswith("---"):
    end = text.find("\n---", 3)
    if end != -1:
        frontmatter = text[3:end]

for line in frontmatter.splitlines():
    match = re.match(r"\s*task_id\s*:\s*['\"]?([^'\"#\s]+)", line)
    if match:
        print(match.group(1).strip())
        break
PYEOF
}

closed_duplicate=""
for candidate in "$vault_root/closed/$task_id-"*.md "$vault_root/closed/$task_id.md"; do
  [[ -f "$candidate" ]] || continue
  candidate_task_id="$(frontmatter_task_id "$candidate" || true)"
  if [[ "$candidate_task_id" == "$task_id" ]]; then
    closed_duplicate="$candidate"
    break
  fi
done
if [[ -n "$closed_duplicate" ]]; then
  echo "cc-close: BLOCKED - closed task duplicate has task_id '$task_id': $closed_duplicate" >&2
  exit 8
fi

# Rapid-closure flag — require --retroactive for tasks closed <5min after claim.
# Prevents the 22-second paperwork closure pattern found by CCTV disconfirmation.
if [[ "$final_status" == "done" && -z "${retroactive:-}" && "${HAPAX_RAPID_CLOSE_OFF:-0}" != "1" ]]; then
  claimed_at="$(python3 -c "
import re, sys
from pathlib import Path
text = Path('$note_path').read_text()
m = re.search(r'^claimed_at:\s*(.+)$', text, re.MULTILINE)
if m: print(m.group(1).strip().strip(\"'\").strip('\"'))
" 2>/dev/null || true)"
  if [[ -n "$claimed_at" ]]; then
    elapsed="$(python3 -c "
from datetime import datetime, timezone
try:
    claimed = datetime.fromisoformat('$claimed_at'.replace('Z','+00:00'))
    now = datetime.now(timezone.utc)
    print(int((now - claimed).total_seconds()))
except: print('999')
" 2>/dev/null || echo "999")"
    if [[ "$elapsed" -lt 300 ]]; then
      echo "cc-close: BLOCKED — task closed ${elapsed}s after claim (< 5min threshold)." >&2
      echo "  If this is a retroactive close of already-completed work, re-run with --retroactive." >&2
      echo "  Bypass: HAPAX_RAPID_CLOSE_OFF=1" >&2
      exit 2
    fi
  fi
fi

# Closure-discipline gate (cc-task cc-task-closure-hook-acceptance-criteria-gate):
# refuse the move when any `## Acceptance criteria` checkbox is unchecked.
# The Bash PreToolUse hook catches manual mv / git mv; this call catches
# the cc-close path (which uses python rename, invisible to the Bash hook).
# Both surfaces share the same checker. Bypass via HAPAX_CC_TASK_CLOSURE_GATE_OFF=1.
# Skip the gate for non-`done` outcomes (withdrawn / superseded close paths
# are operator-marked terminal states where the AC-completeness contract
# does not apply).
if [[ "$final_status" == "done" ]]; then
  CHECKER="$SCRIPT_DIR/cc-task-closure-check.py"
  if [[ -f "$CHECKER" ]]; then
    set +e
    python3 "$CHECKER" "$note_path"
    gate_rc=$?
    set -e
    if [[ "$gate_rc" -ne 0 ]]; then
      exit "$gate_rc"
    fi
  fi

  # Acceptance-receipt gate (routing Phase 0.2) — review-floor
  # (frontier_review_required) tasks close only with a signed acceptance
  # receipt (<task_id>.acceptance.yaml beside the note). The checker honors
  # HAPAX_ACCEPTANCE_RECEIPT_GATE_OFF=1 directly; non-review-floor tasks
  # pass through untouched.
  RECEIPT_CHECKER="$SCRIPT_DIR/cc-close-acceptance-receipt-check.py"
  if [[ -f "$RECEIPT_CHECKER" ]]; then
    set +e
    python3 "$RECEIPT_CHECKER" "$note_path"
    receipt_rc=$?
    set -e
    if [[ "$receipt_rc" -ne 0 ]]; then
      exit "$receipt_rc"
    fi
  fi

  # PR-merge evidence gate — verify PR is merged before allowing done status.
  # Prevents "status: done but PR is open" false-completion pattern.
  # Bypass: HAPAX_PR_MERGE_GATE_OFF=1
  if [[ "${HAPAX_PR_MERGE_GATE_OFF:-0}" != "1" ]]; then
    PR_MERGE_CHECKER="$SCRIPT_DIR/cc-close-pr-merge-check.py"
    if [[ -f "$PR_MERGE_CHECKER" ]]; then
      set +e
      python3 "$PR_MERGE_CHECKER" "$note_path" ${pr:+--pr "$pr"}
      merge_rc=$?
      set -e
      if [[ "$merge_rc" -ne 0 ]]; then
        exit "$merge_rc"
      fi
    fi
  fi

  # Artifact disposition gate
  DISP_CHECKER="$SCRIPT_DIR/cc-task-artifact-disposition-check.py"
  if [[ -f "$DISP_CHECKER" ]]; then
    set +e
    if [[ -n "${debt_reason:-}" ]]; then
      python3 "$DISP_CHECKER" "$note_path" "$task_id" --debt "$debt_reason"
    else
      python3 "$DISP_CHECKER" "$note_path" "$task_id"
    fi
    disp_rc=$?
    set -e
    if [[ "$disp_rc" -ne 0 ]]; then
      exit "$disp_rc"
    fi
  fi

  # Sibling-task advisory check — warns about stalled siblings under the same
  # parent request. Advisory only (exit 0), prevents the remediation execution
  # gap found by CCTV disconfirmation (PR #3659).
  SIBLING_CHECKER="$SCRIPT_DIR/cc-close-sibling-check.py"
  if [[ -f "$SIBLING_CHECKER" ]]; then
    python3 "$SIBLING_CHECKER" "$note_path" || true
  fi
fi

start_hygiene=0
for claim_key in \
  "$role" \
  ${session_id:+"$role-$session_id"}; do
  claim_file="$HOME/.cache/hapax/cc-active-task-$claim_key"
  if [[ -f "$claim_file" ]] &&
     [[ "$(head -n1 "$claim_file" | tr -d '[:space:]')" == "$task_id" ]]; then
    start_hygiene=1
  fi
done

python3 - "$note_path" "$task_id" "$final_status" "$pr" "$role" "$platform" \
  "$note_sha256" "$SCRIPT_DIR/.." "$session_id" "$HOME/.cache/hapax" \
  "$transaction_journal" <<'PYEOF'
import hashlib
import re
import stat
import sys
from datetime import datetime, timezone
from pathlib import Path

path = Path(sys.argv[1])
task_id, final_status, pr, role, platform, expected_sha256 = sys.argv[2:8]
repo_root = Path(sys.argv[8]).resolve()
session_id = sys.argv[9]
cache_dir = Path(sys.argv[10])
transaction_journal = Path(sys.argv[11])
sys.path.insert(0, str(repo_root))

from shared.sdlc_filesystem_transaction import (  # noqa: E402
    FileMutation,
    FilesystemTransactionError,
    execute_filesystem_transaction,
)
from shared.sdlc_task_store import (  # noqa: E402
    TaskStoreError,
    assert_close_slot_owned,
)
from shared.sdlc_lifecycle import frontmatter_from_text  # noqa: E402
from shared.sdlc_owner_identity import owner_matches  # noqa: E402

try:
    task_content = path.read_bytes()
except OSError as exc:
    print(f"cc-close: task snapshot unreadable before commit: {exc}", file=sys.stderr)
    raise SystemExit(9) from exc
if hashlib.sha256(task_content).hexdigest() != expected_sha256:
    print(
        "cc-close: task changed during closure checks; retry from the current exact bytes",
        file=sys.stderr,
    )
    raise SystemExit(9)
try:
    text = task_content.decode("utf-8")
    frontmatter = frontmatter_from_text(text)
except (UnicodeDecodeError, ValueError) as exc:
    print(f"cc-close: task snapshot malformed before commit: {exc}", file=sys.stderr)
    raise SystemExit(9) from exc
owner = str(frontmatter.get("assigned_to") or "").strip()
if not owner_matches(owner, role, platform or None):
    print(
        "cc-close: close_task_owner_mismatch: HOLD; task owner changed before commit "
        f"(assigned_to={owner or '<null>'} caller={platform or 'unknown'}/{role})",
        file=sys.stderr,
    )
    raise SystemExit(9)
try:
    assert_close_slot_owned(
        cache_dir=cache_dir,
        role=role,
        session_id=session_id,
        task_id=task_id,
    )
except TaskStoreError as exc:
    print(f"cc-close: ownership projection changed before commit: {exc}", file=sys.stderr)
    raise SystemExit(9)
now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

text = re.sub(r"^status:.*$", f"status: {final_status}", text, count=1, flags=re.MULTILINE)
text = re.sub(
    r"^completed_at:.*$", f"completed_at: {now}", text, count=1, flags=re.MULTILINE
)
text = re.sub(
    r"^updated_at:.*$", f"updated_at: {now}", text, count=1, flags=re.MULTILINE
)
if pr:
    text = re.sub(r"^pr:.*$", f"pr: {pr}", text, count=1, flags=re.MULTILINE)
log_line = f"- {now} {role or 'session'} closed as {final_status}"
if pr:
    log_line += f" (PR #{pr})"
log_line += " (cc-close)\n"
text = text.replace("## Session log\n", f"## Session log\n{log_line}", 1)

# Move from active/ to closed/.
new_path = path.parent.parent / "closed" / path.name
new_path.parent.mkdir(parents=True, exist_ok=True)
mode = path.stat().st_mode & 0o777
mutations = [
    FileMutation(
        path=path,
        content=None,
        expected_sha256=expected_sha256,
        expected_exists=True,
    ),
    FileMutation(
        path=new_path,
        content=text.encode("utf-8"),
        mode=mode,
        expected_exists=False,
    ),
]


def deletion_precondition(path: Path) -> tuple[FileMutation, bytes | None, int | None]:
    try:
        metadata = path.lstat()
    except FileNotFoundError:
        return FileMutation(path=path, content=None, expected_exists=False), None, None
    except OSError as exc:
        print(f"cc-close: ownership preimage unreadable: {path}: {exc}", file=sys.stderr)
        raise SystemExit(9)
    if stat.S_ISLNK(metadata.st_mode) or not stat.S_ISREG(metadata.st_mode):
        print(f"cc-close: ownership preimage is not a regular file: {path}", file=sys.stderr)
        raise SystemExit(9)
    try:
        content = path.read_bytes()
    except OSError as exc:
        print(f"cc-close: ownership preimage unreadable: {path}: {exc}", file=sys.stderr)
        raise SystemExit(9)
    return (
        FileMutation(
            path=path,
            content=None,
            expected_sha256=hashlib.sha256(content).hexdigest(),
            expected_exists=True,
        ),
        content,
        stat.S_IMODE(metadata.st_mode),
    )

# The acceptance receipt (routing Phase 0.2) lives ALONGSIDE the note —
# keep that invariant across the move so closed review-floor tasks stay
# closure-valid for the autoqueue and audits.
receipt = path.parent / f"{task_id}.acceptance.yaml"
receipt_delete, receipt_content, receipt_mode = deletion_precondition(receipt)
mutations.append(receipt_delete)
closed_receipt = new_path.parent / receipt.name
if receipt_content is not None:
    assert receipt_mode is not None
    mutations.extend(
        (
            FileMutation(
                path=closed_receipt,
                content=receipt_content,
                mode=receipt_mode,
                expected_exists=False,
            ),
        )
    )
else:
    mutations.append(FileMutation(path=closed_receipt, content=None, expected_exists=False))

keys = [role]
if session_id:
    keys.append(f"{role}-{session_id}")
cleared: list[Path] = []
for claim_key in keys:
    claim_path = cache_dir / f"cc-active-task-{claim_key}"
    claim_delete, claim_content, _claim_mode = deletion_precondition(claim_path)
    mutations.append(claim_delete)
    if claim_content is not None:
        cleared.append(claim_path)
    for projection in (
        cache_dir / f"cc-claim-epoch-{claim_key}",
        cache_dir / f"cc-claim-dispatch-{claim_key}.json",
    ):
        projection_delete, _content, _mode = deletion_precondition(projection)
        mutations.append(projection_delete)

try:
    assert_close_slot_owned(
        cache_dir=cache_dir,
        role=role,
        session_id=session_id,
        task_id=task_id,
    )
except TaskStoreError as exc:
    print(f"cc-close: ownership projection changed before commit: {exc}", file=sys.stderr)
    raise SystemExit(9)

try:
    execute_filesystem_transaction(
        transaction_journal,
        mutations,
        allowed_roots=(path.parent.parent, cache_dir),
    )
except FilesystemTransactionError as exc:
    print(f"cc-close: ownership transaction failed: {exc}", file=sys.stderr)
    raise SystemExit(9)

print(f"cc-close: moved '{task_id}' to closed/, status={final_status}")
if receipt.is_file():
    raise AssertionError("active receipt remained after committed close")
if closed_receipt.is_file():
    print(f"cc-close: moved acceptance receipt '{task_id}.acceptance.yaml' to closed/")
for claim_path in cleared:
    print(f"cc-close: cleared claim file '{claim_path}' (role '{role}')")
PYEOF

# The ownership transaction is complete once the note and claim projections
# agree. Never invoke another writer while holding these locks: hygiene may
# traverse the same claim plane and otherwise deadlock behind this process.
flock -u 9
flock -u 8
exec 9>&-
exec 8>&-
if [[ "$start_hygiene" == 1 && "${HAPAX_CC_HYGIENE_OFF:-0}" != "1" ]]; then
  systemctl --user start --no-block hapax-cc-hygiene.service 2>/dev/null || true
fi

# Best-effort request lifecycle reconciliation. `request-intake-consumer`
# remains read-only; this writer is explicit and conservative, and only runs
# after a successful fulfilling cc-task close.
if [[ "$final_status" == "done" && "${HAPAX_REQUEST_RECONCILER_OFF:-0}" != "1" && "${HAPAX_CC_HYGIENE_OFF:-0}" != "1" ]]; then
  reconciler="$SCRIPT_DIR/request-fulfillment-reconciler"
  if [[ -x "$reconciler" ]]; then
    set +e
    "$reconciler" --apply --task-id "$task_id" --write-report --quiet
    reconcile_rc=$?
    set -e
    if [[ "$reconcile_rc" -ne 0 ]]; then
      echo "cc-close: request fulfillment reconciler failed rc=$reconcile_rc" >&2
    fi
  fi

  # Phase-advance: if this task is Phase N, create Phase N+1 if the request has more phases.
  phase_advance="$SCRIPT_DIR/cc-phase-advance.py"
  if [[ -f "$phase_advance" ]]; then
    set +e
    python3 "$phase_advance" "$vault_root/closed/$(basename "$note_path")" "$task_id"
    set -e
  fi

  # Cascade-unblock: transition blocked tasks whose depends_on are now all satisfied.
  cascade="$SCRIPT_DIR/cc-cascade-unblock"
  if [[ -x "$cascade" ]]; then
    set +e
    "$cascade" "$task_id"
    set -e
  fi
fi
