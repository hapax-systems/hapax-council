#!/usr/bin/env bash
# cc-close <task_id> [--pr N] [--status done|withdrawn|superseded]
#
# This wrapper has no independent mutation path. Every operational close enters
# the shared claim-bound close transaction; admission failures leave task and
# claim state byte-identical.

set -euo pipefail

_cc_self="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  _cc_self="$(readlink -f "$_cc_self" 2>/dev/null || printf '%s' "$_cc_self")"
fi
SCRIPT_DIR="$(cd "$(dirname "$_cc_self")" && pwd)"
ROLE_HELPER="$SCRIPT_DIR/../hooks/scripts/agent-role.sh"
if [[ -f "$ROLE_HELPER" ]]; then
  # shellcheck source=../hooks/scripts/agent-role.sh
  . "$ROLE_HELPER"
fi

if [[ $# -lt 1 ]]; then
  echo "usage: cc-close <task_id> [--pr N] [--status done|withdrawn|superseded]" >&2
  echo "       active blocked evidence stays active with a reason and witness" >&2
  exit 1
fi

task_id="$1"
shift
pr=""
final_status="done"
debt_reason=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --pr) pr="${2:-}"; shift 2 ;;
    --status) final_status="${2:-}"; shift 2 ;;
    --debt) debt_reason="${2:-}"; shift 2 ;;
    --retroactive)
      echo "cc-close: HOLD - raw --retroactive is retired; supply typed operator evidence through the admitted close contract" >&2
      exit 2
      ;;
    *) echo "cc-close: unknown arg '$1'" >&2; exit 1 ;;
  esac
done

case "$final_status" in
  done|withdrawn|superseded) ;;
  *) echo "cc-close: --status must be done, withdrawn, or superseded (got '$final_status')" >&2; exit 1 ;;
esac

if declare -F hapax_effective_role >/dev/null 2>&1; then
  role="$(hapax_effective_role 2>/dev/null || true)"
else
  role="${HAPAX_AGENT_ROLE:-${CODEX_ROLE:-${CLAUDE_ROLE:-}}}"
fi
if [[ -z "$role" ]]; then
  echo "cc-close: cannot determine the claim-bound role" >&2
  exit 2
fi

PROJECT_PYTHON="$SCRIPT_DIR/../.venv/bin/python"
if [[ ! -x "$PROJECT_PYTHON" ]]; then
  echo "cc-close: project_runtime_unprovisioned: expected pinned interpreter at $PROJECT_PYTHON" >&2
  exit 3
fi

session_id=""
if declare -F hapax_session_id >/dev/null 2>&1; then
  session_id="$(hapax_session_id 2>/dev/null || true)"
else
  session_id="${HAPAX_SESSION_ID:-}"
fi

close_args=("$task_id" --status "$final_status")
if [[ -n "$pr" ]]; then
  close_args+=(--pr "$pr")
fi
if [[ -n "$debt_reason" ]]; then
  close_args+=(--debt "$debt_reason")
fi

set +e
HAPAX_AGENT_ROLE="$role" HAPAX_SESSION_ID="$session_id" \
  "$PROJECT_PYTHON" -I -m shared.sdlc_close "${close_args[@]}"
close_rc=$?
set -e
if [[ "$close_rc" -eq 0 && "$final_status" == "done" ]]; then
  echo "cc-close: HOLD - request reconciliation, phase advance, and cascade require a governed post-close transaction" >&2
fi
exit "$close_rc"
