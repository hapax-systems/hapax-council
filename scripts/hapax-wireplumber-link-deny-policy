#!/usr/bin/env python3
"""Guarded install/status helper for the Hapax WirePlumber link deny hook."""

from __future__ import annotations

import argparse
import filecmp
import json
import os
import shutil
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from shared.audio_routing_policy import (
    DEFAULT_WIREPLUMBER_DENY_CONF_PATH,
    DEFAULT_WIREPLUMBER_DENY_SCRIPT_PATH,
    generated_wireplumber_deny_policy_texts,
)

RUNTIME_AUTH_ENV = "HAPAX_AUDIO_WIREPLUMBER_DENY_RUNTIME_AUTHORIZED"
INSTALLED_CONF_REL = Path("wireplumber.conf.d") / DEFAULT_WIREPLUMBER_DENY_CONF_PATH.name
INSTALLED_SCRIPT_REL = Path("scripts") / "hapax" / DEFAULT_WIREPLUMBER_DENY_SCRIPT_PATH.name


def _installed_paths(
    installed_wireplumber_dir: Path,
    installed_wireplumber_data_dir: Path,
) -> dict[str, Path]:
    return {
        "conf": installed_wireplumber_dir / INSTALLED_CONF_REL,
        "script": installed_wireplumber_data_dir / INSTALLED_SCRIPT_REL,
        "legacy_config_script": installed_wireplumber_dir / INSTALLED_SCRIPT_REL,
    }


def _same_resolved_path(left: Path, right: Path) -> bool:
    return left.resolve(strict=False) == right.resolve(strict=False)


def _legacy_config_script_is_distinct(installed: dict[str, Path]) -> bool:
    return not _same_resolved_path(installed["legacy_config_script"], installed["script"])


def _source_paths() -> dict[str, Path]:
    return {
        "conf": DEFAULT_WIREPLUMBER_DENY_CONF_PATH,
        "script": DEFAULT_WIREPLUMBER_DENY_SCRIPT_PATH,
    }


def _path_status(source: Path, installed: Path) -> dict[str, object]:
    installed_matches = (
        source.exists() and installed.exists() and filecmp.cmp(source, installed, shallow=False)
    )
    return {
        "source": str(source),
        "source_exists": source.exists(),
        "installed": str(installed),
        "installed_exists": installed.exists(),
        "installed_matches_source": installed_matches,
    }


def status_payload(
    installed_wireplumber_dir: Path,
    installed_wireplumber_data_dir: Path,
) -> dict[str, object]:
    source = _source_paths()
    installed = _installed_paths(installed_wireplumber_dir, installed_wireplumber_data_dir)
    return {
        "runtime_auth_env": RUNTIME_AUTH_ENV,
        "runtime_authorized": os.environ.get(RUNTIME_AUTH_ENV) == "1",
        "installed_wireplumber_dir": str(installed_wireplumber_dir),
        "installed_wireplumber_data_dir": str(installed_wireplumber_data_dir),
        "files": {name: _path_status(source[name], installed[name]) for name in ("conf", "script")},
        "legacy_config_script": {
            "installed": str(installed["legacy_config_script"]),
            "installed_exists": installed["legacy_config_script"].exists(),
            "distinct_from_data_script": _legacy_config_script_is_distinct(installed),
            "should_exist": False,
        },
    }


def check_source() -> list[str]:
    conf_text, script_text = generated_wireplumber_deny_policy_texts()
    expected = {
        DEFAULT_WIREPLUMBER_DENY_CONF_PATH: conf_text,
        DEFAULT_WIREPLUMBER_DENY_SCRIPT_PATH: script_text,
    }
    return [
        str(path)
        for path, text in expected.items()
        if not path.exists() or path.read_text(encoding="utf-8") != text
    ]


def check_installed(
    installed_wireplumber_dir: Path,
    installed_wireplumber_data_dir: Path,
) -> list[str]:
    source = _source_paths()
    installed = _installed_paths(installed_wireplumber_dir, installed_wireplumber_data_dir)
    stale = [
        str(installed[name])
        for name in ("conf", "script")
        if not source[name].exists()
        or not installed[name].exists()
        or not filecmp.cmp(source[name], installed[name], shallow=False)
    ]
    if _legacy_config_script_is_distinct(installed) and installed["legacy_config_script"].exists():
        stale.append(f"{installed['legacy_config_script']} (legacy config script should be absent)")
    return stale


def install(
    installed_wireplumber_dir: Path,
    installed_wireplumber_data_dir: Path,
    *,
    dry_run: bool,
) -> list[str]:
    source = _source_paths()
    installed = _installed_paths(installed_wireplumber_dir, installed_wireplumber_data_dir)
    operations = [
        f"{source['conf']} -> {installed['conf']}",
        f"{source['script']} -> {installed['script']}",
        f"remove legacy config script if present: {installed['legacy_config_script']}",
    ]

    if dry_run:
        return operations

    if os.environ.get(RUNTIME_AUTH_ENV) != "1":
        raise SystemExit(
            f"refusing live WirePlumber writes without {RUNTIME_AUTH_ENV}=1; "
            "rerun with --dry-run for a non-mutating preview"
        )

    for name in ("conf", "script"):
        if not source[name].exists():
            raise SystemExit(f"source artifact missing: {source[name]}")
        installed[name].parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source[name], installed[name])
    if _legacy_config_script_is_distinct(installed) and installed["legacy_config_script"].exists():
        installed["legacy_config_script"].unlink()
    return operations


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--installed-wireplumber-dir",
        type=Path,
        default=Path.home() / ".config" / "wireplumber",
    )
    parser.add_argument(
        "--installed-wireplumber-data-dir",
        type=Path,
        default=Path.home() / ".local" / "share" / "wireplumber",
    )
    parser.add_argument("--check-source", action="store_true")
    parser.add_argument("--check-installed", action="store_true")
    parser.add_argument("--install", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    if args.check_source:
        stale = check_source()
        if stale:
            raise SystemExit(
                "WirePlumber deny source artifact(s) stale: "
                + ", ".join(stale)
                + "; rerun scripts/generate-pipewire-audio-confs.py "
                "--write-wireplumber-deny-policy"
            )

    if args.install:
        operations = install(
            args.installed_wireplumber_dir,
            args.installed_wireplumber_data_dir,
            dry_run=args.dry_run,
        )
        payload = {
            "dry_run": args.dry_run,
            "operations": operations,
            "runtime_auth_env": RUNTIME_AUTH_ENV,
        }
        if args.json:
            print(json.dumps(payload, indent=2, sort_keys=True))
        else:
            mode = "DRY RUN" if args.dry_run else "INSTALLED"
            for operation in operations:
                print(f"{mode}: {operation}")

    if args.check_installed:
        stale = check_installed(args.installed_wireplumber_dir, args.installed_wireplumber_data_dir)
        if stale:
            raise SystemExit(
                "installed WirePlumber deny artifact(s) differ from source: " + ", ".join(stale)
            )

    if not (args.check_source or args.install or args.check_installed):
        payload = status_payload(
            args.installed_wireplumber_dir, args.installed_wireplumber_data_dir
        )
        if args.json:
            print(json.dumps(payload, indent=2, sort_keys=True))
        else:
            for name, file_status in payload["files"].items():
                status = "installed" if file_status["installed_matches_source"] else "not-installed"
                print(f"{name}: {status} ({file_status['installed']})")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
