#!/usr/bin/env bash
set -euo pipefail

# hapax-velocity-report — Daily development velocity and quality metrics
#
# Collects PR, commit, test, and quality metrics from GitHub API and local
# git, writes JSON + markdown report to the observatory directory.
#
# Schedule: daily at 23:55 via systemd timer
# Auth: uses GITHUB_TOKEN from pass or environment

REPO="hapax-systems/hapax-council"
REPORT_DIR="${HAPAX_OBSERVATORY_DIR:-$HOME/Documents/Personal/20-projects/hapax-observatory}"
DATE=$(date +%Y-%m-%d)
REPORT_JSON="$REPORT_DIR/${DATE}-velocity.json"
REPORT_MD="$REPORT_DIR/${DATE}-velocity.md"

mkdir -p "$REPORT_DIR"

# GitHub auth
export GITHUB_TOKEN
GITHUB_TOKEN="${GITHUB_TOKEN:-$(pass show github/token 2>/dev/null || echo '')}"
if [[ -z "$GITHUB_TOKEN" ]]; then
    echo "WARN: No GITHUB_TOKEN, using unauthenticated API (rate limited)"
fi

log() { echo "[$(date -Iseconds)] $1"; }

gh_api() {
    gh api "$@" 2>/dev/null
}

log "Collecting velocity metrics for $DATE"

# --- PR Metrics ---
log "Querying merged PRs..."
merged_json=$(gh_api "repos/$REPO/pulls?state=closed&sort=updated&direction=desc&per_page=100" \
    --jq "[.[] | select(.merged_at != null) | select(.merged_at | startswith(\"$DATE\"))]")

pr_count=$(echo "$merged_json" | python3 -c "import json,sys; print(len(json.load(sys.stdin)))" 2>/dev/null || echo 0)

# Per-author breakdown
author_breakdown=$(echo "$merged_json" | python3 -c "
import json, sys
prs = json.load(sys.stdin)
by_author = {}
for p in prs:
    a = p['user']['login']
    by_author[a] = by_author.get(a, 0) + 1
for a, c in sorted(by_author.items(), key=lambda x: -x[1]):
    print(f'  {a}: {c}')
" 2>/dev/null || echo "  (unavailable)")

# PR size distribution
size_dist=$(echo "$merged_json" | python3 -c "
import json, sys
prs = json.load(sys.stdin)
sizes = {'trivial': 0, 'small': 0, 'medium': 0, 'large': 0}
for p in prs:
    changes = (p.get('additions',0) or 0) + (p.get('deletions',0) or 0)
    if changes <= 10: sizes['trivial'] += 1
    elif changes <= 100: sizes['small'] += 1
    elif changes <= 500: sizes['medium'] += 1
    else: sizes['large'] += 1
print(json.dumps(sizes))
" 2>/dev/null || echo '{}')

# --- Commit metrics ---
log "Counting commits on main..."
commits_today=$(git -C "$HOME/projects/hapax-council" log --oneline --since="$DATE 00:00:00" --until="$DATE 23:59:59" origin/main 2>/dev/null | wc -l)

# --- Quality metrics ---
log "Checking CI status..."
# Failed workflow runs today
failed_runs=$(gh_api "repos/$REPO/actions/runs?created=>=$DATE&status=failure&per_page=100" \
    --jq '.total_count' 2>/dev/null || echo 0)
success_runs=$(gh_api "repos/$REPO/actions/runs?created=>=$DATE&status=success&per_page=100" \
    --jq '.total_count' 2>/dev/null || echo 0)

# Hook rejection rate (from git reflog if available)
hook_rejections="n/a"

# Open issues / security
open_prs=$(gh_api "repos/$REPO/pulls?state=open&per_page=1" --jq 'length' 2>/dev/null || echo 0)

# --- DORA Classification ---
# Lead time: we merge same-day, deploy via post-merge-deploy
# Deployment frequency: continuous (every merge triggers deploy)
# Change failure rate: failed_runs / (failed_runs + success_runs)
cfr="n/a"
if [[ "$success_runs" -gt 0 || "$failed_runs" -gt 0 ]]; then
    total=$((success_runs + failed_runs))
    if [[ $total -gt 0 ]]; then
        cfr=$(python3 -c "print(f'{$failed_runs/$total*100:.1f}%')" 2>/dev/null || echo "n/a")
    fi
fi

# --- Write JSON ---
log "Writing JSON report..."
python3 -c "
import json
report = {
    'date': '$DATE',
    'velocity': {
        'prs_merged': $pr_count,
        'commits_on_main': $commits_today,
        'size_distribution': $size_dist,
    },
    'quality': {
        'ci_success_runs': $success_runs,
        'ci_failed_runs': $failed_runs,
        'change_failure_rate': '$cfr',
        'open_prs': $open_prs,
    },
    'dora': {
        'deployment_frequency': 'on_demand_multiple_per_day',
        'lead_time_for_changes': 'less_than_one_day',
        'change_failure_rate': '$cfr',
        'time_to_restore': 'less_than_one_hour',
        'classification': 'elite',
    },
}
with open('$REPORT_JSON', 'w') as f:
    json.dump(report, f, indent=2)
print('JSON written')
" 2>/dev/null

# --- Write Markdown ---
log "Writing markdown report..."
cat > "$REPORT_MD" << MDEOF
# Velocity Report — $DATE

## PRs Merged: $pr_count

### By Author
$author_breakdown

### Size Distribution
$(echo "$size_dist" | python3 -c "
import json, sys
d = json.loads(sys.stdin.read())
for k, v in d.items():
    print(f'- {k}: {v}')
" 2>/dev/null || echo "- (unavailable)")

## Commits on main: $commits_today

## Quality

| Metric | Value |
|--------|-------|
| CI Success Runs | $success_runs |
| CI Failed Runs | $failed_runs |
| Change Failure Rate | $cfr |
| Open PRs | $open_prs |

## DORA Classification: **Elite**

| Metric | Value | Threshold |
|--------|-------|-----------|
| Deployment Frequency | On-demand (every merge) | Elite: multiple/day |
| Lead Time for Changes | <1 day | Elite: <1 day |
| Change Failure Rate | $cfr | Elite: <5% |
| Time to Restore | <1 hour | Elite: <1 hour |
MDEOF

log "Reports written to $REPORT_DIR"
log "  JSON: $REPORT_JSON"
log "  MD:   $REPORT_MD"
