#!/usr/bin/env python3
"""Publish a lane-to-operator message through the durable relay MQ.

This is the narrow session-to-operator uplink for the SBCL/CLOG Operator
Inbox. It is intentionally not a dispatch surface.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from shared.relay_mq import DEFAULT_DB_PATH, send_message
from shared.relay_mq_envelope import DiskPressureError, Envelope

ACTION_TYPES = {"query", "escalation"}
DEFAULT_TAGS = ("operator-inbox", "lane-to-operator")


def default_sender() -> str:
    for name in (
        "HAPAX_AGENT_NAME",
        "CLAUDE_ROLE",
        "CODEX_ROLE",
        "HAPAX_AGENT_ROLE",
        "CODEX_SESSION_NAME",
        "CODEX_THREAD_NAME",
    ):
        value = os.environ.get(name)
        if value:
            return value
    return "unknown-session"


def split_tags(raw: str | None) -> list[str]:
    if not raw:
        return []
    return [part.strip() for part in raw.split(",") if part.strip()]


def governed_ref_present(args: argparse.Namespace) -> bool:
    return any(
        (
            args.authority_case,
            args.authority_item,
            args.task_id,
            args.request_id,
        )
    )


def needs_governed_ref(args: argparse.Namespace) -> bool:
    return args.action_required or args.type in ACTION_TYPES or args.priority <= 1


def payload_from_args(args: argparse.Namespace) -> tuple[str | None, str | None]:
    if args.payload and args.payload_file:
        raise ValueError("use either --payload or --payload-file, not both")
    if args.payload_file:
        path = Path(args.payload_file)
        if not path.exists():
            raise ValueError(f"payload file not found: {path}")
        return None, str(path)
    if args.payload is not None:
        if not args.payload.strip():
            raise ValueError("--payload must not be empty")
        return args.payload, None
    if not sys.stdin.isatty():
        text = sys.stdin.read()
        if text.strip():
            return text, None
    raise ValueError("message body required via --payload, --payload-file, or stdin")


def build_tags(args: argparse.Namespace) -> list[str]:
    tags = [*DEFAULT_TAGS, *split_tags(args.tags)]
    if args.task_id:
        tags.append(f"task:{args.task_id}")
    if args.request_id:
        tags.append(f"request:{args.request_id}")
    return tags


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--type",
        required=True,
        choices=["advisory", "query", "escalation", "dispatch"],
        help="message type; dispatch is explicitly refused by this wrapper",
    )
    parser.add_argument("--priority", type=int, default=2, choices=[0, 1, 2, 3])
    parser.add_argument("--sender", default=default_sender())
    parser.add_argument("--subject", required=True)
    parser.add_argument("--payload")
    parser.add_argument("--payload-file")
    parser.add_argument("--authority-case")
    parser.add_argument("--authority-item")
    parser.add_argument("--task-id")
    parser.add_argument("--request-id")
    parser.add_argument("--parent")
    parser.add_argument("--tags")
    parser.add_argument("--action-required", action="store_true")
    parser.add_argument("--db", type=Path, default=DEFAULT_DB_PATH)
    parser.add_argument("--json", action="store_true")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    if args.type == "dispatch":
        print(
            "Error: hapax-operator-message refuses dispatch; use "
            "hapax-methodology-dispatch for governed work assignment.",
            file=sys.stderr,
        )
        return 2
    if needs_governed_ref(args) and not governed_ref_present(args):
        print(
            "Error: query/escalation/P0/P1/action-required messages require "
            "--authority-case, --authority-item, --task-id, or --request-id.",
            file=sys.stderr,
        )
        return 2

    try:
        payload, payload_path = payload_from_args(args)
        envelope = Envelope(
            sender=args.sender,
            message_type=args.type,
            priority=args.priority,
            subject=args.subject,
            authority_case=args.authority_case,
            authority_item=args.authority_item or args.task_id or args.request_id,
            parent_message_id=args.parent,
            recipients_spec="operator",
            payload=payload,
            payload_path=payload_path,
            tags=build_tags(args),
        )
        args.db.parent.mkdir(parents=True, exist_ok=True)
        message_id = send_message(args.db, envelope)
    except (DiskPressureError, ValueError) as exc:
        print(f"Error: {exc}", file=sys.stderr)
        return 1

    result = {
        "message_id": message_id,
        "recipient": "operator",
        "sender": envelope.sender,
        "message_type": envelope.message_type,
        "priority": envelope.priority,
        "subject": envelope.subject,
    }
    if args.json:
        print(json.dumps(result, sort_keys=True))
    else:
        print(
            f"Queued operator message: {message_id} ({envelope.message_type}/P{envelope.priority})"
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
