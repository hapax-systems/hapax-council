#!/usr/bin/env bash
# hapax-post-merge-smoke — gate-driven smoke verification for a merge.
#
# Invoked by hapax-post-merge-deploy after services restart. Walks a
# matrix of smoke gates that match the diff produced by $SHA, and
# ntfy's on any failure. Always exits 0 — the deploy already happened;
# the smoke is informational. The operator decides whether to revert.
#
# Per cc-task `post-merge-smoke-runner` (WSJF 6.5, 2026-05-02).
#
# Usage:
#   scripts/hapax-post-merge-smoke <merge-sha>
#
# Env:
#   NTFY_TOPIC          (optional) ntfy topic; if unset, prints to stderr
#   HAPAX_SMOKE_OFF=1   skip all gates (post-merge-deploy can hard-disable)
#   HAPAX_SMOKE_DRYRUN=1  print which gates would fire without running them
set -uo pipefail

[ "${HAPAX_SMOKE_OFF:-0}" = "1" ] && exit 0

SHA="${1:-HEAD}"
REPO_ROOT="${REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || echo .)}"
DRYRUN="${HAPAX_SMOKE_DRYRUN:-0}"

cd "$REPO_ROOT" || exit 0

# Resolve the SHA range. If SHA is a single commit, compare against its
# first parent. Tolerant of merge commits and squash-merges.
if ! git rev-parse --verify --quiet "${SHA}^{commit}" >/dev/null; then
    echo "smoke: invalid SHA '$SHA'; skipping" >&2
    exit 0
fi
if FIRST_PARENT="$(git rev-parse --verify --quiet "${SHA}^1" 2>/dev/null)"; then
    DIFF_BASE="$FIRST_PARENT"
else
    DIFF_BASE="${SHA}~1"
fi

CHANGED_FILES="$(git diff --name-only "${DIFF_BASE}..${SHA}" 2>/dev/null || true)"
[ -z "$CHANGED_FILES" ] && exit 0

# ── Failure tracking ─────────────────────────────────────────────────

FAILED_GATES=()
record_failure() {
    FAILED_GATES+=("$1: $2")
}

# ── Helper: emit ntfy + stderr on any failure ────────────────────────

emit_failure_notice() {
    local count=${#FAILED_GATES[@]}
    [ "$count" -eq 0 ] && return
    local body="merge=$SHA gates_failed=$count"
    for entry in "${FAILED_GATES[@]}"; do
        echo "smoke FAIL: $entry" >&2
        body="$body | $entry"
    done
    if [ -n "${NTFY_TOPIC:-}" ]; then
        curl -s \
            -H "Title: post-merge smoke FAIL ($count gate$([ "$count" -gt 1 ] && echo s))" \
            -H "Priority: default" \
            -H "Tags: warning,test" \
            -d "$body" \
            "https://ntfy.sh/${NTFY_TOPIC}" \
            >/dev/null 2>&1 || true
    fi
}
trap emit_failure_notice EXIT

# ── Gate: services-restarted ─────────────────────────────────────────
# When any systemd/units/*.service is in the diff, verify units that should
# be running are active after deploy. Timer-backed Type=oneshot units are
# expected to exit, so accept a completed successful oneshot as healthy.
# Newly installed disabled services are also install-only until a later
# enable/start PR; the deploy script copies them and daemon-reloads without
# starting them.

gate_services_restarted() {
    local changed_units=()
    while IFS= read -r f; do
        case "$f" in
            systemd/units/*.service)
                changed_units+=("$(basename "$f")")
                ;;
        esac
    done <<< "$CHANGED_FILES"
    [ "${#changed_units[@]}" -eq 0 ] && return

    [ "$DRYRUN" = "1" ] && { echo "[dry-run] services-restarted: ${changed_units[*]}"; return; }

    for unit in "${changed_units[@]}"; do
        # Skip decommissioned-list units; they should NOT be active.
        if grep -qF "$unit" "$REPO_ROOT/systemd/scripts/install-units.sh" 2>/dev/null \
            && grep -qE "DECOMMISSIONED_UNITS=\(" "$REPO_ROOT/systemd/scripts/install-units.sh"; then
            continue
        fi
        if ! systemctl --user is-active --quiet "$unit" 2>/dev/null; then
            local unit_type result exec_status unit_file_state
            unit_type="$(systemctl --user show "$unit" -p Type --value 2>/dev/null || true)"
            result="$(systemctl --user show "$unit" -p Result --value 2>/dev/null || true)"
            exec_status="$(systemctl --user show "$unit" -p ExecMainStatus --value 2>/dev/null || true)"
            if [ "$unit_type" = "oneshot" ] && [ "$result" = "success" ] && [ "$exec_status" = "0" ]; then
                continue
            fi
            unit_file_state="$(systemctl --user show "$unit" -p UnitFileState --value 2>/dev/null || true)"
            if [ "$unit_file_state" = "disabled" ] && [ "$result" = "success" ]; then
                continue
            fi
            record_failure "services-restarted" "$unit not active after deploy"
        fi
    done
}

# ── Gate: broadcast-healthy ──────────────────────────────────────────
# When the diff touches the audio-routing surface, verify the broadcast
# audio-health producer (shared.broadcast_audio_health) is still alive
# after the deploy — i.e. its state file is fresh (`checked_at` within
# 60s). This intentionally does NOT gate on `safe == true`; broadcast
# unsafety is an operator-visibility concern, separate from "did the
# deploy break the producer." A regressed producer (no fresh writes)
# blinds every downstream WCS consumer.

gate_broadcast_healthy() {
    local touched=false
    while IFS= read -r f; do
        case "$f" in
            agents/studio_compositor/*|\
            agents/hapax_daimonion/*|\
            shared/voice_output_router.py|\
            shared/voice_role_router.py|\
            shared/broadcast_audio_health.py|\
            shared/audio_world_surface_health.py|\
            config/voice-output-routes.yaml)
                touched=true
                break
                ;;
        esac
    done <<< "$CHANGED_FILES"
    $touched || return

    [ "$DRYRUN" = "1" ] && { echo "[dry-run] broadcast-healthy"; return; }

    # Real path written by shared.broadcast_audio_health.DEFAULT_STATE_PATH.
    local health_file="/dev/shm/hapax-broadcast/audio-safe-for-broadcast.json"
    local deadline=$(( $(date +%s) + 30 ))
    while [ "$(date +%s)" -lt "$deadline" ]; do
        if [ -f "$health_file" ]; then
            # Producer must be fresh: file mtime within 60s of now.
            local mtime now age
            mtime="$(stat -c %Y "$health_file" 2>/dev/null || echo 0)"
            now="$(date +%s)"
            age=$(( now - mtime ))
            if [ "$age" -le 60 ]; then
                return
            fi
        fi
        sleep 2
    done
    record_failure "broadcast-healthy" "$health_file did not show a fresh write (age ≤60s) within 30s"
}

# ── Gate: m8-midi-clock-peer ──────────────────────────────────────────
# When agents/hapax_daimonion/backends/midi_clock.py changes, verify
# the M8 device produces a peer tempo signal the daimonion picks up.

gate_m8_midi_clock_peer() {
    local touched=false
    while IFS= read -r f; do
        case "$f" in
            agents/hapax_daimonion/backends/midi_clock.py)
                touched=true
                break
                ;;
        esac
    done <<< "$CHANGED_FILES"
    $touched || return

    [ "$DRYRUN" = "1" ] && { echo "[dry-run] m8-midi-clock-peer"; return; }

    # Only run the check if the M8 is actually present (operator-physical
    # device). On absence, skip — the smoke is informational, not gating.
    if ! command -v amidi >/dev/null 2>&1; then
        return
    fi
    if ! amidi -l 2>/dev/null | grep -qiE 'M8|hw:.*M8'; then
        return  # M8 not connected; skip
    fi
    # Look for the daimonion's published tempo signal.
    local tempo_file="/dev/shm/hapax-daimonion/peer-tempo.json"
    local deadline=$(( $(date +%s) + 15 ))
    while [ "$(date +%s)" -lt "$deadline" ]; do
        if [ -f "$tempo_file" ]; then
            if grep -qE '"source"\s*:\s*"m8"' "$tempo_file" 2>/dev/null; then
                return
            fi
        fi
        sleep 1
    done
    record_failure "m8-midi-clock-peer" "$tempo_file did not show source=m8 within 15s of deploy"
}

# ── Gate dispatch ─────────────────────────────────────────────────────

gate_services_restarted
gate_broadcast_healthy
gate_m8_midi_clock_peer

# Trap fires emit_failure_notice on exit. Always exit 0.
exit 0
