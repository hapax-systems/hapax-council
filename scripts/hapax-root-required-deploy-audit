#!/usr/bin/env bash
# Fail when post-merge root-required deploy actions were deferred and not drained.
set -euo pipefail

ROOT_DEFER_DIR="${HAPAX_POST_MERGE_ROOT_DEFER_DIR:-$HOME/.cache/hapax/post-merge-root-required}"
# Deferrals are cleared only by the explicit HAPAX_ROOT_REQUIRED_DRAIN_DIR path
# in the owning installer; this audit intentionally never mutates them.
ROOT_REQUIRED_STATE_ROOT="${HAPAX_ROOT_REQUIRED_STATE_ROOT:-$HOME/.local/state/hapax/root-required}"
INSTALLED_SOURCE_ROOT="${HAPAX_ROOT_REQUIRED_INSTALLED_SOURCE_ROOT:-$ROOT_REQUIRED_STATE_ROOT/current-source}"
INSTALLED_RECEIPT_ROOT="${HAPAX_ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT:-$ROOT_REQUIRED_STATE_ROOT/installed-receipts}"
DESIRED_RECEIPT_ROOT="${HAPAX_ROOT_REQUIRED_DESIRED_RECEIPT_ROOT:-$ROOT_REQUIRED_STATE_ROOT/desired-receipts}"
ROOT_REQUIRED_GIT_REPO="${HAPAX_ROOT_REQUIRED_GIT_REPO:-$HOME/.cache/hapax/source-activation/worktree}"
ROOT_REQUIRED_LOCK_FILE="${HAPAX_ROOT_REQUIRED_LOCK_FILE:-$ROOT_REQUIRED_STATE_ROOT/.lock}"
OOM_ENFORCER_DEST="${HAPAX_OOM_ENFORCER_DEST:-/usr/local/sbin/hapax-oom-score-enforce}"
OOM_TRIGGER_DEST="${HAPAX_OOM_TRIGGER_DEST:-/usr/local/bin/hapax-oom-score-trigger}"
OOM_SUDOERS_DEST="${HAPAX_OOM_SUDOERS_DEST:-/etc/sudoers.d/hapax-oom-score-enforce}"
ROOT_FAILURE_INTAKE_DEST="${HAPAX_ROOT_FAILURE_INTAKE_DEST:-/usr/local/sbin/hapax-root-failure-intake}"
OOM_POLICY_AUDIT_DEST="${HAPAX_OOM_POLICY_AUDIT_DEST:-/usr/local/sbin/hapax-oom-policy-audit}"
ROOT_REQUIRED_AUDIT_DEST="${HAPAX_ROOT_REQUIRED_AUDIT_DEST:-/usr/local/sbin/hapax-root-required-deploy-audit}"
EARLYOOM_DEST="${HAPAX_OOM_EARLYOOM_DEST:-/etc/default/earlyoom}"
SYSTEMD_SYSTEM_DIR="${HAPAX_OOM_SYSTEMD_SYSTEM_DIR:-/etc/systemd/system}"
SYSTEMD_USER_DIR="${HAPAX_OOM_SYSTEMD_USER_DIR:-$HOME/.config/systemd/user}"
APCUPSD_DEST="${HAPAX_APCUPSD_DEST:-/etc/apcupsd}"
APCUPSD_LOGROTATE_DEST="${HAPAX_APCUPSD_LOGROTATE_DEST:-/etc/logrotate.d/hapax-ups-power-events}"
UPOWER_CONF_DEST="${HAPAX_UPOWER_CONF_DEST:-/etc/UPower/UPower.conf.d/90-hapax-apcupsd-owner.conf}"
SYSTEMCTL="${HAPAX_ROOT_AUDIT_SYSTEMCTL:-systemctl}"
BUSCTL="${HAPAX_ROOT_AUDIT_BUSCTL:-busctl}"
APCACCESS="${HAPAX_ROOT_AUDIT_APCACCESS:-apcaccess}"
VISUDO="${HAPAX_ROOT_AUDIT_VISUDO:-visudo}"

oom_package_files=(
    config/root-required/oom-containment.files
    scripts/install-p0-oom-containment
    config/root-required/hapax-oom-score-enforce.sudoers
    scripts/hapax-oom-score-enforce
    scripts/hapax-oom-score-trigger
    scripts/hapax-root-failure-intake
    scripts/hapax-oom-policy-audit
    scripts/hapax-root-required-deploy-audit
    config/earlyoom/default
    systemd/system/system.slice.d/oom-containment.conf
    systemd/system/user.slice.d/oom-containment.conf
    systemd/system/user-1000.slice.d/oom-containment.conf
    systemd/system/user@1000.service.d/oom.conf
    systemd/system/apcupsd.service.d/oom-protect.conf
    systemd/system/systemd-logind.service.d/oom-protect.conf
    systemd/system/systemd-resolved.service.d/oom-protect.conf
    systemd/system/systemd-timesyncd.service.d/oom-protect.conf
    systemd/system/NetworkManager.service.d/oom-protect.conf
    systemd/system/dbus-broker.service.d/oom-protect.conf
    systemd/system/sshd.service.d/oom-protect.conf
    systemd/units/hapax-root-failure-intake@.service
    systemd/units/hapax-oom-score-enforce.service
    systemd/units/hapax-oom-score-enforce.timer
    systemd/units/hapax-oom-policy-audit.service
    systemd/units/hapax-oom-policy-audit.timer
    systemd/units/hapax-root-required-deploy-audit.service
    systemd/units/hapax-root-required-deploy-audit.timer
    systemd/units/app.slice.d/oom-containment.conf
    systemd/units/pipewire.service.d/oom-protect.conf
    systemd/units/pipewire-pulse.service.d/oom-protect.conf
    systemd/units/wireplumber.service.d/oom-protect.conf
    systemd/units/hapax-daimonion.service.d/oom-protect.conf
    systemd/units/studio-compositor.service.d/oom-protect.conf
    systemd/units/hapax-imagination.service.d/oom-protect.conf
)
apcupsd_package_files=(
    config/root-required/apcupsd-power-alerts.files
    scripts/install-apcupsd-power-alerts
    config/apcupsd/apcupsd.conf
    config/apcupsd/hapax-power-event.py
    config/apcupsd/onbattery
    config/apcupsd/offbattery
    config/apcupsd/doshutdown
    config/upower/90-hapax-apcupsd-owner.conf
    systemd/logrotate.d/hapax-ups-power-events
)

mkdir -p "$ROOT_DEFER_DIR" "$(dirname "$ROOT_REQUIRED_LOCK_FILE")"
exec {ROOT_REQUIRED_LOCK_FD}>"$ROOT_REQUIRED_LOCK_FILE"
flock -s "$ROOT_REQUIRED_LOCK_FD"

rc=0

pending_runbooks() {
    [ -d "$ROOT_DEFER_DIR" ] || return 0
    find "$ROOT_DEFER_DIR" -mindepth 3 -maxdepth 3 -name RUNBOOK.txt -type f | sort
}

source_for_rel() {
    local rel="$1"
    printf '%s/%s\n' "$INSTALLED_SOURCE_ROOT" "$rel"
}

audit_package_receipt() {
    local label="$1" receipt sha rel failed=0
    shift
    receipt="$INSTALLED_RECEIPT_ROOT/$label.sha"
    if [ ! -f "$receipt" ]; then
        echo "root-required installed receipt missing: $receipt" >&2
        echo "  next action: rerun the newest governed $label installer package" >&2
        return 1
    fi
    sha="$(tr -d '[:space:]' < "$receipt")"
    if ! [[ "$sha" =~ ^[0-9a-f]{40}$ ]] || ! git -C "$ROOT_REQUIRED_GIT_REPO" cat-file -e "$sha^{commit}" 2>/dev/null; then
        echo "root-required installed receipt is invalid or unavailable: $receipt sha=$sha" >&2
        echo "  next action: fetch the installed commit into $ROOT_REQUIRED_GIT_REPO and rerun the newest governed $label installer package" >&2
        return 1
    fi
    for rel in "$@"; do
        case "$rel" in
            config/root-required/*.files)
                if ! git -C "$ROOT_REQUIRED_GIT_REPO" cat-file -e "$sha:$rel" 2>/dev/null; then
                    if [ ! -e "$INSTALLED_SOURCE_ROOT/$rel" ]; then
                        continue
                    fi
                    echo "root-required installed manifest is not bound to legacy $label receipt $sha: $INSTALLED_SOURCE_ROOT/$rel" >&2
                    echo "  next action: rerun the newest governed $label installer package" >&2
                    failed=1
                    continue
                fi
                ;;
        esac
        if [ ! -f "$INSTALLED_SOURCE_ROOT/$rel" ] \
            || [ -L "$INSTALLED_SOURCE_ROOT/$rel" ] \
            || ! cmp -s <(git -C "$ROOT_REQUIRED_GIT_REPO" show "$sha:$rel") "$INSTALLED_SOURCE_ROOT/$rel"; then
            echo "root-required installed source is not bound to $label receipt $sha: $INSTALLED_SOURCE_ROOT/$rel" >&2
            echo "  next action: rerun the newest governed $label installer package from an exact staged RUNBOOK" >&2
            failed=1
        fi
    done
    [ "$failed" -eq 0 ]
}

audit_desired_receipt() {
    local label="$1" desired installed desired_sha installed_sha
    desired="$DESIRED_RECEIPT_ROOT/$label.sha"
    installed="$INSTALLED_RECEIPT_ROOT/$label.sha"
    if [ ! -f "$desired" ]; then
        echo "root-required desired receipt missing: $desired" >&2
        echo "  next action: rerun hapax-post-merge-deploy for current main or the newest governed $label installer" >&2
        return 1
    fi
    desired_sha="$(tr -d '[:space:]' < "$desired")"
    if ! [[ "$desired_sha" =~ ^[0-9a-f]{40}$ ]] || ! git -C "$ROOT_REQUIRED_GIT_REPO" cat-file -e "$desired_sha^{commit}" 2>/dev/null; then
        echo "root-required desired receipt is invalid or unavailable: $desired sha=$desired_sha" >&2
        echo "  next action: fetch the desired commit into $ROOT_REQUIRED_GIT_REPO and rerun hapax-post-merge-deploy" >&2
        return 1
    fi
    installed_sha=""
    if [ -f "$installed" ]; then
        installed_sha="$(tr -d '[:space:]' < "$installed")"
    fi
    if [ "$installed_sha" != "$desired_sha" ]; then
        echo "root-required desired package is not installed: $label desired=$desired_sha installed=${installed_sha:-missing}" >&2
        echo "  next action: regenerate the exact package from $desired_sha and run its governed installer, even if the cached RUNBOOK was lost" >&2
        return 1
    fi
}

compare_root_file() {
    local rel="$1" dest="$2" source expected_mode actual_mode
    source="$(source_for_rel "$rel")"
    if [ ! -f "$source" ] || [ -L "$source" ]; then
        echo "root-required source missing or not a regular stable copy: $source" >&2
        echo "  next action: rerun the owning root installer to refresh the receipt-bound snapshot at $INSTALLED_SOURCE_ROOT" >&2
        return 1
    fi
    if [ ! -f "$dest" ] || [ -L "$dest" ]; then
        echo "root-required install missing or not a regular stable copy: $dest" >&2
        case "$rel" in
            config/apcupsd/*|config/upower/*|systemd/logrotate.d/hapax-ups-power-events)
                echo "  next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
                ;;
            *)
                echo "  next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
                ;;
        esac
        return 1
    fi
    expected_mode="$(expected_install_mode "$rel")"
    actual_mode="$(stat -c '%a' "$dest" 2>/dev/null || true)"
    if [ "$actual_mode" != "$expected_mode" ]; then
        echo "root-required install mode drift: $dest mode=${actual_mode:-unavailable} expected=$expected_mode" >&2
        case "$rel" in
            config/apcupsd/*|config/upower/*|systemd/logrotate.d/hapax-ups-power-events)
                echo "  next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
                ;;
            *)
                echo "  next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
                ;;
        esac
        return 1
    fi
    if ! cmp -s "$source" "$dest"; then
        echo "root-required install drift: $dest differs from $source" >&2
        case "$rel" in
            config/apcupsd/*|config/upower/*|systemd/logrotate.d/hapax-ups-power-events)
                echo "  next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
                ;;
            *)
                echo "  next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
                ;;
        esac
        return 1
    fi
}

expected_install_mode() {
    case "$1" in
        config/root-required/hapax-oom-score-enforce.sudoers)
            printf '440\n'
            ;;
        scripts/hapax-oom-score-enforce|scripts/hapax-oom-score-trigger|scripts/hapax-root-failure-intake|scripts/hapax-oom-policy-audit|scripts/hapax-root-required-deploy-audit|config/apcupsd/hapax-power-event.py|config/apcupsd/onbattery|config/apcupsd/offbattery|config/apcupsd/doshutdown)
            printf '755\n'
            ;;
        *)
            printf '644\n'
            ;;
    esac
}

verify_executable() {
    local rel="$1" dest="$2"
    [ -x "$dest" ] || {
        echo "root-required executable mode drift: $dest is not executable" >&2
        case "$rel" in
            config/apcupsd/*)
                echo "  next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
                ;;
            *)
                echo "  next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
                ;;
        esac
        return 1
    }
}

audit_systemd_state() {
    local failed=0 loaded_upower_action
    if ! "$SYSTEMCTL" is-enabled --quiet hapax-oom-score-enforce.timer; then
        echo "root-required activation drift: hapax-oom-score-enforce.timer is not enabled" >&2
        echo "  next action: run sudo systemctl enable --now hapax-oom-score-enforce.timer" >&2
        failed=1
    fi
    if ! "$SYSTEMCTL" is-active --quiet hapax-oom-score-enforce.timer; then
        echo "root-required activation drift: hapax-oom-score-enforce.timer is not active" >&2
        echo "  next action: run sudo systemctl enable --now hapax-oom-score-enforce.timer" >&2
        failed=1
    fi
    if ! "$SYSTEMCTL" is-active --quiet apcupsd.service; then
        echo "root-required activation drift: apcupsd.service is not active" >&2
        echo "  next action: run sudo systemctl restart apcupsd.service and inspect journalctl -u apcupsd.service" >&2
        failed=1
    fi
    if ! "$SYSTEMCTL" is-enabled --quiet apcupsd.service; then
        echo "root-required activation drift: apcupsd.service is not enabled" >&2
        echo "  next action: run sudo systemctl enable --now apcupsd.service" >&2
        failed=1
    fi
    loaded_upower_action="$("$BUSCTL" call org.freedesktop.UPower /org/freedesktop/UPower org.freedesktop.UPower GetCriticalAction 2>/dev/null || true)"
    if [ "$loaded_upower_action" != 's "Ignore"' ]; then
        echo "root-required activation drift: UPower loaded critical action is ${loaded_upower_action:-unavailable}, expected Ignore" >&2
        echo "  next action: run sudo systemctl restart upower.service and scripts/install-apcupsd-power-alerts --verify-live" >&2
        failed=1
    fi
    if ! "$SYSTEMCTL" is-enabled --quiet earlyoom.service; then
        echo "root-required activation drift: earlyoom.service is not enabled" >&2
        echo "  next action: run sudo systemctl enable --now earlyoom.service" >&2
        failed=1
    fi
    if ! "$SYSTEMCTL" is-active --quiet earlyoom.service; then
        echo "root-required activation drift: earlyoom.service is not active" >&2
        echo "  next action: run sudo systemctl enable --now earlyoom.service and inspect journalctl -u earlyoom.service" >&2
        failed=1
    fi
    for timer in hapax-oom-policy-audit.timer hapax-root-required-deploy-audit.timer; do
        if ! "$SYSTEMCTL" --user is-enabled --quiet "$timer"; then
            echo "root-required activation drift: $timer is not enabled" >&2
            echo "  next action: run systemctl --user enable --now $timer" >&2
            failed=1
        fi
        if ! "$SYSTEMCTL" --user is-active --quiet "$timer"; then
            echo "root-required activation drift: $timer is not active" >&2
            echo "  next action: run systemctl --user enable --now $timer" >&2
            failed=1
        fi
    done
    [ "$failed" -eq 0 ]
}

audit_apcupsd_loaded_policy() {
    local status spec config_key status_key expected actual source_config failed=0
    source_config="$INSTALLED_SOURCE_ROOT/config/apcupsd/apcupsd.conf"
    status="$("$APCACCESS" status 2>/dev/null)" || {
        echo "root-required activation drift: unable to query apcupsd loaded shutdown policy" >&2
        echo "  next action: inspect systemctl status apcupsd.service and run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
        return 1
    }
    for spec in BATTERYLEVEL:MBATTCHG MINUTES:MINTIMEL TIMEOUT:MAXTIME; do
        config_key="${spec%%:*}"
        status_key="${spec##*:}"
        expected="$(awk -v key="$config_key" '$1 == key {print $2; exit}' "$source_config" 2>/dev/null || true)"
        actual="$(printf '%s\n' "$status" | awk -F: -v key="$status_key" '
            {
                name = $1
                gsub(/[[:space:]]/, "", name)
                if (name == key) {
                    value = $2
                    sub(/^[[:space:]]*/, "", value)
                    split(value, fields, /[[:space:]]+/)
                    print fields[1]
                    exit
                }
            }
        ')"
        if [ -z "$expected" ] || [ "$actual" != "$expected" ]; then
            echo "root-required activation drift: apcupsd loaded $status_key=${actual:-unavailable}, expected $expected from $config_key" >&2
            echo "  next action: run sudo systemctl restart apcupsd.service and scripts/install-apcupsd-power-alerts --verify-live" >&2
            failed=1
        fi
    done
    [ "$failed" -eq 0 ]
}

audit_root_installs() {
    local -a manifest=(
        "scripts/hapax-oom-score-enforce|$OOM_ENFORCER_DEST"
        "scripts/hapax-oom-score-trigger|$OOM_TRIGGER_DEST"
        "config/root-required/hapax-oom-score-enforce.sudoers|$OOM_SUDOERS_DEST"
        "scripts/hapax-root-failure-intake|$ROOT_FAILURE_INTAKE_DEST"
        "scripts/hapax-oom-policy-audit|$OOM_POLICY_AUDIT_DEST"
        "scripts/hapax-root-required-deploy-audit|$ROOT_REQUIRED_AUDIT_DEST"
        "config/earlyoom/default|$EARLYOOM_DEST"
        "systemd/system/system.slice.d/oom-containment.conf|$SYSTEMD_SYSTEM_DIR/system.slice.d/oom-containment.conf"
        "systemd/system/user.slice.d/oom-containment.conf|$SYSTEMD_SYSTEM_DIR/user.slice.d/oom-containment.conf"
        "systemd/system/user-1000.slice.d/oom-containment.conf|$SYSTEMD_SYSTEM_DIR/user-1000.slice.d/oom-containment.conf"
        "systemd/system/user@1000.service.d/oom.conf|$SYSTEMD_SYSTEM_DIR/user@1000.service.d/oom.conf"
        "systemd/system/apcupsd.service.d/oom-protect.conf|$SYSTEMD_SYSTEM_DIR/apcupsd.service.d/oom-protect.conf"
        "systemd/system/systemd-logind.service.d/oom-protect.conf|$SYSTEMD_SYSTEM_DIR/systemd-logind.service.d/oom-protect.conf"
        "systemd/system/systemd-resolved.service.d/oom-protect.conf|$SYSTEMD_SYSTEM_DIR/systemd-resolved.service.d/oom-protect.conf"
        "systemd/system/systemd-timesyncd.service.d/oom-protect.conf|$SYSTEMD_SYSTEM_DIR/systemd-timesyncd.service.d/oom-protect.conf"
        "systemd/system/NetworkManager.service.d/oom-protect.conf|$SYSTEMD_SYSTEM_DIR/NetworkManager.service.d/oom-protect.conf"
        "systemd/system/dbus-broker.service.d/oom-protect.conf|$SYSTEMD_SYSTEM_DIR/dbus-broker.service.d/oom-protect.conf"
        "systemd/system/sshd.service.d/oom-protect.conf|$SYSTEMD_SYSTEM_DIR/sshd.service.d/oom-protect.conf"
        "systemd/units/hapax-root-failure-intake@.service|$SYSTEMD_SYSTEM_DIR/hapax-root-failure-intake@.service"
        "systemd/units/hapax-oom-score-enforce.service|$SYSTEMD_SYSTEM_DIR/hapax-oom-score-enforce.service"
        "systemd/units/hapax-oom-score-enforce.timer|$SYSTEMD_SYSTEM_DIR/hapax-oom-score-enforce.timer"
        "systemd/units/hapax-oom-policy-audit.service|$SYSTEMD_USER_DIR/hapax-oom-policy-audit.service"
        "systemd/units/hapax-oom-policy-audit.timer|$SYSTEMD_USER_DIR/hapax-oom-policy-audit.timer"
        "systemd/units/hapax-root-required-deploy-audit.service|$SYSTEMD_USER_DIR/hapax-root-required-deploy-audit.service"
        "systemd/units/hapax-root-required-deploy-audit.timer|$SYSTEMD_USER_DIR/hapax-root-required-deploy-audit.timer"
        "systemd/units/app.slice.d/oom-containment.conf|$SYSTEMD_USER_DIR/app.slice.d/oom-containment.conf"
        "systemd/units/pipewire.service.d/oom-protect.conf|$SYSTEMD_USER_DIR/pipewire.service.d/oom-protect.conf"
        "systemd/units/pipewire-pulse.service.d/oom-protect.conf|$SYSTEMD_USER_DIR/pipewire-pulse.service.d/oom-protect.conf"
        "systemd/units/wireplumber.service.d/oom-protect.conf|$SYSTEMD_USER_DIR/wireplumber.service.d/oom-protect.conf"
        "systemd/units/hapax-daimonion.service.d/oom-protect.conf|$SYSTEMD_USER_DIR/hapax-daimonion.service.d/oom-protect.conf"
        "systemd/units/studio-compositor.service.d/oom-protect.conf|$SYSTEMD_USER_DIR/studio-compositor.service.d/oom-protect.conf"
        "systemd/units/hapax-imagination.service.d/oom-protect.conf|$SYSTEMD_USER_DIR/hapax-imagination.service.d/oom-protect.conf"
        "config/apcupsd/apcupsd.conf|$APCUPSD_DEST/apcupsd.conf"
        "config/apcupsd/hapax-power-event.py|$APCUPSD_DEST/hapax-power-event.py"
        "config/apcupsd/onbattery|$APCUPSD_DEST/onbattery"
        "config/apcupsd/offbattery|$APCUPSD_DEST/offbattery"
        "config/apcupsd/doshutdown|$APCUPSD_DEST/doshutdown"
        "config/upower/90-hapax-apcupsd-owner.conf|$UPOWER_CONF_DEST"
        "systemd/logrotate.d/hapax-ups-power-events|$APCUPSD_LOGROTATE_DEST"
    )
    local entry rel dest failed=0
    for entry in "${manifest[@]}"; do
        rel="${entry%%|*}"
        dest="${entry#*|}"
        compare_root_file "$rel" "$dest" || failed=1
        case "$rel" in
            scripts/hapax-oom-score-enforce|scripts/hapax-oom-score-trigger|scripts/hapax-root-failure-intake|scripts/hapax-oom-policy-audit|scripts/hapax-root-required-deploy-audit|config/apcupsd/hapax-power-event.py|config/apcupsd/onbattery|config/apcupsd/offbattery|config/apcupsd/doshutdown)
                verify_executable "$rel" "$dest" || failed=1
                ;;
        esac
    done
    if ! "$VISUDO" -cf "$OOM_SUDOERS_DEST" >/dev/null; then
        echo "root-required install drift: sudoers policy does not parse: $OOM_SUDOERS_DEST" >&2
        echo "  next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
        failed=1
    fi
    audit_systemd_state || failed=1
    audit_apcupsd_loaded_policy || failed=1
    [ "$failed" -eq 0 ]
}

mapfile -t runbooks < <(pending_runbooks)
if [ "${#runbooks[@]}" -eq 0 ]; then
    audit_desired_receipt "oom-containment" || rc=1
    audit_desired_receipt "apcupsd-power-alerts" || rc=1
    audit_package_receipt "oom-containment" "${oom_package_files[@]}" || rc=1
    audit_package_receipt "apcupsd-power-alerts" "${apcupsd_package_files[@]}" || rc=1
    audit_root_installs || rc=1
    if [ "$rc" -ne 0 ]; then
        exit "$rc"
    fi
    echo "root-required post-merge deploy deferrals: none"
    exit 0
fi

echo "root-required post-merge deploy deferrals pending (${#runbooks[@]}):" >&2
for runbook in "${runbooks[@]}"; do
    dir="$(dirname "$runbook")"
    command="$(awk '/^  .*--install --verify-live$/ {sub(/^  /, ""); print; exit}' "$runbook")"
    echo "  $dir" >&2
    if [ -n "$command" ]; then
        echo "    next action: $command" >&2
    else
        echo "    next action: inspect $runbook and run the root-required installer" >&2
    fi
done
exit 1
