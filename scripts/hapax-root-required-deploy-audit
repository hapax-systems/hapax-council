mkdir -p "$ROOT_DEFER_DIR"
reexec_with_safe_root_required_lock

rc=0

pending_runbooks() {
    [ -d "$ROOT_DEFER_DIR" ] || return 0
    find "$ROOT_DEFER_DIR" -mindepth 3 -maxdepth 3 -name RUNBOOK.txt -type f | sort
}

source_for_rel() {
    local rel="$1"
    printf '%s/%s\n' "$INSTALLED_SOURCE_ROOT" "$rel"
}

audit_package_receipt() {
    local label="$1" receipt sha rel failed=0
    shift
    receipt="$INSTALLED_RECEIPT_ROOT/$label.sha"
    if [ ! -f "$receipt" ]; then
        echo "root-required installed receipt missing: $receipt" >&2
        echo "  next action: rerun the newest governed $label installer package" >&2
        return 1
    fi
    sha="$(tr -d '[:space:]' < "$receipt")"
    if ! [[ "$sha" =~ ^[0-9a-f]{40}$ ]] || ! git -C "$ROOT_REQUIRED_GIT_REPO" cat-file -e "$sha^{commit}" 2>/dev/null; then
        echo "root-required installed receipt is invalid or unavailable: $receipt sha=$sha" >&2
        echo "  next action: fetch the installed commit into $ROOT_REQUIRED_GIT_REPO and rerun the newest governed $label installer package" >&2
        return 1
    fi
    for rel in "$@"; do
        case "$rel" in
            config/root-required/*.files)
                if ! git -C "$ROOT_REQUIRED_GIT_REPO" cat-file -e "$sha:$rel" 2>/dev/null; then
                    if [ ! -e "$INSTALLED_SOURCE_ROOT/$rel" ]; then
                        continue
                    fi
                    echo "root-required installed manifest is not bound to legacy $label receipt $sha: $INSTALLED_SOURCE_ROOT/$rel" >&2
                    echo "  next action: rerun the newest governed $label installer package" >&2
                    failed=1
                    continue
                fi
                ;;
        esac
        if [ ! -f "$INSTALLED_SOURCE_ROOT/$rel" ] \
            || [ -L "$INSTALLED_SOURCE_ROOT/$rel" ] \
            || ! cmp -s <(git -C "$ROOT_REQUIRED_GIT_REPO" show "$sha:$rel") "$INSTALLED_SOURCE_ROOT/$rel"; then
            echo "root-required installed source is not bound to $label receipt $sha: $INSTALLED_SOURCE_ROOT/$rel" >&2
            echo "  next action: rerun the newest governed $label installer package from an exact staged RUNBOOK" >&2
            failed=1
        fi
    done
    [ "$failed" -eq 0 ]
}

audit_desired_receipt() {
    local label="$1" desired installed desired_sha installed_sha
    desired="$DESIRED_RECEIPT_ROOT/$label.sha"
    installed="$INSTALLED_RECEIPT_ROOT/$label.sha"
    if [ ! -f "$desired" ]; then
        echo "root-required desired receipt missing: $desired" >&2
        echo "  next action: rerun hapax-post-merge-deploy for current main or the newest governed $label installer" >&2
        return 1
    fi
    desired_sha="$(tr -d '[:space:]' < "$desired")"
    if ! [[ "$desired_sha" =~ ^[0-9a-f]{40}$ ]] || ! git -C "$ROOT_REQUIRED_GIT_REPO" cat-file -e "$desired_sha^{commit}" 2>/dev/null; then
        echo "root-required desired receipt is invalid or unavailable: $desired sha=$desired_sha" >&2
        echo "  next action: fetch the desired commit into $ROOT_REQUIRED_GIT_REPO and rerun hapax-post-merge-deploy" >&2
        return 1
    fi
    installed_sha=""
    if [ -f "$installed" ]; then
        installed_sha="$(tr -d '[:space:]' < "$installed")"
    fi
    if [ "$installed_sha" != "$desired_sha" ]; then
        echo "root-required desired package is not installed: $label desired=$desired_sha installed=${installed_sha:-missing}" >&2
        echo "  next action: regenerate the exact package from $desired_sha and run its governed installer, even if the cached RUNBOOK was lost" >&2
        return 1
    fi
}

compare_root_file() {
    local rel="$1" dest="$2" mode_override="${3:-}" source expected_mode actual_mode
    source="$(source_for_rel "$rel")"
    if [ ! -f "$source" ] || [ -L "$source" ]; then
        echo "root-required source missing or not a regular stable copy: $source" >&2
        echo "  next action: rerun the owning root installer to refresh the receipt-bound snapshot at $INSTALLED_SOURCE_ROOT" >&2
        return 1
    fi
    if [ ! -f "$dest" ] || [ -L "$dest" ]; then
        echo "root-required install missing or not a regular stable copy: $dest" >&2
        case "$rel" in
            config/apcupsd/*|config/upower/*|systemd/logrotate.d/hapax-ups-power-events)
                echo "  next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
                ;;
            *)
                echo "  next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
                ;;
        esac
        return 1
    fi
    expected_mode="${mode_override:-$(expected_install_mode "$rel")}"
    actual_mode="$(stat -c '%a' "$dest" 2>/dev/null || true)"
    if [ "$actual_mode" != "$expected_mode" ]; then
        echo "root-required install mode drift: $dest mode=${actual_mode:-unavailable} expected=$expected_mode" >&2
        case "$rel" in
            config/apcupsd/*|config/upower/*|systemd/logrotate.d/hapax-ups-power-events)
                echo "  next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
                ;;
            *)
                echo "  next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
                ;;
        esac
        return 1
    fi
    if [ "$dest" = "$OOM_SUDOERS_DEST" ]; then
        "$SUDO" -n "$CMP" -s "$OOM_SUDOERS_REFERENCE_DEST" "$dest"
    else
        cmp -s "$source" "$dest"
    fi || {
        echo "root-required install drift: $dest differs from $source" >&2
        case "$rel" in
            config/apcupsd/*|config/upower/*|systemd/logrotate.d/hapax-ups-power-events)
                echo "  next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
                ;;
            *)
                echo "  next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
                ;;
        esac
        return 1
    }
}

audit_root_artifact_trust() {
    local path="$1" expected_uid expected_gid actual parent parent_actual parent_mode
    case "$path" in
        "$SYSTEMD_USER_DIR"/*)
            return 0
            ;;
        /etc/*|/usr/local/*)
            expected_uid=0
            expected_gid=0
            ;;
        *)
            expected_uid="$ROOT_ARTIFACT_TEST_UID"
            expected_gid="$ROOT_ARTIFACT_TEST_GID"
            ;;
    esac
    actual="$(stat -c '%u:%g' "$path" 2>/dev/null || true)"
    if [ "$actual" != "$expected_uid:$expected_gid" ]; then
        echo "root-required root-artifact ownership drift: $path owner=${actual:-unavailable} expected=$expected_uid:$expected_gid" >&2
        echo "  next action: rerun the owning installer as the target account after sudo -v" >&2
        return 1
    fi
    parent="$(dirname "$path")"
    if [ ! -d "$parent" ] || [ -L "$parent" ]; then
        echo "root-required root-artifact parent is missing, symlinked, or not a directory: $parent" >&2
        echo "  next action: repair the root-owned destination directory and rerun the owning installer" >&2
        return 1
    fi
    parent_actual="$(stat -c '%u:%g' "$parent" 2>/dev/null || true)"
    parent_mode="$(stat -c '%a' "$parent" 2>/dev/null || true)"
    if [ "$parent_actual" != "$expected_uid:$expected_gid" ] \
        || ! [[ "$parent_mode" =~ ^[0-7]+$ ]] \
        || (( (8#$parent_mode & 8#022) != 0 )); then
        echo "root-required root-artifact parent trust drift: $parent owner/mode=${parent_actual:-unavailable}:${parent_mode:-unavailable} expected=$expected_uid:$expected_gid and no group/other write bits" >&2
        echo "  next action: repair the root-owned destination directory and rerun the owning installer" >&2
        return 1
    fi
}

audit_sudoers_trust() {
    local path="$1" expected_mode="$2" label="$3" actual failed=0
    if [ ! -f "$path" ] || [ -L "$path" ]; then
        echo "root-required $label missing or not a regular stable copy: $path" >&2
        echo "  next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    fi
    actual="$(stat -c '%u:%g:%a' "$path" 2>/dev/null || true)"
    if [ "$actual" != "$OOM_SUDOERS_OWNER_UID:$OOM_SUDOERS_OWNER_GID:$expected_mode" ]; then
        echo "root-required $label ownership/mode drift: $path owner/mode=${actual:-unavailable} expected=$OOM_SUDOERS_OWNER_UID:$OOM_SUDOERS_OWNER_GID:$expected_mode" >&2
        echo "  next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
        failed=1
    fi
    if [ "$path" = "$OOM_SUDOERS_REFERENCE_DEST" ] \
        && [ "$OOM_SUDOERS_REFERENCE_DEST" = "/usr/local/share/hapax/root-required/hapax-oom-score-enforce.sudoers" ]; then
        for path in /usr/local/share/hapax /usr/local/share/hapax/root-required; do
            actual="$(stat -c '%u:%g:%a:%F' "$path" 2>/dev/null || true)"
            if [ -L "$path" ] || [ "$actual" != "0:0:755:directory" ]; then
                echo "root-required sudoers reference directory trust drift: $path owner/mode/type=${actual:-unavailable} expected=0:0:755:directory" >&2
                echo "  next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
                failed=1
            fi
        done
    fi
    return "$failed"
}

expected_install_mode() {
    case "$1" in
        config/root-required/hapax-oom-score-enforce.sudoers)
            printf '440\n'
            ;;
        scripts/hapax-oom-score-enforce|scripts/hapax-oom-score-trigger|scripts/hapax-root-failure-intake|scripts/hapax-oom-policy-audit|scripts/hapax-root-required-deploy-audit|config/apcupsd/hapax-power-event.py|config/apcupsd/onbattery|config/apcupsd/offbattery|config/apcupsd/doshutdown)
            printf '755\n'
            ;;
        *)
            printf '644\n'
            ;;
    esac
}

verify_executable() {
    local rel="$1" dest="$2"
    [ -x "$dest" ] || {
        echo "root-required executable mode drift: $dest is not executable" >&2
        case "$rel" in
            config/apcupsd/*)
                echo "  next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
                ;;
            *)
                echo "  next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
                ;;
        esac
        return 1
    }
}

installed_unit_value() {
    local rel="$1" key="$2"
    awk -v key="$key" '$0 ~ "^" key "=" {sub(/^[^=]*=/, ""); print; exit}' \
        "$INSTALLED_SOURCE_ROOT/$rel" 2>/dev/null || true
}

loaded_unit_property() {
    local manager="$1" unit="$2" property="$3"
    if [ "$manager" = "user" ]; then
        "$SYSTEMCTL" --user show "$unit" -p "$property" --value 2>/dev/null
    else
        "$SYSTEMCTL" show "$unit" -p "$property" --value 2>/dev/null
    fi
}

audit_effective_service_unit() {
    local manager="$1" unit="$2" rel="$3" expected_fragment="$4"
    local expected_exec expected_failure expected_user actual_fragment actual_dropins
    local actual_exec actual_failure actual_user
    expected_exec="$(installed_unit_value "$rel" ExecStart)"
    expected_failure="$(installed_unit_value "$rel" OnFailure)"
    expected_failure="${expected_failure//%n/$unit}"
    expected_user="$(installed_unit_value "$rel" User)"
    actual_fragment="$(loaded_unit_property "$manager" "$unit" FragmentPath)" || actual_fragment=""
    actual_dropins="$(loaded_unit_property "$manager" "$unit" DropInPaths)" || actual_dropins="query-error"
    actual_exec="$(loaded_unit_property "$manager" "$unit" ExecStart)" || actual_exec=""
    actual_failure="$(loaded_unit_property "$manager" "$unit" OnFailure)" || actual_failure="query-error"
    actual_user="$(loaded_unit_property "$manager" "$unit" User)" || actual_user="query-error"
    if [ -z "$expected_exec" ] || [ "$actual_fragment" != "$expected_fragment" ] \
        || [ -n "$actual_dropins" ]; then
        echo "root-required effective $unit unit-source drift: FragmentPath=${actual_fragment:-unavailable} DropInPaths=${actual_dropins:-none} expected FragmentPath=$expected_fragment and no drop-ins" >&2
        echo "  next action: remove unauthorized overrides, reload the manager, and run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    fi
    case "$actual_exec" in
        *"argv[]=$expected_exec ;"*) ;;
        *)
            echo "root-required effective $unit ExecStart drift: actual=${actual_exec:-unavailable} expected=$expected_exec" >&2
            echo "  next action: remove unauthorized overrides, reload the manager, and run scripts/install-p0-oom-containment --install --verify-live" >&2
            return 1
            ;;
    esac
    if [ "$actual_failure" != "$expected_failure" ] || [ "$actual_user" != "$expected_user" ]; then
        echo "root-required effective $unit failure/identity drift: OnFailure=${actual_failure:-none} User=${actual_user:-default} expected OnFailure=${expected_failure:-none} User=${expected_user:-default}" >&2
        echo "  next action: remove unauthorized overrides, reload the manager, and run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    fi
}

audit_effective_failure_intake_unit() {
    local unit="hapax-root-failure-intake@hapax-oom-score-enforce.service.service"
    local instance="hapax-oom-score-enforce.service"
    local rel="systemd/units/hapax-root-failure-intake@.service"
    local expected_fragment="$SYSTEMD_SYSTEM_DIR/hapax-root-failure-intake@.service"
    local expected_exec expected_user expected_environment expected_interval expected_burst
    local actual_fragment actual_dropins actual_exec actual_user actual_environment
    local actual_interval actual_burst
    expected_exec="$(installed_unit_value "$rel" ExecStart)"
    expected_exec="${expected_exec//%i/$instance}"
    expected_user="$(installed_unit_value "$rel" User)"
    expected_environment="$(installed_unit_value "$rel" Environment)"
    expected_interval="$(installed_unit_value "$rel" StartLimitIntervalSec)"
    expected_burst="$(installed_unit_value "$rel" StartLimitBurst)"
    actual_fragment="$(loaded_unit_property system "$unit" FragmentPath)" || actual_fragment=""
    actual_dropins="$(loaded_unit_property system "$unit" DropInPaths)" || actual_dropins="query-error"
    actual_exec="$(loaded_unit_property system "$unit" ExecStart)" || actual_exec=""
    actual_user="$(loaded_unit_property system "$unit" User)" || actual_user="query-error"
    actual_environment="$(loaded_unit_property system "$unit" Environment)" || actual_environment="query-error"
    actual_interval="$(loaded_unit_property system "$unit" StartLimitIntervalUSec)" || actual_interval="query-error"
    actual_burst="$(loaded_unit_property system "$unit" StartLimitBurst)" || actual_burst="query-error"
    if [ -z "$expected_exec" ] || [ -z "$expected_user" ] || [ -z "$expected_environment" ] \
        || [ -z "$expected_interval" ] || [ -z "$expected_burst" ] \
        || [ "$actual_fragment" != "$expected_fragment" ] || [ -n "$actual_dropins" ]; then
        echo "root-required effective $unit unit-source drift: FragmentPath=${actual_fragment:-unavailable} DropInPaths=${actual_dropins:-none} expected FragmentPath=$expected_fragment and no drop-ins" >&2
        echo "  next action: remove unauthorized template or instance overrides, reload the manager, and run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    fi
    case "$actual_exec" in
        *"argv[]=$expected_exec ;"*) ;;
        *)
            echo "root-required effective $unit ExecStart drift: actual=${actual_exec:-unavailable} expected=$expected_exec" >&2
            echo "  next action: remove unauthorized template or instance overrides, reload the manager, and run scripts/install-p0-oom-containment --install --verify-live" >&2
            return 1
            ;;
    esac
    if [ "$actual_user" != "$expected_user" ] || [ "$actual_environment" != "$expected_environment" ] \
        || [ "$actual_interval" != "$expected_interval" ] || [ "$actual_burst" != "$expected_burst" ]; then
        echo "root-required effective $unit identity/limit drift: User=${actual_user:-default} Environment=${actual_environment:-none} StartLimitIntervalUSec=${actual_interval:-none} StartLimitBurst=${actual_burst:-none} expected User=$expected_user Environment=$expected_environment StartLimitIntervalUSec=$expected_interval StartLimitBurst=$expected_burst" >&2
        echo "  next action: remove unauthorized template or instance overrides, reload the manager, and run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    fi
}

audit_effective_timer_unit() {
    local manager="$1" unit="$2" rel="$3" expected_fragment="$4"
    local expected_target expected_boot expected_active actual_fragment actual_dropins
    local actual_target actual_timers
    expected_target="$(installed_unit_value "$rel" Unit)"
    expected_boot="$(installed_unit_value "$rel" OnBootSec)"
    expected_active="$(installed_unit_value "$rel" OnUnitActiveSec)"
    actual_fragment="$(loaded_unit_property "$manager" "$unit" FragmentPath)" || actual_fragment=""
    actual_dropins="$(loaded_unit_property "$manager" "$unit" DropInPaths)" || actual_dropins="query-error"
    actual_target="$(loaded_unit_property "$manager" "$unit" Unit)" || actual_target="query-error"
    actual_timers="$(loaded_unit_property "$manager" "$unit" TimersMonotonic)" || actual_timers="query-error"
    if [ -z "$expected_target" ] || [ -z "$expected_boot" ] || [ -z "$expected_active" ] \
        || [ "$actual_fragment" != "$expected_fragment" ] || [ -n "$actual_dropins" ]; then
        echo "root-required effective $unit unit-source drift: FragmentPath=${actual_fragment:-unavailable} DropInPaths=${actual_dropins:-none} expected FragmentPath=$expected_fragment and no drop-ins" >&2
        echo "  next action: remove unauthorized overrides, reload the manager, and run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    fi
    if [ "$actual_target" != "$expected_target" ]; then
        echo "root-required effective $unit target drift: actual=${actual_target:-unavailable} expected=$expected_target" >&2
        echo "  next action: remove unauthorized overrides, reload the manager, and run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    fi
    case "$actual_timers" in
        *"OnBootUSec=$expected_boot"*"OnUnitActiveUSec=$expected_active"*|*"OnUnitActiveUSec=$expected_active"*"OnBootUSec=$expected_boot"*) ;;
        *)
            echo "root-required effective $unit cadence drift: actual=${actual_timers:-unavailable} expected OnBootUSec=$expected_boot and OnUnitActiveUSec=$expected_active" >&2
            echo "  next action: remove unauthorized overrides, reload the manager, and run scripts/install-p0-oom-containment --install --verify-live" >&2
            return 1
            ;;
    esac
}

audit_effective_safety_units() {
    local failed=0
    audit_effective_service_unit system hapax-oom-score-enforce.service \
        systemd/units/hapax-oom-score-enforce.service \
        "$SYSTEMD_SYSTEM_DIR/hapax-oom-score-enforce.service" || failed=1
    audit_effective_failure_intake_unit || failed=1
    audit_effective_timer_unit system hapax-oom-score-enforce.timer \
        systemd/units/hapax-oom-score-enforce.timer \
        "$SYSTEMD_SYSTEM_DIR/hapax-oom-score-enforce.timer" || failed=1
    audit_effective_service_unit user hapax-oom-policy-audit.service \
        systemd/units/hapax-oom-policy-audit.service \
        "$SYSTEMD_USER_DIR/hapax-oom-policy-audit.service" || failed=1
    audit_effective_timer_unit user hapax-oom-policy-audit.timer \
        systemd/units/hapax-oom-policy-audit.timer \
        "$SYSTEMD_USER_DIR/hapax-oom-policy-audit.timer" || failed=1
    audit_effective_service_unit user hapax-root-required-deploy-audit.service \
        systemd/units/hapax-root-required-deploy-audit.service \
        "$SYSTEMD_USER_DIR/hapax-root-required-deploy-audit.service" || failed=1
    audit_effective_timer_unit user hapax-root-required-deploy-audit.timer \
        systemd/units/hapax-root-required-deploy-audit.timer \
        "$SYSTEMD_USER_DIR/hapax-root-required-deploy-audit.timer" || failed=1
    return "$failed"
}

audit_systemd_state() {
    local failed=0 loaded_upower_action expected_enforcer_timeout loaded_enforcer_timeout
    local spec unit rel expected_audit_timeout loaded_audit_timeout
    local expected_audit_environment loaded_audit_environment
    if ! "$SYSTEMCTL" is-enabled --quiet hapax-oom-score-enforce.timer; then
        echo "root-required activation drift: hapax-oom-score-enforce.timer is not enabled" >&2
        echo "  next action: run sudo systemctl enable --now hapax-oom-score-enforce.timer" >&2
        failed=1
    fi
    if ! "$SYSTEMCTL" is-active --quiet hapax-oom-score-enforce.timer; then
        echo "root-required activation drift: hapax-oom-score-enforce.timer is not active" >&2
        echo "  next action: run sudo systemctl enable --now hapax-oom-score-enforce.timer" >&2
        failed=1
    fi
    expected_enforcer_timeout="$(awk -F= '$1 == "TimeoutStartSec" {print $2; exit}' "$INSTALLED_SOURCE_ROOT/systemd/units/hapax-oom-score-enforce.service" 2>/dev/null || true)"
    if ! loaded_enforcer_timeout="$("$SYSTEMCTL" show hapax-oom-score-enforce.service -p TimeoutStartUSec --value 2>/dev/null)"; then
        loaded_enforcer_timeout=""
    fi
    if [ -z "$expected_enforcer_timeout" ] || [ "$loaded_enforcer_timeout" != "$expected_enforcer_timeout" ]; then
        echo "root-required activation drift: hapax-oom-score-enforce.service loaded TimeoutStartUSec=${loaded_enforcer_timeout:-unavailable}, expected ${expected_enforcer_timeout:-source value missing}" >&2
        echo "  next action: run sudo systemctl daemon-reload and scripts/install-p0-oom-containment --install --verify-live" >&2
        failed=1
    fi
    if ! "$SYSTEMCTL" is-active --quiet apcupsd.service; then
        echo "root-required activation drift: apcupsd.service is not active" >&2
        echo "  next action: run sudo systemctl restart apcupsd.service and inspect journalctl -u apcupsd.service" >&2
        failed=1
    fi
    if ! "$SYSTEMCTL" is-enabled --quiet apcupsd.service; then
        echo "root-required activation drift: apcupsd.service is not enabled" >&2
        echo "  next action: run sudo systemctl enable --now apcupsd.service" >&2
        failed=1
    fi
    loaded_upower_action="$("$BUSCTL" call org.freedesktop.UPower /org/freedesktop/UPower org.freedesktop.UPower GetCriticalAction 2>/dev/null || true)"
    if [ "$loaded_upower_action" != 's "Ignore"' ]; then
        echo "root-required activation drift: UPower loaded critical action is ${loaded_upower_action:-unavailable}, expected Ignore" >&2
        echo "  next action: run sudo systemctl restart upower.service and scripts/install-apcupsd-power-alerts --verify-live" >&2
        failed=1
    fi
    if ! "$SYSTEMCTL" is-enabled --quiet earlyoom.service; then
        echo "root-required activation drift: earlyoom.service is not enabled" >&2
        echo "  next action: run sudo systemctl enable --now earlyoom.service" >&2
        failed=1
    fi
    if ! "$SYSTEMCTL" is-active --quiet earlyoom.service; then
        echo "root-required activation drift: earlyoom.service is not active" >&2
        echo "  next action: run sudo systemctl enable --now earlyoom.service and inspect journalctl -u earlyoom.service" >&2
        failed=1
    fi
    for timer in hapax-oom-policy-audit.timer hapax-root-required-deploy-audit.timer; do
        if ! "$SYSTEMCTL" --user is-enabled --quiet "$timer"; then
            echo "root-required activation drift: $timer is not enabled" >&2
            echo "  next action: run systemctl --user enable --now $timer" >&2
            failed=1
        fi
        if ! "$SYSTEMCTL" --user is-active --quiet "$timer"; then
            echo "root-required activation drift: $timer is not active" >&2
            echo "  next action: run systemctl --user enable --now $timer" >&2
            failed=1
        fi
    done
    for spec in \
        "hapax-oom-policy-audit.service|systemd/units/hapax-oom-policy-audit.service" \
        "hapax-root-required-deploy-audit.service|systemd/units/hapax-root-required-deploy-audit.service"; do
        unit="${spec%%|*}"
        rel="${spec#*|}"
        expected_audit_timeout="$(awk -F= '$1 == "TimeoutStartSec" {print $2; exit}' "$INSTALLED_SOURCE_ROOT/$rel" 2>/dev/null || true)"
        if ! loaded_audit_timeout="$("$SYSTEMCTL" --user show "$unit" -p TimeoutStartUSec --value 2>/dev/null)"; then
            loaded_audit_timeout=""
        fi
        if [ -z "$expected_audit_timeout" ] || [ "$loaded_audit_timeout" != "$expected_audit_timeout" ]; then
            echo "root-required activation drift: $unit loaded TimeoutStartUSec=${loaded_audit_timeout:-unavailable}, expected ${expected_audit_timeout:-source value missing}" >&2
            echo "  next action: run systemctl --user daemon-reload and scripts/install-p0-oom-containment --install --verify-live" >&2
            failed=1
        fi
        expected_audit_environment="$(awk '$0 ~ /^Environment=/ {sub(/^[^=]*=/, ""); print; exit}' "$INSTALLED_SOURCE_ROOT/$rel" 2>/dev/null || true)"
        if ! loaded_audit_environment="$("$SYSTEMCTL" --user show "$unit" -p Environment --value 2>/dev/null)"; then
            loaded_audit_environment=""
        fi
        case " $loaded_audit_environment " in
            *" $expected_audit_environment "*)
                [ -n "$expected_audit_environment" ] || {
                    echo "root-required activation drift: $unit source Environment is missing" >&2
                    echo "  next action: restore the receipt-bound unit and run scripts/install-p0-oom-containment --install --verify-live" >&2
                    failed=1
                }
                ;;
            *)
                echo "root-required activation drift: $unit loaded Environment=${loaded_audit_environment:-unavailable}, expected to contain ${expected_audit_environment:-source value missing}" >&2
                echo "  next action: run systemctl --user daemon-reload and scripts/install-p0-oom-containment --install --verify-live" >&2
                failed=1
                ;;
        esac
    done
    audit_effective_safety_units || failed=1
    [ "$failed" -eq 0 ]
}

audit_apcupsd_loaded_policy() {
    local status spec config_key status_key expected actual source_config failed=0
    source_config="$INSTALLED_SOURCE_ROOT/config/apcupsd/apcupsd.conf"
    status="$("$APCACCESS" status 2>/dev/null)" || {
        echo "root-required activation drift: unable to query apcupsd loaded shutdown policy" >&2
        echo "  next action: inspect systemctl status apcupsd.service and run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
        return 1
    }
    for spec in BATTERYLEVEL:MBATTCHG MINUTES:MINTIMEL TIMEOUT:MAXTIME; do
        config_key="${spec%%:*}"
        status_key="${spec##*:}"
        expected="$(awk -v key="$config_key" '$1 == key {print $2; exit}' "$source_config" 2>/dev/null || true)"
        actual="$(printf '%s\n' "$status" | awk -F: -v key="$status_key" '
            {
                name = $1
                gsub(/[[:space:]]/, "", name)
                if (name == key) {
                    value = $2
                    sub(/^[[:space:]]*/, "", value)
                    split(value, fields, /[[:space:]]+/)
                    print fields[1]
                    exit
                }
            }
        ')"
        if [ -z "$expected" ] || [ "$actual" != "$expected" ]; then
            echo "root-required activation drift: apcupsd loaded $status_key=${actual:-unavailable}, expected $expected from $config_key" >&2
            echo "  next action: run sudo systemctl restart apcupsd.service and scripts/install-apcupsd-power-alerts --verify-live" >&2
            failed=1
        fi
    done
    [ "$failed" -eq 0 ]
}

audit_root_installs() {
    local -a manifest=(
        "scripts/hapax-oom-score-enforce|$OOM_ENFORCER_DEST"
        "scripts/hapax-oom-score-trigger|$OOM_TRIGGER_DEST"
        "config/root-required/hapax-oom-score-enforce.sudoers|$OOM_SUDOERS_DEST"
        "scripts/hapax-root-failure-intake|$ROOT_FAILURE_INTAKE_DEST"
