#!/usr/bin/bash
# Fail when post-merge root-required deploy actions were deferred and not drained.
set -euo pipefail
ORIGINAL_ARGS=("$@")
PATH=/usr/local/sbin:/usr/local/bin:/usr/bin:/bin
export PATH

ROOT_DEFER_DIR="${HAPAX_POST_MERGE_ROOT_DEFER_DIR:-$HOME/.cache/hapax/post-merge-root-required}"
# Deferrals are cleared only by the explicit HAPAX_ROOT_REQUIRED_DRAIN_DIR path
# in the owning installer; this audit intentionally never mutates them.
ROOT_REQUIRED_STATE_ROOT="${HAPAX_ROOT_REQUIRED_STATE_ROOT:-$HOME/.local/state/hapax/root-required}"
INSTALLED_SOURCE_ROOT="${HAPAX_ROOT_REQUIRED_INSTALLED_SOURCE_ROOT:-$ROOT_REQUIRED_STATE_ROOT/current-source}"
INSTALLED_RECEIPT_ROOT="${HAPAX_ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT:-$ROOT_REQUIRED_STATE_ROOT/installed-receipts}"
DESIRED_RECEIPT_ROOT="${HAPAX_ROOT_REQUIRED_DESIRED_RECEIPT_ROOT:-$ROOT_REQUIRED_STATE_ROOT/desired-receipts}"
ROOT_REQUIRED_GIT_REPO="${HAPAX_ROOT_REQUIRED_GIT_REPO:-$HOME/.cache/hapax/source-activation/worktree}"
ROOT_REQUIRED_LOCK_FILE="${HAPAX_ROOT_REQUIRED_LOCK_FILE:-$ROOT_REQUIRED_STATE_ROOT/.lock}"
OOM_ENFORCER_DEST="${HAPAX_OOM_ENFORCER_DEST:-/usr/local/sbin/hapax-oom-score-enforce}"
OOM_TRIGGER_DEST="${HAPAX_OOM_TRIGGER_DEST:-/usr/local/bin/hapax-oom-score-trigger}"
OOM_SUDOERS_DEST="${HAPAX_OOM_SUDOERS_DEST:-/etc/sudoers.d/hapax-oom-score-enforce}"
OOM_SUDOERS_REFERENCE_DEST="${HAPAX_OOM_SUDOERS_REFERENCE_DEST:-/usr/local/share/hapax/root-required/hapax-oom-score-enforce.sudoers}"
OOM_SUDOERS_OWNER_UID="${HAPAX_OOM_SUDOERS_OWNER_UID:-0}"
OOM_SUDOERS_OWNER_GID="${HAPAX_OOM_SUDOERS_OWNER_GID:-0}"
if [ "$OOM_SUDOERS_REFERENCE_DEST" = "/usr/local/share/hapax/root-required/hapax-oom-score-enforce.sudoers" ]; then
    OOM_SUDOERS_OWNER_UID=0
    OOM_SUDOERS_OWNER_GID=0
fi
ROOT_FAILURE_INTAKE_DEST="${HAPAX_ROOT_FAILURE_INTAKE_DEST:-/usr/local/sbin/hapax-root-failure-intake}"
OOM_POLICY_AUDIT_DEST="${HAPAX_OOM_POLICY_AUDIT_DEST:-/usr/local/sbin/hapax-oom-policy-audit}"
ROOT_REQUIRED_AUDIT_DEST="${HAPAX_ROOT_REQUIRED_AUDIT_DEST:-/usr/local/sbin/hapax-root-required-deploy-audit}"
EARLYOOM_DEST="${HAPAX_OOM_EARLYOOM_DEST:-/etc/default/earlyoom}"
SYSTEMD_SYSTEM_DIR="${HAPAX_OOM_SYSTEMD_SYSTEM_DIR:-/etc/systemd/system}"
SYSTEMD_USER_DIR="${HAPAX_OOM_SYSTEMD_USER_DIR:-$HOME/.config/systemd/user}"
APCUPSD_DEST="${HAPAX_APCUPSD_DEST:-/etc/apcupsd}"
APCUPSD_AUDIT_LOG="${HAPAX_UPS_AUDIT_LOG:-/var/log/hapax/ups-power-events.jsonl}"
APCUPSD_CANONICAL_AUDIT_LOG="/var/log/hapax/ups-power-events.jsonl"
APCUPSD_CANONICAL_AUDIT_GROUP="hapax"
APCUPSD_AUDIT_LOG_OWNER_UID="${HAPAX_UPS_AUDIT_LOG_OWNER_UID:-}"
APCUPSD_AUDIT_LOG_OWNER_GID="${HAPAX_UPS_AUDIT_LOG_OWNER_GID:-}"
APCUPSD_LOGROTATE_DEST="${HAPAX_APCUPSD_LOGROTATE_DEST:-/etc/logrotate.d/hapax-ups-power-events}"
UPOWER_CONF_DEST="${HAPAX_UPOWER_CONF_DEST:-/etc/UPower/UPower.conf.d/90-hapax-apcupsd-owner.conf}"
SYSTEMCTL="${HAPAX_ROOT_AUDIT_SYSTEMCTL:-/usr/bin/systemctl}"
BUSCTL="${HAPAX_ROOT_AUDIT_BUSCTL:-/usr/bin/busctl}"
APCACCESS="${HAPAX_ROOT_AUDIT_APCACCESS:-/usr/bin/apcaccess}"
CMP="${HAPAX_ROOT_AUDIT_CMP:-/usr/bin/cmp}"
GETENT="${HAPAX_ROOT_AUDIT_GETENT:-/usr/bin/getent}"
SUDO="${HAPAX_ROOT_AUDIT_SUDO:-/usr/bin/sudo}"
VISUDO="${HAPAX_ROOT_AUDIT_VISUDO:-/usr/bin/visudo}"
ROOT_ARTIFACT_TEST_UID="${HAPAX_ROOT_AUDIT_TEST_ROOT_UID:-$(/usr/bin/id -u)}"
ROOT_ARTIFACT_TEST_GID="${HAPAX_ROOT_AUDIT_TEST_ROOT_GID:-$(/usr/bin/id -g)}"

acquire_inherited_root_required_lock() {
    local lock_fd="${HAPAX_ROOT_REQUIRED_LOCK_FD:-}"
    local lock_mode="${HAPAX_ROOT_REQUIRED_LOCK_MODE:-shared}"
    if ! [[ "$lock_fd" =~ ^[0-9]+$ ]] || [ "$lock_fd" -lt 3 ]; then
        echo "root-required audit safe lock descriptor is absent; next action: remove caller-supplied HAPAX_ROOT_REQUIRED_LOCK_* values and rerun the installed audit" >&2
        return 1
    fi
    /usr/bin/python3 - "$lock_fd" "$ROOT_REQUIRED_LOCK_FILE" "$lock_mode" <<'PY'
from __future__ import annotations

import fcntl
import os
import stat
import sys

fd = int(sys.argv[1])
lock_path = sys.argv[2]
lock_mode = sys.argv[3]
try:
    inode = os.fstat(fd)
    path_inode = os.lstat(lock_path)
except OSError as exc:
    print(
        f"root-required audit refused invalid shared lock descriptor for {lock_path}: {exc}; "
        "next action: remove caller-supplied HAPAX_ROOT_REQUIRED_LOCK_* values and rerun",
        file=sys.stderr,
    )
    raise SystemExit(1) from exc
if (
    not stat.S_ISREG(inode.st_mode)
    or not stat.S_ISREG(path_inode.st_mode)
    or (inode.st_dev, inode.st_ino) != (path_inode.st_dev, path_inode.st_ino)
    or inode.st_uid != os.geteuid()
    or inode.st_nlink != 1
    or inode.st_mode & 0o022
):
    print(
        f"root-required audit refused invalid shared lock descriptor for {lock_path}; expected "
        "the caller-owned, single-link, non-group-writable regular path inode; next action: "
        "remove caller-supplied HAPAX_ROOT_REQUIRED_LOCK_* values and rerun",
        file=sys.stderr,
    )
    raise SystemExit(1)
os.fchmod(fd, 0o600)
fcntl.flock(fd, fcntl.LOCK_EX if lock_mode == "exclusive" else fcntl.LOCK_SH)
PY
}

reexec_with_safe_root_required_lock() {
    if [ -n "${HAPAX_ROOT_REQUIRED_LOCK_FD:-}" ]; then
        acquire_inherited_root_required_lock
        return
    fi
    exec /usr/bin/python3 - "$ROOT_REQUIRED_LOCK_FILE" "$0" "${ORIGINAL_ARGS[@]}" <<'PY'
from __future__ import annotations

import fcntl
import os
import stat
import subprocess
import sys

lock_path, script, *args = sys.argv[1:]
os.makedirs(os.path.dirname(lock_path) or ".", exist_ok=True)
try:
    fd = os.open(
        lock_path,
        os.O_CLOEXEC | os.O_CREAT | os.O_NOFOLLOW | os.O_RDWR,
        0o600,
    )
except OSError as exc:
    print(
        f"root-required audit refused unsafe shared lock {lock_path}: {exc}; "
        "next action: remove only a confirmed symlink/non-regular lock and rerun",
        file=sys.stderr,
    )
    raise SystemExit(1) from exc
try:
    inode = os.fstat(fd)
    if (
        not stat.S_ISREG(inode.st_mode)
        or inode.st_uid != os.geteuid()
        or inode.st_nlink != 1
        or inode.st_mode & 0o022
    ):
        print(
            f"root-required audit refused unsafe shared lock inode {lock_path}; expected one "
            "caller-owned, single-link, non-group-writable regular file; next action: remove "
            "only a confirmed unsafe lock and rerun",
            file=sys.stderr,
        )
        raise SystemExit(1)
    os.fchmod(fd, 0o600)
    fcntl.flock(fd, fcntl.LOCK_SH)
    env = os.environ.copy()
    env.pop("HAPAX_ROOT_REQUIRED_LOCK_HELD", None)
    env["HAPAX_ROOT_REQUIRED_LOCK_FD"] = str(fd)
    env["HAPAX_ROOT_REQUIRED_LOCK_MODE"] = "shared"
    result = subprocess.run(
        [os.path.abspath(script), *args],
        env=env,
        pass_fds=(fd,),
        check=False,
    )
    raise SystemExit(result.returncode)
finally:
    os.close(fd)
PY
}

resolve_apcupsd_audit_log_identity() {
    local group_entry required_gid
    if [ "$APCUPSD_AUDIT_LOG" = "$APCUPSD_CANONICAL_AUDIT_LOG" ]; then
        if ! group_entry="$("$GETENT" group "$APCUPSD_CANONICAL_AUDIT_GROUP" 2>/dev/null)" \
            || [ -z "$group_entry" ]; then
            echo "root-required install drift: required UPS audit group missing: $APCUPSD_CANONICAL_AUDIT_GROUP" >&2
            echo "  next action: restore the canonical $APCUPSD_CANONICAL_AUDIT_GROUP group and rerun the installed audit" >&2
            return 1
        fi
        required_gid="$(printf '%s\n' "$group_entry" | /usr/bin/cut -d: -f3)"
        if ! [[ "$required_gid" =~ ^[0-9]+$ ]]; then
            echo "root-required install drift: required UPS audit group has an invalid gid: $APCUPSD_CANONICAL_AUDIT_GROUP" >&2
            echo "  next action: repair the canonical group entry and rerun the installed audit" >&2
            return 1
        fi
        if [ -n "$APCUPSD_AUDIT_LOG_OWNER_UID" ] \
            && [ "$APCUPSD_AUDIT_LOG_OWNER_UID" != "0" ]; then
            echo "root-required install drift: canonical UPS audit log requires owner uid 0, not $APCUPSD_AUDIT_LOG_OWNER_UID" >&2
            echo "  next action: remove HAPAX_UPS_AUDIT_LOG_OWNER_UID or set it to 0, then rerun the installed audit" >&2
            return 1
        fi
        if [ -n "$APCUPSD_AUDIT_LOG_OWNER_GID" ] \
            && [ "$APCUPSD_AUDIT_LOG_OWNER_GID" != "$required_gid" ]; then
            echo "root-required install drift: canonical UPS audit log requires gid $required_gid from group $APCUPSD_CANONICAL_AUDIT_GROUP, not $APCUPSD_AUDIT_LOG_OWNER_GID" >&2
            echo "  next action: remove HAPAX_UPS_AUDIT_LOG_OWNER_GID or set it to the canonical group gid, then rerun the installed audit" >&2
            return 1
        fi
        APCUPSD_AUDIT_LOG_OWNER_UID=0
        APCUPSD_AUDIT_LOG_OWNER_GID="$required_gid"
    fi
    if [ -z "$APCUPSD_AUDIT_LOG_OWNER_UID" ]; then
        if [[ "$APCUPSD_AUDIT_LOG" == /var/log/* ]]; then
            APCUPSD_AUDIT_LOG_OWNER_UID=0
        else
            APCUPSD_AUDIT_LOG_OWNER_UID="$(/usr/bin/id -u)"
        fi
    fi
    if [ -z "$APCUPSD_AUDIT_LOG_OWNER_GID" ]; then
        if [[ "$APCUPSD_AUDIT_LOG" == /var/log/* ]] && "$GETENT" group hapax >/dev/null 2>&1; then
            APCUPSD_AUDIT_LOG_OWNER_GID="$("$GETENT" group hapax | /usr/bin/cut -d: -f3)"
        else
            APCUPSD_AUDIT_LOG_OWNER_GID="$(/usr/bin/id -g)"
        fi
    fi
    if ! [[ "$APCUPSD_AUDIT_LOG_OWNER_UID" =~ ^[0-9]+$ \
        && "$APCUPSD_AUDIT_LOG_OWNER_GID" =~ ^[0-9]+$ ]]; then
        echo "root-required install drift: invalid UPS audit-log owner identity uid=$APCUPSD_AUDIT_LOG_OWNER_UID gid=$APCUPSD_AUDIT_LOG_OWNER_GID" >&2
        echo "  next action: remove invalid HAPAX_UPS_AUDIT_LOG_OWNER_UID/GID overrides and rerun the installed audit" >&2
        return 1
    fi
}

audit_apcupsd_audit_log() {
    local parent_expected_mode=""
    resolve_apcupsd_audit_log_identity || return 1
    if [ "$APCUPSD_AUDIT_LOG" = "$APCUPSD_CANONICAL_AUDIT_LOG" ]; then
        parent_expected_mode=2775
    fi
    /usr/bin/python3 - "$APCUPSD_AUDIT_LOG" \
        "$APCUPSD_AUDIT_LOG_OWNER_UID" "$APCUPSD_AUDIT_LOG_OWNER_GID" \
        "$parent_expected_mode" <<'PY'
from __future__ import annotations

import os
import stat
import sys

path = sys.argv[1]
owner_uid = int(sys.argv[2])
owner_gid = int(sys.argv[3])
parent_expected_mode = int(sys.argv[4], 8) if sys.argv[4] else None
parent = os.path.dirname(path) or "."
try:
    parent_inode = os.lstat(parent)
except OSError as exc:
    print(
        f"root-required install drift: UPS audit log parent missing: {parent}: {exc}",
        file=sys.stderr,
    )
    print(
        "  next action: run scripts/install-apcupsd-power-alerts --install --verify-live",
        file=sys.stderr,
    )
    raise SystemExit(1) from exc
if not stat.S_ISDIR(parent_inode.st_mode) or (
    parent_expected_mode is not None
    and (
        parent_inode.st_uid != owner_uid
        or parent_inode.st_gid != owner_gid
        or stat.S_IMODE(parent_inode.st_mode) != parent_expected_mode
    )
):
    print(
        f"root-required install drift: UPS audit log parent trust drift: {parent} "
        f"owner={parent_inode.st_uid}:{parent_inode.st_gid} "
        f"mode={stat.S_IMODE(parent_inode.st_mode):04o}; expected a lexical non-symlink "
        + (
            f"directory with {owner_uid}:{owner_gid}:{parent_expected_mode:04o}"
            if parent_expected_mode is not None
            else "directory"
        ),
        file=sys.stderr,
    )
    print(
        "  next action: repair the audit-log directory and run "
        "scripts/install-apcupsd-power-alerts --install --verify-live",
        file=sys.stderr,
    )
    raise SystemExit(1)
try:
    inode = os.lstat(path)
except OSError as exc:
    print(f"root-required install drift: UPS audit log missing: {path}: {exc}", file=sys.stderr)
    print(
        "  next action: run scripts/install-apcupsd-power-alerts --install --verify-live",
        file=sys.stderr,
    )
    raise SystemExit(1) from exc
if (
    not stat.S_ISREG(inode.st_mode)
    or inode.st_nlink != 1
    or inode.st_uid != owner_uid
    or inode.st_gid != owner_gid
    or stat.S_IMODE(inode.st_mode) != 0o640
):
    print(
        f"root-required install drift: unsafe UPS audit log {path} "
        f"owner={inode.st_uid}:{inode.st_gid} mode={stat.S_IMODE(inode.st_mode):03o} "
        f"links={inode.st_nlink}; expected {owner_uid}:{owner_gid}:640 with one regular link",
        file=sys.stderr,
    )
    print(
        "  next action: preserve valid content and run "
        "scripts/install-apcupsd-power-alerts --install --verify-live",
        file=sys.stderr,
    )
    raise SystemExit(1)
PY
}

