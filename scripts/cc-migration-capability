#!/usr/bin/env python3
"""cc-migration-capability — mint/check/consume a scoped migration intent
record, and run TTL-guarded bulk backfills of cc-task scaffolding.

NEW-6 (master design section 4.3): bulk-stamping ``stage`` + ``mutation_scope_refs``
across the active task population is a mass mutation. Rather than an env bypass,
it runs under an operator-minted migration record scoped to a namespace and
bounded by TTL. This is not a cryptographic grant: enforcement is the recorded
operator intent, expiry check, per-task audit ledger, and automatic consumption
after ``--apply``.

Subcommands:
  mint --namespace NS [--ttl-minutes N] [--grantor G]
        Mint a migration record scoped to NS; print its id. Default TTL 120 min.
  check --namespace NS
        Exit 0 if an active (unexpired) migration record exists for NS, else 2.
  list  List migration records (active first).
  expire --id ID
        Mark a migration record consumed.
  backfill --namespace NS [--apply] [--stage S6_IMPLEMENTATION]
        Derive or repair ``stage`` across ACTIVE cc-tasks from status:
        offered -> S0_INTAKE, blocked -> S5_REVIEW_GATE,
        claimed/in_progress -> S6_IMPLEMENTATION, ready/pr_open/open/merge_queue
        -> S7_RELEASE. Terminal tasks are left untouched. Also stamps an absent
        ``mutation_scope_refs`` field on non-terminal tasks. Requires a valid
        migration record for NS. Dry-run unless --apply. ``--apply`` emits
        per-task ledger rows and consumes the record.

Coordination reform Phase 2 (CASE-SDLC-REFORM-001).
"""

from __future__ import annotations

import argparse
import json
import re
import secrets
import stat
import sys
from datetime import UTC, datetime, timedelta
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))
from shared.sdlc_filesystem_transaction import (  # noqa: E402
    FilesystemTransactionError,
    replace_task_note_transactionally,
)

CAP_DIR = Path.home() / ".cache" / "hapax" / "migration-capabilities"
LEDGER = CAP_DIR / "ledger.jsonl"
VAULT_ACTIVE = Path.home() / "Documents" / "Personal" / "20-projects" / "hapax-cc-tasks" / "active"
OWNERSHIP_CACHE = Path.home() / ".cache" / "hapax"
_NULLISH = {"", "null", "none", "~", "[]"}
TERMINAL_STATUSES = frozenset({"closed", "completed", "done", "superseded", "withdrawn"})
RELEASE_STATUSES = frozenset({"merge_queue", "open", "pr_open", "ready"})
IMPLEMENTATION_STATUSES = frozenset({"claimed", "in_progress"})
PRE_IMPLEMENTATION_STAGES = {
    "offered": "S0_INTAKE",
    "blocked": "S5_REVIEW_GATE",
}


def _now() -> datetime:
    return datetime.now(UTC)


def _iso(dt: datetime) -> str:
    return dt.strftime("%Y-%m-%dT%H:%M:%SZ")


def _ledger(record: dict) -> None:
    CAP_DIR.mkdir(parents=True, exist_ok=True)
    with LEDGER.open("a", encoding="utf-8") as h:
        h.write(json.dumps(record, sort_keys=True) + "\n")


def _load_caps() -> list[dict]:
    caps: list[dict] = []
    if not CAP_DIR.is_dir():
        return caps
    for p in sorted(CAP_DIR.glob("*.json")):
        try:
            caps.append(json.loads(p.read_text(encoding="utf-8")))
        except (json.JSONDecodeError, OSError):
            continue
    return caps


def _cap_path(cap_id: str) -> Path:
    return CAP_DIR / f"{cap_id}.json"


def _active_cap(namespace: str) -> dict | None:
    now = _now()
    for cap in _load_caps():
        if cap.get("namespace") != namespace or cap.get("status") != "active":
            continue
        try:
            expires = datetime.fromisoformat(cap["expires_at"].replace("Z", "+00:00"))
        except (KeyError, ValueError):
            continue
        if expires > now:
            return cap
    return None


def _consume_capability(cap: dict, *, reason: str) -> None:
    cap_id = str(cap["id"])
    path = _cap_path(cap_id)
    now = _iso(_now())
    cap["status"] = "consumed"
    cap["consumed_at"] = now
    cap["consumed_reason"] = reason
    path.write_text(json.dumps(cap, indent=2, sort_keys=True), encoding="utf-8")
    _ledger({"ts": now, "kind": "capability_consume", "id": cap_id, "reason": reason})


def cmd_mint(args: argparse.Namespace) -> int:
    CAP_DIR.mkdir(parents=True, exist_ok=True)
    now = _now()
    cap = {
        "id": f"mig-{now.strftime('%Y%m%dT%H%M%SZ')}-{secrets.token_hex(4)}",
        "namespace": args.namespace,
        "grantor": args.grantor,
        "minted_at": _iso(now),
        "expires_at": _iso(now + timedelta(minutes=args.ttl_minutes)),
        "status": "active",
    }
    (CAP_DIR / f"{cap['id']}.json").write_text(
        json.dumps(cap, indent=2, sort_keys=True), encoding="utf-8"
    )
    _ledger({"ts": _iso(now), "kind": "capability_mint", **cap})
    print(cap["id"])
    return 0


def cmd_check(args: argparse.Namespace) -> int:
    cap = _active_cap(args.namespace)
    if cap is None:
        print(f"cc-migration-capability: no active migration record for '{args.namespace}'")
        return 2
    print(f"active record: {cap['id']} (expires {cap['expires_at']})")
    return 0


def cmd_list(_args: argparse.Namespace) -> int:
    caps = sorted(_load_caps(), key=lambda c: (c.get("status") != "active", c.get("minted_at", "")))
    for c in caps:
        print(
            f"{c.get('status'):9} {c.get('id')} ns={c.get('namespace')} expires={c.get('expires_at')}"
        )
    if not caps:
        print("(none)")
    return 0


def cmd_expire(args: argparse.Namespace) -> int:
    path = _cap_path(args.id)
    if not path.is_file():
        print(f"cc-migration-capability: no such migration record '{args.id}'")
        return 2
    cap = json.loads(path.read_text(encoding="utf-8"))
    _consume_capability(cap, reason="manual_expire")
    print(f"consumed {args.id}")
    return 0


def _scalar(front: str, key: str) -> str:
    m = re.search(rf"(?m)^{re.escape(key)}:\s*(.*)$", front)
    return m.group(1).strip().strip('"').strip("'") if m else ""


def _has_field(front: str, key: str) -> bool:
    return re.search(rf"(?m)^{re.escape(key)}:", front) is not None


def _normalize_status(status: str) -> str:
    return status.strip().strip('"').strip("'").lower().replace("-", "_").replace(" ", "_")


def _derived_stage(status: str, implementation_stage: str) -> str | None:
    normalized = _normalize_status(status)
    if normalized in TERMINAL_STATUSES:
        return None
    if normalized in RELEASE_STATUSES:
        return "S7_RELEASE"
    if normalized in IMPLEMENTATION_STATUSES:
        return implementation_stage
    return PRE_IMPLEMENTATION_STAGES.get(normalized, "S0_INTAKE")


def _field_snapshot(front: str, key: str) -> str | None:
    lines = front.splitlines()
    for index, line in enumerate(lines):
        if not re.match(rf"^{re.escape(key)}:", line):
            continue
        captured = [line]
        for child in lines[index + 1 :]:
            if child.startswith((" ", "\t")):
                captured.append(child)
                continue
            break
        return "\n".join(captured)
    return None


def _set_scalar(front: str, key: str, value: str) -> str:
    if _has_field(front, key):
        return re.sub(rf"(?m)^{re.escape(key)}:.*$", f"{key}: {value}", front, count=1)
    return front.rstrip("\n") + f"\n{key}: {value}\n"


def cmd_backfill(args: argparse.Namespace) -> int:
    cap = _active_cap(args.namespace)
    if cap is None:
        print(
            f"cc-migration-capability: REFUSED — no active migration record for "
            f"'{args.namespace}'. Mint one first: cc-migration-capability mint "
            f"--namespace {args.namespace}"
        )
        return 2
    if not VAULT_ACTIVE.is_dir():
        print(f"cc-migration-capability: no active vault at {VAULT_ACTIVE}")
        return 3

    stage_changed: list[str] = []
    stamped_scope: list[str] = []
    terminal_skipped = 0
    task_records: list[dict] = []
    for note in sorted(VAULT_ACTIVE.glob("*.md")):
        metadata = note.lstat()
        raw = note.read_bytes()
        text = raw.decode("utf-8")
        if not text.startswith("---"):
            continue
        end = text.find("\n---", 4)
        if end < 0:
            continue
        front, body = text[: end + 1], text[end + 1 :]
        if _scalar(front, "type") != "cc-task":
            continue
        task_id = _scalar(front, "task_id") or note.stem
        status = _scalar(front, "status") or "offered"
        stage_before = _field_snapshot(front, "stage")
        scope_before = _field_snapshot(front, "mutation_scope_refs")
        derived_stage = _derived_stage(status, args.stage)
        if derived_stage is None:
            terminal_skipped += 1
            continue

        new_front = front
        if _scalar(front, "stage") != derived_stage:
            new_front = _set_scalar(new_front, "stage", derived_stage)
            stage_changed.append(note.stem)
        if not _has_field(new_front, "mutation_scope_refs"):
            new_front = new_front.rstrip("\n") + "\nmutation_scope_refs: []\n"
            stamped_scope.append(note.stem)
        if new_front == front:
            continue
        task_records.append(
            {
                "kind": "migration_backfill_task",
                "capability_id": cap["id"],
                "namespace": args.namespace,
                "path": str(note),
                "task_id": task_id,
                "status": _normalize_status(status),
                "stage_before": stage_before,
                "stage_after": _field_snapshot(new_front, "stage"),
                "scope_before": scope_before,
                "scope_after": _field_snapshot(new_front, "mutation_scope_refs"),
            }
        )
        if args.apply:
            try:
                replace_task_note_transactionally(
                    note,
                    expected_content=raw,
                    content=(new_front + body).encode("utf-8"),
                    expected_mode=stat.S_IMODE(metadata.st_mode),
                    cache_dir=OWNERSHIP_CACHE,
                    vault_root=VAULT_ACTIVE.parent,
                )
            except (OSError, FilesystemTransactionError) as exc:
                print(f"cc-migration-capability: task note changed before commit: {exc}")
                return 3

    if args.apply:
        ts = _iso(_now())
        for record in task_records:
            _ledger({"ts": ts, **record})
        _ledger(
            {
                "ts": _iso(_now()),
                "kind": "migration_backfill",
                "capability_id": cap["id"],
                "namespace": args.namespace,
                "task_records": len(task_records),
                "stage_changed": len(stage_changed),
                "scope_stamped": len(stamped_scope),
                "terminal_skipped": terminal_skipped,
                "implementation_stage": args.stage,
            }
        )
        _consume_capability(cap, reason="migration_backfill_apply")
    verb = "set" if args.apply else "would set"
    print(
        f"cc-migration-capability backfill ({'APPLY' if args.apply else 'dry-run'}, "
        f"cap={cap['id']}): {verb} stage on {len(stage_changed)} tasks, "
        f"mutation_scope_refs on {len(stamped_scope)} tasks; "
        f"left {terminal_skipped} terminal tasks untouched."
    )
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(prog="cc-migration-capability")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_mint = sub.add_parser("mint")
    p_mint.add_argument("--namespace", required=True)
    p_mint.add_argument("--ttl-minutes", type=int, default=120)
    p_mint.add_argument("--grantor", default="operator_blanket_reform_preauthorization_20260530")
    p_mint.set_defaults(func=cmd_mint)

    p_check = sub.add_parser("check")
    p_check.add_argument("--namespace", required=True)
    p_check.set_defaults(func=cmd_check)

    sub.add_parser("list").set_defaults(func=cmd_list)

    p_exp = sub.add_parser("expire")
    p_exp.add_argument("--id", required=True)
    p_exp.set_defaults(func=cmd_expire)

    p_bf = sub.add_parser("backfill")
    p_bf.add_argument("--namespace", required=True)
    p_bf.add_argument("--apply", action="store_true")
    p_bf.add_argument("--stage", default="S6_IMPLEMENTATION")
    p_bf.set_defaults(func=cmd_backfill)

    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
