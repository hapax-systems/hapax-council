#!/usr/bin/env bash
set -euo pipefail

message() {
  cat <<'EOF'
hapax-gemini is retired.

Gemini-family CLI work must run through agy-backed Hapax surfaces:
  - scripts/hapax-gemini-sidecar for read-only packet work
  - scripts/hapax-gemini-jr-team for JR packets
  - scripts/hapax-antigrav for governed interactive agy work

Native Gemini API and LiteLLM usage is unaffected.
EOF
}

case "${1:-}" in
  --help|-h)
    message
    exit 0
    ;;
esac

message >&2
exit 64
