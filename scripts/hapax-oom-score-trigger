#!/usr/bin/bash
# Fail-bounded user-side bridge to the allowlisted root OOM score enforcer.
set -euo pipefail

unit="${1:-}"
case "$unit" in
    pipewire.service | pipewire-pulse.service | wireplumber.service | hapax-daimonion.service | studio-compositor.service | hapax-imagination.service) ;;
    *)
        echo "refusing non-allowlisted protected user unit: $unit; next action: update this trigger allowlist and config/root-required/hapax-oom-score-enforce.sudoers together, then reinstall the OOM package" >&2
        exit 2
        ;;
esac

if [ "${HAPAX_OOM_TRIGGER_TEST_MODE:-0}" = "1" ]; then
    TIMEOUT="${HAPAX_OOM_TRIGGER_TIMEOUT:-/usr/bin/timeout}"
    SUDO="${HAPAX_OOM_TRIGGER_SUDO:-/usr/bin/sudo}"
    ENFORCER="${HAPAX_OOM_TRIGGER_ENFORCER:-/usr/local/sbin/hapax-oom-score-enforce}"
    DEADLINE="${HAPAX_OOM_TRIGGER_DEADLINE:-5s}"
else
    TIMEOUT="/usr/bin/timeout"
    SUDO="/usr/bin/sudo"
    ENFORCER="/usr/local/sbin/hapax-oom-score-enforce"
    DEADLINE="5s"
fi

exec "$TIMEOUT" --signal=KILL "$DEADLINE" \
    "$SUDO" -n "$ENFORCER" --apply-unit "$unit"
