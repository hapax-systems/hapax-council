#!/usr/bin/env bash
# Install P0 OOM containment policy from the source tree to live systemd/earlyoom paths.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SOURCE="$ROOT"
SYSTEMD_SYSTEM_DIR="${HAPAX_OOM_SYSTEMD_SYSTEM_DIR:-/etc/systemd/system}"
TARGET_UID="${HAPAX_OOM_TARGET_UID:-1000}"
TARGET_USER="${HAPAX_OOM_TARGET_USER:-}"
TARGET_HOME="${HAPAX_OOM_TARGET_HOME:-}"
TARGET_GID="${HAPAX_OOM_TARGET_GID:-}"
if [ -z "$TARGET_USER" ]; then
    TARGET_USER="$(getent passwd "$TARGET_UID" | cut -d: -f1 || true)"
fi
if [ -z "$TARGET_HOME" ]; then
    TARGET_HOME="$(getent passwd "$TARGET_UID" | cut -d: -f6 || true)"
fi
if [ -z "$TARGET_GID" ]; then
    TARGET_GID="$(getent passwd "$TARGET_UID" | cut -d: -f4 || true)"
fi
if [ -z "$TARGET_USER" ] || [ -z "$TARGET_HOME" ] || [ -z "$TARGET_GID" ]; then
    echo "unable to resolve account/home/group for OOM target UID $TARGET_UID; next action: set HAPAX_OOM_TARGET_UID, HAPAX_OOM_TARGET_USER, HAPAX_OOM_TARGET_HOME, and HAPAX_OOM_TARGET_GID explicitly" >&2
    exit 2
fi
SYSTEMD_USER_DIR="${HAPAX_OOM_SYSTEMD_USER_DIR:-$TARGET_HOME/.config/systemd/user}"
SYSTEMD_USER_CONTROL_DIR="${HAPAX_OOM_SYSTEMD_USER_CONTROL_DIR:-$TARGET_HOME/.config/systemd/user.control}"
EARLYOOM_DEST="${HAPAX_OOM_EARLYOOM_DEST:-/etc/default/earlyoom}"
OOM_ENFORCER_DEST="${HAPAX_OOM_ENFORCER_DEST:-/usr/local/sbin/hapax-oom-score-enforce}"
ROOT_FAILURE_INTAKE_DEST="${HAPAX_ROOT_FAILURE_INTAKE_DEST:-/usr/local/sbin/hapax-root-failure-intake}"
OOM_POLICY_AUDIT_DEST="${HAPAX_OOM_POLICY_AUDIT_DEST:-/usr/local/sbin/hapax-oom-policy-audit}"
ROOT_REQUIRED_AUDIT_DEST="${HAPAX_ROOT_REQUIRED_AUDIT_DEST:-/usr/local/sbin/hapax-root-required-deploy-audit}"
SYSTEMCTL="${HAPAX_OOM_SYSTEMCTL:-systemctl}"
SUDO="${HAPAX_OOM_INSTALL_SUDO-sudo}"
RUNUSER="${HAPAX_OOM_RUNUSER:-runuser}"
EFFECTIVE_UID="${HAPAX_OOM_EFFECTIVE_UID:-$(id -u)}"
ROOT_REQUIRED_STATE_ROOT="${HAPAX_ROOT_REQUIRED_STATE_ROOT:-$TARGET_HOME/.local/state/hapax/root-required}"
ROOT_REQUIRED_INSTALLED_SOURCE_ROOT="${HAPAX_ROOT_REQUIRED_INSTALLED_SOURCE_ROOT:-$ROOT_REQUIRED_STATE_ROOT/current-source}"
ROOT_REQUIRED_DEFER_ROOT="${HAPAX_POST_MERGE_ROOT_DEFER_DIR:-}"
if [ -z "$ROOT_REQUIRED_DEFER_ROOT" ] && [ -n "${HAPAX_ROOT_REQUIRED_DRAIN_DIR:-}" ]; then
    ROOT_REQUIRED_DEFER_ROOT="$(dirname "$(dirname "$HAPAX_ROOT_REQUIRED_DRAIN_DIR")")"
fi
ROOT_REQUIRED_DEFER_ROOT="${ROOT_REQUIRED_DEFER_ROOT:-$TARGET_HOME/.cache/hapax/post-merge-root-required}"
ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT="${HAPAX_ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT:-$ROOT_REQUIRED_STATE_ROOT/installed-receipts}"
ROOT_REQUIRED_DESIRED_RECEIPT_ROOT="${HAPAX_ROOT_REQUIRED_DESIRED_RECEIPT_ROOT:-$ROOT_REQUIRED_STATE_ROOT/desired-receipts}"
ROOT_REQUIRED_GIT_REPO="${HAPAX_ROOT_REQUIRED_GIT_REPO:-$TARGET_HOME/.cache/hapax/source-activation/worktree}"
ROOT_REQUIRED_PACKAGE_SHA="${HAPAX_ROOT_REQUIRED_PACKAGE_SHA:-}"
ROOT_REQUIRED_LOCK_FILE="${HAPAX_ROOT_REQUIRED_LOCK_FILE:-$ROOT_REQUIRED_STATE_ROOT/.lock}"
ROOT_REQUIRED_RECEIPT="$ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT/oom-containment.sha"
ROOT_REQUIRED_DESIRED_RECEIPT="$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT/oom-containment.sha"
SKIP_SUPERSEDED_INSTALL=0
PROC_ROOT="${HAPAX_OOM_PROC_ROOT:-/proc}"
if [ -n "${HAPAX_OOM_CGROUP_ROOT:-}" ]; then
    CGROUP_ROOT="$HAPAX_OOM_CGROUP_ROOT"
elif [ "$PROC_ROOT" != "/proc" ]; then
    CGROUP_ROOT="$(dirname "$PROC_ROOT")/cgroup"
else
    CGROUP_ROOT="/sys/fs/cgroup"
fi
ROOT_REQUIRED_RC=77
INSTALL=0
CHECK=0
VERIFY_LIVE=0
APPLY_RUNTIME=1

usage() {
    cat <<'USAGE'
usage: scripts/install-p0-oom-containment [--source DIR] [--check] [--install] [--verify-live] [--no-runtime]

Installs the P0 podium OOM containment package:
  systemd/system/user@1000.service.d/oom.conf       -> /etc/systemd/system/user@1000.service.d/oom.conf
  systemd/system/system.slice.d/oom-containment.conf -> /etc/systemd/system/system.slice.d/oom-containment.conf
  systemd/system/*.service.d/oom-protect.conf       -> /etc/systemd/system/*.service.d/oom-protect.conf
  systemd/units/hapax-root-failure-intake@.service  -> /etc/systemd/system/
  systemd/units/hapax-oom-score-enforce.{service,timer} -> /etc/systemd/system/
  scripts/hapax-oom-score-enforce                   -> /usr/local/sbin/hapax-oom-score-enforce
  scripts/hapax-root-failure-intake                  -> /usr/local/sbin/hapax-root-failure-intake
  scripts/hapax-oom-policy-audit                     -> /usr/local/sbin/hapax-oom-policy-audit
  scripts/hapax-root-required-deploy-audit            -> /usr/local/sbin/hapax-root-required-deploy-audit
  systemd/units/hapax-{oom-policy,root-required-deploy}-audit.{service,timer}
                                                     -> ~/.config/systemd/user/
  systemd/units/*.service.d/oom-protect.conf        -> ~/.config/systemd/user/*.service.d/oom-protect.conf
  systemd/units/app.slice.d/oom-containment.conf    -> ~/.config/systemd/user/app.slice.d/oom-containment.conf
  config/earlyoom/default                           -> /etc/default/earlyoom

The app.slice drop-in is copied, not symlinked, so live containment does not
depend on a mutable PR worktree. Runtime activation uses set-property for the
active app.slice instead of restarting the slice.
USAGE
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --source)
            SOURCE="${2:?source dir required after --source}"
            shift 2
            ;;
        --check)
            CHECK=1
            shift
            ;;
        --install)
            INSTALL=1
            shift
            ;;
        --verify-live)
            VERIFY_LIVE=1
            shift
            ;;
        --no-runtime)
            APPLY_RUNTIME=0
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [ "$INSTALL" -eq 1 ]; then
    VERIFY_LIVE=1
fi

if [ "$CHECK" -eq 0 ] && [ "$INSTALL" -eq 0 ] && [ "$VERIFY_LIVE" -eq 0 ]; then
    CHECK=1
fi

run_root() {
    if [ -n "$SUDO" ]; then
        "$SUDO" "$@"
    else
        "$@"
    fi
}

user_systemctl() {
    if [ "$EFFECTIVE_UID" = "$TARGET_UID" ]; then
        "$SYSTEMCTL" --user "$@"
    elif [ "$EFFECTIVE_UID" = "0" ]; then
        "$RUNUSER" -u "$TARGET_USER" -- env XDG_RUNTIME_DIR="/run/user/$TARGET_UID" "$SYSTEMCTL" --user "$@"
    else
        echo "cannot control UID $TARGET_UID user manager from effective UID $EFFECTIVE_UID; next action: run as UID $TARGET_UID or root, or set HAPAX_OOM_TARGET_UID/USER/HOME correctly" >&2
        return 1
    fi
}

preflight_root() {
    if [ -n "$SUDO" ] && [ "$INSTALL" -eq 1 ]; then
        "$SUDO" -n true 2>/dev/null || {
            echo "sudo non-interactive access is required for OOM containment install; next action: run sudo -v, grant NOPASSWD for install/systemctl/tee, or run as root with HAPAX_OOM_INSTALL_SUDO= scripts/install-p0-oom-containment --install --verify-live" >&2
            return "$ROOT_REQUIRED_RC"
        }
    fi
}

canonical_dir() {
    local dir="$1"
    [ -d "$dir" ] || return 1
    (cd "$dir" && pwd -P)
}

acquire_root_required_lock() {
    mkdir -p "$ROOT_REQUIRED_DEFER_ROOT" "$(dirname "$ROOT_REQUIRED_LOCK_FILE")"
    exec {ROOT_REQUIRED_LOCK_FD}>"$ROOT_REQUIRED_LOCK_FILE"
    flock -x "$ROOT_REQUIRED_LOCK_FD"
    migrate_legacy_root_required_state
}

migrate_legacy_root_required_state() {
    local label legacy receipt temp
    legacy="$ROOT_REQUIRED_DEFER_ROOT/current-source"
    if [ ! -e "$ROOT_REQUIRED_INSTALLED_SOURCE_ROOT" ] && [ -d "$legacy" ]; then
        mkdir -p "$(dirname "$ROOT_REQUIRED_INSTALLED_SOURCE_ROOT")"
        temp="$ROOT_REQUIRED_INSTALLED_SOURCE_ROOT.migrate.$$"
        rm -rf "$temp"
        cp -a "$legacy" "$temp"
        mv "$temp" "$ROOT_REQUIRED_INSTALLED_SOURCE_ROOT"
        echo "migrated root-required installed-source snapshot to durable state"
    fi
    for label in oom-containment apcupsd-power-alerts; do
        legacy="$ROOT_REQUIRED_DEFER_ROOT/installed-receipts/$label.sha"
        receipt="$ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT/$label.sha"
        if [ ! -f "$receipt" ] && [ "$legacy" != "$receipt" ] && [ -f "$legacy" ]; then
            mkdir -p "$ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT"
            cp "$legacy" "$receipt.migrate.$$"
            mv -f "$receipt.migrate.$$" "$receipt"
            echo "migrated $label installed-package receipt to durable state"
        fi
        receipt="$ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT/$label.sha"
        if [ ! -f "$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT/$label.sha" ] && [ -f "$receipt" ]; then
            mkdir -p "$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT"
            cp "$receipt" "$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT/$label.sha.migrate.$$"
            mv -f "$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT/$label.sha.migrate.$$" "$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT/$label.sha"
            echo "initialized $label desired-package receipt from installed state"
        fi
    done
}

package_commits_equivalent() {
    local installed_sha="$1" candidate_sha="$2" rel
    cmp -s \
        <(git -C "$ROOT_REQUIRED_GIT_REPO" show "$installed_sha:$package_manifest_source" 2>/dev/null) \
        <(git -C "$ROOT_REQUIRED_GIT_REPO" show "$candidate_sha:$package_manifest_source" 2>/dev/null) || return 1
    for rel in "${package_files[@]}"; do
        git -C "$ROOT_REQUIRED_GIT_REPO" cat-file -e "$installed_sha:$rel" 2>/dev/null || return 1
        git -C "$ROOT_REQUIRED_GIT_REPO" cat-file -e "$candidate_sha:$rel" 2>/dev/null || return 1
        cmp -s \
            <(git -C "$ROOT_REQUIRED_GIT_REPO" show "$installed_sha:$rel") \
            <(git -C "$ROOT_REQUIRED_GIT_REPO" show "$candidate_sha:$rel") || return 1
    done
}

validate_candidate_against_receipt() {
    local receipt_kind="$1" receipt_path="$2" receipt_sha
    [ -f "$receipt_path" ] || return 0
    receipt_sha="$(tr -d '[:space:]' < "$receipt_path")"
    [[ "$receipt_sha" =~ ^[0-9a-f]{40}$ ]] || {
        echo "invalid $receipt_kind OOM package receipt: $receipt_path; next action: inspect the receipt and rerun the newest governed post-merge package" >&2
        return 1
    }
    [ "$receipt_sha" != "$ROOT_REQUIRED_PACKAGE_SHA" ] || return 0
    if ! git -C "$ROOT_REQUIRED_GIT_REPO" cat-file -e "$receipt_sha^{commit}" 2>/dev/null; then
        echo "cannot validate OOM package order for $receipt_kind=$receipt_sha candidate=$ROOT_REQUIRED_PACKAGE_SHA; next action: fetch both commits into $ROOT_REQUIRED_GIT_REPO and rerun the staged RUNBOOK" >&2
        return 1
    fi
    if git -C "$ROOT_REQUIRED_GIT_REPO" merge-base --is-ancestor "$receipt_sha" "$ROOT_REQUIRED_PACKAGE_SHA"; then
        return 0
    fi
    if git -C "$ROOT_REQUIRED_GIT_REPO" merge-base --is-ancestor "$ROOT_REQUIRED_PACKAGE_SHA" "$receipt_sha"; then
        SKIP_SUPERSEDED_INSTALL=1
        echo "root-required OOM package $ROOT_REQUIRED_PACKAGE_SHA is superseded by $receipt_kind $receipt_sha; live files and durable desired state will not be rolled back"
        return 0
    fi
    if package_commits_equivalent "$receipt_sha" "$ROOT_REQUIRED_PACKAGE_SHA"; then
        echo "root-required OOM package and $receipt_kind receipt are ancestry-divergent but package-content equivalent; accepting squash/rebase transition"
        return 0
    fi
    echo "refusing divergent OOM package $receipt_kind=$receipt_sha candidate=$ROOT_REQUIRED_PACKAGE_SHA; next action: dispatch a governed reconciliation from current main and leave this RUNBOOK pending" >&2
    return 1
}

validate_root_required_package_order() {
    local staged_sha package_sha_file
    package_sha_file="$SOURCE/.hapax-root-required-package-sha"
    if [ -f "$package_sha_file" ]; then
        staged_sha="$(tr -d '[:space:]' < "$package_sha_file")"
        if [ -z "$ROOT_REQUIRED_PACKAGE_SHA" ]; then
            ROOT_REQUIRED_PACKAGE_SHA="$staged_sha"
        elif [ "$ROOT_REQUIRED_PACKAGE_SHA" != "$staged_sha" ]; then
            echo "root-required OOM package SHA mismatch: env=$ROOT_REQUIRED_PACKAGE_SHA staged=$staged_sha; next action: rerun the unmodified command from this package's RUNBOOK.txt" >&2
            return 1
        fi
    fi
    if [ -z "$ROOT_REQUIRED_PACKAGE_SHA" ]; then
        ROOT_REQUIRED_PACKAGE_SHA="$(git -C "$SOURCE" rev-parse HEAD 2>/dev/null || true)"
    fi
    if [ -z "$ROOT_REQUIRED_PACKAGE_SHA" ]; then
        echo "OOM install source has no package SHA; next action: run from a Git worktree or the exact staged RUNBOOK command" >&2
        return 1
    fi
    [[ "$ROOT_REQUIRED_PACKAGE_SHA" =~ ^[0-9a-f]{40}$ ]] || {
        echo "invalid root-required package SHA: $ROOT_REQUIRED_PACKAGE_SHA; next action: rerun the exact command from the staged RUNBOOK.txt" >&2
        return 1
    }
    git -C "$ROOT_REQUIRED_GIT_REPO" cat-file -e "$ROOT_REQUIRED_PACKAGE_SHA^{commit}" 2>/dev/null || {
        echo "root-required OOM package commit is unavailable: $ROOT_REQUIRED_PACKAGE_SHA; next action: fetch it into $ROOT_REQUIRED_GIT_REPO and rerun the staged RUNBOOK" >&2
        return 1
    }
    validate_candidate_against_receipt installed "$ROOT_REQUIRED_RECEIPT"
    validate_candidate_against_receipt desired "$ROOT_REQUIRED_DESIRED_RECEIPT"
}

record_root_required_package_receipt() {
    local temp desired_temp
    mkdir -p "$ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT" "$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT"
    temp="$ROOT_REQUIRED_RECEIPT.tmp.$$"
    printf '%s\n' "$ROOT_REQUIRED_PACKAGE_SHA" > "$temp"
    mv -f "$temp" "$ROOT_REQUIRED_RECEIPT"
    desired_temp="$ROOT_REQUIRED_DESIRED_RECEIPT.tmp.$$"
    printf '%s\n' "$ROOT_REQUIRED_PACKAGE_SHA" > "$desired_temp"
    mv -f "$desired_temp" "$ROOT_REQUIRED_DESIRED_RECEIPT"
}

validate_package_source_matches_commit() {
    local rel
    for rel in "${package_files[@]}"; do
        if [ ! -f "$SOURCE/$rel" ] || ! cmp -s <(git -C "$ROOT_REQUIRED_GIT_REPO" show "$ROOT_REQUIRED_PACKAGE_SHA:$rel") "$SOURCE/$rel"; then
            echo "OOM install source does not match claimed commit $ROOT_REQUIRED_PACKAGE_SHA at $rel; next action: discard the modified package and rerun from a clean Git worktree or exact staged RUNBOOK" >&2
            return 1
        fi
    done
}

validate_no_unhandled_package_removals() {
    local installed_sha rel
    [ -f "$ROOT_REQUIRED_RECEIPT" ] || return 0
    installed_sha="$(tr -d '[:space:]' < "$ROOT_REQUIRED_RECEIPT")"
    if ! git -C "$ROOT_REQUIRED_GIT_REPO" cat-file -e "$installed_sha:$package_manifest_source" 2>/dev/null; then
        echo "installed OOM commit predates the versioned ownership manifest; package-removal guard is using the one-time legacy bridge"
        return 0
    fi
    while IFS= read -r rel; do
        if ! awk -v wanted="$rel" 'NF && $1 !~ /^#/ && $1 == wanted { found = 1 } END { exit !found }' "$(src_path "$package_manifest_source")"; then
            echo "refusing OOM package removal or rename of $rel; next action: retain the owned path or add explicit governed live-removal handling before advancing receipts" >&2
            return 1
        fi
    done < <(
        git -C "$ROOT_REQUIRED_GIT_REPO" show "$installed_sha:$package_manifest_source" |
            awk 'NF && $1 !~ /^#/ {print $1}'
    )
}

validate_root_required_deferral_dir() {
    local drain="$1" root_real drain_real expected_real source_real
    [ -n "$drain" ] || return 0
    case "$drain" in
        /*) ;;
        *)
            echo "refusing relative root-required drain dir: $drain; next action: set HAPAX_ROOT_REQUIRED_DRAIN_DIR to the absolute deferral directory named in its RUNBOOK.txt" >&2
            return 1
            ;;
    esac
    [ -f "$drain/RUNBOOK.txt" ] || {
        echo "root-required drain dir missing RUNBOOK.txt: $drain; next action: inspect the staged deferral and rerun with the exact directory named by hapax-post-merge-deploy" >&2
        return 1
    }
    root_real="$(canonical_dir "$ROOT_REQUIRED_DEFER_ROOT")" || {
        echo "root-required defer root missing: $ROOT_REQUIRED_DEFER_ROOT; next action: set HAPAX_POST_MERGE_ROOT_DEFER_DIR to the parent of the requested deferral" >&2
        return 1
    }
    drain_real="$(canonical_dir "$drain")" || {
        echo "root-required drain dir missing: $drain; next action: clear HAPAX_ROOT_REQUIRED_DRAIN_DIR if it was already drained, or use the extant staged directory" >&2
        return 1
    }
    case "$drain_real" in
        "$root_real"/*) ;;
        *)
            echo "refusing root-required drain dir outside defer root: $drain; next action: set HAPAX_POST_MERGE_ROOT_DEFER_DIR to its governed parent and retry" >&2
            return 1
            ;;
    esac
    expected_real="$(canonical_dir "$ROOT_REQUIRED_DEFER_ROOT/$ROOT_REQUIRED_PACKAGE_SHA/oom-containment")" || {
        echo "expected OOM deferral package is missing: $ROOT_REQUIRED_DEFER_ROOT/$ROOT_REQUIRED_PACKAGE_SHA/oom-containment; next action: rerun the exact command from that package's RUNBOOK.txt" >&2
        return 1
    }
    source_real="$(canonical_dir "$SOURCE")" || {
        echo "OOM install source is missing: $SOURCE; next action: rerun the exact staged RUNBOOK command" >&2
        return 1
    }
    if [ "$drain_real" != "$expected_real" ] || [ "$source_real" != "$expected_real" ]; then
        echo "refusing mismatched OOM deferral drain: source=$source_real drain=$drain_real expected=$expected_real; next action: use the unmodified command from $expected_real/RUNBOOK.txt" >&2
        return 1
    fi
    ROOT_REQUIRED_DRAIN_REAL="$drain_real"
}

validate_root_required_deferral() {
    [ -n "${HAPAX_ROOT_REQUIRED_DRAIN_DIR:-}" ] || return 0
    validate_root_required_deferral_dir "$HAPAX_ROOT_REQUIRED_DRAIN_DIR"
}

drain_root_required_deferral() {
    [ -n "${HAPAX_ROOT_REQUIRED_DRAIN_DIR:-}" ] || return 0
    [ -n "${ROOT_REQUIRED_DRAIN_REAL:-}" ] || validate_root_required_deferral
    mv "$ROOT_REQUIRED_DRAIN_REAL/RUNBOOK.txt" "$ROOT_REQUIRED_DRAIN_REAL/DRAINED.txt"
    echo "root-required deferral marked drained: $ROOT_REQUIRED_DRAIN_REAL"
}

normalize_target_ownership() {
    local rel dest path
    [ "$(id -u)" = "0" ] || return 0
    for path in "$ROOT_REQUIRED_STATE_ROOT" "$ROOT_REQUIRED_INSTALLED_SOURCE_ROOT" "$ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT" "$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT" "$ROOT_REQUIRED_LOCK_FILE"; do
        [ -e "$path" ] || continue
        chown -R "$TARGET_UID:$TARGET_GID" "$path"
    done
    dest="$SYSTEMD_USER_DIR/app.slice.d/oom-containment.conf"
    chown "$TARGET_UID:$TARGET_GID" "$(dirname "$dest")" "$dest"
    for rel in "${user_protection_dropins[@]}" "${user_audit_units[@]}"; do
        dest="$SYSTEMD_USER_DIR/${rel#systemd/units/}"
        chown "$TARGET_UID:$TARGET_GID" "$(dirname "$dest")" "$dest"
    done
}

system_dropins=(
    systemd/system/system.slice.d/oom-containment.conf
    systemd/system/user.slice.d/oom-containment.conf
    systemd/system/user-1000.slice.d/oom-containment.conf
    systemd/system/user@1000.service.d/oom.conf
    systemd/system/apcupsd.service.d/oom-protect.conf
    systemd/system/systemd-logind.service.d/oom-protect.conf
    systemd/system/systemd-resolved.service.d/oom-protect.conf
    systemd/system/systemd-timesyncd.service.d/oom-protect.conf
    systemd/system/NetworkManager.service.d/oom-protect.conf
    systemd/system/dbus-broker.service.d/oom-protect.conf
    systemd/system/sshd.service.d/oom-protect.conf
)
system_units=(
    systemd/units/hapax-root-failure-intake@.service
    systemd/units/hapax-oom-score-enforce.service
    systemd/units/hapax-oom-score-enforce.timer
)
user_audit_units=(
    systemd/units/hapax-oom-policy-audit.service
    systemd/units/hapax-oom-policy-audit.timer
    systemd/units/hapax-root-required-deploy-audit.service
    systemd/units/hapax-root-required-deploy-audit.timer
)
user_audit_timers=(
    hapax-oom-policy-audit.timer
    hapax-root-required-deploy-audit.timer
)
user_dropin="systemd/units/app.slice.d/oom-containment.conf"
user_protection_dropins=(
    systemd/units/pipewire.service.d/oom-protect.conf
    systemd/units/pipewire-pulse.service.d/oom-protect.conf
    systemd/units/wireplumber.service.d/oom-protect.conf
    systemd/units/hapax-daimonion.service.d/oom-protect.conf
    systemd/units/studio-compositor.service.d/oom-protect.conf
    systemd/units/hapax-imagination.service.d/oom-protect.conf
)
earlyoom_source="config/earlyoom/default"
oom_enforcer_source="scripts/hapax-oom-score-enforce"
root_failure_intake_source="scripts/hapax-root-failure-intake"
oom_policy_audit_source="scripts/hapax-oom-policy-audit"
root_required_audit_source="scripts/hapax-root-required-deploy-audit"
package_manifest_source="config/root-required/oom-containment.files"
package_files=(
    "$package_manifest_source"
    scripts/install-p0-oom-containment
    "${system_dropins[@]}"
    "${system_units[@]}"
    "${user_audit_units[@]}"
    "$user_dropin"
    "${user_protection_dropins[@]}"
    "$earlyoom_source"
    "$oom_enforcer_source"
    "$root_failure_intake_source"
    "$oom_policy_audit_source"
    "$root_required_audit_source"
)
recovery_unit_scores=(
    apcupsd.service:-900
    systemd-logind.service:-800
    systemd-resolved.service:-800
    systemd-timesyncd.service:-800
    NetworkManager.service:-800
    dbus-broker.service:-900
    sshd.service:0
)
protected_user_unit_scores=(
    pipewire.service:-900
    pipewire-pulse.service:-900
    wireplumber.service:-900
    hapax-daimonion.service:-500
    studio-compositor.service:-800
    hapax-imagination.service:-800
)

src_path() {
    printf '%s/%s\n' "$SOURCE" "$1"
}

record_installed_source() {
    local rel dest
    for rel in "${package_files[@]}"; do
        dest="$ROOT_REQUIRED_INSTALLED_SOURCE_ROOT/$rel"
        mkdir -p "$(dirname "$dest")"
        cp -a "$(src_path "$rel")" "$dest"
    done
}

validate_package_manifest() {
    local -a declared=()
    local index
    mapfile -t declared < <(awk 'NF && $1 !~ /^#/ {print $1}' "$(src_path "$package_manifest_source")")
    if [ "${#declared[@]}" -ne "${#package_files[@]}" ]; then
        echo "OOM package ownership manifest count mismatch; next action: reconcile $package_manifest_source with package_files in scripts/install-p0-oom-containment" >&2
        return 1
    fi
    for index in "${!package_files[@]}"; do
        if [ "${declared[$index]}" != "${package_files[$index]}" ]; then
            echo "OOM package ownership manifest mismatch at index $index: declared=${declared[$index]} runtime=${package_files[$index]}; next action: update both lists in the same governed change" >&2
            return 1
        fi
    done
}

app_slice_value() {
    local key="$1" file value
    file="$(src_path "$user_dropin")"
    value="$(awk -F= -v key="$key" '$1 == key {print $2; exit}' "$file" 2>/dev/null || true)"
    if [ -z "$value" ]; then
        echo "app.slice drop-in missing $key; next action: restore $user_dropin from the P0 PR" >&2
        return 1
    fi
    printf '%s\n' "$value"
}

source_unit_value() {
    local rel="$1" key="$2" file value
    file="$(src_path "$rel")"
    value="$(awk -F= -v key="$key" '$1 == key {print $2; exit}' "$file" 2>/dev/null || true)"
    if [ -z "$value" ]; then
        echo "$rel missing $key; next action: restore $rel from the P0 PR" >&2
        return 1
    fi
    printf '%s\n' "$value"
}

memory_to_bytes() {
    local value="$1" number suffix
    case "$value" in
        infinity|max)
            printf 'infinity\n'
            ;;
        *K|*M|*G|*T)
            number="${value%?}"
            suffix="${value#"$number"}"
            [[ "$number" =~ ^[0-9]+$ ]] || return 1
            case "$suffix" in
                K) printf '%s\n' "$((number * 1024))" ;;
                M) printf '%s\n' "$((number * 1024 * 1024))" ;;
                G) printf '%s\n' "$((number * 1024 * 1024 * 1024))" ;;
                T) printf '%s\n' "$((number * 1024 * 1024 * 1024 * 1024))" ;;
            esac
            ;;
        *)
            [[ "$value" =~ ^[0-9]+$ ]] || return 1
            printf '%s\n' "$value"
            ;;
    esac
}

system_dest() {
    local rel="$1"
    case "$rel" in
        systemd/system/*) printf '%s/%s\n' "$SYSTEMD_SYSTEM_DIR" "${rel#systemd/system/}" ;;
        systemd/units/*) printf '%s/%s\n' "$SYSTEMD_SYSTEM_DIR" "${rel#systemd/units/}" ;;
    esac
}

check_source() {
    local rel
    validate_package_manifest
    for rel in "${package_files[@]}"; do
        [ -f "$(src_path "$rel")" ] || {
            echo "missing source file: $(src_path "$rel"); next action: restore the source tree or rerun from the PR/activation worktree" >&2
            return 1
        }
    done
    grep -Eq '^OOMScoreAdjust=100$' "$(src_path systemd/system/user@1000.service.d/oom.conf)" || {
        echo "user@1000 OOM drop-in must set OOMScoreAdjust=100; next action: restore systemd/system/user@1000.service.d/oom.conf from the P0 PR" >&2
        return 1
    }
    grep -Eq '^OOMPolicy=continue$' "$(src_path systemd/system/user@1000.service.d/oom.conf)" || {
        echo "user@1000 OOM drop-in must continue after a descendant OOM; next action: restore systemd/system/user@1000.service.d/oom.conf from the P0 PR" >&2
        return 1
    }
    grep -Eq '^OOMScoreAdjust=0$' "$(src_path systemd/system/sshd.service.d/oom-protect.conf)" || {
        echo "sshd OOM drop-in must keep child-inheritable OOMScoreAdjust neutral; next action: restore systemd/system/sshd.service.d/oom-protect.conf from the P0 PR" >&2
        return 1
    }
    grep -Eq '^OOMPolicy=continue$' "$(src_path systemd/system/sshd.service.d/oom-protect.conf)" || {
        echo "sshd OOM drop-in must continue after a session OOM; next action: restore systemd/system/sshd.service.d/oom-protect.conf from the P0 PR" >&2
        return 1
    }
    app_slice_value MemoryHigh >/dev/null
    app_slice_value MemoryMax >/dev/null
    app_slice_value MemorySwapMax >/dev/null
    app_slice_value MemoryLow >/dev/null
    app_slice_value MemoryMin >/dev/null
    source_unit_value systemd/system/user-1000.slice.d/oom-containment.conf MemoryHigh >/dev/null
    source_unit_value systemd/system/user-1000.slice.d/oom-containment.conf MemoryMax >/dev/null
    source_unit_value systemd/system/user-1000.slice.d/oom-containment.conf MemorySwapMax >/dev/null
    source_unit_value systemd/system/user-1000.slice.d/oom-containment.conf MemoryLow >/dev/null
    source_unit_value systemd/system/user-1000.slice.d/oom-containment.conf MemoryMin >/dev/null
    source_unit_value systemd/system/system.slice.d/oom-containment.conf MemoryHigh >/dev/null
    source_unit_value systemd/system/system.slice.d/oom-containment.conf MemoryMax >/dev/null
    source_unit_value systemd/system/system.slice.d/oom-containment.conf MemorySwapMax >/dev/null
    source_unit_value systemd/system/system.slice.d/oom-containment.conf MemoryLow >/dev/null
    source_unit_value systemd/system/system.slice.d/oom-containment.conf MemoryMin >/dev/null
    source_unit_value systemd/system/user.slice.d/oom-containment.conf MemoryHigh >/dev/null
    source_unit_value systemd/system/user.slice.d/oom-containment.conf MemoryMax >/dev/null
    source_unit_value systemd/system/user.slice.d/oom-containment.conf MemorySwapMax >/dev/null
    source_unit_value systemd/system/user.slice.d/oom-containment.conf MemoryLow >/dev/null
    source_unit_value systemd/system/user.slice.d/oom-containment.conf MemoryMin >/dev/null
    source_unit_value systemd/system/user@1000.service.d/oom.conf MemoryHigh >/dev/null
    source_unit_value systemd/system/user@1000.service.d/oom.conf MemoryMax >/dev/null
    source_unit_value systemd/system/user@1000.service.d/oom.conf MemorySwapMax >/dev/null
    source_unit_value systemd/system/user@1000.service.d/oom.conf MemoryLow >/dev/null
    source_unit_value systemd/system/user@1000.service.d/oom.conf MemoryMin >/dev/null
    grep -q -- "--ignore" "$(src_path "$earlyoom_source")" || {
        echo "earlyoom config missing --ignore recovery list; next action: restore config/earlyoom/default from the P0 PR" >&2
        return 1
    }
    if grep -Eq -- "--(prefer|avoid|ignore)[[:space:]]+'" "$(src_path "$earlyoom_source")"; then
        echo "earlyoom regex arguments must not carry literal single quotes; next action: remove inner quotes from config/earlyoom/default and rerun scripts/install-p0-oom-containment --check" >&2
        return 1
    fi
}

write_oom_score() {
    local pid score path
    pid="$1"
    score="$2"
    path="$PROC_ROOT/$pid/oom_score_adj"
    [ -e "$path" ] || return 0
    if [ "${HAPAX_OOM_FORCE_DIRECT_WRITE_FAIL:-0}" != "1" ] && { printf '%s\n' "$score" > "$path"; } 2>/dev/null; then
        return 0
    fi
    [ ! -e "$path" ] && return 0
    if [ -n "$SUDO" ] || [ "$(id -u)" = "0" ]; then
        printf '%s\n' "$score" | run_root tee "$path" >/dev/null || {
            [ ! -e "$path" ] && return 0
            return 1
        }
        return 0
    fi
    return 1
}

main_pid_for_unit() {
    local unit="$1" pid
    pid="$("$SYSTEMCTL" show "$unit" -p MainPID --value 2>/dev/null || true)"
    if [[ "$pid" =~ ^[0-9]+$ ]] && [ "$pid" -gt 0 ]; then
        printf '%s\n' "$pid"
    fi
    return 0
}

main_pid_for_user_unit() {
    local unit="$1" pid
    pid="$(user_systemctl show "$unit" -p MainPID --value 2>/dev/null || true)"
    if [[ "$pid" =~ ^[0-9]+$ ]] && [ "$pid" -gt 0 ]; then
        printf '%s\n' "$pid"
    fi
    return 0
}

control_group_for_user_unit() {
    local unit="$1"
    user_systemctl show "$unit" -p ControlGroup --value 2>/dev/null || true
}

cgroup_pids() {
    local cgroup="$1" dir procs
    [ -n "$cgroup" ] || return 0
    dir="$CGROUP_ROOT/${cgroup#/}"
    [ -d "$dir" ] || return 0
    find "$dir" -name cgroup.procs -type f -print 2>/dev/null |
        while IFS= read -r procs; do
            sed -n '/^[0-9][0-9]*$/p' "$procs" 2>/dev/null || true
        done | sort -u
}

user_unit_pids() {
    local unit="$1" cgroup pid
    cgroup="$(control_group_for_user_unit "$unit")"
    cgroup_pids "$cgroup"
    pid="$(main_pid_for_user_unit "$unit")"
    [ -n "$pid" ] && printf '%s\n' "$pid"
    return 0
}

pid_matches_cgroup() {
    local pid="$1" cgroup="$2" proc_cgroup _hierarchy _controllers path
    proc_cgroup="$PROC_ROOT/$pid/cgroup"
    [ -n "$cgroup" ] || return 1
    [ -r "$proc_cgroup" ] || return 1
    while IFS=: read -r _hierarchy _controllers path; do
        if [ "$path" = "$cgroup" ] || [[ "$path" == "$cgroup/"* ]]; then
            return 0
        fi
    done < "$proc_cgroup"
    return 1
}

write_oom_score_or_warn() {
    local pid="$1" score="$2" label="$3"
    if write_oom_score "$pid" "$score"; then
        return 0
    fi
    echo "warning: failed to set oom_score_adj for $label pid=$pid; next action: run scripts/hapax-oom-policy-audit --json and rerun scripts/install-p0-oom-containment --install --verify-live" >&2
    return 0
}

apply_recovery_unit_oom_scores() {
    local spec unit score pid
    for spec in "${recovery_unit_scores[@]}"; do
        unit="${spec%%:*}"
        score="${spec##*:}"
        pid="$(main_pid_for_unit "$unit")"
        [ -n "$pid" ] || continue
        write_oom_score_or_warn "$pid" "$score" "$unit"
    done
}

apply_protected_user_unit_oom_scores() {
    local spec unit score pid
    for spec in "${protected_user_unit_scores[@]}"; do
        unit="${spec%%:*}"
        score="${spec##*:}"
        user_unit_pids "$unit" | while IFS= read -r pid; do
            [ -n "$pid" ] || continue
            write_oom_score_or_warn "$pid" "$score" "$unit"
        done
    done
}

allowed_user_protected_process() {
    case "$1" in
        pipewire|pipewire-pulse|wireplumber|dbus-broker|dbus-daemon|systemd)
            return 0
            ;;
    esac
    return 1
}

protected_user_unit_member_pid() {
    local candidate="$1" spec unit pid cgroup
    for spec in "${protected_user_unit_scores[@]}"; do
        unit="${spec%%:*}"
        pid="$(main_pid_for_user_unit "$unit")"
        [ -n "$pid" ] && [ "$candidate" = "$pid" ] && return 0
        cgroup="$(control_group_for_user_unit "$unit")"
        pid_matches_cgroup "$candidate" "$cgroup" && return 0
    done
    return 1
}

status_field() {
    local status="$1" key="$2"
    awk -v key="$key" '$1 == key ":" {print $2; exit}' "$status" 2>/dev/null || true
}

apply_user_process_oom_floor() {
    local adj pid_dir pid status uid name score fixed=0
    [ -d "$PROC_ROOT" ] || return 0
    for adj in "$PROC_ROOT"/[0-9]*/oom_score_adj; do
        [ -e "$adj" ] || continue
        pid_dir="$(dirname "$adj")"
        pid="$(basename "$pid_dir")"
        status="$pid_dir/status"
        [ -r "$status" ] || continue
        uid="$(status_field "$status" Uid)"
        [ "$uid" = "$TARGET_UID" ] || continue
        name="$(status_field "$status" Name)"
        score="$(cat "$adj" 2>/dev/null || true)"
        [[ "$score" =~ ^-?[0-9]+$ ]] || continue
        [ "$score" -le -800 ] || continue
        protected_user_unit_member_pid "$pid" && continue
        allowed_user_protected_process "$name" && continue
        if write_oom_score "$pid" 100; then
            fixed=$((fixed + 1))
        else
            echo "warning: failed to set oom_score_adj for user process name=$name pid=$pid; next action: run scripts/hapax-oom-policy-audit --json and rerun scripts/install-p0-oom-containment --install --verify-live" >&2
        fi
    done
    if [ "$fixed" -gt 0 ]; then
        echo "reset $fixed stale user process oom_score_adj values to 100"
    fi
}

install_live() {
    local rel dest timer control_dropin_dir user_pid mem_high mem_max mem_swap
    check_source
    preflight_root
    for rel in "${system_dropins[@]}"; do
        dest="$(system_dest "$rel")"
        run_root install -d -m 0755 "$(dirname "$dest")"
        run_root install -m 0644 "$(src_path "$rel")" "$dest"
        echo "  '$rel' -> '$dest'"
    done
    for rel in "${system_units[@]}"; do
        dest="$(system_dest "$rel")"
        run_root install -d -m 0755 "$(dirname "$dest")"
        run_root install -m 0644 "$(src_path "$rel")" "$dest"
        echo "  '$rel' -> '$dest'"
    done
    run_root install -d -m 0755 "$(dirname "$OOM_ENFORCER_DEST")"
    run_root install -m 0755 "$(src_path "$oom_enforcer_source")" "$OOM_ENFORCER_DEST"
    echo "  '$oom_enforcer_source' -> '$OOM_ENFORCER_DEST'"
    run_root install -d -m 0755 "$(dirname "$ROOT_FAILURE_INTAKE_DEST")"
    run_root install -m 0755 "$(src_path "$root_failure_intake_source")" "$ROOT_FAILURE_INTAKE_DEST"
    echo "  '$root_failure_intake_source' -> '$ROOT_FAILURE_INTAKE_DEST'"
    run_root install -d -m 0755 "$(dirname "$OOM_POLICY_AUDIT_DEST")"
    run_root install -m 0755 "$(src_path "$oom_policy_audit_source")" "$OOM_POLICY_AUDIT_DEST"
    echo "  '$oom_policy_audit_source' -> '$OOM_POLICY_AUDIT_DEST'"
    run_root install -d -m 0755 "$(dirname "$ROOT_REQUIRED_AUDIT_DEST")"
    run_root install -m 0755 "$(src_path "$root_required_audit_source")" "$ROOT_REQUIRED_AUDIT_DEST"
    echo "  '$root_required_audit_source' -> '$ROOT_REQUIRED_AUDIT_DEST'"
    run_root install -d -m 0755 "$(dirname "$EARLYOOM_DEST")"
    run_root install -m 0644 "$(src_path "$earlyoom_source")" "$EARLYOOM_DEST"
    echo "  '$earlyoom_source' -> '$EARLYOOM_DEST'"

    dest="$SYSTEMD_USER_DIR/app.slice.d/oom-containment.conf"
    install -d -m 0755 "$(dirname "$dest")"
    if [ -L "$dest" ]; then
        rm -f "$dest"
    fi
    install -m 0644 "$(src_path "$user_dropin")" "$dest"
    echo "  '$user_dropin' -> '$dest' (copy)"

    for rel in "${user_protection_dropins[@]}"; do
        dest="$SYSTEMD_USER_DIR/${rel#systemd/units/}"
        install -d -m 0755 "$(dirname "$dest")"
        install -m 0644 "$(src_path "$rel")" "$dest"
        echo "  '$rel' -> '$dest' (copy)"
    done

    for rel in "${user_audit_units[@]}"; do
        dest="$SYSTEMD_USER_DIR/${rel#systemd/units/}"
        install -d -m 0755 "$(dirname "$dest")"
        [ ! -L "$dest" ] || rm -f "$dest"
        install -m 0644 "$(src_path "$rel")" "$dest"
        echo "  '$rel' -> '$dest' (copy)"
    done

    control_dropin_dir="$SYSTEMD_USER_CONTROL_DIR/app.slice.d"
    if [ -d "$control_dropin_dir" ]; then
        rm -f \
            "$control_dropin_dir/50-MemoryHigh.conf" \
            "$control_dropin_dir/50-MemoryMax.conf" \
            "$control_dropin_dir/50-MemorySwapMax.conf" \
            "$control_dropin_dir/50-MemoryLow.conf" \
            "$control_dropin_dir/50-MemoryMin.conf"
        rmdir "$control_dropin_dir" 2>/dev/null || true
    fi

    run_root "$SYSTEMCTL" daemon-reload
    run_root "$SYSTEMCTL" enable --now hapax-oom-score-enforce.timer >/dev/null 2>&1 || {
        echo "unable to enable hapax-oom-score-enforce.timer; next action: run sudo systemctl enable --now hapax-oom-score-enforce.timer" >&2
        return 1
    }
    run_root "$SYSTEMCTL" enable --now earlyoom.service >/dev/null 2>&1 || {
        echo "unable to enable earlyoom.service; next action: run sudo systemctl enable --now earlyoom.service" >&2
        return 1
    }
    run_root "$SYSTEMCTL" restart earlyoom.service || {
        echo "unable to restart earlyoom.service with the installed policy; next action: run sudo systemctl restart earlyoom.service and inspect journalctl -u earlyoom.service" >&2
        return 1
    }
    user_systemctl daemon-reload
    for timer in "${user_audit_timers[@]}"; do
        user_systemctl enable --now "$timer" >/dev/null 2>&1 || {
            echo "unable to enable $timer for UID $TARGET_UID; next action: run systemctl --user enable --now $timer as $TARGET_USER" >&2
            return 1
        }
    done
    if [ "$APPLY_RUNTIME" -eq 1 ]; then
        apply_system_runtime_memory system.slice systemd/system/system.slice.d/oom-containment.conf
        apply_system_runtime_memory user.slice systemd/system/user.slice.d/oom-containment.conf
        apply_system_runtime_memory user-1000.slice systemd/system/user-1000.slice.d/oom-containment.conf
        apply_system_runtime_memory user@1000.service systemd/system/user@1000.service.d/oom.conf
        mem_high="$(app_slice_value MemoryHigh)"
        mem_max="$(app_slice_value MemoryMax)"
        mem_swap="$(app_slice_value MemorySwapMax)"
        user_systemctl set-property --runtime app.slice \
            "MemoryHigh=$mem_high" \
            "MemoryMax=$mem_max" \
            "MemorySwapMax=$mem_swap" \
            "MemoryLow=$(app_slice_value MemoryLow)" \
            "MemoryMin=$(app_slice_value MemoryMin)"
        apply_recovery_unit_oom_scores
        apply_protected_user_unit_oom_scores
        user_pid="$("$SYSTEMCTL" show user@1000.service -p MainPID --value 2>/dev/null || true)"
        if [[ "$user_pid" =~ ^[0-9]+$ ]] && [ "$user_pid" -gt 0 ]; then
            write_oom_score_or_warn "$user_pid" 100 "user@1000.service"
        fi
        apply_user_process_oom_floor
    fi
}

apply_system_runtime_memory() {
    local unit="$1" rel="$2"
    run_root "$SYSTEMCTL" set-property --runtime "$unit" \
        "MemoryHigh=$(source_unit_value "$rel" MemoryHigh)" \
        "MemoryMax=$(source_unit_value "$rel" MemoryMax)" \
        "MemorySwapMax=$(source_unit_value "$rel" MemorySwapMax)" \
        "MemoryLow=$(source_unit_value "$rel" MemoryLow)" \
        "MemoryMin=$(source_unit_value "$rel" MemoryMin)" || {
        echo "unable to apply runtime memory policy to $unit; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    }
}

verify_pair() {
    local source="$1" dest="$2"
    [ -f "$dest" ] || {
        echo "missing live file: $dest; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    }
    cmp -s "$source" "$dest" || {
        echo "live drift: $dest differs from $source; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    }
}

verify_live() {
    local rel dest timer
    for rel in "${system_dropins[@]}"; do
        verify_pair "$(src_path "$rel")" "$(system_dest "$rel")"
    done
    for rel in "${system_units[@]}"; do
        verify_pair "$(src_path "$rel")" "$(system_dest "$rel")"
    done
    verify_pair "$(src_path "$oom_enforcer_source")" "$OOM_ENFORCER_DEST"
    verify_pair "$(src_path "$root_failure_intake_source")" "$ROOT_FAILURE_INTAKE_DEST"
    verify_pair "$(src_path "$oom_policy_audit_source")" "$OOM_POLICY_AUDIT_DEST"
    verify_pair "$(src_path "$root_required_audit_source")" "$ROOT_REQUIRED_AUDIT_DEST"
    verify_pair "$(src_path "$earlyoom_source")" "$EARLYOOM_DEST"
    run_root "$SYSTEMCTL" is-enabled --quiet earlyoom.service || {
        echo "earlyoom.service is not enabled; next action: run sudo systemctl enable --now earlyoom.service" >&2
        return 1
    }
    run_root "$SYSTEMCTL" is-active --quiet earlyoom.service || {
        echo "earlyoom.service is not active; next action: run sudo systemctl enable --now earlyoom.service and inspect journalctl -u earlyoom.service" >&2
        return 1
    }
    dest="$SYSTEMD_USER_DIR/app.slice.d/oom-containment.conf"
    if [ -L "$dest" ]; then
        echo "live app.slice drop-in is a symlink: $dest; next action: run scripts/install-p0-oom-containment --install --verify-live to replace it with a copy" >&2
        return 1
    fi
    verify_pair "$(src_path "$user_dropin")" "$dest"
    for rel in "${user_protection_dropins[@]}"; do
        verify_pair "$(src_path "$rel")" "$SYSTEMD_USER_DIR/${rel#systemd/units/}"
    done
    for rel in "${user_audit_units[@]}"; do
        dest="$SYSTEMD_USER_DIR/${rel#systemd/units/}"
        if [ -L "$dest" ]; then
            echo "live P0 audit unit is a symlink: $dest; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
            return 1
        fi
        verify_pair "$(src_path "$rel")" "$dest"
    done
    for timer in "${user_audit_timers[@]}"; do
        user_systemctl is-enabled --quiet "$timer" || {
            echo "$timer is not enabled for UID $TARGET_UID; next action: run systemctl --user enable --now $timer as $TARGET_USER" >&2
            return 1
        }
        user_systemctl is-active --quiet "$timer" || {
            echo "$timer is not active for UID $TARGET_UID; next action: run systemctl --user enable --now $timer as $TARGET_USER" >&2
            return 1
        }
    done
    verify_user_manager_oom_score
    verify_system_unit_runtime_memory system.slice systemd/system/system.slice.d/oom-containment.conf
    verify_system_unit_runtime_memory user.slice systemd/system/user.slice.d/oom-containment.conf
    verify_system_unit_runtime_memory user-1000.slice systemd/system/user-1000.slice.d/oom-containment.conf
    verify_system_unit_runtime_memory user@1000.service systemd/system/user@1000.service.d/oom.conf
    verify_app_slice_runtime
    verify_recovery_unit_oom_scores
    verify_protected_user_unit_oom_scores
    verify_user_process_oom_floor
}

verify_system_unit_runtime_memory() {
    local unit="$1" rel="$2" key expected_raw expected_bytes actual failed=0
    for key in MemoryHigh MemoryMax MemorySwapMax MemoryLow MemoryMin; do
        expected_raw="$(source_unit_value "$rel" "$key")"
        expected_bytes="$(memory_to_bytes "$expected_raw")" || {
            echo "cannot parse $unit $key=$expected_raw from $rel; next action: fix the source drop-in and rerun scripts/install-p0-oom-containment --check" >&2
            return 1
        }
        actual="$("$SYSTEMCTL" show "$unit" -p "$key" --value 2>/dev/null || true)"
        if [ "$actual" != "$expected_raw" ] && [ "$actual" != "$expected_bytes" ]; then
            echo "live $unit $key drift: actual=$actual expected=$expected_raw; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
            failed=1
        fi
    done
    [ "$failed" -eq 0 ]
}

verify_app_slice_runtime() {
    local key expected_raw expected_bytes actual failed=0
    for key in MemoryHigh MemoryMax MemorySwapMax MemoryLow MemoryMin; do
        expected_raw="$(app_slice_value "$key")"
        expected_bytes="$(memory_to_bytes "$expected_raw")" || {
            echo "cannot parse app.slice $key=$expected_raw from $user_dropin; next action: fix the source drop-in and rerun scripts/install-p0-oom-containment --check" >&2
            return 1
        }
        actual="$(user_systemctl show app.slice -p "$key" --value 2>/dev/null || true)"
        if [ "$actual" != "$expected_raw" ] && [ "$actual" != "$expected_bytes" ]; then
            echo "live app.slice $key drift: actual=$actual expected=$expected_raw; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
            failed=1
        fi
    done
    [ "$failed" -eq 0 ]
}

verify_recovery_unit_oom_scores() {
    local spec unit score pid actual configured policy failed=0
    for spec in "${recovery_unit_scores[@]}"; do
        unit="${spec%%:*}"
        score="${spec##*:}"
        configured="$("$SYSTEMCTL" show "$unit" -p OOMScoreAdjust --value 2>/dev/null || true)"
        if [ "$configured" != "$score" ]; then
            echo "effective OOM policy drift for $unit: configured=$configured expected=$score; next action: remove higher-priority drop-in drift and rerun scripts/install-p0-oom-containment --install --verify-live" >&2
            failed=1
        fi
        if [ "$unit" = "sshd.service" ]; then
            policy="$("$SYSTEMCTL" show "$unit" -p OOMPolicy --value 2>/dev/null || true)"
            if [ "$policy" != "continue" ]; then
                echo "effective OOM policy drift for sshd.service: OOMPolicy=$policy expected=continue; next action: remove higher-priority drop-in drift and rerun scripts/install-p0-oom-containment --install --verify-live" >&2
                failed=1
            fi
        fi
        pid="$(main_pid_for_unit "$unit")"
        if [ -z "$pid" ]; then
            echo "recovery daemon has no live MainPID: $unit; next action: inspect systemctl status $unit and rerun scripts/install-p0-oom-containment --install --verify-live" >&2
            failed=1
            continue
        fi
        actual="$(cat "$PROC_ROOT/$pid/oom_score_adj" 2>/dev/null || true)"
        if [ "$actual" != "$score" ]; then
            echo "live OOM score drift for $unit pid $pid: actual=$actual expected=$score; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
            failed=1
        fi
    done
    [ "$failed" -eq 0 ]
}

verify_user_manager_oom_score() {
    local pid actual policy configured
    configured="$("$SYSTEMCTL" show user@1000.service -p OOMScoreAdjust --value 2>/dev/null || true)"
    if [ "$configured" != "100" ]; then
        echo "effective user@1000.service OOMScoreAdjust drift: actual=$configured expected=100; next action: remove higher-priority drop-in drift and rerun scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    fi
    policy="$("$SYSTEMCTL" show user@1000.service -p OOMPolicy --value 2>/dev/null || true)"
    if [ "$policy" != "continue" ]; then
        echo "effective user@1000.service OOMPolicy drift: actual=$policy expected=continue; next action: remove higher-priority drop-in drift and rerun scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    fi
    pid="$("$SYSTEMCTL" show user@1000.service -p MainPID --value 2>/dev/null || true)"
    if ! [[ "$pid" =~ ^[0-9]+$ ]] || [ "$pid" -le 0 ]; then
        echo "unable to read live user@1000.service MainPID; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    fi
    actual="$(cat "$PROC_ROOT/$pid/oom_score_adj" 2>/dev/null || true)"
    if [ "$actual" != "100" ]; then
        echo "live user@1000.service OOM score drift: pid=$pid actual=$actual expected=100; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    fi
}

verify_protected_user_unit_oom_scores() {
    local spec unit score pid actual configured failed=0
    for spec in "${protected_user_unit_scores[@]}"; do
        unit="${spec%%:*}"
        score="${spec##*:}"
        configured="$(user_systemctl show "$unit" -p OOMScoreAdjust --value 2>/dev/null || true)"
        if [ "$configured" != "100" ]; then
            echo "user unit startup OOM policy drift for $unit: configured=$configured expected=100; the user manager cannot lower a child score, so root must apply live score $score after start; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
            failed=1
        fi
        while IFS= read -r pid; do
            [ -n "$pid" ] || continue
            actual="$(cat "$PROC_ROOT/$pid/oom_score_adj" 2>/dev/null || true)"
            if [ "$actual" != "$score" ]; then
                echo "live user unit OOM score drift for $unit pid $pid: actual=$actual expected=$score; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
                failed=1
            fi
        done < <(user_unit_pids "$unit")
    done
    [ "$failed" -eq 0 ]
}

verify_user_process_oom_floor() {
    local adj pid_dir pid status uid name score failed=0
    [ -d "$PROC_ROOT" ] || return 0
    for adj in "$PROC_ROOT"/[0-9]*/oom_score_adj; do
        [ -e "$adj" ] || continue
        pid_dir="$(dirname "$adj")"
        pid="$(basename "$pid_dir")"
        status="$pid_dir/status"
        [ -r "$status" ] || continue
        uid="$(status_field "$status" Uid)"
        [ "$uid" = "$TARGET_UID" ] || continue
        name="$(status_field "$status" Name)"
        score="$(cat "$adj" 2>/dev/null || true)"
        [[ "$score" =~ ^-?[0-9]+$ ]] || continue
        [ "$score" -le -800 ] || continue
        protected_user_unit_member_pid "$pid" && continue
        allowed_user_protected_process "$name" && continue
        echo "residual inherited OOM protection: pid=$pid name=$name oom_score_adj=$score; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
        failed=1
    done
    [ "$failed" -eq 0 ]
}

[ "$CHECK" -eq 0 ] || check_source
[ "$INSTALL" -eq 0 ] || acquire_root_required_lock
[ "$INSTALL" -eq 0 ] || validate_root_required_package_order
if [ "$INSTALL" -eq 1 ] && [ "$SKIP_SUPERSEDED_INSTALL" -eq 1 ]; then
    drain_root_required_deferral
    echo "p0 oom containment superseded deferral drained without live mutation"
    exit 0
fi
[ "$INSTALL" -eq 0 ] || validate_package_source_matches_commit
[ "$INSTALL" -eq 0 ] || validate_no_unhandled_package_removals
[ "$INSTALL" -eq 0 ] || validate_root_required_deferral
[ "$INSTALL" -eq 0 ] || install_live
[ "$VERIFY_LIVE" -eq 0 ] || verify_live
[ "$INSTALL" -eq 0 ] || record_installed_source
[ "$INSTALL" -eq 0 ] || record_root_required_package_receipt
[ "$INSTALL" -eq 0 ] || normalize_target_ownership
[ "$INSTALL" -eq 0 ] || drain_root_required_deferral
echo "p0 oom containment install/check complete"
