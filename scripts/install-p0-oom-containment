#!/usr/bin/env bash
# Install P0 OOM containment policy from the source tree to live systemd/earlyoom paths.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SOURCE="$ROOT"
SYSTEMD_SYSTEM_DIR="${HAPAX_OOM_SYSTEMD_SYSTEM_DIR:-/etc/systemd/system}"
SYSTEMD_USER_DIR="${HAPAX_OOM_SYSTEMD_USER_DIR:-$HOME/.config/systemd/user}"
SYSTEMD_USER_CONTROL_DIR="${HAPAX_OOM_SYSTEMD_USER_CONTROL_DIR:-$HOME/.config/systemd/user.control}"
EARLYOOM_DEST="${HAPAX_OOM_EARLYOOM_DEST:-/etc/default/earlyoom}"
SYSTEMCTL="${HAPAX_OOM_SYSTEMCTL:-systemctl}"
SUDO="${HAPAX_OOM_INSTALL_SUDO:-sudo}"
PROC_ROOT="${HAPAX_OOM_PROC_ROOT:-/proc}"
TARGET_UID="${HAPAX_OOM_TARGET_UID:-$(id -u)}"
ROOT_REQUIRED_RC=77
INSTALL=0
CHECK=0
VERIFY_LIVE=0
APPLY_RUNTIME=1

usage() {
    cat <<'USAGE'
usage: scripts/install-p0-oom-containment [--source DIR] [--check] [--install] [--verify-live] [--no-runtime]

Installs the P0 podium OOM containment package:
  systemd/system/user@1000.service.d/oom.conf       -> /etc/systemd/system/user@1000.service.d/oom.conf
  systemd/system/*.service.d/oom-protect.conf       -> /etc/systemd/system/*.service.d/oom-protect.conf
  systemd/units/app.slice.d/oom-containment.conf    -> ~/.config/systemd/user/app.slice.d/oom-containment.conf
  config/earlyoom/default                           -> /etc/default/earlyoom

The app.slice drop-in is copied, not symlinked, so live containment does not
depend on a mutable PR worktree. Runtime activation uses set-property for the
active app.slice instead of restarting the slice.
USAGE
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --source)
            SOURCE="${2:?source dir required after --source}"
            shift 2
            ;;
        --check)
            CHECK=1
            shift
            ;;
        --install)
            INSTALL=1
            shift
            ;;
        --verify-live)
            VERIFY_LIVE=1
            shift
            ;;
        --no-runtime)
            APPLY_RUNTIME=0
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [ "$CHECK" -eq 0 ] && [ "$INSTALL" -eq 0 ] && [ "$VERIFY_LIVE" -eq 0 ]; then
    CHECK=1
fi

run_root() {
    if [ -n "$SUDO" ]; then
        "$SUDO" "$@"
    else
        "$@"
    fi
}

preflight_root() {
    if [ -n "$SUDO" ] && [ "$INSTALL" -eq 1 ]; then
        "$SUDO" -n true 2>/dev/null || {
            echo "sudo non-interactive access is required for OOM containment install; next action: grant NOPASSWD for install/systemctl/tee or run scripts/install-p0-oom-containment --install --verify-live interactively" >&2
            return "$ROOT_REQUIRED_RC"
        }
    fi
}

system_dropins=(
    systemd/system/user@1000.service.d/oom.conf
    systemd/system/apcupsd.service.d/oom-protect.conf
    systemd/system/systemd-logind.service.d/oom-protect.conf
    systemd/system/systemd-resolved.service.d/oom-protect.conf
    systemd/system/systemd-timesyncd.service.d/oom-protect.conf
    systemd/system/NetworkManager.service.d/oom-protect.conf
    systemd/system/dbus-broker.service.d/oom-protect.conf
    systemd/system/sshd.service.d/oom-protect.conf
)
user_dropin="systemd/units/app.slice.d/oom-containment.conf"
earlyoom_source="config/earlyoom/default"
recovery_unit_scores=(
    apcupsd.service:-900
    systemd-logind.service:-800
    systemd-resolved.service:-800
    systemd-timesyncd.service:-800
    NetworkManager.service:-800
    dbus-broker.service:-900
    sshd.service:-1000
)

src_path() {
    printf '%s/%s\n' "$SOURCE" "$1"
}

system_dest() {
    local rel="$1"
    printf '%s/%s\n' "$SYSTEMD_SYSTEM_DIR" "${rel#systemd/system/}"
}

check_source() {
    local rel
    for rel in "${system_dropins[@]}" "$user_dropin" "$earlyoom_source"; do
        [ -f "$(src_path "$rel")" ] || {
            echo "missing source file: $(src_path "$rel"); next action: restore the source tree or rerun from the PR/activation worktree" >&2
            return 1
        }
    done
    grep -Eq '^OOMScoreAdjust=100$' "$(src_path systemd/system/user@1000.service.d/oom.conf)" || {
        echo "user@1000 OOM drop-in must set OOMScoreAdjust=100; next action: restore systemd/system/user@1000.service.d/oom.conf from the P0 PR" >&2
        return 1
    }
    grep -Eq '^MemoryHigh=80G$' "$(src_path "$user_dropin")" || {
        echo "app.slice drop-in missing MemoryHigh=80G; next action: restore systemd/units/app.slice.d/oom-containment.conf from the P0 PR" >&2
        return 1
    }
    grep -q -- "--ignore" "$(src_path "$earlyoom_source")" || {
        echo "earlyoom config missing --ignore recovery list; next action: restore config/earlyoom/default from the P0 PR" >&2
        return 1
    }
    if grep -Eq -- "--(prefer|avoid|ignore)[[:space:]]+'" "$(src_path "$earlyoom_source")"; then
        echo "earlyoom regex arguments must not carry literal single quotes; next action: remove inner quotes from config/earlyoom/default and rerun scripts/install-p0-oom-containment --check" >&2
        return 1
    fi
}

write_oom_score() {
    local pid score path
    pid="$1"
    score="$2"
    path="$PROC_ROOT/$pid/oom_score_adj"
    [ -e "$path" ] || return 0
    if [ -w "$path" ]; then
        printf '%s\n' "$score" > "$path" 2>/dev/null || {
            [ ! -e "$path" ] && return 0
            return 1
        }
    else
        printf '%s\n' "$score" | run_root tee "$path" >/dev/null || {
            [ ! -e "$path" ] && return 0
            return 1
        }
    fi
}

main_pid_for_unit() {
    local unit="$1" pid
    pid="$("$SYSTEMCTL" show "$unit" -p MainPID --value 2>/dev/null || true)"
    if [[ "$pid" =~ ^[0-9]+$ ]] && [ "$pid" -gt 0 ]; then
        printf '%s\n' "$pid"
    fi
}

apply_recovery_unit_oom_scores() {
    local spec unit score pid
    for spec in "${recovery_unit_scores[@]}"; do
        unit="${spec%%:*}"
        score="${spec##*:}"
        pid="$(main_pid_for_unit "$unit")"
        [ -n "$pid" ] || continue
        write_oom_score "$pid" "$score"
    done
}

allowed_user_protected_process() {
    case "$1" in
        pipewire|wireplumber|dbus-broker|dbus-daemon|hapax-daimonion|hapax-daimonio|studio-compositor|studio-composit|hapax-imagination|hapax-imaginat|systemd)
            return 0
            ;;
    esac
    return 1
}

status_field() {
    local status="$1" key="$2"
    awk -v key="$key" '$1 == key ":" {print $2; exit}' "$status" 2>/dev/null || true
}

apply_user_process_oom_floor() {
    local adj pid_dir pid status uid name score fixed=0
    [ -d "$PROC_ROOT" ] || return 0
    for adj in "$PROC_ROOT"/[0-9]*/oom_score_adj; do
        [ -e "$adj" ] || continue
        pid_dir="$(dirname "$adj")"
        pid="$(basename "$pid_dir")"
        status="$pid_dir/status"
        [ -r "$status" ] || continue
        uid="$(status_field "$status" Uid)"
        [ "$uid" = "$TARGET_UID" ] || continue
        name="$(status_field "$status" Name)"
        score="$(cat "$adj" 2>/dev/null || true)"
        [[ "$score" =~ ^-?[0-9]+$ ]] || continue
        [ "$score" -le -800 ] || continue
        allowed_user_protected_process "$name" && continue
        write_oom_score "$pid" 100
        fixed=$((fixed + 1))
    done
    if [ "$fixed" -gt 0 ]; then
        echo "reset $fixed stale user process oom_score_adj values to 100"
    fi
}

install_live() {
    local rel dest
    check_source
    preflight_root
    for rel in "${system_dropins[@]}"; do
        dest="$(system_dest "$rel")"
        run_root install -d -m 0755 "$(dirname "$dest")"
        run_root install -m 0644 "$(src_path "$rel")" "$dest"
        echo "  '$rel' -> '$dest'"
    done
    run_root install -d -m 0755 "$(dirname "$EARLYOOM_DEST")"
    run_root install -m 0644 "$(src_path "$earlyoom_source")" "$EARLYOOM_DEST"
    echo "  '$earlyoom_source' -> '$EARLYOOM_DEST'"

    dest="$SYSTEMD_USER_DIR/app.slice.d/oom-containment.conf"
    install -d -m 0755 "$(dirname "$dest")"
    if [ -L "$dest" ]; then
        rm -f "$dest"
    fi
    install -m 0644 "$(src_path "$user_dropin")" "$dest"
    echo "  '$user_dropin' -> '$dest' (copy)"

    control_dropin_dir="$SYSTEMD_USER_CONTROL_DIR/app.slice.d"
    if [ -d "$control_dropin_dir" ]; then
        rm -f \
            "$control_dropin_dir/50-MemoryHigh.conf" \
            "$control_dropin_dir/50-MemoryMax.conf" \
            "$control_dropin_dir/50-MemorySwapMax.conf"
        rmdir "$control_dropin_dir" 2>/dev/null || true
    fi

    run_root "$SYSTEMCTL" daemon-reload
    "$SYSTEMCTL" --user daemon-reload
    if [ "$APPLY_RUNTIME" -eq 1 ]; then
        "$SYSTEMCTL" --user set-property --runtime app.slice MemoryHigh=80G MemoryMax=104G MemorySwapMax=8G
        if "$SYSTEMCTL" is-active --quiet earlyoom.service; then
            run_root "$SYSTEMCTL" restart earlyoom.service
        fi
        apply_recovery_unit_oom_scores
        user_pid="$("$SYSTEMCTL" show user@1000.service -p MainPID --value 2>/dev/null || true)"
        if [[ "$user_pid" =~ ^[0-9]+$ ]] && [ "$user_pid" -gt 0 ]; then
            write_oom_score "$user_pid" 100 || true
        fi
        apply_user_process_oom_floor
    fi
}

verify_pair() {
    local source="$1" dest="$2"
    [ -f "$dest" ] || {
        echo "missing live file: $dest; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    }
    cmp -s "$source" "$dest" || {
        echo "live drift: $dest differs from $source; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
        return 1
    }
}

verify_live() {
    local rel dest
    for rel in "${system_dropins[@]}"; do
        verify_pair "$(src_path "$rel")" "$(system_dest "$rel")"
    done
    verify_pair "$(src_path "$earlyoom_source")" "$EARLYOOM_DEST"
    dest="$SYSTEMD_USER_DIR/app.slice.d/oom-containment.conf"
    if [ -L "$dest" ]; then
        echo "live app.slice drop-in is a symlink: $dest; next action: run scripts/install-p0-oom-containment --install --verify-live to replace it with a copy" >&2
        return 1
    fi
    verify_pair "$(src_path "$user_dropin")" "$dest"
    verify_recovery_unit_oom_scores
    verify_user_process_oom_floor
}

verify_recovery_unit_oom_scores() {
    local spec unit score pid actual failed=0
    for spec in "${recovery_unit_scores[@]}"; do
        unit="${spec%%:*}"
        score="${spec##*:}"
        pid="$(main_pid_for_unit "$unit")"
        [ -n "$pid" ] || continue
        actual="$(cat "$PROC_ROOT/$pid/oom_score_adj" 2>/dev/null || true)"
        if [ "$actual" != "$score" ]; then
            echo "live OOM score drift for $unit pid $pid: actual=$actual expected=$score; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
            failed=1
        fi
    done
    [ "$failed" -eq 0 ]
}

verify_user_process_oom_floor() {
    local adj pid_dir pid status uid name score failed=0
    [ -d "$PROC_ROOT" ] || return 0
    for adj in "$PROC_ROOT"/[0-9]*/oom_score_adj; do
        [ -e "$adj" ] || continue
        pid_dir="$(dirname "$adj")"
        pid="$(basename "$pid_dir")"
        status="$pid_dir/status"
        [ -r "$status" ] || continue
        uid="$(status_field "$status" Uid)"
        [ "$uid" = "$TARGET_UID" ] || continue
        name="$(status_field "$status" Name)"
        score="$(cat "$adj" 2>/dev/null || true)"
        [[ "$score" =~ ^-?[0-9]+$ ]] || continue
        [ "$score" -le -800 ] || continue
        allowed_user_protected_process "$name" && continue
        echo "residual inherited OOM protection: pid=$pid name=$name oom_score_adj=$score; next action: run scripts/install-p0-oom-containment --install --verify-live" >&2
        failed=1
    done
    [ "$failed" -eq 0 ]
}

[ "$CHECK" -eq 0 ] || check_source
[ "$INSTALL" -eq 0 ] || install_live
[ "$VERIFY_LIVE" -eq 0 ] || verify_live
echo "p0 oom containment install/check complete"
