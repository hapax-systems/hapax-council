#!/bin/bash
# hapax-post-merge-deploy — delta's post-merge deploy helper
#
# Given a commit SHA (typically a merge commit on origin/main), inspect
# the files changed and run the manual deploy steps that the automated
# rebuild-services.timer doesn't cover.
#
# Automated (by rebuild-services.timer, 5-min cadence):
#   agents/**/*.py, shared/**/*.py, logos/**/*.py  → Python service rebuild
#   hapax-logos/crates/hapax-imagination/**         → hapax-rebuild-logos.timer
#                                                     (timer name retained for
#                                                     compat; only builds and
#                                                     installs hapax-imagination
#                                                     — the Tauri/WebKit
#                                                     hapax-logos preview is
#                                                     decommissioned and is
#                                                     never built or restarted)
#
# Manual (this script):
#   config/pipewire/*.conf         → cp + restart pipewire stack
#   config/hapax/*.conf            → cp + restart hapax-audio-reconciler
#   config/wireplumber/*.conf      → cp + restart wireplumber
#   config/wireplumber/scripts/hapax/*.lua → cp to ~/.local/share/wireplumber/scripts/hapax
#                                            + restart wireplumber
#   systemd/*.service|timer|path   → cp + daemon-reload + restart
#   systemd/units/*.service|timer|path|target → cp + daemon-reload + restart
#   systemd/units/*.slice            → cp + daemon-reload (members activate it; no enable/restart)
#       unless the unit has `# Hapax-Install-Scope: system`, in which case
#       it is system/root-scoped and must be installed by its dedicated
#       installer rather than copied into the user unit directory.
#       A unit carrying `# Hapax-Auto-Enable: true` (+ an [Install] section)
#       is `enable --now`'d when newly installed, so a freshly-merged
#       service/timer goes live instead of installing-but-sleeping (the
#       try-restart-is-a-no-op-for-a-never-enabled-unit gap). Unmarked new
#       timers still auto-enable for back-compat; unmarked services do not.
#   systemd/units/*.service.d/*.conf → cp drop-in + daemon-reload + restart active unit
#   systemd/user-preset.d/*.preset → cp user preset
#   systemd/overrides/**           → source/rationale docs only; no direct deploy
#   systemd/scripts/*              → installer helper scripts; no direct deploy
#   systemd/watchdogs/*            → install executable into ~/.local/bin
#   systemd/logrotate.d/*          → logrotate configs; require sudo install
#   systemd/system/**              → system-scoped configs; require sudo install
#   scripts/hapax-*                → ensure ~/.local/bin/ symlink
#   hooks/scripts/{cc-task-gate.impl.sh,agent-role.sh,escape-grant.sh,
#                  hooks-doctor.sh,cc-task-gate.sh}
#                                  → redeploy the ONE canonical gate closure to
#                                    ~/.local/lib/hapax/hooks via hooks-doctor
#                                    --deploy-canonical (reform FM-6: every
#                                    worktree's cc-task-gate.sh is a shim that
#                                    resolves here, so "update the gate" is a
#                                    one-file change, not a 26-worktree fan-out)
#
# Usage:
#   hapax-post-merge-deploy <commit-sha>
#       deploy classified files for the given commit
#   hapax-post-merge-deploy --dry-run <commit-sha>
#       classify files and write the post-merge trace without copying files
#       or restarting services
#   hapax-post-merge-deploy --report-coverage <commit-sha>
#       drift-report mode — exit 1 if any systemd/** path in the commit
#       falls outside the case-globs above. Used by CI to catch the
#       absence-class deploy bug where a new systemd unit lands at a
#       path the deploy script doesn't case-match (P-4 of the
#       absence-class-bug-prevention-and-remediation epic).
#   hapax-post-merge-deploy --verify-auto-enable
#       post-deploy assertion mode — exit 1 if any unit under
#       systemd/units/ marked `# Hapax-Auto-Enable: true` is not enabled
#       (and, for timers, active). Witnesses FM-11 (and future marked
#       units) is live, not merely installed. Needs no commit SHA.
#
# Exits 0 if nothing needed deploying or all deploys succeeded.
# Exits non-zero if any deploy step failed (or, in --report-coverage
# mode, if any systemd/** path is unclassified).
set -euo pipefail

DRY_RUN=0
REPORT_COVERAGE=0
COVERAGE_FROM_STDIN=0
VERIFY_AUTO_ENABLE=0
SINCE=""
TRACE_READY=0
TRACE_WRITTEN=0
SHA=""
if [ "${1:-}" = "--dry-run" ]; then
    DRY_RUN=1
    shift
fi
# --since <sha>: deploy the CUMULATIVE union diff <since>..<commit> instead of
# the single-merge first-parent diff. One deploy then realizes a multi-merge
# backlog — the systemd-units / pipewire-confs / scripts files that get skipped
# when origin/main jumps several merges between deploy cycles (the root of the
# "merged but never installed" recurrence). Used by the one-time backfill, the
# source-activation cumulative path, and the .service edge-trigger.
if [ "${1:-}" = "--since" ]; then
    SINCE="${2:?commit SHA required after --since}"
    shift 2
fi
if [ "${1:-}" = "--report-coverage" ]; then
    REPORT_COVERAGE=1
    SHA="${2:?commit SHA required after --report-coverage}"
elif [ "${1:-}" = "--report-coverage-stdin" ]; then
    REPORT_COVERAGE=1
    COVERAGE_FROM_STDIN=1
elif [ "${1:-}" = "--verify-auto-enable" ]; then
    VERIFY_AUTO_ENABLE=1
else
    SHA="${1:?commit SHA required}"
fi
REPO="${REPO:-${GITHUB_WORKSPACE:-$HOME/projects/hapax-council}}"
PW_CONF_DIR="$HOME/.config/pipewire/pipewire.conf.d"
HAPAX_CONF_DIR="$HOME/.config/hapax"
WP_CONF_DIR="$HOME/.config/wireplumber/wireplumber.conf.d"
# WirePlumber Lua components load from the XDG *data* dir, not the conf dir.
# scripts/hapax-wireplumber-link-deny-policy installs link-deny.lua here and
# config/wireplumber/98-hapax-link-deny.conf references it as `hapax/link-deny.lua`.
WP_SCRIPTS_DIR="$HOME/.local/share/wireplumber/scripts/hapax"
SYSTEMD_USER_DIR="$HOME/.config/systemd/user"
SYSTEMD_USER_PRESET_DIR="$HOME/.config/systemd/user-preset"
LOCAL_BIN="$HOME/.local/bin"
TRACE_PATH="${HAPAX_POST_MERGE_TRACE_PATH:-$HOME/.cache/hapax/post-merge-traces/post-merge-traces.jsonl}"
TRACE_MAX_RECORDS="${HAPAX_POST_MERGE_TRACE_MAX_RECORDS:-200}"
# Receipt of the last SHA a real deploy cycle ran against (completed or
# no_changes). The rebuild-service.sh staleness alarm and the acceptance check
# `git rev-list <last-deployed-sha>..origin/main` read this, and the .service
# edge-trigger reads it to compute the cumulative --since range. Sibling of the
# trace file by default so a test override of HAPAX_POST_MERGE_TRACE_PATH
# isolates it automatically.
LAST_DEPLOYED_SHA_PATH="${HAPAX_POST_MERGE_LAST_DEPLOYED_SHA_PATH:-$(dirname "$TRACE_PATH")/last-deployed-sha}"

# --- auto-enable marker (reform-improve-deploy-activation-20260601) ---
# A systemd unit may declare it wants to be enabled+started on deploy by
# carrying a `# Hapax-Auto-Enable: true` comment annotation (mirrors the
# `# Hapax-Install-Scope: system` convention). Without this, `try-restart`
# is a no-op for a never-enabled unit, so a freshly-merged timer/service
# installs but never starts — the systemic "merged but sleeping" gap behind
# the FM-11 lane supervisor. The marker is honoured ONLY when the unit also
# has an [Install] section (`systemctl enable` errors on a unit with none).
unit_content_auto_enable() {
    local content="$1"
    [ -n "$content" ] || return 1
    grep -Eiq '^[#;][[:space:]]*Hapax-Auto-Enable:[[:space:]]*(true|yes|1)[[:space:]]*$' <<< "$content" || return 1
    grep -Eq '^\[Install\]' <<< "$content" || return 1
    return 0
}

# --verify-auto-enable: post-deploy assertion that every unit in the repo's
# systemd/units/ carrying `# Hapax-Auto-Enable: true` is actually `enabled`
# (and, for timers, `active`). Exits 0 if all marked units pass, 1 if any
# marked unit is not live. Lets the operator / smoke runner witness FM-11
# (and any future marked unit) is running, not merely installed. Reads the
# working tree, so it needs no commit SHA and runs before the trace/trap setup.
if [ "$VERIFY_AUTO_ENABLE" = "1" ]; then
    UNITS_DIR="$REPO/systemd/units"
    if [ ! -d "$UNITS_DIR" ]; then
        echo "verify-auto-enable: $UNITS_DIR not found" >&2
        exit 2
    fi
    verify_rc=0
    marked_count=0
    for uf in "$UNITS_DIR"/*.service "$UNITS_DIR"/*.timer "$UNITS_DIR"/*.path "$UNITS_DIR"/*.target; do
        [ -f "$uf" ] || continue
        unit_content_auto_enable "$(cat "$uf")" || continue
        unit_base="$(basename "$uf")"
        marked_count=$((marked_count + 1))
        if ! systemctl --user is-enabled "$unit_base" >/dev/null 2>&1; then
            echo "FAIL: $unit_base is marked Hapax-Auto-Enable but is not enabled" >&2
            verify_rc=1
            continue
        fi
        if [[ "$unit_base" == *.timer ]] \
            && ! systemctl --user is-active "$unit_base" >/dev/null 2>&1; then
            echo "FAIL: timer $unit_base is marked Hapax-Auto-Enable but is not active" >&2
            verify_rc=1
            continue
        fi
        if [[ "$unit_base" == *.timer ]]; then
            echo "ok: $unit_base enabled + active"
        else
            echo "ok: $unit_base enabled"
        fi
    done
    if [ "$marked_count" -eq 0 ]; then
        echo "verify-auto-enable: no Hapax-Auto-Enable units in $UNITS_DIR"
    elif [ "$verify_rc" -eq 0 ]; then
        echo "verify-auto-enable: all $marked_count marked unit(s) enabled/active"
    fi
    exit "$verify_rc"
fi

_trace_join() {
    local item
    for item in "$@"; do
        printf '%s\n' "$item"
    done
}

record_post_merge_trace() {
    local status="$1"
    local exit_code="${2:-0}"

    HAPAX_TRACE_FILES="$FILES" \
    HAPAX_TRACE_PW="$(_trace_join "${PW[@]}")" \
    HAPAX_TRACE_HAPAX_CONF="$(_trace_join "${HAPAX_CONF[@]}")" \
    HAPAX_TRACE_WP="$(_trace_join "${WP[@]}")" \
    HAPAX_TRACE_WP_LUA="$(_trace_join "${WP_LUA[@]}")" \
    HAPAX_TRACE_SYSTEMD="$(_trace_join "${SYSTEMD[@]}")" \
    HAPAX_TRACE_SYSTEMD_SYSTEM="$(_trace_join "${SYSTEMD_SYSTEM[@]}")" \
    HAPAX_TRACE_SYSTEMD_DROPINS="$(_trace_join "${SYSTEMD_DROPINS[@]}")" \
    HAPAX_TRACE_USER_PRESETS="$(_trace_join "${USER_PRESETS[@]}")" \
    HAPAX_TRACE_WATCHDOGS="$(_trace_join "${WATCHDOGS[@]}")" \
    HAPAX_TRACE_SCRIPTS="$(_trace_join "${SCRIPTS[@]}")" \
    HAPAX_TRACE_SCRIPT_PY="$(_trace_join "${SCRIPT_PY[@]}")" \
    HAPAX_TRACE_AUDIO_SAFE_RESTARTS="$(_trace_join "${AUDIO_SAFE_RESTARTS[@]}")" \
    HAPAX_TRACE_SYSTEMD_UNCLASSIFIED="$(_trace_join "${SYSTEMD_UNCLASSIFIED[@]}")" \
    python3 - "$TRACE_PATH" "$TRACE_MAX_RECORDS" "$SHA" "$DRY_RUN" "$status" "$exit_code" \
        "$DID_ANYTHING" <<'PY'
from __future__ import annotations

import json
import os
import sys
from datetime import UTC, datetime
from pathlib import Path


def lines(name: str) -> list[str]:
    return [line for line in os.environ.get(name, "").splitlines() if line]


path = Path(sys.argv[1]).expanduser()
try:
    max_records = int(sys.argv[2])
except ValueError:
    max_records = 200
max_records = max(1, max_records)
sha = sys.argv[3]
dry_run = sys.argv[4] == "1"
status = sys.argv[5]
exit_code = int(sys.argv[6])
manual_deploy_executed = sys.argv[7] == "1"

deploy_groups = {
    "pipewire": lines("HAPAX_TRACE_PW"),
    "hapax_runtime_config": lines("HAPAX_TRACE_HAPAX_CONF"),
    "wireplumber": lines("HAPAX_TRACE_WP"),
    "wireplumber_lua": lines("HAPAX_TRACE_WP_LUA"),
    "systemd_units": lines("HAPAX_TRACE_SYSTEMD"),
    "systemd_system_units": lines("HAPAX_TRACE_SYSTEMD_SYSTEM"),
    "systemd_dropins": lines("HAPAX_TRACE_SYSTEMD_DROPINS"),
    "systemd_user_presets": lines("HAPAX_TRACE_USER_PRESETS"),
    "systemd_watchdogs": lines("HAPAX_TRACE_WATCHDOGS"),
    "hapax_scripts": lines("HAPAX_TRACE_SCRIPTS"),
    "unit_backing_scripts": lines("HAPAX_TRACE_SCRIPT_PY"),
}
runtime_media_groups = [
    name
    for name in (
        "pipewire",
        "hapax_runtime_config",
        "wireplumber",
        "wireplumber_lua",
        "systemd_units",
        "systemd_system_units",
        "systemd_dropins",
        "systemd_watchdogs",
        "hapax_scripts",
        "unit_backing_scripts",
    )
    if deploy_groups[name]
]
record = {
    "schema_version": 1,
    "event": "post_merge_deploy",
    "timestamp": datetime.now(UTC).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    "sha": sha,
    "mode": "dry_run" if dry_run else "deploy",
    "status": status,
    "exit_code": exit_code,
    "changed_files": lines("HAPAX_TRACE_FILES"),
    "deploy_groups": deploy_groups,
    "manual_deploy_needed": any(deploy_groups.values()),
    "manual_deploy_executed": manual_deploy_executed,
    "audio_safe_restart_units": lines("HAPAX_TRACE_AUDIO_SAFE_RESTARTS"),
    "systemd_unclassified": lines("HAPAX_TRACE_SYSTEMD_UNCLASSIFIED"),
    "avsdlc": {
        "gate_point": "S9 post-merge production witness",
        "runtime_media_witness_required": bool(runtime_media_groups),
        "runtime_media_witness_groups": runtime_media_groups,
    },
}

path.parent.mkdir(parents=True, exist_ok=True)
previous = []
if path.exists():
    previous = [line for line in path.read_text(encoding="utf-8").splitlines() if line.strip()]
previous.append(json.dumps(record, sort_keys=True))
kept = previous[-max_records:]
tmp_path = path.with_name(f"{path.name}.tmp")
tmp_path.write_text("\n".join(kept) + "\n", encoding="utf-8")
os.replace(tmp_path, path)
PY
}

trace_on_exit() {
    local rc=$?
    if [ "$REPORT_COVERAGE" != "1" ] \
        && [ "$TRACE_READY" = "1" ] \
        && [ "$TRACE_WRITTEN" != "1" ]; then
        if [ "$DRY_RUN" = "1" ]; then
            record_post_merge_trace "dry_run_failed" "$rc" || true
        elif [ "$rc" -ne 0 ]; then
            record_post_merge_trace "failed" "$rc" || true
        fi
    fi
}

trap trace_on_exit EXIT

# Record the SHA this deploy cycle ran against (real-deploy modes only). The
# staleness alarm + the AC `rev-list <last-deployed-sha>..origin/main` read it;
# the .service edge-trigger reads it to compute the cumulative --since range.
record_last_deployed_sha() {
    [ "$DRY_RUN" = "1" ] && return 0
    [ "$REPORT_COVERAGE" = "1" ] && return 0
    [ -n "$SHA" ] || return 0
    mkdir -p "$(dirname "$LAST_DEPLOYED_SHA_PATH")" 2>/dev/null || true
    printf '%s\n' "$SHA" > "$LAST_DEPLOYED_SHA_PATH"
}

cd "$REPO"
# Ensure the commit's objects are available locally even if main hasn't been
# pulled yet; diffing an unfetched SHA would fail and falsely signal
# "file deleted" to the per-file branches below.
if [ "$COVERAGE_FROM_STDIN" != "1" ]; then
    git fetch --quiet origin main 2>/dev/null || true
    if [[ "$SHA" == *..* ]]; then
        echo "hapax-post-merge-deploy: expected a single commit SHA/ref, got range '$SHA'" >&2
        exit 2
    fi
    if ! SHA_RESOLVED="$(git rev-parse --verify --quiet "$SHA^{commit}")"; then
        echo "hapax-post-merge-deploy: '$SHA' is not a valid commit" >&2
        exit 2
    fi
    SHA="$SHA_RESOLVED"
fi

if [ "$COVERAGE_FROM_STDIN" = "1" ]; then
    FILES="$(cat)"
elif [ -n "$SINCE" ]; then
    # Cumulative range deploy: union of every file changed across <since>..<SHA>.
    if ! git rev-parse --verify --quiet "$SINCE^{commit}" >/dev/null; then
        echo "hapax-post-merge-deploy: --since '$SINCE' is not a valid commit" >&2
        exit 2
    fi
    FILES="$(git diff --name-only "$SINCE" "$SHA" | sort -u)"
elif FIRST_PARENT="$(git rev-parse --verify --quiet "$SHA^1")"; then
    FILES="$(git diff --name-only "$FIRST_PARENT" "$SHA" | sort -u)"
else
    FILES="$(git diff-tree --root --no-commit-id --name-only -r "$SHA" | sort -u)"
fi

PW=(); HAPAX_CONF=(); WP=(); WP_LUA=(); SYSTEMD=(); SYSTEMD_SYSTEM=(); SYSTEMD_DROPINS=(); USER_PRESETS=(); WATCHDOGS=(); SCRIPTS=(); SCRIPT_PY=()
GATE_CLOSURE=()
SYSTEMD_UNCLASSIFIED=()
AUDIO_SAFE_RESTARTS=()
DID_ANYTHING=0

unit_install_scope() {
    local f="$1"
    if [ "$COVERAGE_FROM_STDIN" = "1" ]; then
        printf 'user\n'
        return 0
    fi
    local content
    content="$(git show "$SHA:$f" 2>/dev/null || true)"
    if [ -n "$content" ] \
        && grep -Eiq '^[#;][[:space:]]*Hapax-Install-Scope:[[:space:]]*system([[:space:]]*$|[[:space:]]+)' <<< "$content"; then
        printf 'system\n'
    else
        printf 'user\n'
    fi
}

AUDIO_SAFE_RESTART_UNITS=(
    hapax-broadcast-orchestrator.service
    hapax-music-player.service
    hapax-content-resolver.service
    hapax-audio-router.service
    hapax-audio-ducker.service
    hapax-daimonion.service
)

is_audio_safe_restart_unit() {
    local unit="$1"
    local candidate
    for candidate in "${AUDIO_SAFE_RESTART_UNITS[@]}"; do
        if [[ "$candidate" == "$unit" ]]; then
            return 0
        fi
    done
    return 1
}

audio_safe_restart_bin() {
    if [[ -n "${HAPAX_AUDIO_SAFE_RESTART_BIN:-}" ]]; then
        printf '%s\n' "$HAPAX_AUDIO_SAFE_RESTART_BIN"
        return 0
    fi
    if [[ -x "$REPO/scripts/hapax-audio-safe-restart" ]]; then
        printf '%s\n' "$REPO/scripts/hapax-audio-safe-restart"
        return 0
    fi
    local candidate
    if candidate="$(command -v hapax-audio-safe-restart 2>/dev/null)" \
        && [[ -x "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    return 1
}

restart_user_unit() {
    local unit="$1"
    if is_audio_safe_restart_unit "$unit"; then
        local safe_bin
        if ! safe_bin="$(audio_safe_restart_bin)"; then
            echo "hapax-post-merge-deploy: refusing plain restart for audio-touching unit $unit; hapax-audio-safe-restart not found" >&2
            return 4
        fi
        echo "audio-safe restarting $unit"
        set +e
        "$safe_bin" "$unit"
        local safe_rc=$?
        set -e
        AUDIO_SAFE_RESTARTS+=("$unit")
        if [[ "$safe_rc" -eq 0 ]]; then
            return 0
        fi
        if [[ "$safe_rc" -eq 1 ]]; then
            echo "hapax-post-merge-deploy: audio-safe restart rolled back $unit successfully" >&2
            return 0
        fi
        return "$safe_rc"
    fi

    systemctl --user restart "$unit"
}

# Per-file deploy uses `git cat-file -e $SHA:$path` + `git show $SHA:$path`
# to read commit-time content, decoupling the deploy decision from local
# working-tree state. Prior revision used [ -f $REPO/$f ] which raced the
# working-tree pull: when the deploy fired BEFORE the main branch had been
# pulled locally, a deletion commit's [ -f ] returned true (old file still
# present) and the script mistakenly cp-re-deployed the pre-deletion version.
if [ -z "$FILES" ]; then
    if [ "$REPORT_COVERAGE" != "1" ]; then
        TRACE_READY=1
        if record_post_merge_trace "no_changes" "0"; then
            TRACE_WRITTEN=1
        fi
        record_last_deployed_sha
    fi
    echo "no files changed in $SHA"
    exit 0
fi

# Classify the file list. SYSTEMD_UNCLASSIFIED captures systemd/** paths
# that DON'T match the case-globs below — used by --report-coverage to
# catch the absence-class deploy bug where a new unit lands at a path
# this script can't reach (P-4 of the absence-class-bug-prevention-and-
# remediation epic).
while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        config/pipewire/*.conf)           PW+=("$f") ;;
        config/hapax/*.conf)              HAPAX_CONF+=("$f") ;;
        config/wireplumber/scripts/hapax/*.lua) WP_LUA+=("$f") ;;
        config/wireplumber/*.conf)        WP+=("$f") ;;
        systemd/units/*.service|systemd/units/*.timer|systemd/units/*.path|systemd/units/*.target|systemd/units/*.slice)
            if [ "$(unit_install_scope "$f")" = "system" ]; then
                SYSTEMD_SYSTEM+=("$f")
            else
                SYSTEMD+=("$f")
            fi
            ;;
        systemd/*.service|systemd/*.timer|systemd/*.path) SYSTEMD+=("$f") ;;
        systemd/units/*.service.d/*.conf|systemd/units/*.timer.d/*.conf) SYSTEMD_DROPINS+=("$f") ;;
        systemd/user-preset.d/*.preset)   USER_PRESETS+=("$f") ;;
        systemd/watchdogs/*)              WATCHDOGS+=("$f") ;;
        systemd/scripts/*)                ;; # installer helpers; run manually when needed
        systemd/udev/*.rules)             ;; # udev rules; require sudo install + udevadm reload (operator action)
        systemd/logrotate.d/*)            ;; # logrotate configs; require sudo install
        systemd/system/*)                 ;; # system-scoped configs; require sudo install
        hooks/scripts/cc-task-gate.impl.sh|hooks/scripts/agent-role.sh|hooks/scripts/escape-grant.sh|hooks/scripts/cc-task-gate-bootstrap.py|hooks/scripts/hooks-doctor.sh|hooks/scripts/cc-task-gate.sh)
            GATE_CLOSURE+=("$f") ;;
        scripts/hapax-*)                  SCRIPTS+=("$f") ;;
        scripts/*.py|scripts/*.sh)        SCRIPT_PY+=("$f") ;;
        systemd/expected-timers.yaml)     ;; # frozen-baseline doc, not deployable
        systemd/README.md)                ;; # docs
        systemd/overrides/*)              ;; # source/rationale docs; deployable copies live under systemd/units
        systemd/*)                        SYSTEMD_UNCLASSIFIED+=("$f") ;;
    esac
done <<< "$FILES"

if [ "$REPORT_COVERAGE" = "1" ]; then
    if [ "${#SYSTEMD_UNCLASSIFIED[@]}" -gt 0 ]; then
        echo "ERROR: ${#SYSTEMD_UNCLASSIFIED[@]} systemd/** path(s) in $SHA fall outside hapax-post-merge-deploy case-globs:" >&2
        for f in "${SYSTEMD_UNCLASSIFIED[@]}"; do
            echo "  $f" >&2
        done
        echo "" >&2
        echo "Either move the files to a covered glob (systemd/units/*.service|*.timer)" >&2
        echo "or extend the case statement in hapax-post-merge-deploy. The current" >&2
        echo "supported globs are documented at the top of the script." >&2
        exit 1
    fi
    echo "ok: all systemd/** paths in $SHA are covered by case-globs"
    exit 0
fi

TRACE_READY=1
if [ "$DRY_RUN" = "1" ]; then
    record_post_merge_trace "dry_run" "0"
    TRACE_WRITTEN=1
    echo "dry-run: post-merge deploy trace written to $TRACE_PATH"
    exit 0
fi

# --- PipeWire confs ---
if [ "${#PW[@]}" -gt 0 ]; then
    echo "pipewire confs changed (${#PW[@]}):"
    mkdir -p "$PW_CONF_DIR"
    for f in "${PW[@]}"; do
        dest="$PW_CONF_DIR/$(basename "$f")"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$dest"
            echo "  '$f' -> '$dest'"
        else
            echo "  (deleted: $f)"
            rm -fv "$dest" || true
        fi
    done
    echo "restarting pipewire stack"
    systemctl --user restart pipewire pipewire-pulse wireplumber
    DID_ANYTHING=1
fi

# --- Hapax runtime config ---
if [ "${#HAPAX_CONF[@]}" -gt 0 ]; then
    echo "hapax runtime config changed (${#HAPAX_CONF[@]}):"
    mkdir -p "$HAPAX_CONF_DIR"
    for f in "${HAPAX_CONF[@]}"; do
        dest="$HAPAX_CONF_DIR/$(basename "$f")"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$dest"
            echo "  '$f' -> '$dest'"
        else
            echo "  (deleted: $f)"
            rm -fv "$dest" || true
        fi
    done
    echo "restarting hapax-audio-reconciler"
    systemctl --user restart hapax-audio-reconciler.service || true
    DID_ANYTHING=1
fi

# --- WirePlumber confs ---
if [ "${#WP[@]}" -gt 0 ]; then
    echo "wireplumber confs changed (${#WP[@]}):"
    mkdir -p "$WP_CONF_DIR"
    for f in "${WP[@]}"; do
        dest="$WP_CONF_DIR/$(basename "$f")"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$dest"
            echo "  '$f' -> '$dest'"
        else
            rm -fv "$dest" || true
        fi
    done
    # WP restart alone if we didn't already restart above
    if [ "${#PW[@]}" -eq 0 ]; then
        systemctl --user restart wireplumber
    fi
    DID_ANYTHING=1
fi

# --- WirePlumber Lua scripts (private-fence deny policy etc.) ---
# The .conf goes to ~/.config/wireplumber/wireplumber.conf.d (handled above); the
# Lua component it loads lives under the XDG *data* dir
# ~/.local/share/wireplumber/scripts/hapax (see scripts/hapax-wireplumber-link-deny-policy
# and config/wireplumber/98-hapax-link-deny.conf). Without this case the deny
# policy can go stale on deploy while its .conf updates (FM-13).
if [ "${#WP_LUA[@]}" -gt 0 ]; then
    echo "wireplumber lua scripts changed (${#WP_LUA[@]}):"
    mkdir -p "$WP_SCRIPTS_DIR"
    for f in "${WP_LUA[@]}"; do
        dest="$WP_SCRIPTS_DIR/$(basename "$f")"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$dest"
            echo "  '$f' -> '$dest'"
        else
            rm -fv "$dest" || true
        fi
    done
    # Restart wireplumber only if neither the pipewire stack nor the WP confs
    # above already restarted it.
    if [ "${#PW[@]}" -eq 0 ] && [ "${#WP[@]}" -eq 0 ]; then
        systemctl --user restart wireplumber
    fi
    DID_ANYTHING=1
fi

# --- systemd watchdog helper scripts ---
if [ "${#WATCHDOGS[@]}" -gt 0 ]; then
    echo "systemd watchdog scripts changed (${#WATCHDOGS[@]}):"
    mkdir -p "$LOCAL_BIN"
    for f in "${WATCHDOGS[@]}"; do
        base="$(basename "$f")"
        dest="$LOCAL_BIN/$base"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$dest"
            chmod +x "$dest" 2>/dev/null || true
            echo "  '$f' -> '$dest'"
        else
            rm -fv "$dest" || true
        fi
        matches="$(grep -l -F "$dest" "$REPO/systemd/units/"*.service 2>/dev/null || true)"
        for unit_path in $matches; do
            base_unit="$(basename "$unit_path")"
            if systemctl --user is-active --quiet "$base_unit"; then
                echo "  restarting $base_unit (uses $dest)"
                restart_user_unit "$base_unit"
            fi
        done
    done
    DID_ANYTHING=1
fi

# --- systemd unit drop-ins ---
if [ "${#SYSTEMD_DROPINS[@]}" -gt 0 ]; then
    echo "systemd drop-ins changed (${#SYSTEMD_DROPINS[@]}):"
    mkdir -p "$SYSTEMD_USER_DIR"
    DROPIN_UNITS_TO_RESTART=()
    for f in "${SYSTEMD_DROPINS[@]}"; do
        rel="${f#systemd/units/}"
        dropin_dir="$(dirname "$rel")"
        conf_name="$(basename "$f")"
        unit_name="${dropin_dir%.d}"
        dest_dir="$SYSTEMD_USER_DIR/$dropin_dir"
        dest="$dest_dir/$conf_name"
        mkdir -p "$dest_dir"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$dest"
            echo "  '$f' -> '$dest'"
            DROPIN_UNITS_TO_RESTART+=("$unit_name")
        else
            rm -fv "$dest" || true
        fi
    done
    systemctl --user daemon-reload
    for u in "${DROPIN_UNITS_TO_RESTART[@]}"; do
        if systemctl --user is-active --quiet "$u"; then
            echo "restarting $u"
            restart_user_unit "$u"
        elif [[ "$u" == *.timer ]]; then
            echo "try-restarting $u"
            systemctl --user try-restart "$u" || true
        fi
    done
    DID_ANYTHING=1
fi

# --- systemd units ---
if [ "${#SYSTEMD_SYSTEM[@]}" -gt 0 ]; then
    echo "system-scoped systemd units changed (${#SYSTEMD_SYSTEM[@]}):"
    mkdir -p "$SYSTEMD_USER_DIR"
    for f in "${SYSTEMD_SYSTEM[@]}"; do
        base="$(basename "$f")"
        dest="$SYSTEMD_USER_DIR/$base"
        echo "  '$f' marked Hapax-Install-Scope: system; skipping user deploy"
        systemctl --user disable --now "$base" >/dev/null 2>&1 || true
        if [ -e "$dest" ] || [ -L "$dest" ]; then
            rm -fv "$dest" || true
        fi
    done
    systemctl --user daemon-reload
    DID_ANYTHING=1
fi

if [ "${#SYSTEMD[@]}" -gt 0 ]; then
    echo "systemd units changed (${#SYSTEMD[@]}):"
    mkdir -p "$SYSTEMD_USER_DIR"
    SYSTEMD_INSTALLED=()
    for f in "${SYSTEMD[@]}"; do
        base="$(basename "$f")"
        dest="$SYSTEMD_USER_DIR/$base"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$dest"
            echo "  '$f' -> '$dest'"
            SYSTEMD_INSTALLED+=("$f")
        else
            rm -fv "$dest" || true
        fi
    done
    systemctl --user daemon-reload
    for f in "${SYSTEMD_INSTALLED[@]}"; do
        base="$(basename "$f")"
        if systemctl --user is-active --quiet "$base"; then
            # Already running — restart to pick up the new unit definition.
            echo "restarting $base"
            restart_user_unit "$base"
        elif unit_content_auto_enable "$(git show "$SHA:$f" 2>/dev/null || true)"; then
            # Marked `# Hapax-Auto-Enable: true` (+ [Install]): enable+start so a
            # freshly-merged service OR timer goes live instead of sleeping.
            # try-restart is a no-op for a never-enabled unit (the FM-11 gap).
            echo "auto-enabling $base (Hapax-Auto-Enable marker)"
            systemctl --user enable --now "$base"
        elif [[ "$base" == *.timer ]]; then
            # Back-compat: an unmarked NEW timer still auto-enables — timers are
            # inert until started, and this has been the behaviour since #3475.
            echo "enabling+starting $base"
            systemctl --user enable --now "$base"
        fi
    done
    DID_ANYTHING=1
fi

# --- systemd user presets ---
if [ "${#USER_PRESETS[@]}" -gt 0 ]; then
    echo "systemd user presets changed (${#USER_PRESETS[@]}):"
    mkdir -p "$SYSTEMD_USER_PRESET_DIR"
    for f in "${USER_PRESETS[@]}"; do
        base="$(basename "$f")"
        dest="$SYSTEMD_USER_PRESET_DIR/$base"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$dest"
            echo "  '$f' -> '$dest'"
        else
            rm -fv "$dest" || true
        fi
    done
    systemctl --user daemon-reload
    DID_ANYTHING=1
fi

# --- scripts/hapax-* symlinks ---
if [ "${#SCRIPTS[@]}" -gt 0 ]; then
    echo "scripts changed (${#SCRIPTS[@]}):"
    mkdir -p "$LOCAL_BIN"
    for f in "${SCRIPTS[@]}"; do
        base="$(basename "$f")"
        dest="$LOCAL_BIN/$base"
        if [ -f "$REPO/$f" ]; then
            chmod +x "$REPO/$f" 2>/dev/null || true
            if [ ! -L "$dest" ] || [ "$(readlink "$dest")" != "$REPO/$f" ]; then
                ln -sfv "$REPO/$f" "$dest"
            fi
        else
            rm -fv "$dest" || true
        fi
        matches="$(
            { grep -l -F "$dest" "$REPO/systemd/units/"*.service 2>/dev/null || true; \
              grep -l -F "$f" "$REPO/systemd/units/"*.service 2>/dev/null || true; } | sort -u
        )"
        for unit_path in $matches; do
            base_unit="$(basename "$unit_path")"
            if systemctl --user is-active --quiet "$base_unit"; then
                echo "  restarting $base_unit (uses $dest)"
                restart_user_unit "$base_unit"
            fi
        done
    done
    DID_ANYTHING=1
fi

# --- scripts/*.py / *.sh that back systemd user units ---
# The rebuild-services.timer cascade doesn't watch scripts/; if a
# systemd user unit's ExecStart references a script we just changed,
# restart that unit. Catches producers like hapax-youtube-viewer-count
# that live in scripts/ rather than agents/.
if [ "${#SCRIPT_PY[@]}" -gt 0 ]; then
    echo "backing-script changes (${#SCRIPT_PY[@]}):"
    for f in "${SCRIPT_PY[@]}"; do
        # Find units whose ExecStart references this script (any invocation form).
        # Search both the repo definitions and the installed user units.
        matches="$(grep -l -F "$f" "$REPO/systemd/units/"*.service 2>/dev/null || true)"
        for unit_path in $matches; do
            base="$(basename "$unit_path")"
            if systemctl --user is-active --quiet "$base"; then
                echo "  restarting $base (backs $f)"
                restart_user_unit "$base"
                DID_ANYTHING=1
            fi
        done
    done
fi

# --- canonical gate closure (reform FM-6 shim collapse) ---
# When the gate impl or its sourced siblings change, redeploy the ONE canonical
# copy that every worktree's cc-task-gate.sh shim resolves to. Materialize the
# closure from $SHA (commit-time content, decoupled from the working tree like
# every other deploy here), then hand it to hooks-doctor --deploy-canonical, which
# renames the impl to cc-task-gate.sh, writes a sha256 MANIFEST, symlinks
# ~/.local/bin/hapax-hooks-doctor, and REFUSES any impl missing the INV-5
# is_cognition_path carve-out (so a bad gate never lands fleet-wide).
if [ "${#GATE_CLOSURE[@]}" -gt 0 ]; then
    echo "gate closure changed (${#GATE_CLOSURE[@]}): redeploying canonical gate"
    GATE_STAGE="$(mktemp -d)"
    mkdir -p "$GATE_STAGE/hooks/scripts"
    # The full closure the impl needs at runtime: the impl, the files it sources
    # (agent-role, escape-grant) AND invokes (cc-task-gate-bootstrap.py, §3b), plus
    # the doctor. Omitting any makes the deployed gate exit 2 on every mutation.
    for f in hooks/scripts/cc-task-gate.impl.sh hooks/scripts/agent-role.sh \
             hooks/scripts/escape-grant.sh hooks/scripts/cc-task-gate-bootstrap.py \
             hooks/scripts/hooks-doctor.sh; do
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$GATE_STAGE/$f"
            chmod +x "$GATE_STAGE/$f" 2>/dev/null || true
        fi
    done
    if [ -x "$GATE_STAGE/hooks/scripts/hooks-doctor.sh" ]; then
        bash "$GATE_STAGE/hooks/scripts/hooks-doctor.sh" --deploy-canonical --from "$GATE_STAGE" \
            || echo "warning: canonical gate deploy failed" >&2
    else
        echo "warning: hooks-doctor.sh absent at $SHA; skipping canonical gate deploy" >&2
    fi
    rm -rf "$GATE_STAGE" 2>/dev/null || true
    DID_ANYTHING=1
fi

if [ "$DID_ANYTHING" -eq 0 ]; then
    echo "merge $SHA: no manual deploys needed (only auto-rebuild paths changed)"
fi

# Smoke-runner gate (cc-task post-merge-smoke-deploy-wiring, 2026-05-02).
# DRY_RUN and REPORT_COVERAGE modes exited earlier so this only fires
# in real-deploy mode. The smoke runner inspects the diff for $SHA,
# fires gates that match, ntfy's on failure, and ALWAYS exits 0 — the
# deploy already happened; the smoke is informational. The script
# itself enforces the 0-exit contract; we still wrap with `|| true`
# defensively so a smoke-side bug can never block trace recording or
# the deploy script's normal exit. Rationale: shipping in #2148
# without a deploy-chain caller meant every smoke-side fix lived as
# dead code (zeta audit finding 2026-05-02, severity HIGH).
SMOKE_SCRIPT="$REPO/scripts/hapax-post-merge-smoke"
if [ -x "$SMOKE_SCRIPT" ]; then
    "$SMOKE_SCRIPT" "$SHA" || true
fi

if record_post_merge_trace "completed" "0"; then
    TRACE_WRITTEN=1
else
    echo "warning: failed to write post-merge deploy trace to $TRACE_PATH" >&2
fi
record_last_deployed_sha
