#!/bin/bash
# hapax-post-merge-deploy — delta's post-merge deploy helper
#
# Given a commit SHA (typically a merge commit on origin/main), inspect
# the files changed and run the manual deploy steps that the automated
# rebuild-services.timer doesn't cover.
#
# Automated (by rebuild-services.timer, 5-min cadence):
#   agents/**/*.py, shared/**/*.py, logos/**/*.py  → Python service rebuild
#   hapax-logos/crates/hapax-imagination/**         → hapax-rebuild-logos.timer
#                                                     (timer name retained for
#                                                     compat; only builds and
#                                                     installs hapax-imagination
#                                                     — the Tauri/WebKit
#                                                     hapax-logos preview is
#                                                     decommissioned and is
#                                                     never built or restarted)
#
# Manual (this script):
#   config/pipewire/*.conf         → cp + restart pipewire stack
#   config/hapax/*.conf            → cp + restart hapax-audio-reconciler
#   config/wireplumber/*.conf      → cp + restart wireplumber
#   config/wireplumber/scripts/hapax/*.lua → cp to ~/.local/share/wireplumber/scripts/hapax
#                                            + restart wireplumber
#   systemd/*.service|timer|path   → cp + daemon-reload + restart
#   systemd/units/*.service|timer|path|target → cp + daemon-reload + restart
#   systemd/units/*.slice            → cp + daemon-reload (members activate it; no enable/restart)
#       unless the unit has `# Hapax-Install-Scope: system`, in which case
#       it is system/root-scoped and must be installed by its dedicated
#       installer rather than copied into the user unit directory.
#       A unit carrying `# Hapax-Auto-Enable: true` (+ an [Install] section)
#       is `enable --now`'d when newly installed, so a freshly-merged
#       service/timer goes live instead of installing-but-sleeping (the
#       try-restart-is-a-no-op-for-a-never-enabled-unit gap). Unmarked new
#       timers still auto-enable for back-compat; unmarked services do not.
#   systemd/units/*.service.d/*.conf → cp drop-in + daemon-reload + restart active unit
#       plus known stale local route-dropin cleanup for units that are being
#       sourceized out of a temporary worktree override.
#   systemd/units/*.md              → source/rationale docs only; no direct deploy
#   systemd/user-preset.d/*.preset → cp user preset
#   systemd/overrides/**           → source/rationale docs only; no direct deploy
#   systemd/scripts/*              → installer helper scripts; no direct deploy
#   systemd/watchdogs/*            → install executable into ~/.local/bin
#   config/root-required/oom-containment.files and every path it owns
#                                  → install P0 OOM containment policy into
#                                    /etc/default, /etc/systemd/system, and
#                                    ~/.config/systemd/user; apply active
#                                    app.slice properties without restarting
#                                    the live slice
#   systemd/logrotate.d/*          → logrotate configs; require sudo install
#   systemd/system/**              → other system-scoped configs; require sudo install
#   config/root-required/apcupsd-power-alerts.files and every path it owns
#                                  → install podium apcupsd config/hooks/helper
#                                    into /etc/apcupsd from the merge SHA
#   scripts/hapax-recovery-plane-install, scripts/hapax-p0-incident-intake,
#   scripts/hapax-coord-deploy, shared/{__init__,jsonl_append,p0_incident_intake}.py
#                                  → refresh the stable D2 recovery bundle under
#                                    ~/.local/lib/hapax-recovery/council
#   scripts/hapax-*                → publish a release-pinned regular copy in ~/.local/bin/
#   hooks/scripts/{cc-task-gate.impl.sh,agent-role.sh,escape-grant.sh,
#                  hapax_check_enable_latch.sh,cc-task-gate-bootstrap.py,
#                  hooks-doctor.sh,cc-task-gate.sh}
#                                  → reconcile the ONE canonical gate closure
#                                    on every run and redeploy drift to
#                                    ~/.local/lib/hapax/hooks via hooks-doctor
#                                    --deploy-canonical (reform FM-6: every
#                                    worktree's cc-task-gate.sh is a shim that
#                                    resolves here, so "update the gate" is a
#                                    one-file change, not a 26-worktree fan-out)
#   assets/quake/{maps,qc,csqc,models,sound,glsl,scripts,config}/** and
#   assets/quake/darkplaces/**      → install Screwm Quake assets into the
#                                    DarkPlaces gamedir; restart the visible
#                                    renderer only when already active so map,
#                                    CSQC, and live-texture binding changes do
#                                    not sit green-but-unloaded after merge.
#
# Usage:
#   hapax-post-merge-deploy <commit-sha>
#       deploy classified files for the given commit
#   hapax-post-merge-deploy --dry-run <commit-sha>
#       classify files and write the post-merge trace without copying files
#       or restarting services
#   hapax-post-merge-deploy --report-coverage <commit-sha>
#       drift-report mode — exit 1 if any systemd/** path in the commit
#       falls outside the case-globs above. Used by CI to catch the
#       absence-class deploy bug where a new systemd unit lands at a
#       path the deploy script doesn't case-match (P-4 of the
#       absence-class-bug-prevention-and-remediation epic).
#   hapax-post-merge-deploy --verify-auto-enable
#       post-deploy assertion mode — exit 1 if any unit under
#       systemd/units/ marked `# Hapax-Auto-Enable: true` is not enabled
#       (and, for timers, active). Witnesses FM-11 (and future marked
#       units) is live, not merely installed. Needs no commit SHA.
#
# Exits 0 if nothing needed deploying or all deploys succeeded.
# Exits non-zero if any deploy step failed (or, in --report-coverage
# mode, if any systemd/** path is unclassified).
set -euo pipefail
ORIGINAL_ARGS=("$@")

DRY_RUN=0
REPORT_COVERAGE=0
COVERAGE_FROM_STDIN=0
VERIFY_AUTO_ENABLE=0
CHECK_SYMLINK_DRIFT=0
SINCE=""
TRACE_READY=0
TRACE_WRITTEN=0
SHA=""
if [ "${1:-}" = "--dry-run" ]; then
    DRY_RUN=1
    shift
fi
# --since <sha>: deploy the CUMULATIVE union diff <since>..<commit> instead of
# the single-merge first-parent diff. One deploy then realizes a multi-merge
# backlog — the systemd-units / pipewire-confs / scripts files that get skipped
# when origin/main jumps several merges between deploy cycles (the root of the
# "merged but never installed" recurrence). Used by the one-time backfill, the
# source-activation cumulative path, and the .service edge-trigger.
if [ "${1:-}" = "--since" ]; then
    SINCE="${2:?commit SHA required after --since}"
    shift 2
fi
if [ "${1:-}" = "--report-coverage" ]; then
    REPORT_COVERAGE=1
    SHA="${2:?commit SHA required after --report-coverage}"
elif [ "${1:-}" = "--report-coverage-stdin" ]; then
    REPORT_COVERAGE=1
    COVERAGE_FROM_STDIN=1
elif [ "${1:-}" = "--verify-auto-enable" ]; then
    VERIFY_AUTO_ENABLE=1
elif [ "${1:-}" = "--check-symlink-drift" ]; then
    CHECK_SYMLINK_DRIFT=1
else
    SHA="${1:?commit SHA required}"
fi
# Default to the source-activation worktree (the documented production root —
# always at the deployed release) over the interactive primary tree, which can
# be weeks stale (2026-06-11: stale-primary symlinks shipped a pre-#4039
# checker that false-failed hourly for 6h).
_ACTIVATION_WORKTREE="$HOME/.cache/hapax/source-activation/worktree"
if [ -z "${REPO:-}" ] && [ -z "${GITHUB_WORKSPACE:-}" ] && [ -d "$_ACTIVATION_WORKTREE/scripts" ]; then
    REPO="$_ACTIVATION_WORKTREE"
fi
REPO="${REPO:-${GITHUB_WORKSPACE:-$HOME/projects/hapax-council}}"
PW_CONF_DIR="$HOME/.config/pipewire/pipewire.conf.d"
HAPAX_CONF_DIR="$HOME/.config/hapax"
WP_CONF_DIR="$HOME/.config/wireplumber/wireplumber.conf.d"
# WirePlumber Lua components load from the XDG *data* dir, not the conf dir.
# scripts/hapax-wireplumber-link-deny-policy installs link-deny.lua here and
# config/wireplumber/98-hapax-link-deny.conf references it as `hapax/link-deny.lua`.
WP_SCRIPTS_DIR="$HOME/.local/share/wireplumber/scripts/hapax"
SYSTEMD_USER_DIR="$HOME/.config/systemd/user"
SYSTEMD_RUNTIME_USER_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/systemd/user"
SYSTEMD_USER_PRESET_DIR="$HOME/.config/systemd/user-preset"
LOCAL_BIN="$HOME/.local/bin"
TRACE_PATH="${HAPAX_POST_MERGE_TRACE_PATH:-$HOME/.cache/hapax/post-merge-traces/post-merge-traces.jsonl}"
TRACE_MAX_RECORDS="${HAPAX_POST_MERGE_TRACE_MAX_RECORDS:-200}"
# Receipt of the last SHA a real deploy cycle ran against (completed or
# no_changes). The rebuild-service.sh staleness alarm and the acceptance check
# `git rev-list <last-deployed-sha>..origin/main` read this, and the .service
# edge-trigger reads it to compute the cumulative --since range. Sibling of the
# trace file by default so a test override of HAPAX_POST_MERGE_TRACE_PATH
# isolates it automatically.
LAST_DEPLOYED_SHA_PATH="${HAPAX_POST_MERGE_LAST_DEPLOYED_SHA_PATH:-$(dirname "$TRACE_PATH")/last-deployed-sha}"
RECOVERY_INSTALLER_PATH="scripts/hapax-recovery-plane-install"
OOM_CONTAINMENT_INSTALLER_PATH="scripts/install-p0-oom-containment"
APCUPSD_INSTALLER_PATH="scripts/install-apcupsd-power-alerts"
ROOT_REQUIRED_RC=77
ROOT_DEFER_DIR="${HAPAX_POST_MERGE_ROOT_DEFER_DIR:-$HOME/.cache/hapax/post-merge-root-required}"
ROOT_REQUIRED_STATE_ROOT="${HAPAX_ROOT_REQUIRED_STATE_ROOT:-$HOME/.local/state/hapax/root-required}"
ROOT_REQUIRED_INSTALLED_SOURCE_ROOT="${HAPAX_ROOT_REQUIRED_INSTALLED_SOURCE_ROOT:-$ROOT_REQUIRED_STATE_ROOT/current-source}"
ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT="${HAPAX_ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT:-$ROOT_REQUIRED_STATE_ROOT/installed-receipts}"
ROOT_REQUIRED_DESIRED_RECEIPT_ROOT="${HAPAX_ROOT_REQUIRED_DESIRED_RECEIPT_ROOT:-$ROOT_REQUIRED_STATE_ROOT/desired-receipts}"
ROOT_REQUIRED_LOCK_FILE="${HAPAX_ROOT_REQUIRED_LOCK_FILE:-$ROOT_REQUIRED_STATE_ROOT/.lock}"
RECOVERY_BUNDLE_DEST="${HAPAX_RECOVERY_BUNDLE_DEST:-$HOME/.local/lib/hapax-recovery/council/current}"
RECOVERY_BUNDLE_SOURCE_FILES=(
    scripts/hapax-p0-incident-intake
    scripts/hapax-coord-deploy
    shared/__init__.py
    shared/jsonl_append.py
    shared/p0_incident_intake.py
)
RECOVERY_BUNDLE_REQUIRED_FILES=(
    "${RECOVERY_BUNDLE_SOURCE_FILES[@]}"
    manifest.json
)

acquire_inherited_root_required_lock() {
    local lock_fd="${HAPAX_ROOT_REQUIRED_LOCK_FD:-}"
    if ! [[ "$lock_fd" =~ ^[0-9]+$ ]] || [ "$lock_fd" -lt 3 ]; then
        echo "hapax-post-merge-deploy: safe shared lock descriptor is absent; next action: remove caller-supplied HAPAX_ROOT_REQUIRED_LOCK_* values and rerun the package-owned deploy script" >&2
        return 1
    fi
    /usr/bin/python3 - "$lock_fd" "$ROOT_REQUIRED_LOCK_FILE" <<'PY'
from __future__ import annotations

import fcntl
import os
import stat
import sys

fd = int(sys.argv[1])
lock_path = sys.argv[2]
try:
    inode = os.fstat(fd)
    path_inode = os.lstat(lock_path)
except OSError as exc:
    print(
        f"hapax-post-merge-deploy: refused invalid shared lock descriptor for {lock_path}: "
        f"{exc}; next action: remove caller-supplied HAPAX_ROOT_REQUIRED_LOCK_* values and rerun",
        file=sys.stderr,
    )
    raise SystemExit(1) from exc
if (
    not stat.S_ISREG(inode.st_mode)
    or not stat.S_ISREG(path_inode.st_mode)
    or (inode.st_dev, inode.st_ino) != (path_inode.st_dev, path_inode.st_ino)
    or inode.st_uid != os.geteuid()
    or inode.st_nlink != 1
    or inode.st_mode & 0o022
):
    print(
        f"hapax-post-merge-deploy: refused invalid shared lock descriptor for {lock_path}; "
        "expected the caller-owned, single-link, non-group-writable regular path inode; "
        "next action: remove caller-supplied HAPAX_ROOT_REQUIRED_LOCK_* values and rerun",
        file=sys.stderr,
    )
    raise SystemExit(1)
os.fchmod(fd, 0o600)
fcntl.flock(fd, fcntl.LOCK_EX)
PY
}

reexec_with_safe_root_required_lock() {
    if [ -n "${HAPAX_ROOT_REQUIRED_LOCK_FD:-}" ]; then
        acquire_inherited_root_required_lock
        return
    fi
    exec /usr/bin/python3 - "$ROOT_REQUIRED_LOCK_FILE" "$0" "${ORIGINAL_ARGS[@]}" <<'PY'
from __future__ import annotations

import fcntl
import os
import stat
import subprocess
import sys

lock_path, script, *args = sys.argv[1:]
os.makedirs(os.path.dirname(lock_path) or ".", exist_ok=True)
try:
    fd = os.open(
        lock_path,
        os.O_CLOEXEC | os.O_CREAT | os.O_NOFOLLOW | os.O_RDWR,
        0o600,
    )
except OSError as exc:
    print(
        f"hapax-post-merge-deploy: refused unsafe shared lock {lock_path}: {exc}; "
        "next action: remove only a confirmed symlink/non-regular lock and rerun",
        file=sys.stderr,
    )
    raise SystemExit(1) from exc
try:
    inode = os.fstat(fd)
    if (
        not stat.S_ISREG(inode.st_mode)
        or inode.st_uid != os.geteuid()
        or inode.st_nlink != 1
        or inode.st_mode & 0o022
    ):
        print(
            f"hapax-post-merge-deploy: refused unsafe shared lock inode {lock_path}; expected "
            "one caller-owned, single-link, non-group-writable regular file; next action: "
            "remove only a confirmed unsafe lock and rerun",
            file=sys.stderr,
        )
        raise SystemExit(1)
    os.fchmod(fd, 0o600)
    fcntl.flock(fd, fcntl.LOCK_EX)
    env = os.environ.copy()
    env.pop("HAPAX_ROOT_REQUIRED_LOCK_HELD", None)
    env["HAPAX_ROOT_REQUIRED_LOCK_FD"] = str(fd)
    env["HAPAX_ROOT_REQUIRED_LOCK_MODE"] = "exclusive"
    result = subprocess.run(
        [os.path.abspath(script), *args],
        env=env,
        pass_fds=(fd,),
        check=False,
    )
    raise SystemExit(result.returncode)
finally:
    os.close(fd)
PY
}

# --- auto-enable marker (reform-improve-deploy-activation-20260601) ---
# A systemd unit may declare it wants to be enabled+started on deploy by
# carrying a `# Hapax-Auto-Enable: true` comment annotation (mirrors the
# `# Hapax-Install-Scope: system` convention). Without this, `try-restart`
# is a no-op for a never-enabled unit, so a freshly-merged timer/service
# installs but never starts — the systemic "merged but sleeping" gap behind
# the FM-11 lane supervisor. The marker is honoured ONLY when the unit also
# has an [Install] section (`systemctl enable` errors on a unit with none).
unit_content_auto_enable() {
    local content="$1"
    [ -n "$content" ] || return 1
    grep -Eiq '^[#;][[:space:]]*Hapax-Auto-Enable:[[:space:]]*(true|yes|1)[[:space:]]*$' <<< "$content" || return 1
    grep -Eq '^\[Install\]' <<< "$content" || return 1
    return 0
}

unit_content_timer_enable_only() {
    local content="$1"
    [ -n "$content" ] || return 1
    grep -Eiq '^[#;][[:space:]]*Hapax-Timer-Enable-Only:[[:space:]]*(true|yes|1)[[:space:]]*$' <<< "$content" || return 1
    grep -Eq '^\[Install\]' <<< "$content" || return 1
    return 0
}

unit_content_parked() {
    local content="$1"
    [ -n "$content" ] || return 1
    grep -Eiq '^[#;][[:space:]]*Hapax-Parked:[[:space:]]*(true|yes|1)[[:space:]]*$' <<< "$content"
}

# --verify-auto-enable: post-deploy assertion that every unit in the repo's
# systemd/units/ carrying `# Hapax-Auto-Enable: true` is actually `enabled`
# (and, for timers, `active`). Exits 0 if all marked units pass, 1 if any
# marked unit is not live. Lets the operator / smoke runner witness FM-11
# (and any future marked unit) is running, not merely installed. Reads the
# working tree, so it needs no commit SHA and runs before the trace/trap setup.
if [ "$VERIFY_AUTO_ENABLE" = "1" ]; then
    UNITS_DIR="$REPO/systemd/units"
    if [ ! -d "$UNITS_DIR" ]; then
        echo "verify-auto-enable: $UNITS_DIR not found" >&2
        exit 2
    fi
    verify_rc=0
    marked_count=0
    for uf in "$UNITS_DIR"/*.service "$UNITS_DIR"/*.timer "$UNITS_DIR"/*.path "$UNITS_DIR"/*.target; do
        [ -f "$uf" ] || continue
        unit_content_auto_enable "$(cat "$uf")" || continue
        unit_base="$(basename "$uf")"
        marked_count=$((marked_count + 1))
        if ! systemctl --user is-enabled "$unit_base" >/dev/null 2>&1; then
            echo "FAIL: $unit_base is marked Hapax-Auto-Enable but is not enabled" >&2
            verify_rc=1
            continue
        fi
        if [[ "$unit_base" == *.timer ]] \
            && ! systemctl --user is-active "$unit_base" >/dev/null 2>&1; then
            echo "FAIL: timer $unit_base is marked Hapax-Auto-Enable but is not active" >&2
            verify_rc=1
            continue
        fi
        if [[ "$unit_base" == *.timer ]]; then
            echo "ok: $unit_base enabled + active"
        else
            echo "ok: $unit_base enabled"
        fi
    done
    if [ "$marked_count" -eq 0 ]; then
        echo "verify-auto-enable: no Hapax-Auto-Enable units in $UNITS_DIR"
    elif [ "$verify_rc" -eq 0 ]; then
        echo "verify-auto-enable: all $marked_count marked unit(s) enabled/active"
    fi
    exit "$verify_rc"
fi

# --- deploy symlink drift assertion (fix-deploy-symlink-skew-20260602) ---
# Assert every ~/.local/bin/hapax-* deploy symlink resolves to the canonical
# origin/main-tracking deploy tree — NOT a dangling target (a deleted worktree
# or a leaked test tmpdir) nor a stale/foreign worktree checkout. This is the
# complement of rebuild-service.sh's check_post_merge_deploy_staleness: that
# alarm catches a STOPPED deploy chain (the last-deployed-sha receipt lags
# origin/main); this catches the failure the skew P0 actually hit — the
# symlinks silently point at a worktree that no longer carries the merged
# fixes, so the .service ran a script lacking --since and exited 2 while the
# receipt still looked healthy. ntfy (throttled per distinct drift signature)
# so the skew can't recur silently. Returns 1 on drift, 0 when intact.
#
# Only deploy-installed `scripts/hapax-*` symlinks are in scope: their target
# is `<root>/scripts/<name>` and the target basename matches the link name.
# A link to a different managed hapax-* script is still deploy drift; legacy
# aliases to non-hapax script names remain outside this check.
# Symlinks to non-worktree install dirs (e.g. hapax-hooks-doctor ->
# ~/.local/lib/hapax/hooks/...) or legacy aliases to non-hapax script names
# (e.g. hapax-request-decompose -> scripts/request-decompose) are not
# deploy-tree symlinks and are intentionally ignored. Env overrides isolate it for tests:
# HAPAX_LOCAL_BIN, HAPAX_DEPLOY_SYMLINK_ROOTS, HAPAX_DRIFT_STATE_DIR,
# HAPAX_DRIFT_NTFY (set 0 to suppress curl).
check_symlink_drift() {
    local bin="${HAPAX_LOCAL_BIN:-$LOCAL_BIN}"
    local state_dir="${HAPAX_DRIFT_STATE_DIR:-$HOME/.cache/hapax/deploy-symlink-drift}"
    # $REPO is canonical too: a deploy installs scripts/hapax-* symlinks pointing
    # at $REPO/scripts, so the tree this very deploy runs from is by definition a
    # valid target. In production $REPO is the source-activation/rebuild worktree
    # (already listed); in tests it isolates to the tmp repo so the deploy-end
    # self-check stays quiet instead of false-flagging the just-installed links.
    local roots="${HAPAX_DEPLOY_SYMLINK_ROOTS:-$REPO $HOME/.cache/hapax/source-activation/worktree $HOME/.cache/hapax/rebuild/worktree}"
    local origin_main
    origin_main="$(git -C "$REPO" rev-parse --verify --quiet origin/main 2>/dev/null || true)"

    local -a dangling=() offtree=()
    local link base target target_base root ok r
    for link in "$bin"/hapax-*; do
        # A literal (no-match) glob is not a symlink, so this also covers the
        # empty-dir case without nullglob.
        [ -L "$link" ] || continue
        base="$(basename "$link")"
        target="$(readlink "$link")"
        if [ ! -e "$link" ]; then
            dangling+=("$base -> $target")
            continue
        fi
        case "$target" in
            */scripts/*)
                target_base="$(basename "$target")"
                if [ "$target_base" != "$base" ]; then
                    case "$target_base" in
                        hapax-*)
                            offtree+=("$base -> $target (target name mismatch)")
                            ;;
                    esac
                    continue
                fi
                root="${target%/scripts/*}"
                ok=0
                for r in $roots; do
                    if [ "$root" = "$r" ]; then
                        ok=1
                        break
                    fi
                done
                if [ "$ok" -eq 0 ]; then
                    offtree+=("$base -> $target")
                fi
                ;;
        esac
    done

    # Informational SHA drift: the canonical deployed tree HEAD vs origin/main.
    # Persistent lag is the receipt alarm's domain (throttled there); we only
    # annotate the alert so the operator sees how far behind the tree is.
    local sa sa_head behind=""
    sa="$HOME/.cache/hapax/source-activation/worktree"
    sa_head="$(git -C "$sa" rev-parse --verify --quiet HEAD 2>/dev/null || true)"
    if [ -n "$origin_main" ] && [ -n "$sa_head" ] && [ "$sa_head" != "$origin_main" ] \
        && git -C "$REPO" merge-base --is-ancestor "$sa_head" "$origin_main" 2>/dev/null; then
        behind="$(git -C "$REPO" rev-list --count "$sa_head..$origin_main" 2>/dev/null || echo '?')"
    fi

    if [ "${#dangling[@]}" -eq 0 ] && [ "${#offtree[@]}" -eq 0 ]; then
        return 0
    fi

    local msg="deploy symlink drift in $bin:"
    if [ "${#dangling[@]}" -gt 0 ]; then
        msg="$msg ${#dangling[@]} dangling (${dangling[*]})"
    fi
    if [ "${#offtree[@]}" -gt 0 ]; then
        msg="$msg ${#offtree[@]} off-tree (${offtree[*]})"
    fi
    if [ -n "$behind" ]; then
        msg="$msg [deployed tree ${sa_head:0:8} is ${behind} behind origin/main ${origin_main:0:8}]"
    fi
    echo "hapax-post-merge-deploy: $msg" >&2

    # ntfy once per distinct drift signature so the operator is told once, not
    # every deploy cycle, until the set of broken symlinks changes.
    if [ "${HAPAX_DRIFT_NTFY:-1}" = "1" ]; then
        local sig notified_file
        sig="$(printf '%s\n' "${dangling[@]}" "${offtree[@]}" | sort | sha256sum | cut -d' ' -f1)"
        notified_file="$state_dir/drift-notified-sig"
        if [ "$(cat "$notified_file" 2>/dev/null || true)" != "$sig" ]; then
            curl -s -o /dev/null \
                -H "Title: deploy symlink drift" \
                -H "Priority: high" \
                -H "Tags: rotating_light" \
                -d "$msg — repoint via the fix-deploy-symlink-skew runbook: re-run systemd/scripts/install-units.sh + hapax-post-merge-deploy from the canonical origin/main worktree." \
                "${NTFY_BASE_URL:-http://localhost:8090}/hapax-build" 2>/dev/null || true
            # Governed incident record alongside the ntfy channel.
            "$(dirname "$(readlink -f "$0")")/hapax-alert" high "deploy symlink drift" "$msg" --tag deploy --record-only
            mkdir -p "$state_dir" 2>/dev/null || true
            printf '%s\n' "$sig" > "$notified_file" 2>/dev/null || true
        fi
    fi
    return 1
}

# --check-symlink-drift: standalone drift assertion (no commit SHA needed).
# Exits 1 on drift so a timer/.service or smoke run surfaces it; 0 when intact.
if [ "$CHECK_SYMLINK_DRIFT" = "1" ]; then
    if check_symlink_drift; then
        echo "check-symlink-drift: all hapax-* deploy symlinks resolve to the canonical tree"
        exit 0
    fi
    exit 1
fi

_trace_join() {
    local item
    for item in "$@"; do
        printf '%s\n' "$item"
    done
}

record_post_merge_trace() {
    local status="$1"
    local exit_code="${2:-0}"
    local -a recovery_bundle_trace
    recovery_bundle_trace=("${RECOVERY_BUNDLE[@]}")
    if [ "${RECOVERY_BUNDLE_SELF_HEAL:-0}" = "1" ]; then
        recovery_bundle_trace+=("self-heal:$RECOVERY_BUNDLE_DEST")
    fi

    HAPAX_TRACE_FILES="$FILES" \
    HAPAX_TRACE_PW="$(_trace_join "${PW[@]}")" \
    HAPAX_TRACE_HAPAX_CONF="$(_trace_join "${HAPAX_CONF[@]}")" \
    HAPAX_TRACE_WP="$(_trace_join "${WP[@]}")" \
    HAPAX_TRACE_WP_LUA="$(_trace_join "${WP_LUA[@]}")" \
    HAPAX_TRACE_SYSTEMD="$(_trace_join "${SYSTEMD[@]}")" \
    HAPAX_TRACE_SYSTEMD_SYSTEM="$(_trace_join "${SYSTEMD_SYSTEM[@]}")" \
    HAPAX_TRACE_SYSTEMD_DROPINS="$(_trace_join "${SYSTEMD_DROPINS[@]}")" \
    HAPAX_TRACE_OOM_CONTAINMENT="$(_trace_join "${OOM_CONTAINMENT[@]}")" \
    HAPAX_TRACE_APCUPSD_POWER_ALERTS="$(_trace_join "${APCUPSD_POWER_ALERTS[@]}")" \
    HAPAX_TRACE_USER_PRESETS="$(_trace_join "${USER_PRESETS[@]}")" \
    HAPAX_TRACE_WATCHDOGS="$(_trace_join "${WATCHDOGS[@]}")" \
    HAPAX_TRACE_RECOVERY_BUNDLE="$(_trace_join "${recovery_bundle_trace[@]}")" \
    HAPAX_TRACE_SCRIPTS="$(_trace_join "${SCRIPTS[@]}")" \
    HAPAX_TRACE_SCRIPT_PY="$(_trace_join "${SCRIPT_PY[@]}")" \
    HAPAX_TRACE_QUAKE_ASSETS="$(_trace_join "${QUAKE_ASSETS[@]}")" \
    HAPAX_TRACE_CANONICAL_GATE="$(_trace_join "${CANONICAL_GATE[@]}")" \
    HAPAX_TRACE_AUDIO_SAFE_RESTARTS="$(_trace_join "${AUDIO_SAFE_RESTARTS[@]}")" \
    HAPAX_TRACE_SYSTEMD_UNCLASSIFIED="$(_trace_join "${SYSTEMD_UNCLASSIFIED[@]}")" \
    python3 - "$TRACE_PATH" "$TRACE_MAX_RECORDS" "$SHA" "$DRY_RUN" "$status" "$exit_code" \
        "$DID_ANYTHING" <<'PY'
from __future__ import annotations

import json
import os
import sys
from datetime import UTC, datetime
from pathlib import Path


def lines(name: str) -> list[str]:
    return [line for line in os.environ.get(name, "").splitlines() if line]


path = Path(sys.argv[1]).expanduser()
try:
    max_records = int(sys.argv[2])
except ValueError:
    max_records = 200
max_records = max(1, max_records)
sha = sys.argv[3]
dry_run = sys.argv[4] == "1"
status = sys.argv[5]
exit_code = int(sys.argv[6])
manual_deploy_executed = sys.argv[7] == "1"

deploy_groups = {
    "pipewire": lines("HAPAX_TRACE_PW"),
    "hapax_runtime_config": lines("HAPAX_TRACE_HAPAX_CONF"),
    "wireplumber": lines("HAPAX_TRACE_WP"),
    "wireplumber_lua": lines("HAPAX_TRACE_WP_LUA"),
    "systemd_units": lines("HAPAX_TRACE_SYSTEMD"),
    "systemd_system_units": lines("HAPAX_TRACE_SYSTEMD_SYSTEM"),
    "systemd_dropins": lines("HAPAX_TRACE_SYSTEMD_DROPINS"),
    "oom_containment": lines("HAPAX_TRACE_OOM_CONTAINMENT"),
    "apcupsd_power_alerts": lines("HAPAX_TRACE_APCUPSD_POWER_ALERTS"),
    "systemd_user_presets": lines("HAPAX_TRACE_USER_PRESETS"),
    "systemd_watchdogs": lines("HAPAX_TRACE_WATCHDOGS"),
    "recovery_bundle": lines("HAPAX_TRACE_RECOVERY_BUNDLE"),
    "hapax_scripts": lines("HAPAX_TRACE_SCRIPTS"),
    "unit_backing_scripts": lines("HAPAX_TRACE_SCRIPT_PY"),
    "quake_assets": lines("HAPAX_TRACE_QUAKE_ASSETS"),
    "canonical_gate_closure": lines("HAPAX_TRACE_CANONICAL_GATE"),
}
runtime_media_groups = [
    name
    for name in (
        "pipewire",
        "hapax_runtime_config",
        "wireplumber",
        "wireplumber_lua",
        "systemd_units",
        "systemd_system_units",
        "systemd_dropins",
        "oom_containment",
        "apcupsd_power_alerts",
        "systemd_watchdogs",
        "recovery_bundle",
        "hapax_scripts",
        "unit_backing_scripts",
        "quake_assets",
        "canonical_gate_closure",
    )
    if deploy_groups[name]
]
record = {
    "schema_version": 1,
    "event": "post_merge_deploy",
    "timestamp": datetime.now(UTC).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    "sha": sha,
    "mode": "dry_run" if dry_run else "deploy",
    "status": status,
    "exit_code": exit_code,
    "changed_files": lines("HAPAX_TRACE_FILES"),
    "deploy_groups": deploy_groups,
    "manual_deploy_needed": any(deploy_groups.values()),
    "manual_deploy_executed": manual_deploy_executed,
    "audio_safe_restart_units": lines("HAPAX_TRACE_AUDIO_SAFE_RESTARTS"),
    "systemd_unclassified": lines("HAPAX_TRACE_SYSTEMD_UNCLASSIFIED"),
    "avsdlc": {
        "gate_point": "S9 post-merge production witness",
        "runtime_media_witness_required": bool(runtime_media_groups),
        "runtime_media_witness_groups": runtime_media_groups,
    },
}

path.parent.mkdir(parents=True, exist_ok=True)
previous = []
if path.exists():
    previous = [line for line in path.read_text(encoding="utf-8").splitlines() if line.strip()]
previous.append(json.dumps(record, sort_keys=True))
kept = previous[-max_records:]
tmp_path = path.with_name(f"{path.name}.tmp")
tmp_path.write_text("\n".join(kept) + "\n", encoding="utf-8")
os.replace(tmp_path, path)
PY
}

trace_on_exit() {
    local rc=$?
    if [ "$REPORT_COVERAGE" != "1" ] \
        && [ "$TRACE_READY" = "1" ] \
        && [ "$TRACE_WRITTEN" != "1" ]; then
        if [ "$DRY_RUN" = "1" ]; then
            record_post_merge_trace "dry_run_failed" "$rc" || true
        elif [ "$rc" -ne 0 ]; then
            record_post_merge_trace "failed" "$rc" || true
        fi
    fi
}

trap trace_on_exit EXIT

# Record the SHA this deploy cycle ran against (real-deploy modes only). The
# staleness alarm + the AC `rev-list <last-deployed-sha>..origin/main` read it;
# the .service edge-trigger reads it to compute the cumulative --since range.
record_last_deployed_sha() {
    [ "$DRY_RUN" = "1" ] && return 0
    [ "$REPORT_COVERAGE" = "1" ] && return 0
    [ -n "$SHA" ] || return 0
    mkdir -p "$(dirname "$LAST_DEPLOYED_SHA_PATH")" 2>/dev/null || true
    printf '%s\n' "$SHA" > "$LAST_DEPLOYED_SHA_PATH"
}

cd "$REPO"
# Ensure the commit's objects are available locally even if main hasn't been
# pulled yet; diffing an unfetched SHA would fail and falsely signal
# "file deleted" to the per-file branches below.
if [ "$COVERAGE_FROM_STDIN" != "1" ]; then
    git fetch --quiet origin main 2>/dev/null || true
    if [[ "$SHA" == *..* ]]; then
        echo "hapax-post-merge-deploy: expected a single commit SHA/ref, got range '$SHA'" >&2
        exit 2
    fi
    if ! SHA_RESOLVED="$(git rev-parse --verify --quiet "$SHA^{commit}")"; then
        echo "hapax-post-merge-deploy: '$SHA' is not a valid commit" >&2
        exit 2
    fi
    SHA="$SHA_RESOLVED"
fi

if [ "$COVERAGE_FROM_STDIN" = "1" ]; then
    FILES="$(cat)"
elif [ -n "$SINCE" ]; then
    # Cumulative range deploy: union of every file changed across <since>..<SHA>.
    if ! git rev-parse --verify --quiet "$SINCE^{commit}" >/dev/null; then
        echo "hapax-post-merge-deploy: --since '$SINCE' is not a valid commit" >&2
        exit 2
    fi
    FILES="$(git diff --name-only "$SINCE" "$SHA" | sort -u)"
elif FIRST_PARENT="$(git rev-parse --verify --quiet "$SHA^1")"; then
    FILES="$(git diff --name-only "$FIRST_PARENT" "$SHA" | sort -u)"
else
    FILES="$(git diff-tree --root --no-commit-id --name-only -r "$SHA" | sort -u)"
fi

PW=(); HAPAX_CONF=(); WP=(); WP_LUA=(); SYSTEMD=(); SYSTEMD_SYSTEM=(); SYSTEMD_DROPINS=(); OOM_CONTAINMENT=(); APCUPSD_POWER_ALERTS=(); USER_PRESETS=(); WATCHDOGS=(); RECOVERY_BUNDLE=(); SCRIPTS=(); SCRIPT_PY=(); QUAKE_ASSETS=(); CANONICAL_GATE=()
declare -A OOM_PACKAGE_PATHS=()
declare -A APCUPSD_PACKAGE_PATHS=()
GATE_CLOSURE=()
# Must stay a superset of hooks-doctor's CLOSURE_SIBLINGS (+ the impl):
# deploy_canonical REFUSES an incomplete staged closure, so a missing sibling
# here would make every drift redeploy fail (and, under set -e, kill the
# whole post-merge deploy) until the drift resolved itself.
GATE_CLOSURE_FILES=(
    hooks/scripts/cc-task-gate.impl.sh
    hooks/scripts/agent-role.sh
    hooks/scripts/escape-grant.sh
    hooks/scripts/hapax_check_enable_latch.sh
    hooks/scripts/cc-task-gate-bootstrap.py
    hooks/scripts/hooks-doctor.sh
)
CANONICAL_HOOKS_DIR="${HAPAX_CANONICAL_HOOKS:-$HOME/.local/lib/hapax/hooks}"
SYSTEMD_UNCLASSIFIED=()
AUDIO_SAFE_RESTARTS=()
RECOVERY_BUNDLE_SELF_HEAL=0
DID_ANYTHING=0
GOVERNED_INTAKE_PRESET_UNIT_SETS=(
    "hapax-request-decompose.timer hapax-request-decompose.service"
    "hapax-cc-task-offer-ready.timer hapax-cc-task-offer-ready.service"
)
GOVERNED_INTAKE_PRESET_ENABLE=()

load_root_required_manifest_paths() {
    local manifest="$1" revision="$2" target_name="$3" content rel
    local -n target="$target_name"
    if [ "$COVERAGE_FROM_STDIN" = "1" ]; then
        [ -f "$REPO/$manifest" ] || return 0
        content="$(cat "$REPO/$manifest")"
    else
        content="$(git -C "$REPO" show "$revision:$manifest" 2>/dev/null || true)"
    fi
    while IFS= read -r rel; do
        [ -n "$rel" ] || continue
        target["$rel"]=1
    done < <(awk 'NF && $1 !~ /^#/ {print $1}' <<< "$content")
}

load_root_required_package_paths() {
    local base_ref=""
    load_root_required_manifest_paths \
        config/root-required/oom-containment.files "$SHA" OOM_PACKAGE_PATHS
    load_root_required_manifest_paths \
        config/root-required/apcupsd-power-alerts.files "$SHA" APCUPSD_PACKAGE_PATHS
    [ "$COVERAGE_FROM_STDIN" = "1" ] && return 0
    if [ -n "$SINCE" ]; then
        base_ref="$SINCE"
    else
        base_ref="$(git -C "$REPO" rev-parse --verify --quiet "$SHA^1" 2>/dev/null || true)"
    fi
    [ -n "$base_ref" ] || return 0
    # Include the old manifest so removals still trigger their owning package.
    load_root_required_manifest_paths \
        config/root-required/oom-containment.files "$base_ref" OOM_PACKAGE_PATHS
    load_root_required_manifest_paths \
        config/root-required/apcupsd-power-alerts.files "$base_ref" APCUPSD_PACKAGE_PATHS
}

load_root_required_package_paths

unit_install_scope() {
    local f="$1"
    if [ "$COVERAGE_FROM_STDIN" = "1" ]; then
        printf 'user\n'
        return 0
    fi
    local content
    content="$(git show "$SHA:$f" 2>/dev/null || true)"
    if [ -n "$content" ] \
        && grep -Eiq '^[#;][[:space:]]*Hapax-Install-Scope:[[:space:]]*system([[:space:]]*$|[[:space:]]+)' <<< "$content"; then
        printf 'system\n'
    else
        printf 'user\n'
    fi
}

AUDIO_SAFE_RESTART_UNITS=(
    hapax-broadcast-orchestrator.service
    hapax-music-player.service
    hapax-content-resolver.service
    hapax-audio-router.service
    hapax-audio-ducker.service
    hapax-lufs-panic-cap.service
    hapax-usb-router.service
    hapax-daimonion.service
)

is_audio_safe_restart_unit() {
    local unit="$1"
    local candidate
    for candidate in "${AUDIO_SAFE_RESTART_UNITS[@]}"; do
        if [[ "$candidate" == "$unit" ]]; then
            return 0
        fi
    done
    return 1
}

remove_unversioned_user_dropins_for_unit() {
    local unit="$1"
    local dropin_dir="$SYSTEMD_USER_DIR/$unit.d"
    local dropin base
    [ -d "$dropin_dir" ] || return 0
    for dropin in "$dropin_dir"/*.conf; do
        [ -f "$dropin" ] || continue
        base="$(basename "$dropin")"
        if git -C "$REPO" cat-file -e "$SHA:systemd/units/$unit.d/$base" 2>/dev/null; then
            continue
        fi
        echo "  removing unversioned local drop-in '$dropin'"
        rm -f "$dropin" || true
    done
    rmdir "$dropin_dir" 2>/dev/null || true
}

cleanup_known_stale_user_dropins_for_unit() {
    local unit="$1"
    local dropin_dir dropin
    case "$unit" in
        hapax-audio-safety.service)
            dropin_dir="$SYSTEMD_RUNTIME_USER_DIR/$unit.d"
            [ -d "$dropin_dir" ] || return 0
            for dropin in "$dropin_dir"/*.conf; do
                [ -f "$dropin" ] || continue
                if [[ "$(basename "$dropin")" == "deploy-4051.conf" ]]; then
                    echo "  removing runtime-only deploy drop-in '$dropin'"
                    rm -f "$dropin" || true
                fi
            done
            rmdir "$dropin_dir" 2>/dev/null || true
            ;;
        hapax-daimonion.service)
            # Persistent sweep FIRST: the runtime dir is ephemeral (absent
            # after any reboot) and must never short-circuit it (#4090-1).
            remove_unversioned_user_dropins_for_unit "$unit"
            dropin_dir="$SYSTEMD_RUNTIME_USER_DIR/$unit.d"
            [ -d "$dropin_dir" ] || return 0
            for dropin in "$dropin_dir"/*.conf; do
                [ -f "$dropin" ] || continue
                if [[ "$(basename "$dropin")" == "deploy-4052.conf" ]]; then
                    echo "  removing runtime-only deploy drop-in '$dropin'"
                    rm -f "$dropin" || true
                fi
            done
            rmdir "$dropin_dir" 2>/dev/null || true
            ;;
        hapax-audio-routing-check.service)
            dropin_dir="$SYSTEMD_USER_DIR/$unit.d"
            [ -d "$dropin_dir" ] || return 0
            for dropin in "$dropin_dir"/*.conf; do
                [ -f "$dropin" ] || continue
                if [[ "$(basename "$dropin")" == "99-chain13-source-artifacts.conf" ]]; then
                    echo "  removing redundant local drop-in '$dropin'"
                    rm -f "$dropin" || true
                fi
            done
            rmdir "$dropin_dir" 2>/dev/null || true
            ;;
        hapax-obs-audio-bind.service)
            dropin_dir="$SYSTEMD_USER_DIR/$unit.d"
            [ -d "$dropin_dir" ] || return 0
            for dropin in "$dropin_dir"/*.conf; do
                [ -f "$dropin" ] || continue
                if grep -Eq 'hapax-council--codex-audio-l12' "$dropin"; then
                    echo "  removing stale local drop-in '$dropin'"
                    rm -f "$dropin" || true
                fi
            done
            rmdir "$dropin_dir" 2>/dev/null || true
            ;;
        hapax-screwm-audio-reactivity.service)
            dropin_dir="$SYSTEMD_USER_DIR/$unit.d"
            [ -d "$dropin_dir" ] || return 0
            for dropin in "$dropin_dir"/*.conf; do
                [ -f "$dropin" ] || continue
                if grep -Eq 'HAPAX_SCREWM_AUDIO_TARGET=hapax-broadcast-normalized-capture' "$dropin"; then
                    echo "  removing stale local drop-in '$dropin'"
                    rm -f "$dropin" || true
                fi
            done
            rmdir "$dropin_dir" 2>/dev/null || true
            ;;
        hapax-cc-task-offer-ready.service|hapax-imagination.service|hapax-reverie.service|\
        hapax-darkplaces-v4l2.service|hapax-segment-prep.service|logos-api.service)
            remove_unversioned_user_dropins_for_unit "$unit"
            ;;
    esac
}

audio_safe_restart_bin() {
    if [[ -n "${HAPAX_AUDIO_SAFE_RESTART_BIN:-}" ]]; then
        printf '%s\n' "$HAPAX_AUDIO_SAFE_RESTART_BIN"
        return 0
    fi
    if [[ -x "$REPO/scripts/hapax-audio-safe-restart" ]]; then
        printf '%s\n' "$REPO/scripts/hapax-audio-safe-restart"
        return 0
    fi
    local candidate
    if candidate="$(command -v hapax-audio-safe-restart 2>/dev/null)" \
        && [[ -x "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    return 1
}

restart_user_unit() {
    local unit="$1"
    if is_audio_safe_restart_unit "$unit"; then
        local safe_bin
        if ! safe_bin="$(audio_safe_restart_bin)"; then
            echo "hapax-post-merge-deploy: refusing plain restart for audio-touching unit $unit; hapax-audio-safe-restart not found" >&2
            return 4
        fi
        echo "audio-safe restarting $unit"
        set +e
        "$safe_bin" "$unit"
        local safe_rc=$?
        set -e
        AUDIO_SAFE_RESTARTS+=("$unit")
        if [[ "$safe_rc" -eq 0 ]]; then
            return 0
        fi
        if [[ "$safe_rc" -eq 1 ]]; then
            echo "hapax-post-merge-deploy: audio-safe restart rolled back $unit successfully" >&2
            return 0
        fi
        # safe_rc >= 2: the audio-safe restart failed AND its rollback did not
        # cleanly succeed. This is the expected outcome when the audio golden
        # chain is INTENTIONALLY down (dev): the broadcast-clean verify can't
        # pass, so every deploy would otherwise abort here (set -e on the
        # caller) and never install unrelated units — e.g. #3850's SDLC
        # cpu.idle slice. Decouple the deploy from the audio precondition:
        #   - LIVE broadcast on the line (studio-compositor active): keep
        #     aborting — breaking the audio chain mid-stream is critical.
        #   - no live broadcast: DEFER the audio restart (it is retried next
        #     deploy cycle) and let the deploy finish installing everything else.
        if systemctl --user is-active --quiet studio-compositor.service; then
            echo "hapax-post-merge-deploy: audio-safe restart of $unit failed (rc=$safe_rc) during a LIVE broadcast (studio-compositor active); aborting deploy to avoid a mid-stream audio break" >&2
            return "$safe_rc"
        fi
        echo "hapax-post-merge-deploy: audio-safe restart of $unit failed (rc=$safe_rc) but no live broadcast (studio-compositor inactive): DEFERRING the audio restart and continuing the deploy; will retry next cycle" >&2
        return 0
    fi

    systemctl --user restart "$unit"
}

stage_coord_activation_before_restart() {
    local deploy_bin="$RECOVERY_BUNDLE_DEST/scripts/hapax-coord-deploy"
    if [ ! -x "$deploy_bin" ]; then
        echo "hapax-post-merge-deploy: refusing to restart hapax-coord.service before its activation worktree is staged; missing executable $deploy_bin; next: install the D2 recovery bundle, verify $deploy_bin exists, then rerun hapax-post-merge-deploy for this merge" >&2
        return 5
    fi
    echo "staging hapax-coord activation before activating hapax-coord.service"
    HAPAX_COORD_DEPLOY_RESTART_IF_UP_TO_DATE=1 "$deploy_bin"
}

gate_closure_source_status() {
    local present=0
    local -a missing=()
    local f
    for f in "${GATE_CLOSURE_FILES[@]}"; do
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            present=$((present + 1))
        else
            missing+=("$f")
        fi
    done
    if [ "$present" -eq 0 ]; then
        return 1
    fi
    if [ "${#missing[@]}" -gt 0 ]; then
        echo "hapax-post-merge-deploy: incomplete canonical gate closure at $SHA:" >&2
        for f in "${missing[@]}"; do
            echo "  missing $f" >&2
        done
        echo "hapax-post-merge-deploy: next: ensure every GATE_CLOSURE_FILES member exists at $SHA or remove the partial closure, then rerun hapax-post-merge-deploy for this merge" >&2
        return 2
    fi
    return 0
}

stage_gate_closure() {
    local stage="$1"
    local f
    mkdir -p "$stage/hooks/scripts"
    for f in "${GATE_CLOSURE_FILES[@]}"; do
        if ! git show "$SHA:$f" > "$stage/$f"; then
            echo "hapax-post-merge-deploy: failed to materialize $f from $SHA; next: verify the source object exists and rerun hapax-post-merge-deploy for this merge" >&2
            return 2
        fi
        chmod +x "$stage/$f" 2>/dev/null || true
    done
}

canonical_gate_dest_for_source() {
    local f="$1"
    case "$f" in
        hooks/scripts/cc-task-gate.impl.sh)
            printf '%s\n' "$CANONICAL_HOOKS_DIR/cc-task-gate.sh"
            ;;
        *)
            printf '%s/%s\n' "$CANONICAL_HOOKS_DIR" "$(basename "$f")"
            ;;
    esac
}

canonical_gate_closure_in_sync() {
    local stage="$1"
    local f src dest
    for f in "${GATE_CLOSURE_FILES[@]}"; do
        src="$stage/$f"
        dest="$(canonical_gate_dest_for_source "$f")"
        [ -r "$dest" ] || return 1
        cmp -s "$src" "$dest" || return 1
    done
    return 0
}

reconcile_canonical_gate_closure() {
    local source_status=0
    local stage rc

    gate_closure_source_status || source_status=$?
    case "$source_status" in
        0) ;;
        1)
            # Backward-compatible for old/synthetic repos used by tests; the
            # production council tree always carries the hook closure.
            return 0
            ;;
        *)
            return "$source_status"
            ;;
    esac

    stage="$(mktemp -d)"
    if stage_gate_closure "$stage"; then
        :
    else
        rc=$?
        rm -rf "$stage" 2>/dev/null || true
        return "$rc"
    fi

    if canonical_gate_closure_in_sync "$stage"; then
        echo "canonical gate closure already matches $SHA"
        rm -rf "$stage" 2>/dev/null || true
        return 0
    fi

    CANONICAL_GATE+=("hooks/scripts/cc-task-gate.impl.sh")
    if [ "$DRY_RUN" = "1" ]; then
        echo "dry-run: canonical gate drift detected; would redeploy via hooks-doctor --deploy-canonical"
        rm -rf "$stage" 2>/dev/null || true
        return 0
    fi

    if [ "${#GATE_CLOSURE[@]}" -gt 0 ]; then
        echo "gate closure changed (${#GATE_CLOSURE[@]}): redeploying canonical gate"
    else
        echo "canonical gate drift detected: redeploying canonical gate"
    fi
    if bash "$stage/hooks/scripts/hooks-doctor.sh" --deploy-canonical --from "$stage"; then
        DID_ANYTHING=1
        rm -rf "$stage" 2>/dev/null || true
        return 0
    else
        rc=$?
        rm -rf "$stage" 2>/dev/null || true
        echo "hapax-post-merge-deploy: canonical gate deploy failed (rc=$rc); refusing to stamp last-deployed-sha; next: inspect hooks-doctor --deploy-canonical output, repair the staged closure, and rerun hapax-post-merge-deploy for this merge" >&2
        return "$rc"
    fi
}

# Per-file deploy uses `git cat-file -e $SHA:$path` + `git show $SHA:$path`
# to read commit-time content, decoupling the deploy decision from local
# working-tree state. Prior revision used [ -f $REPO/$f ] which raced the
# working-tree pull: when the deploy fired BEFORE the main branch had been
# pulled locally, a deletion commit's [ -f ] returned true (old file still
# present) and the script mistakenly cp-re-deployed the pre-deletion version.
# Classify the file list. SYSTEMD_UNCLASSIFIED captures systemd/** paths
# that DON'T match the case-globs below — used by --report-coverage to
# catch the absence-class deploy bug where a new unit lands at a path
# this script can't reach (P-4 of the absence-class-bug-prevention-and-
# remediation epic).
while IFS= read -r f; do
    [ -z "$f" ] && continue
    if [ -n "${OOM_PACKAGE_PATHS[$f]+present}" ]; then
        OOM_CONTAINMENT+=("$f")
        continue
    fi
    if [ -n "${APCUPSD_PACKAGE_PATHS[$f]+present}" ]; then
        APCUPSD_POWER_ALERTS+=("$f")
        continue
    fi
    case "$f" in
        # ARCHIVED confs are records, not deployables. Bash case-globs match
        # across slashes, so without this exclusion config/pipewire/archive/**
        # walks straight into the PW deploy set — the 2026-06-11 09:34 P0:
        # 25 archived confs resurrected into the live conf dir, one syntax-
        # invalid, PipeWire + daimonion start-limit dead, broadcast audio out.
        config/pipewire/archive/*|config/wireplumber/archive/*|config/hapax/archive/*) : ;;
        config/pipewire/*.conf)           PW+=("$f") ;;
        config/hapax/*.conf)              HAPAX_CONF+=("$f") ;;
        config/wireplumber/scripts/hapax/*.lua) WP_LUA+=("$f") ;;
        config/wireplumber/*.conf)        WP+=("$f") ;;
        systemd/units/notify-failure@.service|systemd/units/hapax-coord.service|systemd/units/hapax-coord-rebuild.service|systemd/units/hapax-coord-rebuild.timer)
            RECOVERY_BUNDLE+=("$f")
            if [ "$(unit_install_scope "$f")" = "system" ]; then
                SYSTEMD_SYSTEM+=("$f")
            else
                SYSTEMD+=("$f")
            fi
            ;;
        systemd/units/*.service|systemd/units/*.timer|systemd/units/*.path|systemd/units/*.target|systemd/units/*.slice)
            if [ "$(unit_install_scope "$f")" = "system" ]; then
                SYSTEMD_SYSTEM+=("$f")
            else
                SYSTEMD+=("$f")
            fi
            ;;
        systemd/*.service|systemd/*.timer|systemd/*.path) SYSTEMD+=("$f") ;;
        systemd/units/*.service.d/*.conf|systemd/units/*.timer.d/*.conf|systemd/units/*.slice.d/*.conf|systemd/units/*.scope.d/*.conf) SYSTEMD_DROPINS+=("$f") ;;
        systemd/user-preset.d/*.preset)   USER_PRESETS+=("$f") ;;
        systemd/watchdogs/*)              WATCHDOGS+=("$f") ;;
        systemd/scripts/*)                ;; # installer helpers; run manually when needed
        systemd/udev/*.rules)             ;; # udev rules; require sudo install + udevadm reload (operator action)
        systemd/logrotate.d/*)            ;; # logrotate configs; require sudo install
        systemd/system/*)                 ;; # system-scoped configs; require sudo install
        scripts/hapax-recovery-plane-install|scripts/hapax-p0-incident-intake|scripts/hapax-coord-deploy)
            RECOVERY_BUNDLE+=("$f")
            SCRIPTS+=("$f")
            ;;
        shared/__init__.py|shared/jsonl_append.py|shared/p0_incident_intake.py)
            RECOVERY_BUNDLE+=("$f")
            ;;
        hooks/scripts/cc-task-gate.impl.sh|hooks/scripts/agent-role.sh|hooks/scripts/escape-grant.sh|hooks/scripts/hapax_check_enable_latch.sh|hooks/scripts/cc-task-gate-bootstrap.py|hooks/scripts/hooks-doctor.sh|hooks/scripts/cc-task-gate.sh)
            GATE_CLOSURE+=("$f") ;;
        assets/quake/maps/*|assets/quake/qc/*|assets/quake/csqc/*|assets/quake/models/*|assets/quake/sound/*|assets/quake/glsl/*|assets/quake/scripts/*|assets/quake/config/*|assets/quake/darkplaces/*)
            QUAKE_ASSETS+=("$f") ;;
        scripts/hapax-*)                  SCRIPTS+=("$f") ;;
        scripts/*.py|scripts/*.sh)        SCRIPT_PY+=("$f") ;;
        systemd/expected-timers.yaml)     ;; # frozen-baseline doc, not deployable
        systemd/README.md)                ;; # docs
        systemd/units/*.d/README.md)      ;; # drop-in dir docs (e.g. collapse ledgers)
        systemd/units/*.md)               ;; # docs
        systemd/overrides/*)              ;; # source/rationale docs; deployable copies live under systemd/units
        systemd/*)                        SYSTEMD_UNCLASSIFIED+=("$f") ;;
    esac
done <<< "$FILES"

if [ "$REPORT_COVERAGE" = "1" ]; then
    if [ "${#SYSTEMD_UNCLASSIFIED[@]}" -gt 0 ]; then
        echo "ERROR: ${#SYSTEMD_UNCLASSIFIED[@]} systemd/** path(s) in $SHA fall outside hapax-post-merge-deploy case-globs:" >&2
        for f in "${SYSTEMD_UNCLASSIFIED[@]}"; do
            echo "  $f" >&2
        done
        echo "" >&2
        echo "Either move the files to a covered glob (systemd/units/*.service|*.timer)" >&2
        echo "or extend the case statement in hapax-post-merge-deploy. The current" >&2
        echo "supported globs are documented at the top of the script." >&2
        exit 1
    fi
    echo "ok: all systemd/** paths in $SHA are covered by case-globs"
    exit 0
fi

if [ "$DRY_RUN" != "1" ]; then
    reexec_with_safe_root_required_lock
fi

TRACE_READY=1
if [ -z "$FILES" ]; then
    reconcile_canonical_gate_closure
    trace_status="no_changes"
    if [ "$DID_ANYTHING" -ne 0 ]; then
        trace_status="completed"
    fi
    if record_post_merge_trace "$trace_status" "0"; then
        TRACE_WRITTEN=1
    fi
    record_last_deployed_sha
    echo "no files changed in $SHA"
    exit 0
fi

if [ "$DRY_RUN" = "1" ]; then
    reconcile_canonical_gate_closure
    record_post_merge_trace "dry_run" "0"
    TRACE_WRITTEN=1
    echo "dry-run: post-merge deploy trace written to $TRACE_PATH"
    exit 0
fi

# --- PipeWire confs ---
if [ "${#PW[@]}" -gt 0 ]; then
    echo "pipewire confs changed (${#PW[@]}):"
    mkdir -p "$PW_CONF_DIR"
    for f in "${PW[@]}"; do
        dest="$PW_CONF_DIR/$(basename "$f")"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            # Parse-lint BEFORE the live conf dir sees it: one syntax-invalid
            # conf start-limit-kills the whole audio stack (2026-06-11 P0).
            if command -v spa-json-dump >/dev/null 2>&1; then
                if ! git show "$SHA:$f" | spa-json-dump /dev/stdin >/dev/null 2>&1; then
                    echo "  REFUSED (spa-json parse error, would kill PipeWire): '$f'" >&2
                    DEPLOY_ERRORS=$((${DEPLOY_ERRORS:-0} + 1))
                    continue
                fi
            fi
            git show "$SHA:$f" > "$dest"
            echo "  '$f' -> '$dest'"
        else
            echo "  (deleted: $f)"
            rm -fv "$dest" || true
        fi
    done
    echo "restarting pipewire stack"
    systemctl --user restart pipewire pipewire-pulse wireplumber
    DID_ANYTHING=1
fi

# --- Hapax runtime config ---
if [ "${#HAPAX_CONF[@]}" -gt 0 ]; then
    echo "hapax runtime config changed (${#HAPAX_CONF[@]}):"
    mkdir -p "$HAPAX_CONF_DIR"
    for f in "${HAPAX_CONF[@]}"; do
        dest="$HAPAX_CONF_DIR/$(basename "$f")"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$dest"
            echo "  '$f' -> '$dest'"
        else
            echo "  (deleted: $f)"
            rm -fv "$dest" || true
        fi
    done
    echo "restarting hapax-audio-reconciler"
    systemctl --user restart hapax-audio-reconciler.service || true
    DID_ANYTHING=1
fi

# --- WirePlumber confs ---
if [ "${#WP[@]}" -gt 0 ]; then
    echo "wireplumber confs changed (${#WP[@]}):"
    mkdir -p "$WP_CONF_DIR"
    for f in "${WP[@]}"; do
        dest="$WP_CONF_DIR/$(basename "$f")"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$dest"
            echo "  '$f' -> '$dest'"
        else
            rm -fv "$dest" || true
        fi
    done
    # WP restart alone if we didn't already restart above
    if [ "${#PW[@]}" -eq 0 ]; then
        systemctl --user restart wireplumber
    fi
    DID_ANYTHING=1
fi

# --- WirePlumber Lua scripts (private-fence deny policy etc.) ---
# The .conf goes to ~/.config/wireplumber/wireplumber.conf.d (handled above); the
# Lua component it loads lives under the XDG *data* dir
# ~/.local/share/wireplumber/scripts/hapax (see scripts/hapax-wireplumber-link-deny-policy
# and config/wireplumber/98-hapax-link-deny.conf). Without this case the deny
# policy can go stale on deploy while its .conf updates (FM-13).
if [ "${#WP_LUA[@]}" -gt 0 ]; then
    echo "wireplumber lua scripts changed (${#WP_LUA[@]}):"
    mkdir -p "$WP_SCRIPTS_DIR"
    for f in "${WP_LUA[@]}"; do
        dest="$WP_SCRIPTS_DIR/$(basename "$f")"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$dest"
            echo "  '$f' -> '$dest'"
        else
            rm -fv "$dest" || true
        fi
    done
    # Restart wireplumber only if neither the pipewire stack nor the WP confs
    # above already restarted it.
    if [ "${#PW[@]}" -eq 0 ] && [ "${#WP[@]}" -eq 0 ]; then
        systemctl --user restart wireplumber
    fi
    DID_ANYTHING=1
fi

# --- systemd watchdog helper scripts ---
if [ "${#WATCHDOGS[@]}" -gt 0 ]; then
    echo "systemd watchdog scripts changed (${#WATCHDOGS[@]}):"
    mkdir -p "$LOCAL_BIN"
    for f in "${WATCHDOGS[@]}"; do
        base="$(basename "$f")"
        dest="$LOCAL_BIN/$base"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$dest"
            chmod +x "$dest" 2>/dev/null || true
            echo "  '$f' -> '$dest'"
        else
            rm -fv "$dest" || true
        fi
        matches="$(grep -l -F "$dest" "$REPO/systemd/units/"*.service 2>/dev/null || true)"
        for unit_path in $matches; do
            base_unit="$(basename "$unit_path")"
            if systemctl --user is-active --quiet "$base_unit"; then
                echo "  restarting $base_unit (uses $dest)"
                restart_user_unit "$base_unit"
            fi
        done
    done
    DID_ANYTHING=1
fi

# --- D2 recovery-plane stable bundle ---
recovery_installer_exists_at_sha() {
    git cat-file -e "$SHA:$RECOVERY_INSTALLER_PATH" 2>/dev/null
}

recovery_bundle_runtime_missing() {
    local f target
    for f in "${RECOVERY_BUNDLE_REQUIRED_FILES[@]}"; do
        target="$RECOVERY_BUNDLE_DEST/$f"
        case "$f" in
            scripts/*)
                [ -x "$target" ] || return 0
                ;;
            *)
                [ -f "$target" ] || return 0
                ;;
        esac
    done
    return 1
}

recovery_bundle_runtime_stale() {
    python3 - "$RECOVERY_BUNDLE_DEST/manifest.json" "$REPO" "$SHA" "${RECOVERY_BUNDLE_SOURCE_FILES[@]}" <<'PY'
import hashlib
import json
import subprocess
import sys
from pathlib import Path

manifest_path = Path(sys.argv[1])
repo = sys.argv[2]
sha = sys.argv[3]
source_files = sys.argv[4:]

try:
    manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
except (OSError, json.JSONDecodeError):
    raise SystemExit(0)

installed_files = manifest.get("files")
if not isinstance(installed_files, list):
    raise SystemExit(0)

installed_sha256 = {}
for entry in installed_files:
    if not isinstance(entry, dict):
        continue
    path = entry.get("path")
    sha256 = entry.get("sha256")
    if isinstance(path, str) and isinstance(sha256, str):
        installed_sha256[path] = sha256

for relative in source_files:
    expected_sha256 = installed_sha256.get(relative)
    if expected_sha256 is None:
        raise SystemExit(0)
    try:
        runtime_bytes = (manifest_path.parent / relative).read_bytes()
    except OSError:
        raise SystemExit(0)
    result = subprocess.run(
        ["git", "-C", repo, "show", f"{sha}:{relative}"],
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        raise SystemExit(0)
    runtime_sha256 = hashlib.sha256(runtime_bytes).hexdigest()
    source_sha256 = hashlib.sha256(result.stdout).hexdigest()
    if runtime_sha256 != expected_sha256 or source_sha256 != expected_sha256:
        raise SystemExit(0)

raise SystemExit(1)
PY
}

RECOVERY_BUNDLE_SELF_HEAL=0
RECOVERY_BUNDLE_SELF_HEAL_REASON=""
if [ "${#RECOVERY_BUNDLE[@]}" -eq 0 ] \
    && recovery_installer_exists_at_sha \
    && recovery_bundle_runtime_missing; then
    RECOVERY_BUNDLE_SELF_HEAL=1
    RECOVERY_BUNDLE_SELF_HEAL_REASON="missing/incomplete"
elif [ "${#RECOVERY_BUNDLE[@]}" -eq 0 ] \
    && recovery_installer_exists_at_sha \
    && recovery_bundle_runtime_stale; then
    RECOVERY_BUNDLE_SELF_HEAL=1
    RECOVERY_BUNDLE_SELF_HEAL_REASON="stale"
fi

if [ "${#RECOVERY_BUNDLE[@]}" -gt 0 ] || [ "$RECOVERY_BUNDLE_SELF_HEAL" = "1" ]; then
    if [ "${#RECOVERY_BUNDLE[@]}" -gt 0 ]; then
        echo "recovery bundle files changed (${#RECOVERY_BUNDLE[@]}):"
        for f in "${RECOVERY_BUNDLE[@]}"; do
            echo "  $f"
        done
    else
        echo "recovery bundle runtime $RECOVERY_BUNDLE_SELF_HEAL_REASON at $RECOVERY_BUNDLE_DEST; self-healing stable closure"
    fi
    if ! git cat-file -e "$SHA:$RECOVERY_INSTALLER_PATH" 2>/dev/null; then
        echo "hapax-post-merge-deploy: missing recovery bundle installer at $SHA:$RECOVERY_INSTALLER_PATH; next: ensure scripts/hapax-recovery-plane-install exists at the deployed source-activation SHA, then rerun hapax-post-merge-deploy for this merge" >&2
        exit 2
    fi
    RECOVERY_INSTALLER="$(mktemp)"
    git show "$SHA:$RECOVERY_INSTALLER_PATH" > "$RECOVERY_INSTALLER"
    chmod +x "$RECOVERY_INSTALLER"
    set +e
    "$RECOVERY_INSTALLER" --source "$REPO" --source-ref "$SHA" --dest "$RECOVERY_BUNDLE_DEST"
    recovery_installer_rc=$?
    set -e
    rm -f "$RECOVERY_INSTALLER"
    if [ "$recovery_installer_rc" -ne 0 ]; then
        exit "$recovery_installer_rc"
    fi
    DID_ANYTHING=1
fi

# --- P0 OOM containment system/user policy ---
stage_root_required_package() {
    local stage="$1" manifest="$2" label="$3"
    local rel dest git_mode
    if ! git cat-file -e "$SHA:$manifest" 2>/dev/null; then
        echo "hapax-post-merge-deploy: missing $label manifest at $SHA:$manifest; next: restore the versioned ownership manifest and rerun hapax-post-merge-deploy for this merge" >&2
        return 2
    fi
    while IFS= read -r rel; do
        [ -n "$rel" ] || continue
        if ! git cat-file -e "$SHA:$rel" 2>/dev/null; then
            echo "hapax-post-merge-deploy: missing $label source at $SHA:$rel; next: restore every path declared by $manifest and rerun hapax-post-merge-deploy for this merge" >&2
            return 2
        fi
        git_mode="$(git -C "$REPO" ls-tree "$SHA" -- "$rel" | awk 'NR == 1 {print $1}')"
        case "$git_mode" in
            100644|100755) ;;
            *)
                echo "hapax-post-merge-deploy: unsupported $label Git mode ${git_mode:-missing} at $SHA:$rel; next: replace symlink/submodule entries with regular package files" >&2
                return 2
                ;;
        esac
        dest="$stage/$rel"
        mkdir -p "$(dirname "$dest")"
        git show "$SHA:$rel" > "$dest"
        if [ "$git_mode" = "100755" ]; then
            chmod 0755 "$dest"
        else
            chmod 0644 "$dest"
        fi
    done < <(git -C "$REPO" show "$SHA:$manifest" | awk 'NF && $1 !~ /^#/ {print $1}')
    printf '%s\n' "$SHA" > "$stage/.hapax-root-required-package-sha"
}

stage_oom_containment_installer() {
    stage_root_required_package \
        "$1" config/root-required/oom-containment.files "OOM containment"
}

defer_root_required_installer() {
    local label="$1" stage="$2" installer="$3" dest temp receipt
    mkdir -p "$ROOT_DEFER_DIR"
    dest="$ROOT_DEFER_DIR/$SHA/$label"
    mkdir -p "$(dirname "$dest")"
    receipt="$ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT/$label.sha"
    if [ -f "$receipt" ] && [ "$(tr -d '[:space:]' < "$receipt")" = "$SHA" ]; then
        echo "root-required $label already installed at $SHA; deferral not recreated"
        return 0
    fi
    temp="$ROOT_DEFER_DIR/$SHA/.${label}.tmp.$$"
    rm -rf "$temp" 2>/dev/null || true
    cp -a "$stage" "$temp"
    cat > "$temp/RUNBOOK.txt" <<EOF
Root-required post-merge deploy action deferred.

Commit: $SHA
Package: $label

Run from this host after this root-authority preparation:

  sudo -v

Default sudo path after sudo -v:

  HAPAX_ROOT_REQUIRED_PACKAGE_SHA=$SHA HAPAX_ROOT_REQUIRED_DRAIN_DIR=$dest HAPAX_ROOT_REQUIRED_INSTALLED_SOURCE_ROOT=$ROOT_REQUIRED_INSTALLED_SOURCE_ROOT HAPAX_ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT=$ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT HAPAX_ROOT_REQUIRED_DESIRED_RECEIPT_ROOT=$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT HAPAX_ROOT_REQUIRED_GIT_REPO=$REPO $dest/$installer --source $dest --install --verify-live

Post-merge deploy continued after this deferral so unrelated user-scope deploy
groups for the same merge were not skipped.
EOF
    rm -rf "$dest" 2>/dev/null || true
    mv "$temp" "$dest"
    echo "root-required $label install deferred to $dest"
    echo "next action: run HAPAX_ROOT_REQUIRED_PACKAGE_SHA=$SHA HAPAX_ROOT_REQUIRED_DRAIN_DIR=$dest HAPAX_ROOT_REQUIRED_INSTALLED_SOURCE_ROOT=$ROOT_REQUIRED_INSTALLED_SOURCE_ROOT HAPAX_ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT=$ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT HAPAX_ROOT_REQUIRED_DESIRED_RECEIPT_ROOT=$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT HAPAX_ROOT_REQUIRED_GIT_REPO=$REPO $dest/$installer --source $dest --install --verify-live with root authority"
}

root_required_stage_matches_commit() {
    local stage="$1" commit="$2" manifest_rel="$3" file rel git_mode stage_mode
    cmp -s "$stage/$manifest_rel" <(git -C "$REPO" show "$commit:$manifest_rel" 2>/dev/null) || return 1
    while IFS= read -r rel; do
        file="$stage/$rel"
        [ -f "$file" ] || return 1
        [ ! -L "$file" ] || return 1
        git -C "$REPO" cat-file -e "$commit:$rel" 2>/dev/null || return 1
        cmp -s "$file" <(git -C "$REPO" show "$commit:$rel") || return 1
        git_mode="$(git -C "$REPO" ls-tree "$commit" -- "$rel" | awk 'NR == 1 {print $1}')"
        stage_mode=100644
        [ -x "$file" ] && stage_mode=100755
        [ "$git_mode" = "$stage_mode" ] || return 1
    done < <(awk 'NF && $1 !~ /^#/ {print $1}' "$stage/$manifest_rel")
}

validate_root_required_stage_manifest() {
    local stage="$1" manifest_rel="$2"
    if ! cmp -s \
        <(awk 'NF && $1 !~ /^#/ {print $1}' "$stage/$manifest_rel" | sort) \
        <(find "$stage" -type f ! -name .hapax-root-required-package-sha -printf '%P\n' | sort); then
        echo "hapax-post-merge-deploy: staged root-required package does not match $manifest_rel; next action: update the versioned ownership manifest and staging list together" >&2
        return 1
    fi
}

record_root_required_desired_sha() {
    local label="$1" stage="$2" receipt temp current manifest_rel
    case "$label" in
        oom-containment) manifest_rel="config/root-required/oom-containment.files" ;;
        apcupsd-power-alerts) manifest_rel="config/root-required/apcupsd-power-alerts.files" ;;
        *) echo "hapax-post-merge-deploy: unknown root-required package label: $label; next action: use oom-containment or apcupsd-power-alerts from the governed staging path" >&2; return 2 ;;
    esac
    validate_root_required_stage_manifest "$stage" "$manifest_rel" || return 1
    mkdir -p "$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT"
    receipt="$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT/$label.sha"
    if [ -f "$receipt" ]; then
        current="$(tr -d '[:space:]' < "$receipt")"
        if ! [[ "$current" =~ ^[0-9a-f]{40}$ ]] || ! git -C "$REPO" cat-file -e "$current^{commit}" 2>/dev/null; then
            echo "hapax-post-merge-deploy: invalid or unavailable desired $label receipt $current; next action: restore the latest governed receipt and rerun this deploy" >&2
            return 1
        fi
        if [ "$current" = "$SHA" ]; then
            return 0
        fi
        if git -C "$REPO" merge-base --is-ancestor "$SHA" "$current"; then
            echo "root-required $label desired state $current supersedes stale deploy $SHA; desired receipt preserved"
            return 0
        fi
        if ! git -C "$REPO" merge-base --is-ancestor "$current" "$SHA"; then
            if root_required_stage_matches_commit "$stage" "$current" "$manifest_rel"; then
                echo "root-required $label desired state is ancestry-divergent but package-content equivalent; accepting squash/rebase transition to $SHA"
            else
                echo "hapax-post-merge-deploy: refusing divergent desired $label transition current=$current candidate=$SHA; next action: dispatch governed root-package reconciliation" >&2
                return 1
            fi
        fi
    fi
    temp="$receipt.tmp.$$"
    printf '%s\n' "$SHA" > "$temp"
    mv -f "$temp" "$receipt"
}

# apcupsd must be active before the OOM package verifies the recovery plane.
stage_apcupsd_power_alert_installer() {
    stage_root_required_package \
        "$1" config/root-required/apcupsd-power-alerts.files "apcupsd power-alert"
}

if [ "${#APCUPSD_POWER_ALERTS[@]}" -gt 0 ]; then
    echo "apcupsd power-alert files changed (${#APCUPSD_POWER_ALERTS[@]}):"
    for f in "${APCUPSD_POWER_ALERTS[@]}"; do
        echo "  $f"
    done
    APCUPSD_STAGE="$(mktemp -d)"
    set +e
    stage_apcupsd_power_alert_installer "$APCUPSD_STAGE"
    stage_apcupsd_rc=$?
    set -e
    if [ "$stage_apcupsd_rc" -ne 0 ]; then
        rm -rf "$APCUPSD_STAGE" 2>/dev/null || true
        exit "$stage_apcupsd_rc"
    fi
    if ! record_root_required_desired_sha "apcupsd-power-alerts" "$APCUPSD_STAGE"; then
        rm -rf "$APCUPSD_STAGE" 2>/dev/null || true
        exit 1
    fi
    set +e
    HAPAX_ROOT_REQUIRED_PACKAGE_SHA="$SHA" \
        HAPAX_ROOT_REQUIRED_INSTALLED_SOURCE_ROOT="$ROOT_REQUIRED_INSTALLED_SOURCE_ROOT" \
        HAPAX_ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT="$ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT" \
        HAPAX_ROOT_REQUIRED_DESIRED_RECEIPT_ROOT="$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT" \
        HAPAX_ROOT_REQUIRED_GIT_REPO="$REPO" \
        "$APCUPSD_STAGE/$APCUPSD_INSTALLER_PATH" --source "$APCUPSD_STAGE" --install --verify-live
    apcupsd_installer_rc=$?
    set -e
    if [ "$apcupsd_installer_rc" -eq "$ROOT_REQUIRED_RC" ]; then
        defer_root_required_installer "apcupsd-power-alerts" "$APCUPSD_STAGE" "$APCUPSD_INSTALLER_PATH"
    elif [ "$apcupsd_installer_rc" -ne 0 ]; then
        rm -rf "$APCUPSD_STAGE" 2>/dev/null || true
        exit "$apcupsd_installer_rc"
    fi
    rm -rf "$APCUPSD_STAGE" 2>/dev/null || true
    DID_ANYTHING=1
fi

if [ "${#OOM_CONTAINMENT[@]}" -gt 0 ]; then
    echo "P0 OOM containment files changed (${#OOM_CONTAINMENT[@]}):"
    for f in "${OOM_CONTAINMENT[@]}"; do
        echo "  $f"
    done
    OOM_STAGE="$(mktemp -d)"
    set +e
    stage_oom_containment_installer "$OOM_STAGE"
    stage_oom_rc=$?
    set -e
    if [ "$stage_oom_rc" -ne 0 ]; then
        rm -rf "$OOM_STAGE" 2>/dev/null || true
        exit "$stage_oom_rc"
    fi
    if ! record_root_required_desired_sha "oom-containment" "$OOM_STAGE"; then
        rm -rf "$OOM_STAGE" 2>/dev/null || true
        exit 1
    fi
    set +e
    HAPAX_ROOT_REQUIRED_PACKAGE_SHA="$SHA" \
        HAPAX_ROOT_REQUIRED_INSTALLED_SOURCE_ROOT="$ROOT_REQUIRED_INSTALLED_SOURCE_ROOT" \
        HAPAX_ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT="$ROOT_REQUIRED_INSTALLED_RECEIPT_ROOT" \
        HAPAX_ROOT_REQUIRED_DESIRED_RECEIPT_ROOT="$ROOT_REQUIRED_DESIRED_RECEIPT_ROOT" \
        HAPAX_ROOT_REQUIRED_GIT_REPO="$REPO" \
        "$OOM_STAGE/$OOM_CONTAINMENT_INSTALLER_PATH" --source "$OOM_STAGE" --install --verify-live
    oom_installer_rc=$?
    set -e
    if [ "$oom_installer_rc" -eq "$ROOT_REQUIRED_RC" ]; then
        defer_root_required_installer "oom-containment" "$OOM_STAGE" "$OOM_CONTAINMENT_INSTALLER_PATH"
    elif [ "$oom_installer_rc" -ne 0 ]; then
        rm -rf "$OOM_STAGE" 2>/dev/null || true
        exit "$oom_installer_rc"
    fi
    rm -rf "$OOM_STAGE" 2>/dev/null || true
    DID_ANYTHING=1
fi

slice_memory_issue_from_content() {
    awk '
        function trim(value) {
            sub(/^[[:space:]]+/, "", value)
            sub(/[[:space:]]+$/, "", value)
            return value
        }
        /^[[:space:]]*[#;]/ || /^[[:space:]]*$/ { next }
        {
            line = $0
            candidate = trim(line)
            if (candidate ~ /^\[[^]]+\]$/) {
                section = candidate
                gsub(/^\[|\]$/, "", section)
                next
            }
            equals = index(line, "=")
            if (!equals) { next }
            key = trim(substr(line, 1, equals - 1))
            value = trim(substr(line, equals + 1))
            if (key !~ /^(MemoryHigh|MemoryMax|MemorySwapMax|MemoryLow|MemoryMin)$/) { next }
            if (section != "Slice") {
                print "memory property outside [Slice]: " candidate
                exit
            }
            if (value !~ /^(infinity|[0-9]+([.][0-9]+)?([KMGTPE](iB|B)?)?|[0-9]+%)$/) {
                print "invalid memory value: " candidate
                exit
            }
        }
    '
}

slice_memory_properties_from_content() {
    awk '
        function trim(value) {
            sub(/^[[:space:]]+/, "", value)
            sub(/[[:space:]]+$/, "", value)
            return value
        }
        /^[[:space:]]*[#;]/ || /^[[:space:]]*$/ { next }
        {
            line = $0
            candidate = trim(line)
            if (candidate ~ /^\[[^]]+\]$/) {
                section = candidate
                gsub(/^\[|\]$/, "", section)
                next
            }
            equals = index(line, "=")
            if (!equals) { next }
            key = trim(substr(line, 1, equals - 1))
            value = trim(substr(line, equals + 1))
            if (section == "Slice" && key ~ /^(MemoryHigh|MemoryMax|MemorySwapMax|MemoryLow|MemoryMin)$/) {
                print key "=" value
            }
        }
    '
}

generic_dropin_destination_is_replaced() {
    local candidate="$1" changed rel
    for changed in "${SYSTEMD_DROPINS[@]}"; do
        rel="${changed#systemd/units/}"
        if [ "$SYSTEMD_USER_DIR/$rel" = "$candidate" ] \
            && git -C "$REPO" cat-file -e "$SHA:$changed" 2>/dev/null; then
            return 0
        fi
    done
    return 1
}

validate_co_resident_slice_dropins() {
    local dropin_dir="$1" conf content issue
    for conf in "$SYSTEMD_USER_DIR/$dropin_dir"/*.conf; do
        [ -e "$conf" ] || [ -L "$conf" ] || continue
        generic_dropin_destination_is_replaced "$conf" && continue
        if [ -L "$conf" ] || [ ! -f "$conf" ]; then
            echo "hapax-post-merge-deploy: unsafe co-resident generic slice drop-in $conf is not a regular file; next action: remove the unsafe local entry or dispatch a slice-specific reconciliation before retrying activation" >&2
            return 1
        fi
        content="$(cat "$conf")"
        issue="$(printf '%s\n' "$content" | slice_memory_issue_from_content)"
        if [ -n "$issue" ]; then
            echo "hapax-post-merge-deploy: unsafe co-resident generic slice drop-in $conf: $issue; next action: repair or remove the local drift before retrying the governed slice activation" >&2
            return 1
        fi
    done
}

validate_generic_dropin_activation() {
    local f="$1" rel dropin_dir unit_name content unsupported invalid_memory old_content old_prop dest deployed_content
    rel="${f#systemd/units/}"
    dropin_dir="$(dirname "$rel")"
    unit_name="${dropin_dir%.d}"
    case "$unit_name" in
        *.scope)
            echo "hapax-post-merge-deploy: refusing generic scope drop-in deploy for $f; next action: use a governed scope-specific installer that updates the transient scope without restarting it" >&2
            return 1
            ;;
        *.slice)
            if ! git -C "$REPO" cat-file -e "$SHA:$f" 2>/dev/null; then
                echo "hapax-post-merge-deploy: refusing generic slice drop-in deletion for $f because runtime set-property overrides cannot be safely inferred; next action: use a governed slice-specific removal that clears persistent and runtime policy together" >&2
                return 1
            fi
            content="$(git -C "$REPO" show "$SHA:$f")"
            invalid_memory="$(printf '%s\n' "$content" | awk -F= '
                /^(MemoryHigh|MemoryMax|MemorySwapMax|MemoryLow|MemoryMin)=/ {
                    if ($2 !~ /^(infinity|[0-9]+([.][0-9]+)?([KMGTPE](iB|B)?)?|[0-9]+%)$/) {
                        print
                        exit
                    }
                }
            ')"
            if [ -n "$invalid_memory" ]; then
                echo "hapax-post-merge-deploy: invalid generic slice memory value in $f: $invalid_memory; next action: use a systemd memory size, percentage, or infinity before retrying activation" >&2
                return 1
            fi
            unsupported="$(printf '%s\n' "$content" | awk '
                /^[[:space:]]*$/ || /^[[:space:]]*[#;]/ { next }
                /^[[:space:]]*\[Slice\][[:space:]]*$/ { section = "slice"; next }
                /^[[:space:]]*\[[^]]+\][[:space:]]*$/ { print; exit }
                /^(MemoryHigh|MemoryMax|MemorySwapMax|MemoryLow|MemoryMin)=[^[:space:]].*$/ {
                    if (section != "slice") { print; exit }
                    next
                }
                { print; exit }
            ')"
            if [ -n "$unsupported" ]; then
                echo "hapax-post-merge-deploy: unsupported generic slice directive in $f: $unsupported; next action: use only MemoryHigh/MemoryMax/MemorySwapMax/MemoryLow/MemoryMin or dispatch a slice-specific activation path" >&2
                return 1
            fi
            if ! grep -Eq '^(MemoryHigh|MemoryMax|MemorySwapMax|MemoryLow|MemoryMin)=' <<< "$content"; then
                echo "hapax-post-merge-deploy: no runtime-safe memory property found in generic slice drop-in $f; next action: use a slice-specific installer for non-memory directives" >&2
                return 1
            fi
            dest="$SYSTEMD_USER_DIR/$rel"
            if [ -L "$dest" ] || { [ -e "$dest" ] && [ ! -f "$dest" ]; }; then
                echo "hapax-post-merge-deploy: unsafe changed generic slice destination $dest is not a regular file, so prior runtime properties cannot be established; next action: replace the unsafe entry with its last deployed regular content or use a governed slice-specific reconciliation" >&2
                return 1
            fi
            validate_co_resident_slice_dropins "$dropin_dir" || return 1
            old_content=""
            if [ -n "${DROPIN_BASE_REF:-}" ] \
                && git -C "$REPO" cat-file -e "$DROPIN_BASE_REF:$f" 2>/dev/null; then
                old_content="$(git -C "$REPO" show "$DROPIN_BASE_REF:$f")"
            fi
            if [ -f "$dest" ]; then
                deployed_content="$(cat "$dest")"
                old_content="${old_content}${old_content:+$'\n'}${deployed_content}"
            fi
            if [ -n "$old_content" ]; then
                while IFS= read -r old_prop; do
                    [ -n "$old_prop" ] || continue
                    if ! grep -q "^${old_prop}=" <<< "$content"; then
                        echo "hapax-post-merge-deploy: refusing generic removal of $old_prop from $f because its runtime override would remain stale; next action: use a governed slice-specific transition that resets the removed property" >&2
                        return 1
                    fi
                done < <(printf '%s\n' "$old_content" | slice_memory_properties_from_content | cut -d= -f1 | sort -u || true)
            fi
            ;;
    esac
}

# --- systemd unit drop-ins ---
if [ "${#SYSTEMD_DROPINS[@]}" -gt 0 ]; then
    echo "systemd drop-ins changed (${#SYSTEMD_DROPINS[@]}):"
    DROPIN_BASE_REF="${SINCE:-${FIRST_PARENT:-}}"
    for f in "${SYSTEMD_DROPINS[@]}"; do
        validate_generic_dropin_activation "$f"
    done
    mkdir -p "$SYSTEMD_USER_DIR"
    DROPIN_UNITS_TO_RESTART=()
    for f in "${SYSTEMD_DROPINS[@]}"; do
        rel="${f#systemd/units/}"
        dropin_dir="$(dirname "$rel")"
        conf_name="$(basename "$f")"
        unit_name="${dropin_dir%.d}"
        dest_dir="$SYSTEMD_USER_DIR/$dropin_dir"
        dest="$dest_dir/$conf_name"
        mkdir -p "$dest_dir"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            if ! dropin_temp="$(mktemp "$dest_dir/.${conf_name}.tmp.XXXXXX")"; then
                echo "hapax-post-merge-deploy: unable to reserve a temporary path for $f; next action: verify destination ownership and capacity, then rerun the governed deploy" >&2
                exit 1
            fi
            if ! git show "$SHA:$f" > "$dropin_temp"; then
                rm -f "$dropin_temp" 2>/dev/null || true
                echo "hapax-post-merge-deploy: unable to materialize $f before drop-in activation; next action: verify the commit object and rerun the governed deploy" >&2
                exit 1
            fi
            chmod 0644 "$dropin_temp"
            if ! mv -fT "$dropin_temp" "$dest"; then
                rm -f "$dropin_temp" 2>/dev/null || true
                echo "hapax-post-merge-deploy: unable to atomically replace drop-in $dest; next action: remove unsafe destination drift and rerun the governed deploy" >&2
                exit 1
            fi
            echo "  '$f' -> '$dest'"
            DROPIN_UNITS_TO_RESTART+=("$unit_name")
        else
            rm -fv "$dest" || true
        fi
    done
    systemctl --user daemon-reload
    for u in "${DROPIN_UNITS_TO_RESTART[@]}"; do
        if [[ "$u" == *.slice ]]; then
            slice_props=()
            for conf in "$SYSTEMD_USER_DIR/$u.d"/*.conf; do
                [ -f "$conf" ] || continue
                content="$(cat "$conf")"
                issue="$(printf '%s\n' "$content" | slice_memory_issue_from_content)"
                if [ -n "$issue" ]; then
                    echo "hapax-post-merge-deploy: refusing runtime promotion from unsafe generic slice drop-in $conf after daemon reload: $issue; next action: repair local slice drift and rerun the governed deploy" >&2
                    exit 1
                fi
                while IFS= read -r prop; do
                    slice_props+=("$prop")
                done < <(printf '%s\n' "$content" | slice_memory_properties_from_content)
            done
            if [ "${#slice_props[@]}" -gt 0 ]; then
                echo "applying active slice properties for $u without restart"
                systemctl --user set-property --runtime "$u" "${slice_props[@]}"
            else
                echo "not restarting active slice $u after drop-in deploy; no runtime set-property candidates found"
            fi
        elif systemctl --user is-active --quiet "$u"; then
            echo "restarting $u"
            restart_user_unit "$u"
        elif [[ "$u" == *.timer ]]; then
            echo "try-restarting $u"
            systemctl --user try-restart "$u" || true
        fi
    done
    DID_ANYTHING=1
fi

# --- systemd units ---
if [ "${#SYSTEMD_SYSTEM[@]}" -gt 0 ]; then
    echo "system-scoped systemd units changed (${#SYSTEMD_SYSTEM[@]}):"
    mkdir -p "$SYSTEMD_USER_DIR"
    for f in "${SYSTEMD_SYSTEM[@]}"; do
        base="$(basename "$f")"
        dest="$SYSTEMD_USER_DIR/$base"
        echo "  '$f' marked Hapax-Install-Scope: system; skipping user deploy"
        systemctl --user disable --now "$base" >/dev/null 2>&1 || true
        if [ -e "$dest" ] || [ -L "$dest" ]; then
            rm -fv "$dest" || true
        fi
    done
    systemctl --user daemon-reload
    DID_ANYTHING=1
fi

if [ "${#SYSTEMD[@]}" -gt 0 ]; then
    echo "systemd units changed (${#SYSTEMD[@]}):"
    mkdir -p "$SYSTEMD_USER_DIR"
    SYSTEMD_INSTALLED=()
    for f in "${SYSTEMD[@]}"; do
        base="$(basename "$f")"
        dest="$SYSTEMD_USER_DIR/$base"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            if [ -L "$dest" ]; then
                rm -f "$dest"
            fi
            git show "$SHA:$f" > "$dest"
            echo "  '$f' -> '$dest'"
            cleanup_known_stale_user_dropins_for_unit "$base"
            SYSTEMD_INSTALLED+=("$f")
        else
            rm -fv "$dest" || true
        fi
    done
    systemctl --user daemon-reload
    for f in "${SYSTEMD_INSTALLED[@]}"; do
        base="$(basename "$f")"
        unit_content="$(git show "$SHA:$f" 2>/dev/null || true)"
        if unit_content_parked "$unit_content"; then
            echo "parking $base (Hapax-Parked marker)"
            if ! systemctl --user disable --now "$base"; then
                echo "hapax-post-merge-deploy: unable to disable parked unit $base; next action: inspect systemctl --user status $base and rerun the governed deploy" >&2
                exit 1
            fi
            systemctl --user reset-failed "$base" >/dev/null 2>&1 || true
        elif systemctl --user is-active --quiet "$base"; then
            if [[ "$base" == *.timer ]] && unit_content_timer_enable_only "$unit_content"; then
                echo "leaving active $base running (Hapax-Timer-Enable-Only marker; not restarting during deploy)"
                systemctl --user enable "$base"
                continue
            fi
            # Already running — restart to pick up the new unit definition.
            if [ "$base" = "hapax-coord.service" ]; then
                stage_coord_activation_before_restart
                echo "hapax-coord.service restarted by hapax-coord-deploy"
                continue
            fi
            echo "restarting $base"
            restart_user_unit "$base"
        elif [[ "$base" == *.timer ]] && unit_content_timer_enable_only "$unit_content"; then
            echo "enabling $base (Hapax-Timer-Enable-Only marker; not starting during deploy)"
            systemctl --user enable "$base"
        elif unit_content_auto_enable "$unit_content"; then
            # Marked `# Hapax-Auto-Enable: true` (+ [Install]): enable+start so a
            # freshly-merged service OR timer goes live instead of sleeping.
            # try-restart is a no-op for a never-enabled unit (the FM-11 gap).
            if [ "$base" = "hapax-coord.service" ]; then
                stage_coord_activation_before_restart
                echo "auto-enabling $base (Hapax-Auto-Enable marker; activation staged by hapax-coord-deploy)"
                systemctl --user enable "$base"
            else
                echo "auto-enabling $base (Hapax-Auto-Enable marker)"
                systemctl --user enable --now "$base"
            fi
        elif [[ "$base" == *.timer ]]; then
            # Back-compat: an unmarked NEW timer still auto-enables — timers are
            # inert until started, and this has been the behaviour since #3475.
            echo "enabling+starting $base"
            systemctl --user enable --now "$base"
        fi
    done
    DID_ANYTHING=1
fi

preset_enables_unit_at_sha() {
    local unit="$1" preset
    for preset in "${USER_PRESETS[@]}"; do
        git cat-file -e "$SHA:$preset" 2>/dev/null || continue
        if git show "$SHA:$preset" | grep -Eq "^[[:space:]]*enable[[:space:]]+$unit([[:space:]]|$)"; then
            return 0
        fi
    done
    return 1
}

install_governed_intake_unit_at_sha() {
    local unit="$1" reason="$2"
    local rel dest
    rel="systemd/units/$unit"
    dest="$SYSTEMD_USER_DIR/$unit"
    if [ -L "$dest" ]; then
        rm -f "$dest"
    fi
    git show "$SHA:$rel" > "$dest"
    echo "  '$rel' -> '$dest' ($reason)"
    cleanup_known_stale_user_dropins_for_unit "$unit"
    return 0
}

governed_intake_unit_exists_at_sha() {
    local unit="$1"
    local rel="systemd/units/$unit"
    if git cat-file -e "$SHA:$rel" 2>/dev/null; then
        return 0
    fi
    echo "  warning: preset requires $unit but $rel is absent at $SHA; cannot activate governed intake. Next action: add $rel at the deployed SHA or remove the preset enable for its timer." >&2
    return 1
}

install_governed_intake_preset_units() {
    local set timer unit install_ok
    GOVERNED_INTAKE_PRESET_ENABLE=()
    for set in "${GOVERNED_INTAKE_PRESET_UNIT_SETS[@]}"; do
        timer="${set%% *}"
        preset_enables_unit_at_sha "$timer" || continue
        install_ok=1
        for unit in $set; do
            if ! governed_intake_unit_exists_at_sha "$unit"; then
                install_ok=0
            fi
        done
        [ "$install_ok" -eq 1 ] || continue
        for unit in $set; do
            install_governed_intake_unit_at_sha "$unit" "preset-activated governed intake unit"
        done
        GOVERNED_INTAKE_PRESET_ENABLE+=("$timer")
    done
}

# --- systemd user presets ---
if [ "${#USER_PRESETS[@]}" -gt 0 ]; then
    echo "systemd user presets changed (${#USER_PRESETS[@]}):"
    mkdir -p "$SYSTEMD_USER_PRESET_DIR"
    mkdir -p "$SYSTEMD_USER_DIR"
    for f in "${USER_PRESETS[@]}"; do
        base="$(basename "$f")"
        dest="$SYSTEMD_USER_PRESET_DIR/$base"
        if git cat-file -e "$SHA:$f" 2>/dev/null; then
            git show "$SHA:$f" > "$dest"
            echo "  '$f' -> '$dest'"
        else
            rm -fv "$dest" || true
        fi
    done
    install_governed_intake_preset_units
    systemctl --user daemon-reload
    for unit in "${GOVERNED_INTAKE_PRESET_ENABLE[@]}"; do
        echo "enable+starting $unit (governed intake preset)"
        systemctl --user enable --now "$unit"
    done
    DID_ANYTHING=1
fi

publish_git_executable_at_sha() {
    local source_path="$1" dest="$2" dest_dir base temp
    dest_dir="$(dirname "$dest")"
    base="$(basename "$dest")"
    if ! temp="$(mktemp "$dest_dir/.${base}.tmp.XXXXXX")"; then
        echo "hapax-post-merge-deploy: unable to reserve a temporary launcher beside $dest; next action: verify destination ownership and capacity, then rerun the governed deploy" >&2
        return 1
    fi
    if ! git -C "$REPO" show "$SHA:$source_path" > "$temp"; then
        rm -f "$temp" 2>/dev/null || true
        echo "hapax-post-merge-deploy: unable to materialize $source_path for $dest; next action: verify the commit object and rerun the governed deploy" >&2
        return 1
    fi
    chmod 0755 "$temp"
    if ! mv -fT -- "$temp" "$dest"; then
        rm -f "$temp" 2>/dev/null || true
        echo "hapax-post-merge-deploy: unable to atomically publish launcher $dest; next action: move unsafe destination drift aside and rerun the governed deploy" >&2
        return 1
    fi
}

# --- scripts/hapax-* release copies ---
if [ "${#SCRIPTS[@]}" -gt 0 ]; then
    echo "scripts changed (${#SCRIPTS[@]}):"
    mkdir -p "$LOCAL_BIN"
    for f in "${SCRIPTS[@]}"; do
        base="$(basename "$f")"
        dest="$LOCAL_BIN/$base"
        if git -C "$REPO" cat-file -e "$SHA:$f" 2>/dev/null; then
            # Copy-from-SHA (the WATCHDOGS pattern): the installed script is the
            # deployed release's content, never a live view of a mutable tree.
            publish_git_executable_at_sha "$f" "$dest"
            echo "  '$f' -> '$dest' (copy @ ${SHA:0:9})"
        else
            rm -fv "$dest" || true
        fi
        matches="$(
            { grep -l -F "$dest" "$REPO/systemd/units/"*.service 2>/dev/null || true; \
              grep -l -F "$f" "$REPO/systemd/units/"*.service 2>/dev/null || true; } | sort -u
        )"
        for unit_path in $matches; do
            base_unit="$(basename "$unit_path")"
            if systemctl --user is-active --quiet "$base_unit"; then
                echo "  restarting $base_unit (uses $dest)"
                restart_user_unit "$base_unit"
            fi
        done
    done
    DID_ANYTHING=1
fi

# --- scripts/*.py / *.sh that back systemd user units ---
# The rebuild-services.timer cascade doesn't watch scripts/; if a
# systemd user unit's ExecStart references a script we just changed,
# restart that unit. Catches producers like hapax-youtube-viewer-count
# that live in scripts/ rather than agents/.
if [ "${#SCRIPT_PY[@]}" -gt 0 ]; then
    echo "backing-script changes (${#SCRIPT_PY[@]}):"
    for f in "${SCRIPT_PY[@]}"; do
        # Find units whose ExecStart references this script (any invocation form).
        # Search both the repo definitions and the installed user units.
        matches="$(grep -l -F "$f" "$REPO/systemd/units/"*.service 2>/dev/null || true)"
        for unit_path in $matches; do
            base="$(basename "$unit_path")"
            if systemctl --user is-active --quiet "$base"; then
                echo "  restarting $base (backs $f)"
                restart_user_unit "$base"
                DID_ANYTHING=1
            fi
        done
    done
fi

# --- Screwm Quake runtime assets ---
# Map, WAD, QC/CSQC, and DarkPlaces live-texture patch artifacts are loaded by
# the running renderer, not by the Python service rebuild loop. Install them
# after merge, then restart the visible renderer only when it is already active.
if [ "${#QUAKE_ASSETS[@]}" -gt 0 ]; then
    echo "quake assets changed (${#QUAKE_ASSETS[@]}):"
    for f in "${QUAKE_ASSETS[@]}"; do
        echo "  $f"
    done
    QUAKE_INSTALLER="$REPO/scripts/install-darkplaces-screwm-assets.sh"
    if [ ! -f "$QUAKE_INSTALLER" ]; then
        echo "hapax-post-merge-deploy: missing Screwm Quake asset installer: $QUAKE_INSTALLER" >&2
        exit 2
    fi
    echo "installing Screwm Quake assets"
    bash "$QUAKE_INSTALLER"
    if systemctl --user is-active --quiet hapax-darkplaces-v4l2.service; then
        echo "restarting hapax-darkplaces-v4l2.service (Screwm Quake assets changed)"
        restart_user_unit hapax-darkplaces-v4l2.service
    else
        echo "hapax-darkplaces-v4l2.service inactive; assets installed for next renderer start"
    fi
    DID_ANYTHING=1
fi

# --- canonical gate closure (reform FM-6 shim collapse) ---
# Every real deploy invocation reconciles the canonical hook closure, even when
# the current diff did not touch gate files. This closes the pre-existing-drift
# gap where a missed/failed deploy left ~/.local/lib/hapax/hooks stale forever
# while later merges stamped last-deployed-sha as healthy.
reconcile_canonical_gate_closure

if [ "$DID_ANYTHING" -eq 0 ]; then
    echo "merge $SHA: no manual deploys needed (only auto-rebuild paths changed)"
fi

# Smoke-runner gate (cc-task post-merge-smoke-deploy-wiring, 2026-05-02).
# DRY_RUN and REPORT_COVERAGE modes exited earlier so this only fires
# in real-deploy mode. The smoke runner inspects the diff for $SHA,
# fires gates that match, ntfy's on failure, and ALWAYS exits 0 — the
# deploy already happened; the smoke is informational. The script
# itself enforces the 0-exit contract; we still wrap with `|| true`
# defensively so a smoke-side bug can never block trace recording or
# the deploy script's normal exit. Rationale: shipping in #2148
# without a deploy-chain caller meant every smoke-side fix lived as
# dead code (zeta audit finding 2026-05-02, severity HIGH).
SMOKE_SCRIPT="$REPO/scripts/hapax-post-merge-smoke"
if [ -x "$SMOKE_SCRIPT" ]; then
    "$SMOKE_SCRIPT" "$SHA" || true
fi

# Self-verify the deploy symlinks resolve to the canonical tree (advisory:
# ntfy's on drift but never fails the deploy that just succeeded). This is the
# "live" half of the drift assertion — it runs every real deploy cycle so a
# dangling/foreign ~/.local/bin/hapax-* symlink can't sit unnoticed.
check_symlink_drift || true

if record_post_merge_trace "completed" "0"; then
    TRACE_WRITTEN=1
else
    echo "warning: failed to write post-merge deploy trace to $TRACE_PATH" >&2
fi
record_last_deployed_sha
