#!/usr/bin/env python3
"""Fail-loud CI entry point for capability_surface_delta.

This wrapper exists so GitHub Actions has a stable, named command for the
forcing-function gate. The implementation stays in shared.capability_inventory.
"""

from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from shared.capability_inventory import main

if __name__ == "__main__":
    sys.exit(main(["--delta", *sys.argv[1:]]))
