#!/usr/bin/bash
# hapax-lane-reaper - read-only lane recovery inspection.
#
# Liveness, quota text, tmux state, service-time estimates, and pressure are
# support signals. They cannot authorize task/claim mutation, worktree removal,
# process termination, task minting, notification, or service activation. This
# command therefore discovers candidates and emits visible HOLD diagnostics only.
# Effects remain held until a ValidAuthorityGrant, AdmissionDecision, and exact
# ExecutionLease are validated at an execution adapter.

set -euo pipefail

TMUX_OBSERVER=(/usr/bin/env -i HOME=/nonexistent LANG=C.UTF-8 PATH=/usr/bin:/bin /usr/bin/tmux -f /dev/null)
readonly -a TMUX_OBSERVER

IDLE_THRESHOLD_MIN=30
DRY_RUN=0
COUNCIL_DIR="${HAPAX_COUNCIL_DIR:-$HOME/projects/hapax-council}"
HOLD_REASON="missing-valid-authority-grant-admission-decision-exact-execution-lease"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run | --check)
            DRY_RUN=1
            shift
            ;;
        --threshold)
            if [[ $# -lt 2 ]]; then
                printf 'lane-reaper: --threshold requires minutes\n' >&2
                exit 2
            fi
            IDLE_THRESHOLD_MIN="$2"
            shift 2
            ;;
        *)
            printf 'lane-reaper: unknown argument: %s\n' "$1" >&2
            exit 2
            ;;
    esac
done

if [[ ! "$IDLE_THRESHOLD_MIN" =~ ^[0-9]+$ ]]; then
    printf 'lane-reaper: threshold must be a non-negative integer\n' >&2
    exit 2
fi

log() { printf 'lane-reaper: %s\n' "$*" >&2; }

held=0
inspected=0

hold_effect() {
    local role="$1" effect="$2" detail="${3:-candidate}"
    log "HOLD lane=$role effect=$effect reason=$HOLD_REASON detail=$detail"
    held=$((held + 1))
}

inspect_worktree() {
    local role="$1" worktree="$COUNCIL_DIR--$role"
    [[ -d "$worktree" ]] || return 0

    local uncommitted branch ahead
    uncommitted=$(/usr/bin/git -C "$worktree" status --porcelain 2>/dev/null | /usr/bin/wc -l) || uncommitted="unknown"
    branch=$(/usr/bin/git -C "$worktree" symbolic-ref --short HEAD 2>/dev/null) || branch="detached-or-unknown"
    ahead=$(/usr/bin/git -C "$worktree" rev-list --count main..HEAD 2>/dev/null) || ahead="unknown"
    log "INSPECT lane=$role worktree=$worktree branch=$branch uncommitted=$uncommitted ahead=$ahead"
    hold_effect "$role" "remove-worktree" "$worktree"
}

inspect_claim() {
    local role="$1" claim_file="$HOME/.cache/hapax/cc-active-task-$role" claim
    [[ -f "$claim_file" ]] || return 0
    claim=$(/usr/bin/tr -d '[:space:]' <"$claim_file" 2>/dev/null) || claim="unreadable"
    log "INSPECT lane=$role claim=${claim:-empty} pointer=$claim_file"
    hold_effect "$role" "release-task" "${claim:-empty}"
    hold_effect "$role" "clear-claim" "$claim_file"
}

sessions=$("${TMUX_OBSERVER[@]}" list-sessions -F '#{session_name}' 2>/dev/null | /usr/bin/grep -E '^hapax-(codex-cx-|claude-)' || true)
while IFS= read -r session; do
    [[ -n "$session" ]] || continue
    inspected=$((inspected + 1))

    pane_pid=$("${TMUX_OBSERVER[@]}" list-panes -t "$session" -F '#{pane_pid}' 2>/dev/null | /usr/bin/head -1) || pane_pid=""
    if [[ -z "$pane_pid" || ! "$pane_pid" =~ ^[0-9]+$ ]]; then
        log "INSPECT session=$session state=indeterminate reason=missing-pane-pid"
        continue
    fi

    role="${session#hapax-codex-}"
    role="${role#hapax-claude-}"

    children=$(/usr/bin/ps --ppid "$pane_pid" -o comm= 2>/dev/null | /usr/bin/grep -Ecv '^(fish|bash|zsh|sh)$') || children=0
    last_output=$("${TMUX_OBSERVER[@]}" capture-pane -t "$session" -p 2>/dev/null | /usr/bin/grep -v '^$' | /usr/bin/tail -3) || last_output=""
    is_stuck=0
    if printf '%s\n' "$last_output" | /usr/bin/grep -Eqi 'rate.limit|quota|429|Usage limit|BLOCKED.*quota'; then
        is_stuck=1
    fi

    if [[ "$children" -gt 0 && "$is_stuck" -eq 0 ]]; then
        log "INSPECT lane=$role state=active children=$children"
        continue
    fi

    if [[ "$children" -gt 0 && "$is_stuck" -eq 1 ]]; then
        log "INSPECT lane=$role state=quota-signal children=$children"
        inspect_claim "$role"
        hold_effect "$role" "notify" "quota-signal"
        continue
    fi

    last_activity=$("${TMUX_OBSERVER[@]}" display-message -t "$session" -p '#{session_activity}' 2>/dev/null) || last_activity=""
    now=$(/usr/bin/date +%s)
    if [[ ! "$last_activity" =~ ^[0-9]+$ || "$last_activity" -gt "$now" ]]; then
        log "INSPECT lane=$role state=indeterminate reason=invalid-session-activity"
        continue
    fi

    idle_sec=$((now - last_activity))
    threshold_sec=$((IDLE_THRESHOLD_MIN * 60))
    if [[ "$idle_sec" -lt "$threshold_sec" ]]; then
        log "INSPECT lane=$role state=idle-within-threshold idle_seconds=$idle_sec"
        continue
    fi

    log "INSPECT lane=$role state=recovery-candidate idle_seconds=$idle_sec dry_run=$DRY_RUN"
    inspect_worktree "$role"
    inspect_claim "$role"
    hold_effect "$role" "terminate-process" "pane-pid=$pane_pid"
    hold_effect "$role" "record-recovery-attempt" "idle-seconds=$idle_sec"
    hold_effect "$role" "mint-escalation-task" "recovery-candidate"
    hold_effect "$role" "notify" "recovery-candidate"
    hold_effect "$role" "start-hygiene-service" "post-recovery"
done <<<"$sessions"

log "Done: inspected=$inspected held_effects=$held effects_executed=0"
