#!/usr/bin/env bash
# hapax-lane-reaper — recover dead lanes (bounded PID-kill) and clean worktrees.
#
# Scans hapax-codex-cx-* and hapax-claude-* tmux sessions. A dead lane (shell
# prompt, no worker process) silent past the MEASURED per-lineage tau is reaped
# via a single PID-targeted os.kill(SIGTERM) — never a whole-session teardown —
# and its merged worktree cleaned. Recovery is bounded: after a per-lane attempt cap the
# reaper escalates (ntfy) and STOPS rather than looping. The tau comes from
# ~/.cache/hapax/dispatch-service-time.json (shared with the coordinator +
# idle-watchdog); --threshold/IDLE_THRESHOLD_MIN is the fixed fallback when the
# cache is absent or HAPAX_DISPATCH_SCHEDULER_LEGACY=1.
#
# Usage:
#   hapax-lane-reaper [--dry-run] [--threshold MINUTES] [--help]
#
# Run via timer: systemd/units/hapax-lane-reaper.timer (every 30 min)

set -euo pipefail

# Fixed-threshold fallback (minutes) for legacy / no-cache mode; --threshold overrides.
# (Previously `${1:-30}` which wrongly captured flags like --dry-run into the number.)
IDLE_THRESHOLD_MIN=30
DRY_RUN=0
COUNCIL_DIR="${HAPAX_COUNCIL_DIR:-$HOME/projects/hapax-council}"

log() { printf 'lane-reaper: %s\n' "$*" >&2; }

usage() {
    cat <<'EOF'
Usage: hapax-lane-reaper [--dry-run] [--threshold MINUTES] [--help]

Recover idle Hapax lanes without whole-session teardown.

Options:
  --dry-run             Report candidate releases/reaps without mutating state.
  --threshold MINUTES   Legacy fixed idle threshold when measured tau is absent.
  -h, --help            Show this help text.
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run) DRY_RUN=1; shift ;;
        --threshold)
            if [[ $# -lt 2 || "$2" == --* ]]; then
                log "--threshold requires a MINUTES argument"
                usage >&2
                exit 64
            fi
            IDLE_THRESHOLD_MIN="$2"
            shift 2
            ;;
        --help | -h)
            usage
            exit 0
            ;;
        *)
            log "unknown argument: $1"
            usage >&2
            exit 64
            ;;
    esac
done

# ─── RecoveryGovernor admission for the load-injecting reap action ────────────
# bb-control-stability: the kill + worktree-cleanup + hygiene-sweep a reap
# triggers is a recovery action; route it through the shared governor so a wave
# of reaps can't storm the box, and so a session that keeps needing reaping
# escalates via AIMD. The release-task path (load-free) stays ungated. Fail-open:
# any non-{0,75,2} exit → PERMIT (the reaper never wedges on the governor).
governor_repo() {
    local repo
    repo="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)"
    [[ -d "$repo/shared" ]] || repo="${HOME}/projects/hapax-council"
    echo "$repo"
}
governor_permit() {
    [[ "${HAPAX_RECOVERY_GOVERNOR_OFF:-}" == "1" ]] && return 0
    local rc
    (cd "$(governor_repo)" 2>/dev/null && python3 -m shared.recovery_governor --permit "$1" >/dev/null 2>&1)
    rc=$?
    case "$rc" in
        0) return 0 ;;
        75 | 2) return 1 ;;
        *) return 0 ;;
    esac
}
governor_record() {
    [[ "${HAPAX_RECOVERY_GOVERNOR_OFF:-}" == "1" ]] && return 0
    (cd "$(governor_repo)" 2>/dev/null && python3 -m shared.recovery_governor --record "$1" "$2" >/dev/null 2>&1) || true
}

is_quota_wall_output() {
    local text="$1"
    [[ -z "$text" ]] && return 1
    printf '%s\n' "$text" | grep -Eiq \
        '(^|[^[:alnum:]])(HTTP[[:space:]]*)?429([^[:alnum:]]|$)|Too Many Requests|rate[-_.[:space:]]*limit(ed)?[-_.[:space:]]*(exceeded|reached|hit|error)|rate[-_.[:space:]]*limited|Usage limit[[:space:]]+(reached|exceeded)|weekly[[:space:]]+limit|quota[-_[:space:]]+(wall|limit|exceeded|reached|blocked|exhausted)|blocked[: _-]+quota([^[:alnum:]-]|$)'
}

if [[ "${HAPAX_LANE_REAPER_CLASSIFY_STDIN:-}" == "1" ]]; then
    if is_quota_wall_output "$(cat)"; then
        printf 'stuck\n'
    else
        printf 'active\n'
    fi
    exit 0
fi

# ─── bb-dispatch-scheduler: measured tau timeout + bounded PID-targeted kill ───
# The reap threshold is no longer a fixed 30m; it is the MEASURED per-lineage tau
# the coordinator + idle-watchdog also read (one timeout, not three divergent
# constants). The kill is a single PID-targeted SIGTERM (os.kill) — never a
# whole-session or whole-process-group teardown, so the worker shuts down and
# reaps its own children instead of the entire pane tree taking a HUP (the
# exit-144 cascade lesson). HAPAX_DISPATCH_SCHEDULER_LEGACY=1 (or a missing cache)
# reverts the THRESHOLD to the fixed minutes; the bounded-kill fix is permanent.
DISPATCH_CACHE="${HAPAX_DISPATCH_SERVICE_TIME_CACHE:-$HOME/.cache/hapax/dispatch-service-time.json}"
REAP_ATTEMPTS_DIR="${HAPAX_REAP_ATTEMPTS_DIR:-$HOME/.cache/hapax/lane-reap-attempts}"
mkdir -p "$REAP_ATTEMPTS_DIR"

reap_decide() {
    # echo skip|reap|escalate for (role, progress_age_s, attempts). Legacy or an
    # absent cache fall back to the fixed minutes so behavior is preserved until
    # the recompute populates measured tau.
    local role="$1" age="$2" attempts="$3"
    local extra=()
    if [[ "${HAPAX_DISPATCH_SCHEDULER_LEGACY:-}" == "1" || ! -f "$DISPATCH_CACHE" ]]; then
        extra=(--tau-override "$((IDLE_THRESHOLD_MIN * 60))")
    fi
    (cd "$(governor_repo)" 2>/dev/null && python3 -m shared.dispatch_service_time \
        --reap-decision --lineage "$role" --progress-age "$age" --attempts "$attempts" \
        --cache "$DISPATCH_CACHE" "${extra[@]}" 2>/dev/null) || echo skip
}

target_pid_for() {
    # the lane's worker process (deepest claude/node/codex child) or the pane shell.
    local pane="$1" found="" cpid comm
    for cpid in $(pgrep -P "$pane" 2>/dev/null || true); do
        comm=$(ps -o comm= -p "$cpid" 2>/dev/null || true)
        case "$comm" in claude | node | codex) found="$cpid" ;; esac
    done
    echo "${found:-$pane}"
}

active_child_count() {
    local pane="$1" count=0 cpid comm
    while IFS= read -r cpid; do
        [[ -z "$cpid" ]] && continue
        comm=$(ps -o comm= -p "$cpid" 2>/dev/null || true)
        case "$comm" in
            fish | bash | zsh | sh | "") ;;
            *) count=$((count + 1)) ;;
        esac
    done < <(pgrep -P "$pane" 2>/dev/null || true)
    echo "$count"
}

reap_kill() {
    # bounded recovery: a single PID-targeted SIGTERM via os.kill. Never a session
    # or process-group teardown. ProcessLookupError == already gone (fine).
    local pid="$1"
    python3 -c "import os, signal, sys
try:
    os.kill(int(sys.argv[1]), signal.SIGTERM)
except (ValueError, ProcessLookupError, PermissionError):
    pass" "$pid" 2>/dev/null || true
}

reap_attempts() { cat "$REAP_ATTEMPTS_DIR/$1" 2>/dev/null || echo 0; }
bump_reap_attempts() { echo "$(($(reap_attempts "$1") + 1))" >"$REAP_ATTEMPTS_DIR/$1"; }
reset_reap_attempts() { rm -f "$REAP_ATTEMPTS_DIR/$1" 2>/dev/null || true; }

# Keep the measured service-time cache warm on the reaper's already-scheduled cadence
# (hourly), so the tau the coordinator + idle-watchdog + this reaper read is current.
# Best-effort and bounded: a fold failure or slowness never blocks a reap. (A dedicated
# Slice=hapax-sdlc.slice oneshot is the deploy follow-up; this populates it meanwhile.)
recompute_cache_if_stale() {
    local cache="$DISPATCH_CACHE" age=999999
    if [[ -f "$cache" ]]; then
        age=$(($(date +%s) - $(stat -c %Y "$cache" 2>/dev/null || echo 0)))
        [[ "$age" -lt 3600 ]] && return 0
    fi
    (cd "$(governor_repo)" 2>/dev/null &&
        timeout 60 python3 -m shared.dispatch_service_time --recompute --cache "$cache" >/dev/null 2>&1) || true
}
if [[ "$DRY_RUN" -eq 0 ]]; then
    recompute_cache_if_stale
fi

killed=0
cleaned=0

for session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -E "^hapax-(codex-cx-|claude-)"); do
    # Check if session has an active process beyond the shell
    pane_pid=$(tmux list-panes -t "$session" -F '#{pane_pid}' 2>/dev/null | head -1)
    [[ -z "$pane_pid" ]] && continue

    role="${session#hapax-codex-}"
    role="${role#hapax-claude-}"

    # Count child processes (excluding the shell itself)
    children=$(active_child_count "$pane_pid")

    # Check last output for explicit provider quota/rate-limit walls.
    last_output=$(tmux capture-pane -t "$session" -p 2>/dev/null | grep -v "^$" | tail -3)
    is_stuck=0
    if is_quota_wall_output "$last_output"; then
        is_stuck=1
    fi

    if [[ "$children" -gt 0 && "$is_stuck" -eq 0 ]]; then
        reset_reap_attempts "$role"  # lane is working again — clear the reap counter
        continue  # Active process making progress — skip
    fi

    if [[ "$children" -gt 0 && "$is_stuck" -eq 1 ]]; then
        # Stuck lane — release the task but DON'T kill the session
        log "$session: STUCK (quota/rate-limit) — releasing task, keeping session"
        claim_file="$HOME/.cache/hapax/cc-active-task-$role"
        if [[ -f "$claim_file" ]]; then
            claim=$(cat "$claim_file" | tr -d '[:space:]')
            if [[ -n "$claim" ]]; then
                for task_file in "$HOME/Documents/Personal/20-projects/hapax-cc-tasks/active/${claim}"*.md; do
                    if [[ -f "$task_file" ]]; then
                        if [[ "$DRY_RUN" -eq 0 ]]; then
                            sed -i "s/^status: claimed/status: offered/" "$task_file"
                            sed -i "s/^status: in_progress/status: offered/" "$task_file"
                            sed -i "s/^assigned_to: .*/assigned_to: unassigned/" "$task_file"
                            log "  Released task: $claim → offered"
                        else
                            log "  DRY RUN: would release task: $claim → offered"
                        fi
                    fi
                done
            fi
            if [[ "$DRY_RUN" -eq 0 ]]; then
                rm -f "$claim_file"
            else
                log "  DRY RUN: would remove claim file: $claim_file"
            fi
        elif [[ "$DRY_RUN" -eq 1 ]]; then
            log "  DRY RUN: no claim file to release for $role"
        fi
        continue  # Don't kill — session may recover
    fi

    # Dead lane — shell prompt, no worker process. Reap candidacy is governed by the
    # MEASURED per-lineage tau (not a fixed 30m): silence within tau -> skip (slow-but-
    # live); past tau -> reap; past tau with attempts exhausted -> escalate + STOP so a
    # genuinely-wedged lane is surfaced once, never reaped in an infinite loop.
    last_activity=$(tmux display-message -t "$session" -p '#{session_activity}' 2>/dev/null || echo 0)
    now=$(date +%s)
    idle_sec=$(( now - last_activity ))

    attempts=$(reap_attempts "$role")
    decision=$(reap_decide "$role" "$idle_sec" "$attempts")
    case "$decision" in
        skip)
            continue  # silence within tau — not a reap candidate this cycle
            ;;
        escalate)
            log "$session: WEDGED — reaped ${attempts}x past tau without recovery; escalate + STOP"
            curl -sf \
                -d "lane-reaper: $role wedged — reaped ${attempts}x past tau without recovery; STOP (needs attention)" \
                -H "Title: Lane wedged (reap cap)" -H "Priority: high" -H "Tags: warning,robot" \
                "${HAPAX_NTFY_URL:-http://localhost:8092}/${HAPAX_NTFY_TOPIC:-hapax}" >/dev/null 2>&1 || true
            # Governed incident record alongside the ntfy channel.
            "$(dirname "$(readlink -f "$0")")/hapax-alert" high "Lane wedged (reap cap)" "$role wedged — reaped ${attempts}x past tau without recovery; STOP (needs attention)" --tag lane --record-only
            continue
            ;;
    esac

    log "$session: DEAD idle ${idle_sec}s (tau-governed reap, attempt $((attempts + 1)))"

    # Check for uncommitted work in the session's worktree
    worktree="$COUNCIL_DIR--$role"

    if [[ -d "$worktree" ]]; then
        uncommitted=$(git -C "$worktree" status --porcelain 2>/dev/null | wc -l)
        branch=$(git -C "$worktree" symbolic-ref --short HEAD 2>/dev/null || echo "detached")
        ahead=$(git -C "$worktree" rev-list --count main..HEAD 2>/dev/null || echo 0)

        if [[ "$uncommitted" -gt 0 ]]; then
            log "  WARNING: $worktree has $uncommitted uncommitted changes — NOT cleaning"
        elif [[ "$ahead" -gt 0 ]]; then
            # Check if branch was merged
            merged=$(git -C "$COUNCIL_DIR" branch --merged main 2>/dev/null | grep -c "$branch" || echo 0)
            if [[ "$merged" -gt 0 ]]; then
                log "  Worktree $worktree: branch $branch merged, cleaning"
                if [[ "$DRY_RUN" -eq 0 ]]; then
                    git -C "$COUNCIL_DIR" worktree remove --force "$worktree" 2>/dev/null && ((cleaned++)) || true
                fi
            else
                log "  Worktree $worktree: branch $branch has $ahead unpushed commits — NOT cleaning"
            fi
        else
            log "  Worktree $worktree: clean, removing"
            if [[ "$DRY_RUN" -eq 0 ]]; then
                git -C "$COUNCIL_DIR" worktree remove --force "$worktree" 2>/dev/null && ((cleaned++)) || true
            fi
        fi
    fi

    # Clear stale claim file
    claim_file="$HOME/.cache/hapax/cc-active-task-$role"
    if [[ -f "$claim_file" ]]; then
        claim=$(cat "$claim_file" | tr -d '[:space:]')
        if [[ -n "$claim" ]]; then
            # Release the task back to offered
            for task_file in "$HOME/Documents/Personal/20-projects/hapax-cc-tasks/active/${claim}"*.md; do
                if [[ -f "$task_file" ]]; then
                    if [[ "$DRY_RUN" -eq 0 ]]; then
                        sed -i "s/^status: claimed/status: offered/" "$task_file"
                        sed -i "s/^status: in_progress/status: offered/" "$task_file"
                        sed -i "s/^assigned_to: .*/assigned_to: unassigned/" "$task_file"
                        log "  Released task: $claim → offered"
                    else
                        log "  DRY RUN: would release stale task: $claim → offered"
                    fi
                fi
            done
        fi
        if [[ "$DRY_RUN" -eq 0 ]]; then
            rm -f "$claim_file"
        else
            log "  DRY RUN: would remove stale claim file: $claim_file"
        fi
    elif [[ "$DRY_RUN" -eq 1 ]]; then
        log "  DRY RUN: no stale claim file to release for $role"
    fi

    # Reap (governed: a reap is a recovery action). MUST-FIX: the kill is a single
    # PID-targeted os.kill(SIGTERM) of the lane's worker (or its idle shell), NOT a
    # whole-session teardown — the worker terminates gracefully and reaps its own
    # children rather than the entire pane tree taking a HUP (bounded, no tree-kill).
    if [[ "$DRY_RUN" -eq 0 ]]; then
        if governor_permit "lane:$role"; then
            reap_kill "$(target_pid_for "$pane_pid")" && ((killed++)) || true
            bump_reap_attempts "$role"
            governor_record "lane:$role" ok
            log "  Reaped lane $session via os.kill (pid $(target_pid_for "$pane_pid"))"
        else
            log "  RecoveryGovernor deferred reap of $session (backoff/pressure); retry next cycle"
        fi
    else
        log "  DRY RUN: would os.kill $(target_pid_for "$pane_pid") (lane $session)"
    fi
done

log "Done: killed=$killed cleaned=$cleaned"

if [[ "$DRY_RUN" -eq 0 && $(( killed + cleaned )) -gt 0 ]]; then
    systemctl --user start hapax-cc-hygiene.service 2>/dev/null || true
    log "Triggered hygiene sweep after cleanup"
fi
