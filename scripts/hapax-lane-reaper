#!/usr/bin/env bash
# hapax-lane-reaper -- project transitional lane inventory from bounded tmux metadata.
#
# This compatibility surface is observation-only in every mode. Direct tmux
# metadata is intentionally not activation-grade. Reins owns the permanent,
# runtime-agnostic observer and governed lifecycle successor.

set -euo pipefail
export LC_ALL=C

readonly SESSION_FORMAT=$'#{session_id}\t#{q:session_name}\t#{session_activity}\t#{session_created}\t#{session_windows}'
readonly PANE_FORMAT=$'#{session_id}\t#{pane_id}\t#{pane_pid}\t#{pane_dead}\t#{pane_active}'
readonly CAPTURE_SENTINEL=$'\036'

usage_error() {
    printf 'lane-reaper: usage_error reason=%s next_action=run_hapax-lane-reaper_--help exit=64\n' \
        "$1" >&2
    exit 64
}

usage() {
    printf '%s\n' \
        'Usage: hapax-lane-reaper [--dry-run] [--threshold MINUTES] [--reap-lineage ID]' \
        'Transitional status: observation-only and non-effectful; compatibility options are inert.' \
        'Permanent successor: Reins runtime-agnostic observation and governed lifecycle control.' \
        'Retirement predicate: Reins parity and source activation.'
}

hold() {
    printf 'lane-reaper: projection state=HOLD scope=tmux operation=%s context=%s reason=tmux_observation_unavailable detail=%s next_action=verify_tmux_metadata_then_retry universal_observer_successor=required successor=Reins exit=69\n' \
        "$1" "$2" "$3" >&2
    exit 69
}

dry_run_seen=0
threshold_seen=0
lineage_seen=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h)
            [[ $# -eq 1 && "$dry_run_seen" -eq 0 && "$threshold_seen" -eq 0 && \
                "$lineage_seen" -eq 0 ]] || usage_error help_must_be_only_argument
            usage
            exit 0
            ;;
        --dry-run)
            [[ "$dry_run_seen" -eq 0 ]] || usage_error duplicate_option
            dry_run_seen=1
            shift
            ;;
        --threshold)
            [[ "$threshold_seen" -eq 0 ]] || usage_error duplicate_option
            [[ $# -ge 2 ]] || usage_error missing_operand
            [[ "$2" =~ ^(0|[1-9][0-9]*)$ ]] || usage_error invalid_operand
            threshold_seen=1
            shift 2
            ;;
        --reap-lineage)
            [[ "$lineage_seen" -eq 0 ]] || usage_error duplicate_option
            [[ $# -ge 2 ]] || usage_error missing_operand
            [[ "$2" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || usage_error invalid_operand
            lineage_seen=1
            shift 2
            ;;
        -*)
            usage_error unknown_argument
            ;;
        *)
            usage_error positional_argument
            ;;
    esac
done

capture_tmux() {
    local rc=0
    # tmux 3.6b maps control delimiters to underscores in the C character
    # locale. Keep shell ordering in C while preserving literal TAB argv bytes
    # for the metadata subprocess. The suffix preserves trailing newlines; raw
    # tmux errors remain in memory for classification and are never emitted.
    LC_ALL=C.UTF-8 tmux "$@" 2>&1 || rc=$?
    printf '%s' "$CAPTURE_SENTINEL"
    return "$rc"
}

legacy_tmux_runtime_absent() {
    local captured="$1" line

    [[ "$captured" == *$'\n' ]] || return 1
    line=${captured%$'\n'}
    [[ "$line" != *$'\n'* ]] || return 1
    case "$line" in
        'no server running on '?*)
            return 0
            ;;
        'error connecting to '?*' (No such file or directory)')
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

split_five() {
    local rest="$1"

    [[ "$rest" == *$'\t'* ]] || return 1
    field_1=${rest%%$'\t'*}
    rest=${rest#*$'\t'}
    [[ "$rest" == *$'\t'* ]] || return 1
    field_2=${rest%%$'\t'*}
    rest=${rest#*$'\t'}
    [[ "$rest" == *$'\t'* ]] || return 1
    field_3=${rest%%$'\t'*}
    rest=${rest#*$'\t'}
    [[ "$rest" == *$'\t'* ]] || return 1
    field_4=${rest%%$'\t'*}
    rest=${rest#*$'\t'}
    [[ "$rest" != *$'\t'* ]] || return 1
    field_5="$rest"
}

canonical_nonnegative_decimal() {
    [[ "$1" =~ ^(0|[1-9][0-9]*)$ ]]
}

canonical_positive_decimal() {
    [[ "$1" =~ ^[1-9][0-9]*$ ]]
}

numeric_id_less_than() {
    local left_number="${1:1}" right_number="${2:1}"

    if [[ "${#left_number}" -lt "${#right_number}" ]]; then
        return 0
    fi
    if [[ "${#left_number}" -gt "${#right_number}" ]]; then
        return 1
    fi
    [[ "$left_number" < "$right_number" ]]
}

swap_eligible_sessions() {
    local left_index="$1" right_index="$2" swap_value

    swap_value=${eligible_session_ids[left_index]}
    eligible_session_ids[left_index]=${eligible_session_ids[right_index]}
    eligible_session_ids[right_index]="$swap_value"
    swap_value=${eligible_session_names[left_index]}
    eligible_session_names[left_index]=${eligible_session_names[right_index]}
    eligible_session_names[right_index]="$swap_value"
    swap_value=${eligible_session_roles[left_index]}
    eligible_session_roles[left_index]=${eligible_session_roles[right_index]}
    eligible_session_roles[right_index]="$swap_value"
}

swap_panes() {
    local left_index="$1" right_index="$2" swap_value

    swap_value=${pane_ids[left_index]}
    pane_ids[left_index]=${pane_ids[right_index]}
    pane_ids[right_index]="$swap_value"
    swap_value=${pane_pids[left_index]}
    pane_pids[left_index]=${pane_pids[right_index]}
    pane_pids[right_index]="$swap_value"
    swap_value=${pane_dead[left_index]}
    pane_dead[left_index]=${pane_dead[right_index]}
    pane_dead[right_index]="$swap_value"
    swap_value=${pane_active[left_index]}
    pane_active[left_index]=${pane_active[right_index]}
    pane_active[right_index]="$swap_value"
}

declare -a seen_session_ids=()
declare -a seen_session_names=()
declare -a eligible_session_ids=()
declare -a eligible_session_names=()
declare -a eligible_session_roles=()
declare -a all_pane_ids=()
declare -a lane_lines=()

if session_capture=$(capture_tmux list-sessions -F "$SESSION_FORMAT"); then
    session_rows=${session_capture%"$CAPTURE_SENTINEL"}
    [[ -n "$session_rows" ]] || hold list-sessions none incoherent
else
    session_rc=$?
    session_rows=${session_capture%"$CAPTURE_SENTINEL"}
    if [[ "$session_rc" -eq 1 ]] && legacy_tmux_runtime_absent "$session_rows"; then
        printf 'lane-reaper: projection state=UNKNOWN scope=inventory lane_count=unknown reason=legacy_tmux_runtime_absent next_action=none_until_Reins_activation universal_observer_successor=required successor=Reins exit=0\n' >&2
        exit 0
    fi
    hold list-sessions none unavailable
fi

while [[ -n "$session_rows" ]]; do
    if [[ "$session_rows" == *$'\n'* ]]; then
        row=${session_rows%%$'\n'*}
        session_rows=${session_rows#*$'\n'}
    else
        row="$session_rows"
        session_rows=""
    fi

    [[ -n "$row" ]] || hold list-sessions none malformed
    split_five "$row" || hold list-sessions none malformed
    [[ "$field_1" =~ ^\$(0|[1-9][0-9]*)$ ]] || hold list-sessions none malformed
    canonical_nonnegative_decimal "$field_3" || hold list-sessions none malformed
    canonical_nonnegative_decimal "$field_4" || hold list-sessions none malformed
    canonical_positive_decimal "$field_5" || hold list-sessions none malformed

    for existing in "${seen_session_ids[@]}"; do
        [[ "$existing" != "$field_1" ]] || hold list-sessions none incoherent
    done
    for existing in "${seen_session_names[@]}"; do
        [[ "$existing" != "$field_2" ]] || hold list-sessions none incoherent
    done
    seen_session_ids+=("$field_1")
    seen_session_names+=("$field_2")

    if [[ "$field_2" =~ ^hapax-(codex-cx-|claude-)[A-Za-z0-9][A-Za-z0-9_-]*$ ]]; then
        role=${field_2#hapax-codex-}
        role=${role#hapax-claude-}
        eligible_session_ids+=("$field_1")
        eligible_session_names+=("$field_2")
        eligible_session_roles+=("$role")
    fi
done

session_count=${#eligible_session_ids[@]}
for ((left_index = 0; left_index < session_count; left_index++)); do
    for ((right_index = left_index + 1; right_index < session_count; right_index++)); do
        if numeric_id_less_than "${eligible_session_ids[right_index]}" "${eligible_session_ids[left_index]}"; then
            swap_eligible_sessions "$left_index" "$right_index"
        fi
    done
done

inventory_pane_count=0
inventory_live_pane_count=0
inventory_active_pane_count=0

for ((session_index = 0; session_index < session_count; session_index++)); do
    session_id=${eligible_session_ids[session_index]}
    session_name=${eligible_session_names[session_index]}
    session_role=${eligible_session_roles[session_index]}

    if pane_capture=$(capture_tmux list-panes -s -t "$session_id" -F "$PANE_FORMAT"); then
        pane_rows=${pane_capture%"$CAPTURE_SENTINEL"}
    else
        hold list-panes "session_id=$session_id" unavailable
    fi
    [[ -n "$pane_rows" ]] || hold list-panes "session_id=$session_id" incoherent

    declare -a pane_ids=()
    declare -a pane_pids=()
    declare -a pane_dead=()
    declare -a pane_active=()

    while [[ -n "$pane_rows" ]]; do
        if [[ "$pane_rows" == *$'\n'* ]]; then
            row=${pane_rows%%$'\n'*}
            pane_rows=${pane_rows#*$'\n'}
        else
            row="$pane_rows"
            pane_rows=""
        fi

        [[ -n "$row" ]] || hold list-panes "session_id=$session_id" malformed
        split_five "$row" || hold list-panes "session_id=$session_id" malformed
        [[ "$field_1" =~ ^\$(0|[1-9][0-9]*)$ ]] || \
            hold list-panes "session_id=$session_id" malformed
        [[ "$field_2" =~ ^%(0|[1-9][0-9]*)$ ]] || \
            hold list-panes "session_id=$session_id" malformed
        canonical_positive_decimal "$field_3" || \
            hold list-panes "session_id=$session_id" malformed
        [[ "$field_4" =~ ^[01]$ ]] || hold list-panes "session_id=$session_id" malformed
        [[ "$field_5" =~ ^[01]$ ]] || hold list-panes "session_id=$session_id" malformed
        [[ "$field_1" == "$session_id" ]] || \
            hold list-panes "session_id=$session_id" incoherent

        for existing in "${all_pane_ids[@]}"; do
            [[ "$existing" != "$field_2" ]] || \
                hold list-panes "session_id=$session_id" incoherent
        done
        all_pane_ids+=("$field_2")
        pane_ids+=("$field_2")
        pane_pids+=("$field_3")
        pane_dead+=("$field_4")
        pane_active+=("$field_5")
    done

    pane_count=${#pane_ids[@]}
    for ((left_index = 0; left_index < pane_count; left_index++)); do
        for ((right_index = left_index + 1; right_index < pane_count; right_index++)); do
            if numeric_id_less_than "${pane_ids[right_index]}" "${pane_ids[left_index]}"; then
                swap_panes "$left_index" "$right_index"
            fi
        done
    done

    live_pane_count=0
    active_pane_count=0
    for ((pane_index = 0; pane_index < pane_count; pane_index++)); do
        pane_id=${pane_ids[pane_index]}
        pane_pid=${pane_pids[pane_index]}
        dead_value=${pane_dead[pane_index]}
        active_value=${pane_active[pane_index]}

        if display_capture=$(capture_tmux display-message -p -t "$pane_id" "$PANE_FORMAT"); then
            display_rows=${display_capture%"$CAPTURE_SENTINEL"}
        else
            hold display-message "session_id=$session_id,pane_id=$pane_id" unavailable
        fi
        [[ -n "$display_rows" ]] || \
            hold display-message "session_id=$session_id,pane_id=$pane_id" malformed

        if [[ "$display_rows" == *$'\n'* ]]; then
            display_row=${display_rows%%$'\n'*}
            display_remainder=${display_rows#*$'\n'}
            [[ -z "$display_remainder" ]] || \
                hold display-message "session_id=$session_id,pane_id=$pane_id" malformed
        else
            display_row="$display_rows"
        fi
        [[ -n "$display_row" ]] || \
            hold display-message "session_id=$session_id,pane_id=$pane_id" malformed

        split_five "$display_row" || \
            hold display-message "session_id=$session_id,pane_id=$pane_id" malformed
        [[ "$field_1" =~ ^\$(0|[1-9][0-9]*)$ ]] || \
            hold display-message "session_id=$session_id,pane_id=$pane_id" malformed
        [[ "$field_2" =~ ^%(0|[1-9][0-9]*)$ ]] || \
            hold display-message "session_id=$session_id,pane_id=$pane_id" malformed
        canonical_positive_decimal "$field_3" || \
            hold display-message "session_id=$session_id,pane_id=$pane_id" malformed
        [[ "$field_4" =~ ^[01]$ ]] || \
            hold display-message "session_id=$session_id,pane_id=$pane_id" malformed
        [[ "$field_5" =~ ^[01]$ ]] || \
            hold display-message "session_id=$session_id,pane_id=$pane_id" malformed
        [[ "$field_1" == "$session_id" && "$field_2" == "$pane_id" && \
            "$field_3" == "$pane_pid" && "$field_4" == "$dead_value" && \
            "$field_5" == "$active_value" ]] || \
            hold display-message "session_id=$session_id,pane_id=$pane_id" incoherent

        if [[ "$dead_value" -eq 0 ]]; then
            live_pane_count=$((live_pane_count + 1))
        fi
        if [[ "$active_value" -eq 1 ]]; then
            active_pane_count=$((active_pane_count + 1))
        fi
    done

    inventory_pane_count=$((inventory_pane_count + pane_count))
    inventory_live_pane_count=$((inventory_live_pane_count + live_pane_count))
    inventory_active_pane_count=$((inventory_active_pane_count + active_pane_count))
    lane_lines+=("lane-reaper: projection state=UNKNOWN scope=lane session_id=$session_id session_name=$session_name role=$session_role pane_count=$pane_count live_pane_count=$live_pane_count active_pane_count=$active_pane_count reason=direct_tmux_metadata_not_activation_grade universal_observer_successor=required successor=Reins")
done

for line in "${lane_lines[@]}"; do
    printf '%s\n' "$line" >&2
done

if [[ "$session_count" -eq 0 ]]; then
    printf 'lane-reaper: projection state=UNKNOWN scope=inventory lane_count=0 reason=valid_empty_inventory universal_observer_successor=required successor=Reins\n' >&2
else
    printf 'lane-reaper: projection state=UNKNOWN scope=inventory lane_count=%s pane_count=%s live_pane_count=%s active_pane_count=%s reason=direct_tmux_metadata_not_activation_grade universal_observer_successor=required successor=Reins\n' \
        "$session_count" "$inventory_pane_count" "$inventory_live_pane_count" \
        "$inventory_active_pane_count" >&2
fi
