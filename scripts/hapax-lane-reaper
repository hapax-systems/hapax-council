#!/usr/bin/env bash
# hapax-lane-reaper — project dead/stuck lanes for governed recovery.
#
# Scans hapax-codex-cx-* and hapax-claude-* tmux sessions. An UNCLAIMED dead
# lane (shell prompt, no worker process) silent past the measured tau is projected
# as a recovery candidate. This standing timer has no kill, worktree-cleanup, or
# claim/task mutation authority; every candidate HOLDs for a separately authorized
# recovery writer. Task-note ownership is authoritative when cache markers are
# absent. Nested processes in every pane are observed before projecting a lane dead.
# The installed unit executes this tracked file from the source-activation
# worktree. Repository-relative helpers resolve that activated release and fail
# closed; they never fall back to the mutable primary worktree. The tau comes from
# ~/.cache/hapax/dispatch-service-time.json (shared with the coordinator +
# idle-watchdog); --threshold/IDLE_THRESHOLD_MIN is the fixed fallback when the
# cache is absent or HAPAX_DISPATCH_SCHEDULER_LEGACY=1.
#
# Usage:
#   hapax-lane-reaper [--dry-run] [--threshold MINUTES] [--help]
#
# Run via timer: systemd/units/hapax-lane-reaper.timer (every 30 min)

set -euo pipefail

# Fixed-threshold fallback (minutes) for legacy / no-cache mode; --threshold overrides.
# (Previously `${1:-30}` which wrongly captured flags like --dry-run into the number.)
IDLE_THRESHOLD_MIN=30

log() { printf 'lane-reaper: %s\n' "$*" >&2; }

usage() {
    cat <<'EOF'
Usage: hapax-lane-reaper [--dry-run] [--threshold MINUTES] [--help]

Project idle Hapax lanes without changing sessions, worktrees, tasks, or claims.

Options:
  --dry-run             Compatibility flag; the standing reaper is always read-only.
  --threshold MINUTES   Legacy fixed idle threshold when measured tau is absent.
  -h, --help            Show this help text.
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run) shift ;;
        --threshold)
            if [[ $# -lt 2 || "$2" == --* ]]; then
                log "--threshold requires a MINUTES argument"
                usage >&2
                exit 64
            fi
            IDLE_THRESHOLD_MIN="$2"
            shift 2
            ;;
        --help | -h)
            usage
            exit 0
            ;;
        *)
            log "unknown argument: $1"
            usage >&2
            exit 64
            ;;
    esac
done

governor_repo() {
    local script_path repo
    script_path="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"
    repo="$(cd "$(dirname "$script_path")/.." 2>/dev/null && pwd)" || return 1
    if [[ ! -d "$repo/shared" ]]; then
        log "activated source root unavailable: $repo"
        return 1
    fi
    printf '%s\n' "$repo"
}

is_quota_wall_output() {
    local text="$1"
    [[ -z "$text" ]] && return 1
    # Provider walls are terminal, line-shaped evidence. Never infer a wall from
    # an identifier, taxonomy label, prose sentence, or underscored classifier.
    local prefix='[[:space:]]*((error|fatal|blocked|provider error)[[:space:]]*:[[:space:]]*)?'
    local suffix='[.!]?[[:space:]]*$'
    printf '%s\n' "$text" | grep -Eiq "^${prefix}(HTTP[[:space:]]*)?429[[:space:]:-]+Too Many Requests${suffix}" && return 0
    printf '%s\n' "$text" | grep -Eiq "^${prefix}rate[-[:space:]]*limit(ed)?[-[:space:]]+(exceeded|reached)${suffix}" && return 0
    printf '%s\n' "$text" | grep -Eiq "^${prefix}(exceeded|reached)[[:space:]]+rate[-[:space:]]*limit${suffix}" && return 0
    printf '%s\n' "$text" | grep -Eiq "^${prefix}Usage[[:space:]]+limit[[:space:]]+(reached|exceeded|hit)${suffix}" && return 0
    printf '%s\n' "$text" | grep -Eiq "^${prefix}weekly[[:space:]]+limit[[:space:]]+(reached|exceeded|hit)${suffix}" && return 0
    printf '%s\n' "$text" | grep -Eiq "^${prefix}(you have|you've|youve)?[[:space:]]*hit[[:space:]]+(your[[:space:]]+)?weekly[[:space:]]+limit${suffix}" && return 0
    printf '%s\n' "$text" | grep -Eiq "^${prefix}quota[-[:space:]]+(wall|exceeded|reached|blocked|exhausted)${suffix}" && return 0
    printf '%s\n' "$text" | grep -Eiq "^${prefix}quota[[:space:]]+limit[[:space:]]+(reached|exceeded|hit)${suffix}" && return 0
    return 1
}

if [[ "${HAPAX_LANE_REAPER_CLASSIFY_STDIN:-}" == "1" ]]; then
    if is_quota_wall_output "$(cat)"; then
        printf 'stuck\n'
    else
        printf 'active\n'
    fi
    exit 0
fi

# ─── bb-dispatch-scheduler: measured tau timeout, projection only ──────────────
# The reap threshold is no longer a fixed 30m; it is the MEASURED per-lineage tau
# the coordinator + idle-watchdog also read (one timeout, not three divergent
# constants). HAPAX_DISPATCH_SCHEDULER_LEGACY=1 (or a missing cache) reverts the
# threshold to fixed minutes. No decision here authorizes a process or worktree effect.
DISPATCH_CACHE="${HAPAX_DISPATCH_SERVICE_TIME_CACHE:-$HOME/.cache/hapax/dispatch-service-time.json}"
REAP_ATTEMPTS_DIR="${HAPAX_REAP_ATTEMPTS_DIR:-$HOME/.cache/hapax/lane-reap-attempts}"

reap_decide() {
    # echo skip|reap|escalate for (role, progress_age_s, attempts). Legacy or an
    # absent cache fall back to the fixed minutes so behavior is preserved until
    # the recompute populates measured tau.
    local role="$1" age="$2" attempts="$3"
    local extra=()
    if [[ "${HAPAX_DISPATCH_SCHEDULER_LEGACY:-}" == "1" || ! -f "$DISPATCH_CACHE" ]]; then
        extra=(--tau-override "$((IDLE_THRESHOLD_MIN * 60))")
    fi
    (cd "$(governor_repo)" 2>/dev/null && python3 -m shared.dispatch_service_time \
        --reap-decision --lineage "$role" --progress-age "$age" --attempts "$attempts" \
        --cache "$DISPATCH_CACHE" "${extra[@]}" 2>/dev/null) || echo skip
}

active_process_count() {
    # Walk the entire pane process tree. Wrapper shells can put the real worker
    # several generations below the pane root; a direct-child sample is not proof
    # of absence.
    local pane="$1" count=0 index=0 pid cpid comm
    local queue=("$pane")
    while [[ "$index" -lt "${#queue[@]}" ]]; do
        pid="${queue[$index]}"
        index=$((index + 1))
        comm=$(ps -o comm= -p "$pid" 2>/dev/null || true)
        case "$comm" in
            fish | bash | zsh | sh | "") ;;
            *) count=$((count + 1)) ;;
        esac
        while IFS= read -r cpid; do
            [[ -n "$cpid" ]] && queue+=("$cpid")
        done < <(pgrep -P "$pid" 2>/dev/null || true)
    done
    echo "$count"
}

claim_for_role() {
    local role="$1" claim_file claim
    local files=()
    shopt -s nullglob
    files=(
        "$HOME/.cache/hapax/cc-active-task-$role"
        "$HOME/.cache/hapax/cc-active-task-$role-"*
    )
    shopt -u nullglob
    for claim_file in "${files[@]}"; do
        [[ -f "$claim_file" ]] || continue
        claim=$(head -n1 "$claim_file" 2>/dev/null | tr -d '[:space:]')
        if [[ -n "$claim" ]]; then
            printf '%s\n' "$claim"
            return 0
        fi
    done
    return 1
}

task_claims_for_role() {
    local role="$1"
    local platform="$2"
    local active_dir="${HAPAX_CC_TASK_ROOT:-$HOME/Documents/Personal/20-projects/hapax-cc-tasks}/active"
    [[ -d "$active_dir" ]] || return 2
    (cd "$(governor_repo)" 2>/dev/null && python3 - "$active_dir" "$role" "$platform" <<'PY'
import sys
from pathlib import Path

from shared.sdlc_lifecycle import TASK_TERMINAL_STATUSES
from shared.sdlc_owner_identity import owner_matches
from shared.strict_yaml import strict_safe_load

active_dir = Path(sys.argv[1])
role = sys.argv[2]
platform = sys.argv[3]
claims: list[str] = []
try:
    paths = sorted(active_dir.glob("*.md"))
except OSError:
    raise SystemExit(2)

for path in paths:
    try:
        text = path.read_text(encoding="utf-8")
        if not text.startswith("---"):
            raise ValueError("missing frontmatter")
        parts = text.split("---", 2)
        if len(parts) < 3:
            raise ValueError("unclosed frontmatter")
        frontmatter = strict_safe_load(parts[1])
    except (OSError, ValueError, TypeError):
        raise SystemExit(2)
    if not isinstance(frontmatter, dict):
        raise SystemExit(2)
    owner = frontmatter.get("assigned_to")
    status = frontmatter.get("status")
    task_id = frontmatter.get("task_id")
    if "assigned_to" not in frontmatter:
        raise SystemExit(2)
    if owner is not None and (not isinstance(owner, str) or not owner.strip()):
        raise SystemExit(2)
    if not all(isinstance(value, str) and value.strip() for value in (status, task_id)):
        raise SystemExit(2)
    owner = owner.strip() if isinstance(owner, str) else ""
    status = status.strip().lower()
    if not owner_matches(owner, role, platform) or status in TASK_TERMINAL_STATUSES:
        continue
    claims.append(task_id.strip())

print(",".join(sorted(set(claims))))
PY
    )
}

reap_attempts() { cat "$REAP_ATTEMPTS_DIR/$1" 2>/dev/null || echo 0; }

candidates=0
held=0

for session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -E "^hapax-(codex-cx-|claude-)"); do
    # Observe every pane. A selected/first-pane-only view can miss the actual
    # worker in another window and is never sufficient for a reap decision.
    mapfile -t pane_pids < <(tmux list-panes -s -t "$session" -F '#{pane_pid}' 2>/dev/null)
    [[ "${#pane_pids[@]}" -gt 0 ]] || continue

    platform=claude
    [[ "$session" == hapax-codex-* ]] && platform=codex
    role="${session#hapax-codex-}"
    role="${role#hapax-claude-}"

    marker_claim="$(claim_for_role "$role" 2>/dev/null || true)"
    task_claims=""
    task_ssot_known=1
    if ! task_claims="$(task_claims_for_role "$role" "$platform" 2>/dev/null)"; then
        task_ssot_known=0
    fi
    claim="$marker_claim"
    if [[ -n "$task_claims" && "$task_claims" != "$marker_claim" ]]; then
        claim="${claim:+$claim,}$task_claims"
    fi

    # Count active processes across the complete process tree of every pane.
    children=0
    for observed_pane_pid in "${pane_pids[@]}"; do
        children=$((children + $(active_process_count "$observed_pane_pid")))
    done

    # Check last output for explicit provider quota/rate-limit walls.
    last_output=$(tmux capture-pane -t "$session" -p 2>/dev/null | grep -v "^$" | tail -3)
    is_stuck=0
    if is_quota_wall_output "$last_output"; then
        is_stuck=1
    fi

    if [[ "$children" -gt 0 && "$is_stuck" -eq 0 ]]; then
        continue  # Active process making progress — skip
    fi

    if [[ "$children" -gt 0 && "$is_stuck" -eq 1 ]]; then
        log "$session: STUCK (quota/rate-limit) — claim detach HOLD task=${claim:-none}"
        held=$((held + 1))
        continue
    fi

    # Dead lane — shell prompt, no worker process. Reap candidacy is governed by the
    # MEASURED per-lineage tau (not a fixed 30m): silence within tau -> skip (slow-but-
    # live); past tau -> reap; past tau with attempts exhausted -> escalate + STOP so a
    # genuinely-wedged lane is surfaced once, never reaped in an infinite loop.
    last_activity=$(tmux display-message -t "$session" -p '#{session_activity}' 2>/dev/null || echo 0)
    now=$(date +%s)
    idle_sec=$(( now - last_activity ))

    attempts=$(reap_attempts "$role")
    decision=$(reap_decide "$role" "$idle_sec" "$attempts")
    case "$decision" in
        skip)
            continue  # silence within tau — not a reap candidate this cycle
            ;;
        escalate)
            log "$session: WEDGED — prior attempts=$attempts; recovery HOLD (projection only)"
            candidates=$((candidates + 1))
            held=$((held + 1))
            continue
            ;;
    esac

    candidates=$((candidates + 1))
    log "$session: DEAD idle ${idle_sec}s (tau-governed recovery candidate)"
    if [[ "$task_ssot_known" -eq 0 ]]; then
        log "  recovery HOLD: task SSOT unreadable; no kill, cleanup, task edit, or claim removal"
    elif [[ -n "$claim" ]]; then
        log "  claim detach HOLD: task=$claim; no kill, cleanup, task edit, or claim removal"
    else
        log "  recovery HOLD: standing effect authority absent; no kill or worktree cleanup"
    fi
    held=$((held + 1))
done

log "Done: candidates=$candidates held=$held"
