#!/usr/bin/env python3
"""Extract prose assertions from CLAUDE.md files, memory, and relay artifacts.

Run: uv run python scripts/extract-prose-assertions [--json] [--summary]
"""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT))

from shared.prose_assertion_extractor import (
    extract_from_directory,
)

MEMORY_DIR = Path.home() / ".claude" / "projects" / "-home-hapax-projects-hapax-council" / "memory"
RELAY_DIR = Path.home() / ".cache" / "hapax" / "relay"


def main() -> None:
    parser = argparse.ArgumentParser(description="Extract prose assertions from markdown sources")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    parser.add_argument("--summary", action="store_true", help="Show summary counts only")
    parser.add_argument(
        "--claude-md-dirs",
        nargs="*",
        default=[str(ROOT)],
        help="Directories to scan for CLAUDE.md files (default: project root)",
    )
    parser.add_argument(
        "--memory-dir",
        default=str(MEMORY_DIR),
        help=f"Memory directory (default: {MEMORY_DIR})",
    )
    parser.add_argument(
        "--relay-dir",
        default=str(RELAY_DIR),
        help=f"Relay directory (default: {RELAY_DIR})",
    )
    parser.add_argument("--skip-claude-md", action="store_true", help="Skip CLAUDE.md extraction")
    parser.add_argument("--skip-memory", action="store_true", help="Skip memory extraction")
    parser.add_argument("--skip-relay", action="store_true", help="Skip relay extraction")
    args = parser.parse_args()

    assertions = []

    if not args.skip_claude_md:
        for dirname in args.claude_md_dirs:
            dirpath = Path(dirname)
            if dirpath.is_dir():
                assertions.extend(extract_from_directory(dirpath, source_kind="claude_md"))

    if not args.skip_memory:
        memory_path = Path(args.memory_dir)
        if memory_path.is_dir():
            assertions.extend(extract_from_directory(memory_path, source_kind="memory"))

    if not args.skip_relay:
        relay_path = Path(args.relay_dir)
        if relay_path.is_dir():
            assertions.extend(extract_from_directory(relay_path, source_kind="relay"))

    if args.summary:
        by_type: dict[str, int] = {}
        by_method: dict[str, int] = {}
        by_source: dict[str, int] = {}
        for a in assertions:
            by_type[a.assertion_type.value] = by_type.get(a.assertion_type.value, 0) + 1
            method = a.provenance.extraction_method
            by_method[method] = by_method.get(method, 0) + 1
            by_source[a.source_type.value] = by_source.get(a.source_type.value, 0) + 1

        print(f"Total assertions: {len(assertions)}")
        print("\nBy type:")
        for t, c in sorted(by_type.items()):
            print(f"  {t}: {c}")
        print("\nBy source:")
        for s, c in sorted(by_source.items()):
            print(f"  {s}: {c}")
        print("\nBy extraction method:")
        for m, c in sorted(by_method.items()):
            print(f"  {m}: {c}")
        return

    if args.json:
        data = [a.model_dump(mode="json") for a in assertions]
        json.dump(data, sys.stdout, indent=2, default=str)
        print()
    else:
        for a in assertions:
            span = f":{a.source_span[0]}-{a.source_span[1]}" if a.source_span else ""
            print(f"[{a.assertion_type.value}] {a.source_uri}{span}")
            print(f"  {a.text[:120]}")
            print()


if __name__ == "__main__":
    main()
