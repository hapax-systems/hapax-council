#!/usr/bin/env bash
# hapax-lane-supervisor — FM-11 lane supervisor (one_for_one re-spawn).
#
# Operator standing mandate: a DEAD lane must ALWAYS auto-restart. Liveness is
# decoupled from task-presence — "idle-await is fine, dead is not".
#
# Clean split (coordination-reform-master-design-2026-05-30 §FM-11, Phase 6,
# CASE-CROSS-RUNTIME-COMMS-001): the *supervisor* guarantees the lane process
# exists; the *dispatcher/launcher* decides what it does. On full local-worker
# hosts, respawning a task-less or quota-walled lane into idle-await is correct,
# not spam — a claimed lane resumes its task; a task-less lane comes up
# read-only and awaits governed dispatch. Appendix/thin-client hosts set
# HAPAX_LOCAL_DEV_MAINTENANCE_MODE=appendix-only, which suppresses unclaimed
# local idle-await respawns while preserving active claimed-task resume.
#
# Coverage spans every runtime (not greek-only):
#   - claude (greek): headless pidfile model at $RUNTIME_DIR/<lane>.pid, OR a
#                     live tmux session hapax-claude-<lane>.
#   - codex  (cx-*):  tmux session hapax-codex-<lane>.
#   - antigrav:       tmux session hapax-antigrav-<lane>.
#
# Spam control mirrors systemd Restart=always + StartLimit: a per-lane restart
# cooldown plus a burst cap over a sliding window.
#
# Runs as a systemd oneshot on a 60s timer (hapax-lane-supervisor.timer).
set -euo pipefail

now="$(date +%s)"

STATE_DIR="${HAPAX_SUPERVISOR_STATE_DIR:-${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/hapax-lane-supervisor}"
RUNTIME_DIR="${HAPAX_SUPERVISOR_RUNTIME_DIR:-/run/user/$(id -u)/hapax-claude}"
WORKTREE_ROOT="${HAPAX_SUPERVISOR_WORKTREE_ROOT:-$HOME/projects}"
VAULT_ROOT="${HAPAX_SUPERVISOR_VAULT_ROOT:-$HOME/Documents/Personal/20-projects/hapax-cc-tasks}"

# Lanes that must stay alive. Greek = non-alpha headless-capable roles (alpha is
# the operator-attended integrator, never auto-respawned); all greek lanes have
# real worktrees (some parked under ~/.claude/worktrees/ — see lane_has_worktree).
#
# Codex/antigrav supervision is OPT-IN (default empty). The prior hardcoded
# defaults (cx-cpu-bridge/cx-effect-drift-current/cx-preset-storm/cx-visual-bandwidth
# and a bare `antigrav`) named lanes with NO git worktree and NO repo references —
# stale entries whose only effect was a permanent rc=4 respawn storm (codex) and
# silent "no worktree — skipping" lines every cycle. The live codex lanes are
# color-named and task-spawned; designating an always-on codex/antigrav roster is
# an operator policy decision (Phase 6 canonical lane registry). Set
# HAPAX_SUPERVISOR_CODEX_LANES / HAPAX_SUPERVISOR_ANTIGRAV_LANES (e.g. a systemd
# drop-in) to supervise specific lanes — a rostered lane that lacks a worktree now
# ESCALATES (below) instead of being silently skipped.
# `${VAR-default}` (not `:-`): an explicitly-set empty roster means "supervise no
# lanes of this kind", not "fall back to the default". Only an UNSET var defaults.
CLAUDE_LANES="${HAPAX_SUPERVISOR_CLAUDE_LANES-beta gamma delta epsilon zeta eta theta}"
CODEX_LANES="${HAPAX_SUPERVISOR_CODEX_LANES-}"
ANTIGRAV_LANES="${HAPAX_SUPERVISOR_ANTIGRAV_LANES-}"

RESTART_COOLDOWN_S="${HAPAX_SUPERVISOR_RESTART_COOLDOWN_S:-120}"
BURST_LIMIT="${HAPAX_SUPERVISOR_BURST_LIMIT:-5}"
BURST_WINDOW_S="${HAPAX_SUPERVISOR_BURST_WINDOW_S:-600}"
LAUNCH_TIMEOUT_S="${HAPAX_SUPERVISOR_LAUNCH_TIMEOUT_S:-60}"
DRY_RUN="${HAPAX_SUPERVISOR_DRY_RUN:-0}"

CLAUDE_HEADLESS_BIN="${HAPAX_CLAUDE_HEADLESS_BIN:-$HOME/.local/bin/hapax-claude-headless}"
CLAUDE_BIN="${HAPAX_CLAUDE_BIN:-$HOME/.local/bin/hapax-claude}"
CODEX_BIN="${HAPAX_CODEX_BIN:-$HOME/.local/bin/hapax-codex}"
ANTIGRAV_BIN="${HAPAX_ANTIGRAV_BIN:-$HOME/.local/bin/hapax-antigrav}"

# ── escalation thresholds (surface chronic failures; never exit-0-silently) ─────
# A lane that respawn-fails this many times in a row, or sits in the roster with no
# worktree for this many sweep cycles, is escalated via ntfy instead of being
# logged-and-forgotten. Re-fires at most once per ESCALATE_REFIRE_S while unhealthy.
ESCALATE_RESPAWN_FAILS="${HAPAX_SUPERVISOR_ESCALATE_RESPAWN_FAILS:-3}"
ESCALATE_MISSING_WORKTREE_CYCLES="${HAPAX_SUPERVISOR_ESCALATE_MISSING_WORKTREE_CYCLES:-10}"
ESCALATE_REFIRE_S="${HAPAX_SUPERVISOR_ESCALATE_REFIRE_S:-3600}"
NOTIFY_CMD="${HAPAX_SUPERVISOR_NOTIFY_CMD:-}"
NTFY_URL="${HAPAX_SUPERVISOR_NTFY_URL:-${NTFY_URL:-https://ntfy.sh}}"
NTFY_TOPIC="${HAPAX_SUPERVISOR_NTFY_TOPIC:-${NTFY_TOPIC:-hapax-ops}}"

# ── progress-watchdog (the stalled-mid-build recovery leg) ────────────────────
# A lane can be process-alive yet make no PROGRESS: the turn ended, nothing
# drives a continuation, so output.jsonl freezes while the slot stays occupied
# in_progress and no PR opens. claude_alive() (the dead-path liveness check) says
# "fine" and skips it — that is the gap this leg fills. Its ntfy uses a distinct
# PROGRESS_NTFY_* endpoint so it never clobbers the escalation NTFY_* above.
CLAUDE_LOG_DIR="${HAPAX_SUPERVISOR_CLAUDE_LOG_DIR:-$HOME/.cache/hapax/claude-headless}"
STALL_T="${HAPAX_SUPERVISOR_STALL_T:-900}"               # output-silence -> stalled (>any quiet build)
RESUME_MAX_ATTEMPTS="${HAPAX_SUPERVISOR_RESUME_MAX_ATTEMPTS:-3}"
RESUME_WINDOW_S="${HAPAX_SUPERVISOR_RESUME_WINDOW_S:-3600}"
RESUME_COOLDOWN_S="${HAPAX_SUPERVISOR_RESUME_COOLDOWN_S:-600}"  # let a resumed lane produce before re-judging
PROGRESS_OFF="${HAPAX_SUPERVISOR_PROGRESS_OFF:-0}"
# Admission state command (DI seam; default is the resource-shielding L3 gate).
ADMISSION_CMD="${HAPAX_SUPERVISOR_ADMISSION_CMD:-python3 -m shared.sdlc_pressure_gate --state}"
METRICS_FILE="${HAPAX_SUPERVISOR_METRICS_FILE:-$HOME/.local/var/lib/node_exporter/textfile_collector/hapax-lane-supervisor.prom}"
PROGRESS_NTFY_URL="${HAPAX_NTFY_URL:-http://localhost:8092}"
PROGRESS_NTFY_TOPIC="${HAPAX_NTFY_TOPIC:-hapax}"

# ── zombie-launcher reaper ────────────────────────────────────────────────────
# A headless launcher can outlive its task: claude reads its stdin from a FIFO
# whose write-end the launcher holds open, so claude never EOFs, the launcher's
# `wait` never returns, and its own task_is_terminal teardown is unreachable. The
# launcher then pins the lane (lifetime flock) and blocks re-dispatch. The
# launcher now self-reaps out-of-band, but (a) launchers deployed before that fix
# and (b) any future wedge need a supervisor-side backstop. This leg SIGTERMs the
# EXACT launcher pid (single positive pid — NEVER a process group, the pinned
# exit-144 cascade) when the lane's task is terminal (gated on admission_state)
# or the launcher exceeds a hard lifetime ceiling (escalate + reap).
REAP_OFF="${HAPAX_SUPERVISOR_REAP_OFF:-0}"
LAUNCHER_MAX_LIFETIME_S="${HAPAX_SUPERVISOR_LAUNCHER_MAX_LIFETIME_S:-21600}"  # 6h

# Repo root for `python3 -m shared.…`. Resolve $0 through the deploy symlink
# (~/.local/bin/…) so REPO_DIR is the release dir that actually ships shared/;
# fall back to the integrator worktree. admission_state fails open regardless.
REPO_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")/.." 2>/dev/null && pwd || true)"
[ -n "$REPO_DIR" ] && [ -d "$REPO_DIR/shared" ] || REPO_DIR="$HOME/projects/hapax-council"

PROGRESS_STALLED_TICK=0  # per-tick gauge: lanes found output-stalled this sweep
mkdir -p "$STATE_DIR"

log() { printf '%s lane-supervisor: %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*"; }

local_dev_maintenance_mode() {
  local mode="${HAPAX_LOCAL_DEV_MAINTENANCE_MODE:-}"
  if [ -z "$mode" ]; then
    mode="${HAPAX_DEFAULT_DISPATCH_HOST:-${HAPAX_DISPATCH_HOST:-local}}"
  fi
  case "$mode" in
    appendix | hapax-appendix | appendix-only | appendix_only | remote | thin-client | thin_client)
      echo "appendix-only"
      ;;
    *)
      echo "local"
      ;;
  esac
}

LOCAL_DEV_MAINTENANCE_MODE="$(local_dev_maintenance_mode)"
if [ "$LOCAL_DEV_MAINTENANCE_MODE" = "appendix-only" ]; then
  log "appendix-only local-dev maintenance: unclaimed idle-await respawns disabled; active claimed-task resumes preserved"
fi

# ── liveness ──────────────────────────────────────────────────────────────────

claude_alive() {
  local lane="$1" pidfile="$RUNTIME_DIR/$1.pid" pid=""
  if [ -f "$pidfile" ]; then
    pid="$(cat "$pidfile" 2>/dev/null || true)"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi
  tmux has-session -t "hapax-claude-$lane" 2>/dev/null
}

tmux_session_alive() { tmux has-session -t "$1" 2>/dev/null; }

# ── spam control ────────────────────────────────────────────────────────────

within_cooldown() {
  local marker="$STATE_DIR/$1.last-restart" last elapsed
  [ -f "$marker" ] || return 1
  last="$(cat "$marker" 2>/dev/null || echo 0)"
  elapsed=$(( now - last ))
  [ "$elapsed" -lt "$RESTART_COOLDOWN_S" ]
}

burst_exhausted() {
  local logf="$STATE_DIR/$1.restart-log" cutoff count=0 ts
  [ -f "$logf" ] || return 1
  cutoff=$(( now - BURST_WINDOW_S ))
  while read -r ts; do
    [ -z "$ts" ] && continue
    [ "$ts" -ge "$cutoff" ] && count=$(( count + 1 ))
  done < "$logf"
  [ "$count" -ge "$BURST_LIMIT" ]
}

record_restart() {
  echo "$now" > "$STATE_DIR/$1.last-restart"
  echo "$now" >> "$STATE_DIR/$1.restart-log"
}

# ── escalation ────────────────────────────────────────────────────────────────

# notify <title> <body>: emit an operator-visible alert. Overridable for tests
# via HAPAX_SUPERVISOR_NOTIFY_CMD; the default posts to ntfy (headless-safe) plus
# a best-effort desktop notification.
notify() {
  local title="$1" body="$2"
  log "ESCALATION — $title: $body"
  if [ -n "$NOTIFY_CMD" ]; then
    "$NOTIFY_CMD" "$title" "$body" || log "notify: NOTIFY_CMD failed"
    return 0
  fi
  if [ -n "$NTFY_TOPIC" ] && command -v curl >/dev/null 2>&1; then
    curl -fsS --max-time 10 \
      -H "Title: $title" -H "Priority: high" -H "Tags: warning,robot" \
      -d "$body" "$NTFY_URL/$NTFY_TOPIC" >/dev/null 2>&1 \
      || log "notify: ntfy POST to $NTFY_URL/$NTFY_TOPIC failed"
  fi
  if [ -x "$REPO_DIR/scripts/hapax-p0-incident-intake" ]; then
    "$REPO_DIR/scripts/hapax-p0-incident-intake" notification \
      --title "$title" \
      --message "$body" \
      --priority urgent \
      --tag skull \
      --technical >/dev/null 2>&1 \
      && return 0
    log "notify: p0 incident intake failed"
  fi
  if command -v notify-send >/dev/null 2>&1; then
    notify-send -u critical "$title" "$body" >/dev/null 2>&1 || true
  fi
}

# bump_streak <lane> <tag>: increment a persisted counter, echo the new value.
bump_streak() {
  local f="$STATE_DIR/$1.$2-streak" v=0
  [ -f "$f" ] && v="$(cat "$f" 2>/dev/null || echo 0)"
  case "$v" in '' | *[!0-9]*) v=0 ;; esac
  v=$(( v + 1 ))
  echo "$v" > "$f"
  printf '%s\n' "$v"
}

# clear_streak <lane> <tag>: reset counter + escalation marker after recovery.
clear_streak() {
  rm -f "$STATE_DIR/$1.$2-streak" "$STATE_DIR/$1.$2-escalated-at" 2>/dev/null || true
}

# escalate <lane> <tag> <title> <body>: notify on first crossing, then at most
# once per ESCALATE_REFIRE_S while the condition persists (avoids per-cycle spam).
escalate() {
  local lane="$1" tag="$2" title="$3" body="$4"
  local marker="$STATE_DIR/$lane.$tag-escalated-at" last=0
  [ -f "$marker" ] && last="$(cat "$marker" 2>/dev/null || echo 0)"
  case "$last" in '' | *[!0-9]*) last=0 ;; esac
  if [ "$(( now - last ))" -lt "$ESCALATE_REFIRE_S" ]; then
    return 0
  fi
  notify "$title" "$body"
  echo "$now" > "$marker"
}

# lane_has_worktree <lane>: true if the lane has a real worktree. Checks the
# configured root first (common case + tests), then any registered git worktree
# (greek lanes can be parked under ~/.claude/worktrees/, not ~/projects/), so a
# live lane is never falsely flagged missing.
lane_has_worktree() {
  local lane="$1"
  [ -d "$WORKTREE_ROOT/hapax-council--$lane" ] && return 0
  if [ "${HAPAX_SUPERVISOR_GIT_WORKTREE_DETECT:-1}" = "1" ] && command -v git >/dev/null 2>&1; then
    local gitdir="${HAPAX_SUPERVISOR_GIT_DIR:-$WORKTREE_ROOT/hapax-council}"
    if [ -d "$gitdir" ] && git -C "$gitdir" worktree list --porcelain 2>/dev/null \
        | grep -qE "^worktree .*/hapax-council--$lane$"; then
      return 0
    fi
  fi
  return 1
}

# Active claim → "task_id<TAB>title", else empty. The claim file names the task;
# the vault note is the authority for status/assignment.
resolve_claimed_task() {
  local lane="$1"
  python3 - "$VAULT_ROOT" "$lane" "$HOME/.cache/hapax/cc-active-task-$lane" <<'PY' 2>/dev/null || true
import re
import sys
from pathlib import Path

vault_root, lane, claim_file = Path(sys.argv[1]), sys.argv[2], Path(sys.argv[3])
if not claim_file.is_file():
    sys.exit(0)
lines = [ln.strip() for ln in claim_file.read_text(errors="replace").splitlines() if ln.strip()]
if not lines:
    sys.exit(0)
task_id = lines[0]

active = vault_root / "active"
note = active / f"{task_id}.md"
if not note.is_file():
    note = next(iter(sorted(active.glob(f"{task_id}-*.md"))), None) if active.is_dir() else None
if note is None or not note.is_file():
    sys.exit(0)

text = note.read_text(errors="replace")

def field(name: str) -> str:
    m = re.search(rf"^{name}:\s*(.+?)\s*$", text, re.MULTILINE)
    return m.group(1).strip().strip('"').strip("'") if m else ""

if field("status") in {"claimed", "in_progress"} and field("assigned_to") == lane:
    print(f"{task_id}\t{field('title')}")
PY
}

# ── respawn ───────────────────────────────────────────────────────────────────

# Fast launchers (hapax-claude --readonly / hapax-codex / hapax-antigrav) create
# a detached tmux session and return promptly, so run them synchronously bounded
# by a timeout. The headless launcher runs a foreground supervise-loop forever,
# so it is the only one backgrounded (setsid + disown).
respawn_sync() {
  local lane="$1"; shift
  local rc=0
  timeout "$LAUNCH_TIMEOUT_S" "$@" >"/tmp/hapax-supervisor-$lane.log" 2>&1 || rc=$?
  if [ "$rc" -ne 0 ]; then
    log "$lane: respawn command exited rc=$rc — see /tmp/hapax-supervisor-$lane.log"
  fi
  return "$rc"
}

# guard <lane> <kind>: ensure the lane process exists; respawn if dead.
guard() {
  local lane="$1" kind="$2" worktree="$WORKTREE_ROOT/hapax-council--$1"
  local task_line task_id title
  task_line="$(resolve_claimed_task "$lane")"
  task_id="${task_line%%	*}"
  title="${task_line#*	}"
  [ "$title" = "$task_line" ] && title=""

  # A rostered lane with no worktree can never be launched. Don't silently skip
  # it forever — count the cycles and escalate once it crosses the threshold, so
  # the operator either provisions the worktree or removes the lane (the roster
  # is then honest). The escalation is the safety net for any future roster drift.
  if ! lane_has_worktree "$lane"; then
    if [ "$LOCAL_DEV_MAINTENANCE_MODE" = "appendix-only" ] && [ -z "$task_id" ]; then
      log "$lane ($kind): no worktree and no active task — appendix-only local-dev maintenance suppresses idle-await respawn"
      return 0
    fi
    local wstreak
    wstreak="$(bump_streak "$lane" no-worktree)"
    log "$lane ($kind): no worktree (configured root $worktree) — skipping (cycle $wstreak)"
    if [ "$wstreak" -ge "$ESCALATE_MISSING_WORKTREE_CYCLES" ]; then
      escalate "$lane" no-worktree \
        "Hapax lane-supervisor: $lane has no worktree" \
        "Rostered $kind lane '$lane' has had no worktree for $wstreak supervisor cycles (~$(( wstreak * 60 ))s). Provision its worktree or drop '$lane' from HAPAX_SUPERVISOR_${kind^^}_LANES."
    fi
    return 0
  fi
  clear_streak "$lane" no-worktree

  case "$kind" in
    claude)   reap_guard "$lane"; if claude_alive "$lane"; then progress_guard "$lane"; return 0; fi ;;
    codex)    tmux_session_alive "hapax-codex-$lane" && return 0 ;;
    antigrav) tmux_session_alive "hapax-antigrav-$lane" && return 0 ;;
  esac

  # Lane is DEAD. It must be respawned regardless of task presence; only spam
  # control (cooldown + burst) may defer a respawn.
  if within_cooldown "$lane"; then
    log "$lane ($kind): DEAD but within restart cooldown — deferring"
    return 0
  fi
  if burst_exhausted "$lane"; then
    log "$lane ($kind): DEAD but restart burst limit reached (StartLimit) — backing off"
    return 0
  fi

  if [ "$LOCAL_DEV_MAINTENANCE_MODE" = "appendix-only" ] && [ -z "$task_id" ]; then
    log "$lane ($kind): DEAD with no active task — appendix-only local-dev maintenance suppresses idle-await respawn"
    return 0
  fi

  if [ "$DRY_RUN" = "1" ]; then
    if [ -n "$task_id" ]; then
      log "$lane ($kind): DEAD — WOULD respawn (resume task $task_id) [dry-run]"
    else
      log "$lane ($kind): DEAD — WOULD respawn into idle-await [dry-run]"
    fi
    return 0
  fi

  # respawn_tracked=1 only for the synchronous launchers whose exit code we can
  # observe; the backgrounded headless resume returns immediately (rc unknowable
  # here) so it is neither counted as a failure nor a recovery.
  local respawn_rc=0 respawn_tracked=0
  case "$kind" in
    claude)
      if [ -n "$task_id" ]; then
        log "$lane ($kind): DEAD with active task $task_id — respawning headless (resume)"
        setsid "$CLAUDE_HEADLESS_BIN" --task "$task_id" "$lane" \
          "Resume your assigned task: $task_id — $title. Ship a PR and cc-close --pr N after merge." \
          >"/tmp/hapax-supervisor-$lane.log" 2>&1 &
        disown
      else
        # Headless launcher is default-deny without a governed task; bring the
        # lane up read-only so the process exists and awaits governed dispatch.
        log "$lane ($kind): DEAD with no active task — respawning read-only (idle-await)"
        respawn_sync "$lane" "$CLAUDE_BIN" --role "$lane" --terminal tmux --readonly || respawn_rc=$?
        respawn_tracked=1
      fi
      ;;
    codex)
      log "$lane ($kind): DEAD — respawning tmux lane (idle-await; lane reads its own claim)"
      respawn_sync "$lane" "$CODEX_BIN" --session "$lane" --no-claim --terminal tmux || respawn_rc=$?
      respawn_tracked=1
      ;;
    antigrav)
      log "$lane ($kind): DEAD — respawning tmux lane (idle-await; lane reads its own claim)"
      respawn_sync "$lane" "$ANTIGRAV_BIN" --session "$lane" --no-claim --terminal tmux || respawn_rc=$?
      respawn_tracked=1
      ;;
  esac

  record_restart "$lane"

  # A respawn that keeps failing (e.g. codex-not-found rc=4) is a chronic crash
  # loop the cooldown can never cure — escalate after N consecutive failures
  # instead of returning exit 0 forever.
  if [ "$respawn_tracked" = "1" ]; then
    if [ "$respawn_rc" -ne 0 ]; then
      local fstreak
      fstreak="$(bump_streak "$lane" respawn-fail)"
      if [ "$fstreak" -ge "$ESCALATE_RESPAWN_FAILS" ]; then
        escalate "$lane" respawn-fail \
          "Hapax lane-supervisor: $lane respawn failing" \
          "$kind lane '$lane' failed to respawn $fstreak consecutive times (last rc=$respawn_rc) — chronically DOWN. See /tmp/hapax-supervisor-$lane.log."
      fi
    else
      clear_streak "$lane" respawn-fail
    fi
  fi
}

# ── progress-watchdog (alive-but-output-stalled recovery) ─────────────────────

# A launcher (hapax-claude-headless) holds a lifetime flock + names its pid at
# $RUNTIME_DIR/<lane>.launcher.pid. "live launcher" = that pid is alive. The
# supervisor's claude_alive() keys on the *claude* pid instead, so a lane whose
# launcher died (orphaned claude) — or whose launcher is alive but wedged after a
# completed turn — slips through. Recovery splits on launcher liveness:
#   dead  -> re-launch headless (flock-free, fresh, resumes from worktree)
#   alive -> nudge the live launcher's stdin fifo (its own injection mechanism;
#            a re-launch would flock-fail). Both resume the SAME task.
launcher_alive() {
  local lpf="$RUNTIME_DIR/$1.launcher.pid" pid=""
  [ -f "$lpf" ] || return 1
  pid="$(cat "$lpf" 2>/dev/null || true)"
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

# Seconds since output.jsonl was last written; returns 1 (no echo) if absent
# (interactive/tmux lanes have none — naturally excluded).
output_age() {
  local oj="$CLAUDE_LOG_DIR/$1/output.jsonl" mt=""
  [ -f "$oj" ] || return 1
  mt="$(stat -c %Y "$oj" 2>/dev/null || true)"
  [ -n "$mt" ] || return 1
  echo $(( now - mt ))
}

# Admission state via the resource-shielding L3 gate (fail-open to "open" so the
# floor never wedges on the gate). 'closed' -> defer (queue, never drop).
admission_state() {
  [ "${HAPAX_SDLC_PRESSURE_GATE_OFF:-}" = "1" ] && { echo open; return; }
  local out=""
  out="$( cd "$REPO_DIR" 2>/dev/null; bash -c "$ADMISSION_CMD" 2>/dev/null || true )"
  case "$out" in
    open|paced|closed) echo "$out" ;;
    *) echo open ;;
  esac
}

# task_id<TAB>status<TAB>title for the lane's active claim (any status), else
# empty. The claim names the task; the vault note is authority for status.
resolve_task_meta() {
  python3 - "$VAULT_ROOT" "$1" "$HOME/.cache/hapax/cc-active-task-$1" <<'PY' 2>/dev/null || true
import re
import sys
from pathlib import Path

vault_root, lane, claim_file = Path(sys.argv[1]), sys.argv[2], Path(sys.argv[3])
if not claim_file.is_file():
    sys.exit(0)
lines = [ln.strip() for ln in claim_file.read_text(errors="replace").splitlines() if ln.strip()]
if not lines:
    sys.exit(0)
task_id = lines[0]

active = vault_root / "active"
note = active / f"{task_id}.md"
if not note.is_file():
    note = next(iter(sorted(active.glob(f"{task_id}-*.md"))), None) if active.is_dir() else None
if note is None or not note.is_file():
    sys.exit(0)

text = note.read_text(errors="replace")


def field(name: str) -> str:
    m = re.search(rf"^{name}:\s*(.+?)\s*$", text, re.MULTILINE)
    return m.group(1).strip().strip('"').strip("'") if m else ""


if field("assigned_to") == lane:
    print(f"{task_id}\t{field('status')}\t{field('title')}")
PY
}

# Per-(lane,task) attempt accounting in a sliding window + a post-resume cooldown
# (so a freshly-resumed lane is given time to produce output before re-judging).
_resume_log() { printf '%s/%s.%s.resume-log' "$STATE_DIR" "$1" "${2//\//_}"; }

progress_attempts_count() {
  local logf cutoff count=0 ts
  logf="$(_resume_log "$1" "$2")"
  [ -f "$logf" ] || { echo 0; return; }
  cutoff=$(( now - RESUME_WINDOW_S ))
  while read -r ts; do
    [ -n "$ts" ] || continue
    if [ "$ts" -ge "$cutoff" ]; then count=$(( count + 1 )); fi
  done < "$logf"
  echo "$count"
}

record_progress_attempt() { echo "$now" >> "$(_resume_log "$1" "$2")"; }
reset_progress_attempts() { rm -f "$(_resume_log "$1" "$2")" 2>/dev/null || true; }

progress_within_cooldown() {
  local marker="$STATE_DIR/$1.last-resume" last elapsed
  [ -f "$marker" ] || return 1
  last="$(cat "$marker" 2>/dev/null || echo 0)"
  elapsed=$(( now - last ))
  [ "$elapsed" -lt "$RESUME_COOLDOWN_S" ]
}
record_progress_resume() { echo "$now" > "$STATE_DIR/$1.last-resume"; }

bump_counter() {
  local f="$STATE_DIR/$1" n
  n="$(cat "$f" 2>/dev/null || echo 0)"
  echo $(( n + 1 )) > "$f"
}

progress_resume_prompt() {
  printf 'Resume %s — you went silent and stalled; continue from your worktree (commit incrementally so progress is never lost); if a sub-part blocks, log it and ship the tractable part to a landed PR.' "$1"
}

# Inject a stream-json user message into a live launcher's stdin fifo (exactly
# what the launcher itself does to restart a turn). Timeout-bounded so a missing
# reader never wedges the oneshot; non-zero -> caller retries next tick.
fifo_nudge() {
  local fifo="$RUNTIME_DIR/$1.stdin" json
  [ -p "$fifo" ] || { log "$1: no stdin fifo at $fifo — cannot nudge live launcher"; return 1; }
  json="$(progress_resume_prompt "$2" | python3 -c 'import sys, json; print(json.dumps({"type":"user","message":{"role":"user","content":[{"type":"text","text":sys.stdin.read()}]}}, separators=(",", ":")))' 2>/dev/null || true)"
  [ -n "$json" ] || return 1
  timeout 5 bash -c 'printf "%s\n" "$1" > "$2"' _ "$json" "$fifo"
}

# Exhaustion path: revert the task to offered+unassigned (re-dispatchable
# elsewhere) and clear the lane's claim slot so the lane stands down.
reoffer_task() {
  python3 - "$VAULT_ROOT" "$2" <<'PY' 2>/dev/null || true
import re
import sys
from pathlib import Path

vault, task = Path(sys.argv[1]), sys.argv[2]
active = vault / "active"
note = active / f"{task}.md"
if not note.is_file():
    cands = sorted(active.glob(f"{task}-*.md")) if active.is_dir() else []
    note = cands[0] if cands else None
if note is not None and note.is_file():
    t = note.read_text(errors="replace")
    t = re.sub(r"^status:.*$", "status: offered", t, count=1, flags=re.MULTILINE)
    t = re.sub(r"^assigned_to:.*$", "assigned_to: unassigned", t, count=1, flags=re.MULTILINE)
    note.write_text(t)
PY
  : > "$HOME/.cache/hapax/cc-active-task-$1" 2>/dev/null || true
}

progress_ntfy() {
  curl -sf -d "Lane progress watchdog: lane $1 stalled on $2 — $3" \
    -H "Title: Lane resume exhausted" -H "Priority: high" -H "Tags: warning,robot" \
    "$PROGRESS_NTFY_URL/$PROGRESS_NTFY_TOPIC" >/dev/null 2>&1 || true
}

emit_progress_metrics() {
  [ -n "$METRICS_FILE" ] || return 0
  local resumed exhausted reaped dir
  resumed="$(cat "$STATE_DIR/lanes_resumed_total" 2>/dev/null || echo 0)"
  exhausted="$(cat "$STATE_DIR/resume_exhausted_total" 2>/dev/null || echo 0)"
  reaped="$(cat "$STATE_DIR/launchers_reaped_total" 2>/dev/null || echo 0)"
  dir="$(dirname "$METRICS_FILE")"
  mkdir -p "$dir" 2>/dev/null || return 0
  {
    printf '# HELP hapax_lane_supervisor_lanes_stalled Lanes detected output-stalled this tick\n'
    printf '# TYPE hapax_lane_supervisor_lanes_stalled gauge\n'
    printf 'hapax_lane_supervisor_lanes_stalled %s\n' "$PROGRESS_STALLED_TICK"
    printf '# HELP hapax_lane_supervisor_lanes_resumed_total Cumulative lane progress resumes\n'
    printf '# TYPE hapax_lane_supervisor_lanes_resumed_total counter\n'
    printf 'hapax_lane_supervisor_lanes_resumed_total %s\n' "$resumed"
    printf '# HELP hapax_lane_supervisor_resume_exhausted_total Cumulative resume-exhaustion reoffers\n'
    printf '# TYPE hapax_lane_supervisor_resume_exhausted_total counter\n'
    printf 'hapax_lane_supervisor_resume_exhausted_total %s\n' "$exhausted"
    printf '# HELP hapax_lane_supervisor_launchers_reaped_total Cumulative zombie launchers reaped\n'
    printf '# TYPE hapax_lane_supervisor_launchers_reaped_total counter\n'
    printf 'hapax_lane_supervisor_launchers_reaped_total %s\n' "$reaped"
  } > "$METRICS_FILE.tmp" 2>/dev/null && mv "$METRICS_FILE.tmp" "$METRICS_FILE" 2>/dev/null || true
}

# progress_guard <lane>: for an ALIVE claude lane, detect output-stall and resume
# it on its same task. Bounded by attempts + cooldown + pressure; reoffers + ntfys
# on exhaustion. No-op for fresh/idle/non-in_progress lanes (AC2).
progress_guard() {
  local lane="$1"
  [ "$PROGRESS_OFF" = "1" ] && return 0

  local age
  age="$(output_age "$lane")" || return 0      # no output.jsonl -> not a progress-stall
  [ "$age" -gt "$STALL_T" ] || return 0         # fresh output -> genuinely working (AC2)

  local meta task status title
  meta="$(resolve_task_meta "$lane")"
  [ -n "$meta" ] || return 0
  task="$(printf '%s' "$meta" | cut -f1)"
  status="$(printf '%s' "$meta" | cut -f2)"
  title="$(printf '%s' "$meta" | cut -f3)"
  # Only mid-build (in_progress) stalls; pr_open/claimed/merge_queue are not it.
  [ "$status" = "in_progress" ] || return 0

  PROGRESS_STALLED_TICK=$(( PROGRESS_STALLED_TICK + 1 ))
  log "$lane: PROGRESS-STALL — task $task in_progress, output stale ${age}s (>${STALL_T}s)"

  local adm
  adm="$(admission_state)"
  if [ "$adm" = "closed" ]; then
    log "$lane: sdlc-pressure CLOSED — deferring resume (queued; retries next tick, never dropped)"
    return 0
  fi

  if progress_within_cooldown "$lane"; then
    log "$lane: within resume cooldown (${RESUME_COOLDOWN_S}s) — letting the prior resume settle"
    return 0
  fi

  local attempts
  attempts="$(progress_attempts_count "$lane" "$task")"
  if [ "$attempts" -ge "$RESUME_MAX_ATTEMPTS" ]; then
    if [ "$DRY_RUN" = "1" ]; then
      log "$lane: resume EXHAUSTED ($attempts/$RESUME_MAX_ATTEMPTS) — WOULD reoffer $task + ntfy [dry-run]"
      return 0
    fi
    log "$lane: resume EXHAUSTED ($attempts/$RESUME_MAX_ATTEMPTS) — reoffering $task (offered+unassigned) + ntfy"
    reoffer_task "$lane" "$task"
    progress_ntfy "$lane" "$task" "auto-resume exhausted after $attempts attempts; reverted to offered+unassigned"
    reset_progress_attempts "$lane" "$task"
    bump_counter resume_exhausted_total
    return 0
  fi

  if [ "$DRY_RUN" = "1" ]; then
    if launcher_alive "$lane"; then
      log "$lane: WOULD nudge live launcher to resume $task ($title) [dry-run]"
    else
      log "$lane: WOULD re-launch headless to resume $task ($title) [dry-run]"
    fi
    return 0
  fi

  record_progress_attempt "$lane" "$task"
  record_progress_resume "$lane"
  if launcher_alive "$lane"; then
    log "$lane: live launcher stalled — nudging stdin fifo to resume $task"
    fifo_nudge "$lane" "$task" || log "$lane: fifo nudge failed (no reader?) — retrying next tick"
  else
    log "$lane: no live launcher — re-launching headless (resume $task from worktree)"
    setsid "$CLAUDE_HEADLESS_BIN" --task "$task" "$lane" "$(progress_resume_prompt "$task")" \
      >"/tmp/hapax-supervisor-progress-$lane.log" 2>&1 &
    disown
  fi
  bump_counter lanes_resumed_total
}

# ── zombie-launcher reaper (terminal-task + lifetime ceiling) ─────────────────

# launcher_pid <lane>: echo the lane's LIVE launcher pid, or return 1 if there is
# no live launcher. (launcher_alive returns only a boolean; the reaper needs the
# pid value to target the SIGTERM.)
launcher_pid() {
  local lpf="$RUNTIME_DIR/$1.launcher.pid" pid=""
  [ -f "$lpf" ] || return 1
  pid="$(cat "$lpf" 2>/dev/null || true)"
  case "$pid" in '' | *[!0-9]*) return 1 ;; esac
  kill -0 "$pid" 2>/dev/null || return 1
  printf '%s\n' "$pid"
}

# launcher_etimes <pid>: elapsed seconds since the launcher started, or return 1
# if unknowable.
launcher_etimes() {
  local et=""
  et="$(ps -o etimes= -p "$1" 2>/dev/null | tr -d ' ' || true)"
  case "$et" in '' | *[!0-9]*) return 1 ;; esac
  printf '%s\n' "$et"
}

# launcher_task_terminal <lane>: 0 if the lane's claimed task is terminal (note
# left active/, terminal status, or its PR merged), 1 if still live or no claim.
# Mirrors the launcher's own task_is_terminal so supervisor and launcher agree on
# when a headless lane should stop.
launcher_task_terminal() {
  python3 - "$VAULT_ROOT" "$1" "$HOME/.cache/hapax/cc-active-task-$1" 2>/dev/null <<'PY'
import re
import subprocess
import sys
from pathlib import Path

vault_root, lane, claim_file = Path(sys.argv[1]), sys.argv[2], Path(sys.argv[3])
# No claim -> not terminal on task grounds (the lifetime ceiling covers a
# claimless launcher); mirror the launcher's "no task binding -> live".
if not claim_file.is_file():
    sys.exit(1)
lines = [ln.strip() for ln in claim_file.read_text(errors="replace").splitlines() if ln.strip()]
if not lines:
    sys.exit(1)
task_id = lines[0]
active = vault_root / "active"
note = active / f"{task_id}.md"
if not note.is_file():
    cands = sorted(active.glob(f"{task_id}-*.md")) if active.is_dir() else []
    note = cands[0] if cands else None
# Claim names a task but its note is no longer in active/ -> closed -> terminal.
if note is None or not note.is_file():
    sys.exit(0)
text = note.read_text(errors="replace")


def field(name: str) -> str:
    m = re.search(rf"^{name}:\s*(.+?)\s*$", text, re.MULTILINE)
    return m.group(1).strip().strip('"').strip("'") if m else ""


if field("status") in {"done", "completed", "closed", "withdrawn", "superseded"}:
    sys.exit(0)
pr = field("pr")
if pr.isdigit():
    try:
        out = subprocess.run(
            ["gh", "pr", "view", pr, "--json", "state", "--jq", ".state"],
            capture_output=True,
            text=True,
            timeout=10,
        ).stdout.strip()
        if out == "MERGED":
            sys.exit(0)
    except Exception:
        pass
sys.exit(1)
PY
}

# reap_launcher <lane> <pid> <reason>: SIGTERM the EXACT launcher pid. A single
# POSITIVE pid only — NEVER a process group / negative pid (`kill -- -PGID`): the
# exit-144 group-kill cascade that took down sibling lanes is pinned here. The
# launcher's own EXIT trap reaps its fifo + lock; closing its FIFO write-end EOFs
# the claude child, which exits. The next sweep brings the lane back read-only
# into idle-await.
reap_launcher() {
  local lane="$1" pid="$2" reason="$3"
  if [ "$DRY_RUN" = "1" ]; then
    log "$lane: WOULD reap launcher pid=$pid ($reason) [dry-run]"
    return 0
  fi
  log "$lane: reaping launcher pid=$pid ($reason) — SIGTERM (single pid)"
  kill -TERM "$pid" 2>/dev/null || log "$lane: SIGTERM pid=$pid failed (already gone?)"
  bump_counter launchers_reaped_total
}

# reap_guard <lane>: reap a zombie headless launcher that has outlived its task.
# Two triggers: (1) the claimed task is terminal (closed/merged) — gated on
# admission_state so a pressure-closed window defers (queued, retried next tick);
# (2) a hard lifetime ceiling — pathological regardless of task, escalate + reap.
reap_guard() {
  local lane="$1"
  [ "$REAP_OFF" = "1" ] && return 0
  local pid
  pid="$(launcher_pid "$lane")" || return 0   # no live launcher -> nothing to reap

  local age
  if age="$(launcher_etimes "$pid")" && [ "$age" -ge "$LAUNCHER_MAX_LIFETIME_S" ]; then
    escalate "$lane" launcher-lifetime \
      "Hapax lane-supervisor: $lane launcher over lifetime ceiling" \
      "Headless launcher pid=$pid for lane '$lane' has run ${age}s (>=${LAUNCHER_MAX_LIFETIME_S}s) — reaping (SIGTERM, single pid)."
    reap_launcher "$lane" "$pid" "lifetime-ceiling ${age}s"
    return 0
  fi

  launcher_task_terminal "$lane" || return 0  # task still live -> keep the launcher

  local adm
  adm="$(admission_state)"
  if [ "$adm" = "closed" ]; then
    log "$lane: terminal-task launcher pid=$pid — sdlc-pressure CLOSED, deferring reap (retries next tick)"
    return 0
  fi
  reap_launcher "$lane" "$pid" "terminal-task"
}

# ── sweep ─────────────────────────────────────────────────────────────────────

for lane in $CLAUDE_LANES;   do guard "$lane" claude;   done
for lane in $CODEX_LANES;    do guard "$lane" codex;     done
for lane in $ANTIGRAV_LANES; do guard "$lane" antigrav;  done

emit_progress_metrics

exit 0
