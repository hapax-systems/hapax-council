#!/usr/bin/env bash
# hapax-lane-supervisor - projection-only lane health diagnostics.
#
# This timer-driven surface observes configured Claude and Codex lanes. It may
# report dead lanes, stale output, missing worktrees, and launcher detach
# candidates, but it has no authority to launch, resume, signal, reassign, or
# clear anything. Every recovery candidate remains on HOLD for a separately
# governed, single-use effect mechanism.

set -euo pipefail

SCRIPT_VERSION=3
now="$(date +%s)"

RUNTIME_DIR="${HAPAX_SUPERVISOR_RUNTIME_DIR:-/run/user/$(id -u)/hapax-claude}"
WORKTREE_ROOT="${HAPAX_SUPERVISOR_WORKTREE_ROOT:-$HOME/projects}"
VAULT_ROOT="${HAPAX_SUPERVISOR_VAULT_ROOT:-$HOME/Documents/Personal/20-projects/hapax-cc-tasks}"
CLAIM_CACHE_DIR="${HAPAX_SUPERVISOR_CLAIM_CACHE_DIR:-$HOME/.cache/hapax}"
CLAUDE_LOG_DIR="${HAPAX_SUPERVISOR_CLAUDE_LOG_DIR:-$HOME/.cache/hapax/claude-headless}"
METRICS_FILE="${HAPAX_SUPERVISOR_METRICS_FILE:-$HOME/.local/var/lib/node_exporter/textfile_collector/hapax-lane-supervisor.prom}"

# An explicitly empty roster remains empty. Codex supervision is opt-in.
CLAUDE_LANES="${HAPAX_SUPERVISOR_CLAUDE_LANES-beta gamma delta epsilon zeta eta theta}"
CODEX_LANES="${HAPAX_SUPERVISOR_CODEX_LANES-}"
ANTIGRAV_LANES="${HAPAX_SUPERVISOR_ANTIGRAV_LANES-}"

STALL_T="${HAPAX_SUPERVISOR_STALL_T:-900}"
LAUNCHER_MAX_LIFETIME_S="${HAPAX_SUPERVISOR_LAUNCHER_MAX_LIFETIME_S:-21600}"
PROGRESS_OFF="${HAPAX_SUPERVISOR_PROGRESS_OFF:-0}"
REAP_OFF="${HAPAX_SUPERVISOR_REAP_OFF:-0}"
PROC_SCAN_LAUNCHERS="${HAPAX_SUPERVISOR_PROC_SCAN_LAUNCHERS:-1}"

RECOVERY_CANDIDATES=0
STALL_CANDIDATES=0
DETACH_CANDIDATES=0
CONFIGURATION_CANDIDATES=0
SCAN_ERRORS=0

log() { printf '%s lane-supervisor: %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*"; }

usage() {
  cat <<'EOF'
Usage: hapax-lane-supervisor [--dry-run] [--version] [--help]

Project configured lane health without launching, resuming, signaling, or
changing task/claim ownership. --dry-run is retained as a compatibility flag;
the supervisor is always read-only.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --dry-run) shift ;;
    --version)
      printf 'hapax-lane-supervisor v%s (projection-only)\n' "$SCRIPT_VERSION"
      exit 0
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf 'hapax-lane-supervisor: unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 64
      ;;
  esac
done

if [ -n "$ANTIGRAV_LANES" ]; then
  log "HAPAX_SUPERVISOR_ANTIGRAV_LANES is retired; antigrav/agy is not admitted live supply"
fi

case "${HAPAX_LOCAL_DEV_MAINTENANCE_MODE:-}" in
  appendix|hapax-appendix|appendix-only|appendix_only|remote|thin-client|thin_client)
    log "appendix-only local-dev maintenance observed; projection semantics are unchanged"
    ;;
esac

REPO_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")")/.." 2>/dev/null && pwd || true)"
if [ -z "$REPO_DIR" ] || [ ! -d "$REPO_DIR/shared" ]; then
  printf 'hapax-lane-supervisor: activated source root unavailable: %s\n' "${REPO_DIR:-<unknown>}" >&2
  exit 78
fi

lane_has_worktree() {
  local lane="$1"
  [ -d "$WORKTREE_ROOT/hapax-council--$lane" ] && return 0
  if [ "${HAPAX_SUPERVISOR_GIT_WORKTREE_DETECT:-1}" = "1" ] && command -v git >/dev/null 2>&1; then
    local gitdir="${HAPAX_SUPERVISOR_GIT_DIR:-$WORKTREE_ROOT/hapax-council}"
    if [ -d "$gitdir" ] && git -C "$gitdir" worktree list --porcelain 2>/dev/null \
        | grep -qE "^worktree .*/hapax-council--$lane$"; then
      return 0
    fi
  fi
  return 1
}

pid_is_observed() {
  local pid="$1"
  case "$pid" in
    ''|*[!0-9]*) return 1 ;;
  esac
  [ "$pid" -gt 1 ] 2>/dev/null || return 1
  ps -p "$pid" -o pid= >/dev/null 2>&1
}

tmux_session_observed() {
  tmux has-session -t "$1" 2>/dev/null
}

claude_process_observed() {
  local lane="$1" pid=""
  if [ -f "$RUNTIME_DIR/$lane.pid" ]; then
    pid="$(sed -n '1p' "$RUNTIME_DIR/$lane.pid" 2>/dev/null || true)"
    pid_is_observed "$pid" && return 0
  fi
  tmux_session_observed "hapax-claude-$lane"
}

launcher_pid_from_proc() {
  local lane="$1"
  [ "$PROC_SCAN_LAUNCHERS" = "1" ] || return 1
  python3 - "$lane" <<'PY'
import os
import sys
from pathlib import Path

lane = sys.argv[1]
for proc in sorted(Path("/proc").glob("[0-9]*"), key=lambda path: int(path.name)):
    try:
        raw = (proc / "cmdline").read_bytes()
    except OSError:
        continue
    argv = [part.decode(errors="replace") for part in raw.split(b"\0") if part]
    if not argv:
        continue
    if Path(argv[0]).name != "hapax-claude-headless":
        continue
    if "--task" not in argv or lane not in argv:
        continue
    print(proc.name)
    raise SystemExit(0)
raise SystemExit(1)
PY
}

launcher_pid() {
  local lane="$1" pid=""
  if [ -f "$RUNTIME_DIR/$lane.launcher.pid" ]; then
    pid="$(sed -n '1p' "$RUNTIME_DIR/$lane.launcher.pid" 2>/dev/null || true)"
    if pid_is_observed "$pid"; then
      printf '%s\n' "$pid"
      return 0
    fi
  fi
  launcher_pid_from_proc "$lane"
}

launcher_age() {
  local pid="$1" age=""
  age="$(ps -o etimes= -p "$pid" 2>/dev/null | tr -d '[:space:]' || true)"
  case "$age" in
    ''|*[!0-9]*) return 1 ;;
  esac
  printf '%s\n' "$age"
}

output_age() {
  local output="$CLAUDE_LOG_DIR/$1/output.jsonl" mtime="" age=0
  [ -f "$output" ] || return 1
  mtime="$(stat -c %Y "$output" 2>/dev/null || true)"
  case "$mtime" in
    ''|*[!0-9]*) return 1 ;;
  esac
  age=$((now - mtime))
  [ "$age" -ge 0 ] || age=0
  printf '%s\n' "$age"
}

# Emit one TSV row per authoritative, nonterminal task owned by the lane:
# task_id, status, pr, title. Any malformed active note makes the complete task
# projection unknown, which is reported as a diagnostic HOLD by the caller.
task_projection_for_lane() {
  local lane="$1"
  local platform="$2"
  (cd "$REPO_DIR" 2>/dev/null && python3 - "$VAULT_ROOT/active" "$lane" "$platform" <<'PY'
import re
import sys
from pathlib import Path

from shared.sdlc_lifecycle import TASK_TERMINAL_STATUSES
from shared.sdlc_owner_identity import owner_matches
from shared.strict_yaml import strict_safe_load

active = Path(sys.argv[1])
lane = sys.argv[2]
platform = sys.argv[3]
if not active.is_dir():
    print(f"task store unavailable: {active}", file=sys.stderr)
    raise SystemExit(2)

records: list[tuple[str, str, str, str]] = []
seen: set[str] = set()
try:
    paths = sorted(active.glob("*.md"))
except OSError as exc:
    print(f"task store scan failed: {exc}", file=sys.stderr)
    raise SystemExit(2)

for path in paths:
    try:
        text = path.read_text(encoding="utf-8")
        if not text.startswith("---"):
            raise ValueError("missing frontmatter")
        parts = text.split("---", 2)
        if len(parts) < 3:
            raise ValueError("unclosed frontmatter")
        data = strict_safe_load(parts[1])
        if not isinstance(data, dict):
            raise ValueError("frontmatter is not a mapping")
        task_id = data.get("task_id")
        status = data.get("status")
        owner = data.get("assigned_to")
        if not isinstance(task_id, str) or not task_id.strip():
            raise ValueError("task_id must be a non-empty string")
        if not isinstance(status, str) or not status.strip():
            raise ValueError("status must be a non-empty string")
        if owner is not None and (not isinstance(owner, str) or not owner.strip()):
            raise ValueError("assigned_to must be null or a non-empty string")
        task_id = task_id.strip()
        if task_id in seen:
            raise ValueError(f"duplicate active task_id {task_id}")
        seen.add(task_id)
        status = status.strip().lower()
        owner = owner.strip() if isinstance(owner, str) else ""
        if not owner_matches(owner, lane, platform) or status in TASK_TERMINAL_STATUSES:
            continue
        pr_value = data.get("pr")
        if pr_value is None:
            pr = "null"
        elif isinstance(pr_value, (str, int)) and not isinstance(pr_value, bool):
            pr = str(pr_value).strip() or "null"
        else:
            raise ValueError("pr must be null, a string, or an integer")
        title_value = data.get("title", "")
        if title_value is not None and not isinstance(title_value, str):
            raise ValueError("title must be a string")
        title = re.sub(r"\s+", " ", title_value or "").strip()
        records.append((task_id, status, pr, title))
    except (OSError, TypeError, ValueError) as exc:
        print(f"{path}: {exc}", file=sys.stderr)
        raise SystemExit(2)

for record in sorted(records):
    print("\t".join(record))
PY
  )
}

marker_claims_for_lane() {
  local lane="$1" claim_file task claims=""
  local files=()
  shopt -s nullglob
  files=(
    "$CLAIM_CACHE_DIR/cc-active-task-$lane"
    "$CLAIM_CACHE_DIR/cc-active-task-$lane-"*
  )
  shopt -u nullglob
  for claim_file in "${files[@]}"; do
    [ -f "$claim_file" ] || continue
    task="$(sed -n '1p' "$claim_file" 2>/dev/null | tr -d '[:space:]' || true)"
    [ -n "$task" ] || continue
    case ",$claims," in
      *",$task,"*) ;;
      *) claims="${claims:+$claims,}$task" ;;
    esac
  done
  printf '%s\n' "$claims"
}

task_ids_from_projection() {
  local projection="$1" line task ids=""
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    task="${line%%$'\t'*}"
    ids="${ids:+$ids,}$task"
  done <<< "$projection"
  printf '%s\n' "$ids"
}

project_stale_output() {
  local lane="$1" projection="$2" age="" task status pr _title
  [ "$PROGRESS_OFF" = "1" ] && return 0
  age="$(output_age "$lane")" || return 0
  [ "$age" -gt "$STALL_T" ] || return 0

  while IFS=$'\t' read -r task status pr _title; do
    [ -n "$task" ] || continue
    [ "$status" = "in_progress" ] || continue
    STALL_CANDIDATES=$((STALL_CANDIDATES + 1))
    log "$lane: STALL_CANDIDATE task=$task status=$status output_age_s=$age threshold_s=$STALL_T pr=${pr:-null} action=HOLD"
    log "  no resume, prompt injection, task rewrite, or claim cleanup; governed recovery authority required"
  done <<< "$projection"
}

project_launcher_detach() {
  local lane="$1" projection="$2" marker_claims="$3" task_ssot_known="$4"
  local pid="" age="" task_ids=""
  [ "$REAP_OFF" = "1" ] && return 0
  pid="$(launcher_pid "$lane")" || return 0

  if age="$(launcher_age "$pid")" && [ "$age" -ge "$LAUNCHER_MAX_LIFETIME_S" ]; then
    DETACH_CANDIDATES=$((DETACH_CANDIDATES + 1))
    log "$lane: DETACH_CANDIDATE pid=$pid reason=lifetime_projection age_s=$age ceiling_s=$LAUNCHER_MAX_LIFETIME_S action=HOLD"
    log "  no signal or ownership change; elapsed age is diagnostic evidence only"
  fi

  task_ids="$(task_ids_from_projection "$projection")"
  if [ "$task_ssot_known" = "0" ]; then
    DETACH_CANDIDATES=$((DETACH_CANDIDATES + 1))
    log "$lane: DETACH_CANDIDATE pid=$pid reason=task_ssot_unknown observed_claims=${marker_claims:-none} action=HOLD"
    log "  no signal or ownership change; authoritative task state is unavailable"
  elif [ -n "$marker_claims" ] && [ -z "$task_ids" ]; then
    DETACH_CANDIDATES=$((DETACH_CANDIDATES + 1))
    log "$lane: DETACH_CANDIDATE pid=$pid reason=claim_note_incoherent observed_claims=$marker_claims action=HOLD"
    log "  no signal, task rewrite, or claim cleanup; incoherence cannot authorize detachment"
  fi
}

scan_lane() {
  local lane="$1" kind="$2" projection="" task_ssot_known=1 scan_detail=""
  local task_ids="" marker_claims="" observed=0

  if projection="$(task_projection_for_lane "$lane" "$kind" 2>&1)"; then
    task_ssot_known=1
  else
    task_ssot_known=0
    scan_detail="$projection"
    projection=""
    SCAN_ERRORS=$((SCAN_ERRORS + 1))
    log "$lane ($kind): TASK_SSOT_UNKNOWN action=HOLD detail=${scan_detail//$'\n'/; }"
  fi
  task_ids="$(task_ids_from_projection "$projection")"
  marker_claims="$(marker_claims_for_lane "$lane")"

  if ! lane_has_worktree "$lane"; then
    CONFIGURATION_CANDIDATES=$((CONFIGURATION_CANDIDATES + 1))
    log "$lane ($kind): CONFIGURATION_CANDIDATE reason=missing_worktree expected=$WORKTREE_ROOT/hapax-council--$lane action=HOLD"
  fi

  case "$kind" in
    claude)
      if launcher_pid "$lane" >/dev/null 2>&1 || claude_process_observed "$lane"; then
        observed=1
      fi
      ;;
    codex)
      if tmux_session_observed "hapax-codex-$lane"; then
        observed=1
      fi
      ;;
  esac

  if [ "$observed" = "1" ]; then
    log "$lane ($kind): PROCESS_OBSERVED tasks=${task_ids:-none} marker_claims=${marker_claims:-none}"
    if [ "$kind" = "claude" ]; then
      project_stale_output "$lane" "$projection"
      project_launcher_detach "$lane" "$projection" "$marker_claims" "$task_ssot_known"
    fi
    return 0
  fi

  RECOVERY_CANDIDATES=$((RECOVERY_CANDIDATES + 1))
  log "$lane ($kind): RECOVERY_CANDIDATE state=not_observed tasks=${task_ids:-unknown} marker_claims=${marker_claims:-none} action=HOLD"
  if [ "$task_ssot_known" = "0" ]; then
    log "  recovery HOLD: task SSOT unreadable; no launch, task edit, claim cleanup, or ownership detachment"
  elif [ -n "$task_ids" ] || [ -n "$marker_claims" ]; then
    log "  claim detach HOLD: observed ownership remains intact; governed recovery authority required"
  else
    log "  recovery HOLD: standing effect authority absent; no lane launch or replacement"
  fi
}

emit_metrics() {
  [ -n "$METRICS_FILE" ] || return 0
  local dir tmp
  dir="$(dirname "$METRICS_FILE")"
  tmp="$METRICS_FILE.tmp.$$"
  mkdir -p "$dir" 2>/dev/null || return 0
  {
    printf '# HELP hapax_lane_supervisor_recovery_candidates Lane recovery candidates projected this tick\n'
    printf '# TYPE hapax_lane_supervisor_recovery_candidates gauge\n'
    printf 'hapax_lane_supervisor_recovery_candidates %s\n' "$RECOVERY_CANDIDATES"
    printf '# HELP hapax_lane_supervisor_stall_candidates Stale-output candidates projected this tick\n'
    printf '# TYPE hapax_lane_supervisor_stall_candidates gauge\n'
    printf 'hapax_lane_supervisor_stall_candidates %s\n' "$STALL_CANDIDATES"
    printf '# HELP hapax_lane_supervisor_detach_candidates Launcher detach candidates held this tick\n'
    printf '# TYPE hapax_lane_supervisor_detach_candidates gauge\n'
    printf 'hapax_lane_supervisor_detach_candidates %s\n' "$DETACH_CANDIDATES"
    printf '# HELP hapax_lane_supervisor_configuration_candidates Configuration candidates projected this tick\n'
    printf '# TYPE hapax_lane_supervisor_configuration_candidates gauge\n'
    printf 'hapax_lane_supervisor_configuration_candidates %s\n' "$CONFIGURATION_CANDIDATES"
    printf '# HELP hapax_lane_supervisor_scan_errors Authoritative projection errors this tick\n'
    printf '# TYPE hapax_lane_supervisor_scan_errors gauge\n'
    printf 'hapax_lane_supervisor_scan_errors %s\n' "$SCAN_ERRORS"
    printf '# HELP hapax_lane_supervisor_effects Standing controller effects performed this tick\n'
    printf '# TYPE hapax_lane_supervisor_effects gauge\n'
    printf 'hapax_lane_supervisor_effects 0\n'
  } > "$tmp" 2>/dev/null || return 0
  mv "$tmp" "$METRICS_FILE" 2>/dev/null || true
}

for lane in $CLAUDE_LANES; do
  scan_lane "$lane" claude
done
for lane in $CODEX_LANES; do
  scan_lane "$lane" codex
done

emit_metrics
log "Done: recovery_candidates=$RECOVERY_CANDIDATES stall_candidates=$STALL_CANDIDATES detach_candidates=$DETACH_CANDIDATES configuration_candidates=$CONFIGURATION_CANDIDATES scan_errors=$SCAN_ERRORS effects=0"

if [ "$SCAN_ERRORS" -gt 0 ]; then
  exit 2
fi
exit 0
