#!/usr/bin/env python3
"""Decompose an accepted request into cc-tasks via LLM.

Usage:
    uv run python scripts/request-decompose <request_path> [--dry-run]
    uv run python scripts/request-decompose --scan [--dry-run]

Single request mode: reads the request, calls LLM for decomposition,
writes tasks atomically.

Scan mode: finds all accepted_for_planning requests with zero downstream
tasks and decomposes each.
"""

from __future__ import annotations

import argparse
import hashlib
import json
import logging
import os
import re
import sys
from datetime import UTC, datetime
from pathlib import Path
from typing import Any

import yaml

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT))

from agents.request_decomposer.models import RequestDecomposition, TaskSpec
from agents.request_decomposer.writer import write_decomposition
from shared.frontmatter import parse_frontmatter

_log = logging.getLogger(__name__)

REQUESTS_DIR = Path.home() / "Documents/Personal/20-projects/hapax-requests/active"
TASKS_DIR = Path.home() / "Documents/Personal/20-projects/hapax-cc-tasks"
SCAN_LIMIT_ENV = "HAPAX_REQUEST_DECOMPOSE_LIMIT"
REMEDIATION_AUTHORITY_CASE_ENV = "HAPAX_REQUEST_DECOMPOSE_REMEDIATION_AUTHORITY_CASE"
REMEDIATION_PARENT_REQUEST_ENV = "HAPAX_REQUEST_DECOMPOSE_REMEDIATION_PARENT_REQUEST"
REMEDIATION_PARENT_SPEC_ENV = "HAPAX_REQUEST_DECOMPOSE_REMEDIATION_PARENT_SPEC"
DEFAULT_REMEDIATION_AUTHORITY_CASE = "CASE-SDLC-REFORM-001"
DEFAULT_REMEDIATION_PARENT_SPEC = str(
    ROOT / "docs/superpowers/specs/2026-05-30-sdlc-frictionless-self-direction-design.md"
)
AUTHORITY_CASE_RE = re.compile(r"^CASE-[A-Z0-9-]+$")
CCTV_READY_ADMISSION_VALUES = {"ready_to_plan", "advance", "admitted"}
TERMINAL_REMEDIATION_STATUSES = {"done", "closed", "complete", "withdrawn", "superseded"}
CCTV_INTAKE_RECEIPT_FIELDS = (
    "cctv_intake_receipt",
    "cctv_intake_receipt_path",
    "cctv_receipt",
    "intake_receipt",
)
CCTV_INTAKE_ADMISSION_FIELDS = (
    "cctv_intake_verdict",
    "intake_verdict",
    "cctv_verdict",
    "cctv_intake_recommendation",
    "intake_recommendation",
)
CCTV_ROUTE_RESOURCE_ADMISSION_FIELDS = (
    "cctv_route_resource_admission",
    "route_resource_admission",
    "cctv_capability_admission",
    "capability_admission",
)
CCTV_CAPABILITY_RECEIPT_FIELDS = (
    "cctv_capability_receipts",
    "capability_receipts",
    "cctv_capability_receipt_refs",
    "capability_receipt_refs",
)
NULLISH_SCALARS = {"", "null", "none", "None", "NULL", "~", "unassigned", "[]"}

DECOMPOSITION_PROMPT = """\
You are the Hapax request decomposition engine. Given a request note,
produce the complete set of cc-tasks needed to fulfill it.

Return a JSON object with key "tasks" containing an array of task objects.
Each task object must have these fields:
- task_id: slug (e.g., "req-slug-phase1-verb-noun")
- title: concrete deliverable title
- kind: "build" | "operator_action" | "research_packet" | "verification"
- priority: "p0" | "p1" | "p2" | "p3"
- wsjf: float (parent WSJF * 0.85^phase_index for unlisted phases)
- depends_on: list of task_id strings from THIS decomposition
- phase_index: int (0 = first phase)
- intent: 1-3 sentences describing the work
- acceptance_criteria: list of concrete, testable criteria strings
- effort_class: "standard" | "high" | "max"
- mutation_surface: "none" | "vault_docs" | "source" | "runtime" | "public" | "provider_spend"
- quality_floor: "deterministic_ok" | "frontier_review_required" | "frontier_required"
- target_paths: list of repo-relative paths the task is expected to touch; [] if none/unknown
- routing_class: one of "coordination", "research_support", "docs_planning",
  "source_python", "source_other", "source_governance", "runtime_ops",
  "public_surface", "provider_spend", "operator_action", "verification", "unknown"
- requirement_vector: object with exactly these 8 integer 0..5 dimensions:
  quality_floor, information_scope, context_length, mutation_risk, verification_demand,
  ambiguity_novelty, composition_coupling, governance_sensitivity
- composition_tolerance: "atomic" | "parallel_ok" | "sequential_required" |
  "decompose_required" | "unknown"
- requirement_vector_validity_mask: object with the same 8 keys and boolean values

Rules:
1. EVERY task the request needs must appear. No stubs.
2. Dependencies must be explicit via depends_on.
3. Acceptance criteria must be observable/testable.
4. If the request has explicit phases, use them. If not, infer from scope.
5. Generate 1-8 tasks. If >8 needed, the request should be split.
6. Use routing_class="source_governance" for source tasks touching Rust, WGSL,
   CODEOWNERS, or governance-protected paths; otherwise use the narrowest class.
7. The requirement_vector is demand/risk, where 0 is trivial/none and 5 is
   frontier/high-risk/unknown. Set a validity-mask dimension false when the
   request lacks enough evidence; use conservative high scores for unknown hard
   dimensions.
"""


def _read_request(path: Path) -> dict:
    text = path.read_text(encoding="utf-8")
    fm, body = parse_frontmatter(text)
    return {
        "path": str(path),
        "filename": path.name,
        "frontmatter": fm,
        "body": body or text,
    }


def _scalar(value: Any) -> str:
    if value is None:
        return ""
    if isinstance(value, list):
        return ""
    text = str(value).strip()
    if len(text) >= 2 and text[0] == text[-1] and text[0] in {"'", '"'}:
        text = text[1:-1].strip()
    return "" if text in NULLISH_SCALARS or text.lower() in NULLISH_SCALARS else text


def _string_list(value: Any) -> list[str]:
    if value is None:
        return []
    if isinstance(value, list):
        return [_scalar(item) for item in value if _scalar(item)]
    text = _scalar(value)
    if not text:
        return []
    if text.startswith("[") and text.endswith("]"):
        return [
            item for part in text[1:-1].split(",") if (item := _scalar(part.strip().strip("'\"")))
        ]
    return [text]


def _request_keys(path: Path, frontmatter: dict[str, Any]) -> set[str]:
    keys = {str(path), path.name, path.stem}
    request_id = _scalar(frontmatter.get("request_id"))
    if request_id:
        keys.add(request_id)
    return keys


def _utc_now() -> str:
    return datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%SZ")


def _slugify(value: str, *, max_length: int = 58) -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", value.lower()).strip("-")
    if not slug:
        return "request"
    return slug[:max_length].strip("-") or "request"


def _request_id_for_data(request_data: dict[str, Any]) -> str:
    fm = request_data["frontmatter"]
    return _scalar(fm.get("request_id")) or str(request_data["filename"]).removesuffix(".md")


def _priority_for_request(request_data: dict[str, Any]) -> str:
    fm = request_data["frontmatter"]
    for field_name in ("priority_hint", "priority"):
        value = _scalar(fm.get(field_name)).lower()
        if value in {"p0", "p1", "p2", "p3"}:
            return value
        if value in {"critical", "urgent", "security_critical", "incident"}:
            return "p0"
        if value in {"high", "important"}:
            return "p1"
        if value in {"medium", "normal"}:
            return "p2"
        if value in {"low", "later"}:
            return "p3"
    return "p1"


def _wsjf_for_remediation(request_data: dict[str, Any], priority: str) -> float:
    floor_by_priority = {"p0": 30.0, "p1": 20.0, "p2": 10.0, "p3": 5.0}
    try:
        request_wsjf = float(request_data["frontmatter"].get("wsjf", 0) or 0)
    except (TypeError, ValueError):
        request_wsjf = 0.0
    return max(floor_by_priority.get(priority, 10.0), request_wsjf)


def _remediation_parent_request(request_data: dict[str, Any]) -> str:
    return os.environ.get(REMEDIATION_PARENT_REQUEST_ENV, str(request_data["filename"]))


def _remediation_parent_spec() -> str:
    return os.environ.get(REMEDIATION_PARENT_SPEC_ENV, DEFAULT_REMEDIATION_PARENT_SPEC)


def _remediation_authority_case() -> str:
    return os.environ.get(REMEDIATION_AUTHORITY_CASE_ENV, DEFAULT_REMEDIATION_AUTHORITY_CASE)


def _decomposition_remediation_task_id(
    request_data: dict[str, Any],
    failure_class: str,
) -> str:
    request_id = _request_id_for_data(request_data)
    digest_seed = f"{request_data['path']}:{request_id}:{failure_class}"
    digest = hashlib.sha1(digest_seed.encode("utf-8")).hexdigest()[:8]
    return f"request-decompose-{_slugify(failure_class, max_length=24)}-{_slugify(request_id)}-{digest}"


def _render_note(frontmatter: dict[str, Any], body: str) -> str:
    yaml_text = yaml.safe_dump(
        frontmatter,
        sort_keys=False,
        allow_unicode=False,
        default_flow_style=False,
    ).strip()
    return f"---\n{yaml_text}\n---\n\n{body.rstrip()}\n"


def _existing_task_path(task_id: str) -> Path | None:
    candidate = TASKS_DIR / "active" / f"{task_id}.md"
    if candidate.is_file():
        fm, _body = parse_frontmatter(candidate)
        if (
            _scalar(fm.get("remediates_request_id"))
            and _scalar(fm.get("status")) in TERMINAL_REMEDIATION_STATUSES
        ):
            return None
        return candidate
    return None


def _known_task_ids() -> set[str]:
    task_ids: set[str] = set()
    for task_dir in (TASKS_DIR / "active", TASKS_DIR / "closed"):
        if not task_dir.is_dir():
            continue
        for task_path in sorted(task_dir.glob("*.md")):
            if task_path.suffix != ".md":
                continue
            fm, _body = parse_frontmatter(task_path)
            if _scalar(fm.get("remediates_request_id")):
                continue
            task_id = _scalar(fm.get("task_id")) or task_path.stem
            if task_id:
                task_ids.add(task_id)
                task_ids.add(task_path.stem)
    return task_ids


def _task_parent_reference_keys(value: Any) -> set[str]:
    text = _scalar(value)
    if not text:
        return set()
    keys = {text}
    base = Path(os.path.expanduser(text)).name
    if base:
        keys.add(base)
        if base.endswith(".md"):
            keys.add(base.removesuffix(".md"))
    return keys


def _record_decomposition_remediation(
    request_data: dict[str, Any],
    failure_class: str,
    reasons: list[str],
    *,
    dry_run: bool,
) -> str:
    """Create a durable, idempotent remediation cc-task for failed decomposition."""
    task_id = _decomposition_remediation_task_id(request_data, failure_class)
    existing = _existing_task_path(task_id)
    if existing is not None:
        return "existing"
    if dry_run:
        return "dry_run"

    active_dir = TASKS_DIR / "active"
    active_dir.mkdir(parents=True, exist_ok=True)
    path = active_dir / f"{task_id}.md"
    now = _utc_now()
    request_id = _request_id_for_data(request_data)
    request_path = str(request_data["path"])
    priority = _priority_for_request(request_data)
    wsjf = _wsjf_for_remediation(request_data, priority)
    mutation_surface = "source" if failure_class == "llm_failed" else "vault_docs"
    mutation_scope_refs = [
        request_path,
        "request-decompose:failing-intake-flow",
    ]
    if mutation_surface == "source":
        mutation_scope_refs.append(str(ROOT / "scripts/request-decompose"))
    title_actions = {
        "admission_blocked": "Repair request decomposition admission",
        "llm_failed": "Repair request decomposition generation",
        "write_conflict": "Repair request decomposition write conflict",
    }
    title_action = title_actions.get(failure_class, "Repair request decomposition")
    reason_lines = "\n".join(f"- `{reason}`" for reason in reasons)
    frontmatter = {
        "type": "cc-task",
        "task_id": task_id,
        "title": f"{title_action} for {request_id}",
        "status": "offered",
        "assigned_to": "unassigned",
        "priority": priority,
        "wsjf": wsjf,
        "effort_class": "standard",
        "quality_floor": "deterministic_ok",
        "mutation_surface": mutation_surface,
        "mutation_scope_refs": mutation_scope_refs,
        "authority_level": "authoritative",
        "route_metadata_schema": 1,
        "kind": "recovery_triage",
        "risk_tier": "T1",
        "implementation_authorized": True,
        "source_mutation_authorized": mutation_surface == "source",
        "docs_mutation_authorized": mutation_surface in {"source", "vault_docs"},
        "runtime_mutation_authorized": False,
        "depends_on": [],
        "blocks": [],
        "branch": None,
        "pr": None,
        "created_at": now,
        "updated_at": now,
        "claimed_at": None,
        "completed_at": None,
        # Normal decomposition/coverage indexes ignore remediation tasks via
        # remediates_request_id, so this lineage does not mark the failed
        # request as decomposed or fulfilled.
        "parent_request": _remediation_parent_request(request_data),
        "parent_spec": _remediation_parent_spec(),
        "authority_case": _remediation_authority_case(),
        "remediates_request_id": request_id,
        "remediates_request_path": request_path,
        "decompose_failure_class": failure_class,
        "decompose_failure_reasons": reasons,
        "tags": [
            "cc-task",
            priority,
            "request-decompose-remediation",
            "auto-remediation",
        ],
    }
    body = f"""# {title_action} for {request_id}

`request-decompose` could not create the real downstream task graph for this
request. This remediation item exists so the failed decomposition is tracked
instead of becoming an orphaned warning in the timer journal.

## Failed Request

- Request id: `{request_id}`
- Request path: `{request_path}`
- Failure class: `{failure_class}`

## Failure Reasons

{reason_lines}

## Acceptance Criteria

- [ ] The failed request has valid CCTV intake receipt and ready verdict when
      the failure is admission-related.
- [ ] The failed request has a valid `CASE-*` authority case and non-null parent
      lineage before source/runtime mutation work is decomposed.
- [ ] If generation failed after admission, the LLM/runtime/prompt failure is
      corrected or routed to an explicit operator blocker with evidence.
- [ ] `scripts/request-decompose --scan --dry-run` no longer reports this
      request as failing for the same reasons.
- [ ] The original request receives its real `downstream_tasks`; this remediation
      task alone is not treated as fulfillment of the request.
"""
    tmp = path.with_suffix(".md.decompose-remediation-tmp")
    tmp.write_text(_render_note(frontmatter, body), encoding="utf-8")
    tmp.replace(path)
    return "created"


def _remediation_next_action(task_id: str, remediation_result: str) -> str:
    if remediation_result == "dry_run":
        return f"rerun without --dry-run to create remediation task {task_id}"
    return f"cc-claim {task_id}"


def _normalize_mutation_surface(value: Any) -> str:
    text = _scalar(value) or "source"
    aliases = {
        "vault": "vault_docs",
        "docs": "vault_docs",
        "system": "runtime",
        "external": "public",
    }
    normalized = aliases.get(text, text)
    allowed = {"none", "vault_docs", "source", "runtime", "public", "provider_spend"}
    return normalized if normalized in allowed else "source"


def _normalize_task_kind(value: Any) -> str:
    text = _slugify(_scalar(value), max_length=40).replace("-", "_")
    aliases = {
        "code": "build",
        "coding": "build",
        "implementation": "build",
        "implement": "build",
        "source": "build",
        "ops": "operator_action",
        "operator": "operator_action",
        "operator_task": "operator_action",
        "research": "research_packet",
        "research_task": "research_packet",
        "test": "verification",
        "tests": "verification",
        "testing": "verification",
        "verify": "verification",
        "validation": "verification",
        "recovery": "recovery_triage",
        "remediation": "recovery_triage",
    }
    normalized = aliases.get(text, text)
    allowed = {
        "build",
        "operator_action",
        "recovery_triage",
        "watcher",
        "research_packet",
        "verification",
    }
    return normalized if normalized in allowed else "build"


def _normalize_priority(value: Any, request_data: dict[str, Any]) -> str:
    text = _scalar(value).lower().replace("_", "-")
    aliases = {
        "critical": "p0",
        "urgent": "p0",
        "security-critical": "p0",
        "incident": "p0",
        "high": "p1",
        "important": "p1",
        "medium": "p2",
        "normal": "p2",
        "low": "p3",
        "later": "p3",
    }
    normalized = aliases.get(text, text)
    if normalized in {"p0", "p1", "p2", "p3"}:
        return normalized
    return _priority_for_request(request_data)


def _normalize_quality_floor(value: Any, request_data: dict[str, Any]) -> str:
    text = _scalar(value).lower().replace("-", "_")
    aliases = {
        "deterministic": "deterministic_ok",
        "deterministic_okay": "deterministic_ok",
        "normal": "deterministic_ok",
        "frontier": "frontier_required",
        "frontier_review": "frontier_review_required",
        "review": "frontier_review_required",
        "independent_review": "frontier_review_required",
        "production": "frontier_required",
        "frontier_required": "frontier_required",
        "frontier_review_required": "frontier_review_required",
        "deterministic_ok": "deterministic_ok",
    }
    normalized = aliases.get(text, text)
    if normalized in {"deterministic_ok", "frontier_review_required", "frontier_required"}:
        return normalized
    request_floor = _scalar(request_data["frontmatter"].get("quality_floor")).lower()
    return aliases.get(request_floor.replace("-", "_"), "deterministic_ok")


def _normalize_effort_class(value: Any) -> str:
    text = _scalar(value).lower()
    if text in {"standard", "high", "max"}:
        return text
    if text in {"small", "low", "medium", "normal"}:
        return "standard"
    if text in {"large", "complex"}:
        return "high"
    return "standard"


def _string_items(value: Any) -> list[str]:
    if isinstance(value, list):
        return [_scalar(item) for item in value if _scalar(item)]
    text = _scalar(value)
    if not text:
        return []
    lines = [line.strip(" -\t") for line in text.splitlines() if line.strip(" -\t")]
    return lines or [text]


def _completion_content(response: Any) -> str:
    """Extract LiteLLM/OpenAI-style message content from object or dict responses."""
    choices = getattr(response, "choices", None)
    if choices is None and isinstance(response, dict):
        choices = response.get("choices")
    if not choices:
        return ""
    first = choices[0]
    message = getattr(first, "message", None)
    if message is None and isinstance(first, dict):
        message = first.get("message")
    content = getattr(message, "content", None)
    if content is None and isinstance(message, dict):
        content = message.get("content")
    return _scalar(content)


def _json_object_from_completion(content: str) -> dict[str, Any]:
    """Parse JSON even when the model wraps it in a fenced block or short preface."""
    text = content.strip()
    if text.startswith("```"):
        text = text.split("\n", 1)[1] if "\n" in text else text
        if text.endswith("```"):
            text = text[:-3].strip()
        if text.lower().startswith("json\n"):
            text = text.split("\n", 1)[1].strip()
    try:
        loaded = json.loads(text)
    except json.JSONDecodeError:
        start = text.find("{")
        end = text.rfind("}")
        if start == -1 or end == -1 or end <= start:
            raise
        loaded = json.loads(text[start : end + 1])
    if not isinstance(loaded, dict):
        raise ValueError("LLM response JSON must be an object")
    return loaded


def _request_prompt_context(request_data: dict[str, Any]) -> str:
    """Build the prompt from body plus frontmatter, for sparse metadata-heavy requests."""
    fm = request_data["frontmatter"]
    field_names = (
        "request_id",
        "title",
        "request_type",
        "priority",
        "priority_hint",
        "risk_guess",
        "surfaces",
        "mutation_surface",
        "quality_floor",
        "authority_level",
        "principle_flags",
        "tags",
    )
    metadata: dict[str, Any] = {}
    for field_name in field_names:
        value = fm.get(field_name)
        if value not in (None, "", [], {}):
            metadata[field_name] = value
    metadata_text = yaml.safe_dump(metadata, sort_keys=False, allow_unicode=True).strip()
    body = _scalar(request_data.get("body")) or _scalar(fm.get("title")) or request_data["filename"]
    return (
        f"Request frontmatter summary:\n{metadata_text or '(none)'}\n\nRequest body:\n{body[:8000]}"
    )


def _coerce_llm_task(
    raw_task: Any,
    *,
    request_data: dict[str, Any],
    slug: str,
    req_wsjf: float,
    index: int,
) -> dict[str, Any]:
    if not isinstance(raw_task, dict):
        raise ValueError(f"task #{index + 1} is not an object")
    title = _scalar(raw_task.get("title")) or f"Implement {_request_id_for_data(request_data)}"
    task_id = _slugify(_scalar(raw_task.get("task_id")) or f"{slug}-{index + 1}-{title}")
    phase_index = raw_task.get("phase_index", index)
    try:
        phase = int(phase_index)
    except (TypeError, ValueError):
        phase = index
    try:
        wsjf = float(raw_task.get("wsjf", req_wsjf * (0.85**phase)))
    except (TypeError, ValueError):
        wsjf = req_wsjf * (0.85**phase)
    acceptance = _string_items(raw_task.get("acceptance_criteria"))
    if not acceptance:
        acceptance = [
            f"{_request_id_for_data(request_data)} has an observable implementation outcome."
        ]
    return {
        "task_id": task_id,
        "title": title,
        "kind": _normalize_task_kind(raw_task.get("kind", "build")),
        "priority": _normalize_priority(raw_task.get("priority"), request_data),
        "wsjf": wsjf,
        "depends_on": _string_items(raw_task.get("depends_on")),
        "phase_index": phase,
        "intent": _scalar(raw_task.get("intent")),
        "acceptance_criteria": acceptance,
        "effort_class": _normalize_effort_class(raw_task.get("effort_class")),
        "mutation_surface": _normalize_mutation_surface(raw_task.get("mutation_surface")),
        "quality_floor": _normalize_quality_floor(raw_task.get("quality_floor"), request_data),
        "target_paths": _string_items(raw_task.get("target_paths")),
        "routing_class": raw_task.get("routing_class", "unknown"),
        "requirement_vector": raw_task.get("requirement_vector", {}),
        "composition_tolerance": raw_task.get("composition_tolerance", "unknown"),
        "requirement_vector_validity_mask": raw_task.get(
            "requirement_vector_validity_mask",
            raw_task.get("validity_mask", {}),
        ),
        "route_envelope": raw_task.get("route_envelope"),
        "task_demand": raw_task.get("task_demand", {}),
    }


def _first_scalar(frontmatter: dict[str, Any], field_names: tuple[str, ...]) -> str:
    for field_name in field_names:
        value = _scalar(frontmatter.get(field_name))
        if value:
            return value
    return ""


def _first_values(frontmatter: dict[str, Any], field_names: tuple[str, ...]) -> list[str]:
    values: list[str] = []
    for field_name in field_names:
        for value in _string_list(frontmatter.get(field_name)):
            if value and value not in values:
                values.append(value)
    return values


def _authority_case(frontmatter: dict[str, Any]) -> str:
    return _scalar(frontmatter.get("planning_case")) or _scalar(frontmatter.get("authority_case"))


def _parent_spec_for_request(request_data: dict[str, Any]) -> str:
    fm = request_data["frontmatter"]
    return (
        _scalar(fm.get("parent_spec"))
        or _scalar(fm.get("parent_plan"))
        or _scalar(request_data.get("path"))
    )


def _decomposition_admission_blockers(request_data: dict[str, Any]) -> list[str]:
    fm = request_data["frontmatter"]
    blockers: list[str] = []

    receipt = _first_scalar(fm, CCTV_INTAKE_RECEIPT_FIELDS)
    if not receipt:
        blockers.append("missing_cctv_intake_receipt")

    admission_value = _first_scalar(fm, CCTV_INTAKE_ADMISSION_FIELDS)
    if not admission_value:
        blockers.append("missing_cctv_intake_verdict")
    elif admission_value not in CCTV_READY_ADMISSION_VALUES:
        blockers.append(f"cctv_intake_not_ready:{admission_value}")

    route_admission = _first_scalar(fm, CCTV_ROUTE_RESOURCE_ADMISSION_FIELDS)
    if not route_admission:
        blockers.append("missing_cctv_route_resource_admission")
    elif route_admission != "admitted":
        blockers.append(f"cctv_route_resource_not_admitted:{route_admission}")
    elif not _first_values(fm, CCTV_CAPABILITY_RECEIPT_FIELDS):
        blockers.append("missing_cctv_capability_receipts")

    authority = _authority_case(fm)
    if not authority:
        blockers.append("missing_authority_case")
    elif not AUTHORITY_CASE_RE.match(authority):
        blockers.append(f"invalid_authority_case:{authority}")

    if not _parent_spec_for_request(request_data):
        blockers.append("missing_parent_lineage")

    return blockers


def _find_undecomposed_requests() -> list[Path]:
    task_parents = set()
    task_ids = _known_task_ids()
    for d in [TASKS_DIR / "active", TASKS_DIR / "closed"]:
        if not d.is_dir():
            continue
        for f in sorted(d.glob("*.md")):
            if f.suffix != ".md":
                continue
            fm, _body = parse_frontmatter(f)
            if _scalar(fm.get("remediates_request_id")):
                continue
            for field_name in ("parent_request", "parent_plan", "parent_spec"):
                for item in _string_list(fm.get(field_name)):
                    task_parents.update(_task_parent_reference_keys(item))

    undecomposed = []
    for f in sorted(REQUESTS_DIR.glob("*.md")):
        if f.suffix != ".md":
            continue
        fm, _body = parse_frontmatter(f)
        if _scalar(fm.get("status")) != "accepted_for_planning":
            continue
        downstream_tasks = _string_list(fm.get("downstream_tasks"))
        if downstream_tasks and any(task_id in task_ids for task_id in downstream_tasks):
            continue
        keys = _request_keys(f, fm)
        if keys & task_parents:
            continue
        undecomposed.append(f)
    return undecomposed


def _parse_scan_limit(cli_limit: int | None, env_value: str | None) -> int | None:
    value: int | str | None = cli_limit
    if value is None:
        value = env_value
    if value is None or str(value).strip() == "":
        return None
    try:
        limit = int(value)
    except (TypeError, ValueError) as exc:
        raise ValueError(f"scan limit must be a positive integer, got {value!r}") from exc
    if limit < 1:
        raise ValueError(f"scan limit must be a positive integer, got {value!r}")
    return limit


def _limit_scan_requests(requests: list[Path], limit: int | None) -> list[Path]:
    if limit is None:
        return requests
    return requests[:limit]


def _decompose_with_llm(request_data: dict) -> RequestDecomposition | None:
    """Call LLM to decompose. Returns None on failure (fail-closed)."""
    try:
        from shared.config import LITELLM_KEY, MODELS

        model = MODELS.get("balanced", "balanced")
    except Exception:
        model = "local-fast"
        LITELLM_KEY = os.environ.get("LITELLM_API_KEY", "")

    fm = request_data["frontmatter"]
    fm.get("title", request_data["filename"])[:60]
    req_wsjf = float(fm.get("wsjf", "5.0") or "5.0")
    req_priority = fm.get("priority", "medium")
    authority = _authority_case(fm)
    parent_spec = _parent_spec_for_request(request_data)
    slug = request_data["filename"].replace(".md", "").replace("REQ-", "").lower()[:30]

    try:
        import litellm

        response = litellm.completion(
            model=f"litellm_proxy/{model}",
            messages=[
                {"role": "system", "content": DECOMPOSITION_PROMPT},
                {
                    "role": "user",
                    "content": (
                        f"{_request_prompt_context(request_data)}\n\n"
                        f"Parent WSJF: {req_wsjf}\n"
                        f"Priority: {req_priority}\n"
                        f"Authority case: {authority}\n"
                        f"Request filename: {request_data['filename']}\n"
                        f"Slug prefix: {slug}\n"
                    ),
                },
            ],
            response_format={"type": "json_object"},
            timeout=60,
            api_base="http://localhost:4000",
            api_key=LITELLM_KEY,
        )

        content = _completion_content(response)
        data = _json_object_from_completion(content)
        tasks_data = data.get("tasks", [])
        if not isinstance(tasks_data, list) or not tasks_data:
            raise ValueError("LLM response did not contain a non-empty tasks array")

        tasks = []
        for index, t in enumerate(tasks_data):
            normalized = _coerce_llm_task(
                t,
                request_data=request_data,
                slug=slug,
                req_wsjf=req_wsjf,
                index=index,
            )
            tasks.append(
                TaskSpec(
                    task_id=normalized["task_id"],
                    title=normalized["title"],
                    kind=normalized["kind"],
                    priority=normalized["priority"],
                    wsjf=normalized["wsjf"],
                    depends_on=normalized["depends_on"],
                    phase_index=normalized["phase_index"],
                    parent_request=request_data["filename"],
                    authority_case=authority,
                    parent_spec=parent_spec,
                    status="ready" if normalized["depends_on"] else "offered",
                    blocked_reason=(
                        f"Depends on: {', '.join(normalized['depends_on'])}"
                        if normalized["depends_on"]
                        else None
                    ),
                    intent=normalized["intent"],
                    acceptance_criteria=normalized["acceptance_criteria"],
                    effort_class=normalized["effort_class"],
                    mutation_surface=normalized["mutation_surface"],
                    quality_floor=normalized["quality_floor"],
                    target_paths=normalized["target_paths"],
                    routing_class=normalized["routing_class"],
                    requirement_vector=normalized["requirement_vector"],
                    composition_tolerance=normalized["composition_tolerance"],
                    requirement_vector_validity_mask=normalized["requirement_vector_validity_mask"],
                    route_envelope=normalized["route_envelope"],
                    task_demand=normalized["task_demand"],
                )
            )

        return RequestDecomposition(
            request_id=slug,
            request_path=str(request_data["path"]),
            decomposition_model=model,
            tasks=tasks,
        )

    except Exception as e:
        _log.error("LLM decomposition failed: %s", e)
        return None


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Decompose requests into cc-tasks",
        epilog=(
            "Environment: HAPAX_REQUEST_DECOMPOSE_LIMIT caps admitted scan attempts. "
            "Remediation task lineage defaults can be set with "
            f"{REMEDIATION_AUTHORITY_CASE_ENV}, {REMEDIATION_PARENT_REQUEST_ENV}, and "
            f"{REMEDIATION_PARENT_SPEC_ENV}."
        ),
    )
    parser.add_argument("request_path", nargs="?", help="Path to a specific request")
    parser.add_argument(
        "--scan", action="store_true", help="Find and decompose all undecomposed requests"
    )
    parser.add_argument("--dry-run", action="store_true", help="Show what would be created")
    parser.add_argument(
        "--limit",
        type=int,
        help=(
            "Maximum accepted requests to decompose in this scan. Defaults to "
            f"${SCAN_LIMIT_ENV} when set."
        ),
    )
    args = parser.parse_args()

    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")

    if args.scan:
        try:
            scan_limit = _parse_scan_limit(args.limit, os.environ.get(SCAN_LIMIT_ENV))
        except ValueError as exc:
            parser.error(str(exc))
        undecomposed = _find_undecomposed_requests()
        _log.info("Found %d undecomposed requests", len(undecomposed))
        if scan_limit is not None:
            _log.info(
                "Will attempt up to %d admitted requests from %d undecomposed requests",
                scan_limit,
                len(undecomposed),
            )
        total_tasks = 0
        skipped_existing = 0
        skipped_admission = 0
        failed_decomposition = 0
        admitted_attempts = 0
        remediation_created = 0
        remediation_existing = 0
        remediation_dry_run = 0
        for req_path in undecomposed:
            req_data = _read_request(req_path)
            blockers = _decomposition_admission_blockers(req_data)
            if blockers:
                skipped_admission += 1
                remediation_result = _record_decomposition_remediation(
                    req_data,
                    "admission_blocked",
                    blockers,
                    dry_run=args.dry_run,
                )
                if remediation_result == "created":
                    remediation_created += 1
                elif remediation_result == "existing":
                    remediation_existing += 1
                elif remediation_result == "dry_run":
                    remediation_dry_run += 1
                _log.warning(
                    "Skipping %s: decomposition admission blocked: %s (remediation: %s)",
                    req_path.name,
                    ", ".join(blockers),
                    remediation_result,
                )
                continue
            if scan_limit is not None and admitted_attempts >= scan_limit:
                break
            admitted_attempts += 1
            decomp = _decompose_with_llm(req_data)
            if decomp is None:
                failed_decomposition += 1
                remediation_result = _record_decomposition_remediation(
                    req_data,
                    "llm_failed",
                    ["llm_decomposition_failed"],
                    dry_run=args.dry_run,
                )
                if remediation_result == "created":
                    remediation_created += 1
                elif remediation_result == "existing":
                    remediation_existing += 1
                elif remediation_result == "dry_run":
                    remediation_dry_run += 1
                _log.warning(
                    "Failed to decompose %s (fail-closed; remediation: %s)",
                    req_path.name,
                    remediation_result,
                )
                continue
            if args.dry_run:
                _log.info("DRY RUN: %s → %d tasks", req_path.name, len(decomp.tasks))
                for t in decomp.tasks:
                    _log.info("  %s (WSJF %.1f, %s)", t.task_id, t.wsjf, t.status)
                total_tasks += len(decomp.tasks)
            else:
                try:
                    paths = write_decomposition(decomp, TASKS_DIR)
                except FileExistsError as exc:
                    skipped_existing += 1
                    remediation_result = _record_decomposition_remediation(
                        req_data,
                        "write_conflict",
                        [f"task_write_conflict:{exc}"],
                        dry_run=args.dry_run,
                    )
                    if remediation_result == "created":
                        remediation_created += 1
                    elif remediation_result == "existing":
                        remediation_existing += 1
                    elif remediation_result == "dry_run":
                        remediation_dry_run += 1
                    _log.warning(
                        "Skipping %s: %s (remediation: %s)",
                        req_path.name,
                        exc,
                        remediation_result,
                    )
                    continue
                _log.info("Wrote %d tasks for %s", len(paths), req_path.name)
                total_tasks += len(paths)
        _log.info(
            "Total: %d tasks created from %d admitted attempts "
            "(%d backlog requests, %d skipped existing)",
            total_tasks,
            admitted_attempts,
            len(undecomposed),
            skipped_existing,
        )
        if skipped_admission:
            _log.info(
                "%d selected requests held by decomposition admission gate", skipped_admission
            )
        if failed_decomposition:
            _log.info("%d admitted requests failed decomposition", failed_decomposition)
        if remediation_created or remediation_existing or remediation_dry_run:
            _log.info(
                "Decomposition remediation tasks: %d created, %d existing, %d dry-run",
                remediation_created,
                remediation_existing,
                remediation_dry_run,
            )
        return 0

    if args.request_path:
        req_path = Path(args.request_path)
        if not req_path.exists():
            _log.error("Request not found: %s", req_path)
            return 1
        req_data = _read_request(req_path)
        blockers = _decomposition_admission_blockers(req_data)
        if blockers:
            remediation_task_id = _decomposition_remediation_task_id(req_data, "admission_blocked")
            remediation_result = _record_decomposition_remediation(
                req_data,
                "admission_blocked",
                blockers,
                dry_run=args.dry_run,
            )
            _log.error(
                "Decomposition admission blocked for %s: %s (remediation: %s, task: %s, next: %s)",
                req_path.name,
                ", ".join(blockers),
                remediation_result,
                remediation_task_id,
                _remediation_next_action(remediation_task_id, remediation_result),
            )
            return 1
        decomp = _decompose_with_llm(req_data)
        if decomp is None:
            remediation_task_id = _decomposition_remediation_task_id(req_data, "llm_failed")
            remediation_result = _record_decomposition_remediation(
                req_data,
                "llm_failed",
                ["llm_decomposition_failed"],
                dry_run=args.dry_run,
            )
            _log.error(
                "Decomposition failed (fail-closed; remediation: %s, task: %s, next: %s)",
                remediation_result,
                remediation_task_id,
                _remediation_next_action(remediation_task_id, remediation_result),
            )
            return 1
        if args.dry_run:
            _log.info("DRY RUN: %d tasks", len(decomp.tasks))
            for t in decomp.tasks:
                _log.info("  %s: %s (WSJF %.1f)", t.task_id, t.title, t.wsjf)
            return 0
        try:
            paths = write_decomposition(decomp, TASKS_DIR)
        except FileExistsError as exc:
            remediation_task_id = _decomposition_remediation_task_id(req_data, "write_conflict")
            remediation_result = _record_decomposition_remediation(
                req_data,
                "write_conflict",
                [f"task_write_conflict:{exc}"],
                dry_run=args.dry_run,
            )
            _log.error(
                "Decomposition write failed: %s (remediation: %s, task: %s, next: %s)",
                exc,
                remediation_result,
                remediation_task_id,
                _remediation_next_action(remediation_task_id, remediation_result),
            )
            return 1
        _log.info("Wrote %d tasks", len(paths))
        return 0

    parser.print_help()
    return 1


if __name__ == "__main__":
    sys.exit(main())
