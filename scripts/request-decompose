    RequestDecomposition,
    RequestDecompositionPlan,
    TaskSpec,
)
from agents.request_decomposer.writer import (
    DecompositionJournalInspection,
    decomposition_commit_state,
    inspect_decomposition_journals,
    write_decomposition,
)
from shared.frontmatter import parse_frontmatter
from shared.sdlc_task_store import (
    TaskIdentityIndex,
    TaskStoreError,
    build_task_identity_index,
    validate_task_identity_index,
)

_log = logging.getLogger(__name__)

REQUESTS_DIR = Path.home() / "Documents/Personal/20-projects/hapax-requests/active"
TASKS_DIR = Path.home() / "Documents/Personal/20-projects/hapax-cc-tasks"
SCAN_LIMIT_ENV = "HAPAX_REQUEST_DECOMPOSE_LIMIT"
DECOMPOSITION_HOLD_SCHEMA = "hapax.request-decomposition-hold.v1"
DECOMPOSITION_HOLD_DIR = "_decomposition_holds"
HISTORICAL_DECOMPOSITION_PLAN_SCHEMA = "hapax.request-decomposition-plan.v1"
AUTHORITY_CASE_RE = re.compile(r"^CASE-[A-Z0-9-]+$")
CCTV_READY_ADMISSION_VALUES = {"ready_to_plan", "advance", "admitted"}
CCTV_INTAKE_RECEIPT_FIELDS = (
    "cctv_intake_receipt",
    "cctv_intake_receipt_path",
    "cctv_receipt",
    "intake_receipt",
)


class BoundDecompositionHold(ValueError):
    """Typed non-provider HOLD for one exact bound-plan compatibility boundary."""

    def __init__(self, failure_class: str, reason_code: str) -> None:
        self.failure_class = failure_class
        self.reason_code = reason_code
        super().__init__(reason_code)


CCTV_INTAKE_ADMISSION_FIELDS = (
    "cctv_intake_verdict",
    "intake_verdict",
    "cctv_verdict",
    "cctv_intake_recommendation",
    "intake_recommendation",
)
CCTV_ROUTE_RESOURCE_ADMISSION_FIELDS = (
    "cctv_route_resource_admission",
    "route_resource_admission",
    "cctv_capability_admission",
    "capability_admission",
)
CCTV_CAPABILITY_RECEIPT_FIELDS = (
    "cctv_capability_receipts",
    "capability_receipts",
    "cctv_capability_receipt_refs",
    "capability_receipt_refs",
)
NULLISH_SCALARS = {"", "null", "none", "None", "NULL", "~", "unassigned", "[]"}
AUTHORITY_LEVELS = {
    "authoritative",
    "support_non_authoritative",
    "evidence_receipt",
    "relay_only",
}
MAX_DECOMPOSITION_PLAN_BYTES = 8 * 1024 * 1024

DECOMPOSITION_PROMPT = """\
You are the Hapax request decomposition engine. Given a request note,
produce the complete set of cc-tasks needed to fulfill it.

Return a JSON object with key "tasks" containing an array of task objects.
Each task object must have these fields:
- task_id: slug (e.g., "req-slug-phase1-verb-noun")
- title: concrete deliverable title
- kind: "build" | "operator_action" | "research_packet" | "verification"
- priority: "p0" | "p1" | "p2" | "p3"
- wsjf: float (parent WSJF * 0.85^phase_index for unlisted phases)
- depends_on: list of task_id strings from THIS decomposition
- phase_index: int (0 = first phase)
- intent: 1-3 sentences describing the work
- acceptance_criteria: list of concrete, testable criteria strings
- effort_class: "standard" | "high" | "max"
- mutation_surface: "none" | "vault_docs" | "source" | "runtime" | "public" | "provider_spend"
- quality_floor: "deterministic_ok" | "frontier_review_required" | "frontier_required"
- target_paths: list of repo-relative paths the task is expected to touch; [] if none/unknown
- routing_class: one of "coordination", "research_support", "docs_planning",
  "source_python", "source_other", "source_governance", "runtime_ops",
  "public_surface", "provider_spend", "operator_action", "verification", "unknown"
- requirement_vector: object with exactly these 8 integer 0..5 dimensions:
  quality_floor, information_scope, context_length, mutation_risk, verification_demand,
  ambiguity_novelty, composition_coupling, governance_sensitivity
- composition_tolerance: "atomic" | "parallel_ok" | "sequential_required" |
  "decompose_required" | "unknown"
- requirement_vector_validity_mask: object with the same 8 keys and boolean values
- status: "offered" | "ready" | "blocked"; use blocked for any unresolved hold
- blocked_reason: required when status is blocked
- authority_level: requested ceiling only; this proposal cannot grant authority

Rules:
1. EVERY task the request needs must appear. No stubs.
2. Dependencies must be explicit via depends_on.
3. Acceptance criteria must be observable/testable.
4. If the request has explicit phases, use them. If not, infer from scope.
5. Generate 1-8 tasks. If >8 needed, the request should be split.
6. Use routing_class="source_governance" for source tasks touching Rust, WGSL,
   CODEOWNERS, or governance-protected paths; otherwise use the narrowest class.
7. The requirement_vector is demand/risk, where 0 is trivial/none and 5 is
   frontier/high-risk/unknown. Set a validity-mask dimension false when the
   request lacks enough evidence; use conservative high scores for unknown hard
   dimensions.
8. This output is a proposal. It never grants authority, selects a live route,
   satisfies a dependency, or authorizes mutation.
"""


def _read_request(path: Path) -> dict:
    source_bytes = path.read_bytes()
    text = source_bytes.decode("utf-8")
    fm, body = parse_frontmatter(text)
    return {
        "path": str(path),
        "filename": path.name,
        "frontmatter": fm,
        "body": body or text,
        "source_sha256": hashlib.sha256(source_bytes).hexdigest(),
    }


def _scalar(value: Any) -> str:
    if value is None:
        return ""
    if isinstance(value, list):
        return ""
    text = str(value).strip()
    if len(text) >= 2 and text[0] == text[-1] and text[0] in {"'", '"'}:
        text = text[1:-1].strip()
    return "" if text in NULLISH_SCALARS or text.lower() in NULLISH_SCALARS else text


def _string_list(value: Any) -> list[str]:
    if value is None:
        return []
    if isinstance(value, list):
        return [_scalar(item) for item in value if _scalar(item)]
    text = _scalar(value)
    if not text:
        return []
    if text.startswith("[") and text.endswith("]"):
        return [
            item for part in text[1:-1].split(",") if (item := _scalar(part.strip().strip("'\"")))
        ]
    return [text]


def _request_keys(path: Path, frontmatter: dict[str, Any]) -> set[str]:
    keys = {str(path), path.name, path.stem}
    request_id = _scalar(frontmatter.get("request_id"))
    if request_id:
        keys.add(request_id)
    return keys


def _slugify(value: str, *, max_length: int = 58) -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", value.lower()).strip("-")
    if not slug:
        return "request"
    return slug[:max_length].strip("-") or "request"


def _request_id_for_data(request_data: dict[str, Any]) -> str:
    fm = request_data["frontmatter"]
    return _scalar(fm.get("request_id")) or str(request_data["filename"]).removesuffix(".md")


def _priority_for_request(request_data: dict[str, Any]) -> str:
    fm = request_data["frontmatter"]
    for field_name in ("priority_hint", "priority"):
        value = _scalar(fm.get(field_name)).lower()
        if value in {"p0", "p1", "p2", "p3"}:
            return value
        if value in {"critical", "urgent", "security_critical", "incident"}:
            return "p0"
        if value in {"high", "important"}:
            return "p1"
        if value in {"medium", "normal"}:
            return "p2"
        if value in {"low", "later"}:
            return "p3"
    return "p1"


def _known_task_ids(identity_index: TaskIdentityIndex | None = None) -> set[str]:
    index = identity_index or build_task_identity_index(TASKS_DIR)
    remediation_ids = set()
    for entry in index.entries:
        if entry.task_id is None or entry.error_reason_code is not None:
            continue
        fm, _body = parse_frontmatter(entry.path)
        if _scalar(fm.get("remediates_request_id")):
            remediation_ids.add(entry.task_id)
    validate_task_identity_index(index)
    return set(index.by_task_id) - remediation_ids


def _task_parent_reference_keys(value: Any) -> set[str]:
    text = _scalar(value)
    if not text:
        return set()
    keys = {text}
    base = Path(os.path.expanduser(text)).name
    if base:
        keys.add(base)
        if base.endswith(".md"):
            keys.add(base.removesuffix(".md"))
    return keys


def _journal_request_keys(inspection: DecompositionJournalInspection) -> set[str]:
    keys: set[str] = set()
    if inspection.request_id:
        keys.add(inspection.request_id)
    if inspection.request_path:
        keys.update(_task_parent_reference_keys(inspection.request_path))
    return keys


def _journals_for_request(
    request_data: dict[str, Any],
) -> tuple[DecompositionJournalInspection, ...]:
    path = Path(str(request_data["path"]))
    keys = _request_keys(path, request_data["frontmatter"])
    return tuple(
        inspection
        for inspection in inspect_decomposition_journals(TASKS_DIR)
        if keys & _journal_request_keys(inspection)
    )


def _unassociated_invalid_journals() -> tuple[DecompositionJournalInspection, ...]:
    return tuple(
        inspection
        for inspection in inspect_decomposition_journals(TASKS_DIR)
        if inspection.state == "invalid" and not _journal_request_keys(inspection)
    )


def _persist_decomposition_hold(payload: dict[str, Any], *, dry_run: bool) -> str:
    unsigned = yaml.safe_dump(payload, sort_keys=False, allow_unicode=False).encode("utf-8")
    hold_id = hashlib.sha256(unsigned).hexdigest()
    payload["hold_id"] = hold_id
    content = yaml.safe_dump(payload, sort_keys=False, allow_unicode=False).encode("utf-8")
    logical_root = TASKS_DIR.expanduser()
    if logical_root.is_symlink() or (logical_root.exists() and not logical_root.is_dir()):
        raise ValueError("task root must be one real directory")
    physical_root = logical_root.resolve(strict=False)
    hold_dir = logical_root / DECOMPOSITION_HOLD_DIR
    if hold_dir.resolve(strict=False) != physical_root / DECOMPOSITION_HOLD_DIR:
        raise ValueError("decomposition HOLD directory escapes task root")
    path = hold_dir / f"{hold_id}.yaml"
    if path.is_symlink():
        raise ValueError("decomposition HOLD path cannot be a symlink")
    if path.is_file():
        if path.read_bytes() != content:
            raise FileExistsError("decomposition HOLD identity collision")
        return "existing"
    if dry_run:
        return "dry_run"
    hold_dir.mkdir(parents=True, exist_ok=True)
    descriptor, temporary_name = tempfile.mkstemp(prefix=f".{hold_id}.", dir=hold_dir)
    temporary = Path(temporary_name)
    try:
        with os.fdopen(descriptor, "wb") as handle:
            handle.write(content)
            handle.flush()
            os.fsync(handle.fileno())
        try:
            os.link(temporary, path)
        except FileExistsError:
            if path.read_bytes() != content:
                raise FileExistsError("decomposition HOLD identity collision") from None
    finally:
        temporary.unlink(missing_ok=True)
    return "created"


def _hold_authorization_projection() -> dict[str, bool | str]:
    return {
        "authority_level": "support_non_authoritative",
        "claimable": False,
        "may_authorize": False,
        "implementation_authorized": False,
        "source_mutation_authorized": False,
        "docs_mutation_authorized": False,
        "runtime_mutation_authorized": False,
        "release_authorized": False,
        "public_mutation_authorized": False,
        "provider_spend_authorized": False,
    }


def _record_decomposition_remediation(
    request_data: dict[str, Any],
    failure_class: str,
    reasons: list[str],
    *,
    dry_run: bool,
) -> str:
    """Append a non-task HOLD; failure observation must never mint authority."""
    request_id = _request_id_for_data(request_data)
    request_path = Path(str(request_data["path"]))
    request_bytes = request_path.read_bytes()
    payload = {
        "schema": DECOMPOSITION_HOLD_SCHEMA,
        "state": "hold",
        "request_id": request_id,
        "request_path": str(request_path),
        "request_sha256": hashlib.sha256(request_bytes).hexdigest(),
        "failure_class": failure_class,
        "reason_codes": sorted(set(reasons)),
        **_hold_authorization_projection(),
    }
    return _persist_decomposition_hold(payload, dry_run=dry_run)


def _record_journal_reconciliation_hold(
    inspection: DecompositionJournalInspection,
    *,
    dry_run: bool,
) -> str:
    payload = {
        "schema": DECOMPOSITION_HOLD_SCHEMA,
        "state": "hold",
        "request_id": inspection.request_id or None,
        "request_path": inspection.request_path or None,
        "request_sha256": None,
        "decomposition_commit_id": inspection.commit_id,
        "failure_class": "journal_reconciliation_required",
        "reason_codes": [
            f"unassociated_decomposition_journal_invalid:{inspection.commit_id}:{inspection.reason_code}"
        ],
        **_hold_authorization_projection(),
    }
    return _persist_decomposition_hold(payload, dry_run=dry_run)


def _remediation_next_action(remediation_result: str) -> str:
    if remediation_result == "dry_run":
        return "admit a governed non-dry intake transition to persist this HOLD"
    return "satisfy the recorded HOLD through a separately authorized transition"


def _normalize_mutation_surface(value: Any) -> str:
    text = _scalar(value) or "source"
    aliases = {
        "vault": "vault_docs",
        "docs": "vault_docs",
        "system": "runtime",
        "external": "public",
    }
    normalized = aliases.get(text, text)
    allowed = {"none", "vault_docs", "source", "runtime", "public", "provider_spend"}
    return normalized if normalized in allowed else "source"


def _normalize_task_kind(value: Any) -> str:
    text = _slugify(_scalar(value), max_length=40).replace("-", "_")
    aliases = {
        "code": "build",
        "coding": "build",
        "implementation": "build",
        "implement": "build",
        "source": "build",
        "ops": "operator_action",
        "operator": "operator_action",
        "operator_task": "operator_action",
        "research": "research_packet",
        "research_task": "research_packet",
        "test": "verification",
        "tests": "verification",
        "testing": "verification",
        "verify": "verification",
        "validation": "verification",
        "recovery": "recovery_triage",
        "remediation": "recovery_triage",
    }
    normalized = aliases.get(text, text)
    allowed = {
        "build",
        "operator_action",
        "recovery_triage",
        "watcher",
        "research_packet",
        "verification",
    }
    return normalized if normalized in allowed else "build"


def _normalize_priority(value: Any, request_data: dict[str, Any]) -> str:
    text = _scalar(value).lower().replace("_", "-")
    aliases = {
        "critical": "p0",
        "urgent": "p0",
        "security-critical": "p0",
        "incident": "p0",
        "high": "p1",
        "important": "p1",
        "medium": "p2",
        "normal": "p2",
        "low": "p3",
        "later": "p3",
    }
    normalized = aliases.get(text, text)
    if normalized in {"p0", "p1", "p2", "p3"}:
        return normalized
    return _priority_for_request(request_data)


def _normalize_quality_floor(value: Any, request_data: dict[str, Any]) -> str:
    text = _scalar(value).lower().replace("-", "_")
    aliases = {
        "deterministic": "deterministic_ok",
        "deterministic_okay": "deterministic_ok",
        "normal": "deterministic_ok",
        "frontier": "frontier_required",
        "frontier_review": "frontier_review_required",
        "review": "frontier_review_required",
        "independent_review": "frontier_review_required",
        "production": "frontier_required",
        "frontier_required": "frontier_required",
        "frontier_review_required": "frontier_review_required",
        "deterministic_ok": "deterministic_ok",
    }
    normalized = aliases.get(text, text)
    if normalized in {
        "deterministic_ok",
        "frontier_review_required",
        "frontier_required",
    }:
        return normalized
    request_floor = _scalar(request_data["frontmatter"].get("quality_floor")).lower()
    return aliases.get(request_floor.replace("-", "_"), "deterministic_ok")


def _normalize_effort_class(value: Any) -> str:
    text = _scalar(value).lower()
    if text in {"standard", "high", "max"}:
        return text
    if text in {"small", "low", "medium", "normal"}:
        return "standard"
    if text in {"large", "complex"}:
        return "high"
    return "standard"


def _string_items(value: Any) -> list[str]:
    if isinstance(value, list):
        return [_scalar(item) for item in value if _scalar(item)]
    text = _scalar(value)
    if not text:
        return []
    lines = [line.strip(" -\t") for line in text.splitlines() if line.strip(" -\t")]
    return lines or [text]


def _completion_content(response: Any) -> str:
    """Extract LiteLLM/OpenAI-style message content from object or dict responses."""
    choices = getattr(response, "choices", None)
    if choices is None and isinstance(response, dict):
        choices = response.get("choices")
    if not choices:
        return ""
    first = choices[0]
    message = getattr(first, "message", None)
    if message is None and isinstance(first, dict):
        message = first.get("message")
    content = getattr(message, "content", None)
    if content is None and isinstance(message, dict):
        content = message.get("content")
    return _scalar(content)


def _json_object_from_completion(content: str) -> dict[str, Any]:
    """Parse JSON even when the model wraps it in a fenced block or short preface."""
    text = content.strip()
    if text.startswith("```"):
        text = text.split("\n", 1)[1] if "\n" in text else text
        if text.endswith("```"):
            text = text[:-3].strip()
        if text.lower().startswith("json\n"):
            text = text.split("\n", 1)[1].strip()
    try:
        loaded = json.loads(text)
    except json.JSONDecodeError:
        start = text.find("{")
        end = text.rfind("}")
        if start == -1 or end == -1 or end <= start:
            raise
        loaded = json.loads(text[start : end + 1])
    if not isinstance(loaded, dict):
        raise ValueError("LLM response JSON must be an object")
    return loaded


def _request_prompt_context(request_data: dict[str, Any]) -> str:
    """Build the prompt from body plus frontmatter, for sparse metadata-heavy requests."""
    fm = request_data["frontmatter"]
    field_names = (
        "request_id",
        "title",
        "request_type",
        "priority",
        "priority_hint",
        "risk_guess",
        "surfaces",
        "mutation_surface",
        "quality_floor",
        "authority_level",
        "principle_flags",
        "tags",
    )
    metadata: dict[str, Any] = {}
    for field_name in field_names:
        value = fm.get(field_name)
        if value not in (None, "", [], {}):
            metadata[field_name] = value
    metadata_text = yaml.safe_dump(metadata, sort_keys=False, allow_unicode=True).strip()
    body = _scalar(request_data.get("body")) or _scalar(fm.get("title")) or request_data["filename"]
    return (
        f"Request frontmatter summary:\n{metadata_text or '(none)'}\n\nRequest body:\n{body[:8000]}"
    )


def _coerce_llm_task(
    raw_task: Any,
    *,
    request_data: dict[str, Any],
    slug: str,
    req_wsjf: float,
    index: int,
) -> dict[str, Any]:
    if not isinstance(raw_task, dict):
        raise ValueError(f"task #{index + 1} is not an object")
    title = _scalar(raw_task.get("title")) or f"Implement {_request_id_for_data(request_data)}"
    task_id = _slugify(_scalar(raw_task.get("task_id")) or f"{slug}-{index + 1}-{title}")
    phase_index = raw_task.get("phase_index", index)
    try:
        phase = int(phase_index)
    except (TypeError, ValueError):
        phase = index
    try:
        wsjf = float(raw_task.get("wsjf", req_wsjf * (0.85**phase)))
    except (TypeError, ValueError):
        wsjf = req_wsjf * (0.85**phase)
    acceptance = _string_items(raw_task.get("acceptance_criteria"))
    if not acceptance:
        acceptance = [
            f"{_request_id_for_data(request_data)} has an observable implementation outcome."
        ]
    dependencies = _string_items(raw_task.get("depends_on"))
    requested_status = _scalar(raw_task.get("status")).lower()
    if requested_status not in {"offered", "ready", "blocked"}:
        requested_status = "ready" if dependencies else "offered"
    blocked_reason = _scalar(raw_task.get("blocked_reason"))
    if requested_status == "blocked" and not blocked_reason:
        blocked_reason = "proposal_contains_unresolved_hold"
    elif requested_status == "ready" and not blocked_reason and dependencies:
        blocked_reason = f"Depends on: {', '.join(dependencies)}"

    request_authority = _request_authority_level(request_data["frontmatter"])
    proposed_authority = _scalar(raw_task.get("authority_level")) or request_authority
    if proposed_authority not in AUTHORITY_LEVELS:
        raise ValueError(f"invalid proposed authority_level: {proposed_authority!r}")
    if request_authority != "authoritative" and proposed_authority != request_authority:
        raise ValueError("task proposal exceeds or changes the request authority ceiling")
    return {
        "task_id": task_id,
        "title": title,
        "kind": _normalize_task_kind(raw_task.get("kind", "build")),
        "priority": _normalize_priority(raw_task.get("priority"), request_data),
        "wsjf": wsjf,
        "depends_on": dependencies,
        "phase_index": phase,
        "intent": _scalar(raw_task.get("intent")),
        "acceptance_criteria": acceptance,
        "effort_class": _normalize_effort_class(raw_task.get("effort_class")),
        "mutation_surface": _normalize_mutation_surface(raw_task.get("mutation_surface")),
        "quality_floor": _normalize_quality_floor(raw_task.get("quality_floor"), request_data),
        "target_paths": _string_items(raw_task.get("target_paths")),
        "routing_class": raw_task.get("routing_class", "unknown"),
        "requirement_vector": raw_task.get("requirement_vector", {}),
        "composition_tolerance": raw_task.get("composition_tolerance", "unknown"),
        "requirement_vector_validity_mask": raw_task.get(
            "requirement_vector_validity_mask",
            raw_task.get("validity_mask", {}),
        ),
        "route_envelope": raw_task.get("route_envelope"),
        "task_demand": raw_task.get("task_demand", {}),
        "status": requested_status,
        "blocked_reason": blocked_reason or None,
        "authority_level": proposed_authority,
    }


def _first_scalar(frontmatter: dict[str, Any], field_names: tuple[str, ...]) -> str:
    for field_name in field_names:
        value = _scalar(frontmatter.get(field_name))
        if value:
            return value
    return ""


def _first_values(frontmatter: dict[str, Any], field_names: tuple[str, ...]) -> list[str]:
    values: list[str] = []
    for field_name in field_names:
        for value in _string_list(frontmatter.get(field_name)):
            if value and value not in values:
                values.append(value)
    return values


def _authority_case(frontmatter: dict[str, Any]) -> str:
    return _scalar(frontmatter.get("planning_case")) or _scalar(frontmatter.get("authority_case"))


def _request_authority_level(frontmatter: dict[str, Any]) -> str:
    return _scalar(frontmatter.get("authority_level"))


def _parent_spec_for_request(request_data: dict[str, Any]) -> str:
    fm = request_data["frontmatter"]
    return (
        _scalar(fm.get("parent_spec"))
        or _scalar(fm.get("parent_plan"))
        or _scalar(request_data.get("path"))
    )


def _decomposition_admission_blockers(request_data: dict[str, Any]) -> list[str]:
    fm = request_data["frontmatter"]
    blockers: list[str] = []

    status = _scalar(fm.get("status"))
    if status != "accepted_for_planning":
        blockers.append(f"request_status_not_accepted_for_planning:{status or 'missing'}")

    receipt = _first_scalar(fm, CCTV_INTAKE_RECEIPT_FIELDS)
    if not receipt:
        blockers.append("missing_cctv_intake_receipt")

    admission_value = _first_scalar(fm, CCTV_INTAKE_ADMISSION_FIELDS)
    if not admission_value:
        blockers.append("missing_cctv_intake_verdict")
    elif admission_value not in CCTV_READY_ADMISSION_VALUES:
        blockers.append(f"cctv_intake_not_ready:{admission_value}")

    route_admission = _first_scalar(fm, CCTV_ROUTE_RESOURCE_ADMISSION_FIELDS)
    if not route_admission:
        blockers.append("missing_cctv_route_resource_admission")
    elif route_admission != "admitted":
        blockers.append(f"cctv_route_resource_not_admitted:{route_admission}")
    elif not _first_values(fm, CCTV_CAPABILITY_RECEIPT_FIELDS):
        blockers.append("missing_cctv_capability_receipts")

    authority = _authority_case(fm)
    if not authority:
        blockers.append("missing_authority_case")
    elif not AUTHORITY_CASE_RE.match(authority):
        blockers.append(f"invalid_authority_case:{authority}")

    authority_level = _request_authority_level(fm)
    if not authority_level:
        blockers.append("missing_authority_level")
    elif authority_level not in AUTHORITY_LEVELS:
        blockers.append(f"invalid_authority_level:{authority_level}")

    if not _parent_spec_for_request(request_data):
        blockers.append("missing_parent_lineage")

    has_bound_plan = bool(_scalar(fm.get("decomposition_plan_ref"))) and bool(
        _scalar(fm.get("decomposition_plan_sha256"))
    )
    current_plan_sha256 = _scalar(fm.get("decomposition_plan_sha256"))
    request_journals = _journals_for_request(request_data)
    known_task_ids = (
        _known_task_ids()
        if any(inspection.state == "committed" for inspection in request_journals)
        else set()
    )
    for inspection in request_journals:
        if inspection.state == "committed":
            missing_task_ids = sorted(set(inspection.task_ids) - known_task_ids)
            if missing_task_ids:
                blockers.append(
                    "committed_decomposition_projection_missing:"
                    f"{inspection.commit_id}:{','.join(missing_task_ids)}"
                )
            elif not (
                has_bound_plan
                and inspection.plan_sha256
                and current_plan_sha256 == inspection.plan_sha256
            ):
                blockers.append(f"decomposition_already_committed:{inspection.commit_id}")
        elif inspection.state == "invalid":
            blockers.append(
                f"decomposition_journal_invalid:{inspection.commit_id}:{inspection.reason_code}"
            )
        elif not has_bound_plan or not inspection.plan_sha256:
            blockers.append(f"prepared_decomposition_binding_missing:{inspection.commit_id}")
        elif current_plan_sha256 != inspection.plan_sha256:
            blockers.append(f"prepared_decomposition_binding_superseded:{inspection.commit_id}")
    for inspection in _unassociated_invalid_journals():
        blockers.append(
            f"unassociated_decomposition_journal_invalid:{inspection.commit_id}:"
            f"{inspection.reason_code}"
        )
    if not has_bound_plan and fm.get("provider_spend_authorized") is not True:
        blockers.append("provider_spend_not_authorized")

    return blockers


def _find_undecomposed_requests() -> list[Path]:
    journal_inspections = inspect_decomposition_journals(TASKS_DIR)
    identity_index = build_task_identity_index(TASKS_DIR)
    task_parents = set()
    task_ids = _known_task_ids(identity_index)
    for entry in identity_index.entries:
        if entry.task_id is None or entry.error_reason_code is not None:
            continue
        fm, _body = parse_frontmatter(entry.path)
        if _scalar(fm.get("remediates_request_id")):
            continue
        for field_name in ("parent_request", "parent_plan", "parent_spec"):
            for item in _string_list(fm.get(field_name)):
                task_parents.update(_task_parent_reference_keys(item))
    validate_task_identity_index(identity_index)

    undecomposed = []
    for f in sorted(REQUESTS_DIR.glob("*.md")):
        if f.suffix != ".md":
            continue
        fm, _body = parse_frontmatter(f)
        status = _scalar(fm.get("status"))
        request_keys = _request_keys(f, fm)
        request_journals = tuple(
            inspection
            for inspection in journal_inspections
            if request_keys & _journal_request_keys(inspection)
        )
        if any(inspection.state != "committed" for inspection in request_journals):
            undecomposed.append(f)
            continue
        committed_journals = tuple(
            inspection for inspection in request_journals if inspection.state == "committed"
        )
        if committed_journals:
            if any(set(inspection.task_ids) - task_ids for inspection in committed_journals):
                undecomposed.append(f)
            continue
        has_plan_binding = bool(_scalar(fm.get("decomposition_plan_ref"))) or bool(
            _scalar(fm.get("decomposition_plan_sha256"))
        )
        if has_plan_binding:
            try:
                plan = _decompose_from_bound_plan(_read_request(f))
                state = decomposition_commit_state(plan, TASKS_DIR)
            except (OSError, ValueError):
                undecomposed.append(f)
                continue
            if state == "committed":
                continue
            if state == "prepared":
                undecomposed.append(f)
                continue
            if status != "accepted_for_planning":
                continue
            undecomposed.append(f)
            continue
        if status != "accepted_for_planning":
            continue
        downstream_tasks = _string_list(fm.get("downstream_tasks"))
        if downstream_tasks and any(task_id in task_ids for task_id in downstream_tasks):
            continue
        if request_keys & task_parents:
            continue
        undecomposed.append(f)
    return undecomposed


def _parse_scan_limit(cli_limit: int | None, env_value: str | None) -> int | None:
    value: int | str | None = cli_limit
    if value is None:
        value = env_value
    if value is None or str(value).strip() == "":
        return None
    try:
        limit = int(value)
    except (TypeError, ValueError) as exc:
        raise ValueError(f"scan limit must be a positive integer, got {value!r}") from exc
    if limit < 1:
        raise ValueError(f"scan limit must be a positive integer, got {value!r}")
    return limit


def _limit_scan_requests(requests: list[Path], limit: int | None) -> list[Path]:
    if limit is None:
        return requests
    return requests[:limit]


def _decompose_with_llm(request_data: dict) -> RequestDecomposition | None:
    """Call LLM to decompose. Returns None on failure (fail-closed)."""
    try:
        from shared.config import LITELLM_KEY, MODELS

        model = MODELS.get("balanced", "balanced")
    except Exception:
        model = "balanced"
        LITELLM_KEY = os.environ.get("LITELLM_API_KEY", "")

    fm = request_data["frontmatter"]
    fm.get("title", request_data["filename"])[:60]
    req_wsjf = float(fm.get("wsjf", "5.0") or "5.0")
    req_priority = fm.get("priority", "medium")
    authority = _authority_case(fm)
    parent_spec = _parent_spec_for_request(request_data)
    slug = request_data["filename"].replace(".md", "").replace("REQ-", "").lower()[:30]

    try:
        import litellm

        response = litellm.completion(
            model=f"litellm_proxy/{model}",
            messages=[
                {"role": "system", "content": DECOMPOSITION_PROMPT},
                {
                    "role": "user",
                    "content": (
                        f"{_request_prompt_context(request_data)}\n\n"
                        f"Parent WSJF: {req_wsjf}\n"
                        f"Priority: {req_priority}\n"
                        f"Authority case: {authority}\n"
                        f"Request filename: {request_data['filename']}\n"
                        f"Slug prefix: {slug}\n"
                    ),
                },
            ],
            response_format={"type": "json_object"},
            timeout=60,
            api_base="http://localhost:4000",
            api_key=LITELLM_KEY,
        )

        content = _completion_content(response)
        data = _json_object_from_completion(content)
        tasks_data = data.get("tasks", [])
        if not isinstance(tasks_data, list) or not tasks_data:
            raise ValueError("LLM response did not contain a non-empty tasks array")

        tasks = []
        for index, t in enumerate(tasks_data):
            normalized = _coerce_llm_task(
                t,
                request_data=request_data,
                slug=slug,
                req_wsjf=req_wsjf,
                index=index,
            )
            tasks.append(
                TaskSpec(
                    task_id=normalized["task_id"],
                    title=normalized["title"],
                    kind=normalized["kind"],
                    priority=normalized["priority"],
                    wsjf=normalized["wsjf"],
                    depends_on=normalized["depends_on"],
                    phase_index=normalized["phase_index"],
                    parent_request=request_data["filename"],
                    authority_case=authority,
                    parent_spec=parent_spec,
                    status=normalized["status"],
                    blocked_reason=normalized["blocked_reason"],
                    authority_level=normalized["authority_level"],
                    intent=normalized["intent"],
                    acceptance_criteria=normalized["acceptance_criteria"],
                    effort_class=normalized["effort_class"],
                    mutation_surface=normalized["mutation_surface"],
                    quality_floor=normalized["quality_floor"],
                    target_paths=normalized["target_paths"],
                    routing_class=normalized["routing_class"],
                    requirement_vector=normalized["requirement_vector"],
                    composition_tolerance=normalized["composition_tolerance"],
                    requirement_vector_validity_mask=normalized["requirement_vector_validity_mask"],
                    route_envelope=normalized["route_envelope"],
                    task_demand=normalized["task_demand"],
                )
            )

        return RequestDecomposition(
            request_id=slug,
            request_path=str(request_data["path"]),
            request_source_sha256=_scalar(request_data.get("source_sha256")) or None,
            decomposition_model=model,
            tasks=tasks,
        )

    except Exception as e:
        _log.error("LLM decomposition failed: %s", e)
        return None


def _decompose_from_bound_plan(
    request_data: dict[str, Any],
) -> RequestDecompositionPlan:
    frontmatter = request_data["frontmatter"]
    raw_ref = _scalar(frontmatter.get("decomposition_plan_ref"))
    expected_hash = _scalar(frontmatter.get("decomposition_plan_sha256"))
    if not raw_ref or not re.fullmatch(r"[0-9a-f]{64}", expected_hash):
        raise ValueError(
            "bound decomposition requires decomposition_plan_ref and a lowercase SHA-256"
        )

    request_path = Path(str(request_data["path"])).expanduser()
    plan_path = Path(raw_ref).expanduser()
    if not plan_path.is_absolute():
        plan_path = request_path.parent / plan_path
    stat = plan_path.stat()
    if stat.st_size > MAX_DECOMPOSITION_PLAN_BYTES:
        raise ValueError("bound decomposition plan exceeds the size limit")
    plan_bytes = plan_path.read_bytes()
    if hashlib.sha256(plan_bytes).hexdigest() != expected_hash:
        raise ValueError("bound decomposition plan hash mismatch")
    loaded = yaml.safe_load(plan_bytes)
    if isinstance(loaded, dict) and loaded.get("schema") == HISTORICAL_DECOMPOSITION_PLAN_SCHEMA:
        raise BoundDecompositionHold(
            "historical_decomposition_genesis_correction_required",
            "historical_decomposition_plan_v1_requires_explicit_s0_correction",
        )
    plan = RequestDecompositionPlan.model_validate(loaded)
    if plan.request_id != _request_id_for_data(request_data):
        raise ValueError("bound decomposition request identity mismatch")
    if Path(plan.request_path).expanduser().resolve() != request_path.resolve():
        raise ValueError("bound decomposition request path mismatch")
    request_authority = _request_authority_level(frontmatter)
    if request_authority not in {"authoritative", plan.authority_level}:
        raise ValueError("bound decomposition exceeds the request authority ceiling")
    return plan


def _decompose_request(
    request_data: dict[str, Any],
    *,
    provider_allowed: bool = True,
) -> RequestDecomposition | RequestDecompositionPlan | None:
    frontmatter = request_data["frontmatter"]
    has_plan_ref = bool(_scalar(frontmatter.get("decomposition_plan_ref")))
    has_plan_hash = bool(_scalar(frontmatter.get("decomposition_plan_sha256")))
    if has_plan_ref or has_plan_hash:
        try:
            return _decompose_from_bound_plan(request_data)
        except BoundDecompositionHold:
            raise
        except Exception as exc:
            _log.error("Bound decomposition plan failed validation: %s", exc)
            return None
    if not provider_allowed:
        raise ValueError("provider_free_dry_run_requires_bound_decomposition_plan")
    decomposition = _decompose_with_llm(request_data)
    if decomposition is not None:
        source_sha256 = _scalar(request_data.get("source_sha256"))
        if source_sha256:
            decomposition.request_source_sha256 = source_sha256
    return decomposition


def _decomposition_task_status(task: TaskSpec | Any) -> str:
    status = getattr(task, "status", None)
    if isinstance(status, str):
        return status
    initial = getattr(task, "initial_projection", None)
    return str(getattr(initial, "status", "unknown"))


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Decompose requests into cc-tasks",
        epilog=(
            "Environment: HAPAX_REQUEST_DECOMPOSE_LIMIT caps admitted scan attempts. "
            "Decomposition failures append support-only HOLD receipts and never mint tasks."
        ),
    )
    parser.add_argument("request_path", nargs="?", help="Path to a specific request")
    parser.add_argument(
        "--scan",
        action="store_true",
        help="Find and decompose all undecomposed requests",
    )
    parser.add_argument("--dry-run", action="store_true", help="Show what would be created")
    parser.add_argument(
        "--limit",
        type=int,
        help=(
            "Maximum accepted requests to decompose in this scan. Defaults to "
            f"${SCAN_LIMIT_ENV} when set."
        ),
    )
    args = parser.parse_args()

    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")

    if args.scan:
        try:
            scan_limit = _parse_scan_limit(args.limit, os.environ.get(SCAN_LIMIT_ENV))
        except ValueError as exc:
            parser.error(str(exc))
        try:
            undecomposed = _find_undecomposed_requests()
        except TaskStoreError as exc:
            _log.error("Task-store frontier refused request scan: %s", exc)
            return 1
        _log.info("Found %d undecomposed requests", len(undecomposed))
        if scan_limit is not None:
            _log.info(
                "Will attempt up to %d admitted requests from %d undecomposed requests",
                scan_limit,
                len(undecomposed),
            )
        total_tasks = 0
        skipped_existing = 0
        skipped_admission = 0
        failed_decomposition = 0
        admitted_attempts = 0
        remediation_created = 0
        remediation_existing = 0
        remediation_dry_run = 0
        for inspection in _unassociated_invalid_journals():
            remediation_result = _record_journal_reconciliation_hold(
                inspection,
                dry_run=args.dry_run,
            )
            if remediation_result == "created":
                remediation_created += 1
            elif remediation_result == "existing":
                remediation_existing += 1
            elif remediation_result == "dry_run":
                remediation_dry_run += 1
            _log.warning(
                "Decomposition journal %s requires global reconciliation (HOLD: %s)",
                inspection.commit_id,
                remediation_result,
            )
        for req_path in undecomposed:
            req_data = _read_request(req_path)
            blockers = _decomposition_admission_blockers(req_data)
            if blockers:
                skipped_admission += 1
                remediation_result = _record_decomposition_remediation(
                    req_data,
                    "admission_blocked",
                    blockers,
                    dry_run=args.dry_run,
                )
                if remediation_result == "created":
                    remediation_created += 1
                elif remediation_result == "existing":
                    remediation_existing += 1
                elif remediation_result == "dry_run":
                    remediation_dry_run += 1
                _log.warning(
                    "Skipping %s: decomposition admission blocked: %s (remediation: %s)",
                    req_path.name,
                    ", ".join(blockers),
                    remediation_result,
                )
                continue
            if scan_limit is not None and admitted_attempts >= scan_limit:
                break
            admitted_attempts += 1
            try:
                decomp = _decompose_request(
                    req_data,
                    provider_allowed=not args.dry_run,
                )
            except BoundDecompositionHold as exc:
                failed_decomposition += 1
                remediation_result = _record_decomposition_remediation(
                    req_data,
                    exc.failure_class,
                    [exc.reason_code],
                    dry_run=args.dry_run,
                )
                if remediation_result == "created":
                    remediation_created += 1
                elif remediation_result == "existing":
                    remediation_existing += 1
                elif remediation_result == "dry_run":
                    remediation_dry_run += 1
                _log.warning(
                    "Bound historical plan held %s (remediation: %s)",
                    req_path.name,
                    remediation_result,
                )
                continue
            except ValueError as exc:
                failed_decomposition += 1
                _log.warning("Provider-free dry-run held %s: %s", req_path.name, exc)
                continue
            if decomp is None:
                failed_decomposition += 1
                remediation_result = _record_decomposition_remediation(
                    req_data,
                    "llm_failed",
                    ["llm_decomposition_failed"],
                    dry_run=args.dry_run,
                )
                if remediation_result == "created":
                    remediation_created += 1
                elif remediation_result == "existing":
                    remediation_existing += 1
                elif remediation_result == "dry_run":
                    remediation_dry_run += 1
                _log.warning(
                    "Failed to decompose %s (fail-closed; remediation: %s)",
                    req_path.name,
                    remediation_result,
                )
                continue
            if args.dry_run:
                try:
                    paths = write_decomposition(decomp, TASKS_DIR, dry_run=True)
                except (FileExistsError, OSError, TaskStoreError, ValueError) as exc:
                    failed_decomposition += 1
                    _log.warning("Dry-run validation failed for %s: %s", req_path.name, exc)
                    continue
                _log.info("DRY RUN: %s → %d tasks", req_path.name, len(decomp.tasks))
                for t in decomp.tasks:
                    _log.info(
                        "  %s (WSJF %.1f, %s)",
                        t.task_id,
                        t.wsjf,
                        _decomposition_task_status(t),
                    )
                _log.info("  validated postimages: %d", len(paths))
                total_tasks += len(decomp.tasks)
            else:
                try:
                    paths = write_decomposition(decomp, TASKS_DIR)
                except (FileExistsError, TaskStoreError, ValueError) as exc:
                    identity_conflict = isinstance(exc, FileExistsError) or (
                        isinstance(exc, TaskStoreError)
                        and exc.reason_code
                        in {
                            "task_identity_write_identity_exists",
                            "task_identity_write_legacy_alias_collision",
                            "task_identity_write_path_exists",
                            "task_identity_write_path_occupied_by_other_identity",
                        }
                    )
                    validation_refused = not identity_conflict
                    if validation_refused:
                        failed_decomposition += 1
                    else:
                        skipped_existing += 1
                    remediation_result = _record_decomposition_remediation(
                        req_data,
                        "write_validation_refused" if validation_refused else "write_conflict",
                        [
                            f"decomposition_validation_refused:{exc}"
                            if validation_refused
                            else f"task_write_conflict:{exc}"
                        ],
                        dry_run=args.dry_run,
                    )
                    if remediation_result == "created":
                        remediation_created += 1
                    elif remediation_result == "existing":
                        remediation_existing += 1
                    elif remediation_result == "dry_run":
                        remediation_dry_run += 1
                    _log.warning(
                        "Skipping %s: %s (remediation: %s)",
                        req_path.name,
                        exc,
                        remediation_result,
                    )
                    continue
                _log.info("Wrote %d tasks for %s", len(paths), req_path.name)
                total_tasks += len(paths)
        _log.info(
            "Total: %d tasks created from %d admitted attempts "
            "(%d backlog requests, %d skipped existing)",
            total_tasks,
            admitted_attempts,
            len(undecomposed),
            skipped_existing,
        )
        if skipped_admission:
            _log.info(
                "%d selected requests held by decomposition admission gate",
                skipped_admission,
            )
        if failed_decomposition:
            _log.info("%d admitted requests failed decomposition", failed_decomposition)
        if remediation_created or remediation_existing or remediation_dry_run:
            _log.info(
                "Decomposition HOLD receipts: %d created, %d existing, %d dry-run",
                remediation_created,
                remediation_existing,
                remediation_dry_run,
            )
        return 0

    if args.request_path:
        req_path = Path(args.request_path)
        if not req_path.exists():
            _log.error("Request not found: %s", req_path)
            return 1
        req_data = _read_request(req_path)
        blockers = _decomposition_admission_blockers(req_data)
        if blockers:
            remediation_result = _record_decomposition_remediation(
                req_data,
                "admission_blocked",
                blockers,
                dry_run=args.dry_run,
            )
            _log.error(
                "Decomposition admission blocked for %s: %s (HOLD: %s, next: %s)",
                req_path.name,
                ", ".join(blockers),
                remediation_result,
                _remediation_next_action(remediation_result),
            )
            return 1
        try:
            decomp = _decompose_request(
                req_data,
                provider_allowed=not args.dry_run,
            )
        except BoundDecompositionHold as exc:
            remediation_result = _record_decomposition_remediation(
                req_data,
                exc.failure_class,
                [exc.reason_code],
                dry_run=args.dry_run,
            )
            _log.error(
                "Bound historical decomposition held (HOLD: %s, next: %s)",
                remediation_result,
                _remediation_next_action(remediation_result),
            )
            return 1
        except ValueError as exc:
            _log.error("Provider-free dry-run held: %s", exc)
            return 1
        if decomp is None:
            remediation_result = _record_decomposition_remediation(
                req_data,
                "llm_failed",
                ["llm_decomposition_failed"],
                dry_run=args.dry_run,
            )
            _log.error(
                "Decomposition failed (fail-closed; HOLD: %s, next: %s)",
                remediation_result,
                _remediation_next_action(remediation_result),
            )
            return 1
        if args.dry_run:
            try:
                paths = write_decomposition(decomp, TASKS_DIR, dry_run=True)
            except (FileExistsError, OSError, TaskStoreError, ValueError) as exc:
                _log.error("Decomposition dry-run validation failed: %s", exc)
                return 1
            _log.info("DRY RUN: %d tasks", len(decomp.tasks))
            for t in decomp.tasks:
                _log.info("  %s: %s (WSJF %.1f)", t.task_id, t.title, t.wsjf)
            _log.info("Validated %d exact task postimages", len(paths))
            return 0
        try:
            paths = write_decomposition(decomp, TASKS_DIR)
        except (FileExistsError, TaskStoreError, ValueError) as exc:
            identity_conflict = isinstance(exc, FileExistsError) or (
                isinstance(exc, TaskStoreError)
                and exc.reason_code
                in {
                    "task_identity_write_identity_exists",
                    "task_identity_write_legacy_alias_collision",
                    "task_identity_write_path_exists",
                    "task_identity_write_path_occupied_by_other_identity",
                }
            )
            validation_refused = not identity_conflict
            remediation_result = _record_decomposition_remediation(
                req_data,
                "write_validation_refused" if validation_refused else "write_conflict",
                [
                    f"decomposition_validation_refused:{exc}"
                    if validation_refused
                    else f"task_write_conflict:{exc}"
                ],
                dry_run=args.dry_run,
            )
            _log.error(
                "Decomposition write failed: %s (HOLD: %s, next: %s)",
                exc,
                remediation_result,
                _remediation_next_action(remediation_result),
            )
            return 1
        _log.info("Wrote %d tasks", len(paths))
        return 0

    parser.print_help()
    return 1


if __name__ == "__main__":
    sys.exit(main())
