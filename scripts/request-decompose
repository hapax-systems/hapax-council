#!/usr/bin/env python3
"""Decompose an accepted request into cc-tasks via LLM.

Usage:
    uv run python scripts/request-decompose <request_path> [--dry-run]
    uv run python scripts/request-decompose --scan [--dry-run]

Single request mode: reads the request, calls LLM for decomposition,
writes tasks atomically.

Scan mode: finds all accepted_for_planning requests with zero downstream
tasks and decomposes each.
"""

from __future__ import annotations

import argparse
import json
import logging
import os
import re
import sys
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT))

from agents.request_decomposer.models import RequestDecomposition, TaskSpec
from agents.request_decomposer.writer import write_decomposition
from shared.frontmatter import parse_frontmatter

_log = logging.getLogger(__name__)

REQUESTS_DIR = Path.home() / "Documents/Personal/20-projects/hapax-requests/active"
TASKS_DIR = Path.home() / "Documents/Personal/20-projects/hapax-cc-tasks"
SCAN_LIMIT_ENV = "HAPAX_REQUEST_DECOMPOSE_LIMIT"
AUTHORITY_CASE_RE = re.compile(r"^CASE-[A-Z0-9-]+$")
CCTV_READY_ADMISSION_VALUES = {"ready_to_plan", "advance", "admitted"}
CCTV_INTAKE_RECEIPT_FIELDS = (
    "cctv_intake_receipt",
    "cctv_intake_receipt_path",
    "cctv_receipt",
    "intake_receipt",
)
CCTV_INTAKE_ADMISSION_FIELDS = (
    "cctv_intake_verdict",
    "intake_verdict",
    "cctv_verdict",
    "cctv_intake_recommendation",
    "intake_recommendation",
)

DECOMPOSITION_PROMPT = """\
You are the Hapax request decomposition engine. Given a request note,
produce the complete set of cc-tasks needed to fulfill it.

Return a JSON object with key "tasks" containing an array of task objects.
Each task object must have these fields:
- task_id: slug (e.g., "req-slug-phase1-verb-noun")
- title: concrete deliverable title
- kind: "build" | "operator_action" | "research_packet" | "verification"
- priority: "p0" | "p1" | "p2" | "p3"
- wsjf: float (parent WSJF * 0.85^phase_index for unlisted phases)
- depends_on: list of task_id strings from THIS decomposition
- phase_index: int (0 = first phase)
- intent: 1-3 sentences describing the work
- acceptance_criteria: list of concrete, testable criteria strings
- effort_class: "standard" | "high" | "max"
- mutation_surface: "none" | "vault_docs" | "source" | "runtime" | "public" | "provider_spend"
- quality_floor: "deterministic_ok" | "frontier_review_required" | "frontier_required"

Rules:
1. EVERY task the request needs must appear. No stubs.
2. Dependencies must be explicit via depends_on.
3. Acceptance criteria must be observable/testable.
4. If the request has explicit phases, use them. If not, infer from scope.
5. Generate 1-8 tasks. If >8 needed, the request should be split.
"""


def _read_request(path: Path) -> dict:
    text = path.read_text(encoding="utf-8")
    fm, body = parse_frontmatter(text)
    return {
        "path": str(path),
        "filename": path.name,
        "frontmatter": fm,
        "body": body or text,
    }


def _scalar(value: Any) -> str:
    if value is None:
        return ""
    if isinstance(value, list):
        return ""
    text = str(value).strip()
    return "" if text in {"null", "None", "~"} else text


def _string_list(value: Any) -> list[str]:
    if value is None:
        return []
    if isinstance(value, list):
        return [_scalar(item) for item in value if _scalar(item)]
    text = _scalar(value)
    if not text:
        return []
    if text.startswith("[") and text.endswith("]"):
        return [part.strip().strip("'\"") for part in text[1:-1].split(",") if part.strip()]
    return [text]


def _request_keys(path: Path, frontmatter: dict[str, Any]) -> set[str]:
    keys = {str(path), path.name, path.stem}
    request_id = _scalar(frontmatter.get("request_id"))
    if request_id:
        keys.add(request_id)
    return keys


def _normalize_mutation_surface(value: Any) -> str:
    text = _scalar(value) or "source"
    aliases = {
        "vault": "vault_docs",
        "docs": "vault_docs",
        "system": "runtime",
        "external": "public",
    }
    normalized = aliases.get(text, text)
    allowed = {"none", "vault_docs", "source", "runtime", "public", "provider_spend"}
    return normalized if normalized in allowed else "source"


def _first_scalar(frontmatter: dict[str, Any], field_names: tuple[str, ...]) -> str:
    for field_name in field_names:
        value = _scalar(frontmatter.get(field_name))
        if value:
            return value
    return ""


def _authority_case(frontmatter: dict[str, Any]) -> str:
    return _scalar(frontmatter.get("planning_case")) or _scalar(frontmatter.get("authority_case"))


def _parent_spec_for_request(request_data: dict[str, Any]) -> str:
    fm = request_data["frontmatter"]
    return (
        _scalar(fm.get("parent_spec"))
        or _scalar(fm.get("parent_plan"))
        or _scalar(request_data.get("path"))
    )


def _decomposition_admission_blockers(request_data: dict[str, Any]) -> list[str]:
    fm = request_data["frontmatter"]
    blockers: list[str] = []

    receipt = _first_scalar(fm, CCTV_INTAKE_RECEIPT_FIELDS)
    if not receipt:
        blockers.append("missing_cctv_intake_receipt")

    admission_value = _first_scalar(fm, CCTV_INTAKE_ADMISSION_FIELDS)
    if not admission_value:
        blockers.append("missing_cctv_intake_verdict")
    elif admission_value not in CCTV_READY_ADMISSION_VALUES:
        blockers.append(f"cctv_intake_not_ready:{admission_value}")

    authority = _authority_case(fm)
    if not authority:
        blockers.append("missing_authority_case")
    elif not AUTHORITY_CASE_RE.match(authority):
        blockers.append(f"invalid_authority_case:{authority}")

    if not _parent_spec_for_request(request_data):
        blockers.append("missing_parent_lineage")

    return blockers


def _find_undecomposed_requests() -> list[Path]:
    task_parents = set()
    for d in [TASKS_DIR / "active", TASKS_DIR / "closed"]:
        if not d.is_dir():
            continue
        for f in sorted(d.glob("*.md")):
            if f.suffix != ".md":
                continue
            fm, _body = parse_frontmatter(f)
            for field_name in ("parent_request", "parent_plan", "parent_spec"):
                task_parents.update(_string_list(fm.get(field_name)))

    undecomposed = []
    for f in sorted(REQUESTS_DIR.glob("*.md")):
        if f.suffix != ".md":
            continue
        fm, _body = parse_frontmatter(f)
        if _scalar(fm.get("status")) != "accepted_for_planning":
            continue
        if _string_list(fm.get("downstream_tasks")):
            continue
        keys = _request_keys(f, fm)
        if keys & task_parents:
            continue
        has_linked = any(any(key in parent for key in keys) for parent in task_parents)
        if not has_linked:
            undecomposed.append(f)
    return undecomposed


def _parse_scan_limit(cli_limit: int | None, env_value: str | None) -> int | None:
    value: int | str | None = cli_limit
    if value is None:
        value = env_value
    if value is None or str(value).strip() == "":
        return None
    try:
        limit = int(value)
    except (TypeError, ValueError) as exc:
        raise ValueError(f"scan limit must be a positive integer, got {value!r}") from exc
    if limit < 1:
        raise ValueError(f"scan limit must be a positive integer, got {value!r}")
    return limit


def _limit_scan_requests(requests: list[Path], limit: int | None) -> list[Path]:
    if limit is None:
        return requests
    return requests[:limit]


def _decompose_with_llm(request_data: dict) -> RequestDecomposition | None:
    """Call LLM to decompose. Returns None on failure (fail-closed)."""
    try:
        from shared.config import LITELLM_KEY, MODELS

        model = MODELS.get("balanced", "balanced")
    except Exception:
        model = "balanced"
        LITELLM_KEY = os.environ.get("LITELLM_API_KEY", "")

    fm = request_data["frontmatter"]
    fm.get("title", request_data["filename"])[:60]
    req_wsjf = float(fm.get("wsjf", "5.0") or "5.0")
    req_priority = fm.get("priority", "medium")
    authority = _authority_case(fm)
    parent_spec = _parent_spec_for_request(request_data)
    slug = request_data["filename"].replace(".md", "").replace("REQ-", "").lower()[:30]

    try:
        import litellm

        response = litellm.completion(
            model=f"litellm_proxy/{model}",
            messages=[
                {"role": "system", "content": DECOMPOSITION_PROMPT},
                {
                    "role": "user",
                    "content": (
                        f"Request: {request_data['body'][:8000]}\n\n"
                        f"Parent WSJF: {req_wsjf}\n"
                        f"Priority: {req_priority}\n"
                        f"Authority case: {authority}\n"
                        f"Request filename: {request_data['filename']}\n"
                        f"Slug prefix: {slug}\n"
                    ),
                },
            ],
            response_format={"type": "json_object"},
            timeout=60,
            api_base="http://localhost:4000",
            api_key=LITELLM_KEY,
        )

        content = response.choices[0].message.content or ""
        content = content.strip()
        if content.startswith("```"):
            content = content.split("\n", 1)[1] if "\n" in content else content
            if content.endswith("```"):
                content = content[:-3].strip()
        data = json.loads(content)
        tasks_data = data.get("tasks", [])

        tasks = []
        for t in tasks_data:
            tasks.append(
                TaskSpec(
                    task_id=t["task_id"],
                    title=t["title"],
                    kind=t.get("kind", "build"),
                    priority=t.get("priority", "p2"),
                    wsjf=float(t.get("wsjf", req_wsjf * 0.85)),
                    depends_on=t.get("depends_on", []),
                    phase_index=t.get("phase_index", 0),
                    parent_request=request_data["filename"],
                    authority_case=authority,
                    parent_spec=parent_spec,
                    status="blocked" if t.get("depends_on") else "offered",
                    blocked_reason=(
                        f"Depends on: {', '.join(t['depends_on'])}" if t.get("depends_on") else None
                    ),
                    intent=t.get("intent", ""),
                    acceptance_criteria=t.get("acceptance_criteria", ["TBD"]),
                    effort_class=t.get("effort_class", "standard"),
                    mutation_surface=_normalize_mutation_surface(t.get("mutation_surface")),
                    quality_floor=t.get("quality_floor", "deterministic_ok"),
                )
            )

        return RequestDecomposition(
            request_id=slug,
            request_path=str(request_data["path"]),
            decomposition_model=model,
            tasks=tasks,
        )

    except Exception as e:
        _log.error("LLM decomposition failed: %s", e)
        return None


def main() -> int:
    parser = argparse.ArgumentParser(description="Decompose requests into cc-tasks")
    parser.add_argument("request_path", nargs="?", help="Path to a specific request")
    parser.add_argument(
        "--scan", action="store_true", help="Find and decompose all undecomposed requests"
    )
    parser.add_argument("--dry-run", action="store_true", help="Show what would be created")
    parser.add_argument(
        "--limit",
        type=int,
        help=(
            "Maximum accepted requests to decompose in this scan. Defaults to "
            f"${SCAN_LIMIT_ENV} when set."
        ),
    )
    args = parser.parse_args()

    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")

    if args.scan:
        try:
            scan_limit = _parse_scan_limit(args.limit, os.environ.get(SCAN_LIMIT_ENV))
        except ValueError as exc:
            parser.error(str(exc))
        undecomposed = _find_undecomposed_requests()
        _log.info("Found %d undecomposed requests", len(undecomposed))
        selected = _limit_scan_requests(undecomposed, scan_limit)
        if scan_limit is not None:
            _log.info(
                "Selected %d of %d undecomposed requests for this run (limit %d)",
                len(selected),
                len(undecomposed),
                scan_limit,
            )
        total_tasks = 0
        skipped_existing = 0
        skipped_admission = 0
        for req_path in selected:
            req_data = _read_request(req_path)
            blockers = _decomposition_admission_blockers(req_data)
            if blockers:
                skipped_admission += 1
                _log.warning(
                    "Skipping %s: decomposition admission blocked: %s",
                    req_path.name,
                    ", ".join(blockers),
                )
                continue
            decomp = _decompose_with_llm(req_data)
            if decomp is None:
                _log.warning("Failed to decompose %s (fail-closed)", req_path.name)
                continue
            if args.dry_run:
                _log.info("DRY RUN: %s → %d tasks", req_path.name, len(decomp.tasks))
                for t in decomp.tasks:
                    _log.info("  %s (WSJF %.1f, %s)", t.task_id, t.wsjf, t.status)
                total_tasks += len(decomp.tasks)
            else:
                try:
                    paths = write_decomposition(decomp, TASKS_DIR)
                except FileExistsError as exc:
                    skipped_existing += 1
                    _log.warning("Skipping %s: %s", req_path.name, exc)
                    continue
                _log.info("Wrote %d tasks for %s", len(paths), req_path.name)
                total_tasks += len(paths)
        _log.info(
            "Total: %d tasks created from %d selected requests "
            "(%d backlog requests, %d skipped existing)",
            total_tasks,
            len(selected),
            len(undecomposed),
            skipped_existing,
        )
        if skipped_admission:
            _log.info("%d selected requests held by decomposition admission gate", skipped_admission)
        return 0

    if args.request_path:
        req_path = Path(args.request_path)
        if not req_path.exists():
            _log.error("Request not found: %s", req_path)
            return 1
        req_data = _read_request(req_path)
        blockers = _decomposition_admission_blockers(req_data)
        if blockers:
            _log.error(
                "Decomposition admission blocked for %s: %s",
                req_path.name,
                ", ".join(blockers),
            )
            return 1
        decomp = _decompose_with_llm(req_data)
        if decomp is None:
            _log.error("Decomposition failed (fail-closed)")
            return 1
        if args.dry_run:
            _log.info("DRY RUN: %d tasks", len(decomp.tasks))
            for t in decomp.tasks:
                _log.info("  %s: %s (WSJF %.1f)", t.task_id, t.title, t.wsjf)
            return 0
        paths = write_decomposition(decomp, TASKS_DIR)
        _log.info("Wrote %d tasks", len(paths))
        return 0

    parser.print_help()
    return 1


if __name__ == "__main__":
    sys.exit(main())
