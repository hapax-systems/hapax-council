# A wall receipt without resets_at stays authoritative this long after
# detection; afterwards it is treated as recovered rather than pinning the
# platform exhausted forever.
WALL_WITHOUT_RESET_TTL = timedelta(hours=24)

VRAM_RED_FRACTION = 0.99
VRAM_YELLOW_FRACTION = 0.90
LOAD_RED_PER_CPU = 8.0
LOAD_YELLOW_PER_CPU = 4.0


def role_platform(role: str) -> str:
    """Map a lane role (relay receipt filename stem) to its platform."""

    normalized = role.lower().replace("_", "-")
    if (
        normalized in {"cx-glmcp", "codex-glmcp", "glmcp"}
        or normalized.startswith("cx-glmcp")
        or normalized.startswith("codex-glmcp")
        or normalized.startswith("glm-")
        or normalized.startswith("glmcp-")
    ):
        return "glmcp"
    if normalized.startswith("cx-") or normalized.startswith("codex"):
        return "codex"
    if normalized.startswith("gemini") or normalized.startswith("gm-"):
        return "retired-gemini"
    if normalized.startswith("agy"):
        return "agy"
    if normalized.startswith("antigrav"):
        return "antigrav"
    if normalized.startswith("vbe-") or normalized.startswith("vibe"):
        return "vibe"
    return "claude"


def _parse_flat_yaml(text: str) -> dict[str, str]:
    """Parse the flat ``key: value`` quota-wall receipts without a YAML dep."""

    fields: dict[str, str] = {}
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or ":" not in line:
            continue
        key, _, value = line.partition(":")
        fields[key.strip()] = value.strip().strip("'\"")
    return fields


def _parse_flat_yaml_strict(
    text: str,
    *,
    allowed_fields: frozenset[str] = GLMCP_ADMISSION_FIELDS,
) -> tuple[dict[str, str], str | None]:
    """Parse flat admission receipts and reject ambiguous YAML-shaped input."""

    fields: dict[str, str] = {}
    for line_no, raw_line in enumerate(text.splitlines(), start=1):
        stripped = raw_line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if raw_line[:1].isspace() or stripped.startswith("-"):
            return {}, f"non-flat line {line_no}"
        if ":" not in raw_line:
            return {}, f"non key-value line {line_no}"
        key, _, value = raw_line.partition(":")
        normalized_key = key.strip()
        if not normalized_key:
            return {}, f"empty key on line {line_no}"
        if normalized_key not in allowed_fields:
            return {}, f"unsupported key on line {line_no}"
        if normalized_key in fields:
            return {}, f"duplicate key on line {line_no}"
        fields[normalized_key] = value.strip().strip("'\"")
    return fields, None


def _parse_utc(value: str) -> datetime | None:
    try:
        parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=UTC)
    return parsed.astimezone(UTC)


def _reason_code(reason: str) -> str:
    code = re.sub(r"[^a-z0-9]+", "-", reason.lower()).strip("-")
    return code[:80] or "ignored"


def _warn_ignored_glmcp_admission(path: Path, reason: str) -> str:
    receipt_label = _receipt_label(path)
    print(
        f"hapax-quota-telemetry-writer: ignoring GLMCP admission receipt {receipt_label}: "
        f"{reason}; recheck: {GLMCP_ADMISSION_RECHECK_COMMAND}; "
        f"{GLMCP_ADMISSION_RECOVERY_HINT}",
        file=sys.stderr,
    )
    return f"relay-receipt:{receipt_label}:ignored:{_reason_code(reason)}"


def _warn_ignored_glmcp_payg_spend(path: Path, reason: str) -> str:
    receipt_label = _receipt_label(path)
    print(
        f"hapax-quota-telemetry-writer: ignoring GLMCP PAYG spend receipt {receipt_label}: "
        f"{reason}; recheck: find ~/.cache/hapax/relay/receipts -maxdepth 1 "
        f"-name '{GLMCP_PAYG_SPEND_RECEIPT_GLOB}' -print",
        file=sys.stderr,
    )
    return f"relay-receipt:{receipt_label}:ignored:{_reason_code(reason)}"


def _warn_stripped_glmcp_payg_spend_task_hash(path: Path, task_hash: str) -> None:
    receipt_label = _receipt_label(path)
    print(
        "hapax-quota-telemetry-writer: stripped malformed optional task_hash from "
        f"GLMCP PAYG spend receipt {receipt_label}; spend still counts against cap; "
        f"task_hash={task_hash!r}",
        file=sys.stderr,
    )


def _glmcp_payg_spend_field_is_nullish(key: str, value: str) -> bool:
    return (
        key in GLMCP_PAYG_SPEND_NULLABLE_FIELDS
        and value.strip().strip("'\"").lower() in GLMCP_PAYG_SPEND_NULL_LITERALS
    )


def _glmcp_payg_budget_request(task_id: str) -> PaidRouteRequest:
    return PaidRouteRequest.model_validate(
        {
            "route_id": "glmcp.review.direct",
            "task_id": task_id,
            "provider": GLMCP_PAYG_BUDGET_PROVIDER,
            "profile": GLMCP_PAYG_BUDGET_PROFILE,
            "task_class": GLMCP_PAYG_BUDGET_TASK_CLASS,
            "quality_floor": GLMCP_PAYG_BUDGET_QUALITY_FLOOR,
            "estimated_cost_usd": GLMCP_PAYG_ESTIMATED_COST_USD,
            "capacity_pool": GLMCP_ADMISSION_PAYG_CAPACITY_POOL,
        }
    )


def _glmcp_payg_spend_gate_ledger(base: QuotaSpendLedger, *, now: datetime) -> QuotaSpendLedger:
    payload = base.model_dump(mode="json")
    payload["captured_at"] = now.isoformat().replace("+00:00", "Z")
    payload["generated_from"] = list(
        dict.fromkeys([*payload["generated_from"], "scripts/hapax-quota-telemetry-writer"])
    )
    return QuotaSpendLedger.model_validate(payload)


def _glmcp_payg_budget_decision(
    base: QuotaSpendLedger,
    *,
    now: datetime,
    task_id: str,
) -> PaidRouteEligibility:
    return evaluate_paid_route_eligibility(
        _glmcp_payg_spend_gate_ledger(base, now=now),
        _glmcp_payg_budget_request(task_id),
        now=now,
    )


def _glmcp_payg_budget_evidence(decision: PaidRouteEligibility) -> list[str]:
    evidence = [f"spend-gate:glmcp.review.direct:{decision.state}"]
    for ref in decision.evidence_refs:
        evidence.append(f"spend-gate-budget:{ref}")
    if decision.budget_id:
        evidence.append(f"spend-gate-budget:{decision.budget_id}")
    for reason in decision.blocking_reasons:
        evidence.append(f"spend-gate-blocker:{_reason_code(reason)}")
    return list(dict.fromkeys(evidence))


def _glmcp_payg_budget_reason(decision: PaidRouteEligibility) -> str:
    if decision.eligible:
        return (
            f"PAYG fallback passed paid-spend gate budget {decision.budget_id}; "
            "GLMCP remains receipt-bounded and budget-bounded"
        )
    blockers = "; ".join(decision.blocking_reasons) or decision.state
    return f"PAYG fallback refused by paid-spend gate: {blockers}"


def _payg_admission_matches_active_wall(
    admission: GlmcpAdmission,
    platform_walls: list[QuotaWall],
) -> bool:
    if (
        admission.endpoint != GLMCP_PAYG_ENDPOINT
        or not admission.quota_wall_evidence_ref
        or not admission.primary_error_class
    ):
        return False
    return any(
        wall.receipt_label == admission.quota_wall_evidence_ref
        and admission.primary_error_class in {wall.failure_class, wall.rate_limit_type}
        for wall in platform_walls
    )


def _payg_spend_receipt_witness_refs(receipt: SpendReceipt) -> set[str]:
    refs = {receipt.spend_id}
    match = re.fullmatch(r"spend-([0-9]{8}T[0-9]{6}Z)-glmcp-payg-review-(.+)", receipt.spend_id)
    if match is not None:
        stamp, suffix = match.groups()
        refs.add(f"glmcp-payg-spend-{stamp.lower()}-{suffix}.yaml")
    return refs


def _payg_admission_matching_spend_receipt(
    admission: GlmcpAdmission,
    receipts: list[SpendReceipt],
) -> SpendReceipt | None:
    if admission.endpoint != GLMCP_PAYG_ENDPOINT:
        return None
    return next(
        (
            receipt
            for receipt in receipts
            if admission.witness_ref in _payg_spend_receipt_witness_refs(receipt)
        ),
        None,
    )


def _payg_admission_has_validated_spend_receipt(
    admission: GlmcpAdmission,
    receipts: list[SpendReceipt],
) -> bool:
    return _payg_admission_matching_spend_receipt(admission, receipts) is not None


def _receipt_label(path: Path) -> str:
    name = path.name
    if CLAUDE_ADMISSION_SAFE_RECEIPT_NAME_RE.fullmatch(name) is not None:
        name_stem = name.removesuffix(".yaml")
        if (
            CLAUDE_ADMISSION_SECRETISH_RE.search(name_stem) is None
            and CLAUDE_ADMISSION_BILLINGISH_RE.search(name_stem) is None
            and CLAUDE_ADMISSION_LANE_PRESENCE_RE.search(name_stem) is None
        ):
            return name
        digest = hashlib.sha256(name.encode("utf-8", errors="replace")).hexdigest()[:16]
        return f"unsafe-receipt-name-sha256:{digest}"
    if (
        AGY_ADMISSION_SAFE_RECEIPT_NAME_RE.fullmatch(name)
        or GLMCP_ADMISSION_SAFE_RECEIPT_NAME_RE.fullmatch(name)
        or GLMCP_PAYG_SPEND_SAFE_RECEIPT_NAME_RE.fullmatch(name)
    ) and GLMCP_ADMISSION_SECRETISH_RE.search(name) is None:
        return name
    digest = hashlib.sha256(name.encode("utf-8", errors="replace")).hexdigest()[:16]
    return f"unsafe-receipt-name-sha256:{digest}"


def active_quota_walls(
    receipt_dir: Path,
    *,
    now: datetime,
) -> dict[str, list[QuotaWall]]:
    """Return platform -> wall evidence refs for unexpired quota-wall receipts."""

    walls: dict[str, list[QuotaWall]] = {}
    if not receipt_dir.is_dir():
        return walls
    for path in sorted(receipt_dir.glob("*-quota-wall.yaml")):
        fields = _parse_flat_yaml(path.read_text(encoding="utf-8"))
        if fields.get("status") != "quota_blocked":
            continue
        role = fields.get("role") or path.name.removesuffix("-quota-wall.yaml")
        resets_at = _parse_utc(fields.get("resets_at", ""))
        if resets_at is not None:
            if resets_at <= now:
                continue
        else:
            detected_at = _parse_utc(fields.get("detected_at", ""))
            if detected_at is None or now - detected_at > WALL_WITHOUT_RESET_TTL:
                continue
        platform = role_platform(role)
        if platform == "retired-gemini":
            print(
                "hapax-quota-telemetry-writer: WARNING ignoring retired Gemini "
                f"quota-wall receipt {path.name}; legacy Gemini CLI lanes are retired",
                file=sys.stderr,
            )
            continue
        failure_class = fields.get("failure_class") or "unknown"
        rate_limit_type = fields.get("rate_limit_type") or "unknown"
        walls.setdefault(platform, []).append(
            QuotaWall(
                evidence_ref=(
                    f"relay-receipt:{path.name}:failure_class:{failure_class}:"
                    f"rate_limit_type:{rate_limit_type}:resets_at:"
                    f"{fields.get('resets_at') or 'unknown'}"
                ),
                receipt_label=path.name,
                failure_class=failure_class,
                rate_limit_type=rate_limit_type,
            )
        )
    return walls


def _warn_ignored_agy_admission(path: Path, reason: str) -> str:
    receipt_label = _receipt_label(path)
    print(
        "hapax-quota-telemetry-writer: ignoring agy admission receipt: "
        f"validation failed; recheck: {AGY_ADMISSION_RECHECK_COMMAND}; "
        f"{AGY_ADMISSION_RECOVERY_HINT}",
        file=sys.stderr,
    )
    return f"relay-receipt:{receipt_label}:ignored:{_reason_code(reason)}"


def _warn_ignored_claude_admission(path: Path, reason: str) -> str:
    # Generic stderr (like agy) so a rejected receipt's field names/values never echo; the specific
    # reason survives only as a slugified code in the returned ignored evidence ref.
    receipt_label = _receipt_label(path)
    print(
        "hapax-quota-telemetry-writer: ignoring claude admission receipt: "
        f"validation failed; recheck: {CLAUDE_ADMISSION_RECHECK_COMMAND}; "
        f"{CLAUDE_ADMISSION_RECOVERY_HINT}",
        file=sys.stderr,
    )
    return f"relay-receipt:{receipt_label}:ignored:{_reason_code(reason)}"


def active_agy_admission_receipts(
    receipt_dir: Path,
    *,
    now: datetime,
) -> AgyAdmissionScan:
    """Return fresh positive agy route-specific admission evidence refs."""

    if not receipt_dir.is_dir():
        return AgyAdmissionScan(admissions=[], ignored_evidence_refs=[])
    refs: list[AgyAdmission] = []
    ignored_refs: list[str] = []

    def reject(path: Path, reason: str) -> None:
        ignored_refs.append(_warn_ignored_agy_admission(path, reason))

    for path in sorted(receipt_dir.glob(AGY_ADMISSION_RECEIPT_GLOB)):
        if AGY_ADMISSION_SAFE_RECEIPT_NAME_RE.fullmatch(path.name) is None:
            reject(path, "unsafe receipt name")
            continue
        try:
            raw_receipt = path.read_text(encoding="utf-8")
        except (OSError, UnicodeDecodeError) as exc:
            reject(path, f"unreadable receipt {type(exc).__name__}")
            continue
        fields, parse_error = _parse_flat_yaml_strict(
            raw_receipt,
            allowed_fields=AGY_ADMISSION_FIELDS,
        )
        if parse_error is not None:
            reject(path, parse_error)
            continue
        expected = {
            "schema": AGY_ADMISSION_SCHEMA,
            "status": "quota_available",
            "provider": AGY_ADMISSION_PROVIDER,
            "route_id": SUBSCRIPTION_ROUTES["agy"],
            "capacity_pool": AGY_ADMISSION_CAPACITY_POOL,
            "supported_tool": AGY_ADMISSION_SUPPORTED_TOOL,
            "model": AGY_ADMISSION_MODEL,
            "secret_source": AGY_ADMISSION_SECRET_SOURCE,
            "secret_value_persisted": "false",
            "prompt_or_output_persisted": "false",
            "billing_mode": AGY_ADMISSION_BILLING_MODE,
            "smoke_command": AGY_ADMISSION_SMOKE_COMMAND,
            "smoke_returncode": "0",
            "smoke_stdout_validated": "true",
            "positive_admission": "true",
        }
        failed = False
        for key, value in expected.items():
            if fields.get(key, "") != value:
                reject(path, f"{key} missing or unsupported; expected {value}")
                failed = True
                break
        if failed:
            continue
        receipt_evidence_ref = " ".join(fields.get("evidence_ref", "").strip().split())
        if (
            AGY_ADMISSION_EVIDENCE_REF_RE.fullmatch(receipt_evidence_ref) is None
            or AGY_ADMISSION_SECRETISH_RE.search(receipt_evidence_ref) is not None
        ):
            reject(path, "evidence_ref unsafe; expected sanitized agy smoke witness reference")
            continue
        observed_at = _parse_utc(fields.get("observed_at", "").strip())
        if observed_at is None:
            reject(path, "missing or malformed observed_at")
            continue
        if observed_at > now:
            reject(path, "observed_at is in the future")
            continue
        try:
            stale_after_seconds = int(fields.get("stale_after_seconds", "").strip())
        except ValueError:
            reject(path, "malformed stale_after_seconds")
            continue
        if stale_after_seconds <= 0:
            reject(path, "non-positive stale_after_seconds")
            continue
        if stale_after_seconds > AGY_ADMISSION_MAX_STALE_AFTER_SECONDS:
            reject(
                path,
                f"stale_after_seconds exceeds maximum {AGY_ADMISSION_MAX_STALE_AFTER_SECONDS}",
            )
            continue
        fresh_until = observed_at + timedelta(seconds=stale_after_seconds)
        if now >= fresh_until:
            reject(path, "receipt expired")
            continue
        refs.append(
            AgyAdmission(
                evidence_ref=(
                    "relay-receipt:"
                    f"{_receipt_label(path)}:witness:{receipt_evidence_ref}:"
                    f"supported_tool:{AGY_ADMISSION_SUPPORTED_TOOL}:"
                    f"model:{AGY_ADMISSION_MODEL}:"
                    f"observed_at:{observed_at.isoformat().replace('+00:00', 'Z')}:"
                    f"fresh_until:{fresh_until.isoformat().replace('+00:00', 'Z')}"
                ),
                fresh_until=fresh_until,
            )
        )
    return AgyAdmissionScan(admissions=refs, ignored_evidence_refs=ignored_refs)


def active_claude_admission_receipts(
    receipt_dir: Path,
    *,
    now: datetime,
) -> ClaudeAdmissionScan:
    """Return fresh positive claude subscription-quota admission evidence refs.

    Account-live subscription quota is proven ONLY by a short-lived sanitized admission receipt
    (scripts/hapax-claude-subscription-quota-admission), NEVER by lane/tmux/session presence. Each
    fresh receipt yields a composite evidence ref ending in :account-live-quota:observed so the
    availability guarantor attests; a secretish or lane/session-shaped witness is refused.
    """

    if not receipt_dir.is_dir():
        return ClaudeAdmissionScan(admissions=[], ignored_evidence_refs=[])
    refs: list[ClaudeAdmission] = []
    ignored_refs: list[str] = []

    def reject(path: Path, reason: str) -> None:
        ignored_refs.append(_warn_ignored_claude_admission(path, reason))

    for path in sorted(receipt_dir.glob(CLAUDE_ADMISSION_RECEIPT_GLOB)):
        if CLAUDE_ADMISSION_SAFE_RECEIPT_NAME_RE.fullmatch(path.name) is None:
            reject(path, "unsafe receipt name")
            continue
        receipt_name_stem = path.name.removesuffix(".yaml")
        if CLAUDE_ADMISSION_SECRETISH_RE.search(receipt_name_stem) is not None:
            reject(path, "receipt name names secretish value")
            continue
        if CLAUDE_ADMISSION_BILLINGISH_RE.search(receipt_name_stem) is not None:
            reject(path, "receipt name names billing or account identifier")
            continue
        if CLAUDE_ADMISSION_LANE_PRESENCE_RE.search(receipt_name_stem) is not None:
            reject(path, "receipt name names lane/session presence")
            continue
        try:
            raw_receipt = path.read_text(encoding="utf-8")
        except (OSError, UnicodeDecodeError) as exc:
            reject(path, f"unreadable receipt {type(exc).__name__}")
            continue
        fields, parse_error = _parse_flat_yaml_strict(
            raw_receipt,
            allowed_fields=CLAUDE_ADMISSION_FIELDS,
        )
        if parse_error is not None:
            reject(path, parse_error)
            continue
        expected = {
            "schema": CLAUDE_ADMISSION_SCHEMA,
            "status": "quota_available",
            "provider": CLAUDE_ADMISSION_PROVIDER,
            "route_id": SUBSCRIPTION_ROUTES["claude"],
            "capacity_pool": CLAUDE_ADMISSION_CAPACITY_POOL,
            "auth_surface": CLAUDE_ADMISSION_AUTH_SURFACE,
            "secret_source": CLAUDE_ADMISSION_SECRET_SOURCE,
            "secret_value_persisted": "false",
            "prompt_or_output_persisted": "false",
            "billing_mode": CLAUDE_ADMISSION_BILLING_MODE,
            "account_live_quota_observed": "true",
            "lane_presence_used_as_quota_evidence": "false",
            "positive_admission": "true",
        }
        failed = False
        for key, value in expected.items():
            if fields.get(key, "") != value:
                reject(path, f"{key} missing or unsupported; expected {value}")
                failed = True
                break
        if failed:
            continue
        observation = fields.get("observation", "").strip()
        if observation not in CLAUDE_ADMISSION_OBSERVATIONS:
            reject(path, "observation missing or unsupported")
            continue
        receipt_evidence_ref = " ".join(fields.get("evidence_ref", "").strip().split())
        if (
            CLAUDE_ADMISSION_EVIDENCE_REF_RE.fullmatch(receipt_evidence_ref) is None
            or CLAUDE_ADMISSION_SECRETISH_RE.search(receipt_evidence_ref) is not None
        ):
            reject(
                path, "evidence_ref unsafe; expected sanitized account-live observation reference"
            )
            continue
        if CLAUDE_ADMISSION_BILLINGISH_RE.search(receipt_evidence_ref) is not None:
            reject(path, "evidence_ref names billing or account identifier")
            continue
        if CLAUDE_ADMISSION_LANE_PRESENCE_RE.search(receipt_evidence_ref) is not None:
            reject(
                path, "evidence_ref names lane/session presence; not account-live quota evidence"
            )
            continue
        observed_at = _parse_utc(fields.get("observed_at", "").strip())
        if observed_at is None:
            reject(path, "missing or malformed observed_at")
            continue
        if observed_at > now:
            reject(path, "observed_at is in the future")
            continue
        try:
            stale_after_seconds = int(fields.get("stale_after_seconds", "").strip())
        except ValueError:
            reject(path, "malformed stale_after_seconds")
            continue
        if stale_after_seconds <= 0:
            reject(path, "non-positive stale_after_seconds")
            continue
        if stale_after_seconds > CLAUDE_ADMISSION_MAX_STALE_AFTER_SECONDS:
            reject(
                path,
                f"stale_after_seconds exceeds maximum {CLAUDE_ADMISSION_MAX_STALE_AFTER_SECONDS}",
            )
            continue
        fresh_until = observed_at + timedelta(seconds=stale_after_seconds)
        if now >= fresh_until:
            reject(path, "receipt expired")
            continue
        refs.append(
            ClaudeAdmission(
                evidence_ref=(
                    "relay-receipt:"
                    f"{_receipt_label(path)}:witness:{receipt_evidence_ref}:"
                    f"observation:{observation}:"
                    f"observed_at:{observed_at.isoformat().replace('+00:00', 'Z')}:"
                    f"fresh_until:{fresh_until.isoformat().replace('+00:00', 'Z')}:"
                    f"{CLAUDE_ADMISSION_ACCOUNT_LIVE_QUOTA_SUFFIX}"
                ),
                fresh_until=fresh_until,
            )
        )
    return ClaudeAdmissionScan(admissions=refs, ignored_evidence_refs=ignored_refs)


def active_glmcp_admission_receipts(
    receipt_dir: Path,
    *,
    now: datetime,
) -> GlmcpAdmissionScan:
    """Return fresh positive GLMCP quota/admission receipt evidence refs.

    GLM Coding Plan Max is finite quota. Unlike the older Claude/Codex/Gemini
    subscription snapshots, absence of a wall is not enough to call GLMCP fresh:
    a bakeoff or dispatcher must leave an explicit, time-bounded admission
    witness first. This keeps GLMCP fail-closed until a supported-tool witness
    exists, without making provider calls from this writer.
    """

    if not receipt_dir.is_dir():
        return GlmcpAdmissionScan(admissions=[], ignored_evidence_refs=[])
    refs: list[GlmcpAdmission] = []
    ignored_refs: list[str] = []

    def reject(path: Path, reason: str) -> None:
        ignored_refs.append(_warn_ignored_glmcp_admission(path, reason))

    for path in sorted(receipt_dir.glob(GLMCP_ADMISSION_RECEIPT_GLOB)):
        try:
            raw_receipt = path.read_text(encoding="utf-8")
        except (OSError, UnicodeDecodeError) as exc:
            reject(
                path,
                f"unreadable receipt {type(exc).__name__}",
            )
            continue
        fields, parse_error = _parse_flat_yaml_strict(raw_receipt)
        if parse_error is not None:
            reject(path, parse_error)
            continue
        status = fields.get("status", "")
        if status != "quota_available":
            reject(
                path,
                "status missing or unsupported; expected quota_available",
            )
            continue
        provider = fields.get("provider", "")
        if provider != GLMCP_ADMISSION_PROVIDER:
            if provider in {"z_ai", "z.ai", "zai"}:
                reject(
                    path,
                    f"provider ambiguous alias; expected {GLMCP_ADMISSION_PROVIDER}",
                )
            else:
                reject(
                    path,
                    f"provider missing or unsupported; expected {GLMCP_ADMISSION_PROVIDER}",
                )
            continue
        route_id = fields.get("route_id", "")
        if route_id != SUBSCRIPTION_ROUTES["glmcp"]:
            reject(
                path,
                f"route_id missing or unsupported; expected {SUBSCRIPTION_ROUTES['glmcp']}",
            )
            continue
        supported_tool = fields.get("supported_tool", "")
        if supported_tool not in GLMCP_ADMISSION_SUPPORTED_TOOLS:
            reject(
                path,
                "supported_tool missing or unsupported; expected supported Coding Plan tool",
            )
            continue
        endpoint = fields.get("endpoint", "")
        if endpoint not in GLMCP_ADMISSION_ENDPOINTS:
            reject(
                path,
                "endpoint missing or unsupported; expected official Z.ai Coding Plan or PAYG endpoint",
            )
            continue
        if endpoint not in GLMCP_ADMISSION_TOOL_ENDPOINTS[supported_tool]:
            reject(
                path,
                "supported_tool/endpoint mismatch; expected official endpoint for supported tool",
            )
            continue
        endpoint_contract = GLMCP_ADMISSION_CONTRACT_BY_ENDPOINT[endpoint]
        capacity_pool = fields.get("capacity_pool", "")
        if capacity_pool != endpoint_contract["capacity_pool"]:
            reject(
                path,
                "capacity_pool missing or unsupported for endpoint",
            )
            continue
        model = fields.get("model", "")
        if model not in GLMCP_ADMISSION_MODELS:
            reject(
                path,
                "model missing or unsupported; expected documented GLM review model id glm-5.2",
            )
            continue
        receipt_evidence_ref = fields.get("evidence_ref", "").strip()
        if not receipt_evidence_ref:
            reject(path, "evidence_ref missing")
            continue
        receipt_evidence_ref = " ".join(receipt_evidence_ref.split())
        if len(receipt_evidence_ref) > 240:
            reject(
                path,
                "evidence_ref unsafe; expected a sanitized witness reference, not raw secret material",
            )
            continue
        if (
            GLMCP_ADMISSION_EVIDENCE_REF_RE.fullmatch(receipt_evidence_ref) is None
            or GLMCP_ADMISSION_SECRETISH_RE.search(receipt_evidence_ref) is not None
        ):
            reject(
                path,
                "evidence_ref unsafe; expected a sanitized witness reference, not raw secret material",
            )
            continue
        if "captured_at" in fields or "detected_at" in fields:
            reject(
                path,
                "unsupported timestamp field; expected observed_at only",
            )
            continue
        observed_raw = fields.get("observed_at", "").strip()
        if not observed_raw:
            reject(path, "missing or malformed observed_at")
            continue
        observed_at = _parse_utc(observed_raw)
        if observed_at is None:
            reject(path, "missing or malformed observed_at")
            continue
        if observed_at > now:
            reject(path, "observed_at is in the future")
            continue
        stale_after_raw = fields.get("stale_after_seconds", "").strip()
        if not stale_after_raw:
            reject(path, "stale_after_seconds missing")
            continue
        try:
            stale_after_seconds = int(stale_after_raw)
        except ValueError:
            reject(
                path,
                "malformed stale_after_seconds",
            )
            continue
        if stale_after_seconds <= 0:
            reject(
                path,
                "non-positive stale_after_seconds",
            )
            continue
        if stale_after_seconds > GLMCP_ADMISSION_MAX_STALE_AFTER_SECONDS:
            reject(
                path,
                f"stale_after_seconds exceeds maximum {GLMCP_ADMISSION_MAX_STALE_AFTER_SECONDS}",
            )
            continue
        fresh_until = observed_at + timedelta(seconds=stale_after_seconds)
        if now >= fresh_until:
            reject(
                path,
                "receipt expired",
            )
            continue
        schema = fields.get("schema", "")
        if schema != GLMCP_ADMISSION_SCHEMA:
            reject(
                path,
                f"schema missing or unsupported; expected {GLMCP_ADMISSION_SCHEMA}",
            )
            continue
        if fields.get("secret_source", "") != "pass:glmcp/api-key":
            reject(path, "secret_source missing or unsupported")
            continue
        if fields.get("secret_value_persisted", "") != "false":
            reject(path, "secret_value_persisted must be false")
            continue
        if fields.get("prompt_or_output_persisted", "") != "false":
            reject(path, "prompt_or_output_persisted must be false")
            continue
        if fields.get("billing_mode", "") != endpoint_contract["billing_mode"]:
            reject(path, "billing_mode missing or unsupported for endpoint")
            continue
        if fields.get("payg_fallback", "") != endpoint_contract["payg_fallback"]:
            reject(path, "payg_fallback missing or unsupported for endpoint")
            continue
        primary_error_class = fields.get("primary_error_class", "").strip()
        quota_wall_evidence_ref = fields.get("quota_wall_evidence_ref", "").strip()
        if endpoint == GLMCP_PAYG_ENDPOINT:
            if primary_error_class not in GLMCP_PAYG_PRIMARY_ERROR_CLASSES:
                reject(
                    path,
                    "PAYG admission missing supported primary Coding Plan quota-wall class",
                )
                continue
            if (
                GLMCP_ADMISSION_EVIDENCE_REF_RE.fullmatch(quota_wall_evidence_ref) is None
                or GLMCP_ADMISSION_SECRETISH_RE.search(quota_wall_evidence_ref) is not None
            ):
                reject(
                    path,
                    "PAYG admission missing sanitized quota-wall evidence reference",
                )
                continue
        elif primary_error_class or quota_wall_evidence_ref:
            reject(path, "Coding Plan admission carried PAYG-only witness fields")
            continue
        refs.append(
            GlmcpAdmission(
                evidence_ref=(
                    "relay-receipt:"
                    f"{_receipt_label(path)}:witness:{receipt_evidence_ref}:"
                    f"supported_tool:{supported_tool}:endpoint:{endpoint}:model:{model}:"
                    + (
                        f"primary_error_class:{primary_error_class}:"
                        f"quota_wall_evidence_ref:{quota_wall_evidence_ref}:"
                        if endpoint == GLMCP_PAYG_ENDPOINT
                        else ""
                    )
                    + f"observed_at:{observed_at.isoformat().replace('+00:00', 'Z')}:"
                    f"fresh_until:{fresh_until.isoformat().replace('+00:00', 'Z')}"
                ),
                fresh_until=fresh_until,
                endpoint=endpoint,
                witness_ref=receipt_evidence_ref,
                primary_error_class=primary_error_class or None,
                quota_wall_evidence_ref=quota_wall_evidence_ref or None,
            )
        )
    return GlmcpAdmissionScan(admissions=refs, ignored_evidence_refs=ignored_refs)


def active_glmcp_payg_spend_receipts(
    receipt_dir: Path,
    *,
    base: QuotaSpendLedger,
    now: datetime,
) -> GlmcpPaygSpendScan:
    """Return validated pending GLMCP PAYG spend receipts for budget accounting."""

    if not receipt_dir.is_dir():
        return GlmcpPaygSpendScan(receipts=[], ignored_evidence_refs=[])
    receipts: list[SpendReceipt] = []
    ignored_refs: list[str] = []
    budget_by_id = {budget.budget_id: budget for budget in base.transition_budgets}

    def reject(path: Path, reason: str) -> None:
        ignored_refs.append(_warn_ignored_glmcp_payg_spend(path, reason))

    for path in sorted(receipt_dir.glob(GLMCP_PAYG_SPEND_RECEIPT_GLOB)):
        try:
            raw_receipt = path.read_text(encoding="utf-8")
        except (OSError, UnicodeDecodeError) as exc:
            reject(path, f"unreadable receipt {type(exc).__name__}")
            continue
        fields, parse_error = _parse_flat_yaml_strict(
            raw_receipt,
            allowed_fields=GLMCP_PAYG_SPEND_FIELDS,
        )
        if parse_error is not None:
            reject(path, parse_error)
            continue
        if fields.get("schema", "") != GLMCP_PAYG_SPEND_RECEIPT_SCHEMA:
            reject(
                path, f"schema missing or unsupported; expected {GLMCP_PAYG_SPEND_RECEIPT_SCHEMA}"
            )
            continue
        if fields.get("status", "") not in {"spend_estimated", "spend_reconciled"}:
            reject(path, "status missing or unsupported; expected spend_estimated/spend_reconciled")
            continue
        if fields.get("supported_tool", "") != "hapax-glmcp-reviewer":
            reject(path, "supported_tool missing or unsupported")
            continue
        if fields.get("endpoint", "") != GLMCP_PAYG_ENDPOINT:
            reject(path, "endpoint missing or unsupported; expected official Z.ai PAYG endpoint")
            continue
        if fields.get("billing_mode", "") != "api_credit_payg":
            reject(path, "billing_mode missing or unsupported")
            continue
        if fields.get("payg_fallback", "") != "true":
            reject(path, "payg_fallback must be true")
            continue
        if fields.get("secret_source", "") != "pass:glmcp/api-key":
            reject(path, "secret_source missing or unsupported")
            continue
        if fields.get("secret_value_persisted", "") != "false":
            reject(path, "secret_value_persisted must be false")
            continue
        if fields.get("prompt_or_output_persisted", "") != "false":
            reject(path, "prompt_or_output_persisted must be false")
            continue
        if fields.get("primary_error_class", "") not in GLMCP_PAYG_PRIMARY_ERROR_CLASSES:
            reject(path, "primary_error_class missing or unsupported")
            continue
        if fields.get("route_id", "") != "glmcp.review.direct":
            reject(path, "route_id missing or unsupported")
            continue
        if fields.get("capacity_pool", "") != GLMCP_ADMISSION_PAYG_CAPACITY_POOL:
            reject(path, "capacity_pool missing or unsupported")
            continue
        if fields.get("provider", "") != GLMCP_PAYG_BUDGET_PROVIDER:
            reject(path, "provider missing or unsupported")
            continue
        if fields.get("model_or_engine", "") != "glm-5.2":
            reject(path, "model_or_engine missing or unsupported")
            continue
        if fields.get("estimated_cost_usd", "") != GLMCP_PAYG_ESTIMATED_COST_USD:
            reject(path, "estimated_cost_usd missing or unsupported")
            continue
        budget = budget_by_id.get(fields.get("budget_id", ""))
        if budget is None:
            reject(path, "budget_id missing or unknown")
            continue
        if fields.get("authority_case", "") != budget.authority_case:
            reject(path, "authority_case does not match budget")
            continue
        created_at = _parse_utc(fields.get("created_at", ""))
        if created_at is None:
            reject(path, "created_at missing or malformed")
            continue
        if created_at > now:
            reject(path, "created_at is in the future")
            continue
        reconcile_by = _parse_utc(fields.get("reconcile_by", ""))
        if reconcile_by is None:
            reject(path, "reconcile_by missing or malformed")
            continue
        receipt_payload = {
            key: value
            for key, value in fields.items()
            if key
            in {
                "auth_surface",
                "authority_case",
                "budget_id",
                "capacity_pool",
                "cap_remaining_usd",
                "created_at",
                "effort",
                "estimated_cost_usd",
                "actual_cost_usd",
                "model_id",
                "model_or_engine",
                "provider",
                "quality_floor",
                "quality_preservation_reason",
                "quantization",
                "reconcile_by",
                "reconciliation_state",
                "reconciled_at",
                "reconciliation_reason",
                "route_id",
                "spend_id",
                "spend_reason",
                "support_artifact_authority",
                "task_hash",
                "task_id",
            }
            and not _glmcp_payg_spend_field_is_nullish(key, value)
        }
        task_hash = receipt_payload.get("task_hash")
        if isinstance(task_hash, str) and not GLMCP_PAYG_SPEND_TASK_HASH_RE.fullmatch(task_hash):
            _warn_stripped_glmcp_payg_spend_task_hash(path, task_hash)
            receipt_payload.pop("task_hash", None)
        receipt_payload["spend_receipt_schema"] = 1
        try:
            receipts.append(SpendReceipt.model_validate(receipt_payload))
        except (ValueError, TypeError) as exc:
            reject(path, f"invalid SpendReceipt contract: {type(exc).__name__}")
            continue
    return GlmcpPaygSpendScan(receipts=receipts, ignored_evidence_refs=ignored_refs)


def _ledger_with_glmcp_payg_spend_receipts(
    base: QuotaSpendLedger,
    receipts: list[SpendReceipt],
) -> QuotaSpendLedger:
    if not receipts:
        return base
    payload = base.model_dump(mode="json")
    existing_ids = {receipt["spend_id"] for receipt in payload["spend_receipts"]}
    new_receipts: list[dict[str, Any]] = []
    for receipt in receipts:
        if receipt.spend_id in existing_ids:
            continue
        existing_ids.add(receipt.spend_id)
        new_receipts.append(receipt.model_dump(mode="json"))
    payload["spend_receipts"] = [
        *payload["spend_receipts"],
        *new_receipts,
    ]
    return QuotaSpendLedger.model_validate(payload)


def probe_local_resource_state(*, nvidia_smi: str = "nvidia-smi") -> tuple[str, list[str]]:
    """Probe VRAM + load pressure; fail closed to unknown when unprobeable."""

    evidence: list[str] = []
    try:
        output = subprocess.run(
            [
                nvidia_smi,
                "--query-gpu=memory.used,memory.total",
                "--format=csv,noheader,nounits",
            ],
            capture_output=True,
            text=True,
            timeout=10,
            check=True,
        ).stdout
    except (OSError, subprocess.SubprocessError) as exc:
        return "unknown", [f"local:nvidia-smi:unavailable:{type(exc).__name__}"]

    worst_fraction = 0.0
    for line in output.strip().splitlines():
        parts = [part.strip() for part in line.split(",")]
        if len(parts) != 2:
            continue
        try:
            used, total = float(parts[0]), float(parts[1])
        except ValueError:
            continue
        if total > 0:
            worst_fraction = max(worst_fraction, used / total)
    evidence.append(f"local:nvidia-smi:vram-worst-fraction:{worst_fraction:.3f}")

    state = "green"
    if worst_fraction >= VRAM_RED_FRACTION:
        state = "red"
    elif worst_fraction >= VRAM_YELLOW_FRACTION:
        state = "yellow"

    try:
        load1 = os.getloadavg()[0]
        cpus = os.cpu_count() or 1
        load_per_cpu = load1 / cpus
        evidence.append(f"local:loadavg:per-cpu:{load_per_cpu:.2f}")
        if load_per_cpu >= LOAD_RED_PER_CPU:
            state = "red"
        elif load_per_cpu >= LOAD_YELLOW_PER_CPU and state == "green":
            state = "yellow"
    except OSError:
        evidence.append("local:loadavg:unavailable")

    return state, evidence


def build_live_ledger(
    base: QuotaSpendLedger,
    *,
    now: datetime,
    walls: dict[str, list[QuotaWall]],
    agy_admissions: list[AgyAdmission],
    agy_ignored_receipts: list[str],
    claude_admissions: list[ClaudeAdmission],
    claude_ignored_receipts: list[str],
    glmcp_admissions: list[GlmcpAdmission],
    glmcp_ignored_receipts: list[str],
    glmcp_payg_spend_receipts: list[SpendReceipt],
    glmcp_ignored_payg_spend_receipts: list[str],
    local_resource_state: str,
    local_resource_evidence: list[str],
) -> QuotaSpendLedger:
    """Carry governance records over from base; re-derive telemetry live."""

    spend_base = _ledger_with_glmcp_payg_spend_receipts(base, glmcp_payg_spend_receipts)
    stamp = now.strftime("%Y%m%dT%H%M%SZ")
    # QuotaSnapshot ids must match ^quota-[a-z0-9_.:-]+$ — lowercase the stamp.
    snapshot_stamp = stamp.lower()
    writer_ref = "scripts/hapax-quota-telemetry-writer"

    snapshots: list[dict[str, Any]] = []
    for platform, route_id in sorted(SUBSCRIPTION_ROUTES.items()):
        platform_walls = walls.get(platform, [])
        platform_wall_evidence = [wall.evidence_ref for wall in platform_walls]
        agy_platform_admissions = [admission for admission in agy_admissions if platform == "agy"]
        claude_platform_admissions = [
            admission for admission in claude_admissions if platform == "claude"
        ]
        glmcp_payg_admissions = [
            admission
            for admission in glmcp_admissions
            if platform == "glmcp" and admission.endpoint == GLMCP_PAYG_ENDPOINT
        ]
        glmcp_wall_matched_payg_admissions = [
            admission
            for admission in glmcp_payg_admissions
            if _payg_admission_matches_active_wall(admission, platform_walls)
        ]
        glmcp_spend_bound_payg_admissions: list[tuple[GlmcpAdmission, SpendReceipt]] = []
        for admission in glmcp_wall_matched_payg_admissions:
            receipt = _payg_admission_matching_spend_receipt(
                admission,
                glmcp_payg_spend_receipts,
            )
            if receipt is not None:
                glmcp_spend_bound_payg_admissions.append((admission, receipt))
        glmcp_coding_plan_admissions = [
            admission
            for admission in glmcp_admissions
            if platform == "glmcp" and admission.endpoint == GLMCP_CODING_PLAN_ENDPOINT
        ]
        glmcp_payg_budget_decisions = [
            (
                admission,
                receipt,
                _glmcp_payg_budget_decision(spend_base, now=now, task_id=receipt.task_id),
            )
            for admission, receipt in glmcp_spend_bound_payg_admissions
        ]
        glmcp_eligible_payg_budget_decisions = [
            (admission, receipt, decision)
            for admission, receipt, decision in glmcp_payg_budget_decisions
            if decision.eligible
        ]
        glmcp_payg_budget_evidence = list(
            dict.fromkeys(
                evidence
                for _, _, decision in glmcp_payg_budget_decisions
                for evidence in _glmcp_payg_budget_evidence(decision)
            )
        )
        glmcp_payg_budget_reason = "; ".join(
            dict.fromkeys(
                _glmcp_payg_budget_reason(decision)
                for _, _, decision in glmcp_payg_budget_decisions
            )
        )
        if not glmcp_payg_budget_reason:
            glmcp_payg_budget_reason = (
                "PAYG fallback did not reach paid-spend gate because no matching "
                "task-bound spend receipt witness was available"
            )
        if platform == "agy":
            if agy_platform_admissions:
                state = "fresh"
                evidence = [
                    *(admission.evidence_ref for admission in agy_platform_admissions),
                    writer_ref,
                ]
                fresh_until = max(admission.fresh_until for admission in agy_platform_admissions)
                reason = (
                    "fresh agy supported-tool route admission receipt present; "
                    "agy.review.direct remains receipt-bounded and reviewer-only"
                )
            else:
                state = "unknown"
                evidence = (
                    [*agy_ignored_receipts, writer_ref]
                    if agy_ignored_receipts
                    else ["relay-receipt:agy:quota-admission:absent", writer_ref]
                )
                fresh_until = None
                reason = (
                    "no fresh agy route-specific quota admission receipt; agy.review.direct "
                    "must hold/backoff rather than dispatch blind"
                )
        elif platform_walls and glmcp_eligible_payg_budget_decisions:
            state = "fresh"
            eligible_admissions = [
                admission for admission, _, _ in glmcp_eligible_payg_budget_decisions
            ]
            evidence = [
                *platform_wall_evidence,
                *(admission.evidence_ref for admission in eligible_admissions),
                *(
                    f"spend-gate-payg-receipt:{admission.witness_ref}"
                    for admission in eligible_admissions
                ),
                *glmcp_payg_budget_evidence,
                writer_ref,
            ]
            fresh_until = max(admission.fresh_until for admission in eligible_admissions)
            reason = (
                "GLMCP Coding Plan quota wall is present, but a fresh API-credit PAYG "
                "supported-tool admission receipt, validated spend receipt reservation, and "
                "paid-spend gate keep the review route available. " + glmcp_payg_budget_reason
            )
        elif platform_walls and glmcp_payg_admissions:
            spend_receipt_blocker = []
            if glmcp_wall_matched_payg_admissions and not glmcp_spend_bound_payg_admissions:
                spend_receipt_blocker.append(
                    "spend-gate-blocker:validated-payg-spend-receipt-absent"
                )
            state = "exhausted"
            evidence = [
                *platform_wall_evidence,
                *(admission.evidence_ref for admission in glmcp_payg_admissions),
                *glmcp_payg_budget_evidence,
                *spend_receipt_blocker,
                writer_ref,
            ]
            fresh_until = None
            reason = (
                "GLMCP Coding Plan quota wall is present, and PAYG admission cannot supersede "
                "it without a matching active quota-wall witness, validated PAYG spend receipt "
                "reservation, and active paid-spend gate. " + glmcp_payg_budget_reason
            )
        elif platform_walls:
            state = "exhausted"
            evidence = [*platform_wall_evidence, writer_ref]
            fresh_until = None
            reason = (
                f"{platform} subscription lane hit an unexpired quota wall; "
                "state from quota-wall relay receipt(s)"
            )
        elif platform == "glmcp":
            if glmcp_coding_plan_admissions:
                state = "fresh"
                evidence = [
                    *(admission.evidence_ref for admission in glmcp_coding_plan_admissions),
                    writer_ref,
                ]
                fresh_until = max(
                    admission.fresh_until for admission in glmcp_coding_plan_admissions
                )
                reason = (
                    "fresh GLMCP supported-tool quota admission receipt present; "
                    "GLM Coding Plan Max remains finite and receipt-bounded"
                )
            elif glmcp_payg_admissions:
                state = "unknown"
                evidence = [
                    *(admission.evidence_ref for admission in glmcp_payg_admissions),
                    *glmcp_payg_budget_evidence,
                    writer_ref,
                ]
                reason = (
                    "GLMCP PAYG admission receipt was present without an active Coding Plan "
                    "quota-wall witness; PAYG cannot be treated as the primary rail and "
                    "unknown quota must hold/backoff. " + glmcp_payg_budget_reason
                )
                fresh_until = None
            else:
                state = "unknown"
                if glmcp_ignored_receipts:
                    evidence = [
                        *glmcp_ignored_receipts,
                        *glmcp_ignored_payg_spend_receipts,
                        writer_ref,
                    ]
                    reason = (
                        "GLMCP quota admission receipt(s) were present but rejected; "
                        "GLM Coding Plan Max is finite and rejected evidence must "
                        "hold/backoff rather than dispatch blind"
                    )
                else:
                    evidence = [
                        "relay-receipt:glmcp:quota-admission:absent",
                        *glmcp_ignored_payg_spend_receipts,
                        writer_ref,
                    ]
                    reason = (
                        "no fresh GLMCP quota admission receipt; GLM Coding Plan Max is finite "
                        "and unknown quota must hold/backoff rather than dispatch blind"
                    )
                fresh_until = None
        elif platform == "claude":
            if claude_platform_admissions:
                state = "fresh"
                evidence = [
                    *(admission.evidence_ref for admission in claude_platform_admissions),
                    writer_ref,
                ]
                fresh_until = max(admission.fresh_until for admission in claude_platform_admissions)
                reason = (
                    "fresh claude subscription-quota admission receipt present; "
                    "claude.headless.full account-live quota is receipt-bounded, "
                    "not lane/session presence"
                )
            else:
                state = "unknown"
                evidence = (
                    [*claude_ignored_receipts, writer_ref]
                    if claude_ignored_receipts
                    else ["relay-receipt:claude:quota-admission:absent", writer_ref]
                )
                fresh_until = None
                reason = (
                    "no fresh claude subscription-quota admission receipt; claude.headless.full "
                    "must hold rather than infer availability from lane/session presence"
                )
        else:
            state = "fresh"
            evidence = [f"relay-receipt:{platform}:quota-wall:absent", writer_ref]
            fresh_until = None
            reason = (
                f"no unexpired quota-wall relay receipt for {platform}; "
                "subscription lanes observed dispatchable"
            )
        snapshot = {
            "quota_snapshot_schema": 1,
            "snapshot_id": f"quota-{platform}-subscription-live-{snapshot_stamp}",
            "captured_at": now.isoformat().replace("+00:00", "Z"),
            "route_id": route_id,
            "provider": SUBSCRIPTION_PROVIDERS.get(platform, f"{platform}-subscription"),
            "capacity_pool": "subscription_quota",
            "subscription_quota_state": state,
            "evidence_refs": evidence,
            "operator_visible_reason": reason,
        }
        if fresh_until is not None:
            snapshot["fresh_until"] = fresh_until.isoformat().replace("+00:00", "Z")
        snapshots.append(snapshot)

    snapshots.append(
        {
            "quota_snapshot_schema": 1,
            "snapshot_id": f"quota-local-compute-live-{snapshot_stamp}",
            "captured_at": now.isoformat().replace("+00:00", "Z"),
            "route_id": LOCAL_COMPUTE_ROUTE,
            "provider": LOCAL_COMPUTE_PROVIDER,
            "capacity_pool": "local_compute",
            "subscription_quota_state": "fresh" if local_resource_state != "unknown" else "unknown",
            "evidence_refs": [*local_resource_evidence, writer_ref],
            "operator_visible_reason": (
                f"local compute resource probe -> {local_resource_state}; "
                "local routes are resource-bound, not quota-bound"
            ),
        }
    )

    base_payload = spend_base.model_dump(mode="json")
    generated_from = list(dict.fromkeys([*base_payload["generated_from"], writer_ref]))
    evidence_refs = list(dict.fromkeys([*base_payload["evidence_refs"], writer_ref]))
    payload = {
        **base_payload,
        "ledger_id": f"quota-spend-ledger-live-{stamp}",
        "captured_at": now.isoformat().replace("+00:00", "Z"),
        "generated_from": generated_from,
        "evidence_refs": evidence_refs,
        "local_resource_state": local_resource_state,
        "quota_snapshots": snapshots,
    }
    return QuotaSpendLedger.model_validate(payload)


def write_ledger_atomic(ledger: QuotaSpendLedger, path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    payload = json.dumps(ledger.model_dump(mode="json"), indent=1, sort_keys=True) + "\n"
    fd, tmp_name = tempfile.mkstemp(dir=path.parent, prefix=f".{path.name}.", suffix=".tmp")
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as fh:
            fh.write(payload)
        os.chmod(tmp_name, 0o600)
        os.replace(tmp_name, path)
    except BaseException:
        Path(tmp_name).unlink(missing_ok=True)
        raise


@contextmanager
def quota_spend_live_lock(path: Path) -> Any:
    lock_path = path.with_name(f"{path.name}.lock")
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    with lock_path.open("a", encoding="utf-8") as lock_file:
        fcntl.flock(lock_file.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(lock_file.fileno(), fcntl.LOCK_UN)


def refresh_capability_receipts(*, timeout: float) -> bool:
    """Refresh per-provider capability receipts; failure degrades, not aborts."""

    script = REPO_ROOT / "scripts" / "hapax-platform-capability-receipts"
    outer_timeout = max(timeout * 3, timeout + 15)
    try:
        result = subprocess.run(
            [
                sys.executable,
                str(script),
                "--all",
                "--codex-exec-auth-probe",
                "--timeout",
                str(timeout),
            ],
            capture_output=True,
            text=True,
            timeout=outer_timeout,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        print(
            f"hapax-quota-telemetry-writer: receipt refresh failed: {exc}",
            file=sys.stderr,
        )
        return False
    if result.returncode != 0:
        print(
            f"hapax-quota-telemetry-writer: receipt refresh failed rc={result.returncode}: "
            f"{(result.stderr or result.stdout).strip()[:400]}",
            file=sys.stderr,
        )
        return False
    return True


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog="hapax-quota-telemetry-writer",
        description="Write live per-provider quota/resource telemetry for the dispatcher.",
    )
    parser.add_argument(
        "--base",
        type=Path,
        default=QUOTA_SPEND_LEDGER_FIXTURES,
        help="Checked-in ledger supplying governance records (default: repo fixtures)",
    )
    parser.add_argument(
        "--out",
        type=Path,
        default=None,
        help="Live ledger output path (default: $HAPAX_QUOTA_SPEND_LEDGER_LIVE or cache path)",
    )
    parser.add_argument(
        "--relay-receipt-dir",
        type=Path,
        default=RELAY_RECEIPT_DIR,
        help="Quota-wall relay receipt directory",
    )
    parser.add_argument("--now", help="Override observation time as ISO-8601 UTC (tests)")
    parser.add_argument(
        "--skip-receipts",
        action="store_true",
        help="Skip the platform capability receipt refresh (tests)",
    )
    parser.add_argument(
        "--nvidia-smi",
        default="nvidia-smi",
        help="nvidia-smi binary for the local resource probe (tests)",
    )
    parser.add_argument("--receipt-timeout", type=float, default=120.0)
    parser.add_argument("--json", action="store_true", help="Print a JSON summary to stdout")
    args = parser.parse_args(argv)

    now = _parse_utc(args.now) if args.now else datetime.now(UTC).replace(microsecond=0)
    if now is None:
        parser.error(f"invalid --now value: {args.now!r}")

    receipts_ok = True
    if not args.skip_receipts:
        receipts_ok = refresh_capability_receipts(timeout=args.receipt_timeout)

    try:
        base = load_quota_spend_ledger(args.base)
    except QuotaSpendLedgerError as exc:
        print(f"hapax-quota-telemetry-writer: base ledger unusable: {exc}", file=sys.stderr)
        return 1

    if args.out is not None:
        out_path = args.out
    else:
        configured = os.environ.get(QUOTA_SPEND_LEDGER_LIVE_ENV)
        out_path = Path(configured).expanduser() if configured else DEFAULT_QUOTA_SPEND_LEDGER_LIVE
    with quota_spend_live_lock(out_path):
        walls = active_quota_walls(args.relay_receipt_dir, now=now)
        agy_scan = active_agy_admission_receipts(args.relay_receipt_dir, now=now)
        claude_scan = active_claude_admission_receipts(args.relay_receipt_dir, now=now)
        glmcp_scan = active_glmcp_admission_receipts(args.relay_receipt_dir, now=now)
        glmcp_payg_spend_scan = active_glmcp_payg_spend_receipts(
            args.relay_receipt_dir,
            base=base,
            now=now,
        )
        resource_state, resource_evidence = probe_local_resource_state(nvidia_smi=args.nvidia_smi)
        try:
            ledger = build_live_ledger(
                base,
                now=now,
                walls=walls,
                agy_admissions=agy_scan.admissions,
                agy_ignored_receipts=agy_scan.ignored_evidence_refs,
                claude_admissions=claude_scan.admissions,
                claude_ignored_receipts=claude_scan.ignored_evidence_refs,
                glmcp_admissions=glmcp_scan.admissions,
                glmcp_ignored_receipts=glmcp_scan.ignored_evidence_refs,
                glmcp_payg_spend_receipts=glmcp_payg_spend_scan.receipts,
                glmcp_ignored_payg_spend_receipts=glmcp_payg_spend_scan.ignored_evidence_refs,
                local_resource_state=resource_state,
                local_resource_evidence=resource_evidence,
            )
        except (ValueError, QuotaSpendLedgerError) as exc:
            print(f"hapax-quota-telemetry-writer: live ledger invalid: {exc}", file=sys.stderr)
            return 1
        write_ledger_atomic(ledger, out_path)

    summary = {
        "ledger_id": ledger.ledger_id,
        "captured_at": ledger.captured_at.isoformat().replace("+00:00", "Z"),
        "out": str(out_path),
        "receipts_refreshed": receipts_ok,
        "local_resource_state": resource_state,
        "agy_admissions": len(agy_scan.admissions),
        "agy_ignored_admissions": len(agy_scan.ignored_evidence_refs),
        "claude_admissions": len(claude_scan.admissions),
        "claude_ignored_admissions": len(claude_scan.ignored_evidence_refs),
        "glmcp_admissions": len(glmcp_scan.admissions),
        "glmcp_ignored_admissions": len(glmcp_scan.ignored_evidence_refs),
        "glmcp_payg_spend_receipts": len(glmcp_payg_spend_scan.receipts),
        "glmcp_ignored_payg_spend_receipts": len(glmcp_payg_spend_scan.ignored_evidence_refs),
        "quota_walls": {platform: len(refs) for platform, refs in sorted(walls.items())},
        "snapshot_count": len(ledger.quota_snapshots),
    }
    if args.json:
        print(json.dumps(summary, sort_keys=True))
    else:
        print(
            "hapax-quota-telemetry-writer: wrote "
            f"{summary['ledger_id']} -> {out_path} "
            f"(resource={resource_state}, walls={summary['quota_walls'] or 'none'}, "
            f"receipts_refreshed={receipts_ok})"
        )
    return 0 if receipts_ok else 3


if __name__ == "__main__":
    raise SystemExit(main())
