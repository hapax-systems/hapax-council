#!/usr/bin/env python3
"""hapax-quota-telemetry-writer — live per-provider quota/resource telemetry.

Phase 0.4 (the designed R3 slice) of
REQ-20260609-model-capability-cost-routing-operationalization: the dispatcher's
quota state must come from live telemetry written on a timer, not from the
checked-in ``config/quota-spend-ledger-fixtures.json`` snapshot.

Each tick does two writes:

1. Refresh the per-provider platform capability receipts (quota / resource /
   capability surfaces) via ``scripts/hapax-platform-capability-receipts --all``.
   The registry freshness check reads these; the quota surface carries
   ``stale_after=15m``, so the paired systemd timer fires inside that window to
   keep subscription routes from HOLDing on ``quota_telemetry_stale_or_unknown``.

2. Rebuild the live quota/spend ledger at
   ``~/.cache/hapax/orchestration/quota-spend-ledger-live.json`` (or
   ``$HAPAX_QUOTA_SPEND_LEDGER_LIVE``). Governance records (transition budgets,
   spend receipts, dependencies, provenance, renewals) are carried over from the
   checked-in base unchanged — telemetry never grants spend authority. The
   telemetry fields are re-derived live:

   - ``captured_at``: now.
   - subscription ``quota_snapshots``: per-platform state from the quota-wall
     relay receipts (``~/.cache/hapax/relay/receipts/<role>-quota-wall.yaml``,
     written by ``shared.quota_wall`` on observed 429/quota-exhaustion). An
     unexpired wall marks the platform ``exhausted``; otherwise the established
     Claude/Codex/Gemini subscription routes are ``fresh``. GLMCP is stricter:
     it is ``unknown`` unless a fresh, short-lived Coding Plan admission receipt
     exists. Recheck admission evidence with
     ``find ~/.cache/hapax/relay/receipts -maxdepth 1 -name '*glmcp-quota-admission*.yaml' -print``
     and ``scripts/hapax-quota-telemetry-writer --json``.
     Admission receipts with ``stale_after_seconds`` above 3600 seconds are
     intentionally ignored; write a fresh short-lived witness instead.
     The emergency false-negative recovery path is to create a fresh
     short-lived admission receipt with supported-tool, endpoint, model, and
     evidence_ref fields, then rerun this writer so the live ledger is refreshed.
     That receipt-plane refresh is the canonical emergency procedure for a
     false negative.
     There is intentionally no environment-variable bypass for stale/unknown
     subscription quota.
   - ``local_resource_state`` + local-compute snapshot: nvidia-smi VRAM
     pressure and load average, fail-closed to ``unknown`` when unprobeable.

The output is validated through ``QuotaSpendLedger.model_validate`` before an
atomic replace, so a bad tick can never clobber a good live ledger with junk.
No secrets are read or persisted: the probes are local files, nvidia-smi, and
the existing receipts script (which records config paths/existence only).
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import tempfile
from dataclasses import dataclass
from datetime import UTC, datetime, timedelta
from pathlib import Path
from typing import Any

REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from shared.quota_spend_ledger import (  # noqa: E402
    DEFAULT_QUOTA_SPEND_LEDGER_LIVE,
    QUOTA_SPEND_LEDGER_FIXTURES,
    QUOTA_SPEND_LEDGER_LIVE_ENV,
    QuotaSpendLedger,
    QuotaSpendLedgerError,
    load_quota_spend_ledger,
)

RELAY_RECEIPT_DIR = Path(
    os.environ.get(
        "HAPAX_RELAY_RECEIPT_DIR",
        str(Path.home() / ".cache/hapax/relay/receipts"),
    )
)

# Subscription platforms with quota-wall detection and their canonical
# dispatch route (the registry's primary subscription route per platform).
SUBSCRIPTION_ROUTES = {
    "claude": "claude.headless.full",
    "codex": "codex.headless.full",
    "gemini": "gemini.headless.full",
    "glmcp": "glmcp.review.direct",
}

SUBSCRIPTION_PROVIDERS = {
    "glmcp": "z_ai-glm-coding-plan",
}

GLMCP_ADMISSION_PROVIDER = SUBSCRIPTION_PROVIDERS["glmcp"]
GLMCP_ADMISSION_CAPACITY_POOL = "subscription_quota"
# ``claude_code`` is accepted as a receipt ``supported_tool`` value only when
# paired with the official Z.ai Coding Plan Claude Code endpoint/model evidence
# below; route-specific quota still gates dispatch.
GLMCP_ADMISSION_TOOL_ENDPOINTS = {
    "hapax-glmcp-reviewer": frozenset({"https://api.z.ai/api/coding/paas/v4"}),
    "claude_code": frozenset({"https://api.z.ai/api/anthropic"}),
}
GLMCP_ADMISSION_SUPPORTED_TOOLS = frozenset(GLMCP_ADMISSION_TOOL_ENDPOINTS)
GLMCP_ADMISSION_ENDPOINTS = frozenset(
    endpoint for endpoints in GLMCP_ADMISSION_TOOL_ENDPOINTS.values() for endpoint in endpoints
)
GLMCP_ADMISSION_MODELS = frozenset({"glm-5.2", "glm-5.2[1m]"})
GLMCP_ADMISSION_DEFAULT_STALE_AFTER_SECONDS = 900
GLMCP_ADMISSION_MAX_STALE_AFTER_SECONDS = 3600
GLMCP_ADMISSION_RECHECK_COMMAND = (
    "find ~/.cache/hapax/relay/receipts -maxdepth 1 -name '*glmcp-quota-admission*.yaml' -print"
)
GLMCP_ADMISSION_RECOVERY_HINT = (
    "false-negative recovery: repair receipt permissions/encoding or create a fresh "
    "short-lived supported-tool admission receipt with evidence_ref, then rerun writer"
)


@dataclass(frozen=True)
class GlmcpAdmission:
    evidence_ref: str
    fresh_until: datetime


LOCAL_COMPUTE_ROUTE = "litellm.local.command-r-35b"
LOCAL_COMPUTE_PROVIDER = "tabbyapi"

# A wall receipt without resets_at stays authoritative this long after
# detection; afterwards it is treated as recovered rather than pinning the
# platform exhausted forever.
WALL_WITHOUT_RESET_TTL = timedelta(hours=24)

VRAM_RED_FRACTION = 0.99
VRAM_YELLOW_FRACTION = 0.90
LOAD_RED_PER_CPU = 8.0
LOAD_YELLOW_PER_CPU = 4.0


def role_platform(role: str) -> str:
    """Map a lane role (relay receipt filename stem) to its platform."""

    normalized = role.lower().replace("_", "-")
    if (
        normalized in {"cx-glmcp", "codex-glmcp", "glmcp"}
        or normalized.startswith("cx-glmcp")
        or normalized.startswith("codex-glmcp")
        or normalized.startswith("glm-")
        or normalized.startswith("glmcp-")
    ):
        return "glmcp"
    if normalized.startswith("cx-") or normalized.startswith("codex"):
        return "codex"
    if normalized.startswith("gemini") or normalized.startswith("gm-"):
        return "gemini"
    if normalized.startswith("antigrav") or normalized.startswith("agy"):
        return "antigrav"
    if normalized.startswith("vbe-") or normalized.startswith("vibe"):
        return "vibe"
    return "claude"


def _parse_flat_yaml(text: str) -> dict[str, str]:
    """Parse the flat ``key: value`` quota-wall receipts without a YAML dep."""

    fields: dict[str, str] = {}
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or ":" not in line:
            continue
        key, _, value = line.partition(":")
        fields[key.strip()] = value.strip().strip("'\"")
    return fields


def _parse_flat_yaml_strict(text: str) -> tuple[dict[str, str], str | None]:
    """Parse flat admission receipts and reject ambiguous YAML-shaped input."""

    fields: dict[str, str] = {}
    for line_no, raw_line in enumerate(text.splitlines(), start=1):
        stripped = raw_line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if raw_line[:1].isspace() or stripped.startswith("-"):
            return {}, f"non-flat line {line_no}"
        if ":" not in raw_line:
            return {}, f"non key-value line {line_no}"
        key, _, value = raw_line.partition(":")
        normalized_key = key.strip()
        if not normalized_key:
            return {}, f"empty key on line {line_no}"
        if normalized_key in fields:
            return {}, f"duplicate key {normalized_key!r} on line {line_no}"
        fields[normalized_key] = value.strip().strip("'\"")
    return fields, None


def _parse_utc(value: str) -> datetime | None:
    try:
        parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=UTC)
    return parsed.astimezone(UTC)


def _warn_ignored_glmcp_admission(path: Path, reason: str) -> None:
    print(
        f"hapax-quota-telemetry-writer: ignoring GLMCP admission receipt {path.name}: "
        f"{reason}; path: {path}; recheck: {GLMCP_ADMISSION_RECHECK_COMMAND}; "
        f"{GLMCP_ADMISSION_RECOVERY_HINT}",
        file=sys.stderr,
    )


def active_quota_walls(
    receipt_dir: Path,
    *,
    now: datetime,
) -> dict[str, list[str]]:
    """Return platform -> wall evidence refs for unexpired quota-wall receipts."""

    walls: dict[str, list[str]] = {}
    if not receipt_dir.is_dir():
        return walls
    for path in sorted(receipt_dir.glob("*-quota-wall.yaml")):
        fields = _parse_flat_yaml(path.read_text(encoding="utf-8"))
        if fields.get("status") != "quota_blocked":
            continue
        role = fields.get("role") or path.name.removesuffix("-quota-wall.yaml")
        resets_at = _parse_utc(fields.get("resets_at", ""))
        if resets_at is not None:
            if resets_at <= now:
                continue
        else:
            detected_at = _parse_utc(fields.get("detected_at", ""))
            if detected_at is None or now - detected_at > WALL_WITHOUT_RESET_TTL:
                continue
        platform = role_platform(role)
        walls.setdefault(platform, []).append(
            f"relay-receipt:{path.name}:resets_at:{fields.get('resets_at') or 'unknown'}"
        )
    return walls


def active_glmcp_admission_receipts(
    receipt_dir: Path,
    *,
    now: datetime,
) -> list[GlmcpAdmission]:
    """Return fresh positive GLMCP quota/admission receipt evidence refs.

    GLM Coding Plan Max is finite quota. Unlike the older Claude/Codex/Gemini
    subscription snapshots, absence of a wall is not enough to call GLMCP fresh:
    a bakeoff or dispatcher must leave an explicit, time-bounded admission
    witness first. This keeps GLMCP fail-closed until a supported-tool witness
    exists, without making provider calls from this writer.
    """

    if not receipt_dir.is_dir():
        return []
    refs: list[str] = []
    for path in sorted(receipt_dir.glob("*glmcp-quota-admission*.yaml")):
        try:
            raw_receipt = path.read_text(encoding="utf-8")
        except (OSError, UnicodeDecodeError) as exc:
            _warn_ignored_glmcp_admission(
                path,
                f"unreadable receipt {type(exc).__name__}: {exc}",
            )
            continue
        fields, parse_error = _parse_flat_yaml_strict(raw_receipt)
        if parse_error is not None:
            _warn_ignored_glmcp_admission(path, parse_error)
            continue
        status = fields.get("status", "")
        if status not in {"quota_available", "admitted"}:
            _warn_ignored_glmcp_admission(
                path,
                f"status {status or 'missing'}; expected quota_available or admitted",
            )
            continue
        provider = fields.get("provider", "")
        if provider != GLMCP_ADMISSION_PROVIDER:
            if provider in {"z_ai", "z.ai", "zai"}:
                _warn_ignored_glmcp_admission(
                    path,
                    f"ambiguous provider {provider!r}; expected {GLMCP_ADMISSION_PROVIDER}",
                )
            else:
                _warn_ignored_glmcp_admission(
                    path,
                    f"provider {provider or 'missing'}; expected {GLMCP_ADMISSION_PROVIDER}",
                )
            continue
        capacity_pool = fields.get("capacity_pool", "")
        if capacity_pool != GLMCP_ADMISSION_CAPACITY_POOL:
            _warn_ignored_glmcp_admission(
                path,
                f"capacity_pool {capacity_pool or 'missing'}; "
                f"expected {GLMCP_ADMISSION_CAPACITY_POOL}",
            )
            continue
        route_id = fields.get("route_id", "")
        if route_id != SUBSCRIPTION_ROUTES["glmcp"]:
            _warn_ignored_glmcp_admission(
                path,
                f"route_id {route_id or 'missing'}; expected {SUBSCRIPTION_ROUTES['glmcp']}",
            )
            continue
        supported_tool = fields.get("supported_tool", "")
        if supported_tool not in GLMCP_ADMISSION_SUPPORTED_TOOLS:
            _warn_ignored_glmcp_admission(
                path,
                f"supported_tool {supported_tool or 'missing'}; expected supported Coding Plan tool",
            )
            continue
        endpoint = fields.get("endpoint", "").rstrip("/")
        if endpoint not in GLMCP_ADMISSION_ENDPOINTS:
            _warn_ignored_glmcp_admission(
                path,
                f"endpoint {endpoint or 'missing'}; expected official Z.ai Coding Plan endpoint",
            )
            continue
        if endpoint not in GLMCP_ADMISSION_TOOL_ENDPOINTS[supported_tool]:
            expected = ", ".join(sorted(GLMCP_ADMISSION_TOOL_ENDPOINTS[supported_tool]))
            _warn_ignored_glmcp_admission(
                path,
                f"supported_tool/endpoint mismatch {supported_tool}:{endpoint}; "
                f"expected endpoint {expected}",
            )
            continue
        model = fields.get("model", "")
        if model not in GLMCP_ADMISSION_MODELS:
            _warn_ignored_glmcp_admission(
                path,
                f"model {model or 'missing'}; expected GLM-5.2",
            )
            continue
        if not fields.get("evidence_ref", "").strip():
            _warn_ignored_glmcp_admission(path, "evidence_ref missing")
            continue
        observed_raw = (
            fields.get("observed_at", "")
            or fields.get("captured_at", "")
            or fields.get("detected_at", "")
        )
        observed_at = _parse_utc(observed_raw)
        if observed_at is None:
            _warn_ignored_glmcp_admission(
                path,
                f"missing or malformed observed_at/captured_at/detected_at {observed_raw!r}",
            )
            continue
        if observed_at > now:
            _warn_ignored_glmcp_admission(
                path,
                "observed_at is in the future",
            )
            continue
        try:
            stale_after_seconds = int(
                fields.get(
                    "stale_after_seconds",
                    str(GLMCP_ADMISSION_DEFAULT_STALE_AFTER_SECONDS),
                )
            )
        except ValueError:
            _warn_ignored_glmcp_admission(
                path,
                f"malformed stale_after_seconds {fields.get('stale_after_seconds')!r}",
            )
            continue
        if stale_after_seconds <= 0:
            _warn_ignored_glmcp_admission(
                path,
                f"non-positive stale_after_seconds {stale_after_seconds}",
            )
            continue
        if stale_after_seconds > GLMCP_ADMISSION_MAX_STALE_AFTER_SECONDS:
            _warn_ignored_glmcp_admission(
                path,
                f"stale_after_seconds {stale_after_seconds} exceeds maximum "
                f"{GLMCP_ADMISSION_MAX_STALE_AFTER_SECONDS}",
            )
            continue
        fresh_until = observed_at + timedelta(seconds=stale_after_seconds)
        if now >= fresh_until:
            _warn_ignored_glmcp_admission(
                path,
                "receipt expired",
            )
            continue
        refs.append(
            GlmcpAdmission(
                evidence_ref=(
                    "relay-receipt:"
                    f"{path.name}:observed_at:{observed_at.isoformat().replace('+00:00', 'Z')}:"
                    f"fresh_until:{fresh_until.isoformat().replace('+00:00', 'Z')}"
                ),
                fresh_until=fresh_until,
            )
        )
    return refs


def probe_local_resource_state(*, nvidia_smi: str = "nvidia-smi") -> tuple[str, list[str]]:
    """Probe VRAM + load pressure; fail closed to unknown when unprobeable."""

    evidence: list[str] = []
    try:
        output = subprocess.run(
            [
                nvidia_smi,
                "--query-gpu=memory.used,memory.total",
                "--format=csv,noheader,nounits",
            ],
            capture_output=True,
            text=True,
            timeout=10,
            check=True,
        ).stdout
    except (OSError, subprocess.SubprocessError) as exc:
        return "unknown", [f"local:nvidia-smi:unavailable:{type(exc).__name__}"]

    worst_fraction = 0.0
    for line in output.strip().splitlines():
        parts = [part.strip() for part in line.split(",")]
        if len(parts) != 2:
            continue
        try:
            used, total = float(parts[0]), float(parts[1])
        except ValueError:
            continue
        if total > 0:
            worst_fraction = max(worst_fraction, used / total)
    evidence.append(f"local:nvidia-smi:vram-worst-fraction:{worst_fraction:.3f}")

    state = "green"
    if worst_fraction >= VRAM_RED_FRACTION:
        state = "red"
    elif worst_fraction >= VRAM_YELLOW_FRACTION:
        state = "yellow"

    try:
        load1 = os.getloadavg()[0]
        cpus = os.cpu_count() or 1
        load_per_cpu = load1 / cpus
        evidence.append(f"local:loadavg:per-cpu:{load_per_cpu:.2f}")
        if load_per_cpu >= LOAD_RED_PER_CPU:
            state = "red"
        elif load_per_cpu >= LOAD_YELLOW_PER_CPU and state == "green":
            state = "yellow"
    except OSError:
        evidence.append("local:loadavg:unavailable")

    return state, evidence


def build_live_ledger(
    base: QuotaSpendLedger,
    *,
    now: datetime,
    walls: dict[str, list[str]],
    glmcp_admissions: list[GlmcpAdmission],
    local_resource_state: str,
    local_resource_evidence: list[str],
) -> QuotaSpendLedger:
    """Carry governance records over from base; re-derive telemetry live."""

    stamp = now.strftime("%Y%m%dT%H%M%SZ")
    # QuotaSnapshot ids must match ^quota-[a-z0-9_.:-]+$ — lowercase the stamp.
    snapshot_stamp = stamp.lower()
    writer_ref = "scripts/hapax-quota-telemetry-writer"

    snapshots: list[dict[str, Any]] = []
    for platform, route_id in sorted(SUBSCRIPTION_ROUTES.items()):
        platform_walls = walls.get(platform, [])
        if platform_walls:
            state = "exhausted"
            evidence = [*platform_walls, writer_ref]
            fresh_until = None
            reason = (
                f"{platform} subscription lane hit an unexpired quota wall; "
                "state from quota-wall relay receipt(s)"
            )
        elif platform == "glmcp":
            if glmcp_admissions:
                state = "fresh"
                evidence = [*(admission.evidence_ref for admission in glmcp_admissions), writer_ref]
                fresh_until = max(admission.fresh_until for admission in glmcp_admissions)
                reason = (
                    "fresh GLMCP supported-tool quota admission receipt present; "
                    "GLM Coding Plan Max remains finite and receipt-bounded"
                )
            else:
                state = "unknown"
                evidence = ["relay-receipt:glmcp:quota-admission:absent", writer_ref]
                fresh_until = None
                reason = (
                    "no fresh GLMCP quota admission receipt; GLM Coding Plan Max is finite "
                    "and unknown quota must hold/backoff rather than dispatch blind"
                )
        else:
            state = "fresh"
            evidence = [f"relay-receipt:{platform}:quota-wall:absent", writer_ref]
            fresh_until = None
            reason = (
                f"no unexpired quota-wall relay receipt for {platform}; "
                "subscription lanes observed dispatchable"
            )
        snapshot = {
            "quota_snapshot_schema": 1,
            "snapshot_id": f"quota-{platform}-subscription-live-{snapshot_stamp}",
            "captured_at": now.isoformat().replace("+00:00", "Z"),
            "route_id": route_id,
            "provider": SUBSCRIPTION_PROVIDERS.get(platform, f"{platform}-subscription"),
            "capacity_pool": "subscription_quota",
            "subscription_quota_state": state,
            "evidence_refs": evidence,
            "operator_visible_reason": reason,
        }
        if fresh_until is not None:
            snapshot["fresh_until"] = fresh_until.isoformat().replace("+00:00", "Z")
        snapshots.append(snapshot)

    snapshots.append(
        {
            "quota_snapshot_schema": 1,
            "snapshot_id": f"quota-local-compute-live-{snapshot_stamp}",
            "captured_at": now.isoformat().replace("+00:00", "Z"),
            "route_id": LOCAL_COMPUTE_ROUTE,
            "provider": LOCAL_COMPUTE_PROVIDER,
            "capacity_pool": "local_compute",
            "subscription_quota_state": "fresh" if local_resource_state != "unknown" else "unknown",
            "evidence_refs": [*local_resource_evidence, writer_ref],
            "operator_visible_reason": (
                f"local compute resource probe -> {local_resource_state}; "
                "local routes are resource-bound, not quota-bound"
            ),
        }
    )

    base_payload = base.model_dump(mode="json")
    generated_from = list(dict.fromkeys([*base_payload["generated_from"], writer_ref]))
    evidence_refs = list(dict.fromkeys([*base_payload["evidence_refs"], writer_ref]))
    payload = {
        **base_payload,
        "ledger_id": f"quota-spend-ledger-live-{stamp}",
        "captured_at": now.isoformat().replace("+00:00", "Z"),
        "generated_from": generated_from,
        "evidence_refs": evidence_refs,
        "local_resource_state": local_resource_state,
        "quota_snapshots": snapshots,
    }
    return QuotaSpendLedger.model_validate(payload)


def write_ledger_atomic(ledger: QuotaSpendLedger, path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    payload = json.dumps(ledger.model_dump(mode="json"), indent=1, sort_keys=True) + "\n"
    fd, tmp_name = tempfile.mkstemp(dir=path.parent, prefix=f".{path.name}.", suffix=".tmp")
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as fh:
            fh.write(payload)
        os.chmod(tmp_name, 0o600)
        os.replace(tmp_name, path)
    except BaseException:
        Path(tmp_name).unlink(missing_ok=True)
        raise


def refresh_capability_receipts(*, timeout: float) -> bool:
    """Refresh per-provider capability receipts; failure degrades, not aborts."""

    script = REPO_ROOT / "scripts" / "hapax-platform-capability-receipts"
    try:
        result = subprocess.run(
            [sys.executable, str(script), "--all"],
            capture_output=True,
            text=True,
            timeout=timeout,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        print(
            f"hapax-quota-telemetry-writer: receipt refresh failed: {exc}",
            file=sys.stderr,
        )
        return False
    if result.returncode != 0:
        print(
            f"hapax-quota-telemetry-writer: receipt refresh failed rc={result.returncode}: "
            f"{(result.stderr or result.stdout).strip()[:400]}",
            file=sys.stderr,
        )
        return False
    return True


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog="hapax-quota-telemetry-writer",
        description="Write live per-provider quota/resource telemetry for the dispatcher.",
    )
    parser.add_argument(
        "--base",
        type=Path,
        default=QUOTA_SPEND_LEDGER_FIXTURES,
        help="Checked-in ledger supplying governance records (default: repo fixtures)",
    )
    parser.add_argument(
        "--out",
        type=Path,
        default=None,
        help="Live ledger output path (default: $HAPAX_QUOTA_SPEND_LEDGER_LIVE or cache path)",
    )
    parser.add_argument(
        "--relay-receipt-dir",
        type=Path,
        default=RELAY_RECEIPT_DIR,
        help="Quota-wall relay receipt directory",
    )
    parser.add_argument("--now", help="Override observation time as ISO-8601 UTC (tests)")
    parser.add_argument(
        "--skip-receipts",
        action="store_true",
        help="Skip the platform capability receipt refresh (tests)",
    )
    parser.add_argument(
        "--nvidia-smi",
        default="nvidia-smi",
        help="nvidia-smi binary for the local resource probe (tests)",
    )
    parser.add_argument("--receipt-timeout", type=float, default=120.0)
    parser.add_argument("--json", action="store_true", help="Print a JSON summary to stdout")
    args = parser.parse_args(argv)

    now = _parse_utc(args.now) if args.now else datetime.now(UTC).replace(microsecond=0)
    if now is None:
        parser.error(f"invalid --now value: {args.now!r}")

    receipts_ok = True
    if not args.skip_receipts:
        receipts_ok = refresh_capability_receipts(timeout=args.receipt_timeout)

    try:
        base = load_quota_spend_ledger(args.base)
    except QuotaSpendLedgerError as exc:
        print(f"hapax-quota-telemetry-writer: base ledger unusable: {exc}", file=sys.stderr)
        return 1

    walls = active_quota_walls(args.relay_receipt_dir, now=now)
    glmcp_admissions = active_glmcp_admission_receipts(args.relay_receipt_dir, now=now)
    resource_state, resource_evidence = probe_local_resource_state(nvidia_smi=args.nvidia_smi)
    try:
        ledger = build_live_ledger(
            base,
            now=now,
            walls=walls,
            glmcp_admissions=glmcp_admissions,
            local_resource_state=resource_state,
            local_resource_evidence=resource_evidence,
        )
    except (ValueError, QuotaSpendLedgerError) as exc:
        print(f"hapax-quota-telemetry-writer: live ledger invalid: {exc}", file=sys.stderr)
        return 1

    if args.out is not None:
        out_path = args.out
    else:
        configured = os.environ.get(QUOTA_SPEND_LEDGER_LIVE_ENV)
        out_path = Path(configured).expanduser() if configured else DEFAULT_QUOTA_SPEND_LEDGER_LIVE
    write_ledger_atomic(ledger, out_path)

    summary = {
        "ledger_id": ledger.ledger_id,
        "captured_at": ledger.captured_at.isoformat().replace("+00:00", "Z"),
        "out": str(out_path),
        "receipts_refreshed": receipts_ok,
        "local_resource_state": resource_state,
        "glmcp_admissions": len(glmcp_admissions),
        "quota_walls": {platform: len(refs) for platform, refs in sorted(walls.items())},
        "snapshot_count": len(ledger.quota_snapshots),
    }
    if args.json:
        print(json.dumps(summary, sort_keys=True))
    else:
        print(
            "hapax-quota-telemetry-writer: wrote "
            f"{summary['ledger_id']} -> {out_path} "
            f"(resource={resource_state}, walls={summary['quota_walls'] or 'none'}, "
            f"receipts_refreshed={receipts_ok})"
        )
    return 0 if receipts_ok else 3


if __name__ == "__main__":
    raise SystemExit(main())
