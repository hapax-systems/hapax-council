#!/usr/bin/env python3
"""Mint a signed route-authority receipt that un-degrades a frontier route.

After #3792 retired ``--policy-rollback``, every route HOLDs until a signed
route-authority receipt is present (reasons ``opus_model_entitlement_receipt_absent``
/ ``quality_equivalence_record_absent`` are only removable by a receipt). This
tool is the executable form of OQ-5 — the operator's standing authorization to
sign the Opus model-entitlement and quality-equivalence receipts.

It computes ``signed_payload_sha256`` via
``shared.dispatcher_policy.route_authority_receipt_payload_hash`` and writes a
validated receipt to ``<receipt-dir>/route-authority/<receipt-id>.json``, where
the live dispatch read-path (``load_dispatch_policy_sources``) discovers it.

Examples
--------
Make opus reachable (default receipt dir, default evidence ref)::

    scripts/hapax-mint-route-authority-receipt \\
        --receipt-type opus_model_entitlement --route-id claude.headless.opus

Record sonnet quality-equivalence for a bounded floor::

    scripts/hapax-mint-route-authority-receipt \\
        --receipt-type quality_equivalence --route-id claude.headless.sonnet \\
        --quality-floor frontier_required --evidence-ref isap:SLICE-123
"""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import sys
from datetime import datetime, timedelta
from pathlib import Path
from urllib.request import Request, urlopen

from pydantic import ValidationError

REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from shared.dispatcher_policy import (  # noqa: E402
    ROUTE_AUTHORITY_RECEIPT_DIRNAME,
    RouteAuthorityReceipt,
    _coerce_utc,
    _parse_duration_spec,
    build_route_authority_receipt,
    now_utc,
    route_authority_receipt_reference,
    write_route_authority_receipt,
)
from shared.platform_capability_receipts import (  # noqa: E402
    DEFAULT_PLATFORM_CAPABILITY_RECEIPT_DIR,
)
from shared.platform_capability_registry import normalize_route_id  # noqa: E402


def _parse_now(value: str | None) -> datetime | None:
    if value is None:
        return None
    return datetime.fromisoformat(value.replace("Z", "+00:00"))


def _stable_receipt_id(
    receipt_type: str,
    route_id: str,
    *,
    task_ids: list[str] | tuple[str, ...] = (),
    mutation_surfaces: list[str] | tuple[str, ...] = (),
) -> str:
    """Timestamp-free receipt id so --ensure-fresh re-mints overwrite one file.

    The default minting id is timestamped (one file per run); timer-driven
    upkeep must instead converge on a single stable artifact in the dir the
    dispatch read-path scans, or stale receipts would accumulate forever.
    """
    base = f"{receipt_type}-{normalize_route_id(route_id).replace('.', '-')}"
    if receipt_type not in {"runtime_actuation", "connector_mutation"}:
        return base
    scope = json.dumps(
        {
            "task_ids": sorted(task_ids),
            "mutation_surfaces": sorted(mutation_surfaces),
        },
        sort_keys=True,
    )
    digest = hashlib.sha256(scope.encode("utf-8")).hexdigest()[:12]
    return f"{base}-{digest}"


def _fresh_enough_to_keep(
    *,
    target: Path,
    receipt_type: str,
    route_id: str,
    stale_after: str,
    task_ids: list[str] | tuple[str, ...] = (),
    mutation_surfaces: list[str] | tuple[str, ...] = (),
    refresh_within: timedelta,
    now: datetime,
) -> RouteAuthorityReceipt | None:
    """Return the on-disk receipt iff it can be kept as-is (skip the re-mint).

    Re-mint (return ``None``) when the receipt is absent, unreadable, fails
    signature validation, targets a different type/route/stale_after, or has
    less than ``refresh_within`` of freshness remaining. Fail toward re-minting:
    a standing authorization is cheap to refresh and must never silently lapse.
    """
    if not target.is_file():
        return None
    try:
        existing = RouteAuthorityReceipt.model_validate(
            json.loads(target.read_text(encoding="utf-8"))
        )
    except (OSError, json.JSONDecodeError, ValidationError, ValueError):
        return None
    if existing.receipt_type != receipt_type:
        return None
    if normalize_route_id(existing.route_id) != normalize_route_id(route_id):
        return None
    if existing.stale_after != stale_after:
        return None
    if existing.receipt_type in {"runtime_actuation", "connector_mutation"}:
        if sorted(existing.task_ids) != sorted(task_ids):
            return None
        if sorted(existing.mutation_surfaces) != sorted(mutation_surfaces):
            return None
    remaining = _parse_duration_spec(existing.stale_after) - (now - _coerce_utc(existing.issued_at))
    if remaining <= refresh_within:
        return None
    return existing


def _emit_kept(receipt: RouteAuthorityReceipt, path: Path, *, json_output: bool) -> None:
    reference = route_authority_receipt_reference(receipt)
    if json_output:
        print(
            json.dumps(
                {
                    "kept": True,
                    "receipt_path": str(path),
                    "receipt_reference": reference,
                    "receipt_id": receipt.receipt_id,
                    "receipt_type": receipt.receipt_type,
                    "route_id": receipt.route_id,
                    "signed_by": receipt.signed_by,
                    "stale_after": receipt.stale_after,
                    "signed_payload_sha256": receipt.signed_payload_sha256,
                },
                indent=2,
                sort_keys=True,
            )
        )
    else:
        print(f"kept fresh {receipt.receipt_type} receipt for {receipt.route_id} (no re-mint)")
        print(f"  path:      {path}")
        print(f"  reference: {reference}")


ROUTE_AUTHORITY_UPKEEP_DIRNAME = "route-authority-upkeep"
DEFAULT_NTFY_URL = "https://ntfy.sh"
DEFAULT_NTFY_TOPIC = "hapax-ops"


def _post_ntfy(
    title: str, message: str, *, priority: str = "high", tags: list[str] | None = None
) -> bool:
    """Best-effort ntfy push (mobile). Never raises into the caller.

    The timer-backed re-mint failure is suppressed by the global notify-failure
    coalescer, so the minter pushes its OWN alert here when upkeep is failing.
    Honours NTFY_URL / NTFY_TOPIC (set on the service unit); an empty topic
    disables the push (test / opt-out).
    """
    topic = os.environ.get("NTFY_TOPIC", DEFAULT_NTFY_TOPIC)
    if not topic:
        return False
    base = os.environ.get("NTFY_URL", DEFAULT_NTFY_URL).rstrip("/")
    headers = {"Title": title, "Priority": priority}
    if tags:
        headers["Tags"] = ",".join(tags)
    request = Request(
        f"{base}/{topic}", data=message.encode("utf-8"), headers=headers, method="POST"
    )
    try:
        with urlopen(request, timeout=5) as response:  # noqa: S310
            return 200 <= getattr(response, "status", 200) < 300
    except Exception:
        return False


def _upkeep_state_path(receipt_dir: Path, receipt_id: str) -> Path:
    """Sidecar tracking consecutive re-mint failures.

    Deliberately a SIBLING of the scanned ``route-authority/`` dir: the dispatch
    read-path globs ``route-authority/*.json`` and RAISES on any file there that
    is not a valid receipt, so the upkeep state must never land in it.
    """
    return receipt_dir / ROUTE_AUTHORITY_UPKEEP_DIRNAME / f"{receipt_id}.json"


def _load_upkeep_state(path: Path) -> dict:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {"consecutive_failures": 0}


def _write_upkeep_state(path: Path, state: dict) -> None:
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    except OSError:
        pass


def _existing_receipt_remaining(target: Path, *, now: datetime) -> timedelta | None:
    """Freshness remaining on the live receipt, or ``None`` if absent/unreadable."""
    if not target.is_file():
        return None
    try:
        existing = RouteAuthorityReceipt.model_validate(
            json.loads(target.read_text(encoding="utf-8"))
        )
    except (OSError, json.JSONDecodeError, ValidationError, ValueError):
        return None
    return _parse_duration_spec(existing.stale_after) - (now - _coerce_utc(existing.issued_at))


def _iso_z(moment: datetime) -> str:
    return moment.isoformat().replace("+00:00", "Z")


def _record_upkeep_success(upkeep_path: Path, now: datetime) -> None:
    _write_upkeep_state(upkeep_path, {"consecutive_failures": 0, "last_success_at": _iso_z(now)})


def _escalate_remint_failure(
    *,
    upkeep_path: Path,
    target: Path,
    exc: Exception,
    now: datetime,
    alert_within: timedelta,
    alert_after_failures: int,
    route_id: str,
) -> None:
    """Record a failed re-mint, then ntfy on N consecutive failures OR within T-alert of expiry.

    This is the un-suppressed escalation path: the OnFailure handler coalesces
    timer-backed failures into a log line, so a receipt that stops refreshing
    would otherwise lapse silently and drop opus off its route authority.
    """
    state = _load_upkeep_state(upkeep_path)
    consecutive = int(state.get("consecutive_failures", 0)) + 1
    state["consecutive_failures"] = consecutive
    state["last_failure_at"] = _iso_z(now)
    state["last_error"] = str(exc)[:300]
    _write_upkeep_state(upkeep_path, state)

    remaining = _existing_receipt_remaining(target, now=now)
    within_expiry = remaining is None or remaining <= alert_within
    enough_failures = alert_after_failures > 0 and consecutive >= alert_after_failures
    if not (within_expiry or enough_failures):
        return

    if remaining is None:
        horizon = "no live receipt on disk"
    else:
        hours = remaining.total_seconds() / 3600.0
        horizon = f"~{hours:.1f}h to expiry" if hours >= 0 else f"EXPIRED {abs(hours):.1f}h ago"
    _post_ntfy(
        "opus route-authority receipt NOT refreshing",
        (
            f"{route_id} re-mint FAILED ({consecutive} consecutive); {horizon}. "
            "Opus dispatch loses route authority once the receipt lapses. "
            f"Last error: {exc}. "
            "Check: journalctl --user -u hapax-opus-route-authority-receipt.service -n 30"
        ),
        priority="urgent",
        tags=["rotating_light", "key"],
    )


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description=(
            "Mint a signed route-authority receipt (opus model entitlement, "
            "quality equivalence, task-bound runtime actuation authority, "
            "or task-bound connector mutation authority)."
        )
    )
    parser.add_argument(
        "--receipt-type",
        required=True,
        choices=[
            "opus_model_entitlement",
            "quality_equivalence",
            "runtime_actuation",
            "connector_mutation",
        ],
        help="opus_model_entitlement raises the opus authority ceiling; "
        "quality_equivalence records a bounded-floor equivalence for a fallback route; "
        "runtime_actuation records task-bound authority for a runtime mutation; "
        "connector_mutation records task-bound authority for an MCP/app connector mutation.",
    )
    parser.add_argument(
        "--route-id",
        required=True,
        help="Target route, e.g. claude.headless.opus (opus_model_entitlement must end in .opus).",
    )
    parser.add_argument(
        "--signed-by",
        default="operator",
        help="Signing principal (default: operator — the standing OQ-5 authority).",
    )
    parser.add_argument(
        "--stale-after",
        default="24h",
        help="Freshness window as <int><s|m|h|d> (default: 24h).",
    )
    parser.add_argument(
        "--evidence-ref",
        action="append",
        dest="evidence_refs",
        default=[],
        metavar="REF",
        help="Evidence reference (repeatable). Defaults to operator-signed:<type>:<route>.",
    )
    parser.add_argument(
        "--quality-floor",
        action="append",
        dest="quality_floors",
        default=[],
        metavar="FLOOR",
        help="Quality floor (repeatable). Required for quality_equivalence receipts.",
    )
    parser.add_argument(
        "--task-id",
        action="append",
        dest="task_ids",
        default=[],
        metavar="TASK",
        help="Task id authorized by a runtime_actuation or connector_mutation receipt "
        "(repeatable).",
    )
    parser.add_argument(
        "--mutation-surface",
        action="append",
        dest="mutation_surfaces",
        default=[],
        metavar="SURFACE",
        help="Mutation surface authorized by a runtime_actuation or connector_mutation receipt "
        "(repeatable; defaults to runtime for runtime_actuation; required for "
        "connector_mutation).",
    )
    parser.add_argument(
        "--receipt-id",
        default=None,
        help="Explicit receipt id (default: derived from type, route, and timestamp).",
    )
    parser.add_argument(
        "--ensure-fresh",
        action="store_true",
        help="Idempotent upkeep mode: converge on a stable receipt id and only "
        "re-mint when the live receipt is missing or within --refresh-within of "
        "going stale. Use from a timer to keep the standing authorization fresh.",
    )
    parser.add_argument(
        "--refresh-within",
        default="8h",
        metavar="DURATION",
        help="With --ensure-fresh, re-mint once the live receipt has less than "
        "this much freshness remaining (<int><s|m|h|d>, default: 8h).",
    )
    parser.add_argument(
        "--alert-within",
        default="2h",
        metavar="DURATION",
        help="With --ensure-fresh, fire an ntfy when a re-mint FAILS and the live "
        "receipt has less than this much freshness remaining — the receipt is "
        "about to lapse (<int><s|m|h|d>, default: 2h).",
    )
    parser.add_argument(
        "--alert-after-failures",
        type=int,
        default=3,
        metavar="N",
        help="With --ensure-fresh, fire an ntfy after N consecutive re-mint "
        "failures even before the expiry window (0 disables; default: 3).",
    )
    parser.add_argument(
        "--receipt-dir",
        type=Path,
        default=DEFAULT_PLATFORM_CAPABILITY_RECEIPT_DIR,
        help="Receipt directory; the receipt lands under <dir>/route-authority/ "
        f"(default: {DEFAULT_PLATFORM_CAPABILITY_RECEIPT_DIR}).",
    )
    parser.add_argument(
        "--now",
        default=None,
        help="ISO timestamp override for issued_at (testing/determinism).",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Emit a machine-readable JSON summary instead of human text.",
    )
    args = parser.parse_args(argv)

    evidence_refs = args.evidence_refs or [f"operator-signed:{args.receipt_type}:{args.route_id}"]
    mutation_surfaces = args.mutation_surfaces
    if args.receipt_type == "runtime_actuation" and not mutation_surfaces:
        mutation_surfaces = ["runtime"]
    if args.receipt_type == "connector_mutation" and not mutation_surfaces:
        print(
            "refused to mint route-authority receipt: --mutation-surface is required "
            "for connector_mutation",
            file=sys.stderr,
        )
        return 2

    receipt_id = args.receipt_id
    now_dt = _coerce_utc(_parse_now(args.now) or now_utc())
    upkeep_path: Path | None = None
    target: Path | None = None
    alert_within: timedelta | None = None
    if args.ensure_fresh:
        if receipt_id is None:
            receipt_id = _stable_receipt_id(
                args.receipt_type,
                args.route_id,
                task_ids=args.task_ids,
                mutation_surfaces=mutation_surfaces,
            )
        try:
            refresh_within = _parse_duration_spec(args.refresh_within)
        except ValueError as exc:
            print(
                f"refused to mint route-authority receipt: invalid --refresh-within: {exc}",
                file=sys.stderr,
            )
            return 2
        try:
            alert_within = _parse_duration_spec(args.alert_within)
        except ValueError as exc:
            print(
                f"refused to mint route-authority receipt: invalid --alert-within: {exc}",
                file=sys.stderr,
            )
            return 2
        target = args.receipt_dir / ROUTE_AUTHORITY_RECEIPT_DIRNAME / f"{receipt_id}.json"
        upkeep_path = _upkeep_state_path(args.receipt_dir, receipt_id)
        kept = _fresh_enough_to_keep(
            target=target,
            receipt_type=args.receipt_type,
            route_id=args.route_id,
            stale_after=args.stale_after,
            task_ids=args.task_ids,
            mutation_surfaces=mutation_surfaces,
            refresh_within=refresh_within,
            now=now_dt,
        )
        if kept is not None:
            _record_upkeep_success(upkeep_path, now_dt)
            _emit_kept(kept, target, json_output=args.json)
            return 0

    try:
        receipt = build_route_authority_receipt(
            receipt_type=args.receipt_type,
            route_id=args.route_id,
            evidence_refs=evidence_refs,
            receipt_id=receipt_id,
            signed_by=args.signed_by,
            stale_after=args.stale_after,
            quality_floors=args.quality_floors,
            task_ids=args.task_ids,
            mutation_surfaces=mutation_surfaces,
            issued_at=_parse_now(args.now),
        )
        path = write_route_authority_receipt(receipt, receipt_dir=args.receipt_dir)
    except (ValueError, ValidationError, OSError) as exc:
        if (
            args.ensure_fresh
            and upkeep_path is not None
            and target is not None
            and alert_within is not None
        ):
            _escalate_remint_failure(
                upkeep_path=upkeep_path,
                target=target,
                exc=exc,
                now=now_dt,
                alert_within=alert_within,
                alert_after_failures=args.alert_after_failures,
                route_id=args.route_id,
            )
        print(f"refused to mint route-authority receipt: {exc}", file=sys.stderr)
        return 2

    if args.ensure_fresh and upkeep_path is not None:
        _record_upkeep_success(upkeep_path, now_dt)
    reference = route_authority_receipt_reference(receipt)

    if args.json:
        print(
            json.dumps(
                {
                    "kept": False,
                    "receipt_path": str(path),
                    "receipt_reference": reference,
                    "receipt_id": receipt.receipt_id,
                    "receipt_type": receipt.receipt_type,
                    "route_id": receipt.route_id,
                    "signed_by": receipt.signed_by,
                    "stale_after": receipt.stale_after,
                    "signed_payload_sha256": receipt.signed_payload_sha256,
                },
                indent=2,
                sort_keys=True,
            )
        )
    else:
        print(f"minted {receipt.receipt_type} receipt for {receipt.route_id}")
        print(f"  path:      {path}")
        print(f"  reference: {reference}")
        print(f"  stale_after: {receipt.stale_after} (signed_by={receipt.signed_by})")
        print("The live dispatch read-path will apply it from the default receipt dir.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
