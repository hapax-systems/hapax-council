#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: block commits that touch frozen experiment paths.
# Freeze is active when experiment-phase.json phase != "off".
# Changes are allowed if a deviation record is staged alongside.

REPO_ROOT="$(git rev-parse --show-toplevel)"
PHASE_FILE="$REPO_ROOT/experiment-phase.json"
MANIFEST_FILE="$REPO_ROOT/experiment-freeze-manifest.txt"

# ── Phase check ──
if [[ ! -f "$PHASE_FILE" ]]; then
    exit 0
fi

phase=$(python3 -c "import json; print(json.load(open('$PHASE_FILE')).get('phase', 'off'))" 2>/dev/null || echo "off")
if [[ "$phase" == "off" ]]; then
    exit 0
fi

# ── Load manifest ──
if [[ ! -f "$MANIFEST_FILE" ]]; then
    echo "WARNING: experiment-freeze-manifest.txt not found but phase=$phase"
    exit 0
fi

# Read non-comment, non-empty lines from manifest
mapfile -t frozen_paths < <(grep -v '^#' "$MANIFEST_FILE" | grep -v '^\s*$')

if [[ ${#frozen_paths[@]} -eq 0 ]]; then
    exit 0
fi

# ── Check staged files against frozen paths ──
staged_files=$(git diff --cached --name-only)
if [[ -z "$staged_files" ]]; then
    exit 0
fi

violations=()
while IFS= read -r file; do
    for frozen in "${frozen_paths[@]}"; do
        frozen=$(echo "$frozen" | xargs)  # trim whitespace
        # Directory prefix match (frozen ends with /)
        if [[ "$frozen" == */ ]]; then
            if [[ "$file" == "$frozen"* ]]; then
                violations+=("$file")
                break
            fi
        # Exact file match
        elif [[ "$file" == "$frozen" ]]; then
            violations+=("$file")
            break
        fi
    done
done <<< "$staged_files"

if [[ ${#violations[@]} -eq 0 ]]; then
    exit 0
fi

# ── Check for deviation record ──
has_deviation=false
while IFS= read -r file; do
    if [[ "$file" == research/protocols/deviations/DEVIATION-*.md ]]; then
        has_deviation=true
        break
    fi
done <<< "$staged_files"

if [[ "$has_deviation" == true ]]; then
    echo "⚠ EXPERIMENT FREEZE: ${#violations[@]} frozen path(s) modified with deviation record."
    for v in "${violations[@]}"; do
        echo "  → $v"
    done
    exit 0
fi

# ── Block ──
echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║  EXPERIMENT FREEZE — commit blocked                        ║"
echo "╠══════════════════════════════════════════════════════════════╣"
echo "║  Phase: $phase"
echo "║  The following paths are frozen during active experiments:  ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""
for v in "${violations[@]}"; do
    echo "  ✗ $v"
done
echo ""
echo "To proceed, create a deviation record:"
echo "  cp research/protocols/deviations/TEMPLATE.md \\"
echo "     research/protocols/deviations/DEVIATION-001.md"
echo "  # Edit the record, then stage it alongside your changes."
echo ""
exit 1
