#!/usr/bin/env python3
"""Audit Hapax host OOM policy drift."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from dataclasses import asdict, dataclass
from pathlib import Path

BYTES_80G = 80 * 1024**3
BYTES_104G = 104 * 1024**3
BYTES_8G = 8 * 1024**3
NEXT_OOM_INSTALL = "next action: scripts/install-p0-oom-containment --install --verify-live"
PROC_ROOT = Path(os.environ.get("HAPAX_OOM_AUDIT_PROC_ROOT", "/proc"))
CGROUP_ROOT = Path(os.environ.get("HAPAX_OOM_AUDIT_CGROUP_ROOT", "/sys/fs/cgroup"))
PROTECTED_USER_UNITS = {
    "pipewire.service": -900,
    "pipewire-pulse.service": -900,
    "wireplumber.service": -900,
    "hapax-daimonion.service": -500,
    "studio-compositor.service": -800,
    "hapax-imagination.service": -800,
}


@dataclass
class Check:
    name: str
    status: str
    target: str
    actual: str
    detail: str = ""


def _systemctl() -> str:
    return os.environ.get("HAPAX_SYSTEMCTL", "systemctl")


def _run(args: list[str]) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(args, capture_output=True, text=True, timeout=10, check=False)
    except (FileNotFoundError, subprocess.TimeoutExpired) as exc:
        return subprocess.CompletedProcess(args=args, returncode=127, stdout="", stderr=str(exc))


def _show(unit: str, properties: list[str], *, user: bool = False) -> dict[str, str]:
    args = [_systemctl()]
    if user:
        args.append("--user")
    args.extend(["show", unit, "--no-pager"])
    for prop in properties:
        args.extend(["-p", prop])
    proc = _run(args)
    if proc.returncode != 0:
        return {"_error": (proc.stderr or proc.stdout).strip() or f"rc={proc.returncode}"}
    values: dict[str, str] = {}
    for line in proc.stdout.splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        values[key] = value
    return values


def _int_value(value: str | None) -> int | None:
    if value is None or value == "" or value == "infinity":
        return None
    try:
        return int(value)
    except ValueError:
        return None


def audit_user_manager(uid: int) -> Check:
    unit = f"user@{uid}.service"
    values = _show(unit, ["OOMScoreAdjust", "DropInPaths"])
    if "_error" in values:
        return Check(
            "user_manager_oom_score_adjust",
            "error",
            ">=0",
            "N/A",
            f"{values['_error']}; {NEXT_OOM_INSTALL}",
        )
    actual = values.get("OOMScoreAdjust", "")
    parsed = _int_value(actual)
    if parsed is None:
        return Check(
            "user_manager_oom_score_adjust",
            "error",
            ">=0",
            actual,
            f"unparseable; {NEXT_OOM_INSTALL}",
        )
    if parsed < 0:
        return Check(
            "user_manager_oom_score_adjust",
            "gap",
            ">=0",
            actual,
            f"user@ must not protect every descendant workload over login/network daemons; {NEXT_OOM_INSTALL}",
        )
    return Check("user_manager_oom_score_adjust", "pass", ">=0", actual)


def audit_user_manager_live_score(uid: int) -> Check:
    unit = f"user@{uid}.service"
    values = _show(unit, ["MainPID"])
    if "_error" in values:
        return Check(
            "user_manager_live_oom_score_adj",
            "error",
            "100",
            "N/A",
            f"{values['_error']}; {NEXT_OOM_INSTALL}",
        )
    pid = values.get("MainPID", "0")
    if not pid or pid == "0":
        return Check(
            "user_manager_live_oom_score_adj",
            "gap",
            "100",
            pid,
            f"user@ has no live MainPID to verify; {NEXT_OOM_INSTALL}",
        )
    actual = _proc_oom_score(pid)
    actual_text = "N/A" if actual is None else str(actual)
    status = "pass" if actual == 100 else "gap"
    detail = "" if status == "pass" else f"live user@ OOM score drifted; {NEXT_OOM_INSTALL}"
    return Check("user_manager_live_oom_score_adj", status, "100", actual_text, detail)


def audit_app_slice() -> list[Check]:
    expected = {
        "MemoryHigh": BYTES_80G,
        "MemoryMax": BYTES_104G,
        "MemorySwapMax": BYTES_8G,
    }
    values = _show("app.slice", list(expected), user=True)
    if "_error" in values:
        return [
            Check("app_slice", "error", "bounded", "N/A", f"{values['_error']}; {NEXT_OOM_INSTALL}")
        ]
    checks: list[Check] = []
    for key, target in expected.items():
        actual = values.get(key, "")
        parsed = _int_value(actual)
        status = "pass" if parsed == target else "gap"
        detail = (
            ""
            if status == "pass"
            else f"app.slice aggregate RAM/swap backstop drifted; {NEXT_OOM_INSTALL}"
        )
        checks.append(Check(f"app_slice_{key}", status, str(target), actual, detail))
    return checks


def _proc_oom_score(pid: str) -> int | None:
    try:
        return int((PROC_ROOT / pid / "oom_score_adj").read_text(encoding="utf-8").strip())
    except (OSError, ValueError):
        return None


def _cgroup_pids(cgroup: str) -> list[str]:
    if not cgroup:
        return []
    root = CGROUP_ROOT / cgroup.lstrip("/")
    if not root.is_dir():
        return []
    pids: set[str] = set()
    for procs in root.rglob("cgroup.procs"):
        try:
            for line in procs.read_text(encoding="utf-8").splitlines():
                if line.isdigit():
                    pids.add(line)
        except OSError:
            continue
    return sorted(pids, key=int)


def _protected_user_unit_pids() -> set[str]:
    protected: set[str] = set()
    for unit in PROTECTED_USER_UNITS:
        values = _show(unit, ["OOMScoreAdjust", "MainPID", "ControlGroup"], user=True)
        main_pid = values.get("MainPID", "0")
        if main_pid and main_pid != "0":
            protected.add(main_pid)
        protected.update(_cgroup_pids(values.get("ControlGroup", "")))
    return protected


def audit_protected_user_units() -> list[Check]:
    checks: list[Check] = []
    for unit, expected in PROTECTED_USER_UNITS.items():
        values = _show(unit, ["OOMScoreAdjust", "MainPID", "ControlGroup"], user=True)
        if "_error" in values:
            checks.append(
                Check(
                    f"user_unit_{unit}_OOMScoreAdjust",
                    "gap",
                    str(expected),
                    "N/A",
                    f"{values['_error']}; {NEXT_OOM_INSTALL}",
                )
            )
            continue
        actual = values.get("OOMScoreAdjust", "")
        parsed = _int_value(actual)
        status = "pass" if parsed == expected else "gap"
        detail = (
            ""
            if status == "pass"
            else f"broadcast-critical user unit OOM policy drifted; {NEXT_OOM_INSTALL}"
        )
        checks.append(
            Check(f"user_unit_{unit}_OOMScoreAdjust", status, str(expected), actual, detail)
        )
        live_pids = _cgroup_pids(values.get("ControlGroup", ""))
        main_pid = values.get("MainPID", "0")
        if main_pid.isdigit() and main_pid != "0":
            live_pids = sorted({*live_pids, main_pid}, key=int)
        for pid in live_pids:
            live = _proc_oom_score(pid)
            live_actual = "N/A" if live is None else str(live)
            live_status = "pass" if live == expected else "gap"
            live_detail = (
                ""
                if live_status == "pass"
                else f"live broadcast-critical user unit OOM score drifted; {NEXT_OOM_INSTALL}"
            )
            checks.append(
                Check(
                    f"user_unit_{unit}_pid_{pid}_live_oom_score_adj",
                    live_status,
                    str(expected),
                    live_actual,
                    live_detail,
                )
            )
    return checks


def audit_tmux_scopes() -> list[Check]:
    proc = _run([_systemctl(), "--user", "list-units", "--type=scope", "--all", "--no-legend"])
    if proc.returncode != 0:
        return [
            Check(
                "tmux_scope_scan",
                "error",
                "observable",
                "N/A",
                f"{(proc.stderr or proc.stdout).strip()}; {NEXT_OOM_INSTALL}",
            )
        ]
    scopes = [line.split()[0] for line in proc.stdout.splitlines() if "tmux-spawn-" in line]
    checks: list[Check] = [Check("tmux_scope_count", "pass", ">=0", str(len(scopes)))]
    for scope in scopes:
        values = _show(scope, ["MemoryHigh", "MemoryMax", "MemorySwapMax", "Slice"], user=True)
        if "_error" in values:
            checks.append(
                Check(
                    f"tmux_scope_{scope}",
                    "error",
                    "bounded-or-app-slice-backed",
                    "N/A",
                    f"{values['_error']}; {NEXT_OOM_INSTALL}",
                )
            )
            continue
        unbounded = [
            key
            for key in ("MemoryHigh", "MemoryMax", "MemorySwapMax")
            if values.get(key) == "infinity"
        ]
        slice_name = values.get("Slice", "")
        outside_app_slice = slice_name != "app.slice"
        status = "gap" if unbounded and outside_app_slice else "pass"
        detail_parts = []
        if unbounded:
            detail_parts.append(f"unbounded properties: {', '.join(unbounded)}")
        if outside_app_slice:
            detail_parts.append(f"Slice={slice_name}")
        detail = ""
        if detail_parts:
            detail = f"tmux scope not bounded-or-app-slice-backed: {'; '.join(detail_parts)}; {NEXT_OOM_INSTALL}"
        actual = ",".join(
            f"{key}={values.get(key, '')}"
            for key in ("MemoryHigh", "MemoryMax", "MemorySwapMax", "Slice")
        )
        checks.append(
            Check(f"tmux_scope_{scope}", status, "bounded-or-app-slice-backed", actual, detail)
        )
    return checks


_ALLOWED_USER_PROTECTED_NAMES = {
    "pipewire",
    "pipewire-pulse",
    "wireplumber",
    "dbus-broker",
    "dbus-daemon",
    "hapax-daimonion",
    "hapax-daimonio",
    "studio-compositor",
    "studio-composit",
    "hapax-imagination",
    "hapax-imaginat",
    "hapax-imaginati",
    "systemd",
}


def _status_field(status: Path, key: str) -> str:
    try:
        for line in status.read_text(encoding="utf-8", errors="replace").splitlines():
            parts = line.split()
            if parts and parts[0] == f"{key}:" and len(parts) > 1:
                return parts[1]
    except OSError:
        return ""
    return ""


def audit_residual_user_process_protection(uid: int) -> Check:
    proc_root = PROC_ROOT
    if not proc_root.is_dir():
        return Check(
            "user_process_residual_oom_protection",
            "error",
            "observable",
            "N/A",
            f"proc root unavailable; {NEXT_OOM_INSTALL}",
        )
    protected_pids = _protected_user_unit_pids()
    offenders: list[str] = []
    for adj in proc_root.glob("[0-9]*/oom_score_adj"):
        pid_dir = adj.parent
        status = pid_dir / "status"
        if _status_field(status, "Uid") != str(uid):
            continue
        try:
            score = int(adj.read_text(encoding="utf-8").strip())
        except (OSError, ValueError):
            continue
        if score > -800:
            continue
        if pid_dir.name in protected_pids:
            continue
        name = _status_field(status, "Name")
        if name in _ALLOWED_USER_PROTECTED_NAMES:
            continue
        offenders.append(f"{pid_dir.name}:{name}={score}")
    if offenders:
        shown = ",".join(offenders[:8])
        extra = "" if len(offenders) <= 8 else f",+{len(offenders) - 8} more"
        return Check(
            "user_process_residual_oom_protection",
            "gap",
            "no uid processes <= -800 outside allowlist",
            shown + extra,
            f"stale inherited OOMScoreAdjust; {NEXT_OOM_INSTALL}",
        )
    return Check(
        "user_process_residual_oom_protection",
        "pass",
        "no uid processes <= -800 outside allowlist",
        "none",
    )


def format_human(checks: list[Check]) -> str:
    lines = []
    for check in checks:
        suffix = f" ({check.detail})" if check.detail else ""
        lines.append(
            f"{check.status.upper():5} {check.name}: actual={check.actual} target={check.target}{suffix}"
        )
    return "\n".join(lines)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--json", action="store_true", help="emit machine-readable JSON")
    parser.add_argument("--uid", type=int, default=os.getuid(), help="user manager UID to audit")
    args = parser.parse_args(argv)

    checks = [
        audit_user_manager(args.uid),
        audit_user_manager_live_score(args.uid),
        *audit_app_slice(),
        *audit_protected_user_units(),
        audit_residual_user_process_protection(args.uid),
        *audit_tmux_scopes(),
    ]
    if args.json:
        print(json.dumps({"checks": [asdict(check) for check in checks]}, indent=2, sort_keys=True))
    else:
        print(format_human(checks))
    return 1 if any(check.status in {"gap", "error"} for check in checks) else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
