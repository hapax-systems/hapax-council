#!/usr/bin/env python3
"""Cascade-unblock cc-tasks whose depends_on are all satisfied.

Called by cc-close after a task moves to done/closed, and also by the
periodic reconciler timer as a safety net.

Usage:
    cc-cascade-unblock [<closed_task_id>]   # after a specific close
    cc-cascade-unblock --reconcile           # full sweep
"""

from __future__ import annotations

import re
import stat
import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from shared.sdlc_filesystem_transaction import (  # noqa: E402
    FilesystemTransactionError,
    replace_task_note_transactionally,
)
from shared.sdlc_lifecycle import (  # noqa: E402
    TASK_NON_FULFILLING_CLOSED_STATUSES,
    frontmatter_from_text,
    is_active_blocked_with_evidence,
    task_closure_validity,
)

DEFAULT_VAULT = Path.home() / "Documents/Personal/20-projects/hapax-cc-tasks"
VAULT = DEFAULT_VAULT
ACTIVE = VAULT / "active"
CLOSED = VAULT / "closed"
OWNERSHIP_CACHE = Path.home() / ".cache/hapax"


def _ownership_cache() -> Path:
    return OWNERSHIP_CACHE if VAULT == DEFAULT_VAULT else VAULT / ".hapax-ownership-cache"


def _safe_read_snapshot(path: Path) -> tuple[bytes, str, int] | None:
    try:
        metadata = path.lstat()
        raw = path.read_bytes()
        return raw, raw.decode("utf-8", errors="replace"), stat.S_IMODE(metadata.st_mode)
    except OSError:
        return None


def _replace_snapshot(path: Path, raw: bytes, mode: int, text: str) -> bool:
    try:
        replace_task_note_transactionally(
            path,
            expected_content=raw,
            content=text.encode("utf-8"),
            expected_mode=mode,
            cache_dir=_ownership_cache(),
            vault_root=VAULT,
        )
    except (OSError, FilesystemTransactionError) as exc:
        print(
            f"cc-cascade-unblock: task note changed before commit: {path}: {exc}", file=sys.stderr
        )
        return False
    return True


def _safe_read_text(path: Path) -> str | None:
    """Read a task note, tolerating concurrent moves/deletes.

    The reconciler enumerates ``active/*.md`` and then reads each file, but
    ``cc-close`` (and the close path that calls this very script) moves notes
    out of ``active/`` into ``closed/`` while the sweep is running. That
    glob-then-read window is a TOCTOU race: a note can vanish between
    enumeration and ``read_text``. Returning ``None`` lets callers skip the
    now-absent note instead of crashing the whole reconcile run.
    """
    try:
        return path.read_text(errors="replace")
    except OSError:
        return None


def _check_pr_merged(pr_number: str) -> str:
    try:
        result = subprocess.run(
            [
                "gh",
                "pr",
                "view",
                pr_number,
                "--json",
                "state,mergedAt",
                "--jq",
                '.state + "," + ((.mergedAt != null and .mergedAt != "") | tostring)',
            ],
            capture_output=True,
            text=True,
            timeout=15,
            cwd=str(Path.home() / "projects" / "hapax-council"),
        )
    except Exception:
        return "unknown"
    if result.returncode != 0:
        return "unknown"
    parts = result.stdout.strip().split(",")
    if len(parts) == 2 and parts[1] == "true":
        return "merged"
    if parts and parts[0] == "OPEN":
        return "open"
    if parts and parts[0] == "CLOSED":
        return "closed_unmerged"
    return "unknown"


def _frontmatter_task_id(text: str) -> str | None:
    tid = re.search(r"^task_id:\s*(.+)", text, re.M)
    if tid:
        return tid.group(1).strip().strip("\"'")
    return None


def _locate_task(task_id: str) -> Path | None:
    for root in (ACTIVE, CLOSED):
        exact = root / f"{task_id}.md"
        if exact.is_file():
            return exact
        for candidate in root.glob(f"{task_id}-*.md"):
            if candidate.is_file():
                return candidate
    return None


def _task_aliases(path: Path, text: str) -> set[str]:
    aliases = {path.stem}
    task_id = _frontmatter_task_id(text)
    if task_id:
        aliases.add(task_id)
    return aliases


def _trigger_aliases(trigger_task_id: str | None) -> set[str]:
    if not trigger_task_id:
        return set()
    path = _locate_task(trigger_task_id)
    if path is None:
        return {trigger_task_id}
    text = _safe_read_text(path)
    if text is None:
        return {trigger_task_id}
    return _task_aliases(path, text)


def _dependency_validity(dep_ids: set[str]) -> tuple[set[str], dict[str, tuple[str, ...]]]:
    satisfied: set[str] = set()
    blockers: dict[str, tuple[str, ...]] = {}
    pr_state_cache: dict[str, str] = {}

    def cached_pr_state(pr_number: str) -> str:
        if pr_number not in pr_state_cache:
            pr_state_cache[pr_number] = _check_pr_merged(pr_number)
        return pr_state_cache[pr_number]

    for dep_id in sorted(dep_ids):
        path = _locate_task(dep_id)
        if path is None:
            blockers[dep_id] = ("dependency_not_found",)
            continue
        text = _safe_read_text(path)
        if text is None:
            blockers[dep_id] = ("dependency_not_found",)
            continue
        validity = task_closure_validity(
            text,
            pr_state_lookup=cached_pr_state,
            require_route_metadata_validity=True,
        )
        ids = _task_aliases(path, text)
        if validity.valid:
            satisfied.update(ids)
        else:
            for task_id in ids:
                blockers[task_id] = validity.blockers
    return satisfied, blockers


def _parse_depends(text: str) -> list[str]:
    frontmatter = frontmatter_from_text(text)
    if "depends_on" in frontmatter:
        return _normalize_depends(frontmatter.get("depends_on"))

    block = re.search(r"^depends_on:\s*\n((?:\s+-\s+.+\n)*)", text, re.M)
    if block:
        return [
            d.strip().lstrip("- ").strip("\"'")
            for d in block.group(1).strip().split("\n")
            if d.strip()
        ]
    inline = re.search(r"^depends_on:\s*\[([^\]]*)\]", text, re.M)
    if inline and inline.group(1).strip():
        return [d.strip().strip("\"'") for d in inline.group(1).split(",") if d.strip()]
    return []


def _normalize_depends(value: object) -> list[str]:
    if value is None:
        return []
    if isinstance(value, str):
        stripped = value.strip().strip("\"'")
        if stripped.lower() in {"", "null", "none", "~", "[]"}:
            return []
        return [stripped]
    if isinstance(value, (list, tuple, set)):
        deps: list[str] = []
        for item in value:
            if item is None:
                continue
            stripped = str(item).strip().strip("\"'")
            if stripped and stripped.lower() not in {"null", "none", "~", "[]"}:
                deps.append(stripped)
        return deps
    return [str(value).strip()]


def _set_frontmatter_scalar(text: str, key: str, value: str) -> str:
    rendered = _yaml_scalar(value)
    pattern = rf"^{re.escape(key)}:.*$"
    if re.search(pattern, text, flags=re.M):
        return re.sub(pattern, lambda _m: f"{key}: {rendered}", text, count=1, flags=re.M)
    return re.sub(
        r"^(status:\s*\S+.*)$",
        lambda match: f"{match.group(1)}\n{key}: {rendered}",
        text,
        count=1,
        flags=re.M,
    )


def _yaml_scalar(value: str) -> str:
    if value in {"null", "true", "false"}:
        return value
    if re.fullmatch(r"[A-Za-z0-9_./~+-]+", value):
        return value
    return "'" + value.replace("'", "''") + "'"


def _blocked_candidates(
    trigger_task_id: str | None,
) -> list[tuple[Path, bytes, str, int, list[str]]]:
    if not ACTIVE.is_dir():
        return []

    trigger_aliases = _trigger_aliases(trigger_task_id)
    candidates: list[tuple[Path, bytes, str, int, list[str]]] = []

    for f in sorted(ACTIVE.glob("*.md")):
        snapshot = _safe_read_snapshot(f)
        if snapshot is None:
            continue
        raw, text, mode = snapshot
        status_m = re.search(r"^status:\s*(\S+)", text, re.M)
        if not status_m or status_m.group(1) != "blocked":
            continue

        deps = _parse_depends(text)
        if not deps:
            continue
        if trigger_aliases and not trigger_aliases.intersection(deps):
            continue
        candidates.append((f, raw, text, mode, deps))

    return candidates


def cascade_unblock(trigger_task_id: str | None = None) -> int:
    candidates = _blocked_candidates(trigger_task_id)
    if not candidates:
        return 0

    required_dep_ids = {dep for _, _, _, _, deps in candidates for dep in deps}
    satisfied_ids, blockers_by_id = _dependency_validity(required_dep_ids)
    unblocked = 0

    for f, raw, text, mode, deps in candidates:
        frontmatter = frontmatter_from_text(text)
        if is_active_blocked_with_evidence(frontmatter):
            print(
                f"cc-cascade-unblock: {f.stem} remains blocked (current blocked evidence present)"
            )
            continue

        unmet = [dep for dep in deps if dep not in satisfied_ids]
        if unmet:
            reasons: list[str] = []
            for dep in unmet:
                dep_blockers = blockers_by_id.get(dep)
                if dep_blockers:
                    reasons.append(f"{dep} ({'; '.join(dep_blockers)})")
                else:
                    reasons.append(f"{dep} (not found or not closure-valid)")
            blocked_reason = "waiting_for_closure_valid_dependencies: " + "; ".join(reasons)
            new = _set_frontmatter_scalar(text, "blocked_reason", blocked_reason)
            if new != text and not _replace_snapshot(f, raw, mode, new):
                continue
            continue

        new = re.sub(r"^status: blocked", "status: offered", text, count=1, flags=re.M)
        new = _set_frontmatter_scalar(new, "blocked_reason", "null")
        if not _replace_snapshot(f, raw, mode, new):
            continue
        unblocked += 1
        print(f"cc-cascade-unblock: {f.stem} -> offered (all deps satisfied)")

    return unblocked


def _dep_status(task_id: str) -> str:
    path = _locate_task(task_id)
    if path is None:
        return ""
    text = _safe_read_text(path)
    if text is None:
        return ""
    m = re.search(r"^status:\s*(\S+)", text, re.M)
    return m.group(1) if m else ""


def cascade_withdraw() -> int:
    """Auto-withdraw tasks whose ALL dependencies are in non-fulfilling terminal states."""
    if not ACTIVE.is_dir():
        return 0

    withdrawn = 0
    for f in sorted(ACTIVE.glob("*.md")):
        snapshot = _safe_read_snapshot(f)
        if snapshot is None:
            continue
        raw, text, mode = snapshot
        status_m = re.search(r"^status:\s*(\S+)", text, re.M)
        if not status_m or status_m.group(1) in TASK_NON_FULFILLING_CLOSED_STATUSES:
            continue

        deps = _parse_depends(text)
        if not deps:
            continue

        dep_statuses = [_dep_status(d) for d in deps]
        if not all(s in TASK_NON_FULFILLING_CLOSED_STATUSES for s in dep_statuses):
            continue

        new = re.sub(
            r"^status: \S+",
            "status: withdrawn",
            text,
            count=1,
            flags=re.M,
        )
        new = re.sub(
            r"^blocked_reason: .+",
            "blocked_reason: all dependencies withdrawn/cancelled",
            new,
            count=1,
            flags=re.M,
        )
        if not _replace_snapshot(f, raw, mode, new):
            continue
        withdrawn += 1
        print(f"cc-cascade-unblock: {f.stem} -> withdrawn (all deps non-fulfilling)")

    return withdrawn


if __name__ == "__main__":
    trigger = None
    reconcile = False
    if len(sys.argv) > 1:
        if sys.argv[1] == "--reconcile":
            reconcile = True
        else:
            trigger = sys.argv[1]
    n = cascade_unblock(trigger)
    if n:
        print(f"cc-cascade-unblock: unblocked {n} task(s)")
    if reconcile or trigger is None:
        w = cascade_withdraw()
        if w:
            print(f"cc-cascade-unblock: withdrew {w} task(s)")
    sys.exit(0)
