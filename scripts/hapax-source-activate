#!/usr/bin/env bash
# hapax-source-activate — make origin/main operationally visible.
#
# Maintains clean detached release worktrees that follow origin/main, promotes
# the stable active-source symlink after candidate checks pass, runs
# commit-addressed post-merge deployment from that source root, and writes
# receipts describing whether the latest source is active. It never resets or
# checks out the operator's canonical worktree.

set -euo pipefail

SKIP_DEPLOY=0
FORCE=0
FORCE_AUTHORITY="${HAPAX_SOURCE_ACTIVATE_FORCE_AUTHORITY:-}"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --skip-deploy) SKIP_DEPLOY=1; shift ;;
        --force) FORCE=1; shift ;;
        --force-authority)
            if [[ $# -lt 2 || -z "$2" ]]; then
                echo "hapax-source-activate: --force-authority requires a non-empty authority value" >&2
                exit 2
            fi
            FORCE=1
            FORCE_AUTHORITY="$2"
            shift 2
            ;;
        *) echo "hapax-source-activate: unknown arg: $1" >&2; exit 2 ;;
    esac
done

CANONICAL_REPO="${HAPAX_SOURCE_ACTIVATE_CANONICAL:-$HOME/projects/hapax-council}"
ACTIVE_WORKTREE="${HAPAX_SOURCE_ACTIVATE_WORKTREE:-$HOME/.cache/hapax/source-activation/worktree}"
STATE_DIR="${HAPAX_SOURCE_ACTIVATE_STATE_DIR:-$HOME/.cache/hapax/source-activation}"
RELEASES_DIR="${HAPAX_SOURCE_ACTIVATE_RELEASES_DIR:-$STATE_DIR/releases}"
CURRENT_JSON="$STATE_DIR/current.json"
HISTORY_JSONL="$STATE_DIR/source-activation.jsonl"
LAST_SUCCESS_SHA="$STATE_DIR/last-success-sha"

mkdir -p "$STATE_DIR"

canonical_branch="unknown"
canonical_head="unknown"
canonical_main="unknown"
canonical_dirty_count=0
canonical_status_hash=""
origin_sha="unknown"
active_head="unknown"
candidate_worktree=""
active_source_target=""
dependency_sync_status="not_started"
dependency_sync_message=""
health_probe_status="not_started"
health_probe_message=""
live_window_status="not_checked"
live_window_message=""
previous_active_target=""
promoted_active_target=""
rollback_status="not_needed"
rollback_message=""
quarantined_untracked_count=0
quarantined_untracked_path=""
quarantined_symlink_count=0
runtime_profile_link_count=0
audio_critical_paths=(
    agents/studio_compositor/director_loop.py
    config/audio-routing.yaml
    config/audio-topology.yaml
    config/hapax/audio-forbidden-links.conf
    config/hapax/audio-link-map.conf
    config/pipewire
    config/voice-output-routes.yaml
    config/wireplumber
    scripts/hapax-source-activate
    scripts/hapax-audio-reconciler
    scripts/hapax-audio-routing-check
    scripts/hapax-audio-topology
    scripts/hapax-private-monitor-recover
    scripts/hapax-usb-topology-witness
    shared/audio_routing_policy.py
    shared/audio_topology_generator.py
    shared/audio_topology_inspector.py
    shared/voice_output_router.py
)

canonical_snapshot() {
    if [[ -d "$CANONICAL_REPO/.git" || -f "$CANONICAL_REPO/.git" ]]; then
        canonical_branch="$(git -C "$CANONICAL_REPO" rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"
        canonical_head="$(git -C "$CANONICAL_REPO" rev-parse HEAD 2>/dev/null || echo unknown)"
        canonical_main="$(git -C "$CANONICAL_REPO" rev-parse main 2>/dev/null || echo unknown)"
        status_text="$(git -C "$CANONICAL_REPO" status --porcelain=v1 2>/dev/null || true)"
        if [[ -n "$status_text" ]]; then
            canonical_dirty_count="$(printf '%s\n' "$status_text" | sed '/^$/d' | wc -l | tr -d ' ')"
            canonical_status_hash="$(printf '%s\n' "$status_text" | sha256sum | awk '{print $1}')"
        else
            canonical_dirty_count=0
            canonical_status_hash="$(printf '' | sha256sum | awk '{print $1}')"
        fi
    fi
}

active_source_git_available() {
    [[ -e "$ACTIVE_WORKTREE/.git" ]]
}

refresh_active_source_fields() {
    if active_source_git_available; then
        active_head="$(git -C "$ACTIVE_WORKTREE" rev-parse HEAD 2>/dev/null || echo unknown)"
    else
        active_head="unknown"
    fi
    if [[ -L "$ACTIVE_WORKTREE" ]]; then
        active_source_target="$(readlink -f "$ACTIVE_WORKTREE" 2>/dev/null || readlink "$ACTIVE_WORKTREE" 2>/dev/null || true)"
    elif [[ -e "$ACTIVE_WORKTREE" ]]; then
        active_source_target="$(realpath -m "$ACTIVE_WORKTREE" 2>/dev/null || true)"
    else
        active_source_target=""
    fi
}

write_receipt() {
    local status="$1"
    local deploy_status="$2"
    local exit_code="$3"
    local message="$4"

    python3 - "$CURRENT_JSON" "$HISTORY_JSONL" \
        "$status" "$deploy_status" "$exit_code" "$message" \
        "$origin_sha" "$active_head" "$CANONICAL_REPO" "$ACTIVE_WORKTREE" \
        "$canonical_branch" "$canonical_head" "$canonical_main" \
        "$canonical_dirty_count" "$canonical_status_hash" \
        "$dependency_sync_status" "$dependency_sync_message" \
        "$health_probe_status" "$health_probe_message" \
        "$live_window_status" "$live_window_message" \
        "$candidate_worktree" "$active_source_target" \
        "$previous_active_target" "$promoted_active_target" \
        "$rollback_status" "$rollback_message" \
        "$quarantined_untracked_count" "$quarantined_untracked_path" \
        "$quarantined_symlink_count" "$runtime_profile_link_count" \
        "$FORCE" "$FORCE_AUTHORITY" <<'PY'
from __future__ import annotations

import json
import os
import sys
from datetime import UTC, datetime
from pathlib import Path

(
    current_path,
    history_path,
    status,
    deploy_status,
    exit_code,
    message,
    origin_sha,
    active_head,
    canonical_repo,
    active_worktree,
    canonical_branch,
    canonical_head,
    canonical_main,
    canonical_dirty_count,
    canonical_status_hash,
    dependency_sync_status,
    dependency_sync_message,
    health_probe_status,
    health_probe_message,
    live_window_status,
    live_window_message,
    candidate_worktree,
    active_source_target,
    previous_active_target,
    promoted_active_target,
    rollback_status,
    rollback_message,
    quarantined_untracked_count,
    quarantined_untracked_path,
    quarantined_symlink_count,
    runtime_profile_link_count,
    force,
    force_authority,
) = sys.argv[1:]

record = {
    "schema_version": 1,
    "event": "source_activation",
    "timestamp": datetime.now(UTC).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    "status": status,
    "deploy_status": deploy_status,
    "exit_code": int(exit_code),
    "message": message,
    "origin_main_sha": origin_sha,
    "active_source_head": active_head,
    "canonical": {
        "path": canonical_repo,
        "branch": canonical_branch,
        "head": canonical_head,
        "main": canonical_main,
        "dirty_count": int(canonical_dirty_count),
        "status_hash": canonical_status_hash,
    },
    "active_source_path": active_worktree,
    "active_source_target": active_source_target,
    "candidate_source_path": candidate_worktree,
    "dependency_sync": {
        "status": dependency_sync_status,
        "message": dependency_sync_message,
    },
    "health_probes": {
        "status": health_probe_status,
        "message": health_probe_message,
    },
    "live_window": {
        "status": live_window_status,
        "message": live_window_message,
    },
    "source_cutover": {
        "previous_active_target": previous_active_target,
        "promoted_active_target": promoted_active_target,
        "rollback_status": rollback_status,
        "rollback_message": rollback_message,
    },
    "source_hygiene": {
        "untracked_quarantine_count": int(quarantined_untracked_count),
        "untracked_quarantine_path": quarantined_untracked_path,
        "untracked_symlink_removed_count": int(quarantined_symlink_count),
        "runtime_profile_link_count": int(runtime_profile_link_count),
    },
    "force": {
        "requested": force == "1",
        "authority": force_authority or None,
    },
}

current = Path(current_path).expanduser()
history = Path(history_path).expanduser()
current.parent.mkdir(parents=True, exist_ok=True)
tmp = current.with_name(f"{current.name}.tmp")
tmp.write_text(json.dumps(record, sort_keys=True, indent=2) + "\n", encoding="utf-8")
os.replace(tmp, current)
with history.open("a", encoding="utf-8") as fh:
    fh.write(json.dumps(record, sort_keys=True) + "\n")
PY
}

hold_on_audio_critical_active_drift() {
    if [[ "$FORCE" == "1" || ! -e "$ACTIVE_WORKTREE/.git" ]]; then
        return 0
    fi

    local -a drift_lines
    mapfile -t drift_lines < <(
        git -C "$ACTIVE_WORKTREE" status --porcelain=v1 -- "${audio_critical_paths[@]}" \
            | sed '/^$/d'
    )
    if [[ "${#drift_lines[@]}" -eq 0 ]]; then
        return 0
    fi

    refresh_active_source_fields
    local drift_summary
    drift_summary="$(
        printf '%s\n' "${drift_lines[@]}" \
            | sed 's/^...//' \
            | sort -u \
            | head -n 12 \
            | tr '\n' ',' \
            | sed 's/,$//'
    )"
    write_receipt \
        "held" \
        "skipped_audio_critical_drift" \
        "0" \
        "audio-critical activation drift active: $drift_summary"
    echo "hapax-source-activate: held because active source has audio-critical drift: $drift_summary" >&2
    echo "hapax-source-activate: sourceize the drift or rerun with --force-authority cc-task:<id> after governed release evidence is recorded" >&2
    exit 0
}

enforce_force_authority() {
    if [[ "$FORCE" != "1" ]]; then
        return 0
    fi
    if [[ -n "$FORCE_AUTHORITY" ]]; then
        return 0
    fi

    refresh_active_source_fields
    write_receipt "failed" "not_started" "2" "--force missing governed release authority"
    echo "hapax-source-activate: --force requires governed release authority; pass --force-authority cc-task:<id> or set HAPAX_SOURCE_ACTIVATE_FORCE_AUTHORITY" >&2
    exit 2
}

fresh_file_exists() {
    local path="$1"
    local max_age_s="$2"
    [[ -f "$path" ]] || return 1
    if [[ "$max_age_s" == "0" ]]; then
        return 0
    fi
    local now mtime age
    now="$(date +%s)"
    mtime="$(stat -c %Y "$path" 2>/dev/null || echo 0)"
    age=$((now - mtime))
    [[ "$age" -ge 0 && "$age" -le "$max_age_s" ]]
}

stream_intent_indicates_live() {
    local path="$1"
    [[ -f "$path" ]] || return 1
    python3 - "$path" <<'PY'
from __future__ import annotations

import json
import sys
from pathlib import Path

try:
    payload = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(1)

live_values = {
    "live",
    "public",
    "public_live",
    "public-live",
    "public_research",
    "youtube_live",
}


def walk(value):
    if isinstance(value, str):
        if value.strip().lower() in live_values:
            raise SystemExit(0)
    elif isinstance(value, dict):
        for child in value.values():
            walk(child)
    elif isinstance(value, list):
        for child in value:
            walk(child)


walk(payload)
raise SystemExit(1)
PY
}

systemd_probes_enabled() {
    [[ "${HAPAX_SOURCE_ACTIVATE_SYSTEMD_PROBES:-1}" == "1" ]]
}

live_window_active() {
    if [[ "${HAPAX_SOURCE_ACTIVATE_ALLOW_LIVE_CUTOVER:-0}" == "1" ]]; then
        live_window_status="overridden"
        live_window_message="HAPAX_SOURCE_ACTIVATE_ALLOW_LIVE_CUTOVER enabled"
        return 1
    fi

    local live_flag="${HAPAX_SOURCE_ACTIVATE_LIVE_FLAG:-/dev/shm/hapax-broadcast/livestream-active}"
    local live_flag_max_age_s="${HAPAX_SOURCE_ACTIVATE_LIVE_FLAG_MAX_AGE_S:-120}"
    if fresh_file_exists "$live_flag" "$live_flag_max_age_s"; then
        live_window_status="active"
        live_window_message="fresh livestream active flag: $live_flag"
        return 0
    fi

    local stream_mode_file="${HAPAX_SOURCE_ACTIVATE_STREAM_MODE_FILE:-$HOME/.cache/hapax/stream-mode}"
    if [[ -f "$stream_mode_file" ]]; then
        local stream_mode
        stream_mode="$(tr -d '[:space:]' < "$stream_mode_file" 2>/dev/null || true)"
        case "$stream_mode" in
            public|public_research)
                live_window_status="active"
                live_window_message="stream-mode is $stream_mode"
                return 0
                ;;
        esac
    fi

    local stream_intent_file="${HAPAX_SOURCE_ACTIVATE_STREAM_INTENT_FILE:-/dev/shm/hapax-compositor/stream-mode-intent.json}"
    if stream_intent_indicates_live "$stream_intent_file"; then
        live_window_status="active"
        live_window_message="stream intent indicates live/public output: $stream_intent_file"
        return 0
    fi

    if systemd_probes_enabled \
        && systemctl --user is-active --quiet hapax-obs-livestream.service >/dev/null 2>&1; then
        live_window_status="active"
        live_window_message="hapax-obs-livestream.service is active"
        return 0
    fi

    live_window_status="clear"
    live_window_message="no active live-window signal"
    return 1
}

candidate_path_for_sha() {
    printf '%s/%s\n' "$RELEASES_DIR" "$1"
}

prepare_candidate_worktree() {
    local sha="$1"
    candidate_worktree="$(candidate_path_for_sha "$sha")"
    mkdir -p "$RELEASES_DIR"

    if [[ -e "$candidate_worktree/.git" ]]; then
        git -C "$candidate_worktree" fetch origin main --quiet
        git -C "$candidate_worktree" reset --hard "$sha" --quiet
    elif [[ -e "$candidate_worktree" ]] \
        && [[ -n "$(find "$candidate_worktree" -mindepth 1 -maxdepth 1 2>/dev/null | head -n 1)" ]]; then
        write_receipt "failed" "not_started" "2" "candidate release path exists but is not a git worktree"
        echo "hapax-source-activate: candidate release path exists but is not a git worktree: $candidate_worktree" >&2
        exit 2
    else
        git -C "$CANONICAL_REPO" worktree prune 2>/dev/null || true
        git -C "$CANONICAL_REPO" worktree add --detach "$candidate_worktree" "$sha" --quiet
    fi

    local candidate_head
    candidate_head="$(git -C "$candidate_worktree" rev-parse HEAD)"
    if [[ "$candidate_head" != "$sha" ]]; then
        write_receipt "failed" "not_started" "2" "candidate source head does not match origin/main"
        echo "hapax-source-activate: candidate source $candidate_head != origin/main $sha" >&2
        exit 2
    fi
}

health_probe_fail() {
    local rc="$1"
    local message="$2"
    health_probe_status="failed"
    health_probe_message="$message"
    write_receipt "failed" "not_started" "$rc" "activation health probe failed"
    echo "hapax-source-activate: activation health probe failed: $message" >&2
    exit "$rc"
}

# Soft, re-armable failure for *liveness* probes (the live system isn't healthy
# enough to safely cut over right now — e.g. logos-api restarting, stale frame).
# Write a deferred receipt and exit 0 so this oneshot never enters a failed
# state that could wedge the 2-min re-arming timer (the "died ~09:10 on a
# health-probe exit-1 and never re-armed" failure mode this task fixes). The
# active source stays at the last good SHA — promoting onto an unhealthy system
# is exactly what we want to avoid — and the next cycle retries. Candidate-prep
# failures (source freshness, missing deploy script) keep using health_probe_fail
# (exit 2): those signal a genuinely broken release, not a transient blip.
health_probe_defer() {
    local message="$1"
    health_probe_status="deferred"
    health_probe_message="$message"
    write_receipt "held" "skipped_health_probe" "0" "activation deferred (live system not ready): $message"
    echo "hapax-source-activate: activation deferred, retrying next cycle: $message" >&2
    exit 0
}

run_activation_health_probes() {
    local source_root="$1"
    health_probe_status="running"
    health_probe_message=""

    local candidate_head
    candidate_head="$(git -C "$source_root" rev-parse HEAD 2>/dev/null || true)"
    if [[ "$candidate_head" != "$origin_sha" ]]; then
        health_probe_fail 2 "candidate source freshness failed: $candidate_head != $origin_sha"
    fi

    if [[ ! -x "$source_root/scripts/hapax-post-merge-deploy" ]]; then
        health_probe_fail 2 "candidate deploy script missing or not executable"
    fi

    local probe_parts=("source_freshness=ok" "deploy_script=ok")
    local http_probe_urls="${HAPAX_SOURCE_ACTIVATE_HTTP_PROBES:-}"
    if [[ -z "$http_probe_urls" ]] \
        && systemd_probes_enabled \
        && systemctl --user is-active --quiet logos-api.service >/dev/null 2>&1; then
        http_probe_urls="http://127.0.0.1:8051/api/health http://127.0.0.1:8051/health http://127.0.0.1:8051/"
    fi
    http_probe_urls="${http_probe_urls//,/ }"
    if [[ -n "$http_probe_urls" ]]; then
        if ! command -v curl >/dev/null 2>&1; then
            health_probe_defer "curl executable not found for HTTP health probe"
        fi
        local url http_ok=0
        for url in $http_probe_urls; do
            if curl -fsS --max-time "${HAPAX_SOURCE_ACTIVATE_HTTP_TIMEOUT_S:-2}" "$url" >/dev/null; then
                http_ok=1
                probe_parts+=("http=$url")
                break
            fi
        done
        if [[ "$http_ok" != "1" ]]; then
            health_probe_defer "HTTP health probes failed: $http_probe_urls"
        fi
    else
        probe_parts+=("http=skipped_inactive")
    fi

    local frame_probe_paths="${HAPAX_SOURCE_ACTIVATE_FRAME_PROBES:-}"
    if [[ -z "$frame_probe_paths" ]] \
        && systemd_probes_enabled \
        && { systemctl --user is-active --quiet studio-compositor.service >/dev/null 2>&1 \
            || systemctl --user is-active --quiet hapax-v4l2-bridge.service >/dev/null 2>&1; }; then
        frame_probe_paths="/dev/shm/hapax-compositor/latest-frame.jpg /dev/shm/hapax-compositor/fx-snapshot.jpg /dev/shm/hapax-compositor/frame.jpg"
    fi
    frame_probe_paths="${frame_probe_paths//,/ }"
    if [[ -n "$frame_probe_paths" ]]; then
        local frame_path frame_ok=0
        for frame_path in $frame_probe_paths; do
            if fresh_file_exists "$frame_path" "${HAPAX_SOURCE_ACTIVATE_FRAME_MAX_AGE_S:-10}"; then
                frame_ok=1
                probe_parts+=("frame=$frame_path")
                break
            fi
        done
        if [[ "$frame_ok" != "1" ]]; then
            health_probe_defer "frame freshness probes failed: $frame_probe_paths"
        fi
    else
        probe_parts+=("frame=skipped_inactive")
    fi

    health_probe_status="success"
    health_probe_message="$(IFS=';'; echo "${probe_parts[*]}")"
}

promote_active_worktree() {
    local target="$1"
    local target_real
    target_real="$(realpath -m "$target")"
    refresh_active_source_fields
    previous_active_target="$active_source_target"

    if [[ -L "$ACTIVE_WORKTREE" ]] && [[ "$active_source_target" == "$target_real" ]]; then
        promoted_active_target="$target_real"
        refresh_active_source_fields
        return 0
    fi

    mkdir -p "$(dirname "$ACTIVE_WORKTREE")"
    local tmp_link="${ACTIVE_WORKTREE}.tmp.$$"
    rm -f "$tmp_link"
    ln -s "$target_real" "$tmp_link"

    if [[ -e "$ACTIVE_WORKTREE" && ! -L "$ACTIVE_WORKTREE" ]]; then
        if [[ -e "$ACTIVE_WORKTREE/.git" ]]; then
            local legacy_path
            legacy_path="$STATE_DIR/legacy-worktree-$(date -u +%Y%m%dT%H%M%SZ)"
            mv "$ACTIVE_WORKTREE" "$legacy_path"
            previous_active_target="$(realpath -m "$legacy_path")"
            echo "hapax-source-activate: moved legacy activation worktree to $legacy_path"
        elif [[ -z "$(find "$ACTIVE_WORKTREE" -mindepth 1 -maxdepth 1 2>/dev/null | head -n 1)" ]]; then
            rmdir "$ACTIVE_WORKTREE"
        else
            rm -f "$tmp_link"
            write_receipt "failed" "not_started" "2" "activation path exists but is not a git worktree"
            echo "hapax-source-activate: activation path exists but is not a git worktree: $ACTIVE_WORKTREE" >&2
            exit 2
        fi
    fi

    mv -Tf "$tmp_link" "$ACTIVE_WORKTREE"
    promoted_active_target="$target_real"
    git -C "$CANONICAL_REPO" worktree prune 2>/dev/null || true
    refresh_active_source_fields
}

rollback_active_worktree() {
    local reason="$1"
    if [[ -z "$previous_active_target" ]]; then
        rollback_status="unavailable"
        rollback_message="no previous active target available after: $reason"
        return 1
    fi

    local active_worktree_real previous_target_real
    active_worktree_real="$(realpath -m "$ACTIVE_WORKTREE")"
    previous_target_real="$(realpath -m "$previous_active_target")"
    if [[ "$previous_target_real" == "$active_worktree_real" ]]; then
        rollback_status="unavailable"
        rollback_message="previous active target would self-reference active worktree after: $reason"
        return 1
    fi

    if [[ ! -e "$previous_active_target/.git" ]]; then
        rollback_status="unavailable"
        rollback_message="previous active target is not a git worktree after: $reason"
        return 1
    fi

    local tmp_link="${ACTIVE_WORKTREE}.rollback.$$"
    rm -f "$tmp_link"
    ln -s "$previous_active_target" "$tmp_link"
    mv -Tf "$tmp_link" "$ACTIVE_WORKTREE"
    rollback_status="success"
    rollback_message="restored previous active target after: $reason"
    refresh_active_source_fields
}

if [[ "${HAPAX_SOURCE_ACTIVATE_HOLD:-0}" == "1" || -f "$STATE_DIR/HOLD" ]]; then
    refresh_active_source_fields
    write_receipt "held" "skipped_hold" "0" "source activation hold active"
    echo "hapax-source-activate: held before fetch/reset/symlink sweep/deploy" >&2
    exit 0
fi

canonical_snapshot

if [[ ! -d "$CANONICAL_REPO/.git" && ! -f "$CANONICAL_REPO/.git" ]]; then
    write_receipt "failed" "not_started" "2" "canonical repo missing"
    echo "hapax-source-activate: canonical repo missing at $CANONICAL_REPO" >&2
    exit 2
fi

git -C "$CANONICAL_REPO" fetch origin main --quiet
origin_sha="$(git -C "$CANONICAL_REPO" rev-parse origin/main)"
enforce_force_authority
hold_on_audio_critical_active_drift

prepare_candidate_worktree "$origin_sha"

refresh_active_source_fields
candidate_real="$(realpath -m "$candidate_worktree")"
if [[ "$active_source_target" != "$candidate_real" ]]; then
    if live_window_active; then
        refresh_active_source_fields
        write_receipt \
            "held" \
            "skipped_live_window" \
            "0" \
            "unsafe live window active; cutover deferred"
        echo "hapax-source-activate: held because unsafe live window is active: $live_window_message" >&2
        exit 0
    fi
else
    live_window_status="not_needed"
    live_window_message="active source already points at candidate"
fi

quarantine_untracked_active_source() {
    local source_root="${1:-$ACTIVE_WORKTREE}"
    local rel
    local -a untracked_paths
    local local_bin
    local base
    local link_path
    local link_target
    mapfile -t untracked_paths < <(git -C "$source_root" ls-files --others --exclude-standard)
    if [[ "${#untracked_paths[@]}" -eq 0 ]]; then
        return 0
    fi

    local stamp
    stamp="$(date -u +%Y%m%dT%H%M%SZ)"
    quarantined_untracked_path="$STATE_DIR/untracked-quarantine/${stamp}-${origin_sha:0:8}"
    mkdir -p "$quarantined_untracked_path"

    for rel in "${untracked_paths[@]}"; do
        [[ -z "$rel" ]] && continue
        if is_canonical_runtime_profile_link "$source_root" "$rel"; then
            continue
        fi
        mkdir -p "$quarantined_untracked_path/$(dirname "$rel")"
        mv "$source_root/$rel" "$quarantined_untracked_path/$rel"
        quarantined_untracked_count=$((quarantined_untracked_count + 1))
        case "$rel" in
            scripts/hapax-*|scripts/cc-claim|scripts/cc-close)
                local_bin="${HAPAX_SOURCE_ACTIVATE_LOCAL_BIN:-$HOME/.local/bin}"
                base="$(basename "$rel")"
                link_path="$local_bin/$base"
                link_target="$(readlink "$link_path" 2>/dev/null || true)"
                if [[ "$link_target" == "$source_root/$rel" || "$link_target" == "$ACTIVE_WORKTREE/$rel" ]]; then
                    rm -f "$link_path"
                    quarantined_symlink_count=$((quarantined_symlink_count + 1))
                fi
                ;;
        esac
    done

    echo "hapax-source-activate: quarantined $quarantined_untracked_count untracked activation files to $quarantined_untracked_path"
    if [[ "$quarantined_symlink_count" -gt 0 ]]; then
        echo "hapax-source-activate: removed $quarantined_symlink_count activation-owned symlinks to quarantined files"
    fi
}

is_canonical_runtime_profile_link() {
    local source_root="$1"
    local rel="$2"
    local path="$source_root/$rel"
    [[ "$rel" == profiles/* ]] || return 1
    [[ -L "$path" ]] || return 1
    [[ -d "$CANONICAL_REPO/profiles" ]] || return 1

    local target_real canonical_profiles_real
    target_real="$(readlink -f "$path" 2>/dev/null || true)"
    canonical_profiles_real="$(realpath -m "$CANONICAL_REPO/profiles")"
    [[ -n "$target_real" && "$target_real" == "$canonical_profiles_real"/* ]]
}

link_canonical_runtime_profiles() {
    local source_root="${1:-$ACTIVE_WORKTREE}"
    local canonical_profiles="$CANONICAL_REPO/profiles"
    local active_profiles="$source_root/profiles"
    [[ -d "$canonical_profiles" && -d "$active_profiles" ]] || return 0

    local canonical_profiles_real active_profiles_real
    canonical_profiles_real="$(realpath -m "$canonical_profiles")"
    active_profiles_real="$(realpath -m "$active_profiles")"
    [[ "$canonical_profiles_real" != "$active_profiles_real" ]] || return 0

    local profile_path base dest
    while IFS= read -r -d '' profile_path; do
        base="$(basename "$profile_path")"
        case "$base" in
            .gitkeep|.quarantine) continue ;;
        esac
        dest="$active_profiles/$base"
        if [[ -e "$dest" || -L "$dest" ]]; then
            continue
        fi
        ln -s "$profile_path" "$dest"
        runtime_profile_link_count=$((runtime_profile_link_count + 1))
    done < <(find "$canonical_profiles" -mindepth 1 -maxdepth 1 -print0)

    if [[ "$runtime_profile_link_count" -gt 0 ]]; then
        echo "hapax-source-activate: linked $runtime_profile_link_count runtime profile files from canonical worktree"
    fi
}

quarantine_untracked_active_source "$candidate_worktree"
link_canonical_runtime_profiles "$candidate_worktree"

sync_dependency_environment() {
    local source_root="${1:-$ACTIVE_WORKTREE}"
    if [[ "${HAPAX_SOURCE_ACTIVATE_SYNC_DEPS:-1}" != "1" ]]; then
        dependency_sync_status="skipped_by_flag"
        dependency_sync_message="HAPAX_SOURCE_ACTIVATE_SYNC_DEPS disabled"
        return 0
    fi
    if [[ ! -f "$source_root/pyproject.toml" ]]; then
        dependency_sync_status="skipped_no_pyproject"
        dependency_sync_message="active source has no pyproject.toml"
        return 0
    fi
    if ! command -v uv >/dev/null 2>&1; then
        dependency_sync_status="failed"
        dependency_sync_message="uv executable not found"
        write_receipt "failed" "not_started" "127" "dependency sync failed"
        echo "hapax-source-activate: dependency sync failed — uv executable not found" >&2
        exit 127
    fi
    if (
        cd "$source_root"
        uv sync --all-extras --quiet
    ); then
        dependency_sync_status="success"
        dependency_sync_message="uv sync --all-extras --quiet completed"
        echo "hapax-source-activate: dependency environment synced"
    else
        rc=$?
        dependency_sync_status="failed"
        dependency_sync_message="uv sync --all-extras --quiet failed"
        write_receipt "failed" "not_started" "$rc" "dependency sync failed"
        echo "hapax-source-activate: dependency sync failed for ${origin_sha:0:8}" >&2
        exit "$rc"
    fi
}

sync_dependency_environment "$candidate_worktree"
run_activation_health_probes "$candidate_worktree"
LOCAL_BIN="${HAPAX_SOURCE_ACTIVATE_LOCAL_BIN:-$HOME/.local/bin}"
if ! mkdir -p "$LOCAL_BIN"; then
    write_receipt "failed" "not_started" "2" "managed launcher directory unavailable"
    echo "hapax-source-activate: unable to prepare managed launcher directory $LOCAL_BIN; next action: repair its permissions or free space, then rerun governed source activation" >&2
    exit 2
fi
promote_active_worktree "$candidate_worktree"

if [[ "$active_head" != "$origin_sha" ]]; then
    rollback_active_worktree "active source head mismatch" || true
    write_receipt "failed" "not_started" "2" "active source head does not match origin/main"
    echo "hapax-source-activate: active source $active_head != origin/main $origin_sha; next action: inspect the activation alias and release worktree, then rerun governed source activation" >&2
    exit 2
fi

sweep_count=0
config_sync_count=0
launcher_snapshot_dir=""
launcher_snapshot_ready=0
predeploy_failure_message=""
active_config_dest="$HOME/.config/hapax/usb-topology-policy.json"

snapshot_managed_launchers() {
    local root script base dest
    local -A managed=()
    for root in "$candidate_worktree" "$previous_active_target"; do
        [[ -d "$root/scripts" ]] || continue
        for script in "$root"/scripts/hapax-*; do
            [[ -f "$script" ]] || continue
            base="${script##*/}"
            [[ "$base" =~ ^hapax-[A-Za-z0-9._-]+$ ]] || {
                echo "hapax-source-activate: refusing unsafe managed launcher name: $base; next action: rename the source launcher to hapax-[A-Za-z0-9._-]+ and rerun governed source activation" >&2
                return 1
            }
            managed["$base"]=1
        done
        for base in cc-claim cc-close; do
            [[ -f "$root/scripts/$base" ]] && managed["$base"]=1
        done
    done

    if ! launcher_snapshot_dir="$(mktemp -d "$STATE_DIR/launcher-rollback.XXXXXX")"; then
        launcher_snapshot_dir=""
        echo "hapax-source-activate: unable to reserve managed launcher snapshot; next action: verify $STATE_DIR is writable with free space, then rerun governed source activation" >&2
        return 1
    fi
    if ! mkdir -p "$launcher_snapshot_dir/present"; then
        echo "hapax-source-activate: unable to create managed launcher snapshot storage at $launcher_snapshot_dir; next action: preserve the path for inspection, repair state-directory permissions or free space, then rerun governed source activation" >&2
        return 1
    fi
    if ! : > "$launcher_snapshot_dir/names"; then
        echo "hapax-source-activate: unable to initialize managed launcher snapshot inventory at $launcher_snapshot_dir/names; next action: preserve the path for inspection, repair state-directory permissions or free space, then rerun governed source activation" >&2
        return 1
    fi
    for base in "${!managed[@]}"; do
        if ! printf '%s\n' "$base" >> "$launcher_snapshot_dir/names"; then
            echo "hapax-source-activate: unable to record managed launcher $base in $launcher_snapshot_dir/names; next action: preserve the snapshot path, repair state-directory permissions or free space, then rerun governed source activation" >&2
            return 1
        fi
        dest="$LOCAL_BIN/$base"
        if [[ -e "$dest" || -L "$dest" ]]; then
            if [[ ! -f "$dest" && ! -L "$dest" ]]; then
                echo "hapax-source-activate: refusing non-file managed launcher during snapshot: $dest; next action: move the non-file entry aside without following it and rerun governed source activation" >&2
                return 1
            fi
            if ! cp -a -- "$dest" "$launcher_snapshot_dir/present/$base"; then
                echo "hapax-source-activate: unable to snapshot managed launcher $dest; next action: leave the launcher unchanged, preserve $launcher_snapshot_dir for inspection, repair state-directory permissions or free space, then rerun governed source activation" >&2
                return 1
            fi
        fi
    done
    if [[ -e "$active_config_dest" || -L "$active_config_dest" ]]; then
        if [[ ! -f "$active_config_dest" && ! -L "$active_config_dest" ]]; then
            echo "hapax-source-activate: refusing non-file active config during snapshot: $active_config_dest; next action: move the non-file entry aside without following it and rerun governed source activation" >&2
            return 1
        fi
        if ! cp -a -- "$active_config_dest" "$launcher_snapshot_dir/config-present"; then
            echo "hapax-source-activate: unable to snapshot active config $active_config_dest; next action: leave the config unchanged, preserve $launcher_snapshot_dir for inspection, repair state-directory permissions or free space, then rerun governed source activation" >&2
            return 1
        fi
    fi
    launcher_snapshot_ready=1
}

restore_managed_launchers() {
    [[ "$launcher_snapshot_ready" == "1" ]] || return 0
    local base dest saved restore_temp_dir
    if [[ ! -f "$launcher_snapshot_dir/names" || -L "$launcher_snapshot_dir/names" ]]; then
        echo "hapax-source-activate: managed launcher snapshot inventory is missing or unsafe at $launcher_snapshot_dir/names; next action: preserve $launcher_snapshot_dir and restore launchers from its present directory before rerunning governed source activation" >&2
        return 1
    fi
    while IFS= read -r base; do
        [[ -n "$base" ]] || continue
        dest="$LOCAL_BIN/$base"
        saved="$launcher_snapshot_dir/present/$base"
        if [[ -d "$dest" && ! -L "$dest" ]]; then
            echo "hapax-source-activate: cannot restore launcher over directory: $dest; next action: move the directory aside, preserve $launcher_snapshot_dir, and rerun governed source activation" >&2
            return 1
        fi
        if [[ -e "$saved" || -L "$saved" ]]; then
            if [[ ! -f "$saved" && ! -L "$saved" ]]; then
                echo "hapax-source-activate: refusing unsafe saved launcher during restore: $saved; next action: preserve $launcher_snapshot_dir for inspection and restore $dest manually before rerunning governed source activation" >&2
                return 1
            fi
            if ! restore_temp_dir="$(mktemp -d "$LOCAL_BIN/.${base}.restore.XXXXXX")"; then
                echo "hapax-source-activate: unable to reserve atomic restore storage for $dest; next action: leave $dest unchanged, preserve $launcher_snapshot_dir, repair $LOCAL_BIN permissions or free space, then restore from $saved" >&2
                return 1
            fi
            if ! cp -a -- "$saved" "$restore_temp_dir/$base"; then
                echo "hapax-source-activate: unable to stage saved launcher $saved for atomic restore; next action: leave $dest unchanged, preserve $launcher_snapshot_dir, repair $LOCAL_BIN permissions or free space, then restore the saved launcher manually" >&2
                if ! rm -rf -- "$restore_temp_dir"; then
                    echo "hapax-source-activate: temporary restore storage also remains at $restore_temp_dir; next action: preserve it until launcher recovery is complete" >&2
                fi
                return 1
            fi
            if ! mv -fT -- "$restore_temp_dir/$base" "$dest"; then
                echo "hapax-source-activate: unable to atomically restore $dest from $saved; next action: leave the current launcher unchanged, preserve $launcher_snapshot_dir and $restore_temp_dir, then restore the saved launcher manually" >&2
                return 1
            fi
            if ! rmdir -- "$restore_temp_dir"; then
                echo "hapax-source-activate: restored $dest but could not remove empty temporary directory $restore_temp_dir; next action: verify the restored launcher, remove only the confirmed empty directory, and rerun governed source activation" >&2
                return 1
            fi
        elif ! rm -f -- "$dest"; then
            echo "hapax-source-activate: unable to restore the prior absent state for $dest; next action: preserve $launcher_snapshot_dir, remove the failed-candidate launcher without following it, and rerun governed source activation" >&2
            return 1
        fi
    done < "$launcher_snapshot_dir/names"
}

restore_active_config() {
    [[ "$launcher_snapshot_ready" == "1" ]] || return 0
    local dest="$active_config_dest" saved="$launcher_snapshot_dir/config-present"
    local dest_dir base restore_temp_dir
    dest_dir="$(dirname "$dest")"
    base="${dest##*/}"
    if [[ -d "$dest" && ! -L "$dest" ]]; then
        echo "hapax-source-activate: cannot restore active config over directory: $dest; next action: move the directory aside, preserve $launcher_snapshot_dir, and restore the prior config before rerunning governed source activation" >&2
        return 1
    fi
    if [[ -e "$saved" || -L "$saved" ]]; then
        if [[ ! -f "$saved" && ! -L "$saved" ]]; then
            echo "hapax-source-activate: refusing unsafe saved active config during restore: $saved; next action: preserve $launcher_snapshot_dir for inspection and restore $dest manually before rerunning governed source activation" >&2
            return 1
        fi
        if ! mkdir -p "$dest_dir"; then
            echo "hapax-source-activate: unable to prepare active config restore directory $dest_dir; next action: preserve $launcher_snapshot_dir, repair the directory, and restore $dest from $saved" >&2
            return 1
        fi
        if ! restore_temp_dir="$(mktemp -d "$dest_dir/.${base}.restore.XXXXXX")"; then
            echo "hapax-source-activate: unable to reserve atomic config restore storage for $dest; next action: leave $dest unchanged, preserve $launcher_snapshot_dir, repair $dest_dir permissions or free space, then restore from $saved" >&2
            return 1
        fi
        if ! cp -a -- "$saved" "$restore_temp_dir/$base"; then
            echo "hapax-source-activate: unable to stage saved active config $saved for atomic restore; next action: leave $dest unchanged, preserve $launcher_snapshot_dir and $restore_temp_dir, then restore the saved config manually" >&2
            rm -rf -- "$restore_temp_dir" 2>/dev/null || true
            return 1
        fi
        if ! mv -fT -- "$restore_temp_dir/$base" "$dest"; then
            echo "hapax-source-activate: unable to atomically restore $dest from $saved; next action: leave the current config unchanged, preserve $launcher_snapshot_dir and $restore_temp_dir, then restore the saved config manually" >&2
            return 1
        fi
        if ! rmdir -- "$restore_temp_dir"; then
            echo "hapax-source-activate: restored $dest but could not remove empty temporary directory $restore_temp_dir; next action: verify the restored config, remove only the confirmed empty directory, and rerun governed source activation" >&2
            return 1
        fi
    elif ! rm -f -- "$dest"; then
        echo "hapax-source-activate: unable to restore the prior absent state for $dest; next action: preserve $launcher_snapshot_dir, remove the failed-candidate config without following it, and rerun governed source activation" >&2
        return 1
    fi
}

discard_launcher_snapshot() {
    if [[ -n "$launcher_snapshot_dir" ]] && ! rm -rf -- "$launcher_snapshot_dir"; then
        echo "hapax-source-activate: unable to discard managed launcher snapshot at $launcher_snapshot_dir; next action: preserve it until launcher state is verified, then remove it and rerun governed source activation" >&2
        return 1
    fi
    launcher_snapshot_dir=""
    launcher_snapshot_ready=0
}

rollback_activation() {
    local reason="$1" worktree_rollback=0 launcher_rollback=0 config_rollback=0
    rollback_active_worktree "$reason" || worktree_rollback=$?
    restore_managed_launchers || launcher_rollback=$?
    restore_active_config || config_rollback=$?
    if [[ "$launcher_rollback" -ne 0 || "$config_rollback" -ne 0 ]]; then
        rollback_status="failed"
        rollback_message="active runtime restore failed after: $reason (launchers=$launcher_rollback config=$config_rollback)"
        return 1
    fi
    if ! discard_launcher_snapshot; then
        rollback_status="failed"
        rollback_message="active runtime restored but rollback snapshot cleanup failed after: $reason"
        return 1
    fi
    return "$worktree_rollback"
}

link_active_script() {
    local script="$1"
    [[ -f "$script" ]] || return 0
    if [[ ! -x "$script" ]] && ! chmod +x "$script"; then
        predeploy_failure_message="managed launcher source mode repair failed: $script"
        echo "hapax-source-activate: unable to make managed launcher source executable: $script; next action: restore its executable Git mode and rerun governed source activation" >&2
        return 1
    fi
    local base dest target
    base="$(basename "$script")"
    dest="$LOCAL_BIN/$base"
    # Post-merge deploy installs changed hapax-* launchers as regular copies.
    # Preserve only an executable copy whose bytes match this commit-addressed
    # release. Stale/tampered copies and cc-task tools remain symlink-owned.
    if [[ "$base" == hapax-* && -f "$dest" && ! -L "$dest" && -x "$dest" ]] \
        && [[ "$(stat -c %h -- "$dest" 2>/dev/null || true)" == "1" ]] \
        && cmp -s "$script" "$dest"; then
        return 0
    fi
    target="$(readlink "$dest" 2>/dev/null || true)"
    if [[ "$target" != "$script" ]]; then
        if ! ln -sfnT "$script" "$dest"; then
            predeploy_failure_message="managed launcher publication failed: $dest"
            echo "hapax-source-activate: unable to publish managed launcher $dest; next action: preserve the rollback receipt, repair $LOCAL_BIN permissions or free space, then rerun governed source activation" >&2
            return 1
        fi
        sweep_count=$((sweep_count + 1))
    fi
}

previous_success="$(cat "$LAST_SUCCESS_SHA" 2>/dev/null || true)"
if ! snapshot_managed_launchers; then
    rollback_active_worktree "managed launcher snapshot failed" || true
    discard_launcher_snapshot || true
    write_receipt "failed" "not_started" "2" "managed launcher snapshot failed"
    exit 2
fi

sync_active_config() {
    local src="$1"
    local dst="$2"
    local dst_dir temp
    [[ -e "$src" || -L "$src" ]] || return 0
    if [[ ! -f "$src" || -L "$src" ]]; then
        predeploy_failure_message="active config source is not a release regular file: $src"
        echo "hapax-source-activate: refusing non-regular active config source $src; next action: restore it as a Git-tracked regular file and rerun governed source activation" >&2
        return 1
    fi
    if [[ -f "$dst" && ! -L "$dst" ]] \
        && [[ "$(stat -c %h -- "$dst" 2>/dev/null || true)" == "1" ]] \
        && [[ "$(stat -c %a -- "$dst" 2>/dev/null || true)" == "644" ]] \
        && cmp -s "$src" "$dst"; then
        return 0
    fi
    dst_dir="$(dirname "$dst")"
    if ! mkdir -p "$dst_dir"; then
        predeploy_failure_message="active config directory unavailable: $dst_dir"
        echo "hapax-source-activate: unable to prepare active config directory $dst_dir; next action: repair its permissions or free space, then rerun governed source activation" >&2
        return 1
    fi
    if ! temp="$(mktemp "$dst_dir/.${dst##*/}.activate.XXXXXX")"; then
        predeploy_failure_message="active config staging reservation failed: $dst"
        echo "hapax-source-activate: unable to reserve atomic config staging for $dst; next action: repair $dst_dir permissions or free space, then rerun governed source activation" >&2
        return 1
    fi
    if ! install -m 0644 "$src" "$temp"; then
        predeploy_failure_message="active config staging failed: $dst"
        echo "hapax-source-activate: unable to stage active config $dst; next action: preserve the prior config, repair $dst_dir permissions or free space, then rerun governed source activation" >&2
        rm -f -- "$temp" 2>/dev/null || true
        return 1
    fi
    if ! mv -fT -- "$temp" "$dst"; then
        predeploy_failure_message="active config publication failed: $dst"
        echo "hapax-source-activate: unable to atomically publish active config $dst; next action: preserve the prior config, repair $dst_dir permissions or free space, then rerun governed source activation" >&2
        rm -f -- "$temp" 2>/dev/null || true
        return 1
    fi
    config_sync_count=$((config_sync_count + 1))
}

prepare_active_runtime_surface() {
    local script
    for script in "$ACTIVE_WORKTREE"/scripts/hapax-*; do
        link_active_script "$script" || return 1
    done
    for script in cc-claim cc-close; do
        link_active_script "$ACTIVE_WORKTREE/scripts/$script" || return 1
    done
    sync_active_config \
        "$ACTIVE_WORKTREE/config/usb-topology-policy.json" \
        "$active_config_dest" || return 1
}

if ! prepare_active_runtime_surface; then
    predeploy_failure_message="${predeploy_failure_message:-active runtime publication failed}"
    rollback_activation "$predeploy_failure_message" || true
    write_receipt "failed" "not_started" "2" "$predeploy_failure_message"
    echo "hapax-source-activate: active runtime publication failed and deployment was not started; next action: inspect the rollback receipt, repair the reported destination, then rerun governed source activation" >&2
    exit 2
fi

if [[ "$sweep_count" -gt 0 ]]; then
    echo "hapax-source-activate: swept $sweep_count symlinks to activation worktree"
fi
if [[ "$config_sync_count" -gt 0 ]]; then
    echo "hapax-source-activate: synced $config_sync_count config files from activation worktree"
fi

if [[ "$FORCE" != "1" && "$SKIP_DEPLOY" != "1" && "$previous_success" == "$origin_sha" ]]; then
    discard_launcher_snapshot
    write_receipt "no_op" "skipped_already_active" "0" "origin/main already activated"
    echo "hapax-source-activate: origin/main already activated at ${origin_sha:0:8}"
    exit 0
fi

if [[ "$SKIP_DEPLOY" == "1" ]]; then
    discard_launcher_snapshot
    write_receipt "completed_skip_deploy" "skipped_by_flag" "0" "activation worktree refreshed; deploy skipped by flag"
    echo "hapax-source-activate: refreshed active source at ${origin_sha:0:8}; deploy skipped"
    exit 0
fi

DEPLOY_SCRIPT="${HAPAX_SOURCE_ACTIVATE_DEPLOY_SCRIPT:-$ACTIVE_WORKTREE/scripts/hapax-post-merge-deploy}"
if [[ ! -x "$DEPLOY_SCRIPT" ]]; then
    rollback_activation "deploy script missing" || true
    write_receipt "failed" "not_started" "2" "deploy script missing or not executable"
    echo "hapax-source-activate: deploy script missing or not executable: $DEPLOY_SCRIPT" >&2
    if [[ "$rollback_status" == "success" ]]; then
        echo "hapax-source-activate: restored previous active source after missing deploy script" >&2
    fi
    exit 2
fi

write_receipt "deploying" "in_progress" "0" "active source promoted; post-merge deploy starting"

# Deploy the CUMULATIVE range since the last successful activation so a
# multi-merge jump (origin/main advancing several merges between 2-min cycles)
# installs every intermediate merge's units / confs / scripts — not just the
# tip merge's first-parent diff, which is the single-commit gap behind the
# deploy backlog. Fall back to the single-SHA tip deploy when there is no clean
# ancestor base (first activation, or rewritten history).
deploy_args=("$origin_sha")
if [[ -n "$previous_success" && "$previous_success" != "$origin_sha" ]] \
    && git -C "$ACTIVE_WORKTREE" merge-base --is-ancestor "$previous_success" "$origin_sha" 2>/dev/null; then
    deploy_args=(--since "$previous_success" "$origin_sha")
fi

set +e
(
    cd "$ACTIVE_WORKTREE"
    REPO="$ACTIVE_WORKTREE" "$DEPLOY_SCRIPT" "${deploy_args[@]}"
)
deploy_rc=$?
set -e

if [[ "$deploy_rc" -ne 0 ]]; then
    rollback_activation "post-merge deploy failed" || true
    write_receipt "failed" "failed" "$deploy_rc" "post-merge deploy failed"
    echo "hapax-source-activate: post-merge deploy failed for ${origin_sha:0:8}" >&2
    if [[ "$rollback_status" == "success" ]]; then
        echo "hapax-source-activate: restored previous active source after failed deploy" >&2
    else
        echo "hapax-source-activate: rollback unavailable after failed deploy: $rollback_message" >&2
    fi
    exit "$deploy_rc"
fi

discard_launcher_snapshot
printf '%s\n' "$origin_sha" > "$LAST_SUCCESS_SHA"
refresh_active_source_fields
write_receipt "completed" "success" "0" "origin/main activated"
echo "hapax-source-activate: activated origin/main at ${origin_sha:0:8}"
