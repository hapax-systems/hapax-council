#!/usr/bin/env python3
"""Read-only state witness for optional audio graph branches."""

from __future__ import annotations

import argparse
import json
import subprocess
from datetime import UTC, datetime
from pathlib import Path
from typing import Any

import yaml

REPO_ROOT = Path(__file__).resolve().parents[1]
DEFAULT_POLICY = REPO_ROOT / "config" / "hapax" / "audio-optional-devices.yaml"


def _load_policy(path: Path) -> dict[str, Any]:
    data = yaml.safe_load(path.read_text(encoding="utf-8"))
    if not isinstance(data, dict):
        raise SystemExit(f"invalid optional-device policy: {path}")
    return data


def _load_pw_dump(path: Path | None) -> list[dict[str, Any]]:
    if path is not None:
        raw = path.read_text(encoding="utf-8")
    else:
        proc = subprocess.run(["pw-dump"], text=True, capture_output=True, check=False)
        if proc.returncode != 0:
            raise SystemExit(f"pw-dump failed: {(proc.stderr or proc.stdout).strip()}")
        raw = proc.stdout
    data = json.loads(raw)
    if not isinstance(data, list):
        raise SystemExit("pw-dump JSON must be a list")
    return [item for item in data if isinstance(item, dict)]


def _node_names(pw_dump: list[dict[str, Any]]) -> set[str]:
    names: set[str] = set()
    for item in pw_dump:
        if item.get("type") != "PipeWire:Interface:Node":
            continue
        props = item.get("info", {}).get("props", {})
        if isinstance(props, dict) and isinstance(props.get("node.name"), str):
            names.add(props["node.name"])
    return names


def _branch_state(branch: dict[str, Any], live_nodes: set[str]) -> str:
    node_name = str(branch.get("node_name") or "")
    target = str(branch.get("target_object") or "")
    fail_closed = branch.get("fail_closed_when_absent") is True

    if node_name not in live_nodes:
        return "inactive"
    if target in live_nodes:
        return "present"
    if fail_closed:
        return "absent"
    return "failed"


def build_state(policy: dict[str, Any], pw_dump: list[dict[str, Any]]) -> dict[str, Any]:
    live_nodes = _node_names(pw_dump)
    branches = []
    for branch in policy.get("branches", []):
        if not isinstance(branch, dict):
            continue
        state = _branch_state(branch, live_nodes)
        branches.append(
            {
                "id": branch.get("id"),
                "node_name": branch.get("node_name"),
                "target_object": branch.get("target_object"),
                "source_config": branch.get("source_config"),
                "state": state,
                "target_present": branch.get("target_object") in live_nodes,
                "node_present": branch.get("node_name") in live_nodes,
                "autoconnect": branch.get("autoconnect"),
                "fail_closed_when_absent": branch.get("fail_closed_when_absent"),
            }
        )
    return {
        "schema_version": policy.get("schema_version", 1),
        "generated_at": datetime.now(UTC).replace(microsecond=0).isoformat(),
        "allowed_states": policy.get("allowed_states", []),
        "branches": branches,
        "summary": {
            "present": sum(1 for branch in branches if branch["state"] == "present"),
            "absent": sum(1 for branch in branches if branch["state"] == "absent"),
            "inactive": sum(1 for branch in branches if branch["state"] == "inactive"),
            "reconnecting": sum(1 for branch in branches if branch["state"] == "reconnecting"),
            "failed": sum(1 for branch in branches if branch["state"] == "failed"),
        },
    }


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--policy", type=Path, default=DEFAULT_POLICY)
    parser.add_argument("--pw-dump-json", type=Path, default=None)
    parser.add_argument("--output", type=Path, default=None)
    parser.add_argument("--print", action="store_true", dest="print_json")
    args = parser.parse_args()

    policy = _load_policy(args.policy)
    state = build_state(policy, _load_pw_dump(args.pw_dump_json))
    output = args.output or Path(str(policy.get("state_path", ""))).expanduser()
    if output:
        output.parent.mkdir(parents=True, exist_ok=True)
        output.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    if args.print_json:
        print(json.dumps(state, indent=2, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
