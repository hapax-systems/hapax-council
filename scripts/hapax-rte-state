#!/usr/bin/env python3
"""hapax-rte-state — read latest RTE tick log + return current authority state.

The RTE writes tick logs to ``~/.cache/hapax/relay/rte-tick-<utc>.yaml``. This
tool reads the most recent one and emits the current status (green/yellow/red/
ops-distress) plus a normalized JSON summary.

Used by:
  * admitted send-scripts (hapax-claude-send, hapax-codex-send, hapax-vibe-send)
    as a pre-flight gate — refuse non-essential dispatches when status is
    red/ops-distress
  * peer/codex/vibe lane sessions as a self-poll — check on every wake before
    starting substantive work
  * humans (operator, alpha) for at-a-glance status

Modes:
  hapax-rte-state                  # human-readable summary
  hapax-rte-state --json           # machine-readable for scripting
  hapax-rte-state --status-only    # just the status keyword (green/yellow/red/ops-distress/unknown)
  hapax-rte-state --gate           # exit 0 if green/yellow, 1 if red, 2 if ops-distress

Exit codes:
  0  green or yellow (proceed)
  1  red (RTE has paused new dispatches; defer)
  2  ops-distress (system protect — pause team entirely)
  3  unknown (no recent RTE tick — treat as yellow caution)

Operator directive (2026-05-06): RTE recommendations are AUTHORITATIVE. Lanes
must follow without operator intervention. Send-scripts use this gate to
prevent new work from flooding a paused team.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
import time
from collections.abc import Callable, Mapping
from dataclasses import dataclass
from datetime import UTC as DATETIME_UTC
from datetime import datetime
from pathlib import Path
from typing import Any

REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from shared.capacity_routing_dashboard import (  # noqa: E402
    build_capacity_routing_dashboard,
    parse_optional_utc,
    route_decision_items_from_jsonl,
    route_metadata_items_from_planning_queue,
)
from shared.relay_mq_health import (  # noqa: E402
    execute_escalations,
    execute_retries,
    tick_health,
)

RELAY_DIR = (
    Path(os.environ["HAPAX_RELAY_DIR"])
    if os.environ.get("HAPAX_RELAY_DIR")
    else Path.home() / ".cache" / "hapax" / "relay"
)
ASSIGNMENT_FILE = RELAY_DIR / "rte-assignment.yaml"
PLANNING_FEED_PATH = (
    Path(os.environ["HAPAX_PLANNING_FEED_STATE"])
    if os.environ.get("HAPAX_PLANNING_FEED_STATE")
    else Path.home() / ".cache" / "hapax" / "planning-feed-state.json"
)
TICK_RE = re.compile(r"^rte-tick-(\d{8}T\d{6}Z)\.yaml$")
STALE_AFTER_S = 600.0  # 10 minutes — RTE cadence is 270s, so 2 missed ticks = stale


def find_latest_tick() -> Path | None:
    """Return the most recent rte-tick-*.yaml file."""
    if not RELAY_DIR.exists():
        return None
    candidates: list[tuple[float, Path]] = []
    for p in RELAY_DIR.iterdir():
        if not p.is_file():
            continue
        m = TICK_RE.match(p.name)
        if not m:
            continue
        try:
            mtime = p.stat().st_mtime
        except OSError:
            continue
        candidates.append((mtime, p))
    if not candidates:
        return None
    candidates.sort(reverse=True)
    return candidates[0][1]


def parse_yaml_minimal(text: str) -> dict[str, Any]:
    """Tiny YAML reader for the tick-log subset we care about.

    Avoids a PyYAML dep so the script is no-deps. Handles:
      key: value
      key: |
        block string
      nested.subkey: value (dotted via key.subkey)
      key:
        nested_key: value
    """
    out: dict[str, Any] = {}
    lines = text.split("\n")
    i = 0
    while i < len(lines):
        line = lines[i]
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            i += 1
            continue
        # Skip block-string continuations (indent > 0 after a `|` line)
        if line.startswith("  ") and ":" not in stripped:
            i += 1
            continue
        if ":" not in stripped:
            i += 1
            continue
        leading = len(line) - len(line.lstrip(" "))
        key, _, value = stripped.partition(":")
        key = key.strip()
        value = value.strip()
        if value == "|":
            # block string — skip
            i += 1
            while i < len(lines) and (lines[i].startswith("  ") or not lines[i].strip()):
                i += 1
            continue
        if not value:
            # nested map — collect "first-level" subkeys only
            i += 1
            sub: dict[str, str] = {}
            while i < len(lines):
                sub_line = lines[i]
                sub_strip = sub_line.strip()
                if not sub_strip or sub_strip.startswith("#"):
                    i += 1
                    continue
                sub_lead = len(sub_line) - len(sub_line.lstrip(" "))
                if sub_lead <= leading:
                    break
                if ":" not in sub_strip:
                    i += 1
                    continue
                sk, _, sv = sub_strip.partition(":")
                sub[sk.strip()] = sv.strip().strip('"').strip("'")
                i += 1
            if sub:
                out[key] = sub
            continue
        # Strip quotes
        out[key] = value.strip('"').strip("'")
        i += 1
    return out


def read_tick(path: Path) -> dict[str, Any]:
    try:
        text = path.read_text()
    except OSError:
        return {}
    return parse_yaml_minimal(text)


def read_assignment() -> dict[str, Any]:
    """Read current RTE assignment metadata.

    Missing assignments are observe-only so legacy tick logs remain readable.
    Present-but-expired or invariant-violating assignments fail closed to
    ``unknown`` in ``evaluate`` because the active train then lacks a valid RTE.
    """

    if not ASSIGNMENT_FILE.exists():
        return {"status": "missing", "path": str(ASSIGNMENT_FILE)}
    parsed = read_tick(ASSIGNMENT_FILE)
    rte = str(parsed.get("rte") or "").strip()
    originator = str(parsed.get("originator") or "").strip()
    assigned_at_raw = str(parsed.get("assigned_at") or "").strip()
    expires_at_raw = str(parsed.get("expires_at") or "").strip()
    assigned_at = parse_optional_utc(assigned_at_raw)
    expires_at = parse_optional_utc(expires_at_raw)
    protocol_exception = str(parsed.get("protocol_exception") or "").strip().lower() in {
        "1",
        "true",
        "yes",
        "on",
    }
    now_dt = parse_optional_utc(
        os.environ.get("HAPAX_RTE_NOW") or os.environ.get("HAPAX_CAPACITY_ROUTING_NOW")
    ) or datetime.fromtimestamp(time.time(), DATETIME_UTC)
    status = "active"
    reasons: list[str] = []
    if not rte:
        status = "invalid"
        reasons.append("assignment is missing rte")
    if rte and originator and rte == originator:
        status = "invalid"
        reasons.append("RTE equals originator")
    if assigned_at is None:
        status = "invalid"
        reasons.append("assignment has invalid assigned_at")
    if expires_at is None:
        status = "invalid"
        reasons.append("assignment has invalid expires_at")
    if rte.startswith("vbe-") and not protocol_exception:
        status = "invalid"
        reasons.append("Vibe burst lane requires protocol_exception")
    if (
        rte in {"agy", "antigrav", "antigravity", "gemini"}
        or rte.startswith("agy-")
        or rte.startswith("antigrav-")
        or rte.startswith("antigravity-")
        or rte.startswith("gemini-")
    ):
        status = "invalid"
        reasons.append(
            "retired/excised RTE lane cannot be active; use admitted frontier lanes or "
            "measured agy supply-leaf intake with route/resource/governance receipts"
        )
    if expires_at is not None and expires_at <= now_dt:
        status = "expired"
        reasons.append("assignment expired")
    return {
        "status": status,
        "path": str(ASSIGNMENT_FILE),
        "rte": rte or None,
        "originator": originator or None,
        "assigned_at": assigned_at_raw or None,
        "expires_at": expires_at_raw or None,
        "algorithm": parsed.get("algorithm"),
        "protocol_exception": protocol_exception,
        "reasons": reasons,
    }


def _env_path(name: str, default: Path) -> Path:
    value = os.environ.get(name)
    return Path(value) if value else default


def _optional_env_path(name: str) -> Path | None:
    value = os.environ.get(name)
    return Path(value) if value else None


def _capacity_now() -> datetime | None:
    return parse_optional_utc(os.environ.get("HAPAX_CAPACITY_ROUTING_NOW"))


def _route_decision_ledger_path() -> Path | None:
    value = os.environ.get("HAPAX_ROUTE_DECISION_LEDGER")
    if value:
        return Path(value)
    if os.environ.get("HAPAX_CAPACITY_ROUTING_NOW"):
        return None
    return Path.home() / ".cache" / "hapax" / "orchestration" / "route-decisions.jsonl"


def _planning_feed_route_metadata() -> tuple[
    Mapping[str, object] | None,
    tuple[dict[str, object], ...],
    datetime | None,
]:
    try:
        payload = json.loads(PLANNING_FEED_PATH.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None, (), None
    if not isinstance(payload, Mapping):
        return None, (), None
    dispatch = payload.get("dispatch")
    if not isinstance(dispatch, Mapping):
        return None, (), parse_optional_utc(payload.get("generated_at"))
    summary = dispatch.get("route_metadata_summary")
    planning_queue = dispatch.get("planning_queue")
    return (
        summary if isinstance(summary, Mapping) else None,
        route_metadata_items_from_planning_queue(
            planning_queue if isinstance(planning_queue, list) else []
        ),
        parse_optional_utc(payload.get("generated_at")),
    )


def collect_capacity_routing_dashboard() -> dict[str, Any]:
    """Build warning-only capacity routing state for RTE consumers."""

    summary, items, generated_at = _planning_feed_route_metadata()
    capacity_now = _capacity_now()
    route_decision_path = _route_decision_ledger_path()
    dashboard = build_capacity_routing_dashboard(
        route_metadata_summary=summary,
        route_metadata_items=items,
        route_decision_items=(
            route_decision_items_from_jsonl(route_decision_path, now=capacity_now)
            if route_decision_path is not None
            else ()
        ),
        route_metadata_generated_at=generated_at,
        registry_path=_env_path(
            "HAPAX_PLATFORM_CAPABILITY_REGISTRY",
            REPO_ROOT / "config" / "platform-capability-registry.json",
        ),
        # None resolves the live telemetry ledger when present (fixture fallback).
        quota_spend_ledger_path=_optional_env_path("HAPAX_QUOTA_SPEND_LEDGER"),
        now=capacity_now,
    )
    return dashboard.model_dump(mode="json")


def collect_relay_mq_health(last_tick_at: datetime | None) -> dict[str, Any]:
    """Return fail-open relay MQ health for RTE state consumers."""

    try:
        health = tick_health(last_tick_at=last_tick_at)
    except Exception as exc:
        return {"label": "UNKNOWN", "available": False, "summary": f"UNKNOWN: {exc}"}
    if health is None:
        return {"label": "UNKNOWN", "available": False, "summary": "UNKNOWN: health failed"}
    return {
        "label": health.label,
        "available": health.available,
        "pending_count": health.pending_count,
        "stale_count": health.stale_count,
        "dead_letter_count": health.dead_letter_count,
        "retry_candidate_count": health.retry_candidate_count,
        "escalation_candidate_count": health.escalation_candidate_count,
        "degraded": health.degraded,
        "summary": health.summary(),
    }


def execute_requested_mq_maintenance(*, retry: bool, escalate: bool) -> dict[str, Any]:
    """Run optional fail-open MQ maintenance actions for RTE operators."""

    results: dict[str, Any] = {}
    if retry:
        try:
            result = execute_retries()
            results["retry"] = {
                "label": result.label,
                "changed_count": result.changed_count,
                "reason": result.reason,
            }
        except Exception as exc:
            results["retry"] = {"label": "UNKNOWN", "changed_count": 0, "reason": str(exc)}
    if escalate:
        try:
            result = execute_escalations()
            results["escalate"] = {
                "label": result.label,
                "changed_count": result.changed_count,
                "reason": result.reason,
            }
        except Exception as exc:
            results["escalate"] = {"label": "UNKNOWN", "changed_count": 0, "reason": str(exc)}
    return results


def evaluate() -> dict[str, Any]:
    """Read latest tick, derive current authority state."""
    capacity_routing = collect_capacity_routing_dashboard()
    assignment = read_assignment()
    latest = find_latest_tick()
    now = time.time()
    if latest is None:
        relay_mq = collect_relay_mq_health(None)
        return {
            "status": "unknown",
            "reasons": ["no RTE tick log found in ~/.cache/hapax/relay/"],
            "tick_age_s": None,
            "tick_fresh": False,
            "tick_path": None,
            "assignment": assignment,
            "capacity_routing": capacity_routing,
            "relay_mq": relay_mq,
        }
    tick_mtime = latest.stat().st_mtime
    tick_age_s = now - tick_mtime
    relay_mq = collect_relay_mq_health(datetime.fromtimestamp(tick_mtime, DATETIME_UTC))
    parsed = read_tick(latest)

    # Status: prefer team_load.status if embedded, else fall back to a
    # heuristic from any field named "status" in the tick.
    status = "unknown"
    reasons: list[str] = []

    team_load = parsed.get("team_load")
    if isinstance(team_load, dict):
        status = (team_load.get("status") or "unknown").lower()
        # Reasons may not be parseable from minimal YAML — emit a generic note
        if status in ("red", "ops-distress"):
            reasons.append(f"RTE tick at {latest.name} reports team-load status={status}")

    if assignment.get("status") in {"expired", "invalid"}:
        assignment_reasons = assignment.get("reasons")
        reason = ", ".join(assignment_reasons) if isinstance(assignment_reasons, list) else ""
        return {
            "status": "unknown",
            "reasons": [f"RTE assignment {assignment.get('status')}: {reason}".strip()],
            "tick_age_s": tick_age_s,
            "tick_fresh": tick_age_s <= STALE_AFTER_S,
            "tick_path": str(latest),
            "tick_summary": parsed.get("summary", ""),
            "rte": parsed.get("rte", assignment.get("rte", "unknown")),
            "assignment": assignment,
            "capacity_routing": capacity_routing,
            "relay_mq": relay_mq,
        }

    # Stale-tick gate: if no tick in last 10 min, treat as unknown/yellow
    if tick_age_s > STALE_AFTER_S:
        return {
            "status": "unknown",
            "reasons": [
                f"latest RTE tick is {tick_age_s:.0f}s stale (>{STALE_AFTER_S:.0f}s threshold)"
            ],
            "tick_age_s": tick_age_s,
            "tick_fresh": False,
            "tick_path": str(latest),
            "tick_summary": parsed.get("summary", ""),
            "rte": parsed.get("rte", assignment.get("rte", "unknown")),
            "assignment": assignment,
            "capacity_routing": capacity_routing,
            "relay_mq": relay_mq,
        }

    if not reasons:
        reasons.append(f"RTE tick fresh ({tick_age_s:.0f}s old), status={status}")

    return {
        "status": status,
        "reasons": reasons,
        "tick_age_s": tick_age_s,
        "tick_fresh": True,
        "tick_path": str(latest),
        "tick_summary": parsed.get("summary", ""),
        "rte": parsed.get("rte", assignment.get("rte", "unknown")),
        "assignment": assignment,
        "capacity_routing": capacity_routing,
        "relay_mq": relay_mq,
    }


def status_to_exit(status: str) -> int:
    if status in ("green", "yellow"):
        return 0
    if status == "red":
        return 1
    if status == "ops-distress":
        return 2
    return 3  # unknown


# --------------------------------------------------------------------------- #
# Reform ENGINE — auto-advance dispatcher (CASE-SDLC-REFORM-001)
#
# Drains the coordination-reform execution manifest: each tick, any unit whose
# hard_deps are all MERGED and whose preferred lane is idle gets dispatched
# (hapax-claude/-codex --task + a --require-ack conductor send), subject to the
# <=2x-lane-count open-PR throttle. This is invoked two ways with ZERO new
# daemon: (1) the RTE 270s session tick calls ``hapax-rte-state --dispatch``;
# (2) cc-pr-merge-watcher calls the same after each close (event complement).
# One degrades to the other — poll covers a missed event, event covers a missed
# poll.
#
# Source of truth for "merged": the manifest's per-unit ``status`` field. The
# merge-watcher closes the task on PR-merge and the manifest status is advanced
# to MERGED, which unblocks downstream units on the next sweep.
# --------------------------------------------------------------------------- #

REFORM_MANIFEST_DEFAULT = (
    Path.home() / "Documents" / "Personal" / "30-areas" / "hapax" / "reform-execution-manifest.yaml"
)
LEASE_DIR_DEFAULT = Path.home() / ".cache" / "hapax"
VAULT_ROOT_DEFAULT = Path.home() / "Documents" / "Personal" / "20-projects" / "hapax-cc-tasks"

# A dep is satisfied only when its unit is fully MERGED. MERGING (in the merge
# queue), blocked, blocked_on_research are NOT satisfied.
MERGED_STATUSES = frozenset({"merged"})
# A unit is dispatchable only when it is pending (or status-less, as the
# immediate ``fixes`` entries are). Everything else is in-flight or terminal.
DISPATCHABLE_STATUSES = frozenset({"", "pending"})

# Codex first-class lanes use the cx- prefix; everything else is a Claude lane.
CODEX_LANE_PREFIX = "cx-"


@dataclass(frozen=True)
class ReformUnit:
    """One dispatchable reform work item (a ``units`` phase or a ``fixes`` entry)."""

    id: str
    lane: str
    hard_deps: tuple[str, ...]
    status: str  # normalized lower-case; "" when the manifest omits it
    authority_case: str | None
    branch: str | None
    summary: str


@dataclass(frozen=True)
class DispatchDecision:
    """A single resolved decision to wake one lane for one ready unit."""

    unit_id: str
    lane: str
    authority_case: str | None
    summary: str


def _reform_unit_from_raw(raw: Mapping[str, Any]) -> ReformUnit | None:
    uid = str(raw.get("id") or "").strip()
    if not uid:
        return None
    deps_raw = raw.get("hard_deps") or []
    deps = tuple(str(d).strip() for d in deps_raw if str(d).strip())
    ac = raw.get("authority_case")
    branch = raw.get("branch")
    return ReformUnit(
        id=uid,
        lane=str(raw.get("lane") or "").strip(),
        hard_deps=deps,
        status=str(raw.get("status") or "").strip().lower(),
        authority_case=str(ac).strip() if ac else None,
        branch=str(branch).strip() if branch else None,
        summary=str(raw.get("summary") or "").strip(),
    )


def _load_yaml_section(text: str, key: str, yaml: Any) -> list[Any]:
    """Parse a single top-level ``key:`` block independently of its siblings.

    The execution manifest's prose-heavy ``meta``/``auto_advance`` blocks contain
    unquoted colons that make whole-document parsing raise; isolating the
    ``units``/``fixes`` blocks lets them load anyway.
    """
    captured: list[str] = []
    capturing = False
    for line in text.split("\n"):
        if not capturing:
            if re.match(rf"^{re.escape(key)}:\s*(#.*)?$", line):
                capturing = True
                captured.append(line)
            continue
        # Stop at the next top-level key (a non-indented ``word:``).
        if line[:1] not in (" ", "\t", "") and re.match(r"^[A-Za-z_][\w-]*:", line):
            break
        captured.append(line)
    if not captured:
        return []
    try:
        doc = yaml.safe_load("\n".join(captured))
    except yaml.YAMLError:
        return []
    if isinstance(doc, Mapping) and isinstance(doc.get(key), list):
        return doc[key]
    return []


def load_reform_manifest(path: Path) -> list[ReformUnit]:
    """Parse the execution manifest into ReformUnit items (fail-open to []).

    Reads the ``units`` phases first, then the immediate ``fixes`` follow-ups —
    both are lane-assigned, dep-aware work the dispatcher can drain. Falls back
    to per-section parsing when whole-document YAML fails (the live manifest
    carries unquoted colons in its prose blocks).
    """
    try:
        import yaml  # lazy: keep the rest of this tool dependency-free
    except ImportError:
        return []
    try:
        text = Path(path).read_text(encoding="utf-8")
    except OSError:
        return []
    try:
        data = yaml.safe_load(text)
    except yaml.YAMLError:
        data = None
    if not isinstance(data, Mapping):
        data = {}

    out: list[ReformUnit] = []
    for key in ("units", "fixes"):
        section = data.get(key)
        if not isinstance(section, list):
            section = _load_yaml_section(text, key, yaml)
        for raw in section:
            if isinstance(raw, Mapping):
                unit = _reform_unit_from_raw(raw)
                if unit is not None:
                    out.append(unit)
    return out


def unit_is_merged(unit: ReformUnit) -> bool:
    return unit.status in MERGED_STATUSES


def unit_is_dispatchable(unit: ReformUnit) -> bool:
    return unit.status in DISPATCHABLE_STATUSES


def ready_units(units: list[ReformUnit]) -> list[ReformUnit]:
    """Dispatchable units whose every hard_dep resolves to a MERGED unit.

    An unknown dep id (not present in the manifest) is treated as NOT merged, so
    a unit with a dangling dep stays blocked rather than dispatching early.
    """
    by_id = {u.id: u for u in units}
    ready: list[ReformUnit] = []
    for unit in units:
        if not unit_is_dispatchable(unit):
            continue
        deps_ok = all(dep in by_id and unit_is_merged(by_id[dep]) for dep in unit.hard_deps)
        if deps_ok:
            ready.append(unit)
    return ready


def lane_is_idle(lane: str, *, lease_dir: Path) -> bool:
    """A lane is idle when it holds no non-empty cc-active-task lease.

    Checks both the legacy ``cc-active-task-<lane>`` and any session-keyed
    ``cc-active-task-<lane>-<session>`` lease (cc-claim writes both).
    """
    lease_dir = Path(lease_dir)
    exact = lease_dir / f"cc-active-task-{lane}"
    if exact.is_file():
        try:
            if exact.read_text(encoding="utf-8").strip():
                return False
        except OSError:
            pass
    for leased in lease_dir.glob(f"cc-active-task-{lane}-*"):
        if not leased.is_file():
            continue
        try:
            if leased.read_text(encoding="utf-8").strip():
                return False
        except OSError:
            continue
    return True


def manifest_lane_count(units: list[ReformUnit]) -> int:
    return len({u.lane for u in units if u.lane})


def count_open_prs(
    *, repo_root: Path, runner: Callable[..., subprocess.CompletedProcess] | None = None
) -> int | None:
    """Return the number of open PRs, or None when ``gh`` is unavailable."""
    runner = runner or subprocess.run
    try:
        proc = runner(
            ["gh", "pr", "list", "--state", "open", "--json", "number", "--limit", "200"],
            cwd=str(repo_root),
            capture_output=True,
            text=True,
            check=False,
            timeout=30,
        )
    except (OSError, subprocess.SubprocessError):
        return None
    if getattr(proc, "returncode", 1) != 0:
        return None
    try:
        return len(json.loads(proc.stdout or "[]"))
    except (json.JSONDecodeError, TypeError):
        return None


def dispatch_headroom(open_pr_count: int | None, lane_count: int) -> int:
    """Open-PR throttle: cap = 2 x lane-count. Unknown count fails closed (0)."""
    if open_pr_count is None:
        return 0
    return max(0, (2 * lane_count) - open_pr_count)


def plan_dispatch(
    units: list[ReformUnit], *, idle_lanes: set[str], headroom: int
) -> list[DispatchDecision]:
    """Pick ready units on idle lanes — one per lane per sweep, capped at headroom."""
    if headroom <= 0:
        return []
    decisions: list[DispatchDecision] = []
    used_lanes: set[str] = set()
    for unit in ready_units(units):
        if unit.lane not in idle_lanes or unit.lane in used_lanes:
            continue
        decisions.append(
            DispatchDecision(
                unit_id=unit.id,
                lane=unit.lane,
                authority_case=unit.authority_case,
                summary=unit.summary,
            )
        )
        used_lanes.add(unit.lane)
        if len(decisions) >= headroom:
            break
    return decisions


def _note_task_id(note: Path) -> str | None:
    try:
        text = note.read_text(encoding="utf-8")
    except OSError:
        return None
    m = re.search(r"^task_id:\s*(.+?)\s*$", text, flags=re.MULTILINE)
    return m.group(1).strip() if m else None


def resolve_task_for_unit(unit: ReformUnit, *, vault_root: Path) -> str | None:
    """Find an active cc-task note for this unit (task_id contains the unit slug).

    Returns None when no task is filed — the dispatcher reports such units rather
    than minting tasks itself (idempotency: poll + event both call this).
    """
    active = Path(vault_root) / "active"
    if not active.is_dir():
        return None
    slug = unit.id.lower()
    for note in sorted(active.glob("*.md")):
        if slug in note.stem.lower():
            return _note_task_id(note) or note.stem
    return None


def _conductor_prompt(unit_id: str, lane: str, summary: str) -> str:
    """The --require-ack send body that re-establishes a build lane on a unit."""
    return (
        f"You are a coordination-reform BUILD LANE, claimed on reform unit {unit_id} "
        f"(lane {lane}). READ FIRST: your unit in "
        "~/Documents/Personal/30-areas/hapax/reform-execution-manifest.yaml (follow its "
        "re-steered summary) + memory project_coordination_reform_driving (merge recipe + "
        "gate route-arounds). Implement YOUR unit ONLY, TDD-first, within your "
        "mutation_scope_refs, to a merged PR, then auto-advance. Standing authorization: "
        "everything approved, mint capabilities yourself, no human sign-off, no live-broadcast "
        f"gates. Bounded slice — systematic bottom-up, no scope creep. Summary: {summary}"
    )


def dispatch_command(
    decision: DispatchDecision, task_id: str, *, repo_root: Path
) -> tuple[list[str], list[str]]:
    """Build the (launch, send) argv pair for one dispatch decision."""
    repo_root = Path(repo_root)
    is_codex = decision.lane.startswith(CODEX_LANE_PREFIX)
    launch_tool = "hapax-codex" if is_codex else "hapax-claude"
    send_tool = "hapax-codex-send" if is_codex else "hapax-claude-send"
    launch = [
        str(repo_root / "scripts" / launch_tool),
        "--terminal",
        "tmux",
        "--role",
        decision.lane,
        "--task",
        task_id,
    ]
    send = [
        str(repo_root / "scripts" / send_tool),
        "--session",
        decision.lane,
        "--require-ack",
        "--",
        _conductor_prompt(decision.unit_id, decision.lane, decision.summary),
    ]
    return launch, send


def dispatch_one(
    decision: DispatchDecision,
    task_id: str,
    *,
    repo_root: Path,
    runner: Callable[..., subprocess.CompletedProcess] | None = None,
) -> bool:
    """Launch the lane then send the conductor prompt. Returns True on launch success."""
    runner = runner or subprocess.run
    launch, send = dispatch_command(decision, task_id, repo_root=repo_root)
    try:
        proc = runner(
            launch, cwd=str(repo_root), capture_output=True, text=True, check=False, timeout=120
        )
    except (OSError, subprocess.SubprocessError):
        return False
    if getattr(proc, "returncode", 1) != 0:
        return False
    # Lane is up; the prompt is best-effort (a re-poll re-sends if it was missed).
    try:
        runner(send, cwd=str(repo_root), capture_output=True, text=True, check=False, timeout=60)
    except (OSError, subprocess.SubprocessError):
        pass
    return True


def run_dispatch(
    *,
    manifest_path: Path,
    lease_dir: Path,
    vault_root: Path,
    repo_root: Path,
    runner: Callable[..., subprocess.CompletedProcess] | None = None,
    dry_run: bool = False,
) -> dict[str, Any]:
    """One manifest-drain sweep. Pure decision-making + (unless dry-run) execution."""
    runner = runner or subprocess.run
    units = load_reform_manifest(manifest_path)
    by_id = {u.id: u for u in units}
    ready = ready_units(units)
    lane_count = manifest_lane_count(units)
    open_prs = count_open_prs(repo_root=repo_root, runner=runner)
    headroom = dispatch_headroom(open_prs, lane_count)
    idle_lanes = {u.lane for u in ready if lane_is_idle(u.lane, lease_dir=lease_dir)}
    plan = plan_dispatch(units, idle_lanes=idle_lanes, headroom=headroom)

    result: dict[str, Any] = {
        "ready": [u.id for u in ready],
        "lane_count": lane_count,
        "open_prs": open_prs,
        "headroom": headroom,
        "throttled": headroom <= 0,
        "planned": [d.unit_id for d in plan],
        "dispatched": [],
        "skipped_no_task": [],
        "dry_run": dry_run,
    }

    for decision in plan:
        unit = by_id[decision.unit_id]
        task_id = resolve_task_for_unit(unit, vault_root=vault_root)
        if not task_id:
            result["skipped_no_task"].append(decision.unit_id)
            continue
        if dry_run:
            continue
        if dispatch_one(decision, task_id, repo_root=repo_root, runner=runner):
            result["dispatched"].append(decision.unit_id)
    return result


def main() -> int:
    ap = argparse.ArgumentParser(
        description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter
    )
    ap.add_argument("--json", action="store_true", help="machine-readable JSON")
    ap.add_argument("--status-only", action="store_true", help="print only the status keyword")
    ap.add_argument(
        "--gate",
        action="store_true",
        help="exit-code-only (0=green/yellow, 1=red, 2=ops-distress, 3=unknown)",
    )
    ap.add_argument(
        "--mq-retry",
        action="store_true",
        help="fail-open re-offer read MQ messages past retry interval before reporting state",
    )
    ap.add_argument(
        "--mq-escalate",
        action="store_true",
        help="fail-open escalate MQ messages past deadline before reporting state",
    )
    ap.add_argument(
        "--dispatch",
        action="store_true",
        help="drain the reform execution manifest: dispatch ready+idle units (auto-advance)",
    )
    ap.add_argument(
        "--dry-run",
        action="store_true",
        help="with --dispatch: compute the plan without launching any lane",
    )
    args = ap.parse_args()

    if args.dispatch:
        result = run_dispatch(
            manifest_path=Path(os.environ.get("HAPAX_REFORM_MANIFEST", REFORM_MANIFEST_DEFAULT)),
            lease_dir=Path(os.environ.get("HAPAX_LEASE_DIR", LEASE_DIR_DEFAULT)),
            vault_root=Path(os.environ.get("HAPAX_CC_TASKS_VAULT", VAULT_ROOT_DEFAULT)),
            repo_root=REPO_ROOT,
            dry_run=args.dry_run,
        )
        if args.json:
            print(json.dumps(result, indent=2))
        else:
            print(
                f"reform dispatch: ready={len(result['ready'])} "
                f"planned={len(result['planned'])} dispatched={result['dispatched']} "
                f"skipped_no_task={result['skipped_no_task']} throttled={result['throttled']}"
            )
        return 0

    mq_maintenance = execute_requested_mq_maintenance(
        retry=args.mq_retry,
        escalate=args.mq_escalate,
    )
    state = evaluate()
    if mq_maintenance:
        state["relay_mq_maintenance"] = mq_maintenance
    status = state["status"]

    if args.gate:
        return status_to_exit(status)

    if args.status_only:
        print(status)
        return status_to_exit(status)

    if args.json:
        print(json.dumps(state, indent=2))
        return status_to_exit(status)

    age = state["tick_age_s"]
    age_str = f"{age:.0f}s ago" if age is not None else "never"
    print(f"RTE state: {status.upper()}")
    print(f"  rte: {state.get('rte', 'unknown')}")
    print(f"  tick: {state.get('tick_path', '(none)')}")
    print(f"  tick age: {age_str}")
    print(f"  summary: {state.get('tick_summary', '')}")
    relay_mq = state.get("relay_mq")
    if isinstance(relay_mq, dict):
        print(f"  relay mq: {relay_mq.get('summary', 'UNKNOWN')}")
    maintenance = state.get("relay_mq_maintenance")
    if isinstance(maintenance, dict):
        for action, result in maintenance.items():
            if isinstance(result, dict):
                print(
                    "  relay mq "
                    f"{action}: {result.get('label')} changed={result.get('changed_count')}"
                )
    for r in state["reasons"]:
        print(f"  • {r}")
    capacity_routing = state.get("capacity_routing")
    if isinstance(capacity_routing, dict):
        warning_count = int(capacity_routing.get("warning_count") or 0)
        if warning_count:
            print(f"  capacity routing warnings: {warning_count} (observe-only)")
            for warning in capacity_routing.get("non_green_states", [])[:5]:
                if not isinstance(warning, dict):
                    continue
                print(f"    - {warning.get('state')}: {warning.get('summary')}")
    if status in ("red", "ops-distress"):
        print()
        print("  RTE AUTHORITY: dispatches deferred, lanes hold pattern.")
        print("  Override only with --rte-bypass on send scripts (operator emergency).")
    return status_to_exit(status)


if __name__ == "__main__":
    sys.exit(main())
