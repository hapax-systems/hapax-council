DEFAULT_MAX_HLS_TARGET_DURATION_SECONDS = 120.0
FULL_SURFACE_MIN_FX_SLOTS = 8
FULL_SURFACE_MIN_VISIBLE_WARDS = 3
FULL_SURFACE_LEGACY_STATIC_LAYOUTS = frozenset({"default", "garage-door"})
FULL_SURFACE_STAGE_FPS_FLOORS = (
