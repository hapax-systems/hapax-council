def _bool_arg(value: str) -> bool:
    return value.strip().lower() in {"1", "true", "yes", "active"}


def _systemd_active(unit: str) -> bool:
    result = subprocess.run(
        ["systemctl", "--user", "is-active", unit],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    return result.stdout.strip() == "active"


def _main_pid(unit: str) -> int | None:
    result = subprocess.run(
        ["systemctl", "--user", "show", unit, "-p", "MainPID", "--value"],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    try:
        pid = int(result.stdout.strip())
    except ValueError:
        return None
    return pid if pid > 0 else None


def _selected_proc_env(pid: int | None) -> dict[str, str]:
    if pid is None:
        return {}
    environ = Path(f"/proc/{pid}/environ")
    try:
        raw = environ.read_bytes()
    except OSError:
        return {}
    selected: dict[str, str] = {}
    for entry in raw.split(b"\0"):
        if b"=" not in entry:
            continue
        key, value = entry.split(b"=", 1)
        name = key.decode("utf-8", "ignore")
        if name in SELECTED_ENV:
            selected[name] = value.decode("utf-8", "ignore")
    return selected


def _load_metrics(args: argparse.Namespace) -> str:
    metrics_file_after = getattr(args, "metrics_file_after", None)
    if metrics_file_after and getattr(args, "_loading_after_sample", False):
        text = Path(metrics_file_after).read_text(encoding="utf-8")
    elif args.metrics_file:
        text = Path(args.metrics_file).read_text(encoding="utf-8")
    else:
        with urllib.request.urlopen(args.metrics_url, timeout=2.0) as response:
            text = response.read().decode("utf-8", "replace")
    extra_files = args.extra_metrics_file
    if extra_files is None:
        extra_files = [] if args.metrics_file else list(DEFAULT_EXTRA_METRICS_FILES)
    for path in extra_files:
        text = _append_metrics_file(text, path)
    return text


def _append_metrics_file(text: str, path: Path) -> str:
    try:
        extra_text = path.read_text(encoding="utf-8")
        age_seconds = max(0.0, time.time() - path.stat().st_mtime)
    except OSError:
        return text
    extra_metrics = parse_prometheus_scalars(extra_text)
    heartbeat = extra_metrics.get("hapax_v4l2_bridge_heartbeat_seconds_ago")
    if heartbeat is not None:
        extra_text = (
            f"{extra_text.rstrip()}\n"
            f"hapax_v4l2_bridge_heartbeat_seconds_ago {max(heartbeat, age_seconds)}\n"
        )
    obs_age = extra_metrics.get("hapax_obs_decoder_screenshot_seconds_ago")
    if obs_age is not None:
        extra_text = (
            f"{extra_text.rstrip()}\n"
            f"hapax_obs_decoder_screenshot_seconds_ago {max(obs_age, age_seconds)}\n"
        )
    return f"{text.rstrip()}\n{extra_text}"


def _proc_cpu_seconds(pid: int | None) -> float | None:
    if pid is None:
        return None
    stat_path = Path(f"/proc/{pid}/stat")
    try:
        raw = stat_path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return None
    close_idx = raw.rfind(")")
    if close_idx < 0:
        return None
    fields = raw[close_idx + 2 :].split()
    if len(fields) <= 12:
        return None
    try:
        user_ticks = float(fields[11])
        system_ticks = float(fields[12])
    except (TypeError, ValueError):
        return None
    try:
        ticks_per_second = float(os.sysconf("SC_CLK_TCK"))
    except (AttributeError, OSError, ValueError):
        return None
    if ticks_per_second <= 0:
        return None
    return (user_ticks + system_ticks) / ticks_per_second


def _file_age_seconds(path: Path) -> float | None:
    try:
        stat = path.stat()
    except OSError:
        return None
    if not path.is_file():
        return None
    return time.time() - stat.st_mtime


def _hls_target_duration_seconds(path: Path) -> float | None:
    try:
        text = path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return None
    for raw_line in text.splitlines():
        line = raw_line.strip()
        if not line.startswith("#EXT-X-TARGETDURATION:"):
            continue
        _, raw_value = line.split(":", 1)
        try:
            value = float(raw_value)
        except ValueError:
            return None
        return value if value > 0 else None
    return None


def _default_hls_max_age_seconds(path: Path) -> float:
    target_duration = _hls_target_duration_seconds(path)
    if target_duration is None:
        return 10.0
    return max(10.0, (target_duration * 2.0) + 2.0)


def _with_extra_degraded_reasons(
    state: LiveSurfaceState,
    reasons: list[str],
    extra_reasons: list[str],
) -> tuple[LiveSurfaceState, list[str]]:
    if not extra_reasons:
        return state, reasons
    merged = [*reasons, *extra_reasons]
    if state is LiveSurfaceState.HEALTHY:
        return LiveSurfaceState.DEGRADED_CONTAINMENT, merged
    return state, merged


def _full_surface_reason(criterion_id: str, slug: str) -> str:
    return f"full_surface:{criterion_id}:{slug}"


def _full_surface_env_failures(env: dict[str, str]) -> list[str]:
    failures: list[str] = []
    for key, blocked_value, criterion_id, slug in FULL_SURFACE_BLOCKING_ENV:
        value = env.get(key)
        if value is not None and value.strip().lower() == blocked_value:
            failures.append(_full_surface_reason(criterion_id, slug))

    raw_slots = env.get("HAPAX_COMPOSITOR_FX_SLOTS")
    if raw_slots is not None:
        try:
            slots = int(raw_slots)
        except ValueError:
            failures.append(_full_surface_reason("LSC-FX-001", "fx_slots_invalid"))
        else:
            if slots < FULL_SURFACE_MIN_FX_SLOTS:
                failures.append(
                    _full_surface_reason(
                        "LSC-FX-001",
                        f"fx_slots_below_min:{slots}<{FULL_SURFACE_MIN_FX_SLOTS}",
                    )
                )
    return failures


def _responsible_default_mode(layout_mode: str | None) -> bool:
    if layout_mode is None:
        return False
    return mode_family(layout_mode) in FULL_SURFACE_RESPONSIBLE_DEFAULT_MODE_FAMILIES


def _full_surface_metric_failures(
    metrics: dict[str, float],
    *,
    layout_mode: str | None = None,
) -> list[str]:
    failures: list[str] = []
    for feature, criterion_id in FULL_SURFACE_REQUIRED_FEATURES:
        key = f"studio_compositor_runtime_feature_active:feature:{feature}"
        if key not in metrics:
            failures.append(_full_surface_reason(criterion_id, f"feature_unknown:{feature}"))
        elif metrics[key] <= 0:
            failures.append(_full_surface_reason(criterion_id, f"feature_inactive:{feature}"))

    flash_key = "studio_compositor_runtime_feature_active:feature:flash_overlay"
    if metrics.get(flash_key, 0) > 0:
        failures.append(_full_surface_reason("LSC-AUDIOREACT-001", "visual_pumping_active"))

    ward_blits = {
        key.removeprefix("studio_compositor_ward_blit_total:ward:"): value
        for key, value in metrics.items()
        if key.startswith("studio_compositor_ward_blit_total:ward:")
    }
    visible_wards = sum(1 for value in ward_blits.values() if value > 0)
    if visible_wards < FULL_SURFACE_MIN_VISIBLE_WARDS:
        failures.append(
            _full_surface_reason(
                "LSC-WARD-001",
                f"visible_ward_count_below_min:{visible_wards}<{FULL_SURFACE_MIN_VISIBLE_WARDS}",
            )
        )

    if metrics.get("hapax_ward_modulator_tick_total", 0) <= 0:
        failures.append(_full_surface_reason("LSC-WARD-002", "ward_modulator_no_ticks"))

    if metrics.get("studio_compositor_gem_substrate_active", 0) <= 0:
        failures.append(_full_surface_reason("LSC-SCRIM-001", "gem_substrate_not_active"))
    if metrics.get("studio_compositor_gem_substrate_paint_total", 0) <= 0:
        failures.append(_full_surface_reason("LSC-SCRIM-001", "gem_substrate_not_painting"))

    active_layouts = {
        key.removeprefix("hapax_compositor_layout_active:layout:"): value
        for key, value in metrics.items()
        if key.startswith("hapax_compositor_layout_active:layout:")
    }
    active_names = [name for name, value in active_layouts.items() if value > 0]
    if not active_names:
        failures.append(_full_surface_reason("LSC-LAYOUT-003", "active_layout_unknown"))
    for layout_name in sorted(active_names):
        if layout_name in FULL_SURFACE_LEGACY_STATIC_LAYOUTS:
            if _responsible_default_mode(layout_mode):
                continue
            failures.append(
                _full_surface_reason(
                    "LSC-LAYOUT-003",
                    f"legacy_static_layout_active:{layout_name}",
                )
            )
    return failures


def _render_stage_count(metrics: dict[str, float], stage: str) -> float | None:
    return metrics.get(f"studio_compositor_render_stage_frames_total:stage:{stage}")


def _bridge_mode_active(metrics: dict[str, float]) -> bool:
    if metrics.get("studio_compositor_runtime_feature_active:feature:shmsink_bridge", 0) > 0:
        return True
    return "hapax_v4l2_bridge_write_frames_total" in metrics


def _counter_rate(
    before_metrics: dict[str, float],
    after_metrics: dict[str, float],
    name: str,
    elapsed: float,
) -> float | None:
    before = before_metrics.get(name)
    after = after_metrics.get(name)
    if before is None or after is None:
        return None
    return max(0.0, (after - before) / elapsed)


def _metric_delta(
    before_metrics: dict[str, float],
    after_metrics: dict[str, float],
    name: str,
) -> float | None:
    before = before_metrics.get(name)
    after = after_metrics.get(name)
    if before is None or after is None:
        return None
    return after - before


def _full_surface_resource_delta_failures(
    before_metrics: dict[str, float],
    after_metrics: dict[str, float],
) -> tuple[list[str], dict[str, float | None]]:
    deltas = {
        "rss_growth_bytes": _metric_delta(
            before_metrics,
            after_metrics,
            "studio_compositor_memory_footprint_bytes",
        ),
        "vram_growth_bytes": _metric_delta(
            before_metrics,
            after_metrics,
            "studio_compositor_gpu_vram_bytes",
        ),
        "fd_growth": _metric_delta(
            before_metrics,
            after_metrics,
            "studio_compositor_process_fd_count",
        ),
        "v4l2_write_error_delta": _metric_delta(
            before_metrics,
            after_metrics,
            "hapax_compositor_v4l2_write_errors_total",
        ),
        "v4l2_fd_reopen_delta": _metric_delta(
            before_metrics,
            after_metrics,
            "hapax_compositor_v4l2_fd_reopens_total",
        ),
        "glfeedback_recompile_delta": _metric_delta(
            before_metrics,
            after_metrics,
            "compositor_glfeedback_recompile_total",
        ),
    }

    failures: list[str] = []
    rss_growth = deltas["rss_growth_bytes"]
    if rss_growth is not None and rss_growth > FULL_SURFACE_MAX_RSS_GROWTH_BYTES:
        failures.append(
            _full_surface_reason(
                "LSC-PERF-003",
                f"rss_growth_above_limit:{int(rss_growth)}>{FULL_SURFACE_MAX_RSS_GROWTH_BYTES}",
            )
        )
    vram_growth = deltas["vram_growth_bytes"]
    if vram_growth is not None and vram_growth > FULL_SURFACE_MAX_VRAM_GROWTH_BYTES:
        failures.append(
            _full_surface_reason(
                "LSC-PERF-003",
                f"vram_growth_above_limit:{int(vram_growth)}>{FULL_SURFACE_MAX_VRAM_GROWTH_BYTES}",
            )
        )
    fd_growth = deltas["fd_growth"]
    if fd_growth is not None and fd_growth > FULL_SURFACE_MAX_FD_GROWTH:
        failures.append(
            _full_surface_reason(
                "LSC-PERF-003",
                f"fd_growth_above_limit:{int(fd_growth)}>{FULL_SURFACE_MAX_FD_GROWTH}",
            )
        )
    write_delta = deltas["v4l2_write_error_delta"]
    if write_delta is not None and write_delta > FULL_SURFACE_MAX_V4L2_WRITE_ERROR_DELTA:
        failures.append(
            _full_surface_reason(
                "LSC-EGRESS-001",
                f"v4l2_write_errors_delta:{int(write_delta)}>0",
            )
        )
    reopen_delta = deltas["v4l2_fd_reopen_delta"]
    if reopen_delta is not None and reopen_delta > FULL_SURFACE_MAX_V4L2_FD_REOPEN_DELTA:
        failures.append(
            _full_surface_reason(
                "LSC-EGRESS-001",
                f"v4l2_fd_reopens_delta:{int(reopen_delta)}>0",
            )
        )
    recompile_delta = deltas["glfeedback_recompile_delta"]
    if (
        recompile_delta is not None
        and recompile_delta > FULL_SURFACE_MAX_GLFEEDBACK_RECOMPILE_DELTA
    ):
        failures.append(
            _full_surface_reason(
                "LSC-FX-002",
                "glfeedback_recompile_delta_above_limit:"
                f"{int(recompile_delta)}>{FULL_SURFACE_MAX_GLFEEDBACK_RECOMPILE_DELTA}",
            )
        )

    return failures, deltas


def _full_surface_performance_sample(
    args: argparse.Namespace,
    before_metrics: dict[str, float],
    *,
    pid: int | None,
) -> tuple[list[str], dict[str, object]]:
    has_synthetic_after = bool(args.metrics_file_after)
    if args.full_surface_sample_seconds is None:
        sample_seconds = 0.0 if args.metrics_file and not has_synthetic_after else 10.0
    else:
        sample_seconds = float(args.full_surface_sample_seconds)
    if sample_seconds <= 0 and not has_synthetic_after:
        return [], {"sampled": False}

    cpu_before = _proc_cpu_seconds(pid)
    start = time.monotonic()
    if has_synthetic_after:
        elapsed = sample_seconds if sample_seconds > 0 else 1.0
    else:
        time.sleep(sample_seconds)
        elapsed = max(time.monotonic() - start, 0.001)

    try:
        args._loading_after_sample = True
        after_metrics = parse_prometheus_scalars(_load_metrics(args))
    finally:
        args._loading_after_sample = False
    cpu_after = _proc_cpu_seconds(pid)

    failures: list[str] = []
    rates: dict[str, float | None] = {}
    for stage, floor_fps, criterion_id in FULL_SURFACE_STAGE_FPS_FLOORS:
        before = _render_stage_count(before_metrics, stage)
        after = _render_stage_count(after_metrics, stage)
        if before is None or after is None:
            rates[stage] = None
            failures.append(_full_surface_reason(criterion_id, f"stage_fps_unknown:{stage}"))
            continue
        fps = max(0.0, (after - before) / elapsed)
        rates[stage] = fps
        if fps < floor_fps:
            failures.append(
                _full_surface_reason(
                    criterion_id,
                    f"stage_fps_below_floor:{stage}:{fps:.2f}<{floor_fps:.2f}",
                )
            )

    if _bridge_mode_active(before_metrics) or _bridge_mode_active(after_metrics):
        for label, metric_name, floor_fps, criterion_id in FULL_SURFACE_BRIDGE_COUNTER_FPS_FLOORS:
            fps = _counter_rate(before_metrics, after_metrics, metric_name, elapsed)
            rates[label] = fps
            if fps is None:
                failures.append(_full_surface_reason(criterion_id, f"stage_fps_unknown:{label}"))
                continue
            if fps < floor_fps:
                failures.append(
                    _full_surface_reason(
                        criterion_id,
                        f"stage_fps_below_floor:{label}:{fps:.2f}<{floor_fps:.2f}",
                    )
                )
    else:
        for stage, floor_fps, criterion_id in FULL_SURFACE_DIRECT_STAGE_FPS_FLOORS:
            before = _render_stage_count(before_metrics, stage)
            after = _render_stage_count(after_metrics, stage)
            if before is None or after is None:
                rates[stage] = None
                failures.append(_full_surface_reason(criterion_id, f"stage_fps_unknown:{stage}"))
                continue
            fps = max(0.0, (after - before) / elapsed)
            rates[stage] = fps
            if fps < floor_fps:
                failures.append(
                    _full_surface_reason(
                        criterion_id,
                        f"stage_fps_below_floor:{stage}:{fps:.2f}<{floor_fps:.2f}",
                    )
                )

    resource_failures, resource_deltas = _full_surface_resource_delta_failures(
        before_metrics,
        after_metrics,
    )
    failures.extend(resource_failures)

    cpu_cores: float | None = None
    if cpu_before is not None and cpu_after is not None:
        cpu_cores = max(0.0, (cpu_after - cpu_before) / elapsed)
        if cpu_cores > FULL_SURFACE_CPU_TARGET_CORES:
            failures.append(
                _full_surface_reason(
                    "LSC-PERF-002",
                    f"cpu_above_target_cores:{cpu_cores:.2f}>{FULL_SURFACE_CPU_TARGET_CORES:.2f}",
                )
            )

    return failures, {
        "sampled": True,
        "elapsed_seconds": elapsed,
        "stage_fps": rates,
        "cpu_cores": cpu_cores,
        "cpu_target_cores": FULL_SURFACE_CPU_TARGET_CORES,
        "resource_deltas": resource_deltas,
        "resource_limits": {
            "max_rss_growth_bytes": FULL_SURFACE_MAX_RSS_GROWTH_BYTES,
            "max_vram_growth_bytes": FULL_SURFACE_MAX_VRAM_GROWTH_BYTES,
            "max_fd_growth": FULL_SURFACE_MAX_FD_GROWTH,
            "max_v4l2_write_error_delta": FULL_SURFACE_MAX_V4L2_WRITE_ERROR_DELTA,
            "max_v4l2_fd_reopen_delta": FULL_SURFACE_MAX_V4L2_FD_REOPEN_DELTA,
            "max_glfeedback_recompile_delta": FULL_SURFACE_MAX_GLFEEDBACK_RECOMPILE_DELTA,
        },
    }


def _proof_sample_count(window_seconds: float, interval_ms: int) -> int:
    interval_seconds = max(0.0, interval_ms / 1000.0)
    if interval_seconds <= 0:
        return FINAL_PIXEL_PROOF_MIN_FRAMES
    return max(FINAL_PIXEL_PROOF_MIN_FRAMES, int(window_seconds / interval_seconds) + 1)


def _copy_proof_frame(source: Path, target: Path) -> bool:
    try:
        if not source.is_file() or source.stat().st_size <= 0:
            return False
        shutil.copy2(source, target)
    except OSError:
        return False
    return True


def _collect_final_pixel_proof(
    *,
    final_frame_image: Path,
    upstream_frame_image: Path,
    proof_dir: Path,
    window_seconds: float,
    interval_ms: int,
) -> tuple[list[Path], list[Path], list[str]]:
    sample_count = _proof_sample_count(window_seconds, interval_ms)
    interval_seconds = max(0.0, interval_ms / 1000.0)
    final_paths: list[Path] = []
    upstream_paths: list[Path] = []
    reasons: list[str] = []
    upstream_missing = False

    for index in range(sample_count):
        final_target = proof_dir / f"final-{index:03d}.jpg"
        upstream_target = proof_dir / f"upstream-{index:03d}.jpg"
        if _copy_proof_frame(final_frame_image, final_target):
            final_paths.append(final_target)
            if _copy_proof_frame(upstream_frame_image, upstream_target):
                upstream_paths.append(upstream_target)
            else:
                upstream_missing = True
        if index + 1 < sample_count and interval_seconds > 0:
            time.sleep(interval_seconds)

    if not final_paths:
        reasons.append(f"final_pixel_proof:final_frame_unavailable:{final_frame_image}")
    if upstream_missing:
        upstream_paths = []
    if not upstream_paths:
        reasons.append(f"final_pixel_proof:upstream_frame_unavailable:{upstream_frame_image}")
    return final_paths, upstream_paths, reasons


def _ward_visibility_failures(path: Path) -> tuple[list[str], dict[str, object] | None]:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, ValueError) as exc:
        return [f"ward_visibility_json_unavailable:{type(exc).__name__}"], None
    if not isinstance(payload, dict):
        return ["ward_visibility_json_invalid"], None
    if payload.get("ok") is True:
        return [], payload
    raw_reasons = payload.get("reasons")
    if isinstance(raw_reasons, list):
        reasons = [str(reason) for reason in raw_reasons if str(reason)]
    else:
        reasons = ["ward_visibility_failed"]
    return [f"ward_visibility:{reason}" for reason in reasons], payload


def _effect_surface_failures(path: Path) -> tuple[list[str], dict[str, object] | None]:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, ValueError) as exc:
        return [f"effect_surface_json_unavailable:{type(exc).__name__}"], None
    if not isinstance(payload, dict):
        return ["effect_surface_json_invalid"], None
    if payload.get("ok") is True:
        return [], payload
    raw_reasons = payload.get("reasons")
    if isinstance(raw_reasons, list):
        reasons = [str(reason) for reason in raw_reasons if str(reason)]
    else:
        reasons = ["effect_surface_failed"]
    return [f"effect_surface:{reason}" for reason in reasons], payload


def _layout_mode_from_state(path: Path) -> str | None:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, ValueError):
        return None
    if not isinstance(payload, dict):
        return None
    raw = payload.get("layout_mode")
    if isinstance(raw, str) and raw.strip():
        return raw.strip()
    return None


def _final_frame_black_fraction_limit(layout_mode: str | None) -> float:
    if not layout_mode:
        return DEFAULT_MAX_UNCLASSIFIED_BLACK_FRACTION
    contract = negative_space_contract_for_mode(layout_mode)
    if contract is None:
        return DEFAULT_MAX_UNCLASSIFIED_BLACK_FRACTION
    return max(DEFAULT_MAX_UNCLASSIFIED_BLACK_FRACTION, contract.max_fraction)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--metrics-url", default="http://127.0.0.1:9482/metrics")
    parser.add_argument("--metrics-file")
    parser.add_argument(
        "--extra-metrics-file",
        action="append",
        type=Path,
        default=None,
        help="additional Prometheus textfile to merge into the readiness snapshot",
    )
    parser.add_argument(
        "--metrics-file-after",
        help=(
            "second Prometheus exposition used for deterministic performance-sample "
            "tests; live runs normally rescrape --metrics-url after sleeping"
        ),
    )
    parser.add_argument("--service-active", choices=("true", "false"))
    parser.add_argument("--bridge-active", choices=("true", "false"))
    parser.add_argument("--env", action="append", default=[], metavar="KEY=VALUE")
    parser.add_argument("--no-systemd", action="store_true")
    parser.add_argument("--allow-containment", action="store_true")
    parser.add_argument("--no-require-v4l2", action="store_true")
    parser.add_argument("--max-egress-age-seconds", type=float, default=10.0)
    parser.add_argument("--require-hls", action="store_true")
    parser.add_argument("--require-rtmp", action="store_true")
    parser.add_argument("--require-obs-decoder", action="store_true")
    parser.add_argument("--require-public-output", action="store_true")
    parser.add_argument(
        "--require-full-surface",
        action="store_true",
        help=(
            "require the full livestream surface criteria packet rather than "
            "operational liveness containment"
        ),
    )
    parser.add_argument(
        "--full-surface-sample-seconds",
        type=float,
        default=None,
        help=(
            "sample render-stage counters over this interval when --require-full-surface "
            "is active; live runs default to 10s, metrics-file tests default to 0"
        ),
    )
    parser.add_argument("--max-obs-screenshot-age-seconds", type=float)
    parser.add_argument("--max-director-silence-seconds", type=float, default=180.0)
    parser.add_argument(
        "--final-frame-image",
        help=(
            "final egress proof image to classify; also used as the proof-window "
            "source when --require-final-pixel-proof is active"
        ),
    )
    parser.add_argument(
        "--upstream-frame-image",
        default=str(DEFAULT_UPSTREAM_FRAME_IMAGE),
        help="pre-FX/upstream snapshot paired with --final-frame-image for final-pixel proof",
    )
    parser.add_argument(
        "--require-final-pixel-proof",
        action="store_true",
        help="sample final/upstream snapshots and fail closed on final-pixel proof failures",
    )
    parser.add_argument(
        "--layout-state-json",
        default=str(DEFAULT_LAYOUT_STATE_JSON),
        help=(
            "current layout-state JSON used to apply the declared negative-space "
            "contract to final-frame proof"
        ),
    )
    parser.add_argument(
        "--final-frame-window-seconds",
        type=float,
        default=8.0,
        help="proof sample window for --require-final-pixel-proof (default 8)",
    )
    parser.add_argument(
        "--final-frame-interval-ms",
        type=int,
        default=1000,
        help="milliseconds between final-pixel proof samples (default 1000)",
    )
    parser.add_argument(
        "--ward-visibility-json",
        help="JSON output from scripts/audit-ward-visibility.py to consume as a gate",
    )
    parser.add_argument(
        "--effect-surface-json",
        help="JSON output from scripts/audit-live-effect-surface.py to consume as a gate",
    )
    parser.add_argument(
        "--hls-playlist",
        default=str(Path.home() / ".cache" / "hapax-compositor" / "hls" / "stream.m3u8"),
    )
    parser.add_argument("--max-hls-age-seconds", type=float)
    parser.add_argument(
        "--max-hls-target-duration-seconds",
        type=float,
        default=DEFAULT_MAX_HLS_TARGET_DURATION_SECONDS,
        help=(
            "largest playlist target duration accepted as plausible live HLS proof; "
            "larger values are treated as malformed"
        ),
    )
    args = parser.parse_args()

    service_active = (
        _bool_arg(args.service_active)
        if args.service_active is not None
        else (False if args.no_systemd else _systemd_active("studio-compositor.service"))
    )
    bridge_active = (
        _bool_arg(args.bridge_active)
        if args.bridge_active is not None
        else (False if args.no_systemd else _systemd_active("hapax-v4l2-bridge.service"))
    )

    main_pid = None if args.no_systemd else _main_pid("studio-compositor.service")
    env = _selected_proc_env(main_pid)
    for assignment in args.env:
        if "=" not in assignment:
            parser.error(f"--env expects KEY=VALUE, got {assignment!r}")
        key, value = assignment.split("=", 1)
        if key in SELECTED_ENV:
            env[key] = value

    containment_flags = {
        "force_cpu": env.get("HAPAX_COMPOSITOR_FORCE_CPU") == "1",
        "disable_v4l2_output": env.get("HAPAX_COMPOSITOR_DISABLE_V4L2_OUTPUT") == "1",
        "disable_inline_fx": env.get("HAPAX_COMPOSITOR_DISABLE_INLINE_FX") == "1",
        "disable_hero_effect": env.get("HAPAX_COMPOSITOR_DISABLE_HERO_EFFECT") == "1",
        "follow_mode_disabled": env.get("HAPAX_FOLLOW_MODE_ACTIVE") == "0",
    }

    try:
        metrics = parse_prometheus_scalars(_load_metrics(args))
    except (OSError, urllib.error.URLError, ValueError) as exc:
        print(
            json.dumps(
                {
                    "state": LiveSurfaceState.FAILED.value,
                    "restored": False,
                    "reasons": [f"metrics_unavailable:{type(exc).__name__}"],
                    "service_active": service_active,
                    "bridge_active": bridge_active,
                },
                sort_keys=True,
            )
        )
        return 11

    hls_playlist = Path(args.hls_playlist)
    hls_playlist_age_seconds = _file_age_seconds(hls_playlist) if args.require_hls else None
    hls_target_duration_seconds = (
        _hls_target_duration_seconds(hls_playlist) if args.require_hls else None
    )
    hls_proof_reasons: list[str] = []
    if (
        hls_target_duration_seconds is not None
        and hls_target_duration_seconds > args.max_hls_target_duration_seconds
    ):
        hls_proof_reasons.append("hls_playlist_malformed_target_duration")
    hls_max_age_seconds = (
        (
            args.max_hls_age_seconds
            if args.max_hls_age_seconds is not None
            else (10.0 if hls_proof_reasons else _default_hls_max_age_seconds(hls_playlist))
        )
        if args.require_hls
        else None
    )

    snapshot = snapshot_from_prometheus(
        metrics,
        service_active=service_active,
        bridge_active=bridge_active,
        bridge_expected=env.get("HAPAX_V4L2_BRIDGE_ENABLED") == "1",
        containment_flags=containment_flags,
        hls_active=hls_playlist_age_seconds is not None,
        hls_playlist_age_seconds=hls_playlist_age_seconds,
    )
    assessment = assess_live_surface(
        snapshot,
        max_egress_age_seconds=args.max_egress_age_seconds,
        require_v4l2=not args.no_require_v4l2,
        require_hls=args.require_hls,
        require_rtmp=args.require_rtmp,
        require_obs_decoder=args.require_obs_decoder,
        require_public_output=args.require_public_output,
        max_hls_age_seconds=hls_max_age_seconds,
        max_obs_screenshot_age_seconds=args.max_obs_screenshot_age_seconds,
        max_director_silence_seconds=args.max_director_silence_seconds,
    )
    state, reasons = _with_extra_degraded_reasons(
        assessment.state,
        list(assessment.reasons),
        hls_proof_reasons,
    )
    full_surface_failures: list[str] = []
    full_surface_performance: dict[str, object] = {"sampled": False}
    layout_mode_for_proof = _layout_mode_from_state(Path(args.layout_state_json))
    if args.require_full_surface:
        performance_failures, full_surface_performance = _full_surface_performance_sample(
            args,
            metrics,
            pid=main_pid,
        )
        full_surface_failures = [
            *_full_surface_env_failures(env),
            *_full_surface_metric_failures(metrics, layout_mode=layout_mode_for_proof),
            *performance_failures,
        ]
        state, reasons = _with_extra_degraded_reasons(
            state,
            reasons,
            full_surface_failures,
        )
    max_final_black_fraction = _final_frame_black_fraction_limit(layout_mode_for_proof)
    final_frame_payload: dict[str, object] | None = None
    if args.final_frame_image:
        try:
            upstream_frame_image = (
                Path(args.upstream_frame_image)
                if args.upstream_frame_image
                else Path("/dev/shm/hapax-compositor/snapshot.jpg")
            )
            classification = classify_final_frame(
                Path(args.final_frame_image),
                upstream_path=upstream_frame_image if upstream_frame_image.exists() else None,
                max_unclassified_black_fraction=max_final_black_fraction,
            )
        except OSError as exc:
            state, reasons = _with_extra_degraded_reasons(
                state,
                reasons,
                [f"final_frame_unavailable:{type(exc).__name__}"],
            )
        else:
            final_frame_payload = classification.as_dict()
            final_frame_payload["layout_mode"] = layout_mode_for_proof
            final_frame_payload["max_unclassified_black_fraction"] = round(
                max_final_black_fraction,
                6,
            )
            state, reasons = _with_extra_degraded_reasons(
                state,
                reasons,
                list(classification.reasons),
            )

    final_pixel_proof_payload: dict[str, object] | None = None
    if args.require_final_pixel_proof:
        final_frame_image = Path(args.final_frame_image or DEFAULT_FINAL_FRAME_IMAGE)
        upstream_frame_image = Path(args.upstream_frame_image)
        with tempfile.TemporaryDirectory(prefix="hapax-final-pixel-proof-") as proof_td:
            final_paths, upstream_paths, proof_collection_reasons = _collect_final_pixel_proof(
                final_frame_image=final_frame_image,
                upstream_frame_image=upstream_frame_image,
                proof_dir=Path(proof_td),
                window_seconds=max(0.0, args.final_frame_window_seconds),
                interval_ms=max(0, args.final_frame_interval_ms),
            )
            try:
                proof = classify_final_frame_series(
                    final_paths,
                    upstream_paths=upstream_paths,
                    require_upstream=True,
                    max_unclassified_black_fraction=max_final_black_fraction,
                )
            except OSError as exc:
                proof_collection_reasons.append(
                    f"final_pixel_proof:classification_failed:{type(exc).__name__}"
                )
                proof = None
            if proof is not None:
                final_pixel_proof_payload = proof.as_dict()
                proof_reasons = [*proof_collection_reasons, *proof.reasons]
            else:
                final_pixel_proof_payload = {
                    "frame_count": len(final_paths),
                    "paired_frame_count": min(len(final_paths), len(upstream_paths)),
                    "reasons": proof_collection_reasons,
                }
                proof_reasons = proof_collection_reasons
        state, reasons = _with_extra_degraded_reasons(
            state,
            reasons,
            list(dict.fromkeys(proof_reasons)),
        )

    ward_visibility_payload: dict[str, object] | None = None
    if args.ward_visibility_json:
        ward_failures, ward_visibility_payload = _ward_visibility_failures(
            Path(args.ward_visibility_json)
        )
        state, reasons = _with_extra_degraded_reasons(state, reasons, ward_failures)

    effect_surface_payload: dict[str, object] | None = None
    if args.effect_surface_json:
        effect_surface_failures, effect_surface_payload = _effect_surface_failures(
            Path(args.effect_surface_json)
        )
        state, reasons = _with_extra_degraded_reasons(
            state,
            reasons,
            effect_surface_failures,
        )

    print(
        json.dumps(
            {
                "state": state.value,
                "restored": state is LiveSurfaceState.HEALTHY,
                "reasons": reasons,
                "service_active": service_active,
                "bridge_active": bridge_active,
                "camera_last_frame_age_seconds": dict(snapshot.camera_last_frame_age_seconds),
                "containment_flags": dict(snapshot.containment_flags),
                "v4l2_egress_mode": snapshot.v4l2_egress_mode.value,
                "hls_playlist_age_seconds": hls_playlist_age_seconds,
                "hls_max_age_seconds": hls_max_age_seconds,
                "hls_target_duration_seconds": hls_target_duration_seconds,
                "max_hls_target_duration_seconds": (
                    args.max_hls_target_duration_seconds if args.require_hls else None
                ),
                "rtmp_connected": snapshot.rtmp_connected,
                "rtmp_bytes_total": snapshot.rtmp_bytes_total,
                "rtmp_bitrate_bps": snapshot.rtmp_bitrate_bps,
                "obs_source_active": snapshot.obs_source_active,
                "obs_playing": snapshot.obs_playing,
                "obs_screenshot_changed": snapshot.obs_screenshot_changed,
                "obs_screenshot_flat": snapshot.obs_screenshot_flat,
                "obs_screenshot_age_seconds": snapshot.obs_screenshot_age_seconds,
                "public_output_live": snapshot.public_output_live,
                "watchdog_last_fed_age_seconds": snapshot.watchdog_last_fed_age_seconds,
                "director_last_intent_age_seconds": snapshot.director_last_intent_age_seconds,
                "final_frame_classification": final_frame_payload,
                "final_pixel_proof_required": args.require_final_pixel_proof,
                "final_pixel_proof": final_pixel_proof_payload,
                "ward_visibility": ward_visibility_payload,
                "effect_surface": effect_surface_payload,
                "full_surface_required": args.require_full_surface,
                "full_surface_failures": full_surface_failures,
                "full_surface_performance": full_surface_performance,
            },
            sort_keys=True,
        )
    )
    if state is LiveSurfaceState.HEALTHY:
        return 0
    if args.allow_containment and state is LiveSurfaceState.DEGRADED_CONTAINMENT:
        return 0
    return 10 if state is LiveSurfaceState.DEGRADED_CONTAINMENT else 11


if __name__ == "__main__":
    sys.exit(main())
