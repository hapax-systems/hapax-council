#!/usr/bin/env python3
"""hapax-audio-graph-validate — read-only audio-graph SSOT validator (P1 CLI).

Walks the live ``~/.config/pipewire/pipewire.conf.d/`` and
``~/.config/wireplumber/wireplumber.conf.d/`` directories, decomposes
every active conf into typed AudioGraph models, runs the 11 invariant
predicates, and emits JSON to stdout.

NO runtime audio mutation. NO ``pw-dump`` / ``pactl`` / ``pw-link``
invocations. File reads only. Safe to run during a livestream.

Usage:
    hapax-audio-graph-validate [--pretty] [--fail-on-violations]

Output JSON shape:
    {
      "active_pipewire_confs": int,
      "active_wireplumber_confs": int,
      "decomposed_clean": {"pipewire": int, "wireplumber": int},
      "decompose_failures": [str, ...],
      "graph_stats": {"nodes": int, "loopbacks": int, ...},
      "violations": [
        {"kind": str, "severity": str, "node_id": str|null, "message": str},
        ...
      ],
      "gaps": {"untyped_confs": [str], "parse_warnings": [str], "inferred_models": [str]}
    }

Exit codes:
    0 — all confs decomposed cleanly, no BLOCKING violations
    1 — some confs failed to decompose
    2 — BLOCKING invariants violated (only when --fail-on-violations)
"""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

from shared.audio_graph import AudioGraphValidator, check_all_invariants
from shared.audio_graph.invariants import InvariantSeverity


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__.split("\n\n", 1)[0])
    parser.add_argument(
        "--pipewire-conf-dir",
        type=Path,
        default=Path("~/.config/pipewire/pipewire.conf.d").expanduser(),
    )
    parser.add_argument(
        "--wireplumber-conf-dir",
        type=Path,
        default=Path("~/.config/wireplumber/wireplumber.conf.d").expanduser(),
    )
    parser.add_argument("--pretty", action="store_true", help="indent JSON output")
    parser.add_argument(
        "--fail-on-violations",
        action="store_true",
        help="exit 2 if any BLOCKING invariant violation is detected",
    )
    args = parser.parse_args(argv)

    validator = AudioGraphValidator(
        pipewire_conf_dir=args.pipewire_conf_dir,
        wireplumber_conf_dir=args.wireplumber_conf_dir,
    )

    pw_confs = validator.list_active_pipewire_confs()
    wp_confs = validator.list_active_wireplumber_confs()

    pw_clean = sum(1 for c in pw_confs if validator.conf_decomposed_cleanly(c))
    wp_clean = sum(1 for c in wp_confs if validator.conf_decomposed_cleanly(c))
    failures = [c.name for c in pw_confs + wp_confs if not validator.conf_decomposed_cleanly(c)]

    result = validator.decompose_confs()
    violations = check_all_invariants(result.graph)

    output = {
        "active_pipewire_confs": len(pw_confs),
        "active_wireplumber_confs": len(wp_confs),
        "decomposed_clean": {
            "pipewire": pw_clean,
            "wireplumber": wp_clean,
            "total": pw_clean + wp_clean,
        },
        "decompose_failures": failures,
        "graph_stats": {
            "nodes": len(result.graph.nodes),
            "loopbacks": len(result.graph.loopbacks),
            "channel_downmixes": len(result.graph.channel_downmixes),
            "tunables": len(result.graph.tunables),
            "alsa_profile_pins": len(result.graph.alsa_profile_pins),
            "alsa_rules": len(result.graph.alsa_rules),
            "bluez_rules": len(result.graph.bluez_rules),
            "stream_restore_rules": len(result.graph.stream_restore_rules),
            "stream_pins": len(result.graph.stream_pins),
            "media_role_sinks": len(result.graph.media_role_sinks),
            "untyped_wireplumber_rules": len(result.graph.untyped_wireplumber_rules),
        },
        "violations": [
            {
                "kind": v.kind.value,
                "severity": v.severity.value,
                "node_id": v.node_id,
                "message": v.message,
            }
            for v in violations
        ],
        "gaps": {
            "untyped_confs": result.gaps.untyped_confs,
            "parse_warnings": result.gaps.parse_warnings,
            "inferred_models": result.gaps.inferred_models,
        },
    }

    indent = 2 if args.pretty else None
    sys.stdout.write(json.dumps(output, indent=indent, sort_keys=True) + "\n")

    if failures:
        return 1
    if args.fail_on_violations:
        if any(v.severity == InvariantSeverity.BLOCKING for v in violations):
            return 2
    return 0


if __name__ == "__main__":
    sys.exit(main())
