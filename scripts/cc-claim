#!/usr/bin/env bash
# cc-claim <task_id>
#
# Claim a vault cc-task for the current session. Atomic: rewrites the
# task note frontmatter (status: offered -> claimed; assigned_to:
# unassigned -> $HAPAX_AGENT_ROLE/$CODEX_ROLE/$CLAUDE_ROLE; claimed_at: now), then writes the
# session's claim file at ~/.cache/hapax/cc-active-task-{role}.
#
# After this, the next file-mutating tool call passes through the
# cc-task-gate hook (which auto-transitions claimed → in_progress).
#
# Operator can also pre-claim a task by hand-editing the frontmatter
# in Obsidian; this script just adds the claim file the hook reads.
#
# Symlink to ~/.local/bin/cc-claim for quick access:
#   ln -sf ~/projects/hapax-council/scripts/cc-claim ~/.local/bin/cc-claim

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROLE_HELPER="$SCRIPT_DIR/../hooks/scripts/agent-role.sh"
if [[ -f "$ROLE_HELPER" ]]; then
  # shellcheck source=../hooks/scripts/agent-role.sh
  . "$ROLE_HELPER"
fi

if [[ $# -lt 1 ]]; then
  echo "usage: cc-claim <task_id>" >&2
  exit 1
fi

task_id="$1"
role="${HAPAX_AGENT_ROLE:-${CODEX_ROLE:-${CLAUDE_ROLE:-}}}"
if [[ -z "$role" ]] && declare -F hapax_agent_role >/dev/null 2>&1; then
  role="$(hapax_agent_role 2>/dev/null || true)"
fi
if [[ -z "$role" ]]; then
  echo "cc-claim: cannot determine role; set HAPAX_AGENT_ROLE, CODEX_ROLE, or CLAUDE_ROLE" >&2
  exit 1
fi

vault_root="$HOME/Documents/Personal/20-projects/hapax-cc-tasks"
note_path=""
# Match `<task_id>-<descriptor>.md` (most tasks).
for candidate in "$vault_root/active/$task_id-"*.md; do
  if [[ -f "$candidate" ]]; then
    note_path="$candidate"
    break
  fi
done
# Fallback: exact-match `<task_id>.md` for tasks without a descriptor
# suffix (eg. ytb-LEGIBILITY-SMOKE-FOLLOWUP.md, ytb-OBJECTIVES-OVERLAY-
# RENDER-FOLLOWUP.md). The glob above doesn't match these because it
# requires a literal `-` after the task_id.
if [[ -z "$note_path" ]] && [[ -f "$vault_root/active/$task_id.md" ]]; then
  note_path="$vault_root/active/$task_id.md"
fi
if [[ -z "$note_path" ]]; then
  echo "cc-claim: task '$task_id' not found in $vault_root/active/" >&2
  echo "browse offered tasks: $vault_root/_dashboard/cc-offered.md" >&2
  exit 2
fi

if ! command -v python3 &>/dev/null; then
  echo "cc-claim: python3 missing; cannot rewrite frontmatter" >&2
  exit 3
fi

# Verify status is offered + assigned_to is unassigned, then transition.
python3 - "$note_path" "$role" "$task_id" <<'PYEOF'
import re
import sys
from datetime import datetime, timezone
from pathlib import Path

path, role, task_id = Path(sys.argv[1]), sys.argv[2], sys.argv[3]
text = path.read_text(encoding="utf-8")
now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

# Sanity: bail if status isn't offered (operator may have already claimed it
# manually, or it's in_progress from another session).
status_match = re.search(r"^status:\s*(\S+)$", text, flags=re.MULTILINE)
if status_match and status_match.group(1) not in ("offered",):
    print(
        f"cc-claim: refusing to claim '{task_id}' — current status is '{status_match.group(1)}', not 'offered'",
        file=sys.stderr,
    )
    sys.exit(4)

assigned_match = re.search(r"^assigned_to:\s*(\S+)$", text, flags=re.MULTILINE)
if assigned_match and assigned_match.group(1) not in ("unassigned",):
    print(
        f"cc-claim: refusing to claim '{task_id}' — already assigned to '{assigned_match.group(1)}'",
        file=sys.stderr,
    )
    sys.exit(4)

def _strip_scalar(value: str) -> str:
    return value.strip().strip('"').strip("'")


_YAML_NULLS = frozenset({"null", "none", "~"})


def _frontmatter_lines(note_text: str) -> list[str]:
    if not note_text.startswith("---"):
        return []
    end = note_text.find("\n---", 4)
    if end < 0:
        return []
    return note_text[4:end].splitlines()


def _parse_inline_list(value: str) -> list[str]:
    value = value.strip()
    if value == "[]":
        return []
    if _strip_scalar(value).lower() in _YAML_NULLS:
        return []
    if not (value.startswith("[") and value.endswith("]")):
        return [_strip_scalar(value)] if value else []
    inner = value[1:-1].strip()
    if not inner:
        return []
    return [_strip_scalar(item) for item in inner.split(",") if _strip_scalar(item)]


def _parse_depends_on(note_text: str) -> list[str]:
    lines = _frontmatter_lines(note_text)
    for idx, line in enumerate(lines):
        stripped = line.strip()
        if not stripped.startswith("depends_on:"):
            continue
        value = stripped.split(":", 1)[1].strip()
        if value:
            return _parse_inline_list(value)

        deps: list[str] = []
        for child in lines[idx + 1 :]:
            child_stripped = child.strip()
            if not child_stripped:
                continue
            if child_stripped.startswith("- "):
                dep_id = _strip_scalar(child_stripped[2:])
                if dep_id:
                    deps.append(dep_id)
                continue
            break
        return deps
    return []


def _parse_frontmatter(note_text: str) -> dict[str, str | list[str]]:
    fields: dict[str, str | list[str]] = {}
    lines = _frontmatter_lines(note_text)
    idx = 0
    while idx < len(lines):
        line = lines[idx]
        stripped = line.strip()
        idx += 1
        if not stripped or stripped.startswith("#") or ":" not in stripped:
            continue
        key, raw_value = stripped.split(":", 1)
        key = key.strip()
        value = raw_value.strip()
        if value:
            if value.startswith("[") and value.endswith("]"):
                fields[key] = _parse_inline_list(value)
            else:
                fields[key] = _strip_scalar(value)
            continue

        items: list[str] = []
        while idx < len(lines):
            child = lines[idx].strip()
            if not child:
                idx += 1
                continue
            if child.startswith("- "):
                item = _strip_scalar(child[2:])
                if item:
                    items.append(item)
                idx += 1
                continue
            break
        fields[key] = items
    return fields


def _field_tokens(value: str | list[str] | None) -> set[str]:
    if value is None:
        return set()
    if isinstance(value, list):
        raw_values = value
    else:
        raw_values = _parse_inline_list(value) if value.startswith("[") else [value]
    tokens: set[str] = set()
    for raw in raw_values:
        token = _strip_scalar(str(raw)).lower().replace("_", "-")
        if token:
            tokens.add(token)
    return tokens


def _is_nullish(value: str | list[str] | None) -> bool:
    if value is None:
        return True
    if isinstance(value, list):
        return len(value) == 0
    return _strip_scalar(value).lower() in ("", "null", "none", "~", "[]")


def _is_authority_exempt(fields: dict[str, str | list[str]]) -> bool:
    tokens: set[str] = set()
    for key in ("kind", "task_type", "work_type", "tier", "tags"):
        tokens.update(_field_tokens(fields.get(key)))

    mutation_tokens = {
        "build",
        "bugfix",
        "code",
        "deploy",
        "feature",
        "fix",
        "implementation",
        "mutation",
        "release",
        "runtime",
        "source",
        "systemd",
    }
    if tokens & mutation_tokens:
        return False

    non_mutating_tokens = {
        "audit",
        "intake",
        "planning",
        "plan",
        "read-only",
        "readonly",
        "research",
        "triage",
        "validation",
        "validation-demo",
    }
    return bool(tokens & non_mutating_tokens)


fields = _parse_frontmatter(text)
missing_authority_fields: list[str] = []
if not _is_authority_exempt(fields):
    if _is_nullish(fields.get("authority_case")):
        missing_authority_fields.append("authority_case")
    if _is_nullish(fields.get("parent_spec")):
        missing_authority_fields.append("parent_spec")

if missing_authority_fields:
    print(
        f"cc-claim: BLOCKED — task '{task_id}' is missing required AuthorityCase/ISAP fields: "
        + ", ".join(missing_authority_fields),
        file=sys.stderr,
    )
    print(
        "Implementation/build/runtime tasks must have non-null authority_case and parent_spec before claim.",
        file=sys.stderr,
    )
    print(
        "Use an explicitly read-only intake/planning task for pre-authorization work.",
        file=sys.stderr,
    )
    sys.exit(6)


def _locate_task(vault_root: Path, dep_id: str) -> Path | None:
    for subdir in ("closed", "active"):
        root = vault_root / subdir
        exact = root / f"{dep_id}.md"
        if exact.is_file():
            return exact
        for candidate in root.glob(f"{dep_id}-*.md"):
            if candidate.is_file():
                return candidate
    return None


def _frontmatter_status(note_text: str) -> str:
    match = re.search(r"^status:\s*(\S+)$", note_text, flags=re.MULTILINE)
    return match.group(1) if match else "unknown"


vault_root = path.parent.parent


def _parse_pr_number(note_text: str) -> str | None:
    """Extract PR number from frontmatter pr: field."""
    match = re.search(r"^pr:\s*(\S+)$", note_text, flags=re.MULTILINE)
    if not match:
        return None
    val = match.group(1).strip().strip("\x27\x22")
    if val.lower() in ("null", "none", "~", ""):
        return None
    # Strip leading # if present
    return val.lstrip("#")


def _check_pr_merged(pr_number: str) -> str:
    """Check PR merge status via gh CLI. Returns merged|open|closed|unknown."""
    import subprocess
    try:
        result = subprocess.run(
            [
                "gh",
                "pr",
                "view",
                pr_number,
                "--json",
                "state,mergedAt",
                "--jq",
                '.state + "," + ((.mergedAt != null and .mergedAt != "") | tostring)',
            ],
            capture_output=True, text=True, timeout=15,
            cwd=str(Path.home() / "projects" / "hapax-council"),
        )
        if result.returncode != 0:
            return "unknown"
        parts = result.stdout.strip().split(",")
        if len(parts) == 2 and parts[1] == "true":
            return "merged"
        if parts[0] == "OPEN":
            return "open"
        if parts[0] == "CLOSED":
            return "closed_unmerged"
        return "unknown"
    except Exception:
        return "unknown"
unmet: list[str] = []
for dep_id in _parse_depends_on(text):
    dep_path = _locate_task(vault_root, dep_id)
    if dep_path is None:
        unmet.append(f"{dep_id} (not found in vault)")
        continue
    dep_status = _frontmatter_status(dep_path.read_text(encoding="utf-8"))
    if dep_status not in ("completed", "closed", "done"):
        unmet.append(f"{dep_id} (status: {dep_status})")
        continue
    # Dependency is closed — check if it has a PR that must be merged
    dep_text = dep_path.read_text(encoding="utf-8")
    pr_num = _parse_pr_number(dep_text)
    if pr_num:
        pr_state = _check_pr_merged(pr_num)
        if pr_state == "open":
            unmet.append(f"{dep_id} (PR #{pr_num} still open — source not on main)")
        elif pr_state == "closed_unmerged":
            unmet.append(f"{dep_id} (PR #{pr_num} closed without merge — source lost)")
        elif pr_state == "unknown":
            # Fail closed: unknown PR state blocks dispatch
            unmet.append(f"{dep_id} (PR #{pr_num} state unknown — cannot verify merge)")

if unmet:
    print(f"cc-claim: BLOCKED — task '{task_id}' has unmet dependencies:", file=sys.stderr)
    for item in unmet:
        print(f"  - {item}", file=sys.stderr)
    print("\nResolve dependencies before claiming this task.", file=sys.stderr)
    sys.exit(5)

text = re.sub(r"^status:.*$", "status: claimed", text, count=1, flags=re.MULTILINE)
text = re.sub(
    r"^assigned_to:.*$", f"assigned_to: {role}", text, count=1, flags=re.MULTILINE
)
text = re.sub(
    r"^claimed_at:.*$", f"claimed_at: {now}", text, count=1, flags=re.MULTILINE
)
text = re.sub(
    r"^updated_at:.*$", f"updated_at: {now}", text, count=1, flags=re.MULTILINE
)
text = text.replace(
    "## Session log\n",
    f"## Session log\n- {now} {role} claimed (cc-claim)\n",
    1,
)

tmp = path.with_suffix(path.suffix + ".tmp")
tmp.write_text(text, encoding="utf-8")
tmp.replace(path)
print(f"cc-claim: claimed task '{task_id}' for role '{role}'")
PYEOF

# Write the per-role claim file the hook reads.
mkdir -p "$HOME/.cache/hapax"
echo "$task_id" > "$HOME/.cache/hapax/cc-active-task-$role"
echo "cc-claim: wrote ~/.cache/hapax/cc-active-task-$role"
