#!/usr/bin/env bash
# cc-claim <task_id>
#
# Claim a vault cc-task for the current session. Atomic: rewrites the
# task note frontmatter (status: offered -> claimed; assigned_to:
# unassigned -> $HAPAX_AGENT_ROLE/$CODEX_ROLE/$CLAUDE_ROLE; claimed_at: now), then writes the
# session's claim file at ~/.cache/hapax/cc-active-task-{role}.
#
# After this, the next file-mutating tool call passes through the
# cc-task-gate hook (which auto-transitions claimed → in_progress).
#
# Operator can also pre-claim a task by hand-editing the frontmatter
# in Obsidian; this script just adds the claim file the hook reads.
#
# Symlink to ~/.local/bin/cc-claim for quick access:
#   ln -sf ~/projects/hapax-council/scripts/cc-claim ~/.local/bin/cc-claim

set -euo pipefail

# Resolve through symlinks — cc-claim is installed as ~/.local/bin/cc-claim ->
# the deployed worktree, so the real script's sibling agent-role.sh (session-id /
# role-less helpers) must be sourced. Without this, the symlinked install would
# silently fall back to env-only role resolution and never session-key a claim.
_cc_self="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  _cc_self="$(readlink -f "$_cc_self" 2>/dev/null || printf '%s' "$_cc_self")"
fi
SCRIPT_DIR="$(cd "$(dirname "$_cc_self")" && pwd)"
ROLE_HELPER="$SCRIPT_DIR/../hooks/scripts/agent-role.sh"
if [[ -f "$ROLE_HELPER" ]]; then
  # shellcheck source=../hooks/scripts/agent-role.sh
  . "$ROLE_HELPER"
fi

force=false
task_id=""
dispatch_message_id="${HAPAX_CLAIM_DISPATCH_MESSAGE_ID:-}"
dispatch_binding_hash="${HAPAX_CLAIM_DISPATCH_BINDING_HASH:-}"
dispatch_platform="${HAPAX_CLAIM_DISPATCH_PLATFORM:-}"
dispatch_mode="${HAPAX_CLAIM_DISPATCH_MODE:-}"
dispatch_profile="${HAPAX_CLAIM_DISPATCH_PROFILE:-}"
dispatch_authority_case="${HAPAX_CLAIM_DISPATCH_AUTHORITY_CASE:-}"
dispatch_idempotency_key="${HAPAX_CLAIM_DISPATCH_IDEMPOTENCY_KEY:-}"
dispatch_task_path="${HAPAX_CLAIM_DISPATCH_TASK_PATH:-}"
dispatch_task_sha256="${HAPAX_CLAIM_DISPATCH_TASK_SHA256:-}"
dispatch_parent_spec="${HAPAX_CLAIM_DISPATCH_PARENT_SPEC:-}"
dispatch_lane_session="${HAPAX_CLAIM_DISPATCH_LANE_SESSION:-}"
dispatch_lane_generation="${HAPAX_CLAIM_DISPATCH_LANE_GENERATION:-}"
dispatch_lane_pid="${HAPAX_CLAIM_DISPATCH_LANE_PID:-}"
dispatch_lane_pid_generation="${HAPAX_CLAIM_DISPATCH_LANE_PID_GENERATION:-}"
dispatch_claim_projection="${HAPAX_CLAIM_DISPATCH_CLAIM_PROJECTION_SHA256:-}"
dispatch_relay_projection="${HAPAX_CLAIM_DISPATCH_RELAY_PROJECTION_SHA256:-}"
for arg in "$@"; do
  case "$arg" in
    --force) force=true ;;
    -*) echo "cc-claim: unknown flag '$arg'" >&2; exit 1 ;;
    *) task_id="$arg" ;;
  esac
done
if [[ -z "$task_id" ]]; then
  echo "usage: cc-claim [--force] <task_id>" >&2
  exit 1
fi
dispatch_values=(
  "$dispatch_message_id" "$dispatch_binding_hash" "$dispatch_platform"
  "$dispatch_mode" "$dispatch_profile" "$dispatch_authority_case"
  "$dispatch_idempotency_key" "$dispatch_task_path" "$dispatch_task_sha256"
  "$dispatch_parent_spec" "$dispatch_lane_generation"
  "$dispatch_claim_projection" "$dispatch_relay_projection"
)
dispatch_present=0
dispatch_missing=0
for value in "${dispatch_values[@]}"; do
  [[ -n "$value" ]] && dispatch_present=$((dispatch_present + 1)) || dispatch_missing=$((dispatch_missing + 1))
done
if [[ "$dispatch_present" -gt 0 && "$dispatch_missing" -gt 0 ]]; then
  echo "cc-claim: dispatch binding environment is incomplete" >&2
  exit 1
fi
# Resolve identity from the SAME source of truth as the gate (agent-role.sh):
# explicit env → agent-role recovery → relay presence → role-less fallback. A
# session with no role but a session id resolves to "roleless" so it can always
# claim (FM-1: "no role" never means "no escape").
if declare -F hapax_effective_role >/dev/null 2>&1; then
  role="$(hapax_effective_role 2>/dev/null || true)"
else
  role="${HAPAX_AGENT_ROLE:-${CODEX_ROLE:-${CLAUDE_ROLE:-}}}"
fi
if [[ -z "$role" ]]; then
  echo "cc-claim: cannot determine identity; set HAPAX_AGENT_ROLE/CODEX_ROLE/CLAUDE_ROLE or a session id (HAPAX_SESSION_ID)" >&2
  exit 1
fi
session_id=""
if declare -F hapax_session_id >/dev/null 2>&1; then
  session_id="$(hapax_session_id 2>/dev/null || true)"
fi
# Claim-by-pid unrepresentable (taxonomy-a3-session-identity): only an id with
# per-session entropy may key a claim. The predicate SSOT is
# shared/session_identity.py::is_claim_keyable_session_id; a pid-shaped id —
# the retired `<role>-$$` spawner fallback — degrades to legacy role keying
# instead of minting an ambiguous key.
if [[ -n "$session_id" ]] && ! python3 -c '
import sys
sys.path.insert(0, sys.argv[2])
from shared.session_identity import is_claim_keyable_session_id
sys.exit(0 if is_claim_keyable_session_id(sys.argv[1]) else 1)
' "$session_id" "$SCRIPT_DIR/.." 2>/dev/null; then
  echo "cc-claim: session id '$session_id' is not claim-keyable (pid-shaped or malformed) — using legacy role-keyed claim only" >&2
  session_id=""
fi
if [[ -n "$session_id" ]]; then
  session_claim_file="$HOME/.cache/hapax/cc-active-task-$role-$session_id"
else
  session_claim_file=""
fi
lease_ttl="${HAPAX_CLAIM_LEASE_TTL_SECS:-21600}"

# Serialize both the role and task identity through note mutation plus cache
# publication. Different roles cannot race to claim the same note, and one role
# cannot race two different tasks into separate active claims.
command -v flock >/dev/null 2>&1 || {
  echo "cc-claim: flock missing; refusing non-atomic claim" >&2
  exit 3
}
mkdir -p "$HOME/.cache/hapax"
role_lock_key="$(printf '%s' "$role" | sha256sum | cut -d' ' -f1)"
task_lock_key="$(printf '%s' "$task_id" | sha256sum | cut -d' ' -f1)"
exec 8>"$HOME/.cache/hapax/cc-claim-role-lock-$role_lock_key"
flock -x 8
exec 9>"$HOME/.cache/hapax/cc-claim-task-lock-$task_lock_key"
flock -x 9

# --- Multi-claim prevention + lease expiry (reform Phase 1, cluster 6) ---
# A role must close its current task before claiming a new one. Without this,
# Codex lanes bulk-claimed dozens of tasks with zero implementation. Scan the
# role's claim files — the legacy cc-active-task-<role> AND every session-keyed
# cc-active-task-<role>-<session_id> (FM-2) — and treat any whose lease has
# expired (mtime older than HAPAX_CLAIM_LEASE_TTL_SECS) as free: a dead/wedged
# session's claim auto-frees instead of deadlocking the role forever. The gate
# refreshes a live session's lease on each mutation, so only stale sessions age
# out. A live claim on a DIFFERENT non-terminal task blocks (unless --force).
vault_root_check="$HOME/Documents/Personal/20-projects/hapax-cc-tasks"
now_epoch="$(date +%s 2>/dev/null || echo 0)"
legacy_claim_file="$HOME/.cache/hapax/cc-active-task-$role"
shopt -s nullglob
for cf in "$legacy_claim_file" "$HOME/.cache/hapax/cc-active-task-$role-"*; do
  [[ -f "$cf" ]] || continue
  cf_mtime="$(stat -c %Y "$cf" 2>/dev/null || echo "$now_epoch")"
  if (( now_epoch - cf_mtime > lease_ttl )); then
    # Expired lease. Reap session-keyed files (a dead session's lease auto-frees);
    # leave the shared legacy file (it is overwritten below and never blocks once
    # expired) for the out-of-scope consumers that still read it.
    if [[ "$cf" != "$legacy_claim_file" ]]; then
      claim_key="${cf##*/cc-active-task-}"
      rm -f \
        "$cf" \
        "$HOME/.cache/hapax/cc-claim-epoch-$claim_key" \
        "$HOME/.cache/hapax/cc-claim-dispatch-$claim_key.json" \
        2>/dev/null || true
    fi
    continue
  fi
  existing_task="$(head -n1 "$cf" | tr -d '[:space:]')"
  [[ -n "$existing_task" && "$existing_task" != "$task_id" ]] || continue
  existing_note=""
  for c in "$vault_root_check/active/$existing_task-"*.md "$vault_root_check/active/$existing_task.md"; do
    [[ -f "$c" ]] && existing_note="$c" && break
  done
  [[ -n "$existing_note" ]] || continue
  existing_status="$(grep -oP '^status:\s*\K\S+' "$existing_note" 2>/dev/null || echo "unknown")"
  case "$existing_status" in
    done|completed|closed|withdrawn|superseded) continue ;;
  esac
  echo "cc-claim: BLOCKED — role '$role' already has active task '$existing_task' (status: $existing_status)." >&2
  echo "  Close it first: cc-close $existing_task" >&2
  echo "  Or force: cc-claim --force $task_id" >&2
  if [[ "$force" != "true" ]]; then
    shopt -u nullglob
    exit 7
  fi
  echo "cc-claim: --force override — releasing prior claim on '$existing_task'" >&2
done
shopt -u nullglob

vault_root="$HOME/Documents/Personal/20-projects/hapax-cc-tasks"
if ! command -v python3 &>/dev/null; then
  echo "cc-claim: python3 missing; cannot rewrite frontmatter" >&2
  exit 3
fi
if ! note_path="$(python3 - "$SCRIPT_DIR/.." "$vault_root" "$task_id" <<'PYEOF'
import sys
from pathlib import Path

sys.path.insert(0, sys.argv[1])
from shared.sdlc_task_store import TaskStoreError, resolve_task_note

try:
    snapshot = resolve_task_note(Path(sys.argv[2]), sys.argv[3], state="active")
except TaskStoreError as exc:
    print(f"cc-claim: {exc}", file=sys.stderr)
    raise SystemExit(2)
print(snapshot.path)
PYEOF
)"; then
  echo "cc-claim: No claim caches were written." >&2
  echo "browse offered tasks: $vault_root/_dashboard/cc-offered.md" >&2
  exit 2
fi

claim_epoch="$(date +%s)"

# Verify status/ownership, then either claim offered work or resume owned
# ready-state work (PR/merge-queue maintenance).
python3 - "$note_path" "$role" "$task_id" "$SCRIPT_DIR/.." "$session_id" \
  "$claim_epoch" "$dispatch_present" "$dispatch_message_id" \
  "$dispatch_binding_hash" "$dispatch_platform" "$dispatch_mode" \
  "$dispatch_profile" "$dispatch_authority_case" "$dispatch_idempotency_key" \
  "$dispatch_task_path" "$dispatch_task_sha256" "$dispatch_parent_spec" \
  "$dispatch_lane_session" "$dispatch_lane_generation" "$dispatch_lane_pid" \
  "$dispatch_lane_pid_generation" "$dispatch_claim_projection" \
  "$dispatch_relay_projection" <<'PYEOF'
import hashlib
import os
import re
import sys
from datetime import datetime, timezone
from pathlib import Path

path, role, task_id, repo_root = (
    Path(sys.argv[1]),
    sys.argv[2],
    sys.argv[3],
    Path(sys.argv[4]).resolve(),
)
# Already validated claim-keyable by the bash caller (empty when not); stamped
# into the session log so vault forensics join on session_id, never on pid.
session_id = sys.argv[5] if len(sys.argv) > 5 else ""
(
    claim_epoch,
    dispatch_present,
    dispatch_message_id,
    dispatch_binding_hash,
    dispatch_platform,
    dispatch_mode,
    dispatch_profile,
    dispatch_authority_case,
    dispatch_idempotency_key,
    dispatch_task_path,
    dispatch_task_sha256,
    dispatch_parent_spec,
    dispatch_lane_session,
    dispatch_lane_generation,
    dispatch_lane_pid,
    dispatch_lane_pid_generation,
    dispatch_claim_projection,
    dispatch_relay_projection,
) = sys.argv[6:24]
if str(repo_root) not in sys.path:
    sys.path.insert(0, str(repo_root))

from shared.sdlc_lifecycle import (  # noqa: E402
    TASK_CLAIMABLE_STATUSES,
    TASK_RESUMABLE_STATUSES,
    blocked_reason_from_frontmatter,
    blocked_witness_from_frontmatter,
    frontmatter_from_text,
    task_closure_validity,
)
from shared.coord_dispatch import (  # noqa: E402
    CoordDispatchError,
    lane_ownership_projection_hashes,
)
from shared.sdlc_task_store import (  # noqa: E402
    ClaimDispatchBinding,
    TaskStoreError,
    resolve_task_note,
    write_claim_dispatch_binding,
)

snapshot = resolve_task_note(path.parent.parent, task_id, state="active")
if snapshot.path != path.resolve():
    raise TaskStoreError(
        "claim_task_path_changed",
        "retry against the exact shared task-note resolution",
        str(snapshot.path),
    )
text = snapshot.content.decode("utf-8")
if int(dispatch_present):
    if (
        str(snapshot.path) != dispatch_task_path
        or snapshot.sha256 != dispatch_task_sha256
        or str(snapshot.frontmatter.get("authority_case") or "").strip()
        != dispatch_authority_case
        or str(snapshot.frontmatter.get("parent_spec") or "").strip()
        != dispatch_parent_spec
    ):
        raise TaskStoreError(
            "claim_dispatch_task_preimage_mismatch",
            "re-dispatch from the current exact task bytes and authority",
            str(snapshot.path),
        )

    def pid_generation(pid: int) -> str:
        try:
            stat_text = Path(f"/proc/{pid}/stat").read_text(encoding="utf-8")
            return f"pid:{pid}:{stat_text.rsplit(')', 1)[1].split()[19]}"
        except (OSError, IndexError):
            return f"pid:{pid}"

    if dispatch_lane_session:
        import subprocess

        proc = subprocess.run(
            [
                "tmux",
                "list-sessions",
                "-F",
                "#{session_name}\t#{session_id}\t#{session_created}",
            ],
            capture_output=True,
            text=True,
            timeout=5,
            check=False,
        )
        generations = {}
        for line in proc.stdout.splitlines():
            values = line.rstrip().split("\t")
            if len(values) >= 3:
                generations[values[0].strip()] = ":".join(values[1:3])
        if generations.get(dispatch_lane_session) != dispatch_lane_generation:
            raise TaskStoreError(
                "claim_dispatch_lane_generation_changed",
                "re-dispatch to the currently observed lane generation",
            )
    else:
        generation_parts = dispatch_lane_generation.split(":", 2)
        if (
            len(generation_parts) < 2
            or generation_parts[0] != "pid"
            or not generation_parts[1].isdigit()
            or pid_generation(int(generation_parts[1])) != dispatch_lane_generation
        ):
            raise TaskStoreError(
                "claim_dispatch_lane_generation_changed",
                "re-dispatch to the currently observed lane generation",
            )
    if dispatch_lane_pid:
        if (
            not dispatch_lane_pid.isdigit()
            or pid_generation(int(dispatch_lane_pid)) != dispatch_lane_pid_generation
        ):
            raise TaskStoreError(
                "claim_dispatch_lane_process_changed",
                "re-dispatch to the currently observed lane process",
            )
    cache_dir = Path.home() / ".cache" / "hapax"
    relay_dir = Path(os.environ.get("HAPAX_RELAY_DIR", str(cache_dir / "relay")))
    try:
        claim_hash, relay_hash = lane_ownership_projection_hashes(
            cache_dir=cache_dir,
            relay_dir=relay_dir,
            role=role,
            session=dispatch_lane_session,
        )
    except CoordDispatchError as exc:
        raise TaskStoreError(
            exc.reason,
            "restore readable claim and relay ownership projections",
        ) from exc
    if claim_hash != dispatch_claim_projection or relay_hash != dispatch_relay_projection:
        raise TaskStoreError(
            "claim_dispatch_ownership_projection_changed",
            "re-dispatch after claim and relay ownership state stabilizes",
        )
if not text.startswith("---") or text.find("\n---", 4) < 0:
    print(
        f"cc-claim: FATAL — task note {path} has no closing frontmatter "
        "delimiter; next action: repair the note (restore the opening and "
        "closing '---' lines), then re-run cc-claim. No claim caches were written.",
        file=sys.stderr,
    )
    sys.exit(6)
frontmatter = frontmatter_from_text(text)
now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def _strip_scalar(value: str) -> str:
    return value.strip().strip('"').strip("'")


_YAML_NULLS = frozenset({"", "null", "none", "~", "[]"})


def _is_claimable_assignee(value: str) -> bool:
    stripped = _strip_scalar(value)
    return stripped == "unassigned" or stripped.lower() in _YAML_NULLS


# Canonical SSOT: a lane may resume an owned task in any merge-ready state, not
# just pr_open/merge_queue (shared/sdlc_lifecycle.py TASK_RESUMABLE_STATUSES).
READY_STATUSES = TASK_RESUMABLE_STATUSES


status_match = re.search(r"^status:\s*(\S+)$", text, flags=re.MULTILINE)
status = status_match.group(1) if status_match else "offered"
assigned_match = re.search(r"^assigned_to:[ \t]*(.*)$", text, flags=re.MULTILINE)
assigned_raw = assigned_match.group(1) if assigned_match else "unassigned"
assigned_to = _strip_scalar(assigned_raw)

if status in TASK_CLAIMABLE_STATUSES:
    if assigned_match and not _is_claimable_assignee(assigned_raw):
        print(
            f"cc-claim: refusing to claim '{task_id}' — already assigned to '{assigned_to}'",
            file=sys.stderr,
        )
        sys.exit(4)
    claim_mode = "claim"
elif status in READY_STATUSES:
    if _is_claimable_assignee(assigned_raw):
        print(
            f"cc-claim: refusing to resume '{task_id}' — ready-state task is not assigned to '{role}'",
            file=sys.stderr,
        )
        sys.exit(4)
    if assigned_to != role:
        print(
            f"cc-claim: refusing to resume '{task_id}' — assigned to '{assigned_to}', not '{role}'",
            file=sys.stderr,
        )
        sys.exit(4)
    claim_mode = "resume"
else:
    detail = ""
    if status == "blocked":
        detail_parts: list[str] = []
        reason = blocked_reason_from_frontmatter(frontmatter)
        witness = blocked_witness_from_frontmatter(frontmatter)
        detail_parts.append(f"blocked_reason: {reason or 'missing'}")
        if witness:
            detail_parts.append(f"blocked_witness: {witness}")
        detail = " (" + "; ".join(detail_parts) + ")"
    print(
        f"cc-claim: refusing to claim '{task_id}' — current status is '{status}'{detail}, "
        "not 'offered' or an assigned ready state",
        file=sys.stderr,
    )
    sys.exit(4)


def _frontmatter_lines(note_text: str) -> list[str]:
    if not note_text.startswith("---"):
        return []
    end = note_text.find("\n---", 4)
    if end < 0:
        return []
    return note_text[4:end].splitlines()


def _parse_inline_list(value: str) -> list[str]:
    value = value.strip()
    if value == "[]":
        return []
    if _strip_scalar(value).lower() in _YAML_NULLS:
        return []
    if not (value.startswith("[") and value.endswith("]")):
        return [_strip_scalar(value)] if value else []
    inner = value[1:-1].strip()
    if not inner:
        return []
    return [_strip_scalar(item) for item in inner.split(",") if _strip_scalar(item)]


def _parse_depends_on(note_text: str) -> list[str]:
    lines = _frontmatter_lines(note_text)
    for idx, line in enumerate(lines):
        stripped = line.strip()
        if not stripped.startswith("depends_on:"):
            continue
        value = stripped.split(":", 1)[1].strip()
        if value:
            return _parse_inline_list(value)

        deps: list[str] = []
        for child in lines[idx + 1 :]:
            child_stripped = child.strip()
            if not child_stripped:
                continue
            if child_stripped.startswith("- "):
                dep_id = _strip_scalar(child_stripped[2:])
                if dep_id:
                    deps.append(dep_id)
                continue
            break
        return deps
    return []


def _parse_frontmatter(note_text: str) -> dict[str, str | list[str]]:
    fields: dict[str, str | list[str]] = {}
    lines = _frontmatter_lines(note_text)
    idx = 0
    while idx < len(lines):
        line = lines[idx]
        stripped = line.strip()
        idx += 1
        if not stripped or stripped.startswith("#") or ":" not in stripped:
            continue
        key, raw_value = stripped.split(":", 1)
        key = key.strip()
        value = raw_value.strip()
        if value:
            if value.startswith("[") and value.endswith("]"):
                fields[key] = _parse_inline_list(value)
            else:
                fields[key] = _strip_scalar(value)
            continue

        items: list[str] = []
        while idx < len(lines):
            child = lines[idx].strip()
            if not child:
                idx += 1
                continue
            if child.startswith("- "):
                item = _strip_scalar(child[2:])
                if item:
                    items.append(item)
                idx += 1
                continue
            break
        fields[key] = items
    return fields


def _field_tokens(value: str | list[str] | None) -> set[str]:
    if value is None:
        return set()
    if isinstance(value, list):
        raw_values = value
    else:
        raw_values = _parse_inline_list(value) if value.startswith("[") else [value]
    tokens: set[str] = set()
    for raw in raw_values:
        token = _strip_scalar(str(raw)).lower().replace("_", "-")
        if token:
            tokens.add(token)
    return tokens


def _is_nullish(value: str | list[str] | None) -> bool:
    if value is None:
        return True
    if isinstance(value, list):
        return len(value) == 0
    return _strip_scalar(value).lower() in ("", "null", "none", "~", "[]")


def _is_authority_exempt(fields: dict[str, str | list[str]]) -> bool:
    tokens: set[str] = set()
    for key in ("kind", "task_type", "work_type", "tier", "tags"):
        tokens.update(_field_tokens(fields.get(key)))

    mutation_tokens = {
        "build",
        "bugfix",
        "code",
        "deploy",
        "feature",
        "fix",
        "implementation",
        "mutation",
        "release",
        "runtime",
        "source",
        "systemd",
    }
    if tokens & mutation_tokens:
        return False

    non_mutating_tokens = {
        "audit",
        "intake",
        "operator_action",
        "planning",
        "plan",
        "read-only",
        "readonly",
        "research",
        "triage",
        "validation",
        "validation-demo",
    }
    return bool(tokens & non_mutating_tokens)


fields = _parse_frontmatter(text)
missing_authority_fields: list[str] = []
if not _is_authority_exempt(fields):
    if _is_nullish(fields.get("authority_case")):
        missing_authority_fields.append("authority_case")
    if all(
        _is_nullish(fields.get(k))
        for k in ("parent_spec", "parent_plan", "parent_request")
    ):
        missing_authority_fields.append("parent_spec (or parent_plan/parent_request)")

if missing_authority_fields:
    print(
        f"cc-claim: BLOCKED — task '{task_id}' is missing required AuthorityCase/ISAP fields: "
        + ", ".join(missing_authority_fields),
        file=sys.stderr,
    )
    print(
        "Implementation/build/runtime tasks must have non-null authority_case and parent_spec before claim.",
        file=sys.stderr,
    )
    print(
        "Use an explicitly read-only intake/planning task for pre-authorization work.",
        file=sys.stderr,
    )
    sys.exit(6)


def _locate_task(vault_root: Path, dep_id: str) -> Path | None:
    for state in ("closed", "active"):
        try:
            return resolve_task_note(vault_root, dep_id, state=state).path
        except TaskStoreError as exc:
            if exc.reason_code != "task_note_not_found":
                raise
    return None


def _frontmatter_status(note_text: str) -> str:
    match = re.search(r"^status:\s*(\S+)$", note_text, flags=re.MULTILINE)
    return match.group(1) if match else "unknown"


vault_root = path.parent.parent
DEFAULT_PR_REPO = "hapax-systems/hapax-council"


def _parse_pr_number(note_text: str) -> str | None:
    """Extract PR number from frontmatter pr: field."""
    match = re.search(r"^pr:\s*(\S+)$", note_text, flags=re.MULTILINE)
    if not match:
        return None
    val = match.group(1).strip().strip("\x27\x22")
    if val.lower() in ("null", "none", "~", ""):
        return None
    # Strip leading # if present
    return val.lstrip("#")


def _parse_pr_repo(note_text: str) -> str:
    """Extract PR repository from frontmatter pr_repo: field."""
    match = re.search(r"^pr_repo:\s*(\S+)$", note_text, flags=re.MULTILINE)
    if not match:
        return DEFAULT_PR_REPO
    val = match.group(1).strip().strip("\x27\x22")
    if val.lower() in ("null", "none", "~", ""):
        return DEFAULT_PR_REPO
    return val


def _check_pr_merged(pr_number: str, repo: str = DEFAULT_PR_REPO) -> str:
    """Check PR merge status via gh CLI. Returns merged|open|closed|unknown."""
    import subprocess
    try:
        cwd = Path.home() / "projects" / "hapax-council"
        run_kwargs = {"cwd": str(cwd)} if cwd.is_dir() else {}
        result = subprocess.run(
            [
                "gh",
                "pr",
                "view",
                pr_number,
                "--repo",
                repo,
                "--json",
                "state,mergedAt",
                "--jq",
                '.state + "," + ((.mergedAt != null and .mergedAt != "") | tostring)',
            ],
            capture_output=True, text=True, timeout=15,
            **run_kwargs,
        )
        if result.returncode != 0:
            return "unknown"
        parts = result.stdout.strip().split(",")
        if len(parts) == 2 and parts[1] == "true":
            return "merged"
        if parts[0] == "OPEN":
            return "open"
        if parts[0] == "CLOSED":
            return "closed_unmerged"
        return "unknown"
    except Exception:
        return "unknown"


def _insert_session_log(note_text: str, log_line: str) -> str:
    heading = re.search(
        r"^## Session [Ll]og[ \t]*(?:\n|$)", note_text, flags=re.MULTILINE
    )
    if heading:
        prefix = note_text[: heading.end()]
        suffix = note_text[heading.end() :]
        if not prefix.endswith("\n"):
            prefix = f"{prefix}\n"
        return f"{prefix}{log_line}{suffix}"
    return f"{note_text.rstrip()}\n\n## Session log\n{log_line}"


unmet: list[str] = []
if claim_mode == "claim":
    for dep_id in _parse_depends_on(text):
        dep_path = _locate_task(vault_root, dep_id)
        if dep_path is None:
            unmet.append(f"{dep_id} (not found in vault)")
            continue
        dep_text = dep_path.read_text(encoding="utf-8")
        dep_pr_repo = _parse_pr_repo(dep_text)
        validity = task_closure_validity(
            dep_text,
            pr_state_lookup=lambda pr_number, repo=dep_pr_repo: _check_pr_merged(
                pr_number,
                repo,
            ),
            require_route_metadata_validity=True,
        )
        if not validity.valid:
            unmet.append(f"{dep_id} ({'; '.join(validity.blockers)})")

if unmet:
    print(f"cc-claim: BLOCKED — task '{task_id}' has unmet dependencies:", file=sys.stderr)
    for item in unmet:
        print(f"  - {item}", file=sys.stderr)
    print("\nResolve dependencies before claiming this task.", file=sys.stderr)
    sys.exit(5)

if claim_mode == "claim":
    # A note authored without the full claim key set makes plain re.sub
    # stamps silent no-ops: the claim lands as `status: claimed` with
    # claimed_at absent — exactly the cc-hygiene H1 ghost predicate — and H1
    # reverts the fresh claim out from under the live lane (2026-07-01
    # eta/ndcvb-phase1 incident). Stamp, insert, and verify STRICTLY inside
    # the frontmatter slice: a column-0 `claimed_at:`/`status:` line in the
    # note BODY (quoted frontmatter in a session log, an annex) must neither
    # absorb the stamp nor satisfy the verification.
    _fm_end = text.find("\n---", 4)
    if _fm_end < 0:
        print(
            f"cc-claim: FATAL — task note {path} has no closing frontmatter "
            "delimiter; next action: repair the note (restore the closing "
            "'---' line), then re-run cc-claim. No claim caches were written.",
            file=sys.stderr,
        )
        sys.exit(6)
    _front, _rest = text[:_fm_end], text[_fm_end:]
    _front = re.sub(r"^status:.*$", "status: claimed", _front, count=1, flags=re.MULTILINE)
    _front = re.sub(
        r"^assigned_to:.*$", f"assigned_to: {role}", _front, count=1, flags=re.MULTILINE
    )
    _front = re.sub(
        r"^claimed_at:.*$", f"claimed_at: {now}", _front, count=1, flags=re.MULTILINE
    )
    _required_stamp = {
        "status": "claimed",
        "assigned_to": role,
        "claimed_at": now,
    }
    # Duplicate claim keys are fail-closed: re.sub(count=1) stamps only the
    # FIRST occurrence while YAML consumers (cc-hygiene) treat the LAST as
    # authoritative — a later duplicate `claimed_at: null` would pass the
    # verification below yet leave the note effectively ghost-claimable.
    _dupes = [
        _key
        for _key in _required_stamp
        if len(re.findall(rf"^{_key}:", _front, flags=re.MULTILINE)) > 1
    ]
    if _dupes:
        print(
            f"cc-claim: FATAL — duplicate frontmatter keys {_dupes} in {path}; "
            "next action: remove the duplicate lines (one occurrence per key), "
            "then re-run cc-claim. No claim caches were written.",
            file=sys.stderr,
        )
        sys.exit(6)
    for _key, _value in _required_stamp.items():
        if not re.search(rf"^{_key}:", _front, flags=re.MULTILINE):
            _front = f"{_front}\n{_key}: {_value}"
    _unstamped = [
        _key
        for _key, _value in _required_stamp.items()
        if not re.search(
            rf"^{_key}:\s*{re.escape(str(_value))}\s*$", _front, flags=re.MULTILINE
        )
    ]
    if _unstamped:
        print(
            f"cc-claim: FATAL — claim stamp did not land for {_unstamped} in {path}; "
            "refusing to write claim caches over a ghost-claimable note. Next "
            "action: repair the note frontmatter (each key must be a "
            "single-line scalar), then re-run cc-claim. No claim caches were "
            "written; nothing to roll back.",
            file=sys.stderr,
        )
        sys.exit(6)
    text = _front + _rest
    session_suffix = f", session={session_id}" if session_id else ""
    log_line = f"- {now} {role} claimed (cc-claim{session_suffix})\n"
    result_message = f"cc-claim: claimed task '{task_id}' for role '{role}'"
else:
    session_suffix = f", session={session_id}" if session_id else ""
    log_line = f"- {now} {role} resumed ready-state task (cc-claim{session_suffix})\n"
    result_message = f"cc-claim: resumed task '{task_id}' for role '{role}'"

text = re.sub(
    r"^updated_at:.*$", f"updated_at: {now}", text, count=1, flags=re.MULTILINE
)
text = _insert_session_log(text, log_line)

if hashlib.sha256(path.read_bytes()).hexdigest() != snapshot.sha256:
    raise TaskStoreError(
        "claim_task_changed_before_compare_and_swap",
        "retry against the current exact task bytes",
        str(path),
    )
tmp = path.with_suffix(path.suffix + ".tmp")
tmp.write_text(text, encoding="utf-8")
tmp.replace(path)
if int(dispatch_present):
    claimed = resolve_task_note(path.parent.parent, task_id, state="active")
    if (
        str(claimed.frontmatter.get("assigned_to") or "").strip() != role
        or str(claimed.frontmatter.get("authority_case") or "").strip()
        != dispatch_authority_case
    ):
        raise TaskStoreError(
            "claim_dispatch_postimage_mismatch",
            "repair the task claim before publishing claim caches",
            str(path),
        )
    binding = ClaimDispatchBinding.create(
        task_id=task_id,
        lane=role,
        session_id=session_id,
        claim_epoch=int(claim_epoch),
        dispatch_message_id=dispatch_message_id,
        platform=dispatch_platform,
        mode=dispatch_mode,
        profile=dispatch_profile,
        authority_case=dispatch_authority_case,
        binding_hash=dispatch_binding_hash,
        coord_dispatch_idempotency_key=dispatch_idempotency_key,
    )
    cache_dir = Path.home() / ".cache" / "hapax"
    keys = [role]
    if session_id:
        keys.append(f"{role}-{session_id}")
    for key in keys:
        write_claim_dispatch_binding(cache_dir, key, binding)
print(result_message)
PYEOF

# Write the claim file(s) the gate + consumers read.
mkdir -p "$HOME/.cache/hapax"
if [[ "$dispatch_present" -eq 0 ]]; then
  rm -f "$HOME/.cache/hapax/cc-claim-dispatch-$role.json"
  if [[ -n "$session_id" ]]; then
    rm -f "$HOME/.cache/hapax/cc-claim-dispatch-$role-$session_id.json"
  fi
fi
# The `cc-claim-epoch-*` SIDECAR records the claim time out-of-band: several
# consumers read the claim file's FULL content as the task id, so the id file
# must stay single-line — and the gate touches the claim file as a lease
# keep-alive before its checks, so its mtime cannot witness claim age.
# task_is_terminal reads the sidecar as its ONLY heartbeat-immune freshness
# source (H1-ghost-revert indeterminate shape); there is deliberately no
# mtime fallback, so every cache writer must keep the sidecar in step. The
# distinct prefix keeps sidecars out of every `cc-active-task-*` glob
# (sweeps, terminal checks) so an epoch can never masquerade as a claim.
# Paths are constructed EXPLICITLY (never by substring substitution on the
# full path — `${var/cc-active-task/...}` rewrites the FIRST occurrence
# anywhere, corrupting the target when a parent directory contains the
# substring).
# Sidecar format: `<epoch> <task_id>` — task-bound so a stale sidecar left by
# an earlier claim can never age a NEW claim of a different task; consumers
# ignore a sidecar whose task id does not match the claim cache.
# Sidecars are written BEFORE their claim caches: a conforming writer can
# never expose a matching cache whose sidecar is not yet visible.
echo "$claim_epoch $task_id" > "$HOME/.cache/hapax/cc-claim-epoch-$role"
# Legacy role-keyed file: read by cc-close, session-context, the coordinator, the
# coordination TUI, and other consumers outside this task's scope. Always written.
echo "$task_id" > "$legacy_claim_file"
if [[ -n "$session_claim_file" ]]; then
  # Session-keyed lease (FM-2): the gate reads this FIRST so two same-role
  # sessions never collide on the shared legacy file. Same task id; the filename
  # carries the session identity.
  echo "$claim_epoch $task_id" > "$HOME/.cache/hapax/cc-claim-epoch-$role-$session_id"
  echo "$task_id" > "$session_claim_file"
  echo "cc-claim: wrote $session_claim_file (+ legacy cc-active-task-$role)"
else
  echo "cc-claim: wrote ~/.cache/hapax/cc-active-task-$role"
fi
