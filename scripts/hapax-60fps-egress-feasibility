#!/usr/bin/env python3
"""Print deterministic 60 fps compositor egress feasibility sizing."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from shared.egress_cadence_feasibility import assess_egress_cadence


def _parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--width", type=int, default=1280)
    parser.add_argument("--height", type=int, default=720)
    parser.add_argument("--current-fps", type=int, default=30)
    parser.add_argument("--target-fps", type=int, default=60)
    parser.add_argument("--source-publish-fps", type=float)
    parser.add_argument("--live-egress-fps", type=float)
    parser.add_argument("--free-vram-mib", type=float)
    parser.add_argument("--three-d-mode", action="store_true")
    parser.add_argument("--json", action="store_true", dest="as_json")
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = _parse_args(sys.argv[1:] if argv is None else argv)
    report = assess_egress_cadence(
        width=args.width,
        height=args.height,
        current_fps=args.current_fps,
        target_fps=args.target_fps,
        source_publish_fps=args.source_publish_fps,
        live_egress_fps=args.live_egress_fps,
        free_vram_mib=args.free_vram_mib,
        three_d_mode=args.three_d_mode,
    )

    payload = report.to_dict()
    if args.as_json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(f"recommendation: {report.recommendation}")
        print(f"resolution: {report.width}x{report.height}")
        print(f"cadence: {report.current_fps}fps -> {report.target_fps}fps")
        print(f"workload_multiplier: {report.workload_multiplier:.2f}x")
        print(f"added_nv12_mib_per_s: {report.added_nv12_mib_per_s:.2f}")
        print(f"added_bgra_mib_per_s: {report.added_bgra_mib_per_s:.2f}")
        print(f"bridge_copy_added_mib_per_s: {report.bridge_copy_added_mib_per_s:.2f}")
        print(f"standing_buffer_increment_mib: {report.standing_buffer_increment_mib:.2f}")
        if report.blockers:
            print("blockers:")
            for blocker in report.blockers:
                print(f"  - {blocker}")
        if report.warnings:
            print("warnings:")
            for warning in report.warnings:
                print(f"  - {warning}")

    return 0 if report.recommendation == "candidate_canary" else 10


if __name__ == "__main__":
    raise SystemExit(main())
