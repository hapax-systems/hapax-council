#!/usr/bin/env bash
# hapax-lane-idle-watchdog — pane-content idle detection + auto-redispatch.
#
# Problem: lanes finish tasks and sit at their prompt producing nothing.
# Existing monitoring (systemd, tmux has-session, process alive) all say
# "fine" because the process IS running — it's just not working.
#
# Solution: capture each lane's pane, detect platform-specific idle state,
# track how long each lane has been idle, and auto-redispatch from the
# WSJF queue once the threshold is exceeded.
#
# Platforms:
#   Claude:  idle = "❯" prompt visible + no active tool indicators
#   Codex:   idle = "gpt-5.5" model line at bottom, NO "Working (" indicator
#   Gemini:  idle = input box visible (▄/▀ bars) with no streaming output
#
# Runs as systemd oneshot (hapax-lane-idle-watchdog.timer, every 2 min).
# Dispatches ALL idle lanes per tick. Cooldown: 120s per lane between kicks.
set -euo pipefail

# ─── Configuration ───────────────────────────────────────────────────────────
IDLE_THRESHOLD_S="${HAPAX_IDLE_THRESHOLD_S:-600}"       # 10 minutes
COOLDOWN_S="${HAPAX_IDLE_COOLDOWN_S:-120}"              # 2 min between kicks
STATE_DIR="${HAPAX_IDLE_STATE_DIR:-/tmp/hapax-lane-idle-state}"
TASK_ROOT="${HOME}/Documents/Personal/20-projects/hapax-cc-tasks/active"
REQUEST_ROOT="${HOME}/Documents/Personal/20-projects/hapax-requests/active"
NTFY_TOPIC="${HAPAX_NTFY_TOPIC:-hapax}"
NTFY_URL="${HAPAX_NTFY_URL:-http://localhost:8092}"
CLAUDE_SEND="${HOME}/projects/hapax-council/scripts/hapax-claude-send"
CODEX_SEND="${HOME}/projects/hapax-council/scripts/hapax-codex-send"
CC_CLAIM="${HOME}/.local/bin/cc-claim"
METHODOLOGY_DISPATCH="${HOME}/.local/bin/hapax-methodology-dispatch"

# Skip alpha (integrator, always has operator) and RTE
SKIP_LANES="${HAPAX_IDLE_SKIP_LANES:-alpha}"

# Lanes that must always be running (operator directive: 4 of each at all times)
REQUIRED_CLAUDE_LANES="${HAPAX_REQUIRED_CLAUDE_LANES:-beta gamma delta epsilon}"
REQUIRED_CODEX_LANES="${HAPAX_REQUIRED_CODEX_LANES:-cx-cpu-bridge cx-effect-drift-current cx-preset-storm cx-visual-bandwidth}"
CLAUDE_LAUNCHER="${HOME}/.local/bin/hapax-claude"
CODEX_LAUNCHER="${HOME}/projects/hapax-council/scripts/hapax-codex"

mkdir -p "$STATE_DIR"
now=$(date +%s)

log() { echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) lane-idle: $*"; }

# ─── Platform detection functions ────────────────────────────────────────────

# Claude: idle when "❯" prompt visible in last few lines.
# When Claude is actively working, output streams and the prompt scrolls out.
# When idle, ❯ sits in the last 5 lines with status bar below.
# Context-full lanes (showing "/clear to save") are ALSO idle — they finished
# work and need /clear + new task dispatch.
is_claude_idle() {
    local pane="$1"
    local tail5
    tail5=$(echo "$pane" | tail -5)

    # Idle: the ❯ prompt is in the last 5 lines (includes context-full state)
    if echo "$tail5" | grep -q '❯'; then
        return 0
    fi

    # Permission prompts in the tail — blocked, not idle-done
    if echo "$tail5" | grep -qE '(Allow|Deny|bypass permissions on)'; then
        return 1
    fi

    return 1  # prompt not visible, assume working
}

is_claude_context_full() {
    local pane="$1"
    echo "$pane" | tail -10 | grep -q "/clear to save"
}

# Codex: idle when model line visible at bottom, no "Working" indicator
is_codex_idle() {
    local pane="$1"
    # Active: "Working (Xm Ys" or "Working (Xs"
    if echo "$pane" | grep -qE 'Working \([0-9]'; then
        return 1  # actively working
    fi
    # Idle: shows model string at bottom (gpt-5.5/gpt-4.1/o3/etc)
    if echo "$pane" | tail -5 | grep -qE '(gpt-[0-9]|o[0-9]|codex-).*~/projects/'; then
        return 0  # idle at prompt
    fi
    # Also idle if we see the "› " prompt line without Working above it
    if echo "$pane" | tail -10 | grep -qE '^› '; then
        if ! echo "$pane" | grep -qE 'Working \('; then
            return 0
        fi
    fi
    return 1
}

# Gemini: idle when input box bars visible and no streaming
is_gemini_idle() {
    local pane="$1"
    # Active: Gemini streams text without the input box delimiter
    # The input box uses ▄ and ▀ bars as delimiters
    # When idle, we see the model/workspace status bar at the bottom
    if echo "$pane" | tail -5 | grep -qE '(gemini-[0-9]|workspace|/model)'; then
        # Has the status bar visible — check not actively outputting
        # If last line is the status bar or ▀▀ bar, it's idle
        local last_content
        last_content=$(echo "$pane" | tail -3 | head -1)
        if echo "$last_content" | grep -qE '^[▀ ]+$'; then
            return 0  # idle
        fi
        if echo "$last_content" | grep -qE '(workspace|/model|sandbox)'; then
            return 0  # idle
        fi
    fi
    # Gemini at the > prompt with no output flowing
    if echo "$pane" | tail -8 | grep -qE '^ ?> $'; then
        return 0
    fi
    return 1
}

# ─── Lane discovery ──────────────────────────────────────────────────────────

declare -A LANES  # session_name -> platform
lane_count=0

for session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null | sort); do
    case "$session" in
        hapax-claude-*)
            lane="${session#hapax-claude-}"
            # Skip configured lanes
            for skip in $SKIP_LANES; do
                [ "$lane" = "$skip" ] && continue 2
            done
            LANES["$session"]="claude"
            lane_count=$((lane_count + 1))
            ;;
        hapax-codex-*)
            lane="${session#hapax-codex-}"
            LANES["$session"]="codex"
            lane_count=$((lane_count + 1))
            ;;
        hapax-gemini-*)
            lane="${session#hapax-gemini-}"
            LANES["$session"]="gemini"
            lane_count=$((lane_count + 1))
            ;;
    esac
done

# ─── Ensure required Claude lanes are alive ─────────────────────────────────

launched_lanes=0
revived_lanes=0

if [ -x "$CLAUDE_LAUNCHER" ]; then
    for role in $REQUIRED_CLAUDE_LANES; do
        session="hapax-claude-${role}"
        worktree="${HOME}/projects/hapax-council--${role}"

        cooldown_file="$STATE_DIR/_lane_launch_${role}.last"
        launch_cooldown=300  # 5 min between launch attempts per lane
        if [ -f "$cooldown_file" ]; then
            last_attempt=$(cat "$cooldown_file")
            elapsed=$((now - last_attempt))
            if [ "$elapsed" -lt "$launch_cooldown" ]; then
                continue
            fi
        fi

        if ! tmux has-session -t "$session" 2>/dev/null; then
            # Session doesn't exist — launch it
            if [ -d "$worktree" ]; then
                log "LAUNCHING missing lane: $role"
                echo "$now" > "$cooldown_file"
                "$CLAUDE_LAUNCHER" --role "$role" --terminal tmux 2>/dev/null || true
                launched_lanes=$((launched_lanes + 1))
                curl -sf -d "Lane idle watchdog: launched $role (session missing)" \
                    -H "Title: Lane auto-launched" \
                    -H "Priority: default" \
                    -H "Tags: rocket" \
                    "$NTFY_URL/$NTFY_TOPIC" >/dev/null 2>&1 || true
            else
                log "WARN: worktree missing for $role at $worktree"
            fi
        else
            # Session exists — check if Claude is actually running in it
            pane_cmd=$(tmux display-message -t "$session" -p '#{pane_current_command}' 2>/dev/null) || continue
            case "$pane_cmd" in
                claude|claude-code|node)
                    # Claude is running, all good
                    ;;
                *)
                    # Claude exited, shell is showing — relaunch
                    log "REVIVING dead Claude in $session (pane_cmd=$pane_cmd)"
                    echo "$now" > "$cooldown_file"
                    tmux send-keys -t "$session" "claude --resume" Enter 2>/dev/null || \
                        tmux send-keys -t "$session" "claude" Enter 2>/dev/null || true
                    revived_lanes=$((revived_lanes + 1))
                    curl -sf -d "Lane idle watchdog: revived $role (Claude had exited, pane was $pane_cmd)" \
                        -H "Title: Lane revived" \
                        -H "Priority: default" \
                        -H "Tags: recycle" \
                        "$NTFY_URL/$NTFY_TOPIC" >/dev/null 2>&1 || true
                    ;;
            esac
        fi
    done
fi

# ─── Ensure required Codex lanes are alive ─────────────────────────────────

if [ -x "$CODEX_LAUNCHER" ]; then
    for color in $REQUIRED_CODEX_LANES; do
        session="hapax-codex-${color}"
        worktree="${HOME}/projects/hapax-council--${color}"

        cooldown_file="$STATE_DIR/_lane_launch_codex_${color}.last"
        launch_cooldown=300
        if [ -f "$cooldown_file" ]; then
            last_attempt=$(cat "$cooldown_file")
            elapsed=$((now - last_attempt))
            if [ "$elapsed" -lt "$launch_cooldown" ]; then
                continue
            fi
        fi

        if ! tmux has-session -t "$session" 2>/dev/null; then
            if [ -d "$worktree" ]; then
                log "LAUNCHING missing Codex lane: $color"
                echo "$now" > "$cooldown_file"
                "$CODEX_LAUNCHER" --session "$color" --cd "$worktree" --terminal tmux 2>/dev/null || true
                launched_lanes=$((launched_lanes + 1))
                curl -sf -d "Lane idle watchdog: launched Codex $color (session missing)" \
                    -H "Title: Codex lane auto-launched" \
                    -H "Priority: default" \
                    -H "Tags: rocket" \
                    "$NTFY_URL/$NTFY_TOPIC" >/dev/null 2>&1 || true
            else
                log "WARN: Codex worktree missing for $color at $worktree"
            fi
        else
            pane_cmd=$(tmux display-message -t "$session" -p '#{pane_current_command}' 2>/dev/null) || continue
            case "$pane_cmd" in
                codex|node)
                    ;;
                *)
                    log "REVIVING dead Codex in $session (pane_cmd=$pane_cmd)"
                    echo "$now" > "$cooldown_file"
                    tmux send-keys -t "$session" "cd $worktree && codex --resume" Enter 2>/dev/null || \
                        tmux send-keys -t "$session" "cd $worktree && codex" Enter 2>/dev/null || true
                    revived_lanes=$((revived_lanes + 1))
                    curl -sf -d "Lane idle watchdog: revived Codex $color (pane was $pane_cmd)" \
                        -H "Title: Codex lane revived" \
                        -H "Priority: default" \
                        -H "Tags: recycle" \
                        "$NTFY_URL/$NTFY_TOPIC" >/dev/null 2>&1 || true
                    ;;
            esac
        fi
    done
fi

if [ "$launched_lanes" -gt 0 ] || [ "$revived_lanes" -gt 0 ]; then
    log "lane maintenance: launched=$launched_lanes revived=$revived_lanes"
fi

if [ "$lane_count" -eq 0 ]; then
    log "no active lanes found after maintenance pass"
    exit 0
fi

# ─── Idle detection pass ─────────────────────────────────────────────────────

declare -A IDLE_LANES=()   # session_name -> idle_duration_s
declare -A CTX_FULL=()     # session_name -> 1 if context-full (needs /clear before dispatch)
active_count=0
idle_count=0

for session in "${!LANES[@]}"; do
    platform="${LANES[$session]}"

    # Capture pane content
    pane_text=$(tmux capture-pane -t "$session" -p -S -30 2>/dev/null) || continue

    # Check if idle based on platform
    is_idle=false
    case "$platform" in
        claude)
            is_claude_idle "$pane_text" && is_idle=true
            if [ "$is_idle" = true ] && is_claude_context_full "$pane_text"; then
                CTX_FULL["$session"]=1
            fi
            ;;
        codex)   is_codex_idle "$pane_text"  && is_idle=true ;;
        gemini)  is_gemini_idle "$pane_text" && is_idle=true ;;
    esac

    state_file="$STATE_DIR/${session}.idle_since"

    if [ "$is_idle" = true ]; then
        # Record when we first saw this lane idle
        if [ -f "$state_file" ]; then
            idle_since=$(cat "$state_file")
        else
            echo "$now" > "$state_file"
            idle_since=$now
        fi
        idle_duration=$((now - idle_since))
        if [ "$idle_duration" -ge "$IDLE_THRESHOLD_S" ]; then
            IDLE_LANES["$session"]=$idle_duration
            idle_count=$((idle_count + 1))
        fi
    else
        # Lane is active — clear idle tracking
        rm -f "$state_file" 2>/dev/null
        active_count=$((active_count + 1))
    fi
done

log "scan: $lane_count lanes, $active_count active, $idle_count idle past threshold"

if [ "$idle_count" -eq 0 ]; then
    exit 0
fi

# ─── Dispatch ALL idle lanes past cooldown ──────────────────────────────────

pick_next_offered() {
    local skip_lane="$1"
    if [ ! -d "$TASK_ROOT" ]; then
        return 0
    fi
    # Find offered+unassigned tasks, sort by WSJF descending, return top task_id
    python3 -c "
import os, re, sys
from pathlib import Path
task_root = Path('$TASK_ROOT')
offered = []
for f in task_root.glob('*.md'):
    text = f.read_text()
    status_m = re.search(r'^status:\s*(\S+)', text, re.M)
    assigned_m = re.search(r'^assigned_to:\s*(.+)', text, re.M)
    wsjf_m = re.search(r'^wsjf:\s*(\S+)', text, re.M)
    if not status_m or status_m.group(1) != 'offered':
        continue
    assigned = (assigned_m.group(1).strip() if assigned_m else 'unassigned')
    if assigned != 'unassigned':
        continue
    wsjf = float(wsjf_m.group(1)) if wsjf_m else 0
    # Extract task_id (filename minus trailing descriptor)
    task_id_m = re.match(r'^([a-zA-Z0-9_-]+?)(?:-[A-Z].*)?$', f.stem)
    task_id = task_id_m.group(1) if task_id_m else f.stem
    offered.append((wsjf, task_id, f.stem))
offered.sort(reverse=True)
if offered:
    print(offered[0][2])
" 2>/dev/null
}

find_claimed_task() {
    local assignee="$1"
    if [ -d "$TASK_ROOT" ]; then
        local match
        match=$(grep -rl "^assigned_to: ${assignee}$" "$TASK_ROOT/" 2>/dev/null | head -1)
        if [ -n "$match" ]; then
            local task_id status
            task_id=$(basename "$match" .md)
            status=$(grep -m1 "^status:" "$match" 2>/dev/null | awk '{print $2}')
            if [ "$status" = "claimed" ] || [ "$status" = "in_progress" ]; then
                echo "$task_id"
                return 0
            fi
        fi
    fi
    return 1
}

dispatched=0
skipped_cooldown=0

for session in "${!IDLE_LANES[@]}"; do
    idle_s="${IDLE_LANES[$session]}"

    cooldown_file="$STATE_DIR/${session}.last_kick"
    if [ -f "$cooldown_file" ]; then
        last_kick=$(cat "$cooldown_file")
        elapsed=$((now - last_kick))
        if [ "$elapsed" -lt "$COOLDOWN_S" ]; then
            skipped_cooldown=$((skipped_cooldown + 1))
            continue
        fi
    fi

    platform="${LANES[$session]}"
    case "$session" in
        hapax-claude-*)  lane="${session#hapax-claude-}" ;;
        hapax-codex-*)   lane="${session#hapax-codex-}" ;;
        hapax-gemini-*)  lane="${session#hapax-gemini-}" ;;
    esac

    dispatch_msg=""
    claimed=$(find_claimed_task "$lane" 2>/dev/null || true)
    dispatch_target=""
    if [ -n "$claimed" ]; then
        dispatch_msg="IDLE WATCHDOG: You have been idle for $((idle_s/60))m with an active task: $claimed. Resume work immediately. Ship a PR and cc-close --pr N after merge."
        dispatch_target="$claimed"
    else
        # Pick next WSJF task from offered queue and claim it for this lane
        next_task=$(pick_next_offered "$lane")
        if [ -n "$next_task" ]; then
            task_title=$(grep -m1 "^title:" "$TASK_ROOT/${next_task}"*.md 2>/dev/null | sed 's/^title:[[:space:]]*//' | head -c 80)
            log "CLAIMING $next_task for $lane ($platform)"
            if HAPAX_AGENT_ROLE="$lane" "$CC_CLAIM" "$next_task" 2>/dev/null; then
                dispatch_msg="IDLE WATCHDOG: Claimed task $next_task for you. Title: ${task_title:-unknown}. Read the task note at ~/Documents/Personal/20-projects/hapax-cc-tasks/active/ and begin work immediately. Ship a PR and cc-close --pr N after merge."
                dispatch_target="$next_task"
            else
                log "CLAIM FAILED for $next_task -> $lane"
                dispatch_msg="IDLE WATCHDOG: Tried to claim $next_task but cc-claim failed. Check the task queue manually: ls ~/Documents/Personal/20-projects/hapax-cc-tasks/active/"
                dispatch_target="claim-failed"
            fi
        else
            log "NO OFFERED TASKS for $lane — queue empty"
            dispatch_msg="IDLE WATCHDOG: You have been idle for $((idle_s/60))m. No offered tasks in queue. Waiting for intake pipeline to produce work."
            dispatch_target="queue-empty"
        fi
    fi

    # Context-full Claude lanes need /clear before dispatch
    if [ "${CTX_FULL[$session]:-}" = "1" ] && [ "$platform" = "claude" ]; then
        log "CLEARING context-full $session before dispatch"
        tmux send-keys -t "$session" "/clear" Enter 2>/dev/null
        sleep 5
    fi

    send_success=false
    case "$platform" in
        claude)
            if [ -x "$CLAUDE_SEND" ]; then
                "$CLAUDE_SEND" --session "$lane" -- "$dispatch_msg" 2>/dev/null && send_success=true
            fi
            if [ "$send_success" = false ]; then
                tmux send-keys -t "$session" "$dispatch_msg" Enter 2>/dev/null && send_success=true
            fi
            ;;
        codex)
            if [ -x "$CODEX_SEND" ]; then
                "$CODEX_SEND" --session "$lane" -- "$dispatch_msg" 2>/dev/null && send_success=true
            fi
            if [ "$send_success" = false ]; then
                tmux send-keys -t "$session" "$dispatch_msg" Enter 2>/dev/null && send_success=true
            fi
            ;;
        gemini)
            tmux send-keys -t "$session" "$dispatch_msg" Enter 2>/dev/null && send_success=true
            ;;
    esac

    echo "$now" > "$STATE_DIR/${session}.last_kick"

    if [ "$send_success" = true ]; then
        log "DISPATCHED $session ($platform/$lane): idle ${idle_s}s -> $dispatch_target"
        rm -f "$STATE_DIR/${session}.idle_since" 2>/dev/null
        dispatched=$((dispatched + 1))
    else
        log "FAILED to dispatch $session ($platform/$lane): idle ${idle_s}s"
        curl -sf -d "Lane idle watchdog: failed to dispatch $lane ($platform) after ${idle_s}s idle" \
            -H "Title: Lane dispatch failure" \
            -H "Priority: high" \
            -H "Tags: warning" \
            "$NTFY_URL/$NTFY_TOPIC" >/dev/null 2>&1 || true
    fi
done

if [ "$dispatched" -eq 0 ] && [ "$skipped_cooldown" -gt 0 ]; then
    log "all $idle_count idle lanes in cooldown"
fi

log "dispatched $dispatched of $idle_count idle lanes"

# ─── Summary alert if many lanes idle ────────────────────────────────────────

if [ "$idle_count" -ge 3 ]; then
    idle_summary=""
    for session in "${!IDLE_LANES[@]}"; do
        idle_s="${IDLE_LANES[$session]}"
        idle_summary+="$session(${idle_s}s) "
    done
    log "WARNING: $idle_count lanes idle past threshold: $idle_summary"
    curl -sf -d "Lane idle watchdog: $idle_count lanes idle — $idle_summary" \
        -H "Title: Multiple lanes idle" \
        -H "Priority: high" \
        -H "Tags: warning,robot" \
        "$NTFY_URL/$NTFY_TOPIC" >/dev/null 2>&1 || true
fi
