#!/usr/bin/bash
# hapax-lane-idle-watchdog - read-only lane liveness observation.
#
# Pane and session observations are support evidence only. This surface cannot
# select claims, launch or revive lanes, clear context, send prompts, notify, or
# mutate cooldown state. Any observation that suggests an effect is printed as
# a visible HOLD until the generic authority, admission, and execution-lease
# composition can dispatch an exact machine adapter.
set -euo pipefail

TMUX_OBSERVER=(/usr/bin/env -i HOME=/nonexistent LANG=C.UTF-8 PATH=/usr/bin:/bin /usr/bin/tmux -f /dev/null)
readonly -a TMUX_OBSERVER

SKIP_LANES="${HAPAX_IDLE_SKIP_LANES-alpha}"
REQUIRED_CLAUDE_LANES="${HAPAX_REQUIRED_CLAUDE_LANES-beta gamma delta epsilon}"
REQUIRED_CODEX_LANES="${HAPAX_REQUIRED_CODEX_LANES-cx-cpu-bridge cx-effect-drift-current cx-preset-storm cx-visual-bandwidth}"

safe_field() {
    local value="$1"
    value="${value//[^A-Za-z0-9._:-]/_}"
    printf '%s' "${value:-unknown}"
}

observe() {
    local status="$1" target="$2" detail="$3"
    printf 'OBSERVE support_only=true status=%s target=%s detail=%s\n' \
        "$(safe_field "$status")" "$(safe_field "$target")" "$(safe_field "$detail")"
}

hold() {
    local action="$1" target="$2" reason="$3"
    printf 'HOLD effect_state=held_not_admitted action=%s target=%s reason=%s may_authorize=false\n' \
        "$(safe_field "$action")" "$(safe_field "$target")" "$(safe_field "$reason")"
}

should_skip_lane() {
    local lane="$1" skipped
    for skipped in $SKIP_LANES; do
        if [ "$lane" = "$skipped" ]; then
            return 0
        fi
    done
    return 1
}

is_claude_idle() {
    local pane="$1"
    if printf '%s\n' "$pane" | /usr/bin/tail -5 | /usr/bin/grep -qE '(Allow|Deny)'; then
        return 1
    fi
    printf '%s\n' "$pane" | /usr/bin/tail -5 | /usr/bin/grep -qE '(❯|⏵⏵|bypass permissions)'
}

is_claude_context_full() {
    printf '%s\n' "$1" | /usr/bin/tail -10 | /usr/bin/grep -q '/clear to save'
}

is_codex_idle() {
    local pane="$1"
    if printf '%s\n' "$pane" | /usr/bin/grep -qE 'Working \([0-9]'; then
        return 1
    fi
    if printf '%s\n' "$pane" | /usr/bin/tail -5 | /usr/bin/grep -qE '(gpt-[0-9]|o[0-9]|codex-).*~/projects/'; then
        return 0
    fi
    printf '%s\n' "$pane" | /usr/bin/tail -10 | /usr/bin/grep -qE '^› '
}

platform_and_lane() {
    local session="$1"
    case "$session" in
        hapax-claude-*)
            printf 'claude\t%s\n' "${session#hapax-claude-}"
            ;;
        hapax-codex-*)
            printf 'codex\t%s\n' "${session#hapax-codex-}"
            ;;
        *)
            return 1
            ;;
    esac
}

check_required_lane() {
    local platform="$1" lane="$2" session pane_cmd pane
    session="hapax-${platform}-${lane}"
    if [ -z "${SEEN_SESSIONS[$session]+present}" ]; then
        hold "lane.launch" "$lane" "execution_authority_admission_lease_absent"
        return
    fi

    pane_cmd="$("${TMUX_OBSERVER[@]}" display-message -t "$session" -p '#{pane_current_command}' 2>/dev/null || true)"
    pane="$("${TMUX_OBSERVER[@]}" capture-pane -t "$session" -p -S -5 2>/dev/null || true)"
    case "$platform:$pane_cmd" in
        claude:claude|claude:claude-code|claude:node|codex:codex|codex:node)
            return
            ;;
    esac
    if [ "$platform" = "claude" ] && printf '%s\n' "$pane" | /usr/bin/grep -qE '(❯|⏵⏵|bypass permissions|tokens)'; then
        return
    fi
    if [ "$platform" = "codex" ] && printf '%s\n' "$pane" | /usr/bin/grep -qE '(Working|gpt-[0-9]|codex-|context left|› )'; then
        return
    fi
    hold "lane.revive" "$lane" "execution_authority_admission_lease_absent"
}

main() {
    case "${1:---check}" in
        --check|--list) ;;
        --help|-h)
            printf 'usage: hapax-lane-idle-watchdog [--check|--list]\n'
            return 0
            ;;
        *)
            printf 'unsupported mode: %s\n' "$1" >&2
            return 2
            ;;
    esac

    local session platform lane pair pane
    local -a sessions=()
    mapfile -t sessions < <("${TMUX_OBSERVER[@]}" list-sessions -F '#{session_name}' 2>/dev/null | /usr/bin/sort || true)
    declare -gA SEEN_SESSIONS=()
    for session in "${sessions[@]}"; do
        [ -n "$session" ] || continue
        SEEN_SESSIONS["$session"]=1
    done

    for lane in $REQUIRED_CLAUDE_LANES; do
        check_required_lane claude "$lane"
    done
    for lane in $REQUIRED_CODEX_LANES; do
        check_required_lane codex "$lane"
    done

    for session in "${sessions[@]}"; do
        pair="$(platform_and_lane "$session" 2>/dev/null || true)"
        [ -n "$pair" ] || continue
        IFS=$'\t' read -r platform lane <<< "$pair"
        if should_skip_lane "$lane"; then
            observe "skipped" "$lane" "configured_skip"
            continue
        fi
        if ! pane="$("${TMUX_OBSERVER[@]}" capture-pane -t "$session" -p -S -30 2>/dev/null)"; then
            observe "indeterminate" "$lane" "pane_unavailable"
            continue
        fi
        case "$platform" in
            claude)
                if is_claude_idle "$pane"; then
                    observe "idle" "$lane" "pane_prompt_visible"
                    if is_claude_context_full "$pane"; then
                        hold "lane.context.clear" "$lane" "execution_authority_admission_lease_absent"
                    fi
                    hold "lane.nudge" "$lane" "execution_authority_admission_lease_absent"
                else
                    observe "active_or_blocked" "$lane" "no_idle_prompt"
                fi
                ;;
            codex)
                if is_codex_idle "$pane"; then
                    observe "idle" "$lane" "pane_prompt_visible"
                    hold "lane.nudge" "$lane" "execution_authority_admission_lease_absent"
                else
                    observe "active_or_blocked" "$lane" "working_or_unclassified"
                fi
                ;;
        esac
    done
    printf '# lane idle check: support_only=true effects=0\n'
}

main "$@"
