#!/usr/bin/env bash
# hapax-lane-idle-watchdog — pane-content idle detection + governed reminders.
#
# Problem: lanes finish tasks and sit at their prompt producing nothing.
# Existing monitoring (systemd, tmux has-session, process alive) all say
# "fine" because the process IS running — it's just not working.
#
# Solution: capture each lane's pane, detect platform-specific idle state,
# track how long each lane has been idle, and remind already-claimed lanes.
# New work assignment is intentionally outside this watchdog; it must flow
# through hapax-methodology-dispatch --launch.
#
# Platforms:
#   Claude:  idle = "❯" prompt visible + no active tool indicators
#   Codex:   idle = "gpt-5.5" model line at bottom, NO "Working (" indicator
#   Gemini:  idle = input box visible (▄/▀ bars) with no streaming output
#
# Runs as systemd oneshot (hapax-lane-idle-watchdog.timer, every 2 min).
# Nudges ALL idle lanes per tick. Cooldown: 120s per lane between kicks.
set -euo pipefail

# bb-dispatch-scheduler: source the idle threshold from the SAME measured tau the
# reaper + coordinator read, so the fleet stops hardcoding divergent stall constants
# (this 600, the reaper's 1800, the coordinator's 900). The env override always wins;
# a missing cache falls back to the prior 600 (10 min).
_idle_threshold_default() {
    local cache="${HAPAX_DISPATCH_SERVICE_TIME_CACHE:-$HOME/.cache/hapax/dispatch-service-time.json}"
    [[ -f "$cache" ]] || { echo 600; return; }
    local repo
    repo="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)"
    [[ -d "$repo/shared" ]] || repo="${HOME}/projects/hapax-council"
    (cd "$repo" 2>/dev/null && python3 -m shared.dispatch_service_time \
        --tau --lineage "" --cache "$cache" 2>/dev/null) || echo 600
}

# ─── Configuration ───────────────────────────────────────────────────────────
IDLE_THRESHOLD_S="${HAPAX_IDLE_THRESHOLD_S:-$(_idle_threshold_default)}"  # measured tau; 600 fallback
COOLDOWN_S="${HAPAX_IDLE_COOLDOWN_S:-120}"              # 2 min between kicks
STATE_DIR="${HAPAX_IDLE_STATE_DIR:-/tmp/hapax-lane-idle-state}"
TASK_ROOT="${HOME}/Documents/Personal/20-projects/hapax-cc-tasks/active"
REQUEST_ROOT="${HOME}/Documents/Personal/20-projects/hapax-requests/active"
NTFY_TOPIC="${HAPAX_NTFY_TOPIC:-hapax}"
NTFY_URL="${HAPAX_NTFY_URL:-http://localhost:8092}"
CLAUDE_SEND="${HOME}/projects/hapax-council/scripts/hapax-claude-send"
CODEX_SEND="${HOME}/projects/hapax-council/scripts/hapax-codex-send"

# Skip alpha (integrator, always has operator) and RTE
SKIP_LANES="${HAPAX_IDLE_SKIP_LANES:-alpha}"

# Lanes that must always be running (operator directive: 4 of each at all times)
REQUIRED_CLAUDE_LANES="${HAPAX_REQUIRED_CLAUDE_LANES:-beta gamma delta epsilon}"
REQUIRED_CODEX_LANES="${HAPAX_REQUIRED_CODEX_LANES:-cx-cpu-bridge cx-effect-drift-current cx-preset-storm cx-visual-bandwidth}"
CLAUDE_LAUNCHER="${HOME}/.local/bin/hapax-claude"
CODEX_LAUNCHER="${HOME}/projects/hapax-council/scripts/hapax-codex"

mkdir -p "$STATE_DIR"
now=$(date +%s)

log() { echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) lane-idle: $*"; }

# ─── L3/L4 SDLC pressure admission ────────────────────────────────────────────
# The respawn FLOOR must yield under CPU pressure. When admission is 'closed'
# this watchdog defers launching/reviving/nudging lanes — skipping a respawn
# only DELAYS it (the cc-task stays claimed/offered; the next 2-min tick
# relaunches once pressure clears), so no work is abandoned. Fail-open: any
# error returns 'open' so the floor never wedges on the gate.
sdlc_admission_state() {
    [[ "${HAPAX_SDLC_PRESSURE_GATE_OFF:-}" == "1" ]] && { echo open; return; }
    local repo state
    repo="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)"
    [[ -d "$repo/shared" ]] || repo="${HOME}/projects/hapax-council"
    state="$(cd "$repo" 2>/dev/null && python3 -m shared.sdlc_pressure_gate --state 2>/dev/null || true)"
    case "$state" in
        open | paced | closed) echo "$state" ;;
        *) echo open ;;
    esac
}
SDLC_ADMISSION="$(sdlc_admission_state)"
if [ "$SDLC_ADMISSION" = "closed" ]; then
    log "sdlc-pressure CLOSED: respawn floor yields this tick (lanes stay as-is; cc-tasks unaffected)"
fi

# ─── RecoveryGovernor admission for the load-injecting relaunch ───────────────
# bb-control-stability: each lane relaunch (~1.5 cores for 60-180s) passes
# through the shared governor (per-target AIMD backoff × global token-bucket ×
# PSI throttle × in-flight concurrency cap) so N stale lanes can no longer fire
# N simultaneous relaunches. In shadow mode the CLI exits 0 (this floor acts as
# today, gated by the fixed cooldown below); under enforce the grant is binding.
# Fail-open: any non-{0,75,2} exit (import error, traceback) is treated as PERMIT
# so the governor can never wedge the respawn floor (NEVER-FREEZE).
_governor_repo() {
    local repo
    repo="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)"
    [[ -d "$repo/shared" ]] || repo="${HOME}/projects/hapax-council"
    echo "$repo"
}
governor_permit() {
    [[ "${HAPAX_RECOVERY_GOVERNOR_OFF:-}" == "1" ]] && return 0
    local target="$1" rc
    (cd "$(_governor_repo)" 2>/dev/null && python3 -m shared.recovery_governor --permit "$target" >/dev/null 2>&1)
    rc=$?
    case "$rc" in
        0) return 0 ;;      # permit
        75 | 2) return 1 ;; # backoff / closed → defer this tick (retried next tick)
        *) return 0 ;;      # error → fail-open PERMIT, never a deny-sink
    esac
}
governor_record() {
    [[ "${HAPAX_RECOVERY_GOVERNOR_OFF:-}" == "1" ]] && return 0
    (cd "$(_governor_repo)" 2>/dev/null && python3 -m shared.recovery_governor --record "$1" "$2" >/dev/null 2>&1) || true
}

# ─── Platform detection functions ────────────────────────────────────────────

# Claude: idle when "❯" prompt visible in last few lines.
# When Claude is actively working, output streams and the prompt scrolls out.
# When idle, ❯ sits in the last 5 lines with status bar below.
# Context-full lanes (showing "/clear to save") are ALSO idle — they finished
# work and need /clear + new task dispatch.
is_claude_idle() {
    local pane="$1"
    local tail5
    tail5=$(echo "$pane" | tail -5)

    # Idle: the ❯ prompt OR ⏵⏵ (bypass-mode prompt) in the last 5 lines
    if echo "$tail5" | grep -qE '❯|⏵⏵'; then
        return 0
    fi

    # Permission prompts in the tail — blocked, not idle-done
    if echo "$tail5" | grep -qE '(Allow|Deny)'; then
        return 1
    fi

    return 1  # prompt not visible, assume working
}

is_claude_context_full() {
    local pane="$1"
    echo "$pane" | tail -10 | grep -q "/clear to save"
}

# Codex: idle when model line visible at bottom, no "Working" indicator
is_codex_idle() {
    local pane="$1"
    # Active: "Working (Xm Ys" or "Working (Xs"
    if echo "$pane" | grep -qE 'Working \([0-9]'; then
        return 1  # actively working
    fi
    # Idle: shows model string at bottom (gpt-5.5/gpt-4.1/o3/etc)
    if echo "$pane" | tail -5 | grep -qE '(gpt-[0-9]|o[0-9]|codex-).*~/projects/'; then
        return 0  # idle at prompt
    fi
    # Also idle if we see the "› " prompt line without Working above it
    if echo "$pane" | tail -10 | grep -qE '^› '; then
        if ! echo "$pane" | grep -qE 'Working \('; then
            return 0
        fi
    fi
    return 1
}

# Gemini: idle when input box bars visible and no streaming
is_gemini_idle() {
    local pane="$1"
    # Active: Gemini streams text without the input box delimiter
    # The input box uses ▄ and ▀ bars as delimiters
    # When idle, we see the model/workspace status bar at the bottom
    if echo "$pane" | tail -5 | grep -qE '(gemini-[0-9]|workspace|/model)'; then
        # Has the status bar visible — check not actively outputting
        # If last line is the status bar or ▀▀ bar, it's idle
        local last_content
        last_content=$(echo "$pane" | tail -3 | head -1)
        if echo "$last_content" | grep -qE '^[▀ ]+$'; then
            return 0  # idle
        fi
        if echo "$last_content" | grep -qE '(workspace|/model|sandbox)'; then
            return 0  # idle
        fi
    fi
    # Gemini at the > prompt with no output flowing
    if echo "$pane" | tail -8 | grep -qE '^ ?> $'; then
        return 0
    fi
    return 1
}

# ─── Quota-wall skip ─────────────────────────────────────────────────────────
# A lane walled until a known future reset is intentionally paused — the headless
# wrapper backs off until the quota frees, so this watchdog must NOT relaunch /
# revive / nudge it in the meantime (that would re-hit the wall every tick).
# Echoes the receipt's resets_at iff walled until a FUTURE time; else returns 1.
quota_walled_until() {
    local role="$1"
    local receipt="$HOME/.cache/hapax/relay/receipts/${role}-quota-wall.yaml"
    [ -f "$receipt" ] || return 1
    local resets_at
    resets_at="$(sed -n 's/^resets_at:[[:space:]]*//p' "$receipt" | head -n1)"
    [ -n "$resets_at" ] && [ "$resets_at" != "unknown" ] || return 1
    local reset_epoch
    reset_epoch="$(date -d "$resets_at" +%s 2>/dev/null)" || return 1
    [ "$reset_epoch" -gt "${now:-$(date +%s)}" ] || return 1
    printf '%s\n' "$resets_at"
}

# ─── Lane discovery ──────────────────────────────────────────────────────────

declare -A LANES  # session_name -> platform
lane_count=0

for session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null | sort); do
    case "$session" in
        hapax-claude-*)
            lane="${session#hapax-claude-}"
            # Skip configured lanes
            for skip in $SKIP_LANES; do
                [ "$lane" = "$skip" ] && continue 2
            done
            LANES["$session"]="claude"
            lane_count=$((lane_count + 1))
            ;;
        hapax-codex-*)
            lane="${session#hapax-codex-}"
            LANES["$session"]="codex"
            lane_count=$((lane_count + 1))
            ;;
        hapax-gemini-*)
            lane="${session#hapax-gemini-}"
            LANES["$session"]="gemini"
            lane_count=$((lane_count + 1))
            ;;
    esac
done

# ─── Ensure required Claude lanes are alive ─────────────────────────────────

launched_lanes=0
revived_lanes=0

# L4: the respawn floor yields under 'closed' — don't re-kick a paused lane.
if [ "$SDLC_ADMISSION" != "closed" ] && [ -x "$CLAUDE_LAUNCHER" ]; then
    for role in $REQUIRED_CLAUDE_LANES; do
        session="hapax-claude-${role}"
        worktree="${HOME}/projects/hapax-council--${role}"

        # Skip a quota-walled lane until its quota frees (no launch/revive thrash).
        if walled_until="$(quota_walled_until "$role")"; then
            log "SKIP $role: quota-walled until $walled_until"
            continue
        fi

        cooldown_file="$STATE_DIR/_lane_launch_${role}.last"
        launch_cooldown=300  # 5 min between launch attempts per lane
        if [ -f "$cooldown_file" ]; then
            last_attempt=$(cat "$cooldown_file")
            elapsed=$((now - last_attempt))
            if [ "$elapsed" -lt "$launch_cooldown" ]; then
                continue
            fi
        fi

        if ! tmux has-session -t "$session" 2>/dev/null; then
            # Session doesn't exist — launch it
            if [ -d "$worktree" ]; then
                if ! governor_permit "lane:$role"; then
                    log "RecoveryGovernor deferred launch of $role (backoff/pressure); retry next tick"
                    continue
                fi
                log "LAUNCHING missing lane: $role"
                echo "$now" > "$cooldown_file"
                launch_err="$STATE_DIR/${session}.launch.err"
                if "$CLAUDE_LAUNCHER" --role "$role" --terminal tmux --readonly >"$launch_err" 2>&1; then
                    launched_lanes=$((launched_lanes + 1))
                    governor_record "lane:$role" ok
                    curl -sf -d "Lane idle watchdog: launched $role (session missing)" \
                        -H "Title: Lane auto-launched" \
                        -H "Priority: default" \
                        -H "Tags: rocket" \
                        "$NTFY_URL/$NTFY_TOPIC" >/dev/null 2>&1 || true
                else
                    governor_record "lane:$role" fail
                    launch_reason="$(tr '\n' ' ' <"$launch_err" 2>/dev/null | head -c 240 || true)"
                    log "FAILED to launch lane $role: ${launch_reason:-unknown launcher failure}"
                fi
                rm -f "$launch_err" 2>/dev/null || true
            else
                log "WARN: worktree missing for $role at $worktree"
            fi
        else
            # Session exists — check if Claude is actually running in it.
            # pane_current_command reports "fish" even when Claude (node) is
            # running as a child process, so also check pane content for
            # Claude's TUI indicators (❯ prompt, bypass permissions bar).
            pane_cmd=$(tmux display-message -t "$session" -p '#{pane_current_command}' 2>/dev/null) || continue
            pane_check=$(tmux capture-pane -t "$session" -p -S -5 2>/dev/null)
            claude_tui=false
            if echo "$pane_check" | grep -qE '(❯|bypass permissions|tokens)'; then
                claude_tui=true
            fi

            case "$pane_cmd" in
                claude|claude-code|node)
                    ;; # running
                *)
                    if [ "$claude_tui" = true ]; then
                        : # Claude runs as node child of fish — TUI visible, not dead
                    elif ! governor_permit "lane:$role"; then
                        log "RecoveryGovernor deferred revive of $role (backoff/pressure); retry next tick"
                    else
                        log "REVIVING dead Claude in $session (pane_cmd=$pane_cmd)"
                        echo "$now" > "$cooldown_file"
                        tmux send-keys -t "$session" "$CLAUDE_LAUNCHER --role $role --readonly" Enter 2>/dev/null || true
                        governor_record "lane:$role" ok
                        revived_lanes=$((revived_lanes + 1))
                        curl -sf -d "Lane idle watchdog: revived $role (Claude had exited, pane was $pane_cmd)" \
                            -H "Title: Lane revived" \
                            -H "Priority: default" \
                            -H "Tags: recycle" \
                            "$NTFY_URL/$NTFY_TOPIC" >/dev/null 2>&1 || true
                    fi
                    ;;
            esac
        fi
    done
fi

# ─── Ensure required Codex lanes are alive ─────────────────────────────────

# L4: the respawn floor yields under 'closed' — don't re-kick a paused lane.
if [ "$SDLC_ADMISSION" != "closed" ] && [ -x "$CODEX_LAUNCHER" ]; then
    for color in $REQUIRED_CODEX_LANES; do
        session="hapax-codex-${color}"
        worktree="${HOME}/projects/hapax-council--${color}"

        cooldown_file="$STATE_DIR/_lane_launch_codex_${color}.last"
        launch_cooldown=300
        if [ -f "$cooldown_file" ]; then
            last_attempt=$(cat "$cooldown_file")
            elapsed=$((now - last_attempt))
            if [ "$elapsed" -lt "$launch_cooldown" ]; then
                continue
            fi
        fi

        if ! tmux has-session -t "$session" 2>/dev/null; then
            if [ -d "$worktree" ]; then
                log "SKIPPING missing Codex lane $color: governed task binding required for auto-launch"
                echo "$now" > "$cooldown_file"
            else
                log "WARN: Codex worktree missing for $color at $worktree"
            fi
        else
            pane_cmd=$(tmux display-message -t "$session" -p '#{pane_current_command}' 2>/dev/null) || continue
            pane_check=$(tmux capture-pane -t "$session" -p -S -5 2>/dev/null)
            codex_tui=false
            if echo "$pane_check" | grep -qE '(Working|gpt-[0-9]|codex-|context left|› )'; then
                codex_tui=true
            fi

            case "$pane_cmd" in
                codex|node)
                    ;;
                *)
                    if [ "$codex_tui" = true ]; then
                        : # Codex runs as node child — TUI visible, not dead
                    else
                        log "SKIPPING dead Codex revive in $session (pane_cmd=$pane_cmd): governed task binding required"
                        echo "$now" > "$cooldown_file"
                    fi
                    ;;
            esac
        fi
    done
fi

if [ "$launched_lanes" -gt 0 ] || [ "$revived_lanes" -gt 0 ]; then
    log "lane maintenance: launched=$launched_lanes revived=$revived_lanes"
fi

if [ "$lane_count" -eq 0 ]; then
    log "no active lanes found after maintenance pass"
    exit 0
fi

# ─── Idle detection pass ─────────────────────────────────────────────────────

declare -A IDLE_LANES=()   # session_name -> idle_duration_s
declare -A CTX_FULL=()     # session_name -> 1 if context-full (needs /clear before dispatch)
active_count=0
idle_observed_count=0
idle_count=0

for session in "${!LANES[@]}"; do
    platform="${LANES[$session]}"

    # Capture pane content
    pane_text=$(tmux capture-pane -t "$session" -p -S -30 2>/dev/null) || continue

    # Check if idle based on platform
    is_idle=false
    case "$platform" in
        claude)
            is_claude_idle "$pane_text" && is_idle=true
            if [ "$is_idle" = true ] && is_claude_context_full "$pane_text"; then
                CTX_FULL["$session"]=1
            fi
            ;;
        codex)   is_codex_idle "$pane_text"  && is_idle=true ;;
        gemini)  is_gemini_idle "$pane_text" && is_idle=true ;;
    esac

    state_file="$STATE_DIR/${session}.idle_since"

    if [ "$is_idle" = true ]; then
        idle_observed_count=$((idle_observed_count + 1))
        # Record when we first saw this lane idle
        if [ -f "$state_file" ]; then
            idle_since=$(cat "$state_file")
        else
            echo "$now" > "$state_file"
            idle_since=$now
        fi
        idle_duration=$((now - idle_since))
        if [ "$idle_duration" -ge "$IDLE_THRESHOLD_S" ]; then
            IDLE_LANES["$session"]=$idle_duration
            idle_count=$((idle_count + 1))
        fi
    else
        # Lane is active — clear idle tracking
        rm -f "$state_file" 2>/dev/null
        active_count=$((active_count + 1))
    fi
done

idle_below_threshold=$((idle_observed_count - idle_count))
log "scan: $lane_count lanes, $active_count active, $idle_below_threshold idle below threshold, $idle_count idle past threshold"

if [ "$idle_count" -eq 0 ]; then
    exit 0
fi

# ─── Nudge ALL idle lanes past cooldown ──────────────────────────────────────

find_claimed_task() {
    local assignee="$1"
    if [ -d "$TASK_ROOT" ]; then
        local match
        match=$(grep -rl "^assigned_to: ${assignee}$" "$TASK_ROOT/" 2>/dev/null | head -1)
        if [ -n "$match" ]; then
            local task_id status
            task_id=$(basename "$match" .md)
            status=$(grep -m1 "^status:" "$match" 2>/dev/null | awk '{print $2}')
            if [ "$status" = "claimed" ] || [ "$status" = "in_progress" ]; then
                echo "$task_id"
                return 0
            fi
        fi
    fi
    return 1
}

dispatched=0
skipped_cooldown=0

# L4: under 'closed' the floor yields — defer nudges (don't re-kick paused lanes).
if [ "$SDLC_ADMISSION" = "closed" ]; then
    log "sdlc-pressure closed: deferring idle nudges for $idle_count lane(s) this tick"
else
for session in "${!IDLE_LANES[@]}"; do
    idle_s="${IDLE_LANES[$session]}"

    cooldown_file="$STATE_DIR/${session}.last_kick"
    if [ -f "$cooldown_file" ]; then
        last_kick=$(cat "$cooldown_file")
        elapsed=$((now - last_kick))
        if [ "$elapsed" -lt "$COOLDOWN_S" ]; then
            skipped_cooldown=$((skipped_cooldown + 1))
            continue
        fi
    fi

    platform="${LANES[$session]}"
    case "$session" in
        hapax-claude-*)  lane="${session#hapax-claude-}" ;;
        hapax-codex-*)   lane="${session#hapax-codex-}" ;;
        hapax-gemini-*)  lane="${session#hapax-gemini-}" ;;
    esac

    dispatch_msg=""
    claimed=$(find_claimed_task "$lane" 2>/dev/null || true)
    dispatch_target=""
    if [ -n "$claimed" ]; then
        dispatch_msg="IDLE WATCHDOG: You have been idle for $((idle_s/60))m with an active task: $claimed. Resume work immediately. Ship a PR and cc-close --pr N after merge."
        dispatch_target="$claimed"
    else
        log "IDLE without claim for $lane — awaiting governed dispatch"
        dispatch_msg="IDLE WATCHDOG: You have been idle for $((idle_s/60))m with no active claimed task. Await governed dispatch; do not self-select queue work. Required path: scripts/hapax-methodology-dispatch --task <id> --lane ${lane} --platform ${platform} --mode <mode>."
        dispatch_target="await-governed-dispatch"
    fi

    # Context-full Claude lanes may need /clear before reminding an already
    # claimed lane. Unclaimed lanes are not prepared for new work here.
    if [ -n "$claimed" ] && [ "${CTX_FULL[$session]:-}" = "1" ] && [ "$platform" = "claude" ]; then
        log "CLEARING context-full $session before dispatch"
        tmux send-keys -t "$session" "/clear" Enter 2>/dev/null
        sleep 5
    fi

    send_success=false
    case "$platform" in
        claude)
            if [ -x "$CLAUDE_SEND" ]; then
                "$CLAUDE_SEND" --session "$lane" -- "$dispatch_msg" 2>/dev/null && send_success=true
            fi
            if [ "$send_success" = false ]; then
                tmux send-keys -t "$session" "$dispatch_msg" Enter 2>/dev/null && send_success=true
            fi
            ;;
        codex)
            if [ -x "$CODEX_SEND" ]; then
                "$CODEX_SEND" --session "$lane" --require-ack -- "$dispatch_msg" 2>/dev/null && send_success=true
            fi
            ;;
        gemini)
            tmux send-keys -t "$session" "$dispatch_msg" Enter 2>/dev/null && send_success=true
            ;;
    esac

    echo "$now" > "$STATE_DIR/${session}.last_kick"

    if [ "$send_success" = true ]; then
        log "DISPATCHED $session ($platform/$lane): idle ${idle_s}s -> $dispatch_target"
        rm -f "$STATE_DIR/${session}.idle_since" 2>/dev/null
        dispatched=$((dispatched + 1))
    else
        log "FAILED to dispatch $session ($platform/$lane): idle ${idle_s}s"
        curl -sf -d "Lane idle watchdog: failed to dispatch $lane ($platform) after ${idle_s}s idle" \
            -H "Title: Lane dispatch failure" \
            -H "Priority: high" \
            -H "Tags: warning" \
            "$NTFY_URL/$NTFY_TOPIC" >/dev/null 2>&1 || true
    fi
done
fi

if [ "$dispatched" -eq 0 ] && [ "$skipped_cooldown" -gt 0 ]; then
    log "all $idle_count idle lanes in cooldown"
fi

log "dispatched $dispatched of $idle_count idle lanes"

# ─── Summary alert if many lanes idle ────────────────────────────────────────

if [ "$idle_count" -ge 3 ]; then
    idle_summary=""
    for session in "${!IDLE_LANES[@]}"; do
        idle_s="${IDLE_LANES[$session]}"
        idle_summary+="$session(${idle_s}s) "
    done
    log "WARNING: $idle_count lanes idle past threshold: $idle_summary"
    curl -sf -d "Lane idle watchdog: $idle_count lanes idle — $idle_summary" \
        -H "Title: Multiple lanes idle" \
        -H "Priority: high" \
        -H "Tags: warning,robot" \
        "$NTFY_URL/$NTFY_TOPIC" >/dev/null 2>&1 || true
fi
