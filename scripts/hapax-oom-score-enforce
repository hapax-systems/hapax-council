#!/usr/bin/env bash
# Root-side live OOM score enforcer for the P0 podium containment package.
set -euo pipefail

TARGET_USER="${HAPAX_OOM_TARGET_USER:-hapax}"
TARGET_UID="${HAPAX_OOM_TARGET_UID:-$(id -u "$TARGET_USER")}"
SYSTEMCTL="${HAPAX_OOM_SYSTEMCTL:-systemctl}"
PROC_ROOT="${HAPAX_OOM_PROC_ROOT:-/proc}"
CGROUP_ROOT="${HAPAX_OOM_CGROUP_ROOT:-/sys/fs/cgroup}"

usage() {
    cat <<'USAGE'
usage: hapax-oom-score-enforce --apply

Writes live /proc oom_score_adj values that unprivileged user units cannot
lower by themselves after user@1000.service is made killable.
USAGE
}

if [ "${1:-}" != "--apply" ]; then
    usage >&2
    exit 2
fi

run_user_systemctl() {
    if [ -n "${HAPAX_OOM_USER_SYSTEMCTL:-}" ]; then
        # shellcheck disable=SC2086
        $HAPAX_OOM_USER_SYSTEMCTL "$@"
    elif [ "$(id -u)" = "$TARGET_UID" ]; then
        "$SYSTEMCTL" --user "$@"
    elif [ "$(id -u)" = "0" ]; then
        runuser -u "$TARGET_USER" -- env XDG_RUNTIME_DIR="/run/user/$TARGET_UID" "$SYSTEMCTL" --user "$@"
    else
        XDG_RUNTIME_DIR="/run/user/$TARGET_UID" "$SYSTEMCTL" --user "$@"
    fi
}

write_oom_score() {
    local pid score path current
    pid="$1"
    score="$2"
    path="$PROC_ROOT/$pid/oom_score_adj"
    [ -e "$path" ] || return 0
    current="$(cat "$path" 2>/dev/null || true)"
    [ "$current" = "$score" ] && return 0
    { printf '%s\n' "$score" > "$path"; } 2>/dev/null || {
        [ ! -e "$path" ] && return 0
        return 1
    }
    printf 'changed\n'
}

pid_matches_unit() {
    local pid="$1" unit="$2" cgroup="$PROC_ROOT/$pid/cgroup"
    [ -r "$cgroup" ] || return 0
    grep -Fq "$unit" "$cgroup"
}

write_oom_score_for_unit() {
    local pid="$1" score="$2" unit="$3"
    if ! pid_matches_unit "$pid" "$unit"; then
        echo "warn: refusing oom_score_adj write for $unit pid=$pid because /proc cgroup no longer matches; next action: run scripts/hapax-oom-policy-audit --json and rerun scripts/install-p0-oom-containment --install --verify-live" >&2
        return 0
    fi
    write_oom_score "$pid" "$score"
}

system_main_pid() {
    local unit="$1" pid
    pid="$("$SYSTEMCTL" show "$unit" -p MainPID --value 2>/dev/null || true)"
    if [[ "$pid" =~ ^[0-9]+$ ]] && [ "$pid" -gt 0 ]; then
        printf '%s\n' "$pid"
    fi
    return 0
}

user_main_pid() {
    local unit="$1" pid
    pid="$(run_user_systemctl show "$unit" -p MainPID --value 2>/dev/null || true)"
    if [[ "$pid" =~ ^[0-9]+$ ]] && [ "$pid" -gt 0 ]; then
        printf '%s\n' "$pid"
    fi
    return 0
}

user_control_group() {
    local unit="$1"
    run_user_systemctl show "$unit" -p ControlGroup --value 2>/dev/null || true
}

cgroup_pids() {
    local cgroup="$1" dir
    [ -n "$cgroup" ] || return 0
    dir="$CGROUP_ROOT/${cgroup#/}"
    [ -d "$dir" ] || return 0
    find "$dir" -name cgroup.procs -type f -print 2>/dev/null |
        while IFS= read -r procs; do
            sed -n '/^[0-9][0-9]*$/p' "$procs" 2>/dev/null || true
        done | sort -u
}

user_unit_pids() {
    local unit="$1" cgroup pid
    cgroup="$(user_control_group "$unit")"
    cgroup_pids "$cgroup"
    pid="$(user_main_pid "$unit")"
    [ -n "$pid" ] && printf '%s\n' "$pid"
}

apply_unit_score() {
    local unit="$1" score="$2" pid changed
    local -a pids
    mapfile -t pids < <(user_unit_pids "$unit" | sort -u)
    [ "${#pids[@]}" -gt 0 ] || return 0
    for pid in "${pids[@]}"; do
        if changed="$(write_oom_score_for_unit "$pid" "$score" "$unit")"; then
            [ -z "$changed" ] || echo "user-unit $unit pid=$pid oom_score_adj=$score"
        else
            echo "warn: failed to set oom_score_adj for $unit pid=$pid; next action: run scripts/hapax-oom-policy-audit --json and rerun scripts/install-p0-oom-containment --install --verify-live" >&2
        fi
    done
}

user_pid="$(system_main_pid "user@$TARGET_UID.service")"
if [ -n "$user_pid" ]; then
    if changed="$(write_oom_score_for_unit "$user_pid" 100 "user@$TARGET_UID.service")"; then
        [ -z "$changed" ] || echo "system user@$TARGET_UID.service pid=$user_pid oom_score_adj=100"
    else
        echo "warn: failed to set oom_score_adj for user@$TARGET_UID.service pid=$user_pid; next action: run scripts/hapax-oom-policy-audit --json and rerun scripts/install-p0-oom-containment --install --verify-live" >&2
    fi
fi

apply_unit_score pipewire.service -900
apply_unit_score pipewire-pulse.service -900
apply_unit_score wireplumber.service -900
apply_unit_score hapax-daimonion.service -500
apply_unit_score studio-compositor.service -800
apply_unit_score hapax-imagination.service -800
