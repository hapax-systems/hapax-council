#!/usr/bin/env python3
"""Emit support-only HKP context for a cc-task's dependency neighbourhood.

Reads the live cache `sdlc` bundle and prints the support-only context (banner +
allow-listed fields + redaction). Fail-open: prints nothing if HKP is
unavailable. Consumed by the dispatch/handoff flow as an optional, never-blocking
augmentation; HKP is support-non-authoritative.
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from shared.hkp_prompt_context import context_for_task  # noqa: E402


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Support-only HKP context for a cc-task.")
    parser.add_argument("task_id")
    args = parser.parse_args(argv)
    ctx = context_for_task(args.task_id)
    if ctx:
        print(ctx)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
