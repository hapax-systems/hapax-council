#!/usr/bin/env bash
# Launch Codex as a first-class Hapax coding interface.

set -euo pipefail

COUNCIL_DIR="${HAPAX_COUNCIL_DIR:-$HOME/projects/hapax-council}"
ROLE_HELPER="$COUNCIL_DIR/hooks/scripts/agent-role.sh"
if [ -f "$ROLE_HELPER" ]; then
  # shellcheck source=../hooks/scripts/agent-role.sh
  # shellcheck disable=SC1091
  . "$ROLE_HELPER"
fi

usage() {
  cat <<'EOF'
usage: hapax-codex [--session cx-color] [--slot alpha|beta|delta|epsilon] [--cd DIR]
                   [--task TASK_ID] [--bootstrap FILE] [--task-gate]
                   [--terminal none|tmux|foot] [--force] [--no-claim]
                   [--] [codex args...]

Defaults:
  - no approval gates: Codex runs with --dangerously-bypass-approvals-and-sandbox
  - Codex thread identity defaults to CODEX_THREAD_NAME or cx-blue
  - worktree slot is inferred from cwd when --slot is omitted
  - worktree selected from the slot when --cd is omitted
  - terminal is none: exec Codex in the current terminal
EOF
}

if ! declare -F hapax_agent_is_codex_name >/dev/null 2>&1; then
  hapax_agent_is_codex_name() {
    [[ "${1:-}" =~ ^cx-[a-z][a-z-]*$ ]]
  }
fi

if ! declare -F hapax_agent_worktree_role_or_default >/dev/null 2>&1; then
  hapax_agent_worktree_role_or_default() {
    printf '%s\n' "${1:-roleless}"
  }
fi

is_codex_subcommand() {
  case "${1:-}" in
    exec|e|review|login|logout|mcp|plugin|mcp-server|app-server|completion|sandbox|debug|apply|a|resume|fork|cloud|exec-server|features|help)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

first_existing_dir() {
  local path
  for path in "$@"; do
    if [ -d "$path" ]; then
      printf '%s\n' "$path"
      return 0
    fi
  done
  return 1
}

slugify() {
  printf '%s\n' "$1" | tr -cs 'A-Za-z0-9_.-' '-' | sed 's/^-//; s/-$//'
}

safe_path_component() {
  local component
  component="$(printf '%s\n' "$1" | tr -cs 'A-Za-z0-9_-' '-' | sed 's/^-//; s/-$//' | cut -c1-96)"
  if [ -z "$component" ]; then
    component="session"
  fi
  printf '%s\n' "$component"
}

session_id_is_safe() {
  local sid="${1:-}" tail=""
  [ "${#sid}" -ge 8 ] && [ "${#sid}" -le 128 ] || return 1
  case "$sid" in
    [A-Za-z0-9]*) ;;
    *) return 1 ;;
  esac
  case "$sid" in
    *[!A-Za-z0-9._-]*) return 1 ;;
  esac
  case "$sid" in
    *[!0-9]*) ;;
    *) return 1 ;;
  esac
  tail="${sid##*-}"
  if [[ "$tail" =~ ^[0-9]{1,7}$ ]]; then
    return 1
  fi
  return 0
}

mint_session_uuid() {
  cat /proc/sys/kernel/random/uuid 2>/dev/null \
    || uuidgen 2>/dev/null \
    || python3 -c 'import uuid; print(uuid.uuid4())' 2>/dev/null \
    || printf '%s-%s-p%sx\n' "$(safe_path_component "$SESSION")" "$(date -u +%Y%m%dT%H%M%SZ)" "$$"
}

normalize_session_uuid() {
  local raw="${1:-}" minted=""
  if [ -n "$raw" ] && session_id_is_safe "$raw"; then
    printf '%s\n' "$raw"
    return 0
  fi
  minted="$(mint_session_uuid)"
  if [ -n "$raw" ]; then
    echo "hapax-codex: ignoring unsafe HAPAX_SESSION_ID; minted safe session id for coordination paths" >&2
  fi
  printf '%s\n' "$minted"
}

relay_retired() {
  # Delegate to the single-source predicate (shared/relay_lifecycle.lane_is_retired)
  # so the launcher agrees with the dispatch gate + the coordinator: one
  # broad-9 vocabulary, freshest-of-candidates resolution, multi-doc
  # latest-wins. The legacy awk (relay_current_values/relay_value_is_retired
  # below) over-refused SUPERSEDED/CLOSED lane relays (task/claim states that
  # leaked); it is now dead code retained only for a minimal diff — remove later.
  # FAIL-OPEN on tooling error (python missing / import fail): the gate at
  # coord_dispatch.run_atomic_dispatch_launch is authoritative on the governed
  # path, so a fail-open launcher only ever sees gate-allowed lanes.
  local relay_name="$1"
  local council_root
  local relay_dir="${HAPAX_RELAY_DIR:-$HOME/.cache/hapax/relay}"
  council_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  PYTHONPATH="$council_root${PYTHONPATH:+:$PYTHONPATH}" python3 -c '
import sys
from pathlib import Path
from shared.relay_lifecycle import lane_is_retired
sys.exit(0 if lane_is_retired(sys.argv[1], relay_dir=Path(sys.argv[2])) else 1)
' "$relay_name" "$relay_dir" 2>/dev/null
  case $? in
    0) return 0 ;;
    *) return 1 ;;  # 1 = not retired; any other = tooling error -> fail-open
  esac
}

relay_current_values() {
  local relay_file="$1"
  awk '
    BEGIN { in_session_status = 0 }

    in_session_status {
      if ($0 ~ /^[[:space:]]*$/) {
        next
      }
      if ($0 !~ /^[[:space:]]+/) {
        in_session_status = 0
      } else {
        value = $0
        sub(/^[[:space:]]+/, "", value)
        print value
        in_session_status = 0
        next
      }
    }

    /^(status|state|relay_status|session_state|role):[[:space:]]*/ {
      value = $0
      sub(/^[^:]+:[[:space:]]*/, "", value)
      if (value !~ /^[|>]/) {
        print value
      }
      next
    }

    /^session_status:[[:space:]]*/ {
      value = $0
      sub(/^session_status:[[:space:]]*/, "", value)
      if (value ~ /^[|>]/) {
        in_session_status = 1
        next
      }
      print value
      next
    }
  ' "$relay_file"
}

relay_value_is_retired() {
  local value="$1"
  local normalized first_word
  normalized="$(printf '%s' "$value" | sed "s/^[[:space:]\"']*//; s/[[:space:]\"']*$//" | tr '[:lower:]' '[:upper:]')"
  first_word="${normalized%%[[:space:]]*}"
  case "$first_word" in
    # NOTE: the broad ANTIGRAVITY* glob stays out because arbitrary relay prose is
    # not a retirement marker. The exact ANTIGRAVITY_TAKEOVER terminal marker is
    # retained only to parse older relay wind-down files after the live
    # Antigrav/agy worker was excised.
    RETIRED*|SUPERSEDED*|CLOSED*|IDLE_WOUND_DOWN*|WIND_DOWN_IDLE*|WOUND_DOWN*|WIND_DOWN*|WINDING_DOWN*|ANTIGRAVITY_TAKEOVER)
      return 0
      ;;
  esac
  case "$normalized" in
    RETIRED*|SUPERSEDED*|CLOSED*|IDLE_WOUND_DOWN*|WIND_DOWN_IDLE*|WOUND_DOWN*|WIND_DOWN*|WINDING_DOWN*|ANTIGRAVITY_TAKEOVER)
      return 0
      ;;
  esac
  return 1
}

session_is_protected() {
  local session="$1"
  local protection_file="${HAPAX_SESSION_PROTECTION_FILE:-$HOME/.cache/hapax/relay/session-protection.md}"

  [ -f "$protection_file" ] || return 1
  awk -v session="$session" '
    {
      line = tolower($0)
      needle = "`" session "`"
      if (index($0, needle) && line ~ /protected/) {
        found = 1
      }
    }
    END {
      exit(found ? 0 : 1)
    }
  ' "$protection_file"
}

live_codex_session_exists() {
  local session="$1"
  local class="hapax-codex-$session"
  local tmux_name="hapax-codex-$session"

  if command -v hyprctl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    if hyprctl clients -j 2>/dev/null \
      | jq -e --arg class "$class" 'any(.[]?; .class == $class)' >/dev/null 2>&1; then
      return 0
    fi
  fi

  if command -v tmux >/dev/null 2>&1 && tmux has-session -t "$tmux_name" 2>/dev/null; then
    return 0
  fi

  if command -v pgrep >/dev/null 2>&1; then
    if pgrep -af -- "$class|run-[0-9TZ]+-$session\\.sh" >/dev/null 2>&1; then
      return 0
    fi
  fi

  return 1
}

assert_protected_terminal_launch_allowed() {
  local session="$1"
  local terminal="$2"

  [ "$terminal" != "none" ] || return 0
  [ "${HAPAX_CODEX_PROTECTED_SESSION_OVERRIDE:-0}" != "1" ] || return 0
  session_is_protected "$session" || return 0
  live_codex_session_exists "$session" || return 0

  cat >&2 <<EOF
hapax-codex: refusing to launch protected live session '$session' because it already appears active.
  protection: ${HAPAX_SESSION_PROTECTION_FILE:-$HOME/.cache/hapax/relay/session-protection.md}
  override only with an explicit operator directive and HAPAX_CODEX_PROTECTED_SESSION_OVERRIDE=1
EOF
  exit 12
}

foot_color_theme_for_current_mode() {
  local mode
  mode="$(cat "$HOME/.cache/hapax/working-mode" 2>/dev/null || printf '%s\n' rnd)"
  case "$mode" in
    research)
      printf '%s\n' light
      ;;
    rnd|fortress|*)
      printf '%s\n' dark
      ;;
  esac
}

active_hyprland_workspace_name() {
  if [ -n "${HAPAX_CODEX_FOOT_WORKSPACE:-}" ]; then
    printf '%s\n' "$HAPAX_CODEX_FOOT_WORKSPACE"
    return 0
  fi
  command -v hyprctl >/dev/null 2>&1 || return 1
  command -v jq >/dev/null 2>&1 || return 1
  hyprctl activeworkspace -j 2>/dev/null | jq -r '.name // empty' 2>/dev/null | sed -n '1p'
}

move_foot_window_to_workspace() {
  local session="$1"
  local workspace="$2"
  [ -n "$workspace" ] || return 0
  command -v hyprctl >/dev/null 2>&1 || return 0
  command -v jq >/dev/null 2>&1 || return 0

  local class="hapax-codex-$session"
  local address=""
  local _
  for _ in {1..20}; do
    address="$(hyprctl clients -j 2>/dev/null | jq -r --arg class "$class" '[.[] | select(.class == $class) | .address][0] // empty' 2>/dev/null || true)"
    if [ -n "$address" ]; then
      hyprctl dispatch movetoworkspacesilent "name:$workspace,address:$address" >/dev/null 2>&1 || true
      return 0
    fi
    sleep 0.1
  done
}

codex_default_worktree_path() {
  local session="$1"
  local slot="$2"
  local root="${HAPAX_CODEX_WORKTREE_ROOT:-$HOME/projects}"
  local primary_session="${HAPAX_CODEX_PRIMARY_SESSION:-cx-red}"

  if [ "$slot" = "alpha" ] && [ "$session" = "$primary_session" ]; then
    printf '%s\n' "$HOME/projects/hapax-council"
    return 0
  fi

  printf '%s\n' "$root/hapax-council--$session"
}

ensure_codex_worktree() {
  local workdir="$1"
  local session="$2"
  local base_ref="${HAPAX_CODEX_WORKTREE_BASE:-main}"
  local branch_prefix="${HAPAX_CODEX_BRANCH_PREFIX:-codex}"
  local branch="$branch_prefix/$session"

  [ "${HAPAX_CODEX_CREATE_WORKTREE:-1}" = "1" ] || return 1
  [ ! -e "$workdir" ] || return 1
  git -C "$COUNCIL_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 1
  mkdir -p "$(dirname "$workdir")"

  if ! git -C "$COUNCIL_DIR" rev-parse --verify --quiet "$base_ref" >/dev/null; then
    base_ref="HEAD"
  fi

  if git -C "$COUNCIL_DIR" show-ref --verify --quiet "refs/heads/$branch"; then
    git -C "$COUNCIL_DIR" worktree add "$workdir" "$branch" >/dev/null
  else
    git -C "$COUNCIL_DIR" worktree add -b "$branch" "$workdir" "$base_ref" >/dev/null
  fi
}

pass_first_line() {
  local name="$1"
  command -v pass >/dev/null 2>&1 || return 1
  pass show "$name" 2>/dev/null | sed -n '1p'
}

load_first_available_pass_secret() {
  local env_name="$1"
  shift
  [ -n "${!env_name:-}" ] && return 0
  local entry value
  for entry in "$@"; do
    value="$(pass_first_line "$entry" || true)"
    if [ -n "$value" ]; then
      export "$env_name=$value"
      return 0
    fi
  done
  return 1
}

load_header_from_claude_mcp() {
  local env_name="$1"
  local server="$2"
  local header_name="$3"
  [ -n "${!env_name:-}" ] && return 0
  [ -r "$HOME/.claude.json" ] || return 1
  command -v jq >/dev/null 2>&1 || return 1
  local value
  value="$(jq -r --arg server "$server" --arg header "$header_name" '.mcpServers[$server].headers[$header] // empty' "$HOME/.claude.json" 2>/dev/null || true)"
  if [ -n "$value" ]; then
    export "$env_name=$value"
    return 0
  fi
  return 1
}

dispatch_host_is_local() {
  local host="${1:-}" short="" fqdn=""
  [ -z "$host" ] && return 0
  case "$host" in
    local|localhost|127.0.0.1|::1)
      return 0
      ;;
  esac
  short="$(hostname -s 2>/dev/null || hostname 2>/dev/null || true)"
  fqdn="$(hostname -f 2>/dev/null || true)"
  [ -n "$short" ] && [ "$host" = "$short" ] && return 0
  [ -n "$fqdn" ] && [ "$host" = "$fqdn" ] && return 0
  return 1
}

remote_python_command() {
  local payload="$1" code="$2"
  local code_b64="" bash_script="" quoted_script="" quoted_payload="" quoted_code=""
  code_b64="$(printf '%s' "$code" | python3 -c 'import base64,sys; print(base64.b64encode(sys.stdin.buffer.read()).decode())')"
  # shellcheck disable=SC2016
  bash_script='export HAPAX_REMOTE_PAYLOAD="$1"; export HAPAX_REMOTE_CODE="$2"; exec python3 -c "import base64,os; exec(base64.b64decode(os.environ[\"HAPAX_REMOTE_CODE\"]))"'
  quoted_script="${bash_script//\'/\'\\\'\'}"
  quoted_payload="${payload//\'/\'\\\'\'}"
  quoted_code="${code_b64//\'/\'\\\'\'}"
  printf "bash -c '%s' bash '%s' '%s'" "$quoted_script" "$quoted_payload" "$quoted_code"
}

strip_inherited_codex_access_token() {
  if [ -n "${CODEX_ACCESS_TOKEN:-}" ]; then
    echo "hapax-codex: ignoring inherited CODEX_ACCESS_TOKEN; governed Codex lanes use saved ChatGPT auth on the dispatch host" >&2
    unset CODEX_ACCESS_TOKEN
  fi
  if [ -n "${CODEX_HOME:-}" ]; then
    echo "hapax-codex: ignoring inherited CODEX_HOME; governed Codex lanes use the dispatch host default saved ChatGPT auth cache" >&2
    unset CODEX_HOME
  fi
  if [ -n "${CODEX_API_KEY:-}" ]; then
    echo "hapax-codex: ignoring inherited CODEX_API_KEY; governed Codex lanes must not use API-key auth" >&2
    unset CODEX_API_KEY
  fi
  if [ -n "${OPENAI_API_KEY:-}" ]; then
    echo "hapax-codex: ignoring inherited OPENAI_API_KEY; governed Codex lanes must not use API-key auth" >&2
    unset OPENAI_API_KEY
  fi
  return 0
}

codex_exec_auth_sentinel_observed() {
  local output_file="$1"
  python3 - "$output_file" <<'PYEOF'
import json
import sys
from pathlib import Path

sentinel = "HAPAX_CODEX_EXEC_AUTH_OK"


def assistant_content_text(content):
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        pieces = []
        for item in content:
            if isinstance(item, dict):
                text = item.get("text")
                if isinstance(text, str):
                    pieces.append(text)
        return "".join(pieces)
    return ""


def event_text(event):
    if not isinstance(event, dict):
        return ""
    if event.get("type") == "item.completed":
        item = event.get("item")
        if isinstance(item, dict) and item.get("type") == "agent_message":
            text = item.get("text")
            return text if isinstance(text, str) else ""
    if event.get("type") == "response.output_text.done":
        text = event.get("text")
        return text if isinstance(text, str) else ""
    if event.get("role") == "assistant":
        return assistant_content_text(event.get("content"))
    message = event.get("message")
    if isinstance(message, dict) and message.get("role") == "assistant":
        return assistant_content_text(message.get("content"))
    return ""


stdout = Path(sys.argv[1]).read_text(encoding="utf-8", errors="replace")
for line in stdout.splitlines():
    try:
        event = json.loads(line)
    except json.JSONDecodeError:
        continue
    if event_text(event).strip() == sentinel:
        raise SystemExit(0)
raise SystemExit(1)
PYEOF
}

prove_local_codex_exec_auth() {
  local codex_bin="$1" output_file="" error_file="" rc=0 timeout_s="" auth_output="" auth_error=""
  timeout_s="${HAPAX_CODEX_EXEC_AUTH_TIMEOUT_SECONDS:-30}"
  if ! python3 - "$timeout_s" <<'PYEOF' >/dev/null 2>&1
import math
import sys

value = float(sys.argv[1])
if not math.isfinite(value) or value <= 0:
    raise ValueError("timeout must be positive and finite")
PYEOF
  then
    echo "hapax-codex: invalid HAPAX_CODEX_EXEC_AUTH_TIMEOUT_SECONDS='$timeout_s'; using 30s for the saved-login auth witness" >&2
    timeout_s="30"
  fi
  output_file="$(mktemp "${TMPDIR:-/tmp}/hapax-codex-exec-auth.XXXXXX")" || {
    echo "hapax-codex: failed to create temporary Codex auth witness file; next action: verify TMPDIR or /tmp permissions before retrying" >&2
    exit 78
  }
  error_file="$(mktemp "${TMPDIR:-/tmp}/hapax-codex-exec-auth-err.XXXXXX")" || {
    rm -f "$output_file"
    echo "hapax-codex: failed to create temporary Codex auth witness file; next action: verify TMPDIR or /tmp permissions before retrying" >&2
    exit 78
  }
  timeout "${timeout_s}s" env -i \
    ALL_PROXY="${ALL_PROXY:-}" \
    HOME="$HOME" \
    HTTP_PROXY="${HTTP_PROXY:-}" \
    HTTPS_PROXY="${HTTPS_PROXY:-}" \
    LANG="${LANG:-C}" \
    LC_ALL="${LC_ALL:-}" \
    NO_COLOR=1 \
    NO_PROXY="${NO_PROXY:-}" \
    PATH="$PATH" \
    REQUESTS_CA_BUNDLE="${REQUESTS_CA_BUNDLE:-}" \
    SSL_CERT_FILE="${SSL_CERT_FILE:-}" \
    "$codex_bin" exec \
      --ephemeral \
      --skip-git-repo-check \
      --ignore-rules \
      --sandbox read-only \
      --json \
      --cd "$WORKDIR" \
      "Reply exactly: HAPAX_CODEX_EXEC_AUTH_OK" \
      >"$output_file" 2>"$error_file" || rc=$?
  if [ "$rc" -ne 0 ]; then
    auth_output="$(cat "$output_file" "$error_file" 2>/dev/null || true)"
    auth_output_lc="${auth_output,,}"
    auth_error="codex_saved_auth_exec_failed:rc=$rc"
    case "$auth_output_lc" in
      *refresh_token_invalidated*)
        auth_error="codex_saved_auth_refresh_token_invalidated"
        ;;
      *token_invalidated*)
        auth_error="codex_saved_auth_token_invalidated"
        ;;
      *"login required"*|*"required to log in"*|*"please log in"*|*"not logged in"*)
        auth_error="codex_saved_auth_login_required"
        ;;
    esac
    echo "hapax-codex: saved Codex auth was rejected by codex exec ($auth_error; rc=$rc); next action: repair saved Codex login on the dispatch host via codex login or the documented auth-cache transfer fallback, then retry governed dispatch" >&2
    sed -n '1,4p' "$error_file" >&2 || true
    rm -f "$output_file" "$error_file"
    exit 78
  fi
  if ! codex_exec_auth_sentinel_observed "$output_file"; then
    echo "hapax-codex: codex exec auth witness did not return the expected sentinel; next action: re-run the Codex auth receipt probe before dispatching Codex lanes" >&2
    rm -f "$output_file" "$error_file"
    exit 78
  fi
  rm -f "$output_file" "$error_file"
}

remote_preflight_payload_b64() {
  python3 - "$WORKDIR" "$COUNCIL_DIR" "$HOME/projects/hapax-mcp" <<'PYEOF'
import base64
import json
import os
import sys

workdir, council_dir, mcp_dir = sys.argv[1:4]
payload = {
    "workdir": workdir,
    "required_dirs": [workdir, council_dir, mcp_dir],
    "executables": [
        f"{council_dir}/scripts/hapax-codex",
        f"{council_dir}/hooks/scripts/codex-hook-adapter.sh",
    ],
    "binaries": ["python3", "codex"],
    "codex_bin_path": os.environ.get("HAPAX_CODEX_BIN_PATH", ""),
    "npm_config_prefix": os.environ.get("NPM_CONFIG_PREFIX", ""),
    "codex_exec_auth_timeout": os.environ.get("HAPAX_CODEX_EXEC_AUTH_TIMEOUT_SECONDS", "30"),
}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

remote_exec_payload_b64() {
  local proof_file="$1"
  shift
  python3 - "$WORKDIR" "$proof_file" "${DISPATCH_HOST_REQUESTED:-}" "$LOGOS_BASE_URL" \
    "$COCKPIT_BASE_URL" "$SESSION" "${TASK_ID:-}" "${TMUX_NAME:-}" "$@" <<'PYEOF'
import base64
import json
import os
import sys

workdir, proof_file, requested_host, logos_url, cockpit_url, session, task_id, tmux_name = sys.argv[1:9]
argv = sys.argv[9:]
env = {
    "LOGOS_BASE_URL": logos_url,
    "COCKPIT_BASE_URL": cockpit_url,
    "HAPAX_DISPATCH_HOST": "local",
    "HAPAX_DISPATCH_REQUESTED_HOST": requested_host,
    "HAPAX_DISPATCH_LOGOS_URL": logos_url,
    "HAPAX_DISPATCH_PROOF_FILE": proof_file,
    "HAPAX_DISPATCH_REMOTE_INNER": "1",
    "HAPAX_AGENT_INTERFACE": "codex",
    "HAPAX_AGENT_NAME": session,
    "CODEX_THREAD_NAME": session,
    "CODEX_ROLE": session,
    "HAPAX_AGENT_ROLE": session,
}
for name in (
    "CLAUDE_ROLE",
    "HAPAX_AGENT_SLOT",
    "HAPAX_WORKTREE_ROLE",
    "HAPAX_SESSION_ID",
    "HAPAX_PARENT_AGENT_INTERFACE",
    "HAPAX_PARENT_AGENT_NAME",
    "HAPAX_METHODOLOGY_DISPATCH_TASK",
    "HAPAX_CODEX_WORKTREE_STRATEGY",
    "HAPAX_CC_TASK_GATE",
    "HAPAX_IDLE_UPDATE_SECONDS",
    "HAPAX_CODEX_BIN_PATH",
    "NPM_CONFIG_PREFIX",
    "PASSWORD_STORE_DIR",
):
    value = os.environ.get(name)
    if value is not None:
        env[name] = value
payload = {
    "workdir": workdir,
    "proof_file": proof_file,
    "requested_host": requested_host,
    "session": session,
    "task_id": task_id,
    "tmux_name": tmux_name,
    "env": env,
    "argv": argv,
}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

REMOTE_PREFLIGHT_PY='import base64,json,math,os,shutil,subprocess,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"]));
missing_dirs=[path for path in p.get("required_dirs",()) if not os.path.isdir(path)]
missing_exec=[path for path in p.get("executables",()) if not (os.path.isfile(path) and os.access(path, os.X_OK))]
missing_bins=[binary for binary in p.get("binaries",()) if binary!="codex" and not shutil.which(binary)]
def _resolve_path(binary):
    path=os.path.expanduser(binary)
    if os.path.isabs(path) or os.sep in path:
        return os.path.abspath(path) if os.path.isfile(path) and os.access(path,os.X_OK) else None
    return shutil.which(binary)
def _resolve_codex_bin():
    codex_bin=shutil.which("codex")
    if codex_bin:
        return codex_bin,""
    npm_prefix=(p.get("npm_config_prefix") or os.environ.get("NPM_CONFIG_PREFIX","")).rstrip("/")
    for candidate in ((p.get("codex_bin_path") or os.environ.get("HAPAX_CODEX_BIN_PATH") or "").strip(),os.path.expanduser("~/.npm-global/bin/codex"),(npm_prefix+"/bin/codex") if npm_prefix else "",os.path.expanduser("~/.local/share/npm/bin/codex"),"/usr/local/bin/codex"):
        if candidate:
            resolved=_resolve_path(candidate)
            if resolved:
                return resolved,""
    return None,"codex_binary_missing"
def _assistant_content_text(content):
    if isinstance(content,str):
        return content
    if isinstance(content,list):
        pieces=[]
        for item in content:
            if isinstance(item,dict):
                text=item.get("text")
                if isinstance(text,str):
                    pieces.append(text)
        return "".join(pieces)
    return ""
def _auth_event_text(event):
    if not isinstance(event,dict):
        return ""
    if event.get("type")=="item.completed":
        item=event.get("item")
        if isinstance(item,dict) and item.get("type")=="agent_message":
            text=item.get("text")
            return text if isinstance(text,str) else ""
    if event.get("type")=="response.output_text.done":
        text=event.get("text")
        return text if isinstance(text,str) else ""
    if event.get("role")=="assistant":
        return _assistant_content_text(event.get("content"))
    message=event.get("message")
    if isinstance(message,dict) and message.get("role")=="assistant":
        return _assistant_content_text(message.get("content"))
    return ""
def _sentinel_observed(stdout):
    for line in stdout.splitlines():
        try:
            event=json.loads(line)
        except json.JSONDecodeError:
            continue
        if _auth_event_text(event).strip()==sentinel:
            return True
    return False
def _auth_error(output, default):
    if "refresh_token_invalidated" in output:
        return "codex_saved_auth_refresh_token_invalidated"
    if "token_invalidated" in output:
        return "codex_saved_auth_token_invalidated"
    lowered=output.lower()
    if (
        "login required" in lowered
        or "required to log in" in lowered
        or "please log in" in lowered
        or "not logged in" in lowered
    ):
        return "codex_saved_auth_login_required"
    return default
auth_error=""
codex_bin,codex_resolution_error=_resolve_codex_bin()
if codex_bin is None:
    auth_error=codex_resolution_error
else:
    env={k:v for k in ("ALL_PROXY","HOME","HTTP_PROXY","HTTPS_PROXY","LANG","LC_ALL","NO_PROXY","PATH","REQUESTS_CA_BUNDLE","SSL_CERT_FILE") if (v:=os.environ.get(k)) is not None}
    env["NO_COLOR"]="1"
    env.pop("CODEX_ACCESS_TOKEN",None); env.pop("CODEX_HOME",None); env.pop("CODEX_API_KEY",None); env.pop("OPENAI_API_KEY",None)
    sentinel="HAPAX_CODEX_EXEC_AUTH_OK"
    auth_workdir=p.get("workdir") or os.getcwd()
    if not os.path.isdir(auth_workdir):
        auth_workdir=os.path.expanduser("~")
    try:
        timeout_s=float(p.get("codex_exec_auth_timeout") or 30)
    except (TypeError,ValueError):
        timeout_s=30.0
    if not math.isfinite(timeout_s) or timeout_s <= 0:
        timeout_s=30.0
    try:
        result=subprocess.run([codex_bin,"exec","--ephemeral","--skip-git-repo-check","--ignore-rules","--sandbox","read-only","--json","--cd",auth_workdir,"Reply exactly: "+sentinel],text=True,capture_output=True,timeout=timeout_s,env=env)
    except subprocess.TimeoutExpired:
        auth_error="codex_saved_auth_exec_timeout"
    except OSError as exc:
        auth_error="codex_saved_auth_exec_failed:"+exc.__class__.__name__
    else:
        output=(result.stdout or "")+"\n"+(result.stderr or "")
        if result.returncode != 0:
            auth_error=_auth_error(output,"codex_saved_auth_exec_failed:rc="+str(result.returncode))
        elif not _sentinel_observed(result.stdout):
            auth_error=_auth_error(output,"codex_saved_auth_sentinel_missing")
if missing_dirs or missing_exec or missing_bins or auth_error:
    print("remote preflight failed: missing_dirs="+json.dumps(missing_dirs)+" missing_executables="+json.dumps(missing_exec)+" missing_binaries="+json.dumps(missing_bins)+" auth_error="+json.dumps(auth_error)+"; next action: repair saved Codex login on the dispatch host via codex login or the documented auth-cache transfer fallback, then verify required paths before retrying", file=sys.stderr)
    sys.exit(1)
sys.exit(0)'
REMOTE_EXEC_PY='import base64,json,os,shutil,socket,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); os.chdir(p["workdir"]); os.environ.update(p.get("env",{})); os.environ.pop("CODEX_ACCESS_TOKEN",None); os.environ.pop("CODEX_HOME",None); os.environ.pop("CODEX_API_KEY",None); os.environ.pop("OPENAI_API_KEY",None); proof=p.get("proof_file",""); cgroup="";
try:
    cgroup=open("/proc/self/cgroup",encoding="utf-8").read()
except OSError:
    pass
def _resolve_path(binary):
    path=os.path.expanduser(binary)
    if os.path.isabs(path) or os.sep in path:
        return os.path.abspath(path) if os.path.isfile(path) and os.access(path,os.X_OK) else None
    return shutil.which(binary)
def _resolve_codex_bin():
    codex_bin=shutil.which("codex")
    if codex_bin:
        return codex_bin,""
    npm_prefix=(p.get("npm_config_prefix") or os.environ.get("NPM_CONFIG_PREFIX","")).rstrip("/")
    for candidate in ((p.get("codex_bin_path") or os.environ.get("HAPAX_CODEX_BIN_PATH") or "").strip(),os.path.expanduser("~/.npm-global/bin/codex"),(npm_prefix+"/bin/codex") if npm_prefix else "",os.path.expanduser("~/.local/share/npm/bin/codex"),"/usr/local/bin/codex"):
        if candidate:
            resolved=_resolve_path(candidate)
            if resolved:
                return resolved,""
    return None,"codex_binary_missing"
codex_bin,codex_resolution_error=_resolve_codex_bin()
if codex_bin is None:
    print("hapax-codex: remote Codex binary is unavailable: "+codex_resolution_error+"; next action: repair PATH on the dispatch host or set HAPAX_CODEX_BIN_PATH to the executable before retrying", file=sys.stderr)
    sys.exit(78)
if proof:
    os.makedirs(os.path.dirname(proof), exist_ok=True)
    data={"schema_version":1,"event":"dispatch_remote_exec","platform":"codex","session":p.get("session"),"task_id":p.get("task_id"),"requested_host":p.get("requested_host"),"actual_host":socket.gethostname(),"pid":os.getpid(),"cgroup":cgroup,"tmux_name":p.get("tmux_name"),"workdir":p.get("workdir"),"logos_base_url":os.environ.get("LOGOS_BASE_URL"),"argv0":codex_bin,"argc":len(p.get("argv",[]))}; open(proof,"w",encoding="utf-8").write(json.dumps(data,sort_keys=True)+"\n")
argv=p["argv"]; argv[0]=codex_bin; os.execv(codex_bin, argv)'

write_local_dispatch_proof() {
  local actual_host="$1" fallback="$2" reason="${3:-}" runner="${4:-}" pane_pid="" cgroup=""
  local proof_file="${DISPATCH_LOCAL_PROOF_FILE:-${DISPATCH_PROOF_FILE:-}}"
  [ -n "$proof_file" ] || return 0
  mkdir -p "$(dirname "$proof_file")" 2>/dev/null || return 0
  if [ -n "${TMUX_BIN:-}" ] && [ -n "${TMUX_NAME:-}" ]; then
    pane_pid="$("$TMUX_BIN" list-panes -t "$TMUX_NAME" -F '#{pane_pid}' 2>/dev/null | sed -n '1p' || true)"
  fi
  cgroup="$(cat /proc/self/cgroup 2>/dev/null || true)"
  python3 - "$proof_file" "$SESSION" "${TASK_ID:-}" "${DISPATCH_HOST_REQUESTED:-}" \
    "$actual_host" "$fallback" "$reason" "${TMUX_NAME:-}" "$pane_pid" "$WORKDIR" "$runner" \
    "$LOGOS_BASE_URL" "$cgroup" <<'PYEOF'
import json
import sys

(
    proof_file,
    session,
    task_id,
    requested_host,
    actual_host,
    fallback,
    reason,
    tmux_name,
    pane_pid,
    workdir,
    runner,
    logos_url,
    cgroup,
) = sys.argv[1:14]
payload = {
    "schema_version": 1,
    "event": "dispatch_local_exec",
    "platform": "codex",
    "session": session,
    "task_id": task_id,
    "requested_host": requested_host,
    "actual_host": actual_host,
    "fallback": fallback == "1",
    "fallback_reason": reason or None,
    "pid": None,
    "cgroup": cgroup,
    "tmux_name": tmux_name or None,
    "tmux_pane_pid": pane_pid or None,
    "workdir": workdir,
    "runner": runner or None,
    "logos_base_url": logos_url,
}
with open(proof_file, "w", encoding="utf-8") as fh:
    fh.write(json.dumps(payload, sort_keys=True) + "\n")
PYEOF
}

preflight_claimable_task() {
  local task_id="$1"
  local session="$2"
  local vault_root="${HAPAX_CC_TASK_ROOT:-$HOME/Documents/Personal/20-projects/hapax-cc-tasks}"

  if ! command -v python3 >/dev/null 2>&1; then
    echo "hapax-codex: python3 missing; cannot verify claimable task" >&2
    exit 3
  fi

  python3 - "$vault_root" "$task_id" "$session" <<'PYEOF'
import re
import sys
from pathlib import Path

vault_root, task_id, session = Path(sys.argv[1]), sys.argv[2], sys.argv[3]
active_root = vault_root / "active"
note_path = None

for candidate in active_root.glob(f"{task_id}-*.md"):
    if candidate.is_file():
        note_path = candidate
        break

exact = active_root / f"{task_id}.md"
if note_path is None and exact.is_file():
    note_path = exact

if note_path is None:
    print(
        f"hapax-codex: task '{task_id}' not found in {active_root}/",
        file=sys.stderr,
    )
    print(f"browse offered tasks: {vault_root}/_dashboard/cc-offered.md", file=sys.stderr)
    sys.exit(2)

text = note_path.read_text(encoding="utf-8")
status_match = re.search(r"^status:\s*(\S+)$", text, flags=re.MULTILINE)
status = status_match.group(1) if status_match else ""
assigned_match = re.search(r"^assigned_to:[ \t]*(.*)$", text, flags=re.MULTILINE)
assigned = assigned_match.group(1).strip().strip('"').strip("'") if assigned_match else "unassigned"
nullish = {"", "null", "none", "~", "[]"}

if status == "offered":
    if assigned != "unassigned" and assigned.lower() not in nullish:
        print(
            f"hapax-codex: refusing to spawn task '{task_id}' - already assigned to "
            f"'{assigned}'",
            file=sys.stderr,
        )
        sys.exit(4)
elif status in {"pr_open", "merge_queue"}:
    if assigned != session:
        printable_assigned = assigned or "unassigned"
        print(
            f"hapax-codex: refusing to spawn task '{task_id}' - ready-state task is "
            f"assigned to '{printable_assigned}', not '{session}'",
            file=sys.stderr,
        )
        sys.exit(4)
else:
    printable = status or "missing"
    print(
        f"hapax-codex: refusing to spawn task '{task_id}' - current status is "
        f"'{printable}', not 'offered' or an assigned ready state",
        file=sys.stderr,
    )
    sys.exit(4)
PYEOF
}

SESSION=""
SLOT=""
WORKDIR=""
WORKDIR_EXPLICIT=0
TASK_ID=""
BOOTSTRAP_FILE=""
TERMINAL="${HAPAX_CODEX_TERMINAL:-none}"
TASK_GATE=0
CLAIM_TASK=1
FORCE=0
CODEX_EXTRA=()

while [ $# -gt 0 ]; do
  case "$1" in
    --session|--thread|--name)
      SESSION="${2:-}"
      shift 2
      ;;
    --session=*|--thread=*|--name=*)
      SESSION="${1#*=}"
      shift
      ;;
    --slot)
      SLOT="${2:-}"
      shift 2
      ;;
    --slot=*)
      SLOT="${1#--slot=}"
      shift
      ;;
    --role)
      if hapax_agent_is_codex_name "${2:-}"; then
        SESSION="${2:-}"
      else
        SLOT="${2:-}"
      fi
      shift 2
      ;;
    --role=*)
      value="${1#--role=}"
      if hapax_agent_is_codex_name "$value"; then
        SESSION="$value"
      else
        SLOT="$value"
      fi
      shift
      ;;
    --cd|-C)
      WORKDIR="${2:-}"
      WORKDIR_EXPLICIT=1
      shift 2
      ;;
    --cd=*)
      WORKDIR="${1#--cd=}"
      WORKDIR_EXPLICIT=1
      shift
      ;;
    --task)
      TASK_ID="${2:-}"
      shift 2
      ;;
    --task=*)
      TASK_ID="${1#--task=}"
      shift
      ;;
    --bootstrap)
      BOOTSTRAP_FILE="${2:-}"
      shift 2
      ;;
    --bootstrap=*)
      BOOTSTRAP_FILE="${1#--bootstrap=}"
      shift
      ;;
    --terminal)
      TERMINAL="${2:-}"
      shift 2
      ;;
    --terminal=*)
      TERMINAL="${1#--terminal=}"
      shift
      ;;
    --task-gate)
      TASK_GATE=1
      shift
      ;;
    --no-claim)
      CLAIM_TASK=0
      shift
      ;;
    --force)
      FORCE=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      CODEX_EXTRA+=("$@")
      break
      ;;
    cx-*)
      if [ -z "$SESSION" ]; then
        SESSION="$1"
      else
        CODEX_EXTRA+=("$1")
      fi
      shift
      ;;
    alpha|beta|delta|epsilon)
      if [ -z "$SLOT" ]; then
        SLOT="$1"
      else
        CODEX_EXTRA+=("$1")
      fi
      shift
      ;;
    *)
      CODEX_EXTRA+=("$1")
      shift
      ;;
  esac
done

if [ -z "$SESSION" ]; then
  SESSION="${HAPAX_AGENT_NAME:-${CODEX_THREAD_NAME:-${CODEX_SESSION_NAME:-${CODEX_SESSION:-${CODEX_ROLE:-}}}}}"
fi
if [ -z "$SESSION" ]; then
  SESSION="${CODEX_DEFAULT_THREAD_NAME:-cx-blue}"
fi

if ! hapax_agent_is_codex_name "$SESSION"; then
  echo "hapax-codex: invalid session '$SESSION' (expected cx-<color>)" >&2
  exit 2
fi

if [ -z "$SLOT" ]; then
  if declare -F hapax_agent_worktree_role >/dev/null 2>&1; then
    SLOT="$(hapax_agent_worktree_role_or_default alpha)"
  else
    SLOT="alpha"
  fi
fi

case "$SLOT" in
  alpha|beta|delta|epsilon) ;;
  *)
    echo "hapax-codex: invalid slot '$SLOT'" >&2
    exit 2
    ;;
esac

case "$TERMINAL" in
  none|tmux|foot) ;;
  *)
    echo "hapax-codex: invalid terminal '$TERMINAL'" >&2
    exit 2
    ;;
esac

CODEX_WORKTREE_STRATEGY="explicit"
if [ -z "$WORKDIR" ]; then
  WORKDIR="$(codex_default_worktree_path "$SESSION" "$SLOT")"
  if [ "$WORKDIR" = "$HOME/projects/hapax-council" ]; then
    CODEX_WORKTREE_STRATEGY="primary"
  else
    CODEX_WORKTREE_STRATEGY="codex-native"
  fi
fi

if [ ! -d "$WORKDIR" ] && [ "$WORKDIR_EXPLICIT" -eq 0 ] && [ "$CODEX_WORKTREE_STRATEGY" = "codex-native" ]; then
  if ! ensure_codex_worktree "$WORKDIR" "$SESSION"; then
    echo "hapax-codex: codex-native worktree missing and could not be created: $WORKDIR" >&2
    echo "  session=$SESSION slot=$SLOT strategy=$CODEX_WORKTREE_STRATEGY" >&2
    exit 3
  fi
fi

if [ -z "$WORKDIR" ] || [ ! -d "$WORKDIR" ]; then
  echo "hapax-codex: no worktree found for session '$SESSION' slot '$SLOT' at $WORKDIR" >&2
  exit 3
fi
WORKDIR="$(cd "$WORKDIR" && pwd)"
export HAPAX_CODEX_WORKTREE_STRATEGY="$CODEX_WORKTREE_STRATEGY"

PARENT_INTERFACE="${HAPAX_PARENT_AGENT_INTERFACE:-${HAPAX_AGENT_INTERFACE:-unknown}}"
PARENT_NAME="${HAPAX_PARENT_AGENT_NAME:-${HAPAX_AGENT_NAME:-${CODEX_THREAD_NAME:-${CODEX_ROLE:-unknown}}}}"

# Per-session id (coordination reform Phase 1): stable uuid so the gate keys a
# claim lease to THIS session — two same-role sessions never collide (FM-2).
SESSION_UUID="$(normalize_session_uuid "${HAPAX_SESSION_ID:-}")"
TMUX_NAME="hapax-codex-$SESSION"
DISPATCH_HOST_REQUESTED="${HAPAX_DISPATCH_HOST:-}"
DISPATCH_HOST=""
DISPATCH_FALLBACK_REASON=""
