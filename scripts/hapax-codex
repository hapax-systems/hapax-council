#!/usr/bin/env bash
# Launch Codex as a first-class Hapax coding interface.

set -euo pipefail

COUNCIL_DIR="${HAPAX_COUNCIL_DIR:-$HOME/projects/hapax-council}"
ROLE_HELPER="$COUNCIL_DIR/hooks/scripts/agent-role.sh"
if [ -f "$ROLE_HELPER" ]; then
  # shellcheck source=../hooks/scripts/agent-role.sh
  # shellcheck disable=SC1091
  . "$ROLE_HELPER"
fi

usage() {
  cat <<'EOF'
usage: hapax-codex [--session cx-color] [--slot alpha|beta|delta|epsilon] [--cd DIR]
                   [--task TASK_ID] [--bootstrap FILE] [--task-gate]
                   [--terminal none|tmux|foot] [--force] [--no-claim]
                   [--] [codex args...]

Defaults:
  - no approval gates: Codex runs with --dangerously-bypass-approvals-and-sandbox
  - Codex thread identity defaults to CODEX_THREAD_NAME or cx-blue
  - worktree slot is inferred from cwd when --slot is omitted
  - worktree selected from the slot when --cd is omitted
  - terminal is none: exec Codex in the current terminal
EOF
}

if ! declare -F hapax_agent_is_codex_name >/dev/null 2>&1; then
  hapax_agent_is_codex_name() {
    [[ "${1:-}" =~ ^cx-[a-z][a-z-]*$ ]]
  }
fi

if ! declare -F hapax_agent_worktree_role_or_default >/dev/null 2>&1; then
  hapax_agent_worktree_role_or_default() {
    printf '%s\n' "${1:-roleless}"
  }
fi

is_codex_subcommand() {
  case "${1:-}" in
    exec|e|review|login|logout|mcp|plugin|mcp-server|app-server|completion|sandbox|debug|apply|a|resume|fork|cloud|exec-server|features|help)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

first_existing_dir() {
  local path
  for path in "$@"; do
    if [ -d "$path" ]; then
      printf '%s\n' "$path"
      return 0
    fi
  done
  return 1
}

slugify() {
  printf '%s\n' "$1" | tr -cs 'A-Za-z0-9_.-' '-' | sed 's/^-//; s/-$//'
}

token_handoff_component() {
  local component
  component="$(printf '%s\n' "$1" | tr -cs 'A-Za-z0-9_-' '-' | sed 's/^-//; s/-$//' | cut -c1-96)"
  if [ -z "$component" ]; then
    component="session"
  fi
  printf '%s\n' "$component"
}

remote_token_handoff_seal_key() {
  python3 - <<'PYEOF'
import secrets

print(secrets.token_hex(32))
PYEOF
}

session_id_is_safe() {
  local sid="${1:-}" tail=""
  [ "${#sid}" -ge 8 ] && [ "${#sid}" -le 128 ] || return 1
  case "$sid" in
    [A-Za-z0-9]*) ;;
    *) return 1 ;;
  esac
  case "$sid" in
    *[!A-Za-z0-9._-]*) return 1 ;;
  esac
  case "$sid" in
    *[!0-9]*) ;;
    *) return 1 ;;
  esac
  tail="${sid##*-}"
  if [[ "$tail" =~ ^[0-9]{1,7}$ ]]; then
    return 1
  fi
  return 0
}

mint_session_uuid() {
  cat /proc/sys/kernel/random/uuid 2>/dev/null \
    || uuidgen 2>/dev/null \
    || python3 -c 'import uuid; print(uuid.uuid4())' 2>/dev/null \
    || printf '%s-%s-p%sx\n' "$(token_handoff_component "$SESSION")" "$(date -u +%Y%m%dT%H%M%SZ)" "$$"
}

normalize_session_uuid() {
  local raw="${1:-}" minted=""
  if [ -n "$raw" ] && session_id_is_safe "$raw"; then
    printf '%s\n' "$raw"
    return 0
  fi
  minted="$(mint_session_uuid)"
  if [ -n "$raw" ]; then
    echo "hapax-codex: ignoring unsafe HAPAX_SESSION_ID; minted safe session id for coordination paths" >&2
  fi
  printf '%s\n' "$minted"
}

relay_retired() {
  # Delegate to the single-source predicate (shared/relay_lifecycle.lane_is_retired)
  # so the launcher agrees with the dispatch gate + the coordinator: one
  # broad-9 vocabulary, freshest-of-candidates resolution, multi-doc
  # latest-wins. The legacy awk (relay_current_values/relay_value_is_retired
  # below) over-refused SUPERSEDED/CLOSED lane relays (task/claim states that
  # leaked); it is now dead code retained only for a minimal diff — remove later.
  # FAIL-OPEN on tooling error (python missing / import fail): the gate at
  # coord_dispatch.run_atomic_dispatch_launch is authoritative on the governed
  # path, so a fail-open launcher only ever sees gate-allowed lanes.
  local relay_name="$1"
  local council_root
  local relay_dir="${HAPAX_RELAY_DIR:-$HOME/.cache/hapax/relay}"
  council_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  PYTHONPATH="$council_root${PYTHONPATH:+:$PYTHONPATH}" python3 -c '
import sys
from pathlib import Path
from shared.relay_lifecycle import lane_is_retired
sys.exit(0 if lane_is_retired(sys.argv[1], relay_dir=Path(sys.argv[2])) else 1)
' "$relay_name" "$relay_dir" 2>/dev/null
  case $? in
    0) return 0 ;;
    *) return 1 ;;  # 1 = not retired; any other = tooling error -> fail-open
  esac
}

relay_current_values() {
  local relay_file="$1"
  awk '
    BEGIN { in_session_status = 0 }

    in_session_status {
      if ($0 ~ /^[[:space:]]*$/) {
        next
      }
      if ($0 !~ /^[[:space:]]+/) {
        in_session_status = 0
      } else {
        value = $0
        sub(/^[[:space:]]+/, "", value)
        print value
        in_session_status = 0
        next
      }
    }

    /^(status|state|relay_status|session_state|role):[[:space:]]*/ {
      value = $0
      sub(/^[^:]+:[[:space:]]*/, "", value)
      if (value !~ /^[|>]/) {
        print value
      }
      next
    }

    /^session_status:[[:space:]]*/ {
      value = $0
      sub(/^session_status:[[:space:]]*/, "", value)
      if (value ~ /^[|>]/) {
        in_session_status = 1
        next
      }
      print value
      next
    }
  ' "$relay_file"
}

relay_value_is_retired() {
  local value="$1"
  local normalized first_word
  normalized="$(printf '%s' "$value" | sed "s/^[[:space:]\"']*//; s/[[:space:]\"']*$//" | tr '[:lower:]' '[:upper:]')"
  first_word="${normalized%%[[:space:]]*}"
  case "$first_word" in
    # NOTE: the broad ANTIGRAVITY* glob stays out because arbitrary relay prose is
    # not a retirement marker. The exact ANTIGRAVITY_TAKEOVER terminal marker is
    # retained only to parse older relay wind-down files after the live
    # Antigrav/agy worker was excised.
    RETIRED*|SUPERSEDED*|CLOSED*|IDLE_WOUND_DOWN*|WIND_DOWN_IDLE*|WOUND_DOWN*|WIND_DOWN*|WINDING_DOWN*|ANTIGRAVITY_TAKEOVER)
      return 0
      ;;
  esac
  case "$normalized" in
    RETIRED*|SUPERSEDED*|CLOSED*|IDLE_WOUND_DOWN*|WIND_DOWN_IDLE*|WOUND_DOWN*|WIND_DOWN*|WINDING_DOWN*|ANTIGRAVITY_TAKEOVER)
      return 0
      ;;
  esac
  return 1
}

session_is_protected() {
  local session="$1"
  local protection_file="${HAPAX_SESSION_PROTECTION_FILE:-$HOME/.cache/hapax/relay/session-protection.md}"

  [ -f "$protection_file" ] || return 1
  awk -v session="$session" '
    {
      line = tolower($0)
      needle = "`" session "`"
      if (index($0, needle) && line ~ /protected/) {
        found = 1
      }
    }
    END {
      exit(found ? 0 : 1)
    }
  ' "$protection_file"
}

live_codex_session_exists() {
  local session="$1"
  local class="hapax-codex-$session"
  local tmux_name="hapax-codex-$session"

  if command -v hyprctl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    if hyprctl clients -j 2>/dev/null \
      | jq -e --arg class "$class" 'any(.[]?; .class == $class)' >/dev/null 2>&1; then
      return 0
    fi
  fi

  if command -v tmux >/dev/null 2>&1 && tmux has-session -t "$tmux_name" 2>/dev/null; then
    return 0
  fi

  if command -v pgrep >/dev/null 2>&1; then
    if pgrep -af -- "$class|run-[0-9TZ]+-$session\\.sh" >/dev/null 2>&1; then
      return 0
    fi
  fi

  return 1
}

assert_protected_terminal_launch_allowed() {
  local session="$1"
  local terminal="$2"

  [ "$terminal" != "none" ] || return 0
  [ "${HAPAX_CODEX_PROTECTED_SESSION_OVERRIDE:-0}" != "1" ] || return 0
  session_is_protected "$session" || return 0
  live_codex_session_exists "$session" || return 0

  cat >&2 <<EOF
hapax-codex: refusing to launch protected live session '$session' because it already appears active.
  protection: ${HAPAX_SESSION_PROTECTION_FILE:-$HOME/.cache/hapax/relay/session-protection.md}
  override only with an explicit operator directive and HAPAX_CODEX_PROTECTED_SESSION_OVERRIDE=1
EOF
  exit 12
}

foot_color_theme_for_current_mode() {
  local mode
  mode="$(cat "$HOME/.cache/hapax/working-mode" 2>/dev/null || printf '%s\n' rnd)"
  case "$mode" in
    research)
      printf '%s\n' light
      ;;
    rnd|fortress|*)
      printf '%s\n' dark
      ;;
  esac
}

active_hyprland_workspace_name() {
  if [ -n "${HAPAX_CODEX_FOOT_WORKSPACE:-}" ]; then
    printf '%s\n' "$HAPAX_CODEX_FOOT_WORKSPACE"
    return 0
  fi
  command -v hyprctl >/dev/null 2>&1 || return 1
  command -v jq >/dev/null 2>&1 || return 1
  hyprctl activeworkspace -j 2>/dev/null | jq -r '.name // empty' 2>/dev/null | sed -n '1p'
}

move_foot_window_to_workspace() {
  local session="$1"
  local workspace="$2"
  [ -n "$workspace" ] || return 0
  command -v hyprctl >/dev/null 2>&1 || return 0
  command -v jq >/dev/null 2>&1 || return 0

  local class="hapax-codex-$session"
  local address=""
  local _
  for _ in {1..20}; do
    address="$(hyprctl clients -j 2>/dev/null | jq -r --arg class "$class" '[.[] | select(.class == $class) | .address][0] // empty' 2>/dev/null || true)"
    if [ -n "$address" ]; then
      hyprctl dispatch movetoworkspacesilent "name:$workspace,address:$address" >/dev/null 2>&1 || true
      return 0
    fi
    sleep 0.1
  done
}

codex_default_worktree_path() {
  local session="$1"
  local slot="$2"
  local root="${HAPAX_CODEX_WORKTREE_ROOT:-$HOME/projects}"
  local primary_session="${HAPAX_CODEX_PRIMARY_SESSION:-cx-red}"

  if [ "$slot" = "alpha" ] && [ "$session" = "$primary_session" ]; then
    printf '%s\n' "$HOME/projects/hapax-council"
    return 0
  fi

  printf '%s\n' "$root/hapax-council--$session"
}

ensure_codex_worktree() {
  local workdir="$1"
  local session="$2"
  local base_ref="${HAPAX_CODEX_WORKTREE_BASE:-main}"
  local branch_prefix="${HAPAX_CODEX_BRANCH_PREFIX:-codex}"
  local branch="$branch_prefix/$session"

  [ "${HAPAX_CODEX_CREATE_WORKTREE:-1}" = "1" ] || return 1
  [ ! -e "$workdir" ] || return 1
  git -C "$COUNCIL_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 1
  mkdir -p "$(dirname "$workdir")"

  if ! git -C "$COUNCIL_DIR" rev-parse --verify --quiet "$base_ref" >/dev/null; then
    base_ref="HEAD"
  fi

  if git -C "$COUNCIL_DIR" show-ref --verify --quiet "refs/heads/$branch"; then
    git -C "$COUNCIL_DIR" worktree add "$workdir" "$branch" >/dev/null
  else
    git -C "$COUNCIL_DIR" worktree add -b "$branch" "$workdir" "$base_ref" >/dev/null
  fi
}

pass_first_line() {
  local name="$1"
  command -v pass >/dev/null 2>&1 || return 1
  pass show "$name" 2>/dev/null | sed -n '1p'
}

load_first_available_pass_secret() {
  local env_name="$1"
  shift
  [ -n "${!env_name:-}" ] && return 0
  local entry value
  for entry in "$@"; do
    value="$(pass_first_line "$entry" || true)"
    if [ -n "$value" ]; then
      export "$env_name=$value"
      return 0
    fi
  done
  return 1
}

load_header_from_claude_mcp() {
  local env_name="$1"
  local server="$2"
  local header_name="$3"
  [ -n "${!env_name:-}" ] && return 0
  [ -r "$HOME/.claude.json" ] || return 1
  command -v jq >/dev/null 2>&1 || return 1
  local value
  value="$(jq -r --arg server "$server" --arg header "$header_name" '.mcpServers[$server].headers[$header] // empty' "$HOME/.claude.json" 2>/dev/null || true)"
  if [ -n "$value" ]; then
    export "$env_name=$value"
    return 0
  fi
  return 1
}

dispatch_host_is_local() {
  local host="${1:-}" short="" fqdn=""
  [ -z "$host" ] && return 0
  case "$host" in
    local|localhost|127.0.0.1|::1)
      return 0
      ;;
  esac
  short="$(hostname -s 2>/dev/null || hostname 2>/dev/null || true)"
  fqdn="$(hostname -f 2>/dev/null || true)"
  [ -n "$short" ] && [ "$host" = "$short" ] && return 0
  [ -n "$fqdn" ] && [ "$host" = "$fqdn" ] && return 0
  return 1
}

remote_python_command() {
  local payload="$1" code="$2"
  local code_b64="" bash_script="" quoted_script="" quoted_payload="" quoted_code=""
  code_b64="$(printf '%s' "$code" | python3 -c 'import base64,sys; print(base64.b64encode(sys.stdin.buffer.read()).decode())')"
  # shellcheck disable=SC2016
  bash_script='export HAPAX_REMOTE_PAYLOAD="$1"; export HAPAX_REMOTE_CODE="$2"; exec python3 -c "import base64,os; exec(base64.b64decode(os.environ[\"HAPAX_REMOTE_CODE\"]))"'
  quoted_script="${bash_script//\'/\'\\\'\'}"
  quoted_payload="${payload//\'/\'\\\'\'}"
  quoted_code="${code_b64//\'/\'\\\'\'}"
  printf "bash -c '%s' bash '%s' '%s'" "$quoted_script" "$quoted_payload" "$quoted_code"
}

maybe_load_local_codex_access_token() {
  if [ -n "${CODEX_ACCESS_TOKEN:-}" ]; then
    return 0
  fi
  local token_file="${HAPAX_CODEX_OAUTH_ACCESS_TOKEN_FILE:-$HOME/.cache/hapax/codex-oauth/access_token}"
  local token="" token_rc=0
  token="$(
    PYTHONPATH="$COUNCIL_DIR${PYTHONPATH:+:$PYTHONPATH}" python3 - "$token_file" <<'PYEOF'
import sys
from pathlib import Path

from shared.codex_oauth_refresher import (
    load_published_access_token,
    needs_refresh,
)

path = Path(sys.argv[1]).expanduser()
token = load_published_access_token(token_file=path)
if token is None:
    raise SystemExit(0)
if needs_refresh(token):
    print(
        "hapax-codex: published Codex OAuth access token is absent or expiring; "
        "continuing without CODEX_ACCESS_TOKEN for interactive launch; next action: "
        "run scripts/hapax-platform-capability-receipts --platform codex --json or reauth Codex",
        file=sys.stderr,
    )
    raise SystemExit(0)
print(token.raw)
PYEOF
	  )" || token_rc=$?
  if [ "$token_rc" -ne 0 ]; then
    echo "hapax-codex: could not inspect published Codex OAuth access token (rc=$token_rc); continuing without CODEX_ACCESS_TOKEN for interactive launch" >&2
    return 0
  fi
  if [ "$token_rc" -eq 0 ] && [ -n "$token" ]; then
    export CODEX_ACCESS_TOKEN="$token"
  fi
  return 0
}

remote_preflight_payload_b64() {
  local token_handoff_file="${1:-}"
  python3 - "$WORKDIR" "$COUNCIL_DIR" "$HOME/projects/hapax-mcp" "$token_handoff_file" <<'PYEOF'
import base64
import json
import os
import sys

def token_handoff_ttl_seconds():
    raw = os.environ.get("HAPAX_REMOTE_TOKEN_HANDOFF_TTL_SECONDS", "900")
    try:
        ttl = int(raw)
    except ValueError:
        print(
            "hapax-codex: invalid HAPAX_REMOTE_TOKEN_HANDOFF_TTL_SECONDS="
            + raw
            + "; next action: set a positive integer between 1 and 3600 before remote dispatch",
            file=sys.stderr,
        )
        raise SystemExit(78)
    if ttl < 1 or ttl > 3600:
        print(
            "hapax-codex: invalid HAPAX_REMOTE_TOKEN_HANDOFF_TTL_SECONDS="
            + raw
            + "; next action: set a positive integer between 1 and 3600 before remote dispatch",
            file=sys.stderr,
        )
        raise SystemExit(78)
    return ttl

workdir, council_dir, mcp_dir, token_handoff_file = sys.argv[1:5]
token_file = (
    os.environ.get("HAPAX_CODEX_OAUTH_ACCESS_TOKEN_FILE")
    or "~/.cache/hapax/codex-oauth/access_token"
)
payload = {
    "workdir": workdir,
    "required_dirs": [workdir, council_dir, mcp_dir],
    "executables": [
        f"{council_dir}/scripts/hapax-codex",
        f"{council_dir}/hooks/scripts/codex-hook-adapter.sh",
    ],
    "binaries": ["python3", "codex"],
    "token_file": token_file,
    "token_handoff_file": token_handoff_file,
    "token_handoff_seal_key": os.environ.get("HAPAX_REMOTE_TOKEN_HANDOFF_SEAL_KEY", ""),
    "token_handoff_ttl_seconds": token_handoff_ttl_seconds(),
}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

remote_exec_payload_b64() {
  local proof_file="$1"
  shift
  python3 - "$WORKDIR" "$proof_file" "${DISPATCH_HOST_REQUESTED:-}" "$LOGOS_BASE_URL" \
    "$COCKPIT_BASE_URL" "$SESSION" "${TASK_ID:-}" "${TMUX_NAME:-}" "$@" <<'PYEOF'
import base64
import json
import os
import sys

workdir, proof_file, requested_host, logos_url, cockpit_url, session, task_id, tmux_name = sys.argv[1:9]
argv = sys.argv[9:]
env = {
    "LOGOS_BASE_URL": logos_url,
    "COCKPIT_BASE_URL": cockpit_url,
    "HAPAX_DISPATCH_HOST": "local",
    "HAPAX_DISPATCH_REQUESTED_HOST": requested_host,
    "HAPAX_DISPATCH_LOGOS_URL": logos_url,
    "HAPAX_DISPATCH_PROOF_FILE": proof_file,
    "HAPAX_DISPATCH_REMOTE_INNER": "1",
    "HAPAX_AGENT_INTERFACE": "codex",
    "HAPAX_AGENT_NAME": session,
    "CODEX_THREAD_NAME": session,
    "CODEX_ROLE": session,
    "HAPAX_AGENT_ROLE": session,
}
for name in (
    "CLAUDE_ROLE",
    "HAPAX_AGENT_SLOT",
    "HAPAX_WORKTREE_ROLE",
    "HAPAX_SESSION_ID",
    "HAPAX_PARENT_AGENT_INTERFACE",
    "HAPAX_PARENT_AGENT_NAME",
    "HAPAX_METHODOLOGY_DISPATCH_TASK",
    "HAPAX_CODEX_WORKTREE_STRATEGY",
    "HAPAX_CC_TASK_GATE",
    "HAPAX_IDLE_UPDATE_SECONDS",
    "HAPAX_CODEX_OAUTH_ACCESS_TOKEN_FILE",
    "PASSWORD_STORE_DIR",
):
    value = os.environ.get(name)
    if value is not None:
        env[name] = value
payload = {
    "workdir": workdir,
    "proof_file": proof_file,
    "requested_host": requested_host,
    "session": session,
    "task_id": task_id,
    "tmux_name": tmux_name,
    "token_handoff_file": os.environ.get("HAPAX_REMOTE_TOKEN_HANDOFF", ""),
    "token_handoff_seal_key": os.environ.get("HAPAX_REMOTE_TOKEN_HANDOFF_SEAL_KEY", ""),
    "env": env,
    "argv": argv,
}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

remote_token_cleanup_payload_b64() {
  python3 - "${REMOTE_TOKEN_HANDOFF:-}" <<'PYEOF'
import base64
import json
import sys

payload = {"path": sys.argv[1]}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

REMOTE_PREFLIGHT_PY='import base64,hashlib,hmac,json,os,shutil,subprocess,sys,tempfile,time; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"]));
missing_dirs=[path for path in p.get("required_dirs",()) if not os.path.isdir(path)]
missing_exec=[path for path in p.get("executables",()) if not (os.path.isfile(path) and os.access(path, os.X_OK))]
missing_bins=[binary for binary in p.get("binaries",()) if not shutil.which(binary)]
def _jwt_exp(token):
    try:
        payload=token.split(".")[1]; payload += "=" * (-len(payload) % 4)
        return float(json.loads(base64.urlsafe_b64decode(payload.encode("ascii"))).get("exp",0))
    except Exception:
        print("hapax-codex: preflight-proven Codex OAuth token handoff is unparseable; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
def _seal_token(token,key_hex):
    try:
        key=bytes.fromhex(key_hex)
    except ValueError:
        key=b""
    if not key:
        print("hapax-codex: missing Codex OAuth token handoff seal key; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    plain=token.encode("utf-8")
    stream=hashlib.shake_256(key+b":hapax-codex-token-handoff-v1").digest(len(plain))
    cipher=bytes(a^b for a,b in zip(plain,stream))
    mac=hmac.new(key,b"hapax-codex-token-handoff-v1\0"+cipher,hashlib.sha256).hexdigest()
    return "hapax-token-sealed-v1."+base64.urlsafe_b64encode(cipher).decode("ascii").rstrip("=")+"."+mac
token_file=os.path.expanduser(p.get("token_file") or "~/.cache/hapax/codex-oauth/access_token")
token_error=""
actuation_error=""
try:
    token=open(token_file,encoding="utf-8").read().strip()
except OSError:
    token_error="missing_codex_oauth_access_token:"+token_file
else:
    if not token or _jwt_exp(token) - time.time() <= 300:
        token_error="codex_oauth_access_token_absent_or_expiring:"+token_file
if not token_error:
    codex_bin=shutil.which("codex")
    if codex_bin is None:
        actuation_error="codex_binary_missing"
    else:
        with tempfile.TemporaryDirectory(prefix="hapax-codex-actuation-") as codex_home:
            env={k:v for k in ("ALL_PROXY","HOME","HTTP_PROXY","HTTPS_PROXY","LANG","LC_ALL","NO_PROXY","PATH","REQUESTS_CA_BUNDLE","SSL_CERT_FILE") if (v:=os.environ.get(k)) is not None}
            env.update({"CODEX_ACCESS_TOKEN":token,"CODEX_HOME":codex_home,"NO_COLOR":"1"})
            try:
                result=subprocess.run([codex_bin,"debug","models"],text=True,capture_output=True,timeout=15,env=env)
            except (OSError,subprocess.TimeoutExpired) as exc:
                actuation_error="codex_bearer_actuation_failed:"+type(exc).__name__
            else:
                if result.returncode != 0:
                    actuation_error="codex_bearer_actuation_failed:rc="+str(result.returncode)
                else:
                    try:
                        payload=json.loads(result.stdout)
                    except json.JSONDecodeError:
                        actuation_error="codex_bearer_actuation_unparseable"
                    else:
                        models=payload.get("models") if isinstance(payload,dict) else None
                        if not isinstance(models,list) or not models:
                            actuation_error="codex_bearer_actuation_unparseable"
if missing_dirs or missing_exec or missing_bins or token_error or actuation_error:
    print("remote preflight failed: missing_dirs="+json.dumps(missing_dirs)+" missing_executables="+json.dumps(missing_exec)+" missing_binaries="+json.dumps(missing_bins)+" token_error="+json.dumps(token_error)+" actuation_error="+json.dumps(actuation_error)+"; next action: ssh to the dispatch host and run the codex OAuth refresher or reauth, then verify required paths before retrying", file=sys.stderr)
    sys.exit(1)
handoff=p.get("token_handoff_file") or ""
if handoff:
    seal_key=p.get("token_handoff_seal_key") or ""
    handoff=os.path.abspath(os.path.expanduser(handoff))
    if os.path.dirname(handoff)!="/tmp" or not os.path.basename(handoff).startswith("hapax-codex-token-"):
        print("hapax-codex: refused invalid Codex OAuth token handoff path "+handoff+"; next action: rerun remote preflight with a sanitized session id", file=sys.stderr)
        sys.exit(78)
    directory=os.path.dirname(handoff)
    if directory:
        os.makedirs(directory,exist_ok=True)
    flags=os.O_WRONLY|os.O_CREAT|os.O_EXCL
    if hasattr(os,"O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    try:
        fd=os.open(handoff,flags,0o600)
    except OSError as exc:
        print("hapax-codex: refused unsafe preflight-proven Codex OAuth token handoff at "+handoff+" ("+exc.__class__.__name__+"); next action: remove stale hapax-codex-token files owned by this user and rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    try:
        ttl=int(p.get("token_handoff_ttl_seconds"))
    except (TypeError,ValueError):
        os.close(fd)
        try:
            os.unlink(handoff)
        except FileNotFoundError:
            pass
        print("hapax-codex: refused invalid Codex OAuth token handoff TTL; next action: set HAPAX_REMOTE_TOKEN_HANDOFF_TTL_SECONDS to a positive integer between 1 and 3600", file=sys.stderr)
        sys.exit(78)
    if ttl < 1 or ttl > 3600:
        os.close(fd)
        try:
            os.unlink(handoff)
        except FileNotFoundError:
            pass
        print("hapax-codex: refused invalid Codex OAuth token handoff TTL; next action: set HAPAX_REMOTE_TOKEN_HANDOFF_TTL_SECONDS to a positive integer between 1 and 3600", file=sys.stderr)
        sys.exit(78)
    try:
        pid=os.fork()
    except (AttributeError,OSError) as exc:
        os.close(fd)
        try:
            os.unlink(handoff)
        except FileNotFoundError:
            pass
        print("hapax-codex: failed to schedule Codex OAuth token handoff self-cleanup ("+exc.__class__.__name__+"); next action: verify remote process limits/fork availability and rerun before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    if pid == 0:
        try:
            os.close(fd)
        except OSError:
            pass
        try:
            os.setsid()
        except OSError:
            pass
        try:
            devnull=os.open(os.devnull,os.O_RDWR)
            for fdno in (0,1,2):
                try:
                    os.dup2(devnull,fdno)
                except OSError:
                    pass
            if devnull > 2:
                os.close(devnull)
        except OSError:
            pass
        try:
            time.sleep(ttl)
            try:
                os.unlink(handoff)
            except FileNotFoundError:
                pass
        finally:
            os._exit(0)
    with os.fdopen(fd,"w",encoding="utf-8") as fh:
        fh.write(_seal_token(token,seal_key))
sys.exit(0)'
REMOTE_EXEC_PY='import base64,hashlib,hmac,json,os,socket,sys,time; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); os.chdir(p["workdir"]); os.environ.update(p.get("env",{})); proof=p.get("proof_file",""); cgroup="";
try:
    cgroup=open("/proc/self/cgroup",encoding="utf-8").read()
except OSError:
    pass
def _jwt_exp(token):
    try:
        payload=token.split(".")[1]; payload += "=" * (-len(payload) % 4)
        return float(json.loads(base64.urlsafe_b64decode(payload.encode("ascii"))).get("exp",0))
    except Exception:
        print("hapax-codex: preflight-proven Codex OAuth token handoff is unparseable; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
def _unseal_token(blob,key_hex):
    try:
        key=bytes.fromhex(key_hex)
    except ValueError:
        key=b""
    if not key:
        print("hapax-codex: missing Codex OAuth token handoff seal key; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    try:
        prefix,cipher_b64,mac=blob.split(".",2)
    except ValueError:
        print("hapax-codex: preflight-proven Codex OAuth token handoff is unsealed; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    if prefix != "hapax-token-sealed-v1":
        print("hapax-codex: preflight-proven Codex OAuth token handoff has unknown seal format; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    try:
        cipher=base64.urlsafe_b64decode((cipher_b64+"="*(-len(cipher_b64)%4)).encode("ascii"))
    except Exception:
        print("hapax-codex: preflight-proven Codex OAuth token handoff seal is unparseable; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    expected=hmac.new(key,b"hapax-codex-token-handoff-v1\0"+cipher,hashlib.sha256).hexdigest()
    if not hmac.compare_digest(mac,expected):
        print("hapax-codex: preflight-proven Codex OAuth token handoff seal failed authentication; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    stream=hashlib.shake_256(key+b":hapax-codex-token-handoff-v1").digest(len(cipher))
    return bytes(a^b for a,b in zip(cipher,stream)).decode("utf-8")
token_handoff=p.get("token_handoff_file") or ""
if not token_handoff:
    print("hapax-codex: missing preflight-proven Codex OAuth token handoff; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
    sys.exit(78)
token_path=os.path.expanduser(token_handoff)
try:
    token_blob=open(token_path,encoding="utf-8").read().strip()
except OSError:
    print("hapax-codex: missing preflight-proven Codex OAuth token handoff at "+token_path+"; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
    sys.exit(78)
try:
    os.unlink(token_path)
except OSError as exc:
    print("hapax-codex: failed to delete preflight-proven Codex OAuth token handoff at "+token_path+" ("+exc.__class__.__name__+"); next action: remove the handoff file on the dispatch host before retrying", file=sys.stderr)
    sys.exit(78)
token=_unseal_token(token_blob,p.get("token_handoff_seal_key") or "")
if not token:
    print("hapax-codex: preflight-proven Codex OAuth token handoff is absent; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
    sys.exit(78)
if _jwt_exp(token) - time.time() <= 300:
    print("hapax-codex: preflight-proven Codex OAuth token handoff is expiring; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
    sys.exit(78)
os.environ["CODEX_ACCESS_TOKEN"]=token
if proof:
    os.makedirs(os.path.dirname(proof), exist_ok=True)
    data={"schema_version":1,"event":"dispatch_remote_exec","platform":"codex","session":p.get("session"),"task_id":p.get("task_id"),"requested_host":p.get("requested_host"),"actual_host":socket.gethostname(),"pid":os.getpid(),"cgroup":cgroup,"tmux_name":p.get("tmux_name"),"workdir":p.get("workdir"),"logos_base_url":os.environ.get("LOGOS_BASE_URL"),"argv0":p["argv"][0] if p.get("argv") else None,"argc":len(p.get("argv",[]))}; open(proof,"w",encoding="utf-8").write(json.dumps(data,sort_keys=True)+"\n")
argv=p["argv"]; os.execvp(argv[0], argv)'
REMOTE_TOKEN_CLEANUP_PY='import base64,json,os,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); path=os.path.expanduser(p.get("path") or "");
# token_handoff_cleanup: unlink only the governed short-lived handoff path.
path=os.path.abspath(path) if path else ""
if not path or os.path.dirname(path)!="/tmp" or not os.path.basename(path).startswith("hapax-codex-token-"):
    print("hapax-codex: refusing invalid Codex OAuth token handoff cleanup path "+(path or "<empty>"), file=sys.stderr)
    sys.exit(78)
try:
    os.unlink(path)
except FileNotFoundError:
    pass
sys.exit(0)'

cleanup_remote_token_handoff() {
  if [ "${REMOTE_TOKEN_HANDOFF_CREATED:-0}" != "1" ]; then
    return 0
  fi
  if [ -z "${REMOTE_TOKEN_HANDOFF:-}" ]; then
    return 0
  fi
  local cleanup_host="${DISPATCH_HOST:-${DISPATCH_HOST_REQUESTED:-}}"
  if [ -z "$cleanup_host" ]; then
    return 0
  fi
  local cleanup_payload="" cleanup_command=""
  cleanup_payload="$(remote_token_cleanup_payload_b64)"
  cleanup_command="$(remote_python_command "$cleanup_payload" "$REMOTE_TOKEN_CLEANUP_PY")"
  if ! ssh -o BatchMode=yes -o ConnectTimeout=2 -i "$HOME/.ssh/id_ed25519" \
    -o ControlPath="$HOME/.ssh/cm-%r@%h:%p" "$cleanup_host" \
    "$cleanup_command" >/dev/null 2>&1; then
    echo "hapax-codex: failed to delete preflight-proven Codex OAuth token handoff at $REMOTE_TOKEN_HANDOFF; next action: remove the handoff file on the dispatch host before retrying" >&2
  fi
  REMOTE_TOKEN_HANDOFF_CREATED=0
}

write_local_dispatch_proof() {
  local actual_host="$1" fallback="$2" reason="${3:-}" runner="${4:-}" pane_pid="" cgroup=""
  local proof_file="${DISPATCH_LOCAL_PROOF_FILE:-${DISPATCH_PROOF_FILE:-}}"
  [ -n "$proof_file" ] || return 0
  mkdir -p "$(dirname "$proof_file")" 2>/dev/null || return 0
  if [ -n "${TMUX_BIN:-}" ] && [ -n "${TMUX_NAME:-}" ]; then
    pane_pid="$("$TMUX_BIN" list-panes -t "$TMUX_NAME" -F '#{pane_pid}' 2>/dev/null | sed -n '1p' || true)"
  fi
  cgroup="$(cat /proc/self/cgroup 2>/dev/null || true)"
  python3 - "$proof_file" "$SESSION" "${TASK_ID:-}" "${DISPATCH_HOST_REQUESTED:-}" \
    "$actual_host" "$fallback" "$reason" "${TMUX_NAME:-}" "$pane_pid" "$WORKDIR" "$runner" \
    "$LOGOS_BASE_URL" "$cgroup" <<'PYEOF'
import json
import sys

(
    proof_file,
    session,
    task_id,
    requested_host,
    actual_host,
    fallback,
    reason,
    tmux_name,
    pane_pid,
    workdir,
    runner,
    logos_url,
    cgroup,
) = sys.argv[1:14]
payload = {
    "schema_version": 1,
    "event": "dispatch_local_exec",
    "platform": "codex",
    "session": session,
    "task_id": task_id,
    "requested_host": requested_host,
    "actual_host": actual_host,
    "fallback": fallback == "1",
    "fallback_reason": reason or None,
    "pid": None,
    "cgroup": cgroup,
    "tmux_name": tmux_name or None,
    "tmux_pane_pid": pane_pid or None,
    "workdir": workdir,
    "runner": runner or None,
    "logos_base_url": logos_url,
}
with open(proof_file, "w", encoding="utf-8") as fh:
    fh.write(json.dumps(payload, sort_keys=True) + "\n")
PYEOF
}

preflight_claimable_task() {
  local task_id="$1"
  local session="$2"
  local vault_root="${HAPAX_CC_TASK_ROOT:-$HOME/Documents/Personal/20-projects/hapax-cc-tasks}"

  if ! command -v python3 >/dev/null 2>&1; then
    echo "hapax-codex: python3 missing; cannot verify claimable task" >&2
    exit 3
  fi

  python3 - "$vault_root" "$task_id" "$session" <<'PYEOF'
import re
import sys
from pathlib import Path

vault_root, task_id, session = Path(sys.argv[1]), sys.argv[2], sys.argv[3]
active_root = vault_root / "active"
note_path = None

for candidate in active_root.glob(f"{task_id}-*.md"):
    if candidate.is_file():
        note_path = candidate
        break

exact = active_root / f"{task_id}.md"
if note_path is None and exact.is_file():
    note_path = exact

if note_path is None:
    print(
        f"hapax-codex: task '{task_id}' not found in {active_root}/",
        file=sys.stderr,
    )
    print(f"browse offered tasks: {vault_root}/_dashboard/cc-offered.md", file=sys.stderr)
    sys.exit(2)

text = note_path.read_text(encoding="utf-8")
status_match = re.search(r"^status:\s*(\S+)$", text, flags=re.MULTILINE)
status = status_match.group(1) if status_match else ""
assigned_match = re.search(r"^assigned_to:[ \t]*(.*)$", text, flags=re.MULTILINE)
assigned = assigned_match.group(1).strip().strip('"').strip("'") if assigned_match else "unassigned"
nullish = {"", "null", "none", "~", "[]"}

if status == "offered":
    if assigned != "unassigned" and assigned.lower() not in nullish:
        print(
            f"hapax-codex: refusing to spawn task '{task_id}' - already assigned to "
            f"'{assigned}'",
            file=sys.stderr,
        )
        sys.exit(4)
elif status in {"pr_open", "merge_queue"}:
    if assigned != session:
        printable_assigned = assigned or "unassigned"
        print(
            f"hapax-codex: refusing to spawn task '{task_id}' - ready-state task is "
            f"assigned to '{printable_assigned}', not '{session}'",
            file=sys.stderr,
        )
        sys.exit(4)
else:
    printable = status or "missing"
    print(
        f"hapax-codex: refusing to spawn task '{task_id}' - current status is "
        f"'{printable}', not 'offered' or an assigned ready state",
        file=sys.stderr,
    )
    sys.exit(4)
PYEOF
}

SESSION=""
SLOT=""
WORKDIR=""
WORKDIR_EXPLICIT=0
TASK_ID=""
BOOTSTRAP_FILE=""
TERMINAL="${HAPAX_CODEX_TERMINAL:-none}"
TASK_GATE=0
CLAIM_TASK=1
FORCE=0
CODEX_EXTRA=()

while [ $# -gt 0 ]; do
  case "$1" in
    --session|--thread|--name)
      SESSION="${2:-}"
      shift 2
      ;;
    --session=*|--thread=*|--name=*)
      SESSION="${1#*=}"
      shift
      ;;
    --slot)
      SLOT="${2:-}"
      shift 2
      ;;
    --slot=*)
      SLOT="${1#--slot=}"
      shift
      ;;
    --role)
      if hapax_agent_is_codex_name "${2:-}"; then
        SESSION="${2:-}"
      else
        SLOT="${2:-}"
      fi
      shift 2
      ;;
    --role=*)
      value="${1#--role=}"
      if hapax_agent_is_codex_name "$value"; then
        SESSION="$value"
      else
        SLOT="$value"
      fi
      shift
      ;;
    --cd|-C)
      WORKDIR="${2:-}"
      WORKDIR_EXPLICIT=1
      shift 2
      ;;
    --cd=*)
      WORKDIR="${1#--cd=}"
      WORKDIR_EXPLICIT=1
      shift
      ;;
    --task)
      TASK_ID="${2:-}"
      shift 2
      ;;
    --task=*)
      TASK_ID="${1#--task=}"
      shift
      ;;
    --bootstrap)
      BOOTSTRAP_FILE="${2:-}"
      shift 2
      ;;
    --bootstrap=*)
      BOOTSTRAP_FILE="${1#--bootstrap=}"
      shift
      ;;
    --terminal)
      TERMINAL="${2:-}"
      shift 2
      ;;
    --terminal=*)
      TERMINAL="${1#--terminal=}"
      shift
      ;;
    --task-gate)
      TASK_GATE=1
      shift
      ;;
    --no-claim)
      CLAIM_TASK=0
      shift
      ;;
    --force)
      FORCE=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      CODEX_EXTRA+=("$@")
      break
      ;;
    cx-*)
      if [ -z "$SESSION" ]; then
        SESSION="$1"
      else
        CODEX_EXTRA+=("$1")
      fi
      shift
      ;;
    alpha|beta|delta|epsilon)
      if [ -z "$SLOT" ]; then
        SLOT="$1"
      else
        CODEX_EXTRA+=("$1")
      fi
      shift
      ;;
    *)
      CODEX_EXTRA+=("$1")
      shift
      ;;
  esac
done

if [ -z "$SESSION" ]; then
  SESSION="${HAPAX_AGENT_NAME:-${CODEX_THREAD_NAME:-${CODEX_SESSION_NAME:-${CODEX_SESSION:-${CODEX_ROLE:-}}}}}"
fi
if [ -z "$SESSION" ]; then
  SESSION="${CODEX_DEFAULT_THREAD_NAME:-cx-blue}"
fi

if ! hapax_agent_is_codex_name "$SESSION"; then
  echo "hapax-codex: invalid session '$SESSION' (expected cx-<color>)" >&2
  exit 2
fi

if [ -z "$SLOT" ]; then
  if declare -F hapax_agent_worktree_role >/dev/null 2>&1; then
    SLOT="$(hapax_agent_worktree_role_or_default alpha)"
  else
    SLOT="alpha"
  fi
fi

case "$SLOT" in
  alpha|beta|delta|epsilon) ;;
  *)
    echo "hapax-codex: invalid slot '$SLOT'" >&2
    exit 2
    ;;
esac

case "$TERMINAL" in
  none|tmux|foot) ;;
  *)
    echo "hapax-codex: invalid terminal '$TERMINAL'" >&2
    exit 2
    ;;
esac

CODEX_WORKTREE_STRATEGY="explicit"
if [ -z "$WORKDIR" ]; then
  WORKDIR="$(codex_default_worktree_path "$SESSION" "$SLOT")"
  if [ "$WORKDIR" = "$HOME/projects/hapax-council" ]; then
    CODEX_WORKTREE_STRATEGY="primary"
  else
    CODEX_WORKTREE_STRATEGY="codex-native"
  fi
fi

if [ ! -d "$WORKDIR" ] && [ "$WORKDIR_EXPLICIT" -eq 0 ] && [ "$CODEX_WORKTREE_STRATEGY" = "codex-native" ]; then
  if ! ensure_codex_worktree "$WORKDIR" "$SESSION"; then
    echo "hapax-codex: codex-native worktree missing and could not be created: $WORKDIR" >&2
    echo "  session=$SESSION slot=$SLOT strategy=$CODEX_WORKTREE_STRATEGY" >&2
    exit 3
  fi
fi

if [ -z "$WORKDIR" ] || [ ! -d "$WORKDIR" ]; then
  echo "hapax-codex: no worktree found for session '$SESSION' slot '$SLOT' at $WORKDIR" >&2
  exit 3
fi
WORKDIR="$(cd "$WORKDIR" && pwd)"
export HAPAX_CODEX_WORKTREE_STRATEGY="$CODEX_WORKTREE_STRATEGY"

PARENT_INTERFACE="${HAPAX_PARENT_AGENT_INTERFACE:-${HAPAX_AGENT_INTERFACE:-unknown}}"
PARENT_NAME="${HAPAX_PARENT_AGENT_NAME:-${HAPAX_AGENT_NAME:-${CODEX_THREAD_NAME:-${CODEX_ROLE:-unknown}}}}"

# Per-session id (coordination reform Phase 1): stable uuid so the gate keys a
# claim lease to THIS session — two same-role sessions never collide (FM-2).
SESSION_UUID="$(normalize_session_uuid "${HAPAX_SESSION_ID:-}")"
TMUX_NAME="hapax-codex-$SESSION"
DISPATCH_HOST_REQUESTED="${HAPAX_DISPATCH_HOST:-}"
DISPATCH_HOST=""
DISPATCH_FALLBACK_REASON=""
DISPATCH_PROOF_DIR="${HAPAX_DISPATCH_PROOF_DIR:-$HOME/.cache/hapax/orchestration/dispatch-host-proofs}"
DISPATCH_PROOF_BASENAME="$(date -u +%Y%m%dT%H%M%SZ)-$(slugify "$SESSION")-$(slugify "${TASK_ID:-no-task}")"
DISPATCH_PROOF_FILE="$DISPATCH_PROOF_DIR/$DISPATCH_PROOF_BASENAME-remote.json"
DISPATCH_LOCAL_PROOF_FILE="$DISPATCH_PROOF_DIR/$DISPATCH_PROOF_BASENAME-local.json"
REMOTE_TOKEN_HANDOFF=""
REMOTE_TOKEN_HANDOFF_CREATED=0

if [ -n "$DISPATCH_HOST_REQUESTED" ]; then
  if dispatch_host_is_local "$DISPATCH_HOST_REQUESTED"; then
    DISPATCH_HOST_REQUESTED=""
  else
    PREFLIGHT_PAYLOAD="$(remote_preflight_payload_b64 "")"
    PREFLIGHT_COMMAND="$(remote_python_command "$PREFLIGHT_PAYLOAD" "$REMOTE_PREFLIGHT_PY")"
    if ssh -o BatchMode=yes -o ConnectTimeout=4 -i "$HOME/.ssh/id_ed25519" \
        -o ControlPath="$HOME/.ssh/cm-%r@%h:%p" "$DISPATCH_HOST_REQUESTED" \
        "$PREFLIGHT_COMMAND"; then
      DISPATCH_HOST="$DISPATCH_HOST_REQUESTED"
      echo "hapax-codex: dispatch -> $DISPATCH_HOST (codex on appendix; tmux/control podium-local)" >&2
    elif [ "${HAPAX_DISPATCH_HOST_FALLBACK:-}" = "local" ]; then
      DISPATCH_FALLBACK_REASON="dispatch_host_unready:$DISPATCH_HOST_REQUESTED"
      echo "hapax-codex: dispatch_host_unready ($DISPATCH_HOST_REQUESTED) -- explicit local fallback" >&2
    else
      LOGOS_BASE_URL="${LOGOS_BASE_URL:-http://localhost:8051/api}"
      COCKPIT_BASE_URL="${COCKPIT_BASE_URL:-$LOGOS_BASE_URL}"
      write_local_dispatch_proof "local" "1" "dispatch_host_unready:$DISPATCH_HOST_REQUESTED"
      echo "hapax-codex: dispatch_host_unready ($DISPATCH_HOST_REQUESTED) -- refusing local fallback without HAPAX_DISPATCH_HOST_FALLBACK=local" >&2
      exit 75
    fi
  fi
fi

if [ -n "$DISPATCH_HOST" ]; then
  LOGOS_BASE_URL="${HAPAX_DISPATCH_LOGOS_URL:-http://192.168.68.85:8051/api}"
else
  LOGOS_BASE_URL="${LOGOS_BASE_URL:-http://localhost:8051/api}"
fi
COCKPIT_BASE_URL="${COCKPIT_BASE_URL:-$LOGOS_BASE_URL}"

CODEX_BIN=""
if [ -z "$DISPATCH_HOST" ]; then
  CODEX_BIN="$(command -v codex || true)"
  if [ -z "$CODEX_BIN" ]; then
    # PATH lookup missed codex. A common cause is a thin systemd-unit PATH (e.g.
    # hapax-lane-supervisor) that omits ~/.npm-global/bin, where `npm i -g
    # @openai/codex` installs the launcher — the rc=4 "codex not found" respawn-loop
    # root cause. Fall back to the usual npm-global install locations so any
    # thin-PATH caller can still resolve codex.
    for _cand in \
      "${HAPAX_CODEX_BIN_PATH:-}" \
      "$HOME/.npm-global/bin/codex" \
      "${NPM_CONFIG_PREFIX:+$NPM_CONFIG_PREFIX/bin/codex}" \
      "$HOME/.local/share/npm/bin/codex" \
      "/usr/local/bin/codex"; do
      if [ -n "$_cand" ] && [ -x "$_cand" ]; then
        CODEX_BIN="$_cand"
        break
      fi
    done
  fi
  if [ -z "$CODEX_BIN" ]; then
    echo "hapax-codex: codex not found in PATH" >&2
    exit 4
  fi
else
  CODEX_BIN="codex"
fi

TMUX_BIN=""
FOOT_BIN=""
FOOT_COLOR_THEME=""
case "$TERMINAL" in
  tmux)
    TMUX_BIN="$(command -v tmux || true)"
    if [ -z "$TMUX_BIN" ]; then
      echo "hapax-codex: tmux not found" >&2
      exit 10
    fi
    if "$TMUX_BIN" has-session -t "$TMUX_NAME" 2>/dev/null && [ "$FORCE" -ne 1 ]; then
      echo "hapax-codex: tmux session already exists: $TMUX_NAME" >&2
      exit 11
    fi
    ;;
  foot)
    FOOT_BIN="$(command -v foot || command -v footclient || true)"
    if [ -z "$FOOT_BIN" ]; then
      echo "hapax-codex: footclient/foot not found" >&2
      exit 10
    fi
    TMUX_BIN="$(command -v tmux || true)"
    if [ -z "$TMUX_BIN" ]; then
      echo "hapax-codex: tmux not found; visible Codex sessions require tmux backing" >&2
      exit 10
    fi
    if "$TMUX_BIN" has-session -t "$TMUX_NAME" 2>/dev/null && [ "$FORCE" -ne 1 ]; then
      echo "hapax-codex: tmux session already exists: $TMUX_NAME" >&2
      exit 11
    fi
    FOOT_COLOR_THEME="$(foot_color_theme_for_current_mode)"
    ;;
esac

assert_protected_terminal_launch_allowed "$SESSION" "$TERMINAL"

if [ "$FORCE" -ne 1 ]; then
  if relay_retired "$SESSION"; then
    RELAY_STATUS_FILE="${HAPAX_RELAY_DIR:-$HOME/.cache/hapax/relay}/$SESSION.yaml"
    echo "hapax-codex: relay '$SESSION' is retired/wound-down ($RELAY_STATUS_FILE); recheck: sed -n '1,80p' \"$RELAY_STATUS_FILE\"; pass --force to reactivate (P0 drain lanes do this automatically)" >&2
    exit 6
  fi
fi

export HAPAX_AGENT_INTERFACE="codex"
export HAPAX_AGENT_NAME="$SESSION"
export CODEX_THREAD_NAME="$SESSION"
export CODEX_ROLE="$SESSION"
export HAPAX_AGENT_ROLE="$SESSION"
export HAPAX_AGENT_SLOT="$SLOT"
export HAPAX_WORKTREE_ROLE="$SLOT"
export HAPAX_SESSION_ID="$SESSION_UUID"
export CLAUDE_ROLE="${CLAUDE_ROLE:-$SESSION}"
export HAPAX_IDLE_UPDATE_SECONDS="${HAPAX_IDLE_UPDATE_SECONDS:-270}"
export PASSWORD_STORE_DIR="${PASSWORD_STORE_DIR:-$HOME/.password-store}"
export LOGOS_BASE_URL
export COCKPIT_BASE_URL
export HAPAX_CC_TASK_GATE="$TASK_GATE"

if [ -n "$TASK_ID" ] && [ "$CLAIM_TASK" -eq 1 ]; then
  CLAIM_SCRIPT="$WORKDIR/scripts/cc-claim"
  if [ ! -x "$CLAIM_SCRIPT" ]; then
    echo "hapax-codex: cannot claim task from selected worktree; missing executable $CLAIM_SCRIPT" >&2
    exit 8
  fi
  if [ "$TERMINAL" = "none" ]; then
    "$CLAIM_SCRIPT" "$TASK_ID"
  elif [ -n "$DISPATCH_HOST" ]; then
    "$CLAIM_SCRIPT" "$TASK_ID" >/dev/null
  else
    preflight_claimable_task "$TASK_ID" "$SESSION"
  fi
fi

if [ -n "$DISPATCH_HOST" ]; then
  # Do not even name a remote bearer handoff until every local guard that can
  # refuse the launch has passed. The early host preflight proves readiness with
  # an empty handoff path; the bearer file is created just-in-time before remote
  # exec and then consumed or cleaned.
  REMOTE_TOKEN_HANDOFF="/tmp/hapax-codex-token-$(token_handoff_component "$SESSION_UUID")-$$"
  REMOTE_TOKEN_HANDOFF_SEAL_KEY="$(remote_token_handoff_seal_key)"
  export HAPAX_REMOTE_TOKEN_HANDOFF="$REMOTE_TOKEN_HANDOFF"
  export HAPAX_REMOTE_TOKEN_HANDOFF_SEAL_KEY="$REMOTE_TOKEN_HANDOFF_SEAL_KEY"
  trap cleanup_remote_token_handoff EXIT
fi

SPAWN_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/hapax/codex-spawns"
mkdir -p "$SPAWN_DIR"

explicit_codex_command=0
if [ "${#CODEX_EXTRA[@]}" -gt 0 ] && is_codex_subcommand "${CODEX_EXTRA[0]}"; then
  explicit_codex_command=1
fi

if [ "${#CODEX_EXTRA[@]}" -gt 0 ]; then
  case "${CODEX_EXTRA[0]}" in
    apply|a)
      if [ "${HAPAX_METHODOLOGY_EMERGENCY:-0}" != "1" ]; then
        cat >&2 <<EOF
hapax-codex: refusing mutation-capable 'codex apply' without governed emergency escape.
  Required: HAPAX_METHODOLOGY_EMERGENCY=1
  Prefer normal task-gated source edits inside an active Codex session.
EOF
        exit 13
      fi
      _ledger="$HOME/.cache/hapax/methodology-emergency-ledger.jsonl"
      mkdir -p "$(dirname "$_ledger")" 2>/dev/null || true
      printf '{"ts":"%s","session":"%s","hook":"hapax-codex","cmd":"codex %s","reason":"codex_apply_emergency"}\n' \
        "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$SESSION" "${CODEX_EXTRA[0]}" \
        >>"$_ledger" 2>/dev/null || true
      ;;
  esac
fi

if [ -n "$BOOTSTRAP_FILE" ]; then
  if [ ! -f "$BOOTSTRAP_FILE" ]; then
    echo "hapax-codex: bootstrap file not found: $BOOTSTRAP_FILE" >&2
    exit 9
  fi
  BOOTSTRAP_FILE="$(cd "$(dirname "$BOOTSTRAP_FILE")" && pwd)/$(basename "$BOOTSTRAP_FILE")"
elif { [ -n "$TASK_ID" ] || [ "$TERMINAL" != "none" ]; } && [ "$explicit_codex_command" -eq 0 ]; then
  stamp="$(date -u +%Y%m%dT%H%M%SZ)"
  task_slug="$(slugify "${TASK_ID:-no-task}")"
  session_slug="$(slugify "$SESSION")"
  BOOTSTRAP_FILE="$SPAWN_DIR/$stamp-$session_slug-$task_slug.md"
  cat >"$BOOTSTRAP_FILE" <<EOF
# Hapax Codex Spawn Bootstrap

- parent_interface: $PARENT_INTERFACE
- parent_session: $PARENT_NAME
- session: $SESSION
- slot: $SLOT
- cwd: $WORKDIR
- worktree_strategy: $CODEX_WORKTREE_STRATEGY
- primary_council_dir: $COUNCIL_DIR
- idle_update_seconds: $HAPAX_IDLE_UPDATE_SECONDS
- task_id: ${TASK_ID:-none}
- task_gate: $TASK_GATE

First actions:

1. Read $HOME/projects/CLAUDE.md, $COUNCIL_DIR/CLAUDE.md, $COUNCIL_DIR/AGENTS.md, $WORKDIR/CLAUDE.md, and $WORKDIR/AGENTS.md when present. Parent AGENTS/posture files are authoritative when the clean child worktree is behind the bootstrap branch.
2. Treat $WORKDIR as the Codex worktree for this thread. Greek slot names are coordination lanes, not Codex worktree names; do not migrate work into Claude-era hapax-council--delta/epsilon/main-red paths unless the parent explicitly passed --cd.
3. Read the parent Codex posture from $COUNCIL_DIR even when the target worktree is stale or detached: $COUNCIL_DIR/scripts/hapax-codex, $COUNCIL_DIR/config/codex/config.toml, $COUNCIL_DIR/hooks/scripts/codex-hook-adapter.sh, and $COUNCIL_DIR/hooks/scripts/agent-role.sh.
4. Read the active task note if task_id is not "none".
5. Read ~/.cache/hapax/relay/$SESSION.yaml and ~/.cache/hapax/relay/$SLOT.yaml when present, then inspect current relay/path claims before edits.
6. Before claims or edits, write a relay/preflight note with branch, head commit, dirty count, Codex version, MCP startup warnings, and the exact evidence commands you intend to rely on.
7. When not actively producing (blocked, waiting on CI/MCP/tools, or idle), check parent/user/relay updates every $HAPAX_IDLE_UPDATE_SECONDS seconds and write a concise relay/status update if the wait continues. Ignore timestamp-only changes such as checked_at/updated when deciding whether there is substantive new work.
8. For headless worker lanes, Obsidian is the operator-visible plane: keep ~/Documents/Personal/20-projects/hapax-cc-tasks/_dashboard/codex-session-health.md, relay YAML, active claim, and PR state accurate. Screen visibility is required for cx-red and protected cx-violet only.
9. Keep work scoped to the task and report changed files, tests, health snapshots, command outputs or artifact paths, and blockers before exit.

Coordination rules:

- Single operator only.
- Use pass and child MCP wrappers for credentials; do not print secret values.
- Use scripts/hapax-codex for child Codex sessions; do not introduce a parallel Claude launcher.
- Use scripts/hapax-codex-send --require-ack for load-bearing parent-to-child instructions; it prefers the tmux-backed channel and verifies receipt with an ACK.
- Maintain Obsidian cc-task and relay discipline.
- Treat implemented features that remain dormant, unshipped, or off by default as baseline defects unless a concrete external blocker is documented; prefer fixing the blocker and shipping.
- Do not claim a persistent watch timer unless you are actively running a loop; after a final response, the session is idle, not watching.
- When the parent says baseline clean/regroup/stop, mark relay status regrouping/no-new-work or RETIRED, stop claiming tasks, and wait for explicit direction.
EOF

  DOSSIER_HELPER="$COUNCIL_DIR/scripts/codex-operator-dossier-context.py"
  {
    printf '\n'
    if [ -x "$DOSSIER_HELPER" ]; then
      "$DOSSIER_HELPER" || {
        printf '%s\n' '## Codex-Visible Operator Dossier'
        printf '\n'
        printf '%s\n' '- status: unavailable'
        printf '%s\n' "- source: $DOSSIER_HELPER"
        printf '%s\n' '- reason: dossier renderer failed'
        printf '%s\n' '- fallback: Use the explicit user message, CLAUDE.md, AGENTS.md, cc-task note, and relay state only.'
      }
    else
      printf '%s\n' '## Codex-Visible Operator Dossier'
      printf '\n'
      printf '%s\n' '- status: unavailable'
      printf '%s\n' "- source: $DOSSIER_HELPER"
      printf '%s\n' '- reason: dossier renderer missing or not executable'
      printf '%s\n' '- fallback: Use the explicit user message, CLAUDE.md, AGENTS.md, cc-task note, and relay state only.'
    fi
  } >>"$BOOTSTRAP_FILE"
fi

# Keep the long-lived Codex session from becoming a credential sink. MCP
# wrappers resolve their own tokens at server start via pass/gh/legacy config.
unset GITHUB_PERSONAL_ACCESS_TOKEN
unset CODEX_GITHUB_PERSONAL_ACCESS_TOKEN
unset TAVILY_API_KEY
unset CONTEXT7_API_KEY

MCP_CONFIG_SCRUB="$COUNCIL_DIR/scripts/hapax-codex-mcp-config-scrub"
if [ -x "$MCP_CONFIG_SCRUB" ]; then
  "$MCP_CONFIG_SCRUB"
fi

maybe_load_local_codex_access_token

HOOK="$COUNCIL_DIR/hooks/scripts/codex-hook-adapter.sh"
if [ ! -x "$HOOK" ]; then
  echo "hapax-codex: hook adapter is not executable: $HOOK" >&2
  exit 5
fi

append_bootstrap_prompt=0
if [ -n "$BOOTSTRAP_FILE" ] && [ "$explicit_codex_command" -eq 0 ]; then
  if [ "${#CODEX_EXTRA[@]}" -eq 0 ]; then
    append_bootstrap_prompt=1
  else
    case "${CODEX_EXTRA[0]}" in
      -*)
        append_bootstrap_prompt=1
        ;;
    esac
  fi
fi

CODEX_ARGS=(
  --dangerously-bypass-approvals-and-sandbox
  --cd "$WORKDIR"
  -c 'model="gpt-5.5"'
  -c 'model_reasoning_effort="xhigh"'
  -c 'approval_policy="never"'
  -c 'sandbox_mode="danger-full-access"'
  -c "projects.\"$HOME/projects\".trust_level=\"trusted\""
  -c "projects.\"$WORKDIR\".trust_level=\"trusted\""
  -c "hooks.SessionStart=[{command=\"$HOOK\",timeout=20,statusMessage=\"Loading Hapax context\"}]"
  -c "hooks.PreToolUse=[{command=\"$HOOK\",timeout=20,include_apply_patch_tool=true,statusMessage=\"Hapax guardrails\"}]"
  -c "hooks.PostToolUse=[{command=\"$HOOK\",timeout=20,include_apply_patch_tool=true,statusMessage=\"Hapax audit\"}]"
  -c "hooks.Stop=[{command=\"$HOOK\",timeout=20,statusMessage=\"Writing Hapax session summary\"}]"
  -c "mcp_servers.hapax.command=\"$HOME/.local/bin/uv\""
  -c "mcp_servers.hapax.args=[\"--directory\",\"$HOME/projects/hapax-mcp\",\"run\",\"hapax-mcp\"]"
  -c "mcp_servers.hapax.env.LOGOS_BASE_URL=\"$LOGOS_BASE_URL\""
  -c "mcp_servers.context7.command=\"$COUNCIL_DIR/scripts/hapax-context7-mcp\""
  -c "mcp_servers.github.command=\"$COUNCIL_DIR/scripts/hapax-github-mcp\""
  -c "mcp_servers.playwright.command=\"$COUNCIL_DIR/scripts/hapax-playwright-mcp\""
  -c "mcp_servers.tavily.command=\"$COUNCIL_DIR/scripts/hapax-tavily-mcp\""
  "${CODEX_EXTRA[@]}"
)

if [ "$append_bootstrap_prompt" -eq 1 ]; then
  CODEX_ARGS+=("Bootstrap file: $BOOTSTRAP_FILE")
fi

if [ "$TERMINAL" = "none" ]; then
  if [ -n "$DISPATCH_HOST" ]; then
    REMOTE_EXEC_PREFLIGHT_PAYLOAD="$(remote_preflight_payload_b64 "$REMOTE_TOKEN_HANDOFF")"
    REMOTE_EXEC_PREFLIGHT_COMMAND="$(remote_python_command "$REMOTE_EXEC_PREFLIGHT_PAYLOAD" "$REMOTE_PREFLIGHT_PY")"
    if ! ssh -o BatchMode=yes -o ConnectTimeout=4 -i "$HOME/.ssh/id_ed25519" \
        -o ControlPath="$HOME/.ssh/cm-%r@%h:%p" "$DISPATCH_HOST" \
        "$REMOTE_EXEC_PREFLIGHT_COMMAND"; then
      echo "hapax-codex: remote token handoff preflight failed for $DISPATCH_HOST; next action: ssh to the dispatch host and run the codex OAuth refresher or reauth, then retry" >&2
      exit 75
    fi
    REMOTE_TOKEN_HANDOFF_CREATED=1
    REMOTE_EXEC_PAYLOAD="$(remote_exec_payload_b64 "$DISPATCH_PROOF_FILE" codex "${CODEX_ARGS[@]}")"
    REMOTE_EXEC_COMMAND="$(remote_python_command "$REMOTE_EXEC_PAYLOAD" "$REMOTE_EXEC_PY")"
    if ssh -o BatchMode=yes -o RequestTTY=no -o ServerAliveInterval=30 -o ServerAliveCountMax=6 \
      -o ControlPath=none -i "$HOME/.ssh/id_ed25519" "$DISPATCH_HOST" "$REMOTE_EXEC_COMMAND"
    then
      REMOTE_EXIT_CODE=0
    else
      REMOTE_EXIT_CODE=$?
    fi
    cleanup_remote_token_handoff
    exit "$REMOTE_EXIT_CODE"
  fi
  if [ -n "$DISPATCH_FALLBACK_REASON" ]; then
    write_local_dispatch_proof "$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf local)" "1" "$DISPATCH_FALLBACK_REASON"
  fi
  exec "$CODEX_BIN" "${CODEX_ARGS[@]}"
fi

FOOT_TARGET_WORKSPACE=""
if [ "$TERMINAL" = "foot" ]; then
  FOOT_TARGET_WORKSPACE="$(active_hyprland_workspace_name || true)"
fi

RUNNER="$SPAWN_DIR/run-$(date -u +%Y%m%dT%H%M%SZ)-$(slugify "$SESSION").sh"
CHILD_ARGS=(--session "$SESSION" --slot "$SLOT" --cd "$WORKDIR" --terminal none)
if [ "$FORCE" -eq 1 ]; then
  CHILD_ARGS+=(--force)
fi
if [ "$CLAIM_TASK" -eq 0 ]; then
  CHILD_ARGS+=(--no-claim)
fi
if [ "$TASK_GATE" -eq 1 ]; then
  CHILD_ARGS+=(--task-gate)
fi
if [ -n "$TASK_ID" ]; then
  CHILD_ARGS+=(--task "$TASK_ID")
fi
if [ -n "$BOOTSTRAP_FILE" ]; then
  CHILD_ARGS+=(--bootstrap "$BOOTSTRAP_FILE")
fi
CHILD_ARGS+=(--)
CHILD_ARGS+=("${CODEX_EXTRA[@]}")

RELAY_RETIRE="$COUNCIL_DIR/scripts/hapax-relay-retire"
if [ -n "$DISPATCH_HOST" ]; then
  REMOTE_EXEC_PREFLIGHT_PAYLOAD="$(remote_preflight_payload_b64 "$REMOTE_TOKEN_HANDOFF")"
  REMOTE_EXEC_PREFLIGHT_COMMAND="$(remote_python_command "$REMOTE_EXEC_PREFLIGHT_PAYLOAD" "$REMOTE_PREFLIGHT_PY")"
  REMOTE_EXEC_PAYLOAD="$(remote_exec_payload_b64 "$DISPATCH_PROOF_FILE" codex "${CODEX_ARGS[@]}")"
  REMOTE_EXEC_COMMAND="$(remote_python_command "$REMOTE_EXEC_PAYLOAD" "$REMOTE_EXEC_PY")"
  REMOTE_TOKEN_CLEANUP_PAYLOAD="$(remote_token_cleanup_payload_b64)"
  REMOTE_TOKEN_CLEANUP_COMMAND="$(remote_python_command "$REMOTE_TOKEN_CLEANUP_PAYLOAD" "$REMOTE_TOKEN_CLEANUP_PY")"
  {
    printf '%s\n' '#!/usr/bin/env bash'
    printf '%s\n' 'set -euo pipefail'
    printf 'DISPATCH_HOST=%q\n' "$DISPATCH_HOST"
    printf 'REMOTE_TOKEN_HANDOFF=%q\n' "$REMOTE_TOKEN_HANDOFF"
    printf 'REMOTE_TOKEN_CLEANUP_COMMAND=%q\n' "$REMOTE_TOKEN_CLEANUP_COMMAND"
    printf 'RELAY_RETIRE=%q\n' "$RELAY_RETIRE"
    printf 'SESSION=%q\n' "$SESSION"
    cat <<'EOF'
REMOTE_TOKEN_HANDOFF_CREATED=0
cleanup_remote_token_handoff() {
  if [ "${REMOTE_TOKEN_HANDOFF_CREATED:-0}" != "1" ]; then
    return 0
  fi
  if ! ssh -o BatchMode=yes -o ConnectTimeout=2 -i "$HOME/.ssh/id_ed25519" \
    -o ControlPath="$HOME/.ssh/cm-%r@%h:%p" "$DISPATCH_HOST" \
    "$REMOTE_TOKEN_CLEANUP_COMMAND" >/dev/null 2>&1; then
    echo "hapax-codex: failed to delete preflight-proven Codex OAuth token handoff at $REMOTE_TOKEN_HANDOFF; next action: remove the handoff file on the dispatch host before retrying" >&2
  fi
  REMOTE_TOKEN_HANDOFF_CREATED=0
}
runner_cleanup() {
  rc=$?
  cleanup_remote_token_handoff
  "$RELAY_RETIRE" "$SESSION" --reason "clean exit (codex remote)" 2>/dev/null || true
  exit "$rc"
}
trap runner_cleanup EXIT
EOF
    printf 'export HAPAX_PARENT_AGENT_INTERFACE=%q\n' "$PARENT_INTERFACE"
    printf 'export HAPAX_PARENT_AGENT_NAME=%q\n' "$PARENT_NAME"
    printf 'export HAPAX_SESSION_ID=%q\n' "$SESSION_UUID"
    printf 'cd %q\n' "$WORKDIR"
    printf 'ssh'
    for arg in \
      -o BatchMode=yes \
      -o ConnectTimeout=4 \
      -i "$HOME/.ssh/id_ed25519" \
      -o "ControlPath=$HOME/.ssh/cm-%r@%h:%p" \
      "$DISPATCH_HOST" \
      "$REMOTE_EXEC_PREFLIGHT_COMMAND"; do
      printf ' %q' "$arg"
    done
    printf '\n'
    printf '%s\n' 'REMOTE_TOKEN_HANDOFF_CREATED=1'
    printf 'ssh'
    for arg in \
      -o BatchMode=yes \
      -o RequestTTY=no \
      -o ServerAliveInterval=30 \
      -o ServerAliveCountMax=6 \
      -o ControlPath=none \
      -i "$HOME/.ssh/id_ed25519" \
      "$DISPATCH_HOST" \
      "$REMOTE_EXEC_COMMAND"; do
      printf ' %q' "$arg"
    done
    printf '\n'
  } >"$RUNNER"
else
  {
    printf '%s\n' '#!/usr/bin/env bash'
    printf '%s\n' 'set -euo pipefail'
    printf 'trap '\''%q %q --reason "clean exit (codex)" 2>/dev/null || true'\'' EXIT\n' "$RELAY_RETIRE" "$SESSION"
    printf 'export HAPAX_PARENT_AGENT_INTERFACE=%q\n' "$PARENT_INTERFACE"
    printf 'export HAPAX_PARENT_AGENT_NAME=%q\n' "$PARENT_NAME"
    # Propagate the session id so the re-exec'd inner hapax-codex keeps ONE stable
    # uuid (reform Phase 1, FM-2) instead of minting a fresh one.
    printf 'export HAPAX_SESSION_ID=%q\n' "$SESSION_UUID"
    printf 'cd %q\n' "$WORKDIR"
    printf 'exec %q' "$COUNCIL_DIR/scripts/hapax-codex"
    for arg in "${CHILD_ARGS[@]}"; do
      printf ' %q' "$arg"
    done
    printf '\n'
  } >"$RUNNER"
fi
chmod 700 "$RUNNER"

case "$TERMINAL" in
  tmux)
    "$TMUX_BIN" new-session -d -s "$TMUX_NAME" -c "$WORKDIR" "$RUNNER"
    if [ -n "$DISPATCH_HOST_REQUESTED" ] || [ -n "$DISPATCH_HOST" ] || [ -n "$DISPATCH_FALLBACK_REASON" ]; then
      if [ -n "$DISPATCH_FALLBACK_REASON" ]; then
        write_local_dispatch_proof "$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf local)" "1" "$DISPATCH_FALLBACK_REASON" "$RUNNER"
      else
        write_local_dispatch_proof "$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf local)" "0" "" "$RUNNER"
      fi
    fi
    printf '%s\n' "$TMUX_NAME"
    ;;
  foot)
    if ! "$TMUX_BIN" has-session -t "$TMUX_NAME" 2>/dev/null; then
      "$TMUX_BIN" new-session -d -s "$TMUX_NAME" -c "$WORKDIR" "$RUNNER"
    fi
    if [ -n "$DISPATCH_HOST_REQUESTED" ] || [ -n "$DISPATCH_HOST" ] || [ -n "$DISPATCH_FALLBACK_REASON" ]; then
      if [ -n "$DISPATCH_FALLBACK_REASON" ]; then
        write_local_dispatch_proof "$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf local)" "1" "$DISPATCH_FALLBACK_REASON" "$RUNNER"
      else
        write_local_dispatch_proof "$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf local)" "0" "" "$RUNNER"
      fi
    fi
    case "$(basename "$FOOT_BIN")" in
      footclient)
        "$FOOT_BIN" -E -N -H \
          --override="initial-color-theme=$FOOT_COLOR_THEME" \
          --app-id "hapax-codex-$SESSION" \
          --title "$SESSION" \
          --working-directory "$WORKDIR" \
          "$TMUX_BIN" attach-session -t "$TMUX_NAME"
        move_foot_window_to_workspace "$SESSION" "$FOOT_TARGET_WORKSPACE"
        ;;
      *)
        setsid -f "$FOOT_BIN" -H \
          --override="initial-color-theme=$FOOT_COLOR_THEME" \
          --app-id "hapax-codex-$SESSION" \
          --title "$SESSION" \
          --working-directory "$WORKDIR" \
          "$TMUX_BIN" attach-session -t "$TMUX_NAME" >/dev/null 2>&1
        move_foot_window_to_workspace "$SESSION" "$FOOT_TARGET_WORKSPACE"
        ;;
    esac
    ;;
esac
