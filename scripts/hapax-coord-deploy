#!/usr/bin/env bash
# Deploy hapax-coord into the coord activation worktree and restart the yard
# only when origin/main changes.
set -euo pipefail

REPO="${HAPAX_COORD_DEPLOY_REPO:-/home/hapax/projects/hapax-coord}"
ACT_ROOT="${HAPAX_COORD_DEPLOY_ACT_ROOT:-$HOME/.cache/hapax/coord-activation}"
WT="$ACT_ROOT/worktree"
LOCK_PATH="${HAPAX_COORD_DEPLOY_LOCK:-$ACT_ROOT/deploy.lock}"
LOCK_WAIT_S="${HAPAX_COORD_DEPLOY_LOCK_WAIT_S:-120}"
SETUP_NEXT="next: verify HAPAX_COORD_DEPLOY_REPO points to a readable hapax-coord git checkout with origin/main, verify HAPAX_COORD_DEPLOY_ACT_ROOT is writable, then rerun scripts/hapax-coord-deploy"

if [ "${1:-}" = "--contract-json" ]; then
    printf '{"schema":1,"source_repo":"%s","activation_worktree":"%s","target_ref":"origin/main","single_writer_lock":"%s","stops_service_before_worktree_mutation":true,"writes_deployed_sha":true,"writes_deployed_sha_after_restart":true,"rolls_back_worktree_on_restart_failure":true,"rolls_back_worktree_on_clean_failure":true,"rolls_back_worktree_on_checkout_failure":true,"proves_rollback_clean_before_service_restart":true,"cleans_activation_worktree":true,"restarts_service":"hapax-coord.service"}\n' "$REPO" "$WT" "$LOCK_PATH"
    exit 0
fi

deploy_fail() {
    local label="$1"
    local rc="$2"
    local detail="$3"
    detail="${detail//$'\n'/; }"
    if [ -z "$detail" ]; then
        detail="no output"
    fi
    echo "coord-deploy: $label failed (rc=$rc): $detail; $SETUP_NEXT" >&2
    exit "$rc"
}

run_or_fail() {
    local label="$1"
    shift
    local out
    local rc
    if out="$("$@" 2>&1)"; then
        if [ -n "$out" ]; then
            printf '%s\n' "$out"
        fi
    else
        rc=$?
        deploy_fail "$label" "$rc" "$out"
    fi
}

capture_or_fail() {
    local label="$1"
    shift
    local out
    local rc
    if out="$("$@" 2>&1)"; then
        printf '%s' "$out"
    else
        rc=$?
        deploy_fail "$label" "$rc" "$out"
    fi
}

acquire_deploy_lock_or_fail() {
    exec 9>"$LOCK_PATH"
    if flock -w "$LOCK_WAIT_S" 9; then
        return 0
    fi
    echo "coord-deploy: deploy lock unavailable after ${LOCK_WAIT_S}s: $LOCK_PATH; another hapax-coord-deploy is active; next: wait for the active deploy to finish, inspect $LOCK_PATH owner if stale, then rerun scripts/hapax-coord-deploy" >&2
    exit 75
}

activation_dirty_entries() {
    git -C "$WT" status --porcelain=v1 --untracked-files=all --ignored=matching 2>/dev/null \
        | grep -Ev '^(\?\?|!!) \.deployed-sha$' || true
}

clean_activation_worktree_or_fail() {
    local out
    local rc
    if out="$(git -C "$WT" clean -xfd -- . ":(exclude).deployed-sha" 2>&1)"; then
        if [ -n "$out" ]; then
            printf '%s\n' "$out"
        fi
    else
        rc=$?
        pre_restart_worktree_fail "$rc" "clean untracked/ignored activation worktree $WT" "$out"
    fi
}

checkout_activation_worktree_or_fail() {
    local out
    local rc
    if out="$(git -C "$WT" checkout --detach --force "$TARGET_SHA" --quiet 2>&1)"; then
        if [ -n "$out" ]; then
            printf '%s\n' "$out"
        fi
    else
        rc=$?
        pre_restart_worktree_fail "$rc" "checkout activation worktree $WT" "$out"
    fi
}

RECEIPT_NEXT="next: inspect $WT/.deployed-sha permissions and systemctl --user status hapax-coord.service, reconcile activation/deployed sha state, then rerun scripts/hapax-coord-deploy"
SERVICE_WAS_ACTIVE_FOR_MUTATION=0

validate_receipt_path_or_fail() {
    if [ -e "$WT/.deployed-sha" ] && [ ! -f "$WT/.deployed-sha" ]; then
        echo "coord-deploy: deployed sha receipt path invalid: $WT/.deployed-sha is not a regular file; $RECEIPT_NEXT" >&2
        exit 1
    fi
}

stop_service_before_worktree_mutation_or_fail() {
    local out
    local rc
    if systemctl --user is-active --quiet hapax-coord.service >/dev/null 2>&1; then
        SERVICE_WAS_ACTIVE_FOR_MUTATION=1
        if out="$(systemctl --user stop hapax-coord.service 2>&1)"; then
            echo "coord-deploy: stopped hapax-coord.service before activation worktree mutation"
        else
            rc=$?
            deploy_fail "stop hapax-coord.service before activation worktree mutation" "$rc" "$out"
        fi
    else
        SERVICE_WAS_ACTIVE_FOR_MUTATION=0
        echo "coord-deploy: hapax-coord.service inactive before activation worktree mutation"
    fi
}

resume_previous_service_after_pre_restart_failure() {
    if [ "$SERVICE_WAS_ACTIVE_FOR_MUTATION" = "1" ]; then
        restart_service_after_restart_failure_rollback
    else
        printf 'hapax-coord.service was inactive before deploy; leaving it stopped'
    fi
}

stop_service_before_rollback_mutation_or_fail() {
    local context="$1"
    local next="$2"
    local out
    local rc
    if out="$(systemctl --user stop hapax-coord.service 2>&1)"; then
        printf 'stopped hapax-coord.service before rollback worktree mutation'
    else
        rc=$?
        out="${out//$'\n'/; }"
        if [ -z "$out" ]; then
            out="no output"
        fi
        echo "coord-deploy: $context; failed to stop hapax-coord.service before rollback worktree mutation (rc=$rc): $out; not mutating live activation worktree; $next" >&2
        exit "$rc"
    fi
}

run_or_fail "create activation root $ACT_ROOT" mkdir -p "$ACT_ROOT"
acquire_deploy_lock_or_fail

run_or_fail "fetch origin/main from $REPO" git -C "$REPO" fetch origin +refs/heads/main:refs/remotes/origin/main --quiet
TARGET_SHA="$(capture_or_fail "resolve origin/main in $REPO" git -C "$REPO" rev-parse refs/remotes/origin/main)"

if [ ! -d "$WT/.git" ] && [ ! -f "$WT/.git" ]; then
    run_or_fail "add activation worktree $WT" git -C "$REPO" worktree add --detach "$WT" "$TARGET_SHA"
fi
validate_receipt_path_or_fail

CURRENT_SHA="$(git -C "$WT" rev-parse HEAD 2>/dev/null || echo none)"
DEPLOYED_SHA="$(cat "$WT/.deployed-sha" 2>/dev/null || echo none)"
ACTIVATION_DIRTY="$(activation_dirty_entries)"
if [ "$CURRENT_SHA" = "$TARGET_SHA" ] && [ "$DEPLOYED_SHA" = "$TARGET_SHA" ] && [ -z "$ACTIVATION_DIRTY" ]; then
    echo "coord-deploy: up to date at $TARGET_SHA"
    exit 0
fi

ROLLBACK_SHA=""
if [ "$DEPLOYED_SHA" != "none" ] && git -C "$WT" cat-file -e "$DEPLOYED_SHA^{commit}" 2>/dev/null; then
    ROLLBACK_SHA="$DEPLOYED_SHA"
elif [ "$CURRENT_SHA" != "none" ] && git -C "$WT" cat-file -e "$CURRENT_SHA^{commit}" 2>/dev/null; then
    ROLLBACK_SHA="$CURRENT_SHA"
fi
RESTART_NEXT="next: inspect systemctl --user status hapax-coord.service and journalctl --user -u hapax-coord.service -n 100, fix the service failure, then rerun scripts/hapax-coord-deploy"
CLEAN_NEXT="next: inspect git -C $WT status --porcelain=v1 --untracked-files=all --ignored=matching and filesystem permissions, repair or clean the activation worktree, then rerun scripts/hapax-coord-deploy"

rollback_service_after_receipt_failure() {
    local service_rc
    if systemctl --user restart hapax-coord.service >/dev/null 2>&1; then
        printf 'restarted hapax-coord.service on rollback sha %s' "$ROLLBACK_SHA"
    else
        service_rc=$?
        systemctl --user stop hapax-coord.service >/dev/null 2>&1 || true
        printf 'rollback service restart failed rc=%s; stopped hapax-coord.service to avoid serving unreceipted target' "$service_rc"
    fi
}

restart_service_after_restart_failure_rollback() {
    local service_rc
    if systemctl --user restart hapax-coord.service >/dev/null 2>&1; then
        printf 'restarted hapax-coord.service on rollback sha %s' "$ROLLBACK_SHA"
    else
        service_rc=$?
        printf 'rollback service restart failed rc=%s; inspect hapax-coord.service before retrying' "$service_rc"
    fi
}

stop_unreceipted_service_after_receipt_failure() {
    local service_rc
    if systemctl --user stop hapax-coord.service >/dev/null 2>&1; then
        printf 'stopped hapax-coord.service to avoid serving unreceipted target'
    else
        service_rc=$?
        printf 'failed to stop hapax-coord.service rc=%s after receipt failure' "$service_rc"
    fi
}

clean_rollback_or_stop() {
    local context="$1"
    local detail="$2"
    local next="$3"
    local rollback_clean_detail
    local rollback_clean_rc
    local service_detail
    local detail_part=""
    if [ -n "$detail" ]; then
        detail_part="; $detail"
    fi
    if rollback_clean_detail="$(git -C "$WT" clean -xfd -- . ":(exclude).deployed-sha" 2>&1)"; then
        return 0
    else
        rollback_clean_rc=$?
    fi
    rollback_clean_detail="${rollback_clean_detail//$'\n'/; }"
    if [ -z "$rollback_clean_detail" ]; then
        rollback_clean_detail="no output"
    fi
    service_detail="$(stop_unreceipted_service_after_receipt_failure)"
    echo "coord-deploy: $context; rolled activation worktree back to $ROLLBACK_SHA but rollback clean failed (rc=$rollback_clean_rc): $rollback_clean_detail; $service_detail$detail_part; $next" >&2
    return "$rollback_clean_rc"
}

pre_restart_worktree_fail() {
    local rc="$1"
    local label="$2"
    local detail="$3"
    local rollback_detail
    local rollback_rc
    local rollback_clean_detail
    local rollback_clean_rc
    local service_detail
    detail="${detail//$'\n'/; }"
    if [ -z "$detail" ]; then
        detail="no output"
    fi
    if [ -n "$ROLLBACK_SHA" ] && [ "$ROLLBACK_SHA" != "$TARGET_SHA" ]; then
        if rollback_detail="$(git -C "$WT" checkout --detach --force "$ROLLBACK_SHA" --quiet 2>&1)"; then
            if rollback_clean_detail="$(git -C "$WT" clean -xfd -- . ":(exclude).deployed-sha" 2>&1)"; then
                service_detail="$(resume_previous_service_after_pre_restart_failure)"
                echo "coord-deploy: $label failed before restart; rolled activation worktree back to $ROLLBACK_SHA; $service_detail; $detail; $CLEAN_NEXT" >&2
            else
                rollback_clean_rc=$?
                rollback_clean_detail="${rollback_clean_detail//$'\n'/; }"
                if [ -z "$rollback_clean_detail" ]; then
                    rollback_clean_detail="no output"
                fi
                service_detail="$(stop_unreceipted_service_after_receipt_failure)"
                echo "coord-deploy: $label failed before restart; rolled activation worktree back to $ROLLBACK_SHA but rollback clean failed (rc=$rollback_clean_rc): $rollback_clean_detail; $service_detail; $detail; $CLEAN_NEXT" >&2
            fi
        else
            rollback_rc=$?
            rollback_detail="${rollback_detail//$'\n'/; }"
            if [ -z "$rollback_detail" ]; then
                rollback_detail="no output"
            fi
            service_detail="$(stop_unreceipted_service_after_receipt_failure)"
            echo "coord-deploy: $label failed before restart; rollback checkout to $ROLLBACK_SHA failed (rc=$rollback_rc): $rollback_detail; $service_detail; $detail; $CLEAN_NEXT" >&2
        fi
    elif [ -n "$ROLLBACK_SHA" ]; then
        service_detail="$(resume_previous_service_after_pre_restart_failure)"
        echo "coord-deploy: $label failed before restart; activation worktree remains at $ROLLBACK_SHA; $service_detail; $detail; $CLEAN_NEXT" >&2
    else
        service_detail="$(stop_unreceipted_service_after_receipt_failure)"
        echo "coord-deploy: $label failed before restart; no prior activation worktree sha available; $service_detail; $detail; $CLEAN_NEXT" >&2
    fi
    exit "$rc"
}

receipt_fail() {
    local rc="$1"
    local detail="$2"
    local checkout_detail
    local checkout_rc
    local service_detail
    local stop_detail
    detail="${detail//$'\n'/; }"
    if [ -z "$detail" ]; then
        detail="no output"
    fi
    stop_detail="$(stop_service_before_rollback_mutation_or_fail "receipt write failed after restart" "$RECEIPT_NEXT")"
    if [ -n "$ROLLBACK_SHA" ] && [ "$ROLLBACK_SHA" != "$TARGET_SHA" ]; then
        if checkout_detail="$(git -C "$WT" checkout --detach --force "$ROLLBACK_SHA" --quiet 2>&1)"; then
            if clean_rollback_or_stop "receipt write failed after restart" "$detail" "$RECEIPT_NEXT"; then
                service_detail="$(rollback_service_after_receipt_failure)"
                echo "coord-deploy: receipt write failed after restart; $stop_detail; rolled activation worktree back to $ROLLBACK_SHA; $service_detail; $detail; $RECEIPT_NEXT" >&2
            fi
        else
            checkout_rc=$?
            checkout_detail="${checkout_detail//$'\n'/; }"
            if [ -z "$checkout_detail" ]; then
                checkout_detail="no output"
            fi
            service_detail="$(stop_unreceipted_service_after_receipt_failure)"
            echo "coord-deploy: receipt write failed after restart; $stop_detail; rollback checkout to $ROLLBACK_SHA failed (rc=$checkout_rc): $checkout_detail; $service_detail; $detail; $RECEIPT_NEXT" >&2
        fi
    elif [ -n "$ROLLBACK_SHA" ]; then
        service_detail="$(stop_unreceipted_service_after_receipt_failure)"
        echo "coord-deploy: receipt write failed after restart; $stop_detail; activation worktree remains at $ROLLBACK_SHA; $service_detail; $detail; $RECEIPT_NEXT" >&2
    else
        service_detail="$(stop_unreceipted_service_after_receipt_failure)"
        echo "coord-deploy: receipt write failed after restart; $stop_detail; no prior activation worktree sha available; $service_detail; $detail; $RECEIPT_NEXT" >&2
    fi
    exit "$rc"
}

write_receipt_or_fail() {
    local out
    local rc
    if out="$(printf '%s\n' "$TARGET_SHA" > "$WT/.deployed-sha.tmp" 2>&1)"; then
        :
    else
        rc=$?
        receipt_fail "$rc" "write .deployed-sha.tmp failed: $out"
    fi
    if out="$(mv -T "$WT/.deployed-sha.tmp" "$WT/.deployed-sha" 2>&1)"; then
        :
    else
        rc=$?
        receipt_fail "$rc" "promote .deployed-sha failed: $out"
    fi
}

stop_service_before_worktree_mutation_or_fail
checkout_activation_worktree_or_fail
clean_activation_worktree_or_fail
echo "coord-deploy: checked out $TARGET_SHA; restarting hapax-coord"
if systemctl --user restart hapax-coord.service; then
    :
else
    rc=$?
    stop_detail="$(stop_service_before_rollback_mutation_or_fail "restart failed" "$RESTART_NEXT")"
    if [ -n "$ROLLBACK_SHA" ] && [ "$ROLLBACK_SHA" != "$TARGET_SHA" ]; then
        if rollback_detail="$(git -C "$WT" checkout --detach --force "$ROLLBACK_SHA" --quiet 2>&1)"; then
            if clean_rollback_or_stop "restart failed" "" "$RESTART_NEXT"; then
                service_detail="$(restart_service_after_restart_failure_rollback)"
                echo "coord-deploy: restart failed; $stop_detail; rolled activation worktree back to $ROLLBACK_SHA; $service_detail; $RESTART_NEXT" >&2
            fi
        else
            rollback_rc=$?
            rollback_detail="${rollback_detail//$'\n'/; }"
            if [ -z "$rollback_detail" ]; then
                rollback_detail="no output"
            fi
            service_detail="$(stop_unreceipted_service_after_receipt_failure)"
            echo "coord-deploy: restart failed; $stop_detail; rollback checkout to $ROLLBACK_SHA failed (rc=$rollback_rc): $rollback_detail; $service_detail; $RESTART_NEXT" >&2
        fi
    elif [ -n "$ROLLBACK_SHA" ]; then
        service_detail="$(stop_unreceipted_service_after_receipt_failure)"
        echo "coord-deploy: restart failed; $stop_detail; activation worktree remains at $ROLLBACK_SHA; $service_detail; $RESTART_NEXT" >&2
    else
        service_detail="$(stop_unreceipted_service_after_receipt_failure)"
        echo "coord-deploy: restart failed; no prior activation worktree sha available; $service_detail; $RESTART_NEXT" >&2
    fi
    exit "$rc"
fi
write_receipt_or_fail
echo "coord-deploy: activated $TARGET_SHA"
