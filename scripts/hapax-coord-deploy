#!/usr/bin/env bash
# Deploy hapax-coord into the coord activation worktree and restart the yard
# only when origin/main changes.
set -euo pipefail

REPO="${HAPAX_COORD_DEPLOY_REPO:-/home/hapax/projects/hapax-coord}"
ACT_ROOT="${HAPAX_COORD_DEPLOY_ACT_ROOT:-$HOME/.cache/hapax/coord-activation}"
WT="$ACT_ROOT/worktree"

if [ "${1:-}" = "--contract-json" ]; then
    printf '{"schema":1,"source_repo":"%s","activation_worktree":"%s","target_ref":"origin/main","writes_deployed_sha":true,"writes_deployed_sha_after_restart":true,"rolls_back_worktree_on_restart_failure":true,"restarts_service":"hapax-coord.service"}\n' "$REPO" "$WT"
    exit 0
fi

git -C "$REPO" fetch origin +refs/heads/main:refs/remotes/origin/main --quiet
TARGET_SHA="$(git -C "$REPO" rev-parse refs/remotes/origin/main)"

mkdir -p "$ACT_ROOT"
if [ ! -d "$WT/.git" ] && [ ! -f "$WT/.git" ]; then
    git -C "$REPO" worktree add --detach "$WT" "$TARGET_SHA"
fi

CURRENT_SHA="$(git -C "$WT" rev-parse HEAD 2>/dev/null || echo none)"
DEPLOYED_SHA="$(cat "$WT/.deployed-sha" 2>/dev/null || echo none)"
if [ "$CURRENT_SHA" = "$TARGET_SHA" ] && [ "$DEPLOYED_SHA" = "$TARGET_SHA" ]; then
    echo "coord-deploy: up to date at $TARGET_SHA"
    exit 0
fi

ROLLBACK_SHA=""
if [ "$DEPLOYED_SHA" != "none" ] && git -C "$WT" cat-file -e "$DEPLOYED_SHA^{commit}" 2>/dev/null; then
    ROLLBACK_SHA="$DEPLOYED_SHA"
elif [ "$CURRENT_SHA" != "none" ] && git -C "$WT" cat-file -e "$CURRENT_SHA^{commit}" 2>/dev/null; then
    ROLLBACK_SHA="$CURRENT_SHA"
fi

git -C "$WT" checkout --detach --force "$TARGET_SHA" --quiet
echo "coord-deploy: checked out $TARGET_SHA; restarting hapax-coord"
if systemctl --user restart hapax-coord.service; then
    :
else
    rc=$?
    if [ -n "$ROLLBACK_SHA" ] && [ "$ROLLBACK_SHA" != "$TARGET_SHA" ]; then
        git -C "$WT" checkout --detach --force "$ROLLBACK_SHA" --quiet || true
        echo "coord-deploy: restart failed; rolled activation worktree back to $ROLLBACK_SHA" >&2
    elif [ -n "$ROLLBACK_SHA" ]; then
        echo "coord-deploy: restart failed; activation worktree remains at $ROLLBACK_SHA" >&2
    else
        echo "coord-deploy: restart failed; no prior activation worktree sha available" >&2
    fi
    exit "$rc"
fi
printf '%s\n' "$TARGET_SHA" > "$WT/.deployed-sha.tmp"
mv "$WT/.deployed-sha.tmp" "$WT/.deployed-sha"
echo "coord-deploy: activated $TARGET_SHA"
