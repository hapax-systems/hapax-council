#!/usr/bin/env bash
# Deploy hapax-coord into the coord activation worktree and restart the yard
# only when origin/main changes.
set -euo pipefail

REPO="${HAPAX_COORD_DEPLOY_REPO:-/home/hapax/projects/hapax-coord}"
ACT_ROOT="${HAPAX_COORD_DEPLOY_ACT_ROOT:-$HOME/.cache/hapax/coord-activation}"
WT="$ACT_ROOT/worktree"
SETUP_NEXT="next: verify HAPAX_COORD_DEPLOY_REPO points to a readable hapax-coord git checkout with origin/main, verify HAPAX_COORD_DEPLOY_ACT_ROOT is writable, then rerun scripts/hapax-coord-deploy"

if [ "${1:-}" = "--contract-json" ]; then
    printf '{"schema":1,"source_repo":"%s","activation_worktree":"%s","target_ref":"origin/main","writes_deployed_sha":true,"writes_deployed_sha_after_restart":true,"rolls_back_worktree_on_restart_failure":true,"restarts_service":"hapax-coord.service"}\n' "$REPO" "$WT"
    exit 0
fi

deploy_fail() {
    local label="$1"
    local rc="$2"
    local detail="$3"
    detail="${detail//$'\n'/; }"
    if [ -z "$detail" ]; then
        detail="no output"
    fi
    echo "coord-deploy: $label failed (rc=$rc): $detail; $SETUP_NEXT" >&2
    exit "$rc"
}

run_or_fail() {
    local label="$1"
    shift
    local out
    local rc
    if out="$("$@" 2>&1)"; then
        if [ -n "$out" ]; then
            printf '%s\n' "$out"
        fi
    else
        rc=$?
        deploy_fail "$label" "$rc" "$out"
    fi
}

capture_or_fail() {
    local label="$1"
    shift
    local out
    local rc
    if out="$("$@" 2>&1)"; then
        printf '%s' "$out"
    else
        rc=$?
        deploy_fail "$label" "$rc" "$out"
    fi
}

run_or_fail "fetch origin/main from $REPO" git -C "$REPO" fetch origin +refs/heads/main:refs/remotes/origin/main --quiet
TARGET_SHA="$(capture_or_fail "resolve origin/main in $REPO" git -C "$REPO" rev-parse refs/remotes/origin/main)"

run_or_fail "create activation root $ACT_ROOT" mkdir -p "$ACT_ROOT"
if [ ! -d "$WT/.git" ] && [ ! -f "$WT/.git" ]; then
    run_or_fail "add activation worktree $WT" git -C "$REPO" worktree add --detach "$WT" "$TARGET_SHA"
fi

CURRENT_SHA="$(git -C "$WT" rev-parse HEAD 2>/dev/null || echo none)"
DEPLOYED_SHA="$(cat "$WT/.deployed-sha" 2>/dev/null || echo none)"
if [ "$CURRENT_SHA" = "$TARGET_SHA" ] && [ "$DEPLOYED_SHA" = "$TARGET_SHA" ]; then
    echo "coord-deploy: up to date at $TARGET_SHA"
    exit 0
fi

ROLLBACK_SHA=""
if [ "$DEPLOYED_SHA" != "none" ] && git -C "$WT" cat-file -e "$DEPLOYED_SHA^{commit}" 2>/dev/null; then
    ROLLBACK_SHA="$DEPLOYED_SHA"
elif [ "$CURRENT_SHA" != "none" ] && git -C "$WT" cat-file -e "$CURRENT_SHA^{commit}" 2>/dev/null; then
    ROLLBACK_SHA="$CURRENT_SHA"
fi
RESTART_NEXT="next: inspect systemctl --user status hapax-coord.service and journalctl --user -u hapax-coord.service -n 100, fix the service failure, then rerun scripts/hapax-coord-deploy"
RECEIPT_NEXT="next: inspect $WT/.deployed-sha permissions and systemctl --user status hapax-coord.service, reconcile activation/deployed sha state, then rerun scripts/hapax-coord-deploy"

rollback_service_after_receipt_failure() {
    local service_rc
    if systemctl --user restart hapax-coord.service >/dev/null 2>&1; then
        printf 'restarted hapax-coord.service on rollback sha %s' "$ROLLBACK_SHA"
    else
        service_rc=$?
        systemctl --user stop hapax-coord.service >/dev/null 2>&1 || true
        printf 'rollback service restart failed rc=%s; stopped hapax-coord.service to avoid serving unreceipted target' "$service_rc"
    fi
}

stop_unreceipted_service_after_receipt_failure() {
    local service_rc
    if systemctl --user stop hapax-coord.service >/dev/null 2>&1; then
        printf 'stopped hapax-coord.service to avoid serving unreceipted target'
    else
        service_rc=$?
        printf 'failed to stop hapax-coord.service rc=%s after receipt failure' "$service_rc"
    fi
}

receipt_fail() {
    local rc="$1"
    local detail="$2"
    local checkout_detail
    local checkout_rc
    local service_detail
    detail="${detail//$'\n'/; }"
    if [ -z "$detail" ]; then
        detail="no output"
    fi
    if [ -n "$ROLLBACK_SHA" ] && [ "$ROLLBACK_SHA" != "$TARGET_SHA" ]; then
        if checkout_detail="$(git -C "$WT" checkout --detach --force "$ROLLBACK_SHA" --quiet 2>&1)"; then
            service_detail="$(rollback_service_after_receipt_failure)"
            echo "coord-deploy: receipt write failed after restart; rolled activation worktree back to $ROLLBACK_SHA; $service_detail; $detail; $RECEIPT_NEXT" >&2
        else
            checkout_rc=$?
            checkout_detail="${checkout_detail//$'\n'/; }"
            if [ -z "$checkout_detail" ]; then
                checkout_detail="no output"
            fi
            service_detail="$(stop_unreceipted_service_after_receipt_failure)"
            echo "coord-deploy: receipt write failed after restart; rollback checkout to $ROLLBACK_SHA failed (rc=$checkout_rc): $checkout_detail; $service_detail; $detail; $RECEIPT_NEXT" >&2
        fi
    elif [ -n "$ROLLBACK_SHA" ]; then
        service_detail="$(stop_unreceipted_service_after_receipt_failure)"
        echo "coord-deploy: receipt write failed after restart; activation worktree remains at $ROLLBACK_SHA; $service_detail; $detail; $RECEIPT_NEXT" >&2
    else
        service_detail="$(stop_unreceipted_service_after_receipt_failure)"
        echo "coord-deploy: receipt write failed after restart; no prior activation worktree sha available; $service_detail; $detail; $RECEIPT_NEXT" >&2
    fi
    exit "$rc"
}

write_receipt_or_fail() {
    local out
    local rc
    if out="$(printf '%s\n' "$TARGET_SHA" > "$WT/.deployed-sha.tmp" 2>&1)"; then
        :
    else
        rc=$?
        receipt_fail "$rc" "write .deployed-sha.tmp failed: $out"
    fi
    if out="$(mv "$WT/.deployed-sha.tmp" "$WT/.deployed-sha" 2>&1)"; then
        :
    else
        rc=$?
        receipt_fail "$rc" "promote .deployed-sha failed: $out"
    fi
}

run_or_fail "checkout activation worktree $WT" git -C "$WT" checkout --detach --force "$TARGET_SHA" --quiet
echo "coord-deploy: checked out $TARGET_SHA; restarting hapax-coord"
if systemctl --user restart hapax-coord.service; then
    :
else
    rc=$?
    if [ -n "$ROLLBACK_SHA" ] && [ "$ROLLBACK_SHA" != "$TARGET_SHA" ]; then
        git -C "$WT" checkout --detach --force "$ROLLBACK_SHA" --quiet || true
        echo "coord-deploy: restart failed; rolled activation worktree back to $ROLLBACK_SHA; $RESTART_NEXT" >&2
    elif [ -n "$ROLLBACK_SHA" ]; then
        echo "coord-deploy: restart failed; activation worktree remains at $ROLLBACK_SHA; $RESTART_NEXT" >&2
    else
        echo "coord-deploy: restart failed; no prior activation worktree sha available; $RESTART_NEXT" >&2
    fi
    exit "$rc"
fi
write_receipt_or_fail
echo "coord-deploy: activated $TARGET_SHA"
