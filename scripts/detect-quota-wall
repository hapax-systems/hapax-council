#!/usr/bin/env python3
"""Detect quota wall from a lane's output.jsonl and write relay receipt.

Exit codes:
  0  — no quota wall detected (lane exited for other reasons)
  75 — quota wall detected, receipt written

Called by hapax-claude-headless after Claude exits to determine
whether to use extended backoff.

Usage:
    detect-quota-wall <role>
    detect-quota-wall beta
    detect-quota-wall gamma --output /path/to/output.jsonl
"""

from __future__ import annotations

import argparse
import logging
import sys
from pathlib import Path

# Make `shared` importable when run directly via PATH: the headless wrapper invokes
# us as a bare `detect-quota-wall` (its PATH has scripts/), so sys.path[0] is
# scripts/, not the repo root. Anchor on the repo root (scripts/'s parent).
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("role", help="Lane role (beta, gamma, etc.)")
    parser.add_argument(
        "--output",
        type=Path,
        help="Path to output.jsonl (default: ~/.cache/hapax/claude-headless/<role>/output.jsonl)",
    )
    parser.add_argument("--verbose", action="store_true")
    parser.add_argument(
        "--streak",
        type=int,
        default=1,
        help="consecutive quota-wall streak (drives exponential backoff)",
    )
    parser.add_argument("--base", type=int, default=30, help="minimum backoff seconds")
    parser.add_argument(
        "--cap", type=int, default=21600, help="maximum backoff seconds (default 6h)"
    )
    args = parser.parse_args(argv)

    logging.basicConfig(
        level=logging.DEBUG if args.verbose else logging.INFO,
        format="%(levelname)-7s %(message)s",
    )

    output_path = args.output or (
        Path.home() / ".cache/hapax/claude-headless" / args.role / "output.jsonl"
    )

    from shared.quota_wall import (
        QUOTA_WALL_EXIT_CODE,
        compute_backoff_seconds,
        handle_quota_wall,
    )

    rc = handle_quota_wall(args.role, output_path)
    if rc == QUOTA_WALL_EXIT_CODE:
        # quota wall: emit the integer backoff so the bash restart loop can sleep it.
        print(compute_backoff_seconds(args.role, args.streak, args.base, args.cap))
    return rc


if __name__ == "__main__":
    sys.exit(main())
