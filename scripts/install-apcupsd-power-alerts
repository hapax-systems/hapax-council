#!/usr/bin/env bash
# Install Hapax apcupsd config/hooks and verify power-event provenance paths.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SOURCE="$ROOT"
SRC="$SOURCE/config/apcupsd"
DEST="${HAPAX_APCUPSD_DEST:-/etc/apcupsd}"
AUDIT_DIR="${HAPAX_APCUPSD_AUDIT_DIR:-/var/log/hapax}"
LOGROTATE_DEST="${HAPAX_APCUPSD_LOGROTATE_DEST:-/etc/logrotate.d/hapax-ups-power-events}"
SYSTEMCTL="${HAPAX_APCUPSD_SYSTEMCTL:-systemctl}"
SUDO="${HAPAX_APCUPSD_INSTALL_SUDO-sudo}"
ROOT_REQUIRED_RC=77
RESTART=1
INSTALL=0
CHECK=0
VERIFY_LIVE=0

usage() {
    cat <<'USAGE'
usage: scripts/install-apcupsd-power-alerts [--source DIR] [--check] [--install] [--verify-live] [--no-restart]

Installs:
  config/apcupsd/apcupsd.conf        -> /etc/apcupsd/apcupsd.conf
  config/apcupsd/hapax-power-event.py -> /etc/apcupsd/hapax-power-event.py
  config/apcupsd/onbattery           -> /etc/apcupsd/onbattery
  config/apcupsd/offbattery          -> /etc/apcupsd/offbattery
  systemd/logrotate.d/hapax-ups-power-events -> /etc/logrotate.d/hapax-ups-power-events

Power events are recorded at /var/log/hapax/ups-power-events.jsonl before/after
ntfy delivery state is known.
USAGE
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --source) SOURCE="${2:?source dir required after --source}"; SRC="$SOURCE/config/apcupsd"; shift ;;
        --check) CHECK=1 ;;
        --install) INSTALL=1 ;;
        --verify-live) VERIFY_LIVE=1 ;;
        --no-restart) RESTART=0 ;;
        -h|--help) usage; exit 0 ;;
        *) echo "unknown argument: $1" >&2; usage >&2; exit 2 ;;
    esac
    shift
done

if [ "$CHECK" -eq 0 ] && [ "$INSTALL" -eq 0 ] && [ "$VERIFY_LIVE" -eq 0 ]; then
    CHECK=1
fi

expect_header() {
    local file="$1"
    local first
    first="$(head -n1 "$file")"
    [ "$first" = "## apcupsd.conf v1.1 ##" ] || {
        echo "bad apcupsd header in $file: $first; next action: restore config/apcupsd/apcupsd.conf and rerun scripts/install-apcupsd-power-alerts --install --verify-live" >&2
        return 1
    }
}

run_root() {
    if [ -n "$SUDO" ]; then
        "$SUDO" "$@"
    else
        "$@"
    fi
}

preflight_root() {
    if [ -n "$SUDO" ] && [ "$INSTALL" -eq 1 ]; then
        "$SUDO" -n true 2>/dev/null || {
            echo "sudo non-interactive access is required for apcupsd power-alert install; next action: run sudo -v, grant the post-merge deploy user NOPASSWD for install/systemctl, or run as root with HAPAX_APCUPSD_INSTALL_SUDO= scripts/install-apcupsd-power-alerts --install --verify-live" >&2
            return "$ROOT_REQUIRED_RC"
        }
    fi
}

check_source() {
    expect_header "$SRC/apcupsd.conf"
    [ -x "$SRC/hapax-power-event.py" ] || {
        echo "source helper is not executable: $SRC/hapax-power-event.py; next action: chmod +x config/apcupsd/hapax-power-event.py and rerun scripts/install-apcupsd-power-alerts --check" >&2
        return 1
    }
    [ -x "$SRC/onbattery" ] || {
        echo "source hook is not executable: $SRC/onbattery; next action: chmod +x config/apcupsd/onbattery and rerun scripts/install-apcupsd-power-alerts --check" >&2
        return 1
    }
    [ -x "$SRC/offbattery" ] || {
        echo "source hook is not executable: $SRC/offbattery; next action: chmod +x config/apcupsd/offbattery and rerun scripts/install-apcupsd-power-alerts --check" >&2
        return 1
    }
    [ -f "$SOURCE/systemd/logrotate.d/hapax-ups-power-events" ] || {
        echo "source logrotate config missing: $SOURCE/systemd/logrotate.d/hapax-ups-power-events; next action: restore the UPS logrotate source and rerun scripts/install-apcupsd-power-alerts --check" >&2
        return 1
    }
}

install_live() {
    local changed=0 pair
    check_source
    preflight_root
    for pair in apcupsd.conf hapax-power-event.py onbattery offbattery; do
        cmp -s "$SRC/$pair" "$DEST/$pair" 2>/dev/null || changed=1
    done
    cmp -s "$SOURCE/systemd/logrotate.d/hapax-ups-power-events" "$LOGROTATE_DEST" 2>/dev/null || changed=1
    run_root install -d -m 0755 "$DEST"
    run_root install -d -m 0750 "$AUDIT_DIR"
    run_root install -m 0644 "$SRC/apcupsd.conf" "$DEST/apcupsd.conf"
    run_root install -m 0755 "$SRC/hapax-power-event.py" "$DEST/hapax-power-event.py"
    run_root install -m 0755 "$SRC/onbattery" "$DEST/onbattery"
    run_root install -m 0755 "$SRC/offbattery" "$DEST/offbattery"
    run_root install -d -m 0755 "$(dirname "$LOGROTATE_DEST")"
    run_root install -m 0644 "$SOURCE/systemd/logrotate.d/hapax-ups-power-events" "$LOGROTATE_DEST"
    if [ "$RESTART" -eq 1 ] && [ "$changed" -eq 1 ]; then
        run_root "$SYSTEMCTL" restart apcupsd
    fi
}

verify_live() {
    expect_header "$DEST/apcupsd.conf"
    cmp -s "$SRC/apcupsd.conf" "$DEST/apcupsd.conf" || {
        echo "live config differs from source: $DEST; next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
        return 1
    }
    [ -x "$DEST/hapax-power-event.py" ] || {
        echo "live helper is not executable: $DEST/hapax-power-event.py; next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
        return 1
    }
    cmp -s "$SRC/hapax-power-event.py" "$DEST/hapax-power-event.py" || {
        echo "live helper differs from source: $DEST/hapax-power-event.py; next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
        return 1
    }
    [ -x "$DEST/onbattery" ] || {
        echo "live onbattery hook is not executable; next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
        return 1
    }
    cmp -s "$SRC/onbattery" "$DEST/onbattery" || {
        echo "live onbattery hook differs from source; next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
        return 1
    }
    [ -x "$DEST/offbattery" ] || {
        echo "live offbattery hook is not executable; next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
        return 1
    }
    cmp -s "$SRC/offbattery" "$DEST/offbattery" || {
        echo "live offbattery hook differs from source; next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
        return 1
    }
    cmp -s "$SOURCE/systemd/logrotate.d/hapax-ups-power-events" "$LOGROTATE_DEST" || {
        echo "live UPS logrotate config differs from source; next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
        return 1
    }
    [ -d "$AUDIT_DIR" ] || {
        echo "audit directory missing: $AUDIT_DIR; next action: run scripts/install-apcupsd-power-alerts --install --verify-live" >&2
        return 1
    }
}

[ "$CHECK" -eq 0 ] || check_source
[ "$INSTALL" -eq 0 ] || install_live
[ "$VERIFY_LIVE" -eq 0 ] || verify_live
echo "apcupsd power alert install/check complete"
