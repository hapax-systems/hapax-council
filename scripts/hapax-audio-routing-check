#!/usr/bin/env bash
# hapax-audio-routing-check — validate PipeWire audio routing invariants
#
# Run before AND after any audio config change. Exits non-zero if any
# invariant is violated. Designed to be called by:
#   - git pre-commit hook (when PipeWire configs change)
#   - systemd health timer (hapax-audio-health.timer)
#   - any AI agent before/after touching audio
#   - the operator manually: ./scripts/hapax-audio-routing-check
#
# INVARIANTS (2026-05-05 golden state):
#
#   1. TTS voice chain: role.broadcast → voice-fx-capture → voice-fx-playback
#      → loudnorm-capture → loudnorm-playback → MPC AUX2/3
#
#   2. NO direct TTS bypass to livestream-tap. hapax-tts-broadcast-playback
#      must NOT exist or be connected to hapax-livestream-tap.
#
#   3. Livestream tap inputs: only route-policy-authorized producers feed
#      hapax-livestream-tap. L-12 wet-return sources remain the default
#      path; S-4/direct content taps are blocked until explicitly promoted.
#
#   4. OBS chain: broadcast-normalized → obs-broadcast-remap → OBS
#
#   5. MPC receives only the specified live software channels:
#      SoundCloud/music AUX0/1, public TTS AUX2/3, private TTS AUX8/9.
#
# Exit codes: 0 = all good, 1 = invariant violation, 2 = PipeWire not running

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

GRAPH=$(pw-link -l 2>&1) || { echo -e "${RED}FAIL: PipeWire not running${NC}"; exit 2; }
FAILURES=0

link_present() {
    local source_port="$1"
    local target_port="$2"
    printf '%s\n' "$GRAPH" | awk -v src="$source_port" -v target="$target_port" '
        {
            line = $0
            sub(/^[[:space:]]*/, "", line)
        }
        line == src { within = 1; next }
        line !~ /^\|/ { within = 0 }
        within && line ~ /^\|->/ && index(line, target) { found = 1 }
        END { exit found ? 0 : 1 }
    '
}

regex_link_present() {
    local source_re="$1"
    local target_re="$2"
    printf '%s\n' "$GRAPH" | awk -v src_re="$source_re" -v target_re="$target_re" '
        {
            line = $0
            sub(/^[[:space:]]*/, "", line)
        }
        line ~ src_re { within = 1; next }
        line !~ /^\|/ { within = 0 }
        within && line ~ /^\|->/ && line ~ target_re { found = 1 }
        END { exit found ? 0 : 1 }
    '
}

current_default_sink() {
    if ! command -v pactl >/dev/null 2>&1; then
        return 1
    fi
    pactl info 2>/dev/null | awk -F': ' '/^Default Sink:/ { print $2; exit }'
}

check() {
    local desc="$1"
    local result="$2"
    if [[ "$result" == PASS* ]]; then
        echo -e "  ${GREEN}✓${NC} $desc ${result#PASS}"
    else
        echo -e "  ${RED}✗ FAIL: $desc — $result${NC}"
        FAILURES=$((FAILURES + 1))
    fi
}

echo "=== Hapax Audio Routing Invariant Check ==="
echo ""

# ── Invariant 1: TTS voice chain exists ──
echo "Chain 1: TTS Voice Path"

if link_present "output.loopback.sink.role.broadcast:output_FL" "hapax-voice-fx-capture:playback_FL"; then
    check "role.broadcast → voice-fx-capture" "PASS"
else
    check "role.broadcast → voice-fx-capture" "link missing"
fi

if link_present "hapax-voice-fx-playback:output_FL" "hapax-loudnorm-capture:playback_FL"; then
    check "voice-fx-playback → loudnorm-capture" "PASS"
else
    check "voice-fx-playback → loudnorm-capture" "link missing"
fi

if link_present "hapax-loudnorm-playback:output_FL" "playback_AUX2"; then
    check "loudnorm-playback → MPC AUX2" "PASS"
else
    check "loudnorm-playback → MPC AUX2" "link missing — TTS not reaching MPC"
fi

echo ""

# ── Invariant 2: NO direct TTS bypass ──
echo "Chain 2: TTS Bypass Guard"

if link_present "hapax-tts-broadcast-playback:output_FL" "hapax-livestream-tap:playback_FL" \
    || link_present "hapax-tts-broadcast-playback:output_FR" "hapax-livestream-tap:playback_FR"; then
    check "no TTS bypass to livestream-tap" "BYPASS DETECTED — tts-broadcast-playback → livestream-tap"
elif echo "$GRAPH" | grep -q "hapax-tts-broadcast-playback"; then
    check "no TTS bypass to livestream-tap" "PASS (node exists but not connected to tap)"
else
    check "no TTS bypass to livestream-tap" "PASS"
fi

echo ""

# ── Invariant 3: Livestream tap inputs are clean ──
echo "Chain 3: Livestream Tap Inputs"

TAP_INPUTS=$(printf '%s\n' "$GRAPH" | awk '
    /^hapax-livestream-tap:playback_/ { in_tap = 1; next }
    /^[^[:space:]|]/ { in_tap = 0 }
    in_tap && /^[[:space:]]*\|<-/ { print }
')
# Source authority:
# - L-12 sources are the MPC-first wet return / processor return.
# S-4, Polyend, M8, YouTube, notification, and the retired
# hapax-tts-broadcast bridge are intentionally not listed here until route
# policy owns and promotes them.
ALLOWED_TAP_SOURCES="^[[:space:]]*\|<-[[:space:]]+(hapax-l12-evilpet-playback|hapax-l12-usb-return-playback):"
UNEXPECTED=$(printf '%s\n' "$TAP_INPUTS" | grep -vE "$ALLOWED_TAP_SOURCES" | grep -v "^$" || true)

if [ -z "$UNEXPECTED" ]; then
    check "livestream-tap has only authorized inputs" "PASS"
else
    check "livestream-tap has only authorized inputs" "unexpected source(s): $UNEXPECTED"
fi

echo ""

# ── Invariant 4: OBS chain intact ──
echo "Chain 4: OBS Broadcast Chain"

if link_present "hapax-obs-broadcast-remap:capture_FL" "OBS:input_FL"; then
    check "obs-broadcast-remap → OBS" "PASS"
else
    check "obs-broadcast-remap → OBS" "link missing — OBS not receiving broadcast"
fi

if link_present "hapax-broadcast-normalized:capture_FL" "hapax-obs-broadcast-remap-capture"; then
    check "broadcast-normalized → obs-remap" "PASS"
else
    check "broadcast-normalized → obs-remap" "link missing"
fi

echo ""

# ── Invariant 5: MPC receiving only specified sources ──
echo "Chain 5: MPC Input Assignments"

if link_present "hapax-music-loudnorm-playback:output_FL" "playback_AUX0" \
    && link_present "hapax-music-loudnorm-playback:output_FR" "playback_AUX1"; then
    check "SoundCloud/music → MPC AUX0/1" "PASS"
else
    check "SoundCloud/music → MPC AUX0/1" "missing — music is not reaching MPC"
fi

if link_present "hapax-loudnorm-playback:output_FL" "playback_AUX2" \
    && link_present "hapax-loudnorm-playback:output_FR" "playback_AUX3"; then
    check "public TTS → MPC AUX2/3" "PASS"
else
    check "public TTS → MPC AUX2/3" "missing — public TTS is not reaching MPC"
fi

if link_present "hapax-private-playback:output_FL" "playback_AUX8" \
    && link_present "hapax-private-playback:output_FR" "playback_AUX9"; then
    check "private TTS → MPC AUX8/9" "PASS"
else
    check "private TTS → MPC AUX8/9" "missing — private TTS is not reaching MPC"
fi

echo ""
echo "Chain 5b: Livestream / Non-Livestream Boundary Guard"

if link_present "hapax-pc-loudnorm-playback:output_FL" "playback_AUX4" \
    || link_present "hapax-pc-loudnorm-playback:output_FR" "playback_AUX5"; then
    check "PC USB 5/6 is fail-closed" "PC loudnorm is feeding MPC AUX4/5"
else
    check "PC USB 5/6 is fail-closed" "PASS"
fi

if link_present "hapax-yt-loudnorm-playback:output_FL" "playback_AUX6" \
    || link_present "hapax-yt-loudnorm-playback:output_FR" "playback_AUX7"; then
    check "YouTube AUX6/7 is disabled" "YT loudnorm is feeding MPC AUX6/7"
else
    check "YouTube AUX6/7 is disabled" "PASS"
fi

if link_present "hapax-notification-private-playback:output_FL" "playback_AUX8" \
    || link_present "hapax-notification-private-playback:output_FR" "playback_AUX9"; then
    check "notifications do not share private TTS AUX8/9" "notification-private is feeding MPC AUX8/9"
else
    check "notifications do not share private TTS AUX8/9" "PASS"
fi

if link_present "hapax-m8-loudnorm-playback:output_AUX10" "playback_AUX10" \
    || link_present "hapax-m8-loudnorm-playback:output_AUX11" "playback_AUX11" \
    || link_present "hapax-m8-loudnorm-playback:output_AUX10" "alsa_output.usb-ZOOM_Corporation_L-12_8253FFFFFFFFFFFF9B5FFFFFFFFFFFFF-00.analog-surround-40:playback_FL" \
    || link_present "hapax-m8-loudnorm-playback:output_AUX11" "alsa_output.usb-ZOOM_Corporation_L-12_8253FFFFFFFFFFFF9B5FFFFFFFFFFFFF-00.analog-surround-40:playback_FR"; then
    check "M8/instrument route is disabled" "M8 loudnorm has a live MPC/L-12 egress"
else
    check "M8/instrument route is disabled" "PASS"
fi

if link_present "hapax-s4-tap:output_FL" "hapax-livestream-tap:playback_FL" \
    || link_present "hapax-s4-tap:output_FR" "hapax-livestream-tap:playback_FR"; then
    check "S-4 direct tap is disabled" "S-4 tap is feeding livestream"
else
    check "S-4 direct tap is disabled" "PASS"
fi

if link_present "input.loopback.sink.role.assistant-output:output_FL" "input.loopback.sink.role.multimedia:playback_FL" \
    || link_present "input.loopback.sink.role.assistant-output:output_FR" "input.loopback.sink.role.multimedia:playback_FR"; then
    check "assistant/private does not fall into multimedia" "assistant role is feeding multimedia/PC"
else
    check "assistant/private does not fall into multimedia" "PASS"
fi

if regex_link_present '^output[.]loopback-[0-9]+-[0-9]+:output_(FL|FR)$' 'input[.]loopback[.]sink[.]role[.]multimedia:playback_(FL|FR)' ; then
    check "livestream tap bridge does not fall into multimedia" "tap bridge is feeding multimedia/PC"
else
    check "livestream tap bridge does not fall into multimedia" "PASS"
fi

if regex_link_present '^alsa_input[.]usb-.*(Logitech|C920|BRIO|ZOOM_Corporation_L-12).*:capture_' 'hapax-polyend-instrument-capture:input_[12]' ; then
    check "optional Polyend capture is fail-closed" "Polyend capture fell back to webcam/L-12/default capture"
else
    check "optional Polyend capture is fail-closed" "PASS"
fi

echo ""
echo "Chain 5c: Default Sink Fail-Closed Guard"

DEFAULT_SINK="$(current_default_sink || true)"
case "$DEFAULT_SINK" in
    hapax-pc-loudnorm|input.loopback.sink.role.multimedia)
        check "default/unclassified audio lands on fail-closed multimedia" "PASS ($DEFAULT_SINK)"
        ;;
    "")
        check "default/unclassified audio lands on fail-closed multimedia" "could not read default sink"
        ;;
    *Akai_Professional_MPC_LIVE_III*|*ZOOM_Corporation_L-12*|*Torso_Electronics_S-4*|*Dirtywave_M8*|*Blue_Microphones_Yeti*|bluez_output.*|*hdmi*)
        check "default/unclassified audio lands on fail-closed multimedia" "default sink is live/physical: $DEFAULT_SINK"
        ;;
    *)
        check "default/unclassified audio lands on fail-closed multimedia" "unexpected default sink: $DEFAULT_SINK"
        ;;
esac

echo ""
echo "Chain 5d: WirePlumber Link-Time Deny Policy"

WP_DENY_CONF_SOURCE="${HAPAX_WP_DENY_CONF_SOURCE:-$REPO_ROOT/config/wireplumber/98-hapax-link-deny.conf}"
WP_DENY_SCRIPT_SOURCE="${HAPAX_WP_DENY_SCRIPT_SOURCE:-$REPO_ROOT/config/wireplumber/scripts/hapax/link-deny.lua}"
WP_DENY_CONF_INSTALLED="${HAPAX_WP_DENY_CONF_INSTALLED:-$HOME/.config/wireplumber/wireplumber.conf.d/98-hapax-link-deny.conf}"
WP_DENY_SCRIPT_INSTALLED="${HAPAX_WP_DENY_SCRIPT_INSTALLED:-$HOME/.local/share/wireplumber/scripts/hapax/link-deny.lua}"
WP_DENY_SCRIPT_LEGACY_INSTALLED="${HAPAX_WP_DENY_SCRIPT_LEGACY_INSTALLED:-$HOME/.config/wireplumber/scripts/hapax/link-deny.lua}"
FORBIDDEN_LINKS_SOURCE="${HAPAX_FORBIDDEN_LINKS_SOURCE:-$REPO_ROOT/config/hapax/audio-forbidden-links.conf}"
FORBIDDEN_LINKS_RUNTIME="${HAPAX_FORBIDDEN_LINKS_RUNTIME:-$HOME/.config/hapax/audio-forbidden-links.conf}"

if [ -f "$WP_DENY_CONF_SOURCE" ] && [ -f "$WP_DENY_SCRIPT_SOURCE" ]; then
    check "WirePlumber deny source artifacts present" "PASS"
else
    check "WirePlumber deny source artifacts present" "missing source policy"
fi

if [ -f "$FORBIDDEN_LINKS_SOURCE" ]; then
    check "forbidden links source conf present" "PASS"
else
    check "forbidden links source conf present" "missing: $FORBIDDEN_LINKS_SOURCE"
fi

if [ -f "$FORBIDDEN_LINKS_RUNTIME" ]; then
    if cmp -s "$FORBIDDEN_LINKS_SOURCE" "$FORBIDDEN_LINKS_RUNTIME"; then
        check "forbidden links runtime conf matches source" "PASS"
    else
        check "forbidden links runtime conf matches source" "runtime file differs from source — reinstall required"
    fi
else
    check "forbidden links runtime conf present" "missing: deny hook will run in degraded fail-closed mode"
fi

if [ -f "$WP_DENY_CONF_INSTALLED" ] && [ -f "$WP_DENY_SCRIPT_INSTALLED" ]; then
    if cmp -s "$WP_DENY_CONF_SOURCE" "$WP_DENY_CONF_INSTALLED" \
        && cmp -s "$WP_DENY_SCRIPT_SOURCE" "$WP_DENY_SCRIPT_INSTALLED"; then
        check "WirePlumber deny policy installed matches source" "PASS"
    else
        check "WirePlumber deny policy installed matches source" "installed policy differs from source — stale hook"
    fi
else
    check "WirePlumber deny policy not installed" "deny hook absent from live WirePlumber — boundaries unguarded at link-time"
fi

wp_deny_script_legacy_real="$(realpath -m "$WP_DENY_SCRIPT_LEGACY_INSTALLED")"
wp_deny_script_installed_real="$(realpath -m "$WP_DENY_SCRIPT_INSTALLED")"
if [ -f "$WP_DENY_SCRIPT_LEGACY_INSTALLED" ] && [ "$wp_deny_script_legacy_real" != "$wp_deny_script_installed_real" ]; then
    check "WirePlumber deny script installed in data path only" "legacy config script exists at $WP_DENY_SCRIPT_LEGACY_INSTALLED — reinstall fixed policy"
else
    check "WirePlumber deny script installed in data path only" "PASS"
fi

if [ -f "$WP_DENY_SCRIPT_INSTALLED" ] && [ -r "$WP_DENY_SCRIPT_INSTALLED" ]; then
    if grep -q "FAIL_CLOSED_BOUNDARY_PAIRS" "$WP_DENY_SCRIPT_INSTALLED"; then
        check "installed deny hook has fail-closed boundary set" "PASS"
    else
        check "installed deny hook has fail-closed boundary set" "hook lacks FAIL_CLOSED_BOUNDARY_PAIRS — pre-fail-closed version"
    fi
fi

# ── Invariant 6: No .conf files that create bypass paths ──
echo ""
echo "Chain 6: Config File Guard"

BYPASS_CONFS=$(ls ~/.config/pipewire/pipewire.conf.d/*tts-broadcast-tap*.conf 2>/dev/null || true)
if [ -z "$BYPASS_CONFS" ]; then
    check "no active TTS bypass configs" "PASS"
else
    check "no active TTS bypass configs" "found: $BYPASS_CONFS"
fi

# Check for any .conf that creates a PLAYBACK node targeting livestream-tap
# that is NOT one of the legitimate L12/S4 sources.
# Legitimate: hapax-l12-evilpet-capture, hapax-l12-usb-return-capture.
# Bypass:     anything else creating a playback→livestream-tap path.
LEGIT_TAP_SOURCES="hapax-l12-evilpet|hapax-l12-usb-return|hapax-broadcast-master"
SUSPECT=$(grep -rl "target.object.*livestream-tap" ~/.config/pipewire/pipewire.conf.d/*.conf 2>/dev/null | while read f; do
    bn=$(basename "$f")
    if ! echo "$bn" | grep -qE "$LEGIT_TAP_SOURCES"; then
        if grep -A5 'playback.props' "$f" | grep -q 'target.object.*livestream-tap'; then
            echo "$f"
        fi
    fi
done || true)
if [ -z "$SUSPECT" ]; then
    check "no unauthorized playback into livestream-tap" "PASS"
else
    check "no unauthorized playback into livestream-tap" "bypass config: $SUSPECT"
fi

# ── Invariant 7: Critical nodes not muted ──
echo ""
echo "Chain 7: Mute State Guard"

# The broadcast loopback being muted silently kills ALL TTS-to-livestream
# audio despite every PipeWire link showing connected. This is the single
# most insidious failure mode — the graph looks perfect but no signal flows.
BROADCAST_MUTE=$(wpctl get-volume "$(pw-cli ls Node 2>/dev/null | grep -B5 'input.loopback.sink.role.broadcast' | head -1 | awk '{print $2}' | tr -d ',')" 2>/dev/null || echo "UNKNOWN")
if echo "$BROADCAST_MUTE" | grep -qi "muted"; then
    check "broadcast loopback not muted" "MUTED — unmute with: wpctl set-mute <id> 0"
elif echo "$BROADCAST_MUTE" | grep -qi "volume"; then
    check "broadcast loopback not muted" "PASS"
else
    check "broadcast loopback not muted" "could not read mute state: $BROADCAST_MUTE"
fi

# Also check the voice-fx and loudnorm chain nodes
for NODE_NAME in hapax-voice-fx-capture hapax-loudnorm-capture; do
    NODE_ID=$(pw-cli ls Node 2>/dev/null | grep -B5 "$NODE_NAME" | head -1 | awk '{print $2}' | tr -d ',' 2>/dev/null || echo "")
    if [ -n "$NODE_ID" ]; then
        MUTE_STATE=$(wpctl get-volume "$NODE_ID" 2>/dev/null || echo "UNKNOWN")
        if echo "$MUTE_STATE" | grep -qi "muted"; then
            check "$NODE_NAME not muted" "MUTED"
        elif echo "$MUTE_STATE" | grep -qi "volume"; then
            check "$NODE_NAME not muted" "PASS"
        else
            check "$NODE_NAME not muted" "could not read: $MUTE_STATE"
        fi
    fi
done


# ── Invariant 8: .conf safety pattern (room-mic-hijack regression) ──
echo ""
echo "Chain 8: PipeWire .conf Safety Pattern"

# Filter-chains targeting specific ALSA hardware MUST set either
# node.passive=true OR node.dont-reconnect=true. Without this, when the
# target ALSA device is missing, WirePlumber's auto-link policy binds
# the filter-chain to the default source (typically a webcam mic), causing
# a class of leak documented in 10-contact-mic.conf as "the whole
# room-mic-hijack class of bugs".
#
# Incident 2026-05-06: hapax-l12-usb-return-capture had dont-reconnect=false
# and no node.passive=true; when L-12 USB was detached, C920 webcam mic
# leaked into broadcast.

UNSAFE_CONFS=""
for conf in ~/.config/pipewire/pipewire.conf.d/*.conf; do
    [ -f "$conf" ] || continue
    if grep -qE 'target\.object\s*=\s*"alsa_|node\.target\s*=\s*"alsa_' "$conf" 2>/dev/null; then
        if ! grep -qE 'node\.passive\s*=\s*true' "$conf" && ! grep -qE 'node\.dont-reconnect\s*=\s*true' "$conf"; then
            UNSAFE_CONFS="$UNSAFE_CONFS $(basename $conf)"
        fi
    fi
done
if [ -n "$UNSAFE_CONFS" ]; then
    check ".conf safety pattern (passive=true OR dont-reconnect=true)" "UNSAFE:$UNSAFE_CONFS"
else
    check ".conf safety pattern (passive=true OR dont-reconnect=true)" "PASS"
fi


# ── Invariant 9: webcam mic NEVER feeds broadcast filter-chains ──
echo ""
echo "Chain 9: Webcam Mic Broadcast Leak Guard"

# Per 2026-05-06 incident: C920 webcam mic leaked into broadcast via
# hapax-l12-usb-return-capture filter-chain when L-12 USB was missing.
# Regression check: NO webcam (C920/Brio) capture pad should be linked
# into hapax-l12-usb-return-capture, hapax-l12-evilpet-capture,
# hapax-m8-instrument-capture, or directly into livestream-feeding chains.

WEBCAM_LEAK=$(pw-link -l 2>/dev/null | grep -B 1 -E "hapax-(l12-usb-return-capture|l12-evilpet-capture|m8-instrument-capture):input_AUX" 2>/dev/null | grep -E "C920|Brio|Logitech" 2>/dev/null || true)
if [ -n "$WEBCAM_LEAK" ]; then
    check "no webcam mic in L-12/M-8 capture filter-chains" "LEAK:${WEBCAM_LEAK:0:80}..."
else
    check "no webcam mic in L-12/M-8 capture filter-chains" "PASS"
fi

# ── Invariant 10: L-12 completeness ──
echo "Chain 10: L-12 Completeness (every active USB return channel reaches broadcast)"

# Per feedback_l12_equals_livestream_invariant (operator directive
# 2026-04-21): "anything entering the L-12 (input OR USB playback)
# MUST reach broadcast. Monitor / private / non-broadcast audio must
# leave L-12 entirely. No carve-outs."
#
# This checks that hapax-livestream-tap (the broadcast aggregation
# point) has ACTIVE input links from both legitimate L-12 sources:
# hapax-l12-evilpet-playback and hapax-l12-usb-return-playback.
# If either is disconnected, L-12 audio is silently dropped from
# broadcast — the invariant violation is a silent failure mode.

L12_COMPLETENESS_OK=true
L12_SOURCE="alsa_input.usb-ZOOM_Corporation_L-12_8253FFFFFFFFFFFF9B5FFFFFFFFFFFFF-00.pro-input-0"

# Check MPC wet-return capture inputs. This is the signal-bearing upstream
# leg for the hardware-first baseline: MPC Out 1/2 and 3/4 land on L-12
# CH 9-12, exposed by PipeWire as AUX8-AUX11, then enter the wet-return
# filter-chain before the stereo sum reaches livestream-tap.
for pair in \
    "AUX8 hapax-l12-usb-return-capture:input_AUX8" \
    "AUX9 hapax-l12-usb-return-capture:input_AUX9" \
    "AUX10 hapax-l12-usb-return-capture:input_AUX10" \
    "AUX11 hapax-l12-usb-return-capture:input_AUX11"; do
    aux="${pair%% *}"
    target="${pair#* }"
    if link_present "$L12_SOURCE:capture_$aux" "$target"; then
        check "L-12 $aux → l12-usb-return-capture linked" "PASS"
    else
        check "L-12 $aux → l12-usb-return-capture linked" "MISSING"
        L12_COMPLETENESS_OK=false
    fi
done

# Check l12-evilpet → livestream-tap link
EVILPET_TO_TAP=$(pw-link -l 2>/dev/null | grep -A 5 "hapax-l12-evilpet-playback" 2>/dev/null | grep "hapax-livestream-tap" 2>/dev/null || true)
if [ -z "$EVILPET_TO_TAP" ]; then
    check "l12-evilpet-playback → livestream-tap linked" "MISSING"
    L12_COMPLETENESS_OK=false
else
    check "l12-evilpet-playback → livestream-tap linked" "PASS"
fi

# Check l12-usb-return → livestream-tap link
USB_RETURN_TO_TAP=$(pw-link -l 2>/dev/null | grep -A 5 "hapax-l12-usb-return-playback" 2>/dev/null | grep "hapax-livestream-tap" 2>/dev/null || true)
if [ -z "$USB_RETURN_TO_TAP" ]; then
    check "l12-usb-return-playback → livestream-tap linked" "MISSING"
    L12_COMPLETENESS_OK=false
else
    check "l12-usb-return-playback → livestream-tap linked" "PASS"
fi

# Check that livestream-tap itself has at least one output going to
# broadcast-master (the normalization stage before OBS).
TAP_TO_MASTER=$(pw-link -l 2>/dev/null | grep -A 5 "hapax-livestream-tap" 2>/dev/null | grep "hapax-broadcast-master" 2>/dev/null || true)
if [ -z "$TAP_TO_MASTER" ]; then
    check "livestream-tap → broadcast-master linked" "MISSING"
    L12_COMPLETENESS_OK=false
else
    check "livestream-tap → broadcast-master linked" "PASS"
fi

if [ "$L12_COMPLETENESS_OK" = true ]; then
    echo "  L-12 completeness: ALL L-12 sources reach broadcast ✓"
fi

# ── Signal-Flow Advisory Check (Invariant 11) ──────────────────────────────
if ! command -v pw-top &>/dev/null; then
    echo ""
    echo "=== Signal-Flow Advisory ==="
    echo "  [SKIP] pw-top not available — signal flow check skipped"
else
# PipeWire links can exist but carry zero audio data. Use pw-top to detect
# nodes that are "Running" but have quantum=0 / rate=0, indicating no data
# is flowing despite the topology being connected. This is advisory (WARN)
# because some nodes legitimately idle (e.g. music player paused).
echo ""
echo "=== Signal-Flow Advisory ==="
FLOW_WARNINGS=0

check_signal_flow() {
    local node_name="$1"
    local label="$2"
    # pw-top -b -n 1 outputs one snapshot; grep for the node and check
    # quantum (field 3) and rate (field 4). Both 0 means no data flows.
    local row
    row=$(pw-top -b -n 1 2>/dev/null | grep "$node_name" | head -1 || true)
    if [ -z "$row" ]; then
        echo -e "  ${YELLOW}[WARN]${NC} $label: node not found in pw-top"
        FLOW_WARNINGS=$((FLOW_WARNINGS + 1))
        return
    fi
    # Fields: State ID Quantum Rate Wait Busy W/Q B/Q ERR Format CH Rate Name
    local quantum rate
    quantum=$(echo "$row" | awk '{print $3}')
    rate=$(echo "$row" | awk '{print $4}')
    if [ "$quantum" = "0" ] && [ "$rate" = "0" ]; then
        echo -e "  ${YELLOW}[WARN]${NC} $label: quantum=0 rate=0 — NO DATA FLOWING"
        FLOW_WARNINGS=$((FLOW_WARNINGS + 1))
    else
        echo -e "  ${GREEN}[OK]${NC}   $label: quantum=$quantum rate=$rate — data flowing"
    fi
}

check_signal_flow "hapax-music-loudnorm" "Music loudnorm filter chain"
check_signal_flow "hapax-livestream-tap" "Livestream tap null-sink"
check_signal_flow "hapax-broadcast-master" "Broadcast master"

if [ "$FLOW_WARNINGS" -gt 0 ]; then
    echo -e "  ${YELLOW}Signal flow: $FLOW_WARNINGS node(s) idle — check music player / source status${NC}"
else
    echo "  Signal flow: ALL critical nodes have active data ✓"
fi

fi  # close: if ! command -v pw-top

echo ""
echo "=== Result ==="
if [ "$FAILURES" -eq 0 ]; then
    echo -e "${GREEN}ALL INVARIANTS PASSED${NC}"
    exit 0
else
    echo -e "${RED}$FAILURES INVARIANT(S) VIOLATED${NC}"
    exit 1
fi
