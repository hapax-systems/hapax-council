#!/usr/bin/env bash
# hapax-audio-routing-check — validate PipeWire audio routing invariants
#
# Run before AND after any audio config change. Exits non-zero if any
# invariant is violated. Designed to be called by:
#   - git pre-commit hook (when PipeWire configs change)
#   - systemd health timer (hapax-audio-routing-check.timer)
#   - any AI agent before/after touching audio
#   - the operator manually: ./scripts/hapax-audio-routing-check
#
# TOPOLOGY (2026-06 — MOTU UltraLite mk5 + Torso S-4 analog insert + Faderfox MX12;
# retired PC->MPC->L-12->PC->OBS; L-12, MPC Live III, Evil Pet all removed):
#
#   TTS -> voice-fx -> loudnorm -> mk5 OUT 3/4 (pro-output AUX2/3)
#       -> S-4 line in -> [S-4 Material=Bypass FX] -> S-4 line out
#       -> mk5 IN 3/4 (pro-input AUX2/3) -> hapax-voice-wet -> livestream-tap
#   Rode -> mk5 IN 1 (pro-input AUX0) -> hapax-mic-rode -> livestream-tap
#   music -> music-loudnorm -> music-duck-mk5 -> livestream-tap ; youtube -> yt-loudnorm -> livestream-tap
#   livestream-tap (software sum) -> broadcast-master -> broadcast-normalized
#       -> obs-broadcast-remap -> OBS
#   private/notification/PC -> fail-closed (no broadcast egress); private monitor -> mk5 Phones AUX10/11
#
# Exit codes: 0 = all good, 1 = invariant violation, 2 = PipeWire not running

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
    SCRIPT_PATH="$(readlink -f -- "$SCRIPT_PATH" 2>/dev/null || printf '%s\n' "$SCRIPT_PATH")"
fi
SCRIPT_DIR="$(cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
DEFAULT_REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
REPO_ROOT="${HAPAX_AUDIO_REPO_ROOT:-$DEFAULT_REPO_ROOT}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ── M3: differential wet-return level witness — pure verdict core + test seam ──
# Chain 2 verifies the S-4 wet-return LINKS exist but not that signal flows; a
# dead S-4 (links up, analog return silent) used to pass GREEN. The witness
# samples the DRY send and the WET return and compares them differentially, so
# it only fails on the green-while-silent state and never at idle:
#   dry < floor                  -> IDLE  (no voice being sent; cannot witness)
#   dry >= floor and wet < floor -> DEAD  (voice sent into the S-4, none returns)
#   both >= floor                -> LIVE  (wet return alive)
wet_return_verdict() {
    local dry="${1:-0}" wet="${2:-0}" floor="${3:-0.001}"
    awk -v dry="$dry" -v wet="$wet" -v floor="$floor" 'BEGIN {
        if (dry + 0 < floor + 0) { print "IDLE"; exit 0 }
        if (wet + 0 < floor + 0) { print "DEAD"; exit 0 }
        print "LIVE"; exit 0
    }'
}

# Testable seam: emit the pure verdict and exit BEFORE any PipeWire call, so CI /
# dev hosts with no audio stack can pin the decision core.
if [ "${1:-}" = "--wet-return-verdict" ]; then
    wet_return_verdict "${2:-0}" "${3:-0}" "${4:-0.001}"
    exit 0
fi

# mk5 ACP pro-audio node names (pinned by wireplumber 14-hapax-mk5-pro-audio.conf).
MK5_OUT="alsa_output.usb-MOTU_UltraLite-mk5_UL5LFEC2B0-00.pro-output-0"
MK5_IN="alsa_input.usb-MOTU_UltraLite-mk5_UL5LFEC2B0-00.pro-input-0"

GRAPH=$(pw-link -l 2>&1) || { echo -e "${RED}FAIL: PipeWire not running${NC}"; exit 2; }
FAILURES=0
# Set when the S-4 wet-return capture link is present; gates the level witness
# below so it never double-counts the link-down case (Chain 2 owns that).
S4_WET_RETURN_LINK_OK=0

link_present() {
    local source_port="$1"
    local target_port="$2"
    printf '%s\n' "$GRAPH" | awk -v src="$source_port" -v target="$target_port" '
        {
            line = $0
            sub(/^[[:space:]]*/, "", line)
        }
        line == src { within = 1; next }
        line !~ /^\|/ { within = 0 }
        within && line ~ /^\|->/ && index(line, target) { found = 1 }
        END { exit found ? 0 : 1 }
    '
}

regex_link_present() {
    local source_re="$1"
    local target_re="$2"
    printf '%s\n' "$GRAPH" | awk -v src_re="$source_re" -v target_re="$target_re" '
        {
            line = $0
            sub(/^[[:space:]]*/, "", line)
        }
        line ~ src_re { within = 1; next }
        line !~ /^\|/ { within = 0 }
        within && line ~ /^\|->/ && line ~ target_re { found = 1 }
        END { exit found ? 0 : 1 }
    '
}

livestream_tap_input_sources() {
    printf '%s\n' "$GRAPH" | awk '
        {
            line = $0
            sub(/^[[:space:]]*/, "", line)
        }
        line !~ /^\|/ {
            current = line
            next
        }
        line ~ /^\|->/ && current != "" && line ~ /hapax-livestream-tap:playback_(FL|FR)/ {
            print current
        }
        current ~ /^hapax-livestream-tap:playback_(FL|FR)$/ && line ~ /^\|<-/ {
            source = line
            sub(/^\|<-[[:space:]]*/, "", source)
            print source
        }
    ' | sort -u
}

current_default_sink() {
    if ! command -v pactl >/dev/null 2>&1; then
        return 1
    fi
    pactl info 2>/dev/null | awk -F': ' '/^Default Sink:/ { print $2; exit }'
}

sink_volume_nonzero() {
    local sink="$1"
    local volume_text
    if ! command -v pactl >/dev/null 2>&1; then
        return 1
    fi
    volume_text="$(pactl get-sink-volume "$sink" 2>/dev/null || true)"
    [ -n "$volume_text" ] || return 1
    python3 -c 'import re, sys
volumes = [int(value) for value in re.findall(r"/\s*([0-9]+)%", sys.stdin.read())]
sys.exit(0 if volumes and all(value > 0 for value in volumes) else 1)
' <<<"$volume_text"
}

sink_unmuted() {
    local sink="$1"
    local mute_text
    if ! command -v pactl >/dev/null 2>&1; then
        return 1
    fi
    mute_text="$(pactl get-sink-mute "$sink" 2>/dev/null || true)"
    [ "$mute_text" = "Mute: no" ]
}

check() {
    local desc="$1"
    local result="$2"
    if [[ "$result" == PASS* ]]; then
        echo -e "  ${GREEN}✓${NC} $desc ${result#PASS}"
    else
        echo -e "  ${RED}✗ FAIL: $desc — $result${NC}"
        FAILURES=$((FAILURES + 1))
    fi
}

echo "=== Hapax Audio Routing Invariant Check (mk5 + S-4 topology) ==="
echo ""

# ── Invariant 1: TTS voice chain to the S-4 dry send ──
echo "Chain 1: TTS Voice Path (-> mk5 OUT 3/4 -> S-4)"
if link_present "input.loopback.sink.role.broadcast-output:output_FL" "hapax-voice-fx-capture:playback_FL"; then
    check "role.broadcast → voice-fx-capture" "PASS"
else
    check "role.broadcast → voice-fx-capture" "link missing"
fi
if link_present "hapax-voice-fx-playback:output_FL" "hapax-loudnorm-capture:playback_FL"; then
    check "voice-fx-playback → loudnorm-capture" "PASS"
else
    check "voice-fx-playback → loudnorm-capture" "link missing"
fi
if link_present "hapax-loudnorm-playback:output_FL" "${MK5_OUT}:playback_AUX2" \
    && link_present "hapax-loudnorm-playback:output_FR" "${MK5_OUT}:playback_AUX3"; then
    check "loudnorm-playback → mk5 OUT AUX2/3 (dry voice → S-4)" "PASS"
else
    check "loudnorm-playback → mk5 OUT AUX2/3 (dry voice → S-4)" "link missing — TTS not reaching the S-4 insert"
fi
echo ""

# ── Invariant 2: S-4 analog insert wet return ──
echo "Chain 2: S-4 Wet Voice Return (mk5 IN 3/4 → livestream)"
if link_present "${MK5_IN}:capture_AUX2" "hapax-voice-wet-capture:input_AUX2" \
    && link_present "${MK5_IN}:capture_AUX3" "hapax-voice-wet-capture:input_AUX3"; then
    check "mk5 IN AUX2/3 → voice-wet-capture (S-4 return)" "PASS"
    S4_WET_RETURN_LINK_OK=1
else
    check "mk5 IN AUX2/3 → voice-wet-capture (S-4 return)" "link missing — S-4 wet voice not captured"
fi
if link_present "hapax-voice-wet-playback:output_FL" "hapax-livestream-tap:playback_FL" \
    && link_present "hapax-voice-wet-playback:output_FR" "hapax-livestream-tap:playback_FR"; then
    check "voice-wet-playback → livestream-tap" "PASS"
else
    check "voice-wet-playback → livestream-tap" "link missing — modulated voice not on broadcast"
fi
echo ""

# ── Invariant 3: Operator Rode mic (never dropped) ──
echo "Chain 3: Operator Rode Mic (mk5 IN 1 → livestream)"
if link_present "${MK5_IN}:capture_AUX0" "hapax-mic-rode-capture:input_AUX0"; then
    check "mk5 IN AUX0 → mic-rode-capture (Rode)" "PASS"
else
    check "mk5 IN AUX0 → mic-rode-capture (Rode)" "link missing — operator mic not captured"
fi
if link_present "hapax-mic-rode-playback:output_FL" "hapax-livestream-tap:playback_FL" \
    && link_present "hapax-mic-rode-playback:output_FR" "hapax-livestream-tap:playback_FR"; then
    check "mic-rode-playback → livestream-tap" "PASS"
else
    check "mic-rode-playback → livestream-tap" "link missing — operator voice not on broadcast"
fi
echo ""

# ── Invariant 4: Music + YouTube into the software sum bus (mk5: loudnorm → music-duck-mk5 → tap) ──
echo "Chain 4: Music / YouTube → livestream-tap (software mix)"
if link_present "hapax-music-loudnorm-playback:output_FL" "hapax-music-duck-mk5:playback_FL"; then
    check "music-loudnorm → music-duck-mk5 (mk5 ducker)" "PASS"
else
    check "music-loudnorm → music-duck-mk5 (mk5 ducker)" "missing — music not loudness-normalized into the mk5 ducker"
fi
if link_present "hapax-music-duck-mk5-playback:output_FL" "hapax-livestream-tap:playback_FL"; then
    check "music-duck-mk5 → livestream-tap" "PASS"
else
    check "music-duck-mk5 → livestream-tap" "missing — music not reaching broadcast sum bus"
fi
if link_present "hapax-yt-loudnorm-playback:output_FL" "hapax-livestream-tap:playback_FL"; then
    check "yt-loudnorm → livestream-tap" "PASS (linked)"
elif echo "$GRAPH" | grep -q "hapax-yt-loudnorm-playback"; then
    check "yt-loudnorm → livestream-tap" "PASS (node present, idle/unlinked — YT bed inactive)"
else
    check "yt-loudnorm → livestream-tap" "PASS (no YT node)"
fi
echo ""

# ── Invariant 5: Livestream tap input allowlist ──
echo "Chain 5: Livestream Tap Input Allowlist"
UNEXPECTED_TAP_INPUTS=""
while IFS= read -r source_port; do
    [ -n "$source_port" ] || continue
    case "$source_port" in
        hapax-voice-wet-playback:output_FL|hapax-voice-wet-playback:output_FR|hapax-mic-rode-playback:output_FL|hapax-mic-rode-playback:output_FR|hapax-music-loudnorm-playback:output_FL|hapax-music-loudnorm-playback:output_FR|hapax-music-duck-mk5-playback:output_FL|hapax-music-duck-mk5-playback:output_FR|hapax-yt-loudnorm-playback:output_FL|hapax-yt-loudnorm-playback:output_FR)
            ;;
        *)
            if [ -n "$UNEXPECTED_TAP_INPUTS" ]; then
                UNEXPECTED_TAP_INPUTS="$UNEXPECTED_TAP_INPUTS, $source_port"
            else
                UNEXPECTED_TAP_INPUTS="$source_port"
            fi
            ;;
    esac
done < <(livestream_tap_input_sources)
if [ -n "$UNEXPECTED_TAP_INPUTS" ]; then
    check "livestream-tap has only authorized inputs" "unexpected source(s): $UNEXPECTED_TAP_INPUTS"
else
    check "livestream-tap has only authorized inputs" "PASS"
fi
echo ""

# ── Invariant 6: Broadcast spine + OBS ──
echo "Chain 6: Broadcast Spine + OBS"
if link_present "hapax-livestream-tap:monitor_FL" "hapax-broadcast-master-capture:input_FL"; then
    check "livestream-tap → broadcast-master" "PASS"
else
    check "livestream-tap → broadcast-master" "link missing — sum bus not feeding master"
fi
if link_present "hapax-broadcast-normalized:capture_FL" "hapax-obs-broadcast-remap-capture:input_FL" \
    || regex_link_present 'hapax-broadcast-normalized' 'hapax-obs-broadcast-remap'; then
    check "broadcast-normalized → obs-broadcast-remap" "PASS"
else
    check "broadcast-normalized → obs-broadcast-remap" "link missing"
fi
if regex_link_present 'hapax-obs-broadcast-remap' 'OBS|obs'; then
    check "obs-broadcast-remap → OBS" "PASS"
else
    echo -e "  ${YELLOW}[WARN]${NC} obs-broadcast-remap → OBS not linked (OBS may be closed or binding pending)"
fi
echo ""

# ── Invariant 7: Livestream / non-livestream boundary (fail-closed) ──
echo "Chain 7: Broadcast Boundary Guard (private/PC/notification fenced)"
boundary_ok=true
for src in hapax-private-playback hapax-notification-private-playback hapax-pc-loudnorm-playback; do
    if link_present "${src}:output_FL" "hapax-livestream-tap:playback_FL" \
        || link_present "${src}:output_FR" "hapax-livestream-tap:playback_FR" \
        || link_present "${src}:output_FL" "hapax-broadcast-master-capture:input_FL"; then
        check "$src is fenced from broadcast" "$src is feeding the broadcast sum/master"
        boundary_ok=false
    else
        check "$src is fenced from broadcast" "PASS"
    fi
done
# private / PC must never reach the mk5 dry-voice send (AUX2/3 → S-4 → broadcast)
for src in hapax-pc-loudnorm-playback hapax-private-playback hapax-notification-private-playback; do
    if link_present "${src}:output_FL" "${MK5_OUT}:playback_AUX2" \
        || link_present "${src}:output_FR" "${MK5_OUT}:playback_AUX3"; then
        check "$src not on mk5 dry-voice send AUX2/3" "$src is feeding the S-4 dry send"
        boundary_ok=false
    else
        check "$src not on mk5 dry-voice send AUX2/3" "PASS"
    fi
done
if link_present "input.loopback.sink.role.assistant-output:output_FL" "input.loopback.sink.role.multimedia:playback_FL" \
    || link_present "output.loopback.sink.role.assistant:output_FL" "input.loopback.sink.role.multimedia:playback_FL"; then
    check "assistant/private does not fall into multimedia" "assistant role is feeding multimedia/PC"
    boundary_ok=false
else
    check "assistant/private does not fall into multimedia" "PASS"
fi
if regex_link_present '^output[.]loopback-[0-9]+-[0-9]+:output_FL$' 'input[.]loopback[.]sink[.]role[.]multimedia:playback_FL' \
    || regex_link_present '^output[.]loopback-[0-9]+-[0-9]+:output_FR$' 'input[.]loopback[.]sink[.]role[.]multimedia:playback_FR'; then
    check "livestream tap bridge does not fall into multimedia" "tap bridge is feeding multimedia/PC"
    boundary_ok=false
else
    check "livestream tap bridge does not fall into multimedia" "PASS"
fi
[ "$boundary_ok" = true ] && echo "  Boundary: non-broadcast lanes are fenced ✓"
echo ""

# ── Invariant 8: Default sink fail-closed ──
echo "Chain 8: Default Sink Fail-Closed Guard"
DEFAULT_SINK="$(current_default_sink || true)"
case "$DEFAULT_SINK" in
    hapax-pc-loudnorm|input.loopback.sink.role.multimedia)
        check "default/unclassified audio lands on fail-closed multimedia" "PASS ($DEFAULT_SINK)" ;;
    "")
        check "default/unclassified audio lands on fail-closed multimedia" "could not read default sink" ;;
    *MOTU_UltraLite-mk5*|*Torso_Electronics_S-4*|*Dirtywave_M8*|*Blue_Microphones_Yeti*|bluez_output.*|*hdmi*)
        check "default/unclassified audio lands on fail-closed multimedia" "default sink is live/physical: $DEFAULT_SINK" ;;
    *)
        check "default/unclassified audio lands on fail-closed multimedia" "unexpected default sink: $DEFAULT_SINK" ;;
esac
echo ""

# ── Invariant 9: .conf safety pattern (room-mic-hijack regression) ──
echo "Chain 9: PipeWire .conf Safety Pattern"
UNSAFE_CONFS=""
for conf in ~/.config/pipewire/pipewire.conf.d/*.conf; do
    [ -f "$conf" ] || continue
    if grep -qE 'target\.object\s*=\s*"alsa_|node\.target\s*=\s*"alsa_' "$conf" 2>/dev/null; then
        if ! grep -qE 'node\.passive\s*=\s*true' "$conf" && ! grep -qE 'node\.dont-reconnect\s*=\s*true' "$conf"; then
            UNSAFE_CONFS="$UNSAFE_CONFS $(basename "$conf")"
        fi
    fi
done
if [ -n "$UNSAFE_CONFS" ]; then
    check ".conf safety pattern (passive=true OR dont-reconnect=true)" "UNSAFE:$UNSAFE_CONFS"
else
    check ".conf safety pattern (passive=true OR dont-reconnect=true)" "PASS"
fi
echo ""

# ── Invariant 10: webcam / optional-device fallback guards ──
echo "Chain 10: Webcam / Optional-Device Fallback Guards"
# Read the $GRAPH snapshot, not a fresh pw-link query — a re-query that fails
# (PipeWire dying mid-run) would silently hide an existing leak.
WEBCAM_LEAK=$(printf '%s\n' "$GRAPH" | grep -B1 -E "hapax-(voice-wet-capture|mic-rode-capture):input" | grep -iE "C920|Brio|Logitech" || true)
if [ -n "$WEBCAM_LEAK" ]; then
    check "no webcam mic in mk5 voice/mic capture chains" "LEAK:${WEBCAM_LEAK:0:80}..."
else
    check "no webcam mic in mk5 voice/mic capture chains" "PASS"
fi
if regex_link_present 'alsa_input[.]usb-(046d_Logitech|ZOOM_Corporation_L-12).*:capture_' 'hapax-polyend-instrument-capture:input_'; then
    check "optional Polyend capture is fail-closed" "Polyend capture fell back to webcam/L-12/default capture"
else
    check "optional Polyend capture is fail-closed" "PASS"
fi
echo ""

# ── Invariant 11: no retired-hardware nodes feed broadcast ──
echo "Chain 11: Retired-Hardware Guard (no L-12 / MPC into broadcast)"
if regex_link_present 'hapax-(l12|mpc)' 'hapax-livestream-tap'; then
    check "no L-12/MPC node feeds livestream-tap" "a retired-hardware node is feeding broadcast"
else
    check "no L-12/MPC node feeds livestream-tap" "PASS"
fi
echo ""

# ── Invariant 12: critical nodes not muted (fail-closed: a node we cannot
# prove audible is a violation — silent skips here are how RED exits 0) ──
echo "Chain 12: Mute State Guard"
for NODE_NAME in input.loopback.sink.role.broadcast hapax-voice-fx-capture hapax-loudnorm-capture hapax-voice-wet-capture hapax-mic-rode-capture; do
    NODE_ID=$(pw-cli ls Node 2>/dev/null | grep -B5 "$NODE_NAME" | grep -oE '^[[:space:]]*id [0-9]+' | head -1 | grep -oE '[0-9]+' || echo "")
    if [ -z "$NODE_ID" ]; then
        check "$NODE_NAME not muted" "critical chain node absent from the live graph"
        continue
    fi
    MUTE_STATE=$(wpctl get-volume "$NODE_ID" 2>/dev/null || echo "")
    if echo "$MUTE_STATE" | grep -qi "muted"; then
        check "$NODE_NAME not muted" "MUTED — unmute with: wpctl set-mute $NODE_ID 0"
    elif echo "$MUTE_STATE" | grep -qi "volume"; then
        check "$NODE_NAME not muted" "PASS"
    else
        check "$NODE_NAME not muted" "mute state unreadable (wpctl said: '${MUTE_STATE:-nothing}')"
    fi
done
if sink_unmuted "hapax-music-loudnorm" && sink_volume_nonzero "hapax-music-loudnorm"; then
    check "hapax-music-loudnorm input sink audible" "PASS"
else
    check "hapax-music-loudnorm input sink audible" "muted or zero-volume — repair with: pactl set-sink-volume hapax-music-loudnorm 100% && pactl set-sink-mute hapax-music-loudnorm 0"
fi
echo ""

# ── Invariant 13: WirePlumber deny policy + forbidden-links present ──
echo "Chain 13: Boundary Policy Artifacts"
WP_DENY_CONF_SOURCE="${HAPAX_WP_DENY_CONF_SOURCE:-$REPO_ROOT/config/wireplumber/98-hapax-link-deny.conf}"
WP_DENY_SCRIPT_SOURCE="${HAPAX_WP_DENY_SCRIPT_SOURCE:-$REPO_ROOT/config/wireplumber/scripts/hapax/link-deny.lua}"
WP_DENY_CONF_INSTALLED="${HAPAX_WP_DENY_CONF_INSTALLED:-$HOME/.config/wireplumber/wireplumber.conf.d/98-hapax-link-deny.conf}"
WP_DENY_SCRIPT_INSTALLED="${HAPAX_WP_DENY_SCRIPT_INSTALLED:-$HOME/.local/share/wireplumber/scripts/hapax/link-deny.lua}"
WP_DENY_SCRIPT_LEGACY_INSTALLED="${HAPAX_WP_DENY_SCRIPT_LEGACY_INSTALLED:-$HOME/.config/wireplumber/scripts/hapax/link-deny.lua}"
FORBIDDEN_LINKS_SOURCE="${HAPAX_FORBIDDEN_LINKS_SOURCE:-$REPO_ROOT/config/hapax/audio-forbidden-links.conf}"
FORBIDDEN_LINKS_RUNTIME="${HAPAX_FORBIDDEN_LINKS_RUNTIME:-$HOME/.config/hapax/audio-forbidden-links.conf}"
LINK_MAP_SOURCE="${HAPAX_LINK_MAP_SOURCE:-$REPO_ROOT/config/hapax/audio-link-map.conf}"
LINK_MAP_RUNTIME="${HAPAX_LINK_MAP_RUNTIME:-$HOME/.config/hapax/audio-link-map.conf}"

if [ -f "$WP_DENY_CONF_SOURCE" ] && [ -f "$WP_DENY_SCRIPT_SOURCE" ]; then
    check "WirePlumber deny source artifacts present" "PASS"
else
    check "WirePlumber deny source artifacts present" "missing source policy"
fi

if [ -f "$FORBIDDEN_LINKS_SOURCE" ]; then
    check "forbidden links source conf present" "PASS"
else
    check "forbidden links source conf present" "missing: $FORBIDDEN_LINKS_SOURCE"
fi

if [ -f "$FORBIDDEN_LINKS_RUNTIME" ]; then
    if cmp -s "$FORBIDDEN_LINKS_SOURCE" "$FORBIDDEN_LINKS_RUNTIME"; then
        check "forbidden links runtime conf matches source" "PASS"
    else
        check "forbidden links runtime conf matches source" "runtime file differs from source — reinstall required"
    fi
else
    check "forbidden links runtime conf present" "missing: deny hook will run in degraded fail-closed mode"
fi

if [ -f "$LINK_MAP_SOURCE" ]; then
    check "link-map source conf present" "PASS"
else
    check "link-map source conf present" "missing: $LINK_MAP_SOURCE"
fi
if [ -f "$LINK_MAP_RUNTIME" ]; then
    if cmp -s "$LINK_MAP_SOURCE" "$LINK_MAP_RUNTIME" && grep -q 'UltraLite-mk5' "$LINK_MAP_RUNTIME" 2>/dev/null; then
        check "link-map runtime targets the mk5" "PASS"
    else
        check "link-map runtime targets the mk5" "runtime file differs from source or still references retired hardware"
    fi
else
    check "link-map runtime targets the mk5" "link-map missing or still references retired hardware"
fi

if [ -f "$WP_DENY_CONF_INSTALLED" ] && [ -f "$WP_DENY_SCRIPT_INSTALLED" ]; then
    if cmp -s "$WP_DENY_CONF_SOURCE" "$WP_DENY_CONF_INSTALLED" \
        && cmp -s "$WP_DENY_SCRIPT_SOURCE" "$WP_DENY_SCRIPT_INSTALLED"; then
        check "WirePlumber deny policy installed matches source" "PASS"
    else
        check "WirePlumber deny policy installed matches source" "installed policy differs from source — stale hook"
    fi
else
    check "WirePlumber deny policy not installed" "deny hook absent from live WirePlumber — boundaries unguarded at link-time"
fi

wp_deny_script_legacy_real="$(realpath -m "$WP_DENY_SCRIPT_LEGACY_INSTALLED")"
wp_deny_script_installed_real="$(realpath -m "$WP_DENY_SCRIPT_INSTALLED")"
if [ -f "$WP_DENY_SCRIPT_LEGACY_INSTALLED" ] && [ "$wp_deny_script_legacy_real" != "$wp_deny_script_installed_real" ]; then
    check "WirePlumber deny script installed in data path only" "legacy config script exists at $WP_DENY_SCRIPT_LEGACY_INSTALLED — reinstall fixed policy"
else
    check "WirePlumber deny script installed in data path only" "PASS"
fi

if [ -f "$WP_DENY_SCRIPT_INSTALLED" ] && [ -r "$WP_DENY_SCRIPT_INSTALLED" ]; then
    if grep -q "FAIL_CLOSED_BOUNDARY_PAIRS" "$WP_DENY_SCRIPT_INSTALLED"; then
        check "installed deny hook has fail-closed boundary set" "PASS"
    else
        check "installed deny hook has fail-closed boundary set" "hook lacks FAIL_CLOSED_BOUNDARY_PAIRS — pre-fail-closed version"
    fi
fi
if systemctl --user is-active hapax-audio-reconciler >/dev/null 2>&1; then
    check "hapax-audio-reconciler active" "PASS"
else
    check "hapax-audio-reconciler active" "reconciler not running — desired-state links unmaintained"
fi

# ── Egress loudness: deployed limiter controls ↔ loudness SSOT (drift guard) ──
# Catches deploy-time drift of the broadcast-master makeup/limit/release from
# shared/audio_loudness.py — the deploy-drift the audio-topology research measured and
# corrected (~/.config/pipewire is not git, and the pre-existing audio gates check route
# STRUCTURE, not these loudness VALUES).
#
# Resolve the helper via the REAL script path (readlink -f follows an installed symlink),
# not the symlink dir, so an installed routing-check still finds the guard beside its
# source. If a conf IS deployed but the guard cannot run, fail CLOSED (UNVERIFIED) — a
# silent no-op here would be the exact fail-open class this guard exists to catch.
_loudness_self="$(readlink -f "$0" 2>/dev/null || echo "$0")"
_loudness_ssot_check="$(dirname "$_loudness_self")/check-broadcast-master-loudness-ssot.py"
_loudness_deployed_conf="$HOME/.config/pipewire/pipewire.conf.d/hapax-broadcast-master.conf"
if [ ! -f "$_loudness_deployed_conf" ]; then
    # No deployed conf (CI / fresh host) → nothing to drift from; skip, don't fail.
    echo "  [SKIP] broadcast-master conf not deployed — loudness SSOT drift check skipped"
elif [ ! -f "$_loudness_ssot_check" ] || ! command -v python3 >/dev/null 2>&1; then
    check "broadcast-master limiter matches loudness SSOT" \
        "guard unavailable (check-broadcast-master-loudness-ssot.py or python3 missing) — a DEPLOYED conf is present but UNVERIFIED (fail-closed, never a silent skip)"
elif python3 "$_loudness_ssot_check" --installed >/dev/null 2>&1; then
    check "broadcast-master limiter matches loudness SSOT" "PASS"
else
    check "broadcast-master limiter matches loudness SSOT" \
        "deployed Input gain/Limit/Release drifted from shared/audio_loudness.py — run scripts/check-broadcast-master-loudness-ssot.py --installed"
fi
echo ""

# ── Signal-Flow Advisory Check ────────────────────────────────────────────
# PipeWire links can exist while a stage carries silence. The old advisory used
# pw-top quantum/rate rows, but those false-negative on the broadcast filter
# chain. Sample the monitor/source with parec and compute RMS instead.
echo ""
echo "=== Signal-Flow Advisory ==="
FLOW_WARNINGS=0

resolve_parec_target() {
    local requested="$1"
    local base="${requested%.monitor}"
    local sources sinks
    sources=$(pactl list sources short 2>/dev/null | awk -F'\t' '{print $2}' || true)
    sinks=$(pactl list sinks short 2>/dev/null | awk -F'\t' '{print $2}' || true)

    if printf '%s\n' "$sources" | grep -Fxq "$requested"; then
        printf '%s\n' "$requested"
    elif [[ "$requested" == *.monitor ]] && printf '%s\n' "$sources" | grep -Fxq "$base"; then
        printf '%s\n' "$base"
    elif [[ "$requested" == *.monitor ]] && printf '%s\n' "$sinks" | grep -Fxq "$base"; then
        printf '%s\n' "$requested"
    elif printf '%s\n' "$sources" | grep -Fxq "$requested"; then
        printf '%s\n' "$requested"
    elif printf '%s\n' "$sinks" | grep -Fxq "$requested"; then
        printf '%s.monitor\n' "$requested"
    else
        printf '%s\n' "$requested"
    fi
}

sample_rms_with_parec() {
    local target="$1"
    local sample_rate="${HAPAX_AUDIO_ROUTING_CHECK_SAMPLE_RATE:-48000}"
    local channels="${HAPAX_AUDIO_ROUTING_CHECK_CHANNELS:-2}"
    local seconds="${HAPAX_AUDIO_ROUTING_CHECK_SIGNAL_SECONDS:-1}"
    local bytes=$((sample_rate * channels * 2 * seconds))
    local timeout_s=$((seconds + 3))
    local rms_line rc

    set +e +o pipefail
    rms_line=$(timeout "$timeout_s" parec \
        --device="$target" \
        --raw \
        --rate="$sample_rate" \
        --channels="$channels" \
        --format=s16le \
        --latency-msec=100 2>/dev/null \
        | head -c "$bytes" \
        | python3 -c 'import array, math, sys
data = sys.stdin.buffer.read()
if len(data) < 2:
    sys.exit(3)
if len(data) % 2:
    data = data[:-1]
samples = array.array("h")
samples.frombytes(data)
if sys.byteorder != "little":
    samples.byteswap()
if not samples:
    sys.exit(3)
mean = sum(int(x) * int(x) for x in samples) / len(samples)
rms = math.sqrt(mean) / 32768.0
dbfs = -120.0 if rms <= 1e-12 else 20.0 * math.log10(rms)
print(f"{rms:.8f} {dbfs:.2f}")')
    rc=$?
    set -e -o pipefail

    if [ "$rc" -ne 0 ] || [ -z "$rms_line" ]; then
        return 1
    fi
    printf '%s\n' "$rms_line"
}

check_signal_flow() {
    local requested_target="$1"
    local label="$2"
    local target rms_line rms dbfs min_rms
    min_rms="${HAPAX_AUDIO_ROUTING_CHECK_RMS_MIN:-0.000001}"
    target=$(resolve_parec_target "$requested_target")
    if ! rms_line=$(sample_rms_with_parec "$target"); then
        echo -e "  ${YELLOW}[WARN]${NC} $label: parec sample failed for $target"
        FLOW_WARNINGS=$((FLOW_WARNINGS + 1))
        return
    fi
    rms=$(printf '%s\n' "$rms_line" | awk '{print $1}')
    dbfs=$(printf '%s\n' "$rms_line" | awk '{print $2}')
    if awk -v rms="$rms" -v min="$min_rms" 'BEGIN { exit !(rms >= min) }'; then
        echo -e "  ${GREEN}[OK]${NC}   $label: RMS=$rms (${dbfs} dBFS) via $target"
    else
        echo -e "  ${YELLOW}[WARN]${NC} $label: RMS=$rms (${dbfs} dBFS) below $min_rms via $target"
        FLOW_WARNINGS=$((FLOW_WARNINGS + 1))
    fi
}

# Fail-closed DIFFERENTIAL witness for the S-4 analog wet return (M3). The
# advisory checks above only WARN; this one increments FAILURES (exit 1) on the
# green-while-silent state. It is gated on the wet-return link being present
# (Chain 2 owns link-down) and is differential — it only fails when dry voice is
# actively flowing yet the wet return is silent, so it never false-fails at idle.
# Mode: HAPAX_WET_RETURN_WITNESS=enforce|warn|off (default enforce).
check_wet_return_witness() {
    local mode floor dry_line wet_line dry_rms wet_rms verdict
    mode="${HAPAX_WET_RETURN_WITNESS:-enforce}"
    [ "$mode" = "off" ] && return 0
    if [ "${S4_WET_RETURN_LINK_OK:-0}" -ne 1 ]; then
        echo -e "  ${YELLOW}[SKIP]${NC} S-4 wet-return witness: link absent (Chain 2 owns this)"
        return 0
    fi
    floor="${HAPAX_WET_RETURN_RMS_MIN:-0.001}"
    if ! dry_line=$(sample_rms_with_parec "$(resolve_parec_target hapax-loudnorm-playback)"); then
        echo -e "  ${YELLOW}[WARN]${NC} S-4 wet-return witness: cannot sample dry send — cannot witness"
        FLOW_WARNINGS=$((FLOW_WARNINGS + 1))
        return 0
    fi
    if ! wet_line=$(sample_rms_with_parec "$(resolve_parec_target hapax-voice-wet-playback)"); then
        # Transient/tooling capture failure is not positive evidence of silence.
        echo -e "  ${YELLOW}[WARN]${NC} S-4 wet-return witness: cannot sample wet return"
        FLOW_WARNINGS=$((FLOW_WARNINGS + 1))
        return 0
    fi
    dry_rms=$(printf '%s\n' "$dry_line" | awk '{print $1}')
    wet_rms=$(printf '%s\n' "$wet_line" | awk '{print $1}')
    verdict=$(wet_return_verdict "$dry_rms" "$wet_rms" "$floor")
    case "$verdict" in
        IDLE)
            echo -e "  ${GREEN}[OK]${NC}   S-4 wet-return witness: IDLE (no dry voice to witness; dry RMS=$dry_rms)"
            ;;
        LIVE)
            echo -e "  ${GREEN}[OK]${NC}   S-4 wet-return witness: LIVE (dry=$dry_rms wet=$wet_rms)"
            ;;
        DEAD)
            if [ "$mode" = "warn" ]; then
                echo -e "  ${YELLOW}[WARN]${NC} S-4 wet-return SILENT while dry voice flows (dry=$dry_rms wet=$wet_rms < $floor) — S-4 insert dead [witness=warn]"
                FLOW_WARNINGS=$((FLOW_WARNINGS + 1))
            else
                check "S-4 wet-return level (dry voice flows but wet return silent)" \
                    "dry=$dry_rms wet=$wet_rms below $floor — S-4 insert DEAD, modulated voice NOT on air"
            fi
            ;;
    esac
}

if ! command -v parec &>/dev/null; then
    echo "  [SKIP] parec not available — signal flow check skipped"
elif ! command -v python3 &>/dev/null; then
    echo "  [SKIP] python3 not available — signal flow check skipped"
else
    check_signal_flow "hapax-livestream-tap.monitor" "Livestream tap"
    check_signal_flow "hapax-broadcast-master.monitor" "Broadcast master"
    check_signal_flow "hapax-obs-broadcast-remap" "OBS broadcast remap"
    check_wet_return_witness

    if [ "$FLOW_WARNINGS" -gt 0 ]; then
        echo -e "  ${YELLOW}Signal flow: $FLOW_WARNINGS node(s) below RMS floor or unavailable${NC}"
    else
        echo "  Signal flow: ALL critical nodes have nonzero RMS ✓"
    fi
fi

echo ""
echo "=== Result ==="
if [ "$FAILURES" -eq 0 ]; then
    echo -e "${GREEN}ALL INVARIANTS PASSED${NC}"
    exit 0
else
    echo -e "${RED}$FAILURES INVARIANT(S) VIOLATED${NC}"
    exit 1
fi
