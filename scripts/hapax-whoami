#!/usr/bin/env bash
# hapax-whoami — print the calling Claude Code session's identity by walking
# the process tree up to the foot terminal window and reading its Hyprland
# window title (alpha / beta / delta / epsilon / gamma or Codex cx-<color>).
#
# Operator convention: each foot window running a Claude Code or Codex
# session is manually titled with the session name (e.g. "alpha" or
# "cx-red"). Claude Code prepends an activity spinner glyph, which this
# script strips before emitting the bare identity.
#
# Exit codes:
#   0 — identity printed to stdout
#   1 — no foot ancestor found, or title has no recognized identity
#   2 — missing dependencies (hyprctl, jq) OR hyprctl output invalid
#       (Hyprland socket unavailable — e.g. HYPRLAND_INSTANCE_SIGNATURE not set)
#
# Installation: install to `~/.local/bin/hapax-whoami` + `chmod +x`.

set -eu

# Canonical identity regex — shared by the --match-title seam and the foot-window
# -title path below. Mirrors the lane vocabulary in hooks/scripts/agent-role.sh.
_IDENTITY_RE='\b(cx-[a-z][a-z-]*|cc-[a-z][a-z-]*|vbe-[0-9]+|antigrav|alpha|beta|gamma|delta|epsilon|zeta|eta|theta|iota)\b'

# Testable seam: `hapax-whoami --match-title "<title>"` runs ONLY the title->identity
# match (the foot-window-title path) so the matcher is unit-testable without a compositor.
if [ "${1:-}" = "--match-title" ]; then
  printf '%s\n' "$(printf '%s' "${2:-}" | grep -oiE "$_IDENTITY_RE" | tail -1 | tr '[:upper:]' '[:lower:]')"
  exit 0
fi

# Env-var identity (the canonical first signal). Mirrors hapax_agent_identity's
# env precedence in hooks/scripts/agent-role.sh EXACTLY (same vars, same order:
# HAPAX_AGENT_NAME -> CODEX thread/session/role -> HAPAX_AGENT_ROLE -> CLAUDE_ROLE)
# so the display can never diverge from the gates' resolver. This is the most
# reliable WM-independent source — it survives a missing compositor (KWin/niri:
# no hyprctl) AND a session-role marker keyed by a non-matching sid (launcher
# SESSION_UUID vs the resolver's CLAUDE_CODE_SESSION_ID). Without it this script
# falsely reported "unassigned" for env-assigned sessions on KWin.
for _ev in "${HAPAX_AGENT_NAME:-}" "${CODEX_THREAD_NAME:-}" "${CODEX_SESSION_NAME:-}" \
  "${CODEX_SESSION:-}" "${CODEX_ROLE:-}" "${HAPAX_AGENT_ROLE:-}" "${CLAUDE_ROLE:-}"; do
  if [ -n "$_ev" ]; then
    printf '%s\n' "$_ev"
    exit 0
  fi
done

# WM-independent identity (reform-identity-coherence, cluster 11): a per-session
# marker — written by the spawners (hapax-claude / hapax-claude-headless) and the
# in-session reassert command, keyed by the session id — resolves identity without
# any compositor query. This is the niri/KWin path; the hyprctl walk below only
# works on Hyprland (this script was previously dead anywhere without hyprctl).
# Path convention SSOT: hapax_session_role_marker in hooks/scripts/agent-role.sh.
_sid="${HAPAX_SESSION_ID:-${CLAUDE_CODE_SESSION_ID:-}}"
if [ -n "$_sid" ] && [ -f "$HOME/.cache/hapax/session-role-$_sid" ]; then
  _role="$(head -n1 "$HOME/.cache/hapax/session-role-$_sid" 2>/dev/null | tr -d '[:space:]' || true)"
  if [ -n "$_role" ]; then
    printf '%s\n' "$_role"
    exit 0
  fi
fi

# Walk up the process tree from $$ looking for a `foot` ancestor.
pid=$$
foot_pid=""
depth=0
while [ "$pid" -gt 1 ] && [ "$depth" -lt 32 ]; do
  if [ ! -r "/proc/$pid/comm" ]; then
    break
  fi
  comm=$(cat "/proc/$pid/comm" 2>/dev/null || true)
  if [ "$comm" = "foot" ]; then
    foot_pid=$pid
    break
  fi
  # Field 4 of /proc/PID/stat is ppid. The second field is (comm) which can
  # contain parentheses/spaces; use the `)` as a boundary.
  stat_line=$(cat "/proc/$pid/stat" 2>/dev/null || true)
  [ -z "$stat_line" ] && break
  pid=$(echo "$stat_line" | awk -F')' '{print $2}' | awk '{print $2}')
  [ -z "$pid" ] && break
  depth=$((depth + 1))
done

if [ -z "$foot_pid" ]; then
  echo "hapax-whoami: no foot ancestor found within $depth levels" >&2
  exit 1
fi

command -v hyprctl >/dev/null 2>&1 || { echo "hapax-whoami: hyprctl not found" >&2; exit 2; }
command -v jq >/dev/null 2>&1 || { echo "hapax-whoami: jq not found" >&2; exit 2; }

# Per beta #215 Edge 3: if HYPRLAND_INSTANCE_SIGNATURE is missing (e.g. run
# via `env -i`), hyprctl prints an error line to stdout instead of JSON,
# which confuses jq downstream. Capture hyprctl output first + validate that
# it parses as JSON before feeding to the real jq query.
hyprctl_json=$(hyprctl clients -j 2>&1) || {
  echo "hapax-whoami: hyprctl failed: $hyprctl_json" >&2
  exit 2
}
if ! echo "$hyprctl_json" | jq empty 2>/dev/null; then
  echo "hapax-whoami: hyprctl output is not valid JSON (Hyprland socket unavailable? HYPRLAND_INSTANCE_SIGNATURE set?)" >&2
  echo "hapax-whoami: raw first line: $(echo "$hyprctl_json" | head -1)" >&2
  exit 2
fi

title=$(echo "$hyprctl_json" | jq -r --argjson pid "$foot_pid" '.[] | select(.pid == $pid) | .title')

if [ -z "$title" ] || [ "$title" = "null" ]; then
  echo "hapax-whoami: no window title for foot pid $foot_pid" >&2
  exit 1
fi

# Match a known session name. Case-insensitive, last match wins so activity
# glyphs + prefixes don't interfere.
identity=$(echo "$title" | grep -oiE "$_IDENTITY_RE" | tail -1 | tr '[:upper:]' '[:lower:]')

if [ -z "$identity" ]; then
  echo "hapax-whoami: window title did not match a known session name: $title" >&2
  exit 1
fi

echo "$identity"
