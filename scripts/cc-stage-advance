#!/usr/bin/env python3
"""cc-stage-advance <task_id> <stage> [--allow-backward] — council AVSDLC stage-setter.

Sets the ``stage:`` field on a cc-task note and appends the transition to the
authority-case ledger, so a task can move S6 (implementation) -> S7 (release)
without hand-editing frontmatter. This is the highest-frequency block the reform
removes: before Phase 2 only ~21/230 active tasks carried a stage, so the
release gate (``stage >= S7`` for ``release_authorized``) could not be satisfied
without manual YAML surgery.

The cc-tasks vault is writable by sanctioned tooling (the gate classifies by
command head, and ``python3`` is not a mutation verb); every advance appends a
``kind="stage_transition"`` record to the authority-case ledger for audit.

Coordination reform Phase 2 (CASE-SDLC-REFORM-001; master design section 8). The
guard for a forward transition (e.g. implementation complete + CI green for
S6->S7) is the caller's responsibility; this tool enforces only stage shape,
authority-case presence, and forward-only ordering (unless --allow-backward).

Usage:
    cc-stage-advance <task_id> <stage e.g. S7_RELEASE>
    cc-stage-advance <task_id> S6_IMPLEMENTATION --allow-backward

Exit: 0 advanced (or already at stage), 2 refused (bad stage / no authority_case
/ backward without flag), 3 not found / IO / usage.
"""

from __future__ import annotations

import os
import re
import sys
from datetime import UTC, datetime
from pathlib import Path

OK = 0
REFUSED = 2
ERROR = 3

VAULT = Path.home() / "Documents" / "Personal" / "20-projects" / "hapax-cc-tasks"
REPO_ROOT = Path(__file__).resolve().parent.parent
# Derived advisory feed for the sdlc_invariants monitor — NOT the SSOT. The
# coordination event log (shared/coord_event_log.py, via _emit_coord_event) is
# the source of truth for stage transitions (coordination reform §4.3).
LEDGER = Path(
    os.environ.get(
        "HAPAX_AUTHORITY_CASE_LEDGER",
        str(Path.home() / ".cache" / "hapax" / "authority-case-ledger.jsonl"),
    )
).expanduser()

#: The six no-go booleans snapshotted into each stage_transition coord event.
NO_GO_FIELDS = (
    "source_mutation_authorized",
    "docs_mutation_authorized",
    "implementation_authorized",
    "release_authorized",
    "public_current",
    "axiom_mutation_authorized",
)

_STAGE_RE = re.compile(r"^S(\d{1,2})(?:_[A-Z][A-Z0-9_]*)?$")
_CASE_RE = re.compile(r"^CASE-[A-Z0-9-]+$")
_NULLISH = {"", "null", "none", "~"}


def _find_note(task_id: str) -> Path | None:
    for sub in ("active", "closed"):
        for cand in sorted((VAULT / sub).glob(f"{task_id}-*.md")):
            return cand
        exact = VAULT / sub / f"{task_id}.md"
        if exact.is_file():
            return exact
    return None


def _stage_num(stage: str) -> int | None:
    m = _STAGE_RE.match(stage)
    return int(m.group(1)) if m else None


def _scalar(front: str, key: str) -> str:
    m = re.search(rf"(?m)^{re.escape(key)}:\s*(.*)$", front)
    return m.group(1).strip().strip('"').strip("'") if m else ""


def _role() -> str:
    for key in ("HAPAX_AGENT_ROLE", "CODEX_ROLE", "CLAUDE_ROLE", "HAPAX_AGENT_NAME"):
        v = os.environ.get(key, "").strip()
        if v:
            return v
    return "unknown"


def _refuse(msg: str) -> int:
    print(f"cc-stage-advance: REFUSED — {msg}", file=sys.stderr)
    return REFUSED


def _no_go_snapshot(front: str) -> dict[str, bool]:
    """Read the six no-go booleans from frontmatter (absent → False)."""
    return {key: _scalar(front, key).lower() == "true" for key in NO_GO_FIELDS}


def _emit_coord_event(
    task_id: str,
    from_stage: str,
    new_stage: str,
    authority_case: str,
    parent_spec: str | None,
    no_go: dict[str, bool],
    now: str,
) -> None:
    """Record the stage transition in the coord SSOT log (coordination reform §4.3).

    ``fail_open`` routes a daemon-down append to the spool for boot
    reconciliation; a hard failure is warned, never fatal — the stage advance and
    its advisory cache-ledger record have already succeeded.
    """
    try:
        if str(REPO_ROOT) not in sys.path:
            sys.path.insert(0, str(REPO_ROOT))
        from shared.coord_event_log import default_event_log
        from shared.coord_projection import emit_stage_transition

        emit_stage_transition(
            event_log=default_event_log(),
            task_id=task_id,
            from_stage=from_stage,
            to_stage=new_stage,
            authority_case=authority_case,
            actor=_role(),
            no_go_snapshot=no_go,
            parent_spec=parent_spec,
            timestamp=now,
            evidence_type="stage_advance",
            evidence_summary=f"{from_stage} -> {new_stage}",
            origin="cli",
        )
    except Exception as exc:  # noqa: BLE001 — coord emit must not fail the advance.
        print(f"cc-stage-advance: WARNING coord event emit failed: {exc}", file=sys.stderr)


def advance(task_id: str, new_stage: str, allow_backward: bool) -> int:
    if _stage_num(new_stage) is None:
        return _refuse(f"'{new_stage}' is not a valid stage (expected S0..S11[_LABEL])")
    note = _find_note(task_id)
    if note is None:
        print(f"cc-stage-advance: task '{task_id}' not found under {VAULT}", file=sys.stderr)
        return ERROR
    text = note.read_text(encoding="utf-8")
    if not text.startswith("---"):
        print("cc-stage-advance: note has no frontmatter", file=sys.stderr)
        return ERROR
    end = text.find("\n---", 4)
    if end < 0:
        print("cc-stage-advance: frontmatter not closed", file=sys.stderr)
        return ERROR
    front, body = text[: end + 1], text[end + 1 :]

    authority_case = _scalar(front, "authority_case")
    if authority_case.lower() in _NULLISH or not _CASE_RE.match(authority_case):
        return _refuse(
            f"task '{task_id}' has no valid authority_case (CASE-*); a stage "
            "transition must be anchored to an authority case"
        )

    from_stage = _scalar(front, "stage") or "(none)"
    if from_stage == new_stage:
        print(f"cc-stage-advance: '{task_id}' already at {new_stage}", file=sys.stderr)
        return OK
    parent_spec = _scalar(front, "parent_spec") or None
    no_go = _no_go_snapshot(front)
    from_num = _stage_num(from_stage)
    to_num = _stage_num(new_stage)
    if from_num is not None and to_num is not None and to_num < from_num and not allow_backward:
        return _refuse(
            f"backward transition {from_stage} -> {new_stage} (use --allow-backward to override)"
        )

    now = datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%SZ")
    if re.search(r"(?m)^stage:", front):
        front = re.sub(r"(?m)^stage:\s*.*$", f"stage: {new_stage}", front)
    else:
        front = front.rstrip("\n") + f"\nstage: {new_stage}\n"
    if re.search(r"(?m)^updated_at:", front):
        front = re.sub(r"(?m)^updated_at:\s*.*$", f"updated_at: {now}", front)

    log = f"- {now} {_role()}: stage {from_stage} -> {new_stage} (cc-stage-advance)."
    body = body.rstrip("\n") + "\n" + log + "\n"
    note.write_text(front + body, encoding="utf-8")

    if str(REPO_ROOT) not in sys.path:
        sys.path.insert(0, str(REPO_ROOT))
    from shared.jsonl_append import append_jsonl

    # Single-writer-safe advisory ledger append (flock + O_APPEND); fail-open —
    # the SSOT is the coord event log emitted below (dn-ledger-flock).
    append_jsonl(
        LEDGER,
        {
            "ts": now,
            "kind": "stage_transition",
            "tool": "cc-stage-advance",
            "role": _role(),
            "task_id": task_id,
            "authority_case": authority_case,
            "from_stage": from_stage,
            "to_stage": new_stage,
            "note": str(note),
        },
        sort_keys=True,
    )
    _emit_coord_event(task_id, from_stage, new_stage, authority_case, parent_spec, no_go, now)
    print(f"cc-stage-advance: {task_id} stage {from_stage} -> {new_stage} (ledgered)")
    return OK


def main(argv: list[str]) -> int:
    args = [a for a in argv[1:] if a != "--allow-backward"]
    allow_backward = "--allow-backward" in argv[1:]
    if len(args) != 2:
        print("usage: cc-stage-advance <task_id> <stage> [--allow-backward]", file=sys.stderr)
        return ERROR
    return advance(args[0], args[1], allow_backward)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
