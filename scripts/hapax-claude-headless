#!/usr/bin/env bash
# hapax-claude-headless - Launch a Claude Code lane in stream-json mode.
#
# This wrapper is deliberately default-deny. Headless lanes can mutate source,
# so they must be enabled only after a methodology-aware dispatcher has selected
# a specific governed task.

set -euo pipefail

# Saved BEFORE arg parsing shifts "$@", so the L1 slice self-attach below can
# re-exec with the full original argv.
ORIG_ARGS=("$@")

DISABLE_FILE="${HAPAX_CLAUDE_HEADLESS_DISABLE_FILE:-$HOME/.cache/hapax/disable-claude-headless}"
ENABLE_FILE="${HAPAX_CLAUDE_HEADLESS_ENABLE_FILE:-$HOME/.cache/hapax/enable-claude-headless}"

headless_allowed() {
  [[ "${HAPAX_CLAUDE_HEADLESS_ALLOW:-}" == "1" || -e "$ENABLE_FILE" ]]
}

ROLE=""
CLAUDE_TASK="${HAPAX_METHODOLOGY_DISPATCH_TASK:-}"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --task)
      CLAUDE_TASK="${2:-}"
      shift 2
      ;;
    --task=*)
      CLAUDE_TASK="${1#--task=}"
      shift
      ;;
    *)
      ROLE="$1"
      shift
      break
      ;;
  esac
done

if [[ -z "$ROLE" ]]; then
  echo "usage: hapax-claude-headless [--task TASK_ID] <role> [governed-initial-message]" >&2
  exit 1
fi

case "$ROLE" in
  alpha|beta|gamma|delta|epsilon|zeta|eta|theta) ;;
  *) echo "hapax-claude-headless: invalid role '$ROLE'" >&2; exit 2 ;;
esac

if [[ -e "$DISABLE_FILE" ]]; then
  echo "hapax-claude-headless: disabled by $DISABLE_FILE" >&2
  exit 77
fi
if ! headless_allowed; then
  echo "hapax-claude-headless: disabled until governed enable exists at $ENABLE_FILE or HAPAX_CLAUDE_HEADLESS_ALLOW=1 is set" >&2
  exit 77
fi

# L1 attachment point (c): self-attach this lane + everything it spawns (claude +
# its git/pytest/cargo grandchildren) into hapax-sdlc.slice so cpu.idle + the
# audio-core cpuset fence inherit. Re-exec into a transient user scope with the
# saved original argv. Skipped when methodology-dispatch already wrapped us
# (HAPAX_SDLC_SLICE_ATTACHED=1), when opted out (HAPAX_SDLC_SLICE_ATTACH=0), or
# when systemd-run/the slice can't be created — the lane must always launch.
# The `-- true` preflight proves the scope is creatable before we commit `exec`.
if [[ "${HAPAX_SDLC_SLICE_ATTACHED:-}" != "1" && "${HAPAX_SDLC_SLICE_ATTACH:-1}" != "0" ]] \
  && command -v systemd-run >/dev/null 2>&1 \
  && systemd-run --user --scope --quiet --slice=hapax-sdlc.slice -- true >/dev/null 2>&1; then
  export HAPAX_SDLC_SLICE_ATTACHED=1
  exec systemd-run --user --scope --quiet --slice=hapax-sdlc.slice -- "$0" "${ORIG_ARGS[@]}"
fi

export HAPAX_AGENT_INTERFACE="claude"
export HAPAX_AGENT_NAME="$ROLE"
export CLAUDE_ROLE="$ROLE"
export HAPAX_AGENT_ROLE="$ROLE"
export HAPAX_WORKTREE_ROLE="$ROLE"

resume_session_id_is_safe() {
  python3 - "$1" <<'PYEOF'
import re
import sys

value = sys.argv[1]
tail = value.rsplit("-", 1)[-1]
safe = (
    8 <= len(value) <= 128
    and re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9._-]*", value) is not None
    and not value.isdigit()
    and not (tail.isdigit() and len(tail) <= 7)
)
raise SystemExit(0 if safe else 1)
PYEOF
}

RESUME_SESSION_UUID="${HAPAX_CLAIM_RESUME_SESSION_ID:-}"
if [[ -n "$RESUME_SESSION_UUID" ]]; then
  if ! resume_session_id_is_safe "$RESUME_SESSION_UUID"; then
    echo "hapax-claude-headless: refusing unsafe resume-session identity" >&2
    exit 17
  fi
  SESSION_UUID="$RESUME_SESSION_UUID"
  CLAIM_RESUME=1
else
  SESSION_UUID="$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen 2>/dev/null || python3 -c 'import uuid; print(uuid.uuid4())' 2>/dev/null || printf 'sid%sx%s%s' "$(date +%s%N)" "$RANDOM" "$RANDOM")"
  CLAIM_RESUME=0
fi
export HAPAX_SESSION_ID="$SESSION_UUID"
mkdir -p "$HOME/.cache/hapax" 2>/dev/null || true
printf '%s\n' "$ROLE" >"$HOME/.cache/hapax/session-role-$SESSION_UUID" 2>/dev/null || true
WORKDIR="${HAPAX_CLAUDE_HEADLESS_WORKDIR:-}"
if [[ -n "$WORKDIR" && "$WORKDIR" == \~/* ]]; then
  WORKDIR="$HOME/${WORKDIR#"~/"}"
fi
if [[ -z "$WORKDIR" ]]; then
  WORKDIR="$HOME/projects/hapax-council"
  [[ "$ROLE" != "alpha" ]] && WORKDIR="$HOME/projects/hapax-council--$ROLE"
fi
[[ -d "$WORKDIR" ]] || { echo "hapax-claude-headless: worktree not found: $WORKDIR" >&2; exit 3; }

SOURCE_ACTIVATION_WORKTREE="${HAPAX_SOURCE_ACTIVATION_WORKTREE:-$HOME/.cache/hapax/source-activation/worktree}"
SOURCE_ACTIVATION_RECEIPT="${HAPAX_SOURCE_ACTIVATION_RECEIPT:-$HOME/.cache/hapax/source-activation/current.json}"
CC_CLAIM="$SOURCE_ACTIVATION_WORKTREE/scripts/cc-claim"
CC_CLAIM_PROTOCOL_VERSION="hapax-claim-dispatch-v1"
CC_CLAIM_PROTOCOL_CHECKED=0
CC_CLAIM_SHA256=""
POST_CLAIM_TASK_SHA256=""

require_checked_cc_claim() {
  local identity="" observed=""
  if [[ "$CC_CLAIM_PROTOCOL_CHECKED" -eq 1 ]]; then
    return 0
  fi
  if ! identity="$(python3 - "$SOURCE_ACTIVATION_WORKTREE" "$SOURCE_ACTIVATION_RECEIPT" <<'PYEOF'
import hashlib
import json
import os
import re
import stat
import subprocess
import sys
from pathlib import Path

root = Path(sys.argv[1])
receipt_path = Path(sys.argv[2])
try:
    target = root.resolve(strict=True)
    receipt_metadata = receipt_path.lstat()
    if stat.S_ISLNK(receipt_metadata.st_mode) or not stat.S_ISREG(receipt_metadata.st_mode):
        raise ValueError("activation receipt is not a regular file")
    receipt = json.loads(receipt_path.read_text(encoding="utf-8"))
    expected_head = receipt["active_source_head"]
    receipt_target = Path(receipt["active_source_target"]).resolve(strict=True)
    if target != receipt_target:
        raise ValueError("activation target does not match receipt")
    if not isinstance(expected_head, str) or not re.fullmatch(r"[0-9a-f]{40}", expected_head):
        raise ValueError("activation receipt head is malformed")
    last_success_path = receipt_path.parent / "last-success-sha"
    last_success_metadata = last_success_path.lstat()
    if stat.S_ISLNK(last_success_metadata.st_mode) or not stat.S_ISREG(last_success_metadata.st_mode):
        raise ValueError("last-success-sha is not a regular file")
    last_success = last_success_path.read_text(encoding="ascii").strip()
    if last_success != expected_head or target.name != expected_head:
        raise ValueError("activation release identity mismatch")
    observed_head = subprocess.run(
        ["git", "-C", str(target), "rev-parse", "HEAD"],
        check=True,
        capture_output=True,
        text=True,
    ).stdout.strip()
    if observed_head != expected_head:
        raise ValueError("activated checkout head does not match receipt")
    shared_kind = subprocess.run(
        ["git", "-C", str(target), "cat-file", "-t", f"{expected_head}:shared"],
        check=True,
        capture_output=True,
        text=True,
    ).stdout.strip()
    surface_status = subprocess.run(
        [
            "git",
            "-C",
            str(target),
            "status",
            "--porcelain=v1",
            "--untracked-files=all",
            "--",
            "scripts/cc-claim",
            "shared",
        ],
        check=True,
        capture_output=True,
        text=True,
    ).stdout
    if shared_kind != "tree" or surface_status:
        raise ValueError("activated cc-claim/shared implementation surface is not tracked and clean")
    claim = target / "scripts" / "cc-claim"
    metadata = claim.lstat()
    if stat.S_ISLNK(metadata.st_mode) or not stat.S_ISREG(metadata.st_mode):
        raise ValueError("activated cc-claim is not a regular file")
    if not os.access(claim, os.X_OK):
        raise ValueError("activated cc-claim is not executable")
    tracked_blob = subprocess.run(
        ["git", "-C", str(target), "rev-parse", f"{expected_head}:scripts/cc-claim"],
        check=True,
        capture_output=True,
        text=True,
    ).stdout.strip()
    observed_blob = subprocess.run(
        ["git", "-C", str(target), "hash-object", str(claim)],
        check=True,
        capture_output=True,
        text=True,
    ).stdout.strip()
    if tracked_blob != observed_blob:
        raise ValueError("activated cc-claim differs from its release commit")
    print(hashlib.sha256(claim.read_bytes()).hexdigest())
except (KeyError, OSError, ValueError, json.JSONDecodeError, subprocess.SubprocessError) as exc:
    print(f"{type(exc).__name__}: {exc}", file=sys.stderr)
    raise SystemExit(1)
PYEOF
  )"; then
    echo "hapax-claude-headless: refusing unverified source-activation cc-claim at $CC_CLAIM" >&2
    exit 14
  fi
  CC_CLAIM_SHA256="$identity"
  if ! observed="$(cd "$WORKDIR" && "$CC_CLAIM" --dispatch-protocol-version)"; then
    echo "hapax-claude-headless: activated cc-claim protocol probe failed at $CC_CLAIM" >&2
    exit 14
  fi
  if [[ "$observed" != "$CC_CLAIM_PROTOCOL_VERSION" ]]; then
    echo "hapax-claude-headless: refusing activated cc-claim with unsupported protocol at $CC_CLAIM (expected $CC_CLAIM_PROTOCOL_VERSION, got ${observed:-<empty>})" >&2
    exit 14
  fi
  CC_CLAIM_PROTOCOL_CHECKED=1
}

require_complete_dispatch_binding() {
  local name=""
  local required=(
    HAPAX_CLAIM_DISPATCH_MESSAGE_ID HAPAX_CLAIM_DISPATCH_BINDING_HASH
    HAPAX_CLAIM_DISPATCH_PLATFORM HAPAX_CLAIM_DISPATCH_MODE
    HAPAX_CLAIM_DISPATCH_PROFILE HAPAX_CLAIM_DISPATCH_AUTHORITY_CASE
    HAPAX_CLAIM_DISPATCH_IDEMPOTENCY_KEY HAPAX_CLAIM_DISPATCH_TASK_PATH
    HAPAX_CLAIM_DISPATCH_TASK_SHA256 HAPAX_CLAIM_DISPATCH_PARENT_SPEC
    HAPAX_CLAIM_DISPATCH_PARENT_SPEC_SHA256 HAPAX_CLAIM_DISPATCH_LANE_GENERATION
    HAPAX_CLAIM_DISPATCH_CLAIM_PROJECTION_SHA256
    HAPAX_CLAIM_DISPATCH_RELAY_PROJECTION_SHA256
  )
  for name in "${required[@]}"; do
    if [[ -z "${!name:-}" ]]; then
      echo "hapax-claude-headless: refusing remote launch without complete dispatch binding ($name missing)" >&2
      exit 19
    fi
  done
  if [[ -z "${HAPAX_CLAIM_DISPATCH_LANE_SESSION:-}" ]] \
    && { [[ -z "${HAPAX_CLAIM_DISPATCH_LANE_PID:-}" ]] \
      || [[ -z "${HAPAX_CLAIM_DISPATCH_LANE_PID_GENERATION:-}" ]]; }; then
    echo "hapax-claude-headless: refusing remote launch without a bound lane session or process generation" >&2
    exit 19
  fi
}

verify_dispatch_binding_if_required() {
  local task="$1"
  [[ -n "${HAPAX_CLAIM_DISPATCH_MESSAGE_ID:-}" ]] || return 0
  require_checked_cc_claim
  if ! (cd "$WORKDIR" && "$CC_CLAIM" --verify-dispatch-binding "$task"); then
    echo "hapax-claude-headless: refusing task '$task'; exact dispatch binding verification failed" >&2
    exit 18
  fi
}

capture_post_claim_task_sha256() {
  local task="$1" snapshot_sha256=""
  require_checked_cc_claim
  if ! snapshot_sha256="$(cd "$WORKDIR" && "$CC_CLAIM" --print-post-claim-task-sha256 "$task")"; then
    echo "hapax-claude-headless: refusing remote launch; canonical post-claim task snapshot verification failed for '$task'" >&2
    exit 18
  fi
  if [[ ! "$snapshot_sha256" =~ ^[0-9a-f]{64}$ ]]; then
    echo "hapax-claude-headless: refusing malformed canonical post-claim task snapshot for '$task'" >&2
    exit 18
  fi
  POST_CLAIM_TASK_SHA256="$snapshot_sha256"
  export HAPAX_CLAIM_REMOTE_POST_CLAIM_TASK_SHA256="$POST_CLAIM_TASK_SHA256"
}

export PATH="$WORKDIR/scripts:$PATH"

PIPE_DIR="${HAPAX_CLAUDE_HEADLESS_PIPE_DIR:-/run/user/$(id -u)/hapax-claude}"
LOG_DIR="$HOME/.cache/hapax/claude-headless/$ROLE"
mkdir -p "$PIPE_DIR" "$LOG_DIR"

# --- Dispatch idempotency (reform deadlane closeout) ---------------------------
# Refuse a second live launcher for this lane. The reboot storm + naive
# re-dispatch (and the lane-supervisor firing during a restart-backoff window)
# otherwise stack zombie wrappers that fight over the lane-keyed $ROLE.stdin /
# $ROLE.pid and re-inject restart prompts forever. A lane-keyed flock makes the
# wrapper the single launcher per lane — the supervisor stays the sole
# *legitimate* respawn authority. The lock auto-releases on process exit, so a
# dead launcher needs no stale-pid reaping. Placed BEFORE the cleanup trap so a
# refused duplicate never reaps the incumbent's pipe/pidfile.
LAUNCHER_LOCK="$PIPE_DIR/$ROLE.launcher.lock"
LAUNCHER_PIDFILE="$PIPE_DIR/$ROLE.launcher.pid"
exec {LAUNCHER_LOCK_FD}>"$LAUNCHER_LOCK"
if ! flock -n "$LAUNCHER_LOCK_FD"; then
  # Stale-lock handling. An OFD flock releases when its holder dies, so a free
  # lock is normally re-acquired on the first attempt above. A failure here means
  # someone holds it — but verify they are actually ALIVE before refusing: a
  # SIGKILL'd launcher skips its EXIT-trap cleanup, stranding the pidfile, and a
  # brief exit-race can have us read a pid that is already gone. If the recorded
  # pid is absent / non-numeric / dead (a stale "no-pid" lock), clear the stale
  # pidfile and retry the lock once; if that wins, the lane was genuinely free.
  # Only a verified-live holder is refused as a duplicate.
  existing="$(cat "$LAUNCHER_PIDFILE" 2>/dev/null || true)"
  if [[ -z "$existing" || ! "$existing" =~ ^[0-9]+$ ]] || ! kill -0 "$existing" 2>/dev/null; then
    rm -f "$LAUNCHER_PIDFILE" 2>/dev/null || true
    if flock -n "$LAUNCHER_LOCK_FD"; then
      echo "hapax-claude-headless: cleared stale launcher lock for lane '$ROLE' (no live pid: ${existing:-none})" >&2
    else
      echo "hapax-claude-headless: refusing duplicate launcher for lane '$ROLE' (lock held, no live pid recorded — incumbent exiting) at $LAUNCHER_LOCK" >&2
      exit 16
    fi
  else
    echo "hapax-claude-headless: refusing duplicate launcher for lane '$ROLE' (live launcher pid=$existing holds $LAUNCHER_LOCK)" >&2
    exit 16
  fi
fi
printf '%s\n' "$$" > "$LAUNCHER_PIDFILE"

STDIN_PIPE="$PIPE_DIR/$ROLE.stdin"
PID_FILE="$PIPE_DIR/$ROLE.pid"
LOG_FILE="$LOG_DIR/output.jsonl"

[[ -p "$STDIN_PIPE" ]] && rm -f "$STDIN_PIPE"
mkfifo "$STDIN_PIPE"

RELAY_RETIRE="${HAPAX_COUNCIL_DIR:-$HOME/projects/hapax-council}/scripts/hapax-relay-retire"
cleanup() {
  if [[ -n "${CLAUDE_TASK:-}" && "$CC_CLAIM_PROTOCOL_CHECKED" -eq 1 && -x "$CC_CLAIM" ]]; then
    local attempts=1 attempt=1 output="" rc=0
    [[ -n "${DISPATCH_HOST:-}" ]] && attempts=40
    while [[ "$attempt" -le "$attempts" ]]; do
      if output="$(cd "$WORKDIR" && "$CC_CLAIM" --retire-terminal-projection "$CLAUDE_TASK" 2>&1)"; then
        printf '%s\n' "$output" >>"$LOG_FILE"
        break
      else
        rc=$?
      fi
      printf '%s\n' "$output" >>"$LOG_FILE"
      [[ "$rc" -eq 75 && "$attempt" -lt "$attempts" ]] || break
      sleep 0.25
      attempt=$((attempt + 1))
    done
  fi
  rm -f "$STDIN_PIPE" "$PID_FILE" "$LAUNCHER_PIDFILE"
  "$RELAY_RETIRE" "$ROLE" --reason "clean exit (headless)" 2>/dev/null || true
}
trap cleanup EXIT

resolve_claude_bin() {
  local candidate=""
  for candidate in \
    "${HAPAX_CLAUDE_BIN:-}" \
    "${HAPAX_CLAUDE_BIN_PATH:-}"
  do
    [[ -n "$candidate" ]] || continue
    if [[ ! -x "$candidate" ]]; then
      echo "hapax-claude-headless: configured Claude binary is not executable: $candidate" >&2
      return 1
    fi
    printf '%s\n' "$candidate"
    return 0
  done
  for candidate in \
    "$(command -v claude 2>/dev/null || true)" \
    "$HOME/.npm-global/bin/claude" \
    "${NPM_CONFIG_PREFIX:+$NPM_CONFIG_PREFIX/bin/claude}" \
    "$HOME/.local/share/npm/bin/claude" \
    "/usr/local/bin/claude"
  do
    [[ -n "$candidate" && -x "$candidate" ]] || continue
    printf '%s\n' "$candidate"
    return 0
  done
  return 1
}

CLAUDE_BIN="$(resolve_claude_bin || true)"
[[ -n "$CLAUDE_BIN" ]] || { echo "hapax-claude-headless: claude not found" >&2; exit 4; }

EFFORT="${HAPAX_CLAUDE_EFFORT:-xhigh}"
MODEL="${HAPAX_CLAUDE_MODEL:-}"
CLAUDE_ARGS=(
  -p
  --input-format stream-json
  --output-format stream-json
  --verbose
  --dangerously-skip-permissions
  --effort "$EFFORT"
)
if [[ -n "$MODEL" ]]; then
  CLAUDE_ARGS+=(--model "$MODEL")
fi

INITIAL_MSG="${1:-}"
if [[ -z "$INITIAL_MSG" ]]; then
  echo "hapax-claude-headless: governed initial message required" >&2
  exit 5
fi
# A fresh launcher has a fresh session id. A matching legacy role claim is not
# authority for this new session and must never bypass cc-claim admission.
SESSION_CLAIM_FILE="$HOME/.cache/hapax/cc-active-task-$ROLE-$SESSION_UUID"
CLAIM_FILE="$HOME/.cache/hapax/cc-active-task-$ROLE"
CLAIMED_TASK=""
if [[ -s "$SESSION_CLAIM_FILE" ]]; then
  CLAIMED_TASK="$(head -n1 "$SESSION_CLAIM_FILE" | tr -d '[:space:]')"
  if [[ ! -s "$CLAIM_FILE" ]] \
    || [[ "$(head -n1 "$CLAIM_FILE" | tr -d '[:space:]')" != "$CLAIMED_TASK" ]]; then
    echo "hapax-claude-headless: refusing incomplete or divergent exact-session claim for '$ROLE'" >&2
    exit 16
  fi
fi
if [[ -z "$CLAUDE_TASK" ]]; then
  echo "hapax-claude-headless: refusing mutating launch without an exact dispatched --task <cc-task-id>" >&2
  exit 15
fi
if [[ -n "$CLAIMED_TASK" && "$CLAIMED_TASK" != "$CLAUDE_TASK" ]]; then
  echo "hapax-claude-headless: refusing launch; role '$ROLE' already claims '$CLAIMED_TASK', not dispatch task '$CLAUDE_TASK'" >&2
  exit 13
fi
export HAPAX_METHODOLOGY_DISPATCH_TASK="$CLAUDE_TASK"
if [[ -z "$CLAIMED_TASK" && "$CLAIM_RESUME" -eq 1 ]]; then
  echo "hapax-claude-headless: resume requires an existing exact-session claim for '$ROLE'" >&2
  exit 17
elif [[ -z "$CLAIMED_TASK" ]]; then
  require_checked_cc_claim
  if ! (cd "$WORKDIR" && "$CC_CLAIM" "$CLAUDE_TASK"); then
    echo "hapax-claude-headless: canonical cc-claim refused exact-session admission for '$CLAUDE_TASK'" >&2
    exit 8
  fi
  if [[ ! -s "$SESSION_CLAIM_FILE" || ! -s "$CLAIM_FILE" ]] \
    || [[ "$(head -n1 "$SESSION_CLAIM_FILE" | tr -d '[:space:]')" != "$CLAUDE_TASK" ]] \
    || [[ "$(head -n1 "$CLAIM_FILE" | tr -d '[:space:]')" != "$CLAUDE_TASK" ]]; then
    echo "hapax-claude-headless: canonical cc-claim did not publish the exact role/session claim" >&2
    exit 17
  fi
  verify_dispatch_binding_if_required "$CLAUDE_TASK"
else
  verify_dispatch_binding_if_required "$CLAUDE_TASK"
fi

SDLC_PREAMBLE="SDLC DISCIPLINE (MANDATORY):
1. Work only on the task named in this dispatch.
2. Run cc-claim for that exact task before mutation.
3. If cc-claim rejects, stop and write a relay receipt.
4. Use only the AuthorityCase and parent spec named in this dispatch.
5. Do not create, select, or claim other work from the task pool.
6. When the task is complete or blocked, report status and idle.

Session identity: role=$ROLE session_id=$SESSION_UUID. Include this session_id in any relay receipt or witness artifact you write.

DISPATCH:
"
INITIAL_MSG="${SDLC_PREAMBLE}${INITIAL_MSG}"

echo "hapax-claude-headless: starting $ROLE in $WORKDIR"
echo "  stdin pipe: $STDIN_PIPE"
echo "  log: $LOG_FILE"

exec 3<>"$STDIN_PIPE"

echo "{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"type\":\"text\",\"text\":$(printf '%s' "$INITIAL_MSG" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))')}]}}" >&3

cd "$WORKDIR"

# --- Merge-aware teardown (reform deadlane closeout) ---------------------------
# The respawn loop must terminate once the dispatched task is finished, instead
# of re-injecting a generic restart prompt forever (which stranded merged work
# and stacked zombies). task_is_terminal decides, before each respawn, whether
# the task is closed (claim cleared / note left active/ / terminal status) or
# its PR has merged.
CC_TASK_ROOT="${HAPAX_CC_TASK_ROOT:-$HOME/Documents/Personal/20-projects/hapax-cc-tasks}"

task_is_terminal() {
  # 0 = terminal (stop future respawns); 1 = live or HOLD. This function is
  # called only after the Claude child exits. Cache projections are never
  # terminality witnesses.
  local task="$1"
  [[ -n "$task" ]] || return 1

  local task_state="" pr=""
  if ! read -r task_state pr < <(python3 - "$SOURCE_ACTIVATION_WORKTREE" "$CC_TASK_ROOT" "$task" "$ROLE" <<'PYEOF'
import sys
from pathlib import Path

sys.path.insert(0, sys.argv[1])
from shared.sdlc_lifecycle import TASK_TERMINAL_STATUSES
from shared.sdlc_owner_identity import owner_matches
from shared.sdlc_task_store import TaskStoreError, resolve_task_note

root = Path(sys.argv[2])
task_id = sys.argv[3]
role = sys.argv[4]
try:
    try:
        snapshot = resolve_task_note(root, task_id, state="active")
    except TaskStoreError as exc:
        if exc.reason_code != "task_note_not_found":
            raise
        snapshot = resolve_task_note(root, task_id, state="closed")
    status = snapshot.frontmatter.get("status")
    owner = snapshot.frontmatter.get("assigned_to")
    if not isinstance(status, str) or not status.strip():
        raise ValueError("status is missing or non-scalar")
    if not isinstance(owner, str) or not owner_matches(owner.strip(), role, "claude"):
        raise ValueError("task owner does not exactly match this Claude lane")
    terminal = status.strip() in TASK_TERMINAL_STATUSES
    if snapshot.state == "closed" and not terminal:
        raise ValueError("closed task note has a nonterminal status")
    raw_pr = snapshot.frontmatter.get("pr")
    if raw_pr is None:
        pr = ""
    elif isinstance(raw_pr, int) and not isinstance(raw_pr, bool) and raw_pr > 0:
        pr = str(raw_pr)
    elif isinstance(raw_pr, str) and raw_pr.strip().isdigit() and int(raw_pr.strip()) > 0:
        pr = str(int(raw_pr.strip()))
    else:
        raise ValueError("PR identity is malformed")
    print("terminal" if terminal else "live", pr)
except (TaskStoreError, ValueError) as exc:
    print(f"hapax-claude-headless: terminality HOLD for {task_id}: {exc}", file=sys.stderr)
    raise SystemExit(2)
PYEOF
  ); then
    return 1
  fi
  [[ "$task_state" == "terminal" ]] && return 0

  # The only second terminal witness is an exact REST readback of this task's
  # numeric PR showing a completed merge. Auth, transport, shape, and state
  # ambiguity all remain nonterminal.
  if [[ -n "$pr" ]]; then
    local state="" repo="${HAPAX_GH_REPO:-${GH_REPO:-hapax-systems/hapax-council}}"
    state="$(gh api --method GET -H 'Accept: application/vnd.github+json' "repos/${repo}/pulls/${pr}" \
      --jq "if .number == ${pr} and .state == \"closed\" and .merged == true and (.merged_at | type) == \"string\" and (.merge_commit_sha | type) == \"string\" then \"MERGED\" else \"\" end" 2>/dev/null || true)"
    [[ "$state" == "MERGED" ]] && return 0
  fi
  return 1
}

dispatch_host_is_local() {
  local host="${1:-}" short="" fqdn="" local_ip="" resolved_ip=""
  [[ -z "$host" || "$host" == "local" || "$host" == "localhost" ]] && return 0
  [[ "$host" == "127.0.0.1" || "$host" == "::1" ]] && return 0
  short="$(hostname -s 2>/dev/null || hostname 2>/dev/null || true)"
  fqdn="$(hostname -f 2>/dev/null || true)"
  [[ "$host" == "appendix" ]] && host="hapax-appendix"
  [[ "$host" == "podium" ]] && host="hapax-podium"
  [[ -n "$short" && "$host" == "$short" ]] && return 0
  [[ -n "$fqdn" && "$host" == "$fqdn" ]] && return 0
  for local_ip in $(hostname -I 2>/dev/null || true); do
    [[ "$host" == "$local_ip" ]] && return 0
  done
  if command -v getent >/dev/null 2>&1; then
    for resolved_ip in $(getent ahosts "$host" 2>/dev/null | awk '{print $1}'); do
      for local_ip in $(hostname -I 2>/dev/null || true); do
        [[ "$resolved_ip" == "$local_ip" ]] && return 0
      done
    done
  fi
  return 1
}

remote_python_command() {
  local payload="$1" code="$2"
  local code_b64="" bash_script="" quoted_script="" quoted_payload="" quoted_code=""
  code_b64="$(printf '%s' "$code" | python3 -c 'import base64,sys; print(base64.b64encode(sys.stdin.buffer.read()).decode())')"
  # shellcheck disable=SC2016
  bash_script='export HAPAX_REMOTE_PAYLOAD="$1"; export HAPAX_REMOTE_CODE="$2"; exec python3 -c "import base64,os; exec(base64.b64decode(os.environ[\"HAPAX_REMOTE_CODE\"]))"'
  quoted_script="${bash_script//\'/\'\\\'\'}"
  quoted_payload="${payload//\'/\'\\\'\'}"
  quoted_code="${code_b64//\'/\'\\\'\'}"
  printf "bash -c '%s' bash '%s' '%s'" "$quoted_script" "$quoted_payload" "$quoted_code"
}

remote_payload_b64() {
  local kind="$1"
  shift
  python3 - "$kind" "$@" <<'PYEOF'
import base64
import json
import sys

kind = sys.argv[1]
if kind == "preflight":
    payload = {"kind": kind, "workdir": sys.argv[2], "binaries": sys.argv[3:]}
elif kind == "exec":
    payload = {
        "kind": kind,
        "workdir": sys.argv[2],
        "env": {
            "LOGOS_BASE_URL": sys.argv[3],
            "COCKPIT_BASE_URL": sys.argv[3],
            "HAPAX_DISPATCH_HOST": sys.argv[4],
            "HAPAX_DISPATCH_LOGOS_URL": sys.argv[3],
            "HAPAX_DISPATCH_PROOF_FILE": sys.argv[5],
        },
        "proof_file": sys.argv[5],
        "requested_host": sys.argv[4],
        "cc_claim": sys.argv[6],
        "cc_claim_sha256": sys.argv[7],
        "cc_claim_protocol": sys.argv[8],
        "source_activation_worktree": sys.argv[9],
        "source_activation_receipt": sys.argv[10],
        "argv": sys.argv[11:],
    }
    # Session identity must survive the SSH boundary (taxonomy-a3-session-
    # identity): without these the exec-host claude resolves a DIFFERENT
    # session id (CLAUDE_CODE_SESSION_ID fallback), the session-keyed claim
    # exists only launcher-side, and the lane hits cc-claim exit-4 walls (the
    # recurring appendix-remote-dispatch claim gap). Pulled from the
    # launcher's own exports — the identity it minted for THIS spawn.
    import os

    identity_keys = (
        "HAPAX_SESSION_ID",
        "HAPAX_AGENT_INTERFACE",
        "HAPAX_AGENT_NAME",
        "HAPAX_AGENT_ROLE",
        "CLAUDE_ROLE",
        "HAPAX_WORKTREE_ROLE",
        "HAPAX_METHODOLOGY_DISPATCH_TASK",
        "HAPAX_DISPATCH_CLAIM_SWEEP",
        "HAPAX_CLAIM_LEASE_TTL_SECS",
        "HAPAX_CLAIM_DISPATCH_MESSAGE_ID",
        "HAPAX_CLAIM_DISPATCH_BINDING_HASH",
        "HAPAX_CLAIM_DISPATCH_PLATFORM",
        "HAPAX_CLAIM_DISPATCH_MODE",
        "HAPAX_CLAIM_DISPATCH_PROFILE",
        "HAPAX_CLAIM_DISPATCH_AUTHORITY_CASE",
        "HAPAX_CLAIM_DISPATCH_IDEMPOTENCY_KEY",
        "HAPAX_CLAIM_DISPATCH_TASK_PATH",
        "HAPAX_CLAIM_DISPATCH_TASK_SHA256",
        "HAPAX_CLAIM_DISPATCH_PARENT_SPEC",
        "HAPAX_CLAIM_DISPATCH_PARENT_SPEC_SHA256",
        "HAPAX_CLAIM_DISPATCH_LANE_SESSION",
        "HAPAX_CLAIM_DISPATCH_LANE_GENERATION",
        "HAPAX_CLAIM_DISPATCH_LANE_PID",
        "HAPAX_CLAIM_DISPATCH_LANE_PID_GENERATION",
        "HAPAX_CLAIM_DISPATCH_CLAIM_PROJECTION_SHA256",
        "HAPAX_CLAIM_DISPATCH_RELAY_PROJECTION_SHA256",
        "HAPAX_CLAIM_REMOTE_POST_CLAIM_TASK_SHA256",
        "HAPAX_CLAIM_REMOTE_WAIT_SECONDS",
    )
    payload["env"].update(
        {k: os.environ[k] for k in identity_keys if os.environ.get(k)}
    )
else:
    raise SystemExit(f"unknown remote payload kind: {kind}")
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

REMOTE_PREFLIGHT_PY='import base64,json,os,shutil,subprocess,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); ok=os.path.isdir(p["workdir"]) and all(shutil.which(b) for b in p.get("binaries",())); gh_ok=shutil.which("gh") is not None and subprocess.run(["gh","auth","status"],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL).returncode==0; sys.exit(0 if ok and gh_ok else 1)'
REMOTE_EXEC_PY='import base64,hashlib,json,os,pathlib,re,socket,stat,subprocess,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); os.chdir(p["workdir"]); os.environ.update(p.get("env",{})); proof=p.get("proof_file",""); cgroup="";
try:
    cgroup=open("/proc/self/cgroup",encoding="utf-8").read()
except OSError:
    pass
bound_env=p.get("env",{}); sid=bound_env.get("HAPAX_SESSION_ID",""); role=bound_env.get("HAPAX_AGENT_ROLE",""); task=bound_env.get("HAPAX_METHODOLOGY_DISPATCH_TASK",""); claim_established=False
required=("HAPAX_CLAIM_DISPATCH_MESSAGE_ID","HAPAX_CLAIM_DISPATCH_BINDING_HASH","HAPAX_CLAIM_DISPATCH_PLATFORM","HAPAX_CLAIM_DISPATCH_MODE","HAPAX_CLAIM_DISPATCH_PROFILE","HAPAX_CLAIM_DISPATCH_AUTHORITY_CASE","HAPAX_CLAIM_DISPATCH_IDEMPOTENCY_KEY","HAPAX_CLAIM_DISPATCH_TASK_PATH","HAPAX_CLAIM_DISPATCH_TASK_SHA256","HAPAX_CLAIM_DISPATCH_PARENT_SPEC","HAPAX_CLAIM_DISPATCH_PARENT_SPEC_SHA256","HAPAX_CLAIM_DISPATCH_LANE_GENERATION","HAPAX_CLAIM_DISPATCH_CLAIM_PROJECTION_SHA256","HAPAX_CLAIM_DISPATCH_RELAY_PROJECTION_SHA256","HAPAX_CLAIM_REMOTE_POST_CLAIM_TASK_SHA256")
missing=[name for name in required if not bound_env.get(name)]
if missing or not sid or not role or not task:
    print("hapax-claude-headless: refusing remote execution without complete identity and dispatch binding: "+",".join(missing),file=sys.stderr); sys.exit(78)
cc_claim=os.path.expanduser(p.get("cc_claim","") or "")
try:
    activation=pathlib.Path(p.get("source_activation_worktree","")).resolve(strict=True); receipt_path=pathlib.Path(p.get("source_activation_receipt","")); receipt_metadata=receipt_path.lstat()
    if stat.S_ISLNK(receipt_metadata.st_mode) or not stat.S_ISREG(receipt_metadata.st_mode):
        raise ValueError("remote activation receipt is not a regular file")
    receipt=json.loads(receipt_path.read_text(encoding="utf-8")); head=receipt["active_source_head"]; receipt_target=pathlib.Path(receipt["active_source_target"]).resolve(strict=True); last_success_path=receipt_path.parent/"last-success-sha"; last_success_metadata=last_success_path.lstat()
    if stat.S_ISLNK(last_success_metadata.st_mode) or not stat.S_ISREG(last_success_metadata.st_mode):
        raise ValueError("remote last-success-sha is not a regular file")
    last_success=last_success_path.read_text(encoding="ascii").strip()
    if activation != receipt_target or not isinstance(head,str) or re.fullmatch(r"[0-9a-f]{40}",head) is None or last_success != head or activation.name != head:
        raise ValueError("remote source-activation receipt mismatch")
    observed_head=subprocess.run(["git","-C",str(activation),"rev-parse","HEAD"],check=True,capture_output=True,text=True).stdout.strip(); shared_kind=subprocess.run(["git","-C",str(activation),"cat-file","-t",head+":shared"],check=True,capture_output=True,text=True).stdout.strip(); surface_status=subprocess.run(["git","-C",str(activation),"status","--porcelain=v1","--untracked-files=all","--","scripts/cc-claim","shared"],check=True,capture_output=True,text=True).stdout; tracked_blob=subprocess.run(["git","-C",str(activation),"rev-parse",head+":scripts/cc-claim"],check=True,capture_output=True,text=True).stdout.strip()
    metadata=os.lstat(cc_claim)
    if not stat.S_ISREG(metadata.st_mode) or stat.S_ISLNK(metadata.st_mode) or not os.access(cc_claim,os.X_OK):
        raise OSError("canonical cc-claim is not a regular executable")
    if pathlib.Path(cc_claim).resolve(strict=True) != (activation/"scripts"/"cc-claim").resolve(strict=True):
        raise ValueError("remote cc-claim is outside the activated target")
    observed_blob=subprocess.run(["git","-C",str(activation),"hash-object",cc_claim],check=True,capture_output=True,text=True).stdout.strip()
    if observed_head != head or shared_kind != "tree" or surface_status or observed_blob != tracked_blob:
        raise ValueError("remote activated cc-claim/shared implementation mismatch")
    observed_sha=hashlib.sha256(open(cc_claim,"rb").read()).hexdigest()
except (KeyError,OSError,ValueError,json.JSONDecodeError,subprocess.SubprocessError) as exc:
    print("hapax-claude-headless: remote canonical cc-claim unavailable: "+str(exc),file=sys.stderr); sys.exit(78)
if observed_sha != p.get("cc_claim_sha256"):
    print("hapax-claude-headless: refusing remote stale cc-claim implementation",file=sys.stderr); sys.exit(78)
probe=subprocess.run([cc_claim,"--dispatch-protocol-version"],cwd=p["workdir"],env=os.environ,text=True,capture_output=True)
if probe.returncode != 0 or probe.stdout.strip() != p.get("cc_claim_protocol"):
    print("hapax-claude-headless: remote canonical cc-claim protocol verification failed",file=sys.stderr); sys.exit(78)
claimed=subprocess.run([cc_claim,"--materialize-remote-projection",task],cwd=p["workdir"],env=os.environ,text=True,capture_output=True)
if claimed.returncode != 0:
    print("hapax-claude-headless: remote canonical projection materialization refused ownership: "+claimed.stderr.strip(),file=sys.stderr); sys.exit(78)
verified=subprocess.run([cc_claim,"--verify-dispatch-binding",task],cwd=p["workdir"],env=os.environ,text=True,capture_output=True)
if verified.returncode != 0:
    print("hapax-claude-headless: remote exact claim/binding verification failed: "+verified.stderr.strip(),file=sys.stderr); sys.exit(78)
post_claim_sha=bound_env["HAPAX_CLAIM_REMOTE_POST_CLAIM_TASK_SHA256"]; cache=os.path.join(os.path.expanduser("~"),".cache","hapax"); remote_receipt=os.path.join(cache,"cc-claim-remote-projection-"+role+"-"+sid+"-"+post_claim_sha+".json")
try:
    receipt_metadata=os.lstat(remote_receipt)
    if not stat.S_ISREG(receipt_metadata.st_mode) or stat.S_ISLNK(receipt_metadata.st_mode):
        raise OSError("remote projection receipt is not a regular file")
    remote_receipt_sha256=hashlib.sha256(open(remote_receipt,"rb").read()).hexdigest()
except OSError as exc:
    print("hapax-claude-headless: remote projection receipt unavailable: "+str(exc),file=sys.stderr); sys.exit(78)
claim_established=True
if proof:
    os.makedirs(os.path.dirname(proof), exist_ok=True)
    data={"schema_version":1,"event":"dispatch_remote_exec","platform":"claude-headless","requested_host":p.get("requested_host"),"actual_host":socket.gethostname(),"pid":os.getpid(),"cgroup":cgroup,"workdir":p.get("workdir"),"logos_base_url":os.environ.get("LOGOS_BASE_URL"),"argv0":p["argv"][0] if p.get("argv") else None,"argc":len(p.get("argv",[])),"session_id":sid or None,"role":role or None,"task_id":task or None,"claim_established":claim_established,"post_claim_task_sha256":post_claim_sha,"remote_projection_receipt":remote_receipt,"remote_projection_receipt_sha256":remote_receipt_sha256}; open(proof,"w",encoding="utf-8").write(json.dumps(data,sort_keys=True)+"\n")
argv=p["argv"]; os.execvp(argv[0], argv)'

RESTART_COUNT=0
MAX_RESTART_BACKOFF="${HAPAX_CLAUDE_HEADLESS_RESTART_BACKOFF_SECONDS:-30}"
RESPAWN_ENABLED="${HAPAX_CLAUDE_HEADLESS_RESPAWN:-1}"
if [[ "$RESPAWN_ENABLED" != "0" && "$RESPAWN_ENABLED" != "1" ]]; then
  echo "hapax-claude-headless: HAPAX_CLAUDE_HEADLESS_RESPAWN must be 0 or 1" >&2
  exit 2
fi
QUOTA_STREAK=0
QUOTA_BACKOFF_CAP="${HAPAX_HEADLESS_QUOTA_BACKOFF_CAP_SECONDS:-21600}"  # 6h ceiling for quota-wall backoff
# ── G2 dispatch-host preflight (appendix migration) ─────────────────────────
# HAPAX_DISPATCH_HOST set → the inner `claude` exec runs on appendix; the
# launcher itself (FIFO, PID/lock/relay, cc-claim, restart loop) stays
# podium-local so the cockpit, send/steer, and reaper keep working unchanged.
# Unsafe remote shell interpolation is forbidden here: path/env/model args are
# JSON→base64 payload, decoded by remote python, then execvp'd as argv. If the
# requested host is not ready, fail closed unless the operator explicitly opts
# into local fallback with HAPAX_DISPATCH_HOST_FALLBACK=local.
DISPATCH_HOST="${HAPAX_DISPATCH_HOST:-}"
# G8: the lane's hapax MCP (stdio) connects to logos-api; on the Workshop that
# must be podium's LAN address, not appendix localhost. Injected into the hop env
# below (hapax-mcp prefers LOGOS_BASE_URL over the config's COCKPIT_BASE_URL).
DISPATCH_LOGOS_URL="${HAPAX_DISPATCH_LOGOS_URL:-http://192.168.68.85:8051/api}"
DISPATCH_PROOF_DIR="${HAPAX_DISPATCH_PROOF_DIR:-$HOME/.cache/hapax/orchestration/dispatch-host-proofs}"
DISPATCH_PROOF_FILE="$DISPATCH_PROOF_DIR/$(date -u +%Y%m%dT%H%M%SZ)-$ROLE-${CLAUDE_TASK:-no-task}-remote.json"
if [[ -n "$DISPATCH_HOST" ]]; then
  if dispatch_host_is_local "$DISPATCH_HOST"; then
    DISPATCH_HOST=""
  else
    require_checked_cc_claim
    require_complete_dispatch_binding
    PREFLIGHT_PAYLOAD="$(remote_payload_b64 preflight "$WORKDIR" python3 claude)"
    PREFLIGHT_COMMAND="$(remote_python_command "$PREFLIGHT_PAYLOAD" "$REMOTE_PREFLIGHT_PY")"
    if ssh -o BatchMode=yes -o ConnectTimeout=4 -i "$HOME/.ssh/id_ed25519" \
          -o ControlPath="$HOME/.ssh/cm-%r@%h:%p" "$DISPATCH_HOST" \
          "$PREFLIGHT_COMMAND" 2>/dev/null; then
      echo "hapax-claude-headless: dispatch -> $DISPATCH_HOST (claude on appendix; launcher podium-local)"
    elif [[ "${HAPAX_DISPATCH_HOST_FALLBACK:-}" == "local" ]]; then
      echo "hapax-claude-headless: dispatch_host_unready ($DISPATCH_HOST) -- explicit local fallback" >&2
      DISPATCH_HOST=""
    else
      echo "hapax-claude-headless: dispatch_host_unready ($DISPATCH_HOST) -- refusing local fallback without HAPAX_DISPATCH_HOST_FALLBACK=local" >&2
      exit 75
    fi
  fi
fi

while true; do
  if [[ -e "$DISABLE_FILE" ]]; then
    echo "hapax-claude-headless: disabled by $DISABLE_FILE" >&2
    exit 77
  fi
  if ! headless_allowed; then
    echo "hapax-claude-headless: disabled until governed enable exists at $ENABLE_FILE or HAPAX_CLAUDE_HEADLESS_ALLOW=1 is set" >&2
    exit 77
  fi

  if [[ -n "$DISPATCH_HOST" ]]; then
    # G2 inner exec on the Workshop: cd the lane's appendix-local worktree and
    # run THAT host's PATH `claude`. fd 3 (the podium FIFO) feeds the ssh child's
    # stdin exactly as it feeds a local claude — no pty (-tt would corrupt the
    # stream-json), dedicated connection (ControlPath=none, kept alive) so an
    # idle lane isn't dropped by the shared master's ControlPersist. On drop the
    # remote claude EOFs its stdin and the loop below re-execs it.
    capture_post_claim_task_sha256 "$CLAUDE_TASK"
    REMOTE_EXEC_PAYLOAD="$(
      remote_payload_b64 exec "$WORKDIR" "$DISPATCH_LOGOS_URL" "$DISPATCH_HOST" \
        "$DISPATCH_PROOF_FILE" "$CC_CLAIM" "$CC_CLAIM_SHA256" \
        "$CC_CLAIM_PROTOCOL_VERSION" "$SOURCE_ACTIVATION_WORKTREE" \
        "$SOURCE_ACTIVATION_RECEIPT" claude "${CLAUDE_ARGS[@]}"
    )"
    REMOTE_EXEC_COMMAND="$(remote_python_command "$REMOTE_EXEC_PAYLOAD" "$REMOTE_EXEC_PY")"
    ssh -o BatchMode=yes -o RequestTTY=no -o ServerAliveInterval=30 -o ServerAliveCountMax=6 \
        -o ControlPath=none -i "$HOME/.ssh/id_ed25519" "$DISPATCH_HOST" \
        "$REMOTE_EXEC_COMMAND" \
        <&3 >> "$LOG_FILE" 2>&1 &
  else
    "$CLAUDE_BIN" "${CLAUDE_ARGS[@]}" <&3 >> "$LOG_FILE" 2>&1 &
  fi
  CLAUDE_PID=$!
  echo "$CLAUDE_PID" > "$PID_FILE"
  echo "hapax-claude-headless: pid=$CLAUDE_PID (restart #$RESTART_COUNT)"

  # Never signal a live worker from task, cache, or PR projections. Terminality
  # is evaluated only after the child exits on its own.
  if wait "$CLAUDE_PID"; then
    EXIT_CODE=0
  else
    EXIT_CODE=$?
  fi
  RESTART_COUNT=$((RESTART_COUNT + 1))

  # Merge-aware teardown: stop respawning once the dispatched task is closed or
  # its PR merged. The cleanup trap (EXIT) reaps the pipe + launcher lock; the
  # lane-supervisor then brings the lane back read-only into idle-await on its
  # next tick — not a forever-respawn zombie.
  if task_is_terminal "$CLAUDE_TASK"; then
    echo "hapax-claude-headless: task $CLAUDE_TASK closed/merged — stopping respawn loop"
    break
  fi
  if [[ "$RESPAWN_ENABLED" == "0" ]]; then
    echo "hapax-claude-headless: child exited and respawn is disabled"
    break
  fi

  # Quota-wall-aware backoff: if the lane hit a rate limit, honor the receipt's
  # resets_at (or an exponential streak backoff) instead of the flat 30s restart
  # thrash that re-hits the wall every tick. (quota-wall-backoff-fix)
  BACKOFF="$MAX_RESTART_BACKOFF"
  QW_RC=0
  QW_OUT="$(detect-quota-wall "$ROLE" --streak "$((QUOTA_STREAK + 1))" --base "$MAX_RESTART_BACKOFF" --cap "$QUOTA_BACKOFF_CAP" 2>/dev/null)" || QW_RC=$?
  if [ "$QW_RC" -eq 75 ]; then
    QUOTA_STREAK=$((QUOTA_STREAK + 1))
    [ -n "$QW_OUT" ] && BACKOFF="$QW_OUT"
    echo "hapax-claude-headless: $ROLE QUOTA WALL (streak=$QUOTA_STREAK) — backing off ${BACKOFF}s"
  else
    QUOTA_STREAK=0
  fi

  echo "hapax-claude-headless: $ROLE exited (code=$EXIT_CODE), restarting in ${BACKOFF}s..."

  if [[ -e "$DISABLE_FILE" ]]; then
    echo "hapax-claude-headless: disabled by $DISABLE_FILE" >&2
    exit 77
  fi
  if ! headless_allowed; then
    echo "hapax-claude-headless: disabled until governed enable exists at $ENABLE_FILE or HAPAX_CLAUDE_HEADLESS_ALLOW=1 is set" >&2
    exit 77
  fi

  RESTART_MSG='{"type":"user","message":{"role":"user","content":[{"type":"text","text":"Resume only the active task named in your claim file and prior governed dispatch. If there is no active claim, write a relay status saying idle-awaiting-dispatch. Do not claim any new task."}]}}'
  sleep "$BACKOFF"
  echo "$RESTART_MSG" >&3
done
