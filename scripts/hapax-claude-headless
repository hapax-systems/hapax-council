#!/usr/bin/env bash
# hapax-claude-headless - Launch a Claude Code lane in stream-json mode.
#
# This wrapper is deliberately default-deny. Headless lanes can mutate source,
# so they must be enabled only after a methodology-aware dispatcher has selected
# a specific governed task.

set -euo pipefail

# Saved BEFORE arg parsing shifts "$@", so the L1 slice self-attach below can
# re-exec with the full original argv.
ORIG_ARGS=("$@")

DISABLE_FILE="${HAPAX_CLAUDE_HEADLESS_DISABLE_FILE:-$HOME/.cache/hapax/disable-claude-headless}"
ENABLE_FILE="${HAPAX_CLAUDE_HEADLESS_ENABLE_FILE:-$HOME/.cache/hapax/enable-claude-headless}"

headless_allowed() {
  [[ "${HAPAX_CLAUDE_HEADLESS_ALLOW:-}" == "1" || -e "$ENABLE_FILE" ]]
}

record_child_spawn_receipt() {
  local task_id="$1"
  local child_id="$2"
  local shape="${3:-existing_agent_harness}"
  local role="${4:-worker}"
  local helper="$WORKDIR/scripts/hapax-child-spawn-receipt"
  local receipt_exports=""

  if [[ -z "${HAPAX_PARENT_ROUTE_ENVELOPE:-}" && "${HAPAX_REQUIRE_PARENT_ROUTE_ENVELOPE:-0}" != "1" ]]; then
    return 0
  fi
  if [[ ! -x "$helper" ]]; then
    echo "hapax-claude-headless: parent route envelope required but helper is missing: $helper; next action: sync this worktree/branch so scripts/hapax-child-spawn-receipt exists, then relaunch through hapax-methodology-dispatch" >&2
    exit 18
  fi
  if ! receipt_exports="$("$helper" --task "$task_id" --child-id "$child_id" --shape "$shape" --capability-role "$role")"; then
    echo "hapax-claude-headless: governed child spawn receipt refused for '$child_id'; see error above" >&2
    exit 18
  fi
  if [[ -n "$receipt_exports" ]]; then
    eval "$receipt_exports"
    export HAPAX_PARENT_ROUTE_ENVELOPE HAPAX_CHILD_SPAWN_ENVELOPE HAPAX_CHILD_RECEIPT_REF HAPAX_CHILD_RECEIPT_ID
  fi
}

ROLE=""
CLAUDE_TASK="${HAPAX_METHODOLOGY_DISPATCH_TASK:-}"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --task)
      CLAUDE_TASK="${2:-}"
      shift 2
      ;;
    --task=*)
      CLAUDE_TASK="${1#--task=}"
      shift
      ;;
    *)
      ROLE="$1"
      shift
      break
      ;;
  esac
done

if [[ -z "$ROLE" ]]; then
  echo "usage: hapax-claude-headless [--task TASK_ID] <role> [governed-initial-message]" >&2
  exit 1
fi

case "$ROLE" in
  alpha|beta|gamma|delta|epsilon|zeta|eta|theta) ;;
  *) echo "hapax-claude-headless: invalid role '$ROLE'" >&2; exit 2 ;;
esac

if [[ -e "$DISABLE_FILE" ]]; then
  echo "hapax-claude-headless: disabled by $DISABLE_FILE" >&2
  exit 77
fi
if ! headless_allowed; then
  echo "hapax-claude-headless: disabled until governed enable exists at $ENABLE_FILE or HAPAX_CLAUDE_HEADLESS_ALLOW=1 is set" >&2
  exit 77
fi

# L1 attachment point (c): self-attach this lane + everything it spawns (claude +
# its git/pytest/cargo grandchildren) into hapax-sdlc.slice so cpu.idle + the
# audio-core cpuset fence inherit. Re-exec into a transient user scope with the
# saved original argv. Skipped when methodology-dispatch already wrapped us
# (HAPAX_SDLC_SLICE_ATTACHED=1), when opted out (HAPAX_SDLC_SLICE_ATTACH=0), or
# when systemd-run/the slice can't be created — the lane must always launch.
# The `-- true` preflight proves the scope is creatable before we commit `exec`.
if [[ "${HAPAX_SDLC_SLICE_ATTACHED:-}" != "1" && "${HAPAX_SDLC_SLICE_ATTACH:-1}" != "0" ]] \
  && command -v systemd-run >/dev/null 2>&1 \
  && systemd-run --user --scope --quiet --slice=hapax-sdlc.slice -- true >/dev/null 2>&1; then
  export HAPAX_SDLC_SLICE_ATTACHED=1
  exec systemd-run --user --scope --quiet --slice=hapax-sdlc.slice -- "$0" "${ORIG_ARGS[@]}"
fi

export HAPAX_AGENT_INTERFACE="claude"
export HAPAX_AGENT_NAME="$ROLE"
export CLAUDE_ROLE="$ROLE"
export HAPAX_AGENT_ROLE="$ROLE"
export HAPAX_WORKTREE_ROLE="$ROLE"

# Per-spawn session id (reform-identity-coherence, cluster 11): every headless
# launch is a fresh lane, so MINT a new uuid unconditionally — never inherit one
# from the dispatcher's environment. launch_claude_headless does os.environ.copy(),
# so honoring an inherited HAPAX_SESSION_ID would let two same-role re-dispatched
# lanes share a claim key (defeats FM-2 / AC1). Computed once, before the restart
# loop below, so it stays stable across in-launcher restarts of this same lane.
# The fallback chain is NEVER pid-derived (claim-by-pid unrepresentable,
# taxonomy-a3-session-identity): the retired `<role>-$$` shape minted ids that
# pid recycling makes ambiguous and that cc-claim now refuses to key. The
# last-resort mint is alpha-infixed so it stays claim-keyable
# (shared/session_identity.py::is_claim_keyable_session_id).
SESSION_UUID="$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen 2>/dev/null || python3 -c 'import uuid; print(uuid.uuid4())' 2>/dev/null || printf 'sid%sx%s%s' "$(date +%s%N)" "$RANDOM" "$RANDOM")"
export HAPAX_SESSION_ID="$SESSION_UUID"
# Per-session identity marker (WM-independent): record THIS session's role keyed by
# the session id so agent-role.sh / hapax-whoami resolve identity without a
# compositor query (dead on niri/KWin). Path convention SSOT:
# hapax_session_role_marker in hooks/scripts/agent-role.sh.
mkdir -p "$HOME/.cache/hapax" 2>/dev/null || true
printf '%s\n' "$ROLE" >"$HOME/.cache/hapax/session-role-$SESSION_UUID" 2>/dev/null || true

WORKDIR="${HAPAX_CLAUDE_HEADLESS_WORKDIR:-}"
if [[ -n "$WORKDIR" && "$WORKDIR" == "~/"* ]]; then
  WORKDIR="$HOME/${WORKDIR#"~/"}"
fi
if [[ -z "$WORKDIR" ]]; then
  WORKDIR="$HOME/projects/hapax-council"
  [[ "$ROLE" != "alpha" ]] && WORKDIR="$HOME/projects/hapax-council--$ROLE"
fi
[[ -d "$WORKDIR" ]] || { echo "hapax-claude-headless: worktree not found: $WORKDIR" >&2; exit 3; }

export PATH="$WORKDIR/scripts:$PATH"

PIPE_DIR="${HAPAX_CLAUDE_HEADLESS_PIPE_DIR:-/run/user/$(id -u)/hapax-claude}"
LOG_DIR="$HOME/.cache/hapax/claude-headless/$ROLE"
mkdir -p "$PIPE_DIR" "$LOG_DIR"

# --- Dispatch idempotency (reform deadlane closeout) ---------------------------
# Refuse a second live launcher for this lane. The reboot storm + naive
# re-dispatch (and the lane-supervisor firing during a restart-backoff window)
# otherwise stack zombie wrappers that fight over the lane-keyed $ROLE.stdin /
# $ROLE.pid and re-inject restart prompts forever. A lane-keyed flock makes the
# wrapper the single launcher per lane — the supervisor stays the sole
# *legitimate* respawn authority. The lock auto-releases on process exit, so a
# dead launcher needs no stale-pid reaping. Placed BEFORE the cleanup trap so a
# refused duplicate never reaps the incumbent's pipe/pidfile.
LAUNCHER_LOCK="$PIPE_DIR/$ROLE.launcher.lock"
LAUNCHER_PIDFILE="$PIPE_DIR/$ROLE.launcher.pid"
exec {LAUNCHER_LOCK_FD}>"$LAUNCHER_LOCK"
if ! flock -n "$LAUNCHER_LOCK_FD"; then
  # Stale-lock handling. An OFD flock releases when its holder dies, so a free
  # lock is normally re-acquired on the first attempt above. A failure here means
  # someone holds it — but verify they are actually ALIVE before refusing: a
  # SIGKILL'd launcher skips its EXIT-trap cleanup, stranding the pidfile, and a
  # brief exit-race can have us read a pid that is already gone. If the recorded
  # pid is absent / non-numeric / dead (a stale "no-pid" lock), clear the stale
  # pidfile and retry the lock once; if that wins, the lane was genuinely free.
  # Only a verified-live holder is refused as a duplicate.
  existing="$(cat "$LAUNCHER_PIDFILE" 2>/dev/null || true)"
  if [[ -z "$existing" || ! "$existing" =~ ^[0-9]+$ ]] || ! kill -0 "$existing" 2>/dev/null; then
    rm -f "$LAUNCHER_PIDFILE" 2>/dev/null || true
    if flock -n "$LAUNCHER_LOCK_FD"; then
      echo "hapax-claude-headless: cleared stale launcher lock for lane '$ROLE' (no live pid: ${existing:-none})" >&2
    else
      echo "hapax-claude-headless: refusing duplicate launcher for lane '$ROLE' (lock held, no live pid recorded — incumbent exiting) at $LAUNCHER_LOCK" >&2
      exit 16
    fi
  else
    echo "hapax-claude-headless: refusing duplicate launcher for lane '$ROLE' (live launcher pid=$existing holds $LAUNCHER_LOCK)" >&2
    exit 16
  fi
fi
printf '%s\n' "$$" > "$LAUNCHER_PIDFILE"

STDIN_PIPE="$PIPE_DIR/$ROLE.stdin"
PID_FILE="$PIPE_DIR/$ROLE.pid"
SELF_REAP_FLAG="$PIPE_DIR/$ROLE.self-reap"
LOG_FILE="$LOG_DIR/output.jsonl"

[[ -p "$STDIN_PIPE" ]] && rm -f "$STDIN_PIPE"
mkfifo "$STDIN_PIPE"

RELAY_RETIRE="${HAPAX_COUNCIL_DIR:-$HOME/projects/hapax-council}/scripts/hapax-relay-retire"
cleanup() {
  rm -f "$STDIN_PIPE" "$PID_FILE" "$LAUNCHER_PIDFILE" "$SELF_REAP_FLAG"
  "$RELAY_RETIRE" "$ROLE" --reason "clean exit (headless)" 2>/dev/null || true
}
trap cleanup EXIT

resolve_claude_bin() {
  local candidate=""
  for candidate in \
    "${HAPAX_CLAUDE_BIN:-}" \
    "${HAPAX_CLAUDE_BIN_PATH:-}"
  do
    [[ -n "$candidate" ]] || continue
    if [[ ! -x "$candidate" ]]; then
      echo "hapax-claude-headless: configured Claude binary is not executable: $candidate" >&2
      return 1
    fi
    printf '%s\n' "$candidate"
    return 0
  done
  for candidate in \
    "$(command -v claude 2>/dev/null || true)" \
    "$HOME/.npm-global/bin/claude" \
    "${NPM_CONFIG_PREFIX:+$NPM_CONFIG_PREFIX/bin/claude}" \
    "$HOME/.local/share/npm/bin/claude" \
    "/usr/local/bin/claude"
  do
    [[ -n "$candidate" && -x "$candidate" ]] || continue
    printf '%s\n' "$candidate"
    return 0
  done
  return 1
}

CLAUDE_BIN="$(resolve_claude_bin || true)"
[[ -n "$CLAUDE_BIN" ]] || { echo "hapax-claude-headless: claude not found" >&2; exit 4; }

EFFORT="${HAPAX_CLAUDE_EFFORT:-xhigh}"
MODEL="${HAPAX_CLAUDE_MODEL:-}"
CLAUDE_ARGS=(
  -p
  --input-format stream-json
  --output-format stream-json
  --verbose
  --dangerously-skip-permissions
  --effort "$EFFORT"
)
if [[ -n "$MODEL" ]]; then
  CLAUDE_ARGS+=(--model "$MODEL")
fi

INITIAL_MSG="${1:-}"
if [[ -z "$INITIAL_MSG" ]]; then
  echo "hapax-claude-headless: governed initial message required" >&2
  exit 5
fi
# Session-keyed claim FIRST (review #4097-1): the legacy role-keyed file is
# shared by every session of this role — reading it alone defeats the
# isolation this PR exists to provide. A fresh launcher has a fresh
# SESSION_UUID, so its session file cannot exist yet; any hit on the legacy
# file is informational fallback for --task-less relaunches only.
SESSION_CLAIM_FILE="$HOME/.cache/hapax/cc-active-task-$ROLE-$SESSION_UUID"
CLAIM_FILE="$HOME/.cache/hapax/cc-active-task-$ROLE"
CLAIMED_TASK=""
if [[ -s "$SESSION_CLAIM_FILE" ]]; then
  CLAIMED_TASK="$(head -n1 "$SESSION_CLAIM_FILE" | tr -d '[:space:]')"
elif [[ -s "$CLAIM_FILE" ]]; then
  CLAIMED_TASK="$(head -n1 "$CLAIM_FILE" | tr -d '[:space:]')"
fi
if [[ -z "$CLAUDE_TASK" && -n "$CLAIMED_TASK" ]]; then
  CLAUDE_TASK="$CLAIMED_TASK"
fi
if [[ -z "$CLAUDE_TASK" ]]; then
  echo "hapax-claude-headless: refusing mutating launch without --task <cc-task-id> or existing active claim for role '$ROLE'" >&2
  exit 15
fi
if [[ -n "$CLAIMED_TASK" && "$CLAIMED_TASK" != "$CLAUDE_TASK" ]]; then
  echo "hapax-claude-headless: refusing launch; role '$ROLE' already claims '$CLAIMED_TASK', not dispatch task '$CLAUDE_TASK'" >&2
  exit 13
fi
if [[ -z "$CLAIMED_TASK" ]]; then
  [[ -x "$WORKDIR/scripts/cc-claim" ]] || { echo "hapax-claude-headless: missing cc-claim in $WORKDIR" >&2; exit 14; }
  (cd "$WORKDIR" && "$WORKDIR/scripts/cc-claim" "$CLAUDE_TASK")
fi
export HAPAX_METHODOLOGY_DISPATCH_TASK="$CLAUDE_TASK"
record_child_spawn_receipt "$CLAUDE_TASK" "claude-headless:$ROLE:$SESSION_UUID"

SDLC_PREAMBLE="SDLC DISCIPLINE (MANDATORY):
1. Work only on the task named in this dispatch.
2. Run cc-claim for that exact task before mutation.
3. If cc-claim rejects, stop and write a relay receipt.
4. Use only the AuthorityCase and parent spec named in this dispatch.
5. Do not create, select, or claim other work from the task pool.
6. When the task is complete or blocked, report status and idle.

Session identity: role=$ROLE session_id=$SESSION_UUID. Include this session_id in any relay receipt or witness artifact you write.

DISPATCH:
"
INITIAL_MSG="${SDLC_PREAMBLE}${INITIAL_MSG}"

echo "hapax-claude-headless: starting $ROLE in $WORKDIR"
echo "  stdin pipe: $STDIN_PIPE"
echo "  log: $LOG_FILE"

exec 3<>"$STDIN_PIPE"

echo "{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"type\":\"text\",\"text\":$(printf '%s' "$INITIAL_MSG" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))')}]}}" >&3

cd "$WORKDIR"

# --- Merge-aware teardown (reform deadlane closeout) ---------------------------
# The respawn loop must terminate once the dispatched task is finished, instead
# of re-injecting a generic restart prompt forever (which stranded merged work
# and stacked zombies). task_is_terminal decides, before each respawn, whether
# the task is closed (claim cleared / note left active/ / terminal status) or
# its PR has merged.
CC_TASK_ACTIVE="${HAPAX_CC_TASK_ROOT:-$HOME/Documents/Personal/20-projects/hapax-cc-tasks}/active"

find_active_note() {
  local task="$1" note=""
  if [[ -f "$CC_TASK_ACTIVE/$task.md" ]]; then
    note="$CC_TASK_ACTIVE/$task.md"
  else
    note="$(ls "$CC_TASK_ACTIVE/$task-"*.md 2>/dev/null | head -n1 || true)"
  fi
  printf '%s' "$note"
}

task_is_terminal() {
  # 0 = terminal (stop the respawn loop); 1 = still live (keep the lane up).
  #
  # v2 fix (2026-06-12 postmortem): a MISSING claim file is treated as
  # INDETERMINATE, not terminal.  The old code returned 0 (terminal) whenever
  # $claimed != $task, which included the missing-file case.  That killed live
  # lanes (delta, zeta) when their caches vanished mid-run with no journaled
  # actor.  Now: if the claim file is absent, fall through to note + PR checks
  # and also consult the session-keyed claim file as a secondary source.
  local task="$1"
  [[ -n "$task" ]] || return 1   # no task binding -> legacy always-on behavior

  local claimed="" claim_source="primary"
  if [[ -s "$CLAIM_FILE" ]]; then
    claimed="$(head -n1 "$CLAIM_FILE" 2>/dev/null | tr -d '[:space:]' || true)"
  fi

  # If primary cache is missing or empty, try session-keyed claim files.
  # cc-claim writes cc-active-task-<role>-<session_id>, so we glob for all
  # session-keyed files matching this role and pick the most recently modified.
  if [[ -z "$claimed" ]]; then
    local session_claim="" newest_mtime=0
    for candidate in "$HOME/.cache/hapax/cc-active-task-${ROLE}-"*; do
      [[ -s "$candidate" ]] || continue
      local mtime
      mtime="$(stat -c %Y "$candidate" 2>/dev/null || echo 0)"
      if (( mtime > newest_mtime )); then
        newest_mtime="$mtime"
        session_claim="$candidate"
      fi
    done
    if [[ -n "$session_claim" && -s "$session_claim" ]]; then
      claimed="$(head -n1 "$session_claim" 2>/dev/null | tr -d '[:space:]' || true)"
      claim_source="session-keyed:$(basename "$session_claim")"
    fi
  fi

  if [[ -z "$claimed" ]]; then
    # Claim cache MISSING on all sources.  This is INDETERMINATE — do NOT
    # treat as terminal.  Fall through to note + PR verification.
    # Log the anomaly for forensic tracing.
    printf 'hapax-claude-headless[%s]: task_is_terminal: claim cache MISSING for role=%s task=%s — treating as indeterminate (fail-open)\n' "$$" "$ROLE" "$task" >&2
  elif [[ "$claimed" != "$task" ]]; then
    # cc-close clears the claim file; a re-point means the lane moved on.
    # This is a DEFINITIVE terminal signal (the file exists and names a
    # different task).
    return 0
  fi
  # claimed == task  OR  claimed is missing (indeterminate) — verify via note.

  local note=""
  note="$(find_active_note "$task")"
  [[ -n "$note" ]] || return 0   # note left active/ (moved to closed/) -> closed
  local status=""
  status="$(grep -oP '^status:\s*\K\S+' "$note" 2>/dev/null | head -n1 || true)"
  case "$status" in
    # Definitively terminal lifecycle states -> the lane's work is over.
    done | completed | closed | withdrawn | superseded | abandoned) return 0 ;;
    # Everything else (claimed/in_progress/pr_open/blocked/unknown) is NOT
    # terminal on status alone: fall through to the assigned + PR-state reality
    # checks below. A live open-PR lane (status: pr_open) must NEVER be killed
    # here (class #5: never kill a live open-PR lane); offered/unassigned are
    # caught by the assigned-mismatch check, and a still-open PR returns live.
    *) ;;
  esac
  local note_assigned=""
  note_assigned="$(grep -oP '^assigned_to:\s*\K\S+' "$note" 2>/dev/null | head -n1 || true)"
  if [[ -n "$note_assigned" && "$note_assigned" != "$ROLE" ]]; then
    return 0
  fi
  # PR merged but the note not yet closed (the dead-lane window): stop now; the
  # merge-watcher closes the note shortly. Fail-open on any gh hiccup.
  local pr=""
  pr="$(grep -oP '^pr:\s*\K[0-9]+' "$note" 2>/dev/null | head -n1 || true)"
  if [[ -n "$pr" ]]; then
    local state=""
    state="$(gh pr view "$pr" --json state --jq .state 2>/dev/null || true)"
    [[ "$state" == "MERGED" ]] && return 0
  fi
  return 1
}

dispatch_host_is_local() {
  local host="${1:-}" short="" fqdn="" local_ip="" resolved_ip=""
  [[ -z "$host" || "$host" == "local" || "$host" == "localhost" ]] && return 0
  [[ "$host" == "127.0.0.1" || "$host" == "::1" ]] && return 0
  short="$(hostname -s 2>/dev/null || hostname 2>/dev/null || true)"
  fqdn="$(hostname -f 2>/dev/null || true)"
  [[ "$host" == "appendix" ]] && host="hapax-appendix"
  [[ "$host" == "podium" ]] && host="hapax-podium"
  [[ -n "$short" && "$host" == "$short" ]] && return 0
  [[ -n "$fqdn" && "$host" == "$fqdn" ]] && return 0
  for local_ip in $(hostname -I 2>/dev/null || true); do
    [[ "$host" == "$local_ip" ]] && return 0
  done
  if command -v getent >/dev/null 2>&1; then
    for resolved_ip in $(getent ahosts "$host" 2>/dev/null | awk '{print $1}'); do
      for local_ip in $(hostname -I 2>/dev/null || true); do
        [[ "$resolved_ip" == "$local_ip" ]] && return 0
      done
    done
  fi
  return 1
}

remote_python_command() {
  local payload="$1" code="$2"
  local code_b64="" bash_script="" quoted_script="" quoted_payload="" quoted_code=""
  code_b64="$(printf '%s' "$code" | python3 -c 'import base64,sys; print(base64.b64encode(sys.stdin.buffer.read()).decode())')"
  bash_script='export HAPAX_REMOTE_PAYLOAD="$1"; export HAPAX_REMOTE_CODE="$2"; exec python3 -c "import base64,os; exec(base64.b64decode(os.environ[\"HAPAX_REMOTE_CODE\"]))"'
  quoted_script="${bash_script//\'/\'\\\'\'}"
  quoted_payload="${payload//\'/\'\\\'\'}"
  quoted_code="${code_b64//\'/\'\\\'\'}"
  printf "bash -c '%s' bash '%s' '%s'" "$quoted_script" "$quoted_payload" "$quoted_code"
}

remote_payload_b64() {
  local kind="$1"
  shift
  python3 - "$kind" "$@" <<'PYEOF'
import base64
import json
import sys

kind = sys.argv[1]
if kind == "preflight":
    payload = {"kind": kind, "workdir": sys.argv[2], "binaries": sys.argv[3:]}
elif kind == "exec":
    payload = {
        "kind": kind,
        "workdir": sys.argv[2],
        "env": {
            "LOGOS_BASE_URL": sys.argv[3],
            "COCKPIT_BASE_URL": sys.argv[3],
            "HAPAX_DISPATCH_HOST": sys.argv[4],
            "HAPAX_DISPATCH_LOGOS_URL": sys.argv[3],
            "HAPAX_DISPATCH_PROOF_FILE": sys.argv[5],
        },
        "proof_file": sys.argv[5],
        "requested_host": sys.argv[4],
        "argv": sys.argv[6:],
    }
    # Session identity must survive the SSH boundary (taxonomy-a3-session-
    # identity): without these the exec-host claude resolves a DIFFERENT
    # session id (CLAUDE_CODE_SESSION_ID fallback), the session-keyed claim
    # exists only launcher-side, and the lane hits cc-claim exit-4 walls (the
    # recurring appendix-remote-dispatch claim gap). Pulled from the
    # launcher's own exports — the identity it minted for THIS spawn.
    import os

    identity_keys = (
        "HAPAX_SESSION_ID",
        "HAPAX_AGENT_INTERFACE",
        "HAPAX_AGENT_NAME",
        "HAPAX_AGENT_ROLE",
        "CLAUDE_ROLE",
        "HAPAX_WORKTREE_ROLE",
        "HAPAX_METHODOLOGY_DISPATCH_TASK",
        "HAPAX_PARENT_ROUTE_ENVELOPE",
        "HAPAX_REQUIRE_PARENT_ROUTE_ENVELOPE",
        "HAPAX_CHILD_SPAWN_ENVELOPE",
        "HAPAX_CHILD_RECEIPT_REF",
        "HAPAX_CHILD_RECEIPT_ID",
    )
    payload["env"].update(
        {k: os.environ[k] for k in identity_keys if os.environ.get(k)}
    )
else:
    raise SystemExit(f"unknown remote payload kind: {kind}")
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

REMOTE_PREFLIGHT_PY='import base64,json,os,shutil,subprocess,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); ok=os.path.isdir(p["workdir"]) and all(shutil.which(b) for b in p.get("binaries",())); gh_ok=shutil.which("gh") is not None and subprocess.run(["gh","auth","status"],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL).returncode==0; sys.exit(0 if ok and gh_ok else 1)'
REMOTE_EXEC_PY='import base64,json,os,socket,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); os.chdir(p["workdir"]); os.environ.update(p.get("env",{})); proof=p.get("proof_file",""); cgroup="";
try:
    cgroup=open("/proc/self/cgroup",encoding="utf-8").read()
except OSError:
    pass
# Exec-host identity materialization (taxonomy-a3-session-identity): the
# session-keyed claim + role marker must exist on the host where the lane
# RUNS, or the gate falls back to a stale legacy file and cc-claim re-binding
# walls the lane (the recurring appendix claim gap). Best-effort: a failure is
# recorded in the proof, never allowed to kill the dispatch.
sid=os.environ.get("HAPAX_SESSION_ID",""); role=os.environ.get("HAPAX_AGENT_ROLE",""); task=os.environ.get("HAPAX_METHODOLOGY_DISPATCH_TASK",""); keyable=False; materialized=False
try:
    sys.path.insert(0, p["workdir"])
    from shared.session_identity import is_claim_keyable_session_id
    keyable=is_claim_keyable_session_id(sid)
except Exception:
    keyable=bool(sid) and "/" not in sid and not sid.isdigit() and not sid.rsplit("-",1)[-1].isdigit()
try:
    if keyable and role:
        cache=os.path.join(os.path.expanduser("~"),".cache","hapax")
        os.makedirs(cache,exist_ok=True)
        open(os.path.join(cache,"session-role-"+sid),"w",encoding="utf-8").write(role+"\n")
        if task:
            open(os.path.join(cache,"cc-active-task-"+role),"w",encoding="utf-8").write(task+"\n")
            open(os.path.join(cache,"cc-active-task-"+role+"-"+sid),"w",encoding="utf-8").write(task+"\n")
            materialized=True
except Exception:
    pass
if proof:
    os.makedirs(os.path.dirname(proof), exist_ok=True)
    data={"schema_version":1,"event":"dispatch_remote_exec","platform":"claude-headless","requested_host":p.get("requested_host"),"actual_host":socket.gethostname(),"pid":os.getpid(),"cgroup":cgroup,"workdir":p.get("workdir"),"logos_base_url":os.environ.get("LOGOS_BASE_URL"),"argv0":p["argv"][0] if p.get("argv") else None,"argc":len(p.get("argv",[])),"session_id":sid or None,"role":role or None,"task_id":task or None,"claim_materialized":materialized}; open(proof,"w",encoding="utf-8").write(json.dumps(data,sort_keys=True)+"\n")
argv=p["argv"]; os.execvp(argv[0], argv)'

RESTART_COUNT=0
MAX_RESTART_BACKOFF="${HAPAX_CLAUDE_HEADLESS_RESTART_BACKOFF_SECONDS:-30}"
QUOTA_STREAK=0
QUOTA_BACKOFF_CAP="${HAPAX_HEADLESS_QUOTA_BACKOFF_CAP_SECONDS:-21600}"  # 6h ceiling for quota-wall backoff
# Out-of-band self-reap poll cadence: how often the teardown watchdog re-checks
# task terminality while claude is alive (claude never EOFs the held FIFO, so a
# bare `wait` would block forever — see the watchdog in the loop below).
TERMINAL_POLL_S="${HAPAX_CLAUDE_HEADLESS_TERMINAL_POLL_SECONDS:-60}"

# ── G2 dispatch-host preflight (appendix migration) ─────────────────────────
# HAPAX_DISPATCH_HOST set → the inner `claude` exec runs on appendix; the
# launcher itself (FIFO, PID/lock/relay, cc-claim, restart loop) stays
# podium-local so the cockpit, send/steer, and reaper keep working unchanged.
# Unsafe remote shell interpolation is forbidden here: path/env/model args are
# JSON→base64 payload, decoded by remote python, then execvp'd as argv. If the
# requested host is not ready, fail closed unless the operator explicitly opts
# into local fallback with HAPAX_DISPATCH_HOST_FALLBACK=local.
DISPATCH_HOST="${HAPAX_DISPATCH_HOST:-}"
# G8: the lane's hapax MCP (stdio) connects to logos-api; on the Workshop that
# must be podium's LAN address, not appendix localhost. Injected into the hop env
# below (hapax-mcp prefers LOGOS_BASE_URL over the config's COCKPIT_BASE_URL).
DISPATCH_LOGOS_URL="${HAPAX_DISPATCH_LOGOS_URL:-http://192.168.68.85:8051/api}"
DISPATCH_PROOF_DIR="${HAPAX_DISPATCH_PROOF_DIR:-$HOME/.cache/hapax/orchestration/dispatch-host-proofs}"
DISPATCH_PROOF_FILE="$DISPATCH_PROOF_DIR/$(date -u +%Y%m%dT%H%M%SZ)-$ROLE-${CLAUDE_TASK:-no-task}-remote.json"
if [[ -n "$DISPATCH_HOST" ]]; then
  if dispatch_host_is_local "$DISPATCH_HOST"; then
    DISPATCH_HOST=""
  else
    PREFLIGHT_PAYLOAD="$(remote_payload_b64 preflight "$WORKDIR" python3 claude)"
    PREFLIGHT_COMMAND="$(remote_python_command "$PREFLIGHT_PAYLOAD" "$REMOTE_PREFLIGHT_PY")"
    if ssh -o BatchMode=yes -o ConnectTimeout=4 -i "$HOME/.ssh/id_ed25519" \
          -o ControlPath="$HOME/.ssh/cm-%r@%h:%p" "$DISPATCH_HOST" \
          "$PREFLIGHT_COMMAND" 2>/dev/null; then
      echo "hapax-claude-headless: dispatch -> $DISPATCH_HOST (claude on appendix; launcher podium-local)"
    elif [[ "${HAPAX_DISPATCH_HOST_FALLBACK:-}" == "local" ]]; then
      echo "hapax-claude-headless: dispatch_host_unready ($DISPATCH_HOST) -- explicit local fallback" >&2
      DISPATCH_HOST=""
    else
      echo "hapax-claude-headless: dispatch_host_unready ($DISPATCH_HOST) -- refusing local fallback without HAPAX_DISPATCH_HOST_FALLBACK=local" >&2
      exit 75
    fi
  fi
fi

while true; do
  if [[ -e "$DISABLE_FILE" ]]; then
    echo "hapax-claude-headless: disabled by $DISABLE_FILE" >&2
    exit 77
  fi
  if ! headless_allowed; then
    echo "hapax-claude-headless: disabled until governed enable exists at $ENABLE_FILE or HAPAX_CLAUDE_HEADLESS_ALLOW=1 is set" >&2
    exit 77
  fi

  if [[ -n "$DISPATCH_HOST" ]]; then
    # G2 inner exec on the Workshop: cd the lane's appendix-local worktree and
    # run THAT host's PATH `claude`. fd 3 (the podium FIFO) feeds the ssh child's
    # stdin exactly as it feeds a local claude — no pty (-tt would corrupt the
    # stream-json), dedicated connection (ControlPath=none, kept alive) so an
    # idle lane isn't dropped by the shared master's ControlPersist. On drop the
    # remote claude EOFs its stdin and the loop below re-execs it.
    REMOTE_EXEC_PAYLOAD="$(
      remote_payload_b64 exec "$WORKDIR" "$DISPATCH_LOGOS_URL" "$DISPATCH_HOST" \
        "$DISPATCH_PROOF_FILE" claude "${CLAUDE_ARGS[@]}"
    )"
    REMOTE_EXEC_COMMAND="$(remote_python_command "$REMOTE_EXEC_PAYLOAD" "$REMOTE_EXEC_PY")"
    ssh -o BatchMode=yes -o RequestTTY=no -o ServerAliveInterval=30 -o ServerAliveCountMax=6 \
        -o ControlPath=none -i "$HOME/.ssh/id_ed25519" "$DISPATCH_HOST" \
        "$REMOTE_EXEC_COMMAND" \
        <&3 >> "$LOG_FILE" 2>&1 &
  else
    "$CLAUDE_BIN" "${CLAUDE_ARGS[@]}" <&3 >> "$LOG_FILE" 2>&1 &
  fi
  CLAUDE_PID=$!
  echo "$CLAUDE_PID" > "$PID_FILE"
  echo "hapax-claude-headless: pid=$CLAUDE_PID (restart #$RESTART_COUNT)"

  # Out-of-band teardown watchdog. claude reads its stdin from the FIFO whose
  # write-end THIS launcher holds open (exec 3<> above), so claude never sees
  # EOF; a bare `wait` would then block forever and the post-turn
  # task_is_terminal check below would be unreachable dead code — the
  # zombie-launcher bug that pinned dozens of lanes on closed/merged tasks. So
  # run a background poller that, while claude is alive, re-checks task
  # terminality every $TERMINAL_POLL_S and SIGTERMs the EXACT child pid (a single
  # positive pid, never a process group) once the task is closed/merged. The main
  # thread still `wait`s on claude directly, so a claude that exits on its own is
  # handled immediately below and the watchdog is torn down — the fast-exit path
  # is unchanged. The watchdog polls AFTER an initial sleep so a fresh turn is
  # never reaped before it starts. It signals a self-reap via a marker file (not
  # by echoing) and runs with its std streams detached to /dev/null: a poll
  # `sleep` that gets orphaned when the watchdog is killed must NOT inherit the
  # launcher's stdout, or it would hold the pipe open past exit and wedge readers.
  rm -f "$SELF_REAP_FLAG"
  (
    exec 3>&-
    while kill -0 "$CLAUDE_PID" 2>/dev/null; do
      sleep "$TERMINAL_POLL_S"
      kill -0 "$CLAUDE_PID" 2>/dev/null || break
      if task_is_terminal "$CLAUDE_TASK"; then
        : > "$SELF_REAP_FLAG"
        kill -TERM "$CLAUDE_PID" 2>/dev/null || true
        break
      fi
    done
  ) >/dev/null 2>&1 &
  TEARDOWN_WATCHDOG_PID=$!

  if wait "$CLAUDE_PID"; then
    EXIT_CODE=0
  else
    EXIT_CODE=$?
  fi
  # claude has exited (on its own or via the watchdog's SIGTERM). Stop the
  # watchdog subshell and reap it so it leaves no zombie. (Any poll `sleep` it
  # orphaned is detached to /dev/null and harmless — it is not waited on here.)
  kill "$TEARDOWN_WATCHDOG_PID" 2>/dev/null || true
  wait "$TEARDOWN_WATCHDOG_PID" 2>/dev/null || true
  if [[ -e "$SELF_REAP_FLAG" ]]; then
    echo "hapax-claude-headless: task $CLAUDE_TASK closed/merged — self-reaping live claude (SIGTERM pid=$CLAUDE_PID)"
    rm -f "$SELF_REAP_FLAG"
  fi
  RESTART_COUNT=$((RESTART_COUNT + 1))

  # Merge-aware teardown: stop respawning once the dispatched task is closed or
  # its PR merged. The cleanup trap (EXIT) reaps the pipe + launcher lock; the
  # lane-supervisor then brings the lane back read-only into idle-await on its
  # next tick — not a forever-respawn zombie.
  if task_is_terminal "$CLAUDE_TASK"; then
    echo "hapax-claude-headless: task $CLAUDE_TASK closed/merged — stopping respawn loop"
    break
  fi

  # Quota-wall-aware backoff: if the lane hit a rate limit, honor the receipt's
  # resets_at (or an exponential streak backoff) instead of the flat 30s restart
  # thrash that re-hits the wall every tick. (quota-wall-backoff-fix)
  BACKOFF="$MAX_RESTART_BACKOFF"
  QW_RC=0
  QW_OUT="$(detect-quota-wall "$ROLE" --streak "$((QUOTA_STREAK + 1))" --base "$MAX_RESTART_BACKOFF" --cap "$QUOTA_BACKOFF_CAP" 2>/dev/null)" || QW_RC=$?
  if [ "$QW_RC" -eq 75 ]; then
    QUOTA_STREAK=$((QUOTA_STREAK + 1))
    [ -n "$QW_OUT" ] && BACKOFF="$QW_OUT"
    echo "hapax-claude-headless: $ROLE QUOTA WALL (streak=$QUOTA_STREAK) — backing off ${BACKOFF}s"
  else
    QUOTA_STREAK=0
  fi

  echo "hapax-claude-headless: $ROLE exited (code=$EXIT_CODE), restarting in ${BACKOFF}s..."

  if [[ -e "$DISABLE_FILE" ]]; then
    echo "hapax-claude-headless: disabled by $DISABLE_FILE" >&2
    exit 77
  fi
  if ! headless_allowed; then
    echo "hapax-claude-headless: disabled until governed enable exists at $ENABLE_FILE or HAPAX_CLAUDE_HEADLESS_ALLOW=1 is set" >&2
    exit 77
  fi

  RESTART_MSG='{"type":"user","message":{"role":"user","content":[{"type":"text","text":"Resume only the active task named in your claim file and prior governed dispatch. If there is no active claim, write a relay status saying idle-awaiting-dispatch. Do not claim any new task."}]}}'
  sleep "$BACKOFF"
  echo "$RESTART_MSG" >&3
done
