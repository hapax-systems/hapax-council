#!/usr/bin/env bash
# hapax-audio-reconciler - continuous desired-state enforcement for broadcast audio links
#
# The reconciler owns broadcast-critical PipeWire links from
# ~/.config/hapax/audio-link-map.conf and privacy/safety disconnects from
# ~/.config/hapax/audio-forbidden-links.conf. It also keeps public broadcast
# source/filter nodes at unity volume so controller or UI drift does not silently
# attenuate the emitted segment. It samples the graph once per tick and only
# mutates missing/present edges and present volume targets; this keeps the
# control plane quiet while preserving fast repair.

set -euo pipefail

INTERVAL_S="${HAPAX_RECONCILER_INTERVAL_S:-2.0}"
LOGFILE="${HAPAX_RECONCILER_LOG:-/tmp/hapax-audio-reconciler.log}"
LINK_MAP="${HAPAX_RECONCILER_LINK_MAP:-/home/hapax/.config/hapax/audio-link-map.conf}"
FORBIDDEN_FILE="${HAPAX_RECONCILER_FORBIDDEN_LINKS:-/home/hapax/.config/hapax/audio-forbidden-links.conf}"
PW_LINK="${HAPAX_RECONCILER_PW_LINK:-pw-link}"
WPCTL="${HAPAX_RECONCILER_WPCTL:-wpctl}"
DEFAULT_VOLUME_NODES="hapax-livestream-tap hapax-broadcast-master hapax-broadcast-normalized hapax-obs-broadcast-remap"
VOLUME_NODE_LIST="${HAPAX_RECONCILER_VOLUME_NODES-$DEFAULT_VOLUME_NODES}"
UNITY_VOLUME_LEVEL="1.0"
ONCE="${HAPAX_RECONCILER_ONCE:-0}"

declare -a DESIRED_LINKS=()
declare -a FORBIDDEN_LINKS=()
declare -a VOLUME_NODES=()
declare -A PRESENT_LINKS=()
declare -A PRESENT_PORTS=()
declare -A ALLOWED_VOLUME_NODES=()
GRAPH=""
WPCTL_STATUS_TEXT=""

log() {
    printf '%s [reconciler] %s\n' "$(date -Iseconds)" "$*" >> "$LOGFILE"
}

trim_policy_line() {
    local line="$1"
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    printf '%s\n' "$line"
}

load_link_map() {
    DESIRED_LINKS=()
    if [[ ! -f "$LINK_MAP" ]]; then
        log "FATAL: link map not found: $LINK_MAP"
        exit 1
    fi
    local line
    while IFS= read -r line; do
        line="$(trim_policy_line "$line")"
        [[ -z "$line" ]] && continue
        DESIRED_LINKS+=("$line")
    done < "$LINK_MAP"
    log "loaded ${#DESIRED_LINKS[@]} desired links from $LINK_MAP"
}

load_forbidden_links() {
    FORBIDDEN_LINKS=()
    [[ ! -f "$FORBIDDEN_FILE" ]] && return
    local line
    while IFS= read -r line; do
        line="$(trim_policy_line "$line")"
        [[ -z "$line" ]] && continue
        FORBIDDEN_LINKS+=("$line")
    done < "$FORBIDDEN_FILE"
    if ((${#FORBIDDEN_LINKS[@]} > 0)); then
        log "loaded ${#FORBIDDEN_LINKS[@]} forbidden link patterns"
    fi
}

init_allowed_volume_nodes() {
    ALLOWED_VOLUME_NODES=()
    local node
    for node in $DEFAULT_VOLUME_NODES; do
        ALLOWED_VOLUME_NODES["$node"]=1
    done
}

load_volume_nodes() {
    VOLUME_NODES=()
    local node
    local rejected=0
    for node in $VOLUME_NODE_LIST; do
        if [[ -n "${ALLOWED_VOLUME_NODES["$node"]+x}" ]]; then
            VOLUME_NODES+=("$node")
        else
            ((rejected += 1))
        fi
    done
    if ((${#VOLUME_NODES[@]} > 0)); then
        log "loaded ${#VOLUME_NODES[@]} unity-volume node target(s)"
    fi
    if ((rejected > 0)); then
        log "WARN: rejected $rejected disallowed unity-volume target(s); Next action: keep volume guard scoped to governed broadcast aggregate nodes or update DEFAULT_VOLUME_NODES through review"
    fi
}

add_port_inventory() {
    local ports="$1"
    local raw line
    while IFS= read -r raw; do
        line="$(trim_policy_line "$raw")"
        [[ -z "$line" ]] && continue
        [[ "$line" == "|->"* || "$line" == "|<-"* ]] && continue
        PRESENT_PORTS["$line"]=1
    done <<< "$ports"
}

refresh_graph() {
    if ! GRAPH="$("$PW_LINK" -l 2>/dev/null)"; then
        GRAPH=""
        PRESENT_LINKS=()
        PRESENT_PORTS=()
        log "WARN: could not read PipeWire link graph"
        return 1
    fi
    PRESENT_LINKS=()
    PRESENT_PORTS=()
    local raw line current_port linked_port
    current_port=""
    while IFS= read -r raw; do
        line="$(trim_policy_line "$raw")"
        [[ -z "$line" ]] && continue
        if [[ "$line" == "|->"* ]]; then
            linked_port="$(trim_policy_line "${line#|->}")"
            [[ -n "$current_port" && -n "$linked_port" ]] || continue
            PRESENT_PORTS["$linked_port"]=1
            PRESENT_LINKS["$current_port|$linked_port"]=1
            continue
        fi
        if [[ "$line" == "|<-"* ]]; then
            linked_port="$(trim_policy_line "${line#|<-}")"
            [[ -n "$current_port" && -n "$linked_port" ]] || continue
            PRESENT_PORTS["$linked_port"]=1
            PRESENT_LINKS["$linked_port|$current_port"]=1
            continue
        fi
        current_port="$line"
        PRESENT_PORTS["$current_port"]=1
    done <<< "$GRAPH"

    local output_ports input_ports
    if output_ports="$("$PW_LINK" -o 2>/dev/null)"; then
        add_port_inventory "$output_ports"
    else
        log "WARN: could not read PipeWire output port inventory"
    fi
    if input_ports="$("$PW_LINK" -i 2>/dev/null)"; then
        add_port_inventory "$input_ports"
    else
        log "WARN: could not read PipeWire input port inventory"
    fi
}

link_present() {
    local source_port="$1"
    local target_port="$2"
    [[ -n "${PRESENT_LINKS["$source_port|$target_port"]+x}" ]]
}

port_present() {
    local port="$1"
    [[ -n "${PRESENT_PORTS["$port"]+x}" ]]
}

enforce_links() {
    local failures=0
    local created=0
    local missing_endpoints=0
    local skipped=0
    local link src tgt err

    for link in "${DESIRED_LINKS[@]}"; do
        src="${link%%|*}"
        tgt="${link##*|}"
        if link_present "$src" "$tgt"; then
            ((skipped += 1))
            continue
        fi
        if ! port_present "$src" || ! port_present "$tgt"; then
            ((missing_endpoints += 1))
            continue
        fi
        err="$("$PW_LINK" "$src" "$tgt" 2>&1)" && {
            ((created += 1))
            continue
        }
        if [[ "$err" == *"File exists"* ]]; then
            ((skipped += 1))
            continue
        fi
        ((failures += 1))
    done

    if ((created > 0)); then
        log "created $created missing link(s); skipped $skipped already-present link(s)"
    fi
    if ((missing_endpoints > 0 && tick % 60 == 0)); then
        log "deferred $missing_endpoints/${#DESIRED_LINKS[@]} link(s) with absent endpoint ports"
    fi
    if ((failures > 0 && tick % 60 == 0)); then
        log "WARN: $failures/${#DESIRED_LINKS[@]} links could not be established (nodes may not exist yet)"
    fi
}

enforce_forbidden() {
    local destroyed=0
    local link src tgt
    for link in "${FORBIDDEN_LINKS[@]}"; do
        src="${link%%|*}"
        tgt="${link##*|}"
        if ! link_present "$src" "$tgt"; then
            continue
        fi
        if "$PW_LINK" -d "$src" "$tgt" 2>/dev/null; then
            ((destroyed += 1))
            log "ALERT: destroyed forbidden link $src -> $tgt"
        fi
    done
    if ((destroyed > 0)); then
        refresh_graph || true
    fi
}

node_id_from_wpctl_status() {
    local wanted="$1"
    local raw line id name
    while IFS= read -r raw; do
        line="$(trim_policy_line "$raw")"
        [[ -z "$line" ]] && continue
        # ``wpctl status --name`` renders a tree prefix, an optional default
        # marker, then ``<id>. <node.name> [metadata]``.
        if [[ "$line" =~ ^[^0-9]*\*?[[:space:]]*([0-9]+)\.[[:space:]]+([^[]+)[[:space:]]+\[ ]]; then
            id="${BASH_REMATCH[1]}"
            name="$(trim_policy_line "${BASH_REMATCH[2]}")"
            if [[ "$name" == "$wanted" ]]; then
                printf '%s\n' "$id"
                return 0
            fi
        fi
    done <<< "$WPCTL_STATUS_TEXT"
    return 1
}

enforce_unity_volumes() {
    ((${#VOLUME_NODES[@]} == 0)) && return

    if ! WPCTL_STATUS_TEXT="$("$WPCTL" status --name 2>/dev/null)"; then
        WPCTL_STATUS_TEXT=""
        if ((tick % 60 == 0)); then
            log "WARN: could not read WirePlumber node status for unity-volume guard; Next action: run 'wpctl status --name' and confirm WirePlumber is active"
        fi
        return
    fi

    local node id
    local repaired=0
    local missing=0
    local failures=0
    for node in "${VOLUME_NODES[@]}"; do
        if ! id="$(node_id_from_wpctl_status "$node")"; then
            ((missing += 1))
            continue
        fi
        if "$WPCTL" set-volume "$id" "$UNITY_VOLUME_LEVEL" 2>/dev/null; then
            ((repaired += 1))
        else
            ((failures += 1))
        fi
    done

    if ((repaired > 0)); then
        log "set unity volume on $repaired broadcast node(s)"
    fi
    if ((missing > 0 && tick % 60 == 0)); then
        log "deferred $missing/${#VOLUME_NODES[@]} unity-volume target(s) with absent node names; Next action: run 'wpctl status --name' and confirm broadcast aggregate node names"
    fi
    if ((failures > 0 && tick % 60 == 0)); then
        log "WARN: $failures/${#VOLUME_NODES[@]} unity-volume target(s) could not be repaired; Next action: identify blocked target with 'wpctl status --name' and retry 'wpctl set-volume <id> 1.0'"
    fi
}

log "=== hapax-audio-reconciler starting ==="
log "interval=${INTERVAL_S}s link_map=$LINK_MAP forbidden=$FORBIDDEN_FILE volume_level=$UNITY_VOLUME_LEVEL"

load_link_map
load_forbidden_links
init_allowed_volume_nodes
load_volume_nodes

tick=0
while true; do
    refresh_graph || true
    enforce_links
    enforce_forbidden
    enforce_unity_volumes

    ((tick += 1))
    if ((tick % 60 == 0)); then
        load_link_map
        load_forbidden_links
        load_volume_nodes
    fi

    if [[ "$ONCE" == "1" ]]; then
        break
    fi
    sleep "$INTERVAL_S"
done
