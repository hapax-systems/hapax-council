#!/usr/bin/env -S uv run python
"""hapax-audio-topology — CLI for the declarative PipeWire topology.

Phase 3 of docs/superpowers/plans/2026-04-20-unified-audio-architecture-
plan.md. Wraps shared.audio_topology + audio_topology_generator with
subcommands operators (and CI) run against ``config/audio-topology.yaml``.

Subcommands shipped in this phase:

- ``describe <yaml>``  — parse the descriptor and print a node/edge
  summary (operator-readable, not machine-readable).
- ``generate <yaml> [--output-dir <dir>]``  — write generated confs
  to ``<dir>/pipewire/<node.id>.conf``. Without ``--output-dir``,
  prints the dict to stdout so it can be piped through ``diff`` or
  similar.
- ``diff <yaml_a> <yaml_b>`` — structural diff between two
  descriptors; shows node additions/removals/changes + edge changes.

Live-graph + recovery subcommands (Phase 4 + Phase 5):

- ``verify``    — assert live graph matches descriptor
- ``audit``     — full drift report
- ``l12-forward-check`` — static L-12 forward/private route guard
- ``l12-scene-check`` — live L-12 BROADCAST-V2 scene signal assertion
- ``watchdog``  — Ryzen codec pin-glitch recovery sequence (manual)
- ``pin-check`` — single-shot pin-glitch detection with persisted
  silence-window state for systemd-timer composition; --auto-fix
  invokes the watchdog recovery on PIN_GLITCH

Exit codes:

- 0  — success
- 1  — parse error / validation error / file-not-found
- 2  — descriptors differ (``diff`` subcommand only; mirrors
       ``diff(1)`` convention)
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

from shared.audio_topology import (
    Edge,
    Node,
    TopologyDescriptor,
)
from shared.audio_topology_generator import generate_confs
from shared.audio_topology_inspector import (
    check_l12_broadcast_scene_active,
    check_l12_forward_invariant,
    check_tts_broadcast_path,
    descriptor_from_dump_file,
    descriptor_from_live,
)


def _load(path: str) -> TopologyDescriptor:
    try:
        return TopologyDescriptor.from_yaml(Path(path))
    except FileNotFoundError:
        print(f"error: descriptor file not found: {path}", file=sys.stderr)
        sys.exit(1)
    except Exception as exc:  # pydantic ValidationError + YAML errors
        print(f"error: failed to load {path}: {exc}", file=sys.stderr)
        sys.exit(1)


def _format_node(n: Node) -> str:
    parts = [f"{n.id} [{n.kind.value}]"]
    parts.append(f"name={n.pipewire_name}")
    if n.hw:
        parts.append(f"hw={n.hw}")
    if n.target_object:
        parts.append(f"target={n.target_object}")
    if n.channels.count != 2 or n.channels.positions not in (["FL", "FR"], []):
        parts.append(f"channels={n.channels.count}")
    return "  " + "  ".join(parts)


def cmd_describe(args: argparse.Namespace) -> int:
    d = _load(args.descriptor)
    print(f"# {d.description or 'topology descriptor'}")
    print(f"schema_version: {d.schema_version}")
    print(f"nodes ({len(d.nodes)}):")
    for n in d.nodes:
        print(_format_node(n))
    print(f"edges ({len(d.edges)}):")
    for e in d.edges:
        src = f"{e.source}:{e.source_port}" if e.source_port else e.source
        tgt = f"{e.target}:{e.target_port}" if e.target_port else e.target
        gain = f" ({e.makeup_gain_db:+.1f} dB)" if e.makeup_gain_db else ""
        print(f"  {src} → {tgt}{gain}")
    return 0


def cmd_generate(args: argparse.Namespace) -> int:
    d = _load(args.descriptor)
    out = generate_confs(d)
    if args.output_dir is None:
        for filename, content in out.items():
            print(f"\n### {filename} ###")
            print(content)
        return 0

    outdir = Path(args.output_dir)
    outdir.mkdir(parents=True, exist_ok=True)
    written = 0
    for filename, content in out.items():
        dest = outdir / filename
        dest.parent.mkdir(parents=True, exist_ok=True)
        dest.write_text(content)
        written += 1
    print(f"wrote {written} conf(s) under {outdir}/")
    return 0


def cmd_diff(args: argparse.Namespace) -> int:
    a = _load(args.left)
    b = _load(args.right)

    a_ids = {n.id: n for n in a.nodes}
    b_ids = {n.id: n for n in b.nodes}

    added = b_ids.keys() - a_ids.keys()
    removed = a_ids.keys() - b_ids.keys()
    shared = a_ids.keys() & b_ids.keys()
    changed = [i for i in shared if a_ids[i] != b_ids[i]]

    drift = False
    if added:
        drift = True
        print("+ added nodes:")
        for node_id in sorted(added):
            print(f"  + {_format_node(b_ids[node_id]).strip()}")
    if removed:
        drift = True
        print("- removed nodes:")
        for node_id in sorted(removed):
            print(f"  - {_format_node(a_ids[node_id]).strip()}")
    if changed:
        drift = True
        print("~ changed nodes:")
        for node_id in sorted(changed):
            print(f"  ~ {node_id}")
            print(f"      was: {_format_node(a_ids[node_id]).strip()}")
            print(f"      now: {_format_node(b_ids[node_id]).strip()}")

    a_edges = {(e.source, e.source_port, e.target, e.target_port): e for e in a.edges}
    b_edges = {(e.source, e.source_port, e.target, e.target_port): e for e in b.edges}
    a_keys = set(a_edges)
    b_keys = set(b_edges)
    added_edges = b_keys - a_keys
    removed_edges = a_keys - b_keys
    changed_edges = [k for k in a_keys & b_keys if a_edges[k] != b_edges[k]]

    if added_edges:
        drift = True
        print("+ added edges:")
        for k in sorted(added_edges):
            e = b_edges[k]
            print(f"  + {e.source} → {e.target} (+{e.makeup_gain_db:+.1f} dB)")
    if removed_edges:
        drift = True
        print("- removed edges:")
        for k in sorted(removed_edges):
            e = a_edges[k]
            print(f"  - {e.source} → {e.target}")
    if changed_edges:
        drift = True
        print("~ changed edges (gain shift):")
        for k in sorted(changed_edges):
            print(
                f"  ~ {k[0]} → {k[2]}: "
                f"{a_edges[k].makeup_gain_db:+.1f} dB → "
                f"{b_edges[k].makeup_gain_db:+.1f} dB"
            )

    if not drift:
        print("descriptors match (no drift)")
        return 0
    return 2


def _diff_descriptors(
    a: TopologyDescriptor,
    b: TopologyDescriptor,
    *,
    collect: dict | None = None,
) -> bool:
    """Compare two descriptors; print report + return True if drift detected.

    Matches nodes by ``pipewire_name`` (the only identifier stable
    between a hand-authored descriptor and a live pw-dump-derived one).
    Matching by ``Node.id`` used to produce false-positive drift for
    every descriptor node because the inspector's ``_id_from_name``
    derives IDs differently from operator hand-authored kebab-case
    (#216 inspector classification gap — fixed by matching on the
    authoritative pipewire_name instead).

    Kind mismatches surface as a separate WARNING rather than as
    "missing on left + extra on right" noise — when a node IS present
    in both by pipewire_name, a kind disagreement means the inspector's
    classification heuristic missed the mark, not that the operator's
    config and the running graph have drifted.

    When ``collect`` is provided, structured drift records are appended
    to it under canonical keys (``classified_added_nodes``,
    ``unclassified_added_nodes``, ``classified_added_edges``,
    ``unclassified_added_edges``, etc.). Used by ``--json``/``--output``
    to publish the verify result as machine-readable evidence.
    """
    a_by_name = {n.pipewire_name: n for n in a.nodes}
    b_by_name = {n.pipewire_name: n for n in b.nodes}
    added_names = b_by_name.keys() - a_by_name.keys()
    removed_names = a_by_name.keys() - b_by_name.keys()
    shared_names = a_by_name.keys() & b_by_name.keys()

    drift = False
    classified_added = []
    unclassified_added = []
    for name in sorted(added_names):
        node = b_by_name[name]
        classification = _classify_live_extra_node(node)
        if classification:
            classified_added.append((node, classification))
        else:
            unclassified_added.append(node)
    if classified_added:
        print("~ nodes only in right (classified external/runtime):")
        for node, classification in classified_added:
            print(f"  ~ {_format_node(node).strip()} [{classification}]")
            if collect is not None:
                collect.setdefault("classified_added_nodes", []).append(
                    {"node": node.pipewire_name, "classification": classification}
                )
    if unclassified_added:
        drift = True
        print("+ nodes only in right (live extras):")
        for node in unclassified_added:
            print(f"  + {_format_node(node).strip()}")
            if collect is not None:
                collect.setdefault("unclassified_added_nodes", []).append(
                    {"node": node.pipewire_name}
                )

    classified_removed = []
    unclassified_removed = []
    for name in sorted(removed_names):
        node = a_by_name[name]
        classification = _classify_declared_missing_node(node)
        if classification:
            classified_removed.append((node, classification))
        else:
            unclassified_removed.append(node)
    if classified_removed:
        print("~ nodes only in left (classified expected-missing):")
        for node, classification in classified_removed:
            print(f"  ~ {_format_node(node).strip()} [{classification}]")
            if collect is not None:
                collect.setdefault("classified_missing_nodes", []).append(
                    {"node": node.pipewire_name, "classification": classification}
                )
    if unclassified_removed:
        drift = True
        print("- nodes only in left (expected but missing):")
        for node in unclassified_removed:
            print(f"  - {_format_node(node).strip()}")
            if collect is not None:
                collect.setdefault("unclassified_missing_nodes", []).append(
                    {"node": node.pipewire_name}
                )

    kind_mismatches = []
    for name in sorted(shared_names):
        if a_by_name[name].kind != b_by_name[name].kind:
            kind_mismatches.append((name, a_by_name[name].kind, b_by_name[name].kind))
    if kind_mismatches:
        # Kind mismatch is NOT drift — the node exists, just classified
        # differently. Common when inspector's _classify_node_kind
        # heuristic misses hapax-* non-factory nodes. Report as INFO.
        print("~ nodes present with kind mismatch (inspector classification only):")
        for name, left_kind, right_kind in kind_mismatches:
            print(f"  ~ {name}: descriptor={left_kind.value} live={right_kind.value}")
            if collect is not None:
                collect.setdefault("kind_mismatches", []).append(
                    {
                        "node": name,
                        "descriptor_kind": left_kind.value,
                        "live_kind": right_kind.value,
                    }
                )

    a_edges = {_edge_name_key(a, e) for e in a.edges}
    b_edges = {_edge_name_key(b, e) for e in b.edges}
    added_edges = b_edges - a_edges
    removed_edges = a_edges - b_edges

    classified_added_edges = []
    unclassified_added_edges = []
    for source_name, target_name in sorted(added_edges):
        classification = _classify_live_extra_edge(source_name, target_name, a_by_name, b_by_name)
        if classification:
            classified_added_edges.append((source_name, target_name, classification))
        else:
            unclassified_added_edges.append((source_name, target_name))
    if classified_added_edges:
        print("~ edges only in right (classified external/runtime):")
        for source_name, target_name, classification in classified_added_edges:
            print(f"  ~ {source_name} → {target_name} [{classification}]")
            if collect is not None:
                collect.setdefault("classified_added_edges", []).append(
                    {
                        "source": source_name,
                        "target": target_name,
                        "classification": classification,
                    }
                )
    if unclassified_added_edges:
        drift = True
        print("+ edges only in right:")
        for s, t in unclassified_added_edges:
            print(f"  + {s} → {t}")
            if collect is not None:
                collect.setdefault("unclassified_added_edges", []).append(
                    {"source": s, "target": t}
                )

    classified_removed_edges = []
    unclassified_removed_edges = []
    for source_name, target_name in sorted(removed_edges):
        classification = _classify_declared_missing_edge(source_name, target_name, a_by_name)
        if classification:
            classified_removed_edges.append((source_name, target_name, classification))
        else:
            unclassified_removed_edges.append((source_name, target_name))
    if classified_removed_edges:
        print("~ edges only in left (classified expected-missing):")
        for source_name, target_name, classification in classified_removed_edges:
            print(f"  ~ {source_name} → {target_name} [{classification}]")
            if collect is not None:
                collect.setdefault("classified_missing_edges", []).append(
                    {
                        "source": source_name,
                        "target": target_name,
                        "classification": classification,
                    }
                )
    if unclassified_removed_edges:
        drift = True
        print("- edges only in left (descriptor-declared but not live):")
        for s, t in unclassified_removed_edges:
            print(f"  - {s} → {t}")
            if collect is not None:
                collect.setdefault("unclassified_missing_edges", []).append(
                    {"source": s, "target": t}
                )

    return drift


def _edge_name_key(descriptor: TopologyDescriptor, edge: Edge) -> tuple[str, str]:
    """Return an edge key using stable PipeWire node names, not descriptor IDs."""
    source = descriptor.node_by_id(edge.source).pipewire_name
    target = descriptor.node_by_id(edge.target).pipewire_name
    return (source, target)


def _classify_live_extra_node(node: Node) -> str | None:
    """Classify live nodes that are expected outside the canonical descriptor."""
    explicit = node.params.get("audit_classification")
    if isinstance(explicit, str) and explicit:
        return explicit
    name = node.pipewire_name
    if name.startswith("alsa_") and not name.startswith(
        (
            "alsa_input.usb-ZOOM_Corporation_L-12",
            "alsa_output.usb-ZOOM_Corporation_L-12",
            "alsa_input.usb-Torso_Electronics_S-4",
            "alsa_output.usb-Torso_Electronics_S-4",
        )
    ):
        return "external-hardware-endpoint"
    if name.startswith("input.loopback.sink.role."):
        return "wireplumber-runtime-role-loopback"
    if name == "hapax-livestream-duck":
        return "legacy-retired-l6-runtime-node"
    # L-12 USB-return capture filter chain — runtime node not yet in the
    # canonical descriptor (added by the L-12 USB-return capture module
    # after the MPC-centric topology migration).
    if name == "hapax-l12-usb-return-capture":
        return "runtime-l12-usb-return-capture"
    return None


def _classify_declared_missing_node(node: Node) -> str | None:
    """Classify descriptor nodes that are legitimately absent at runtime."""
    explicit = node.params.get("audit_classification")
    if isinstance(explicit, str) and explicit:
        return explicit
    return None


def _classify_live_extra_edge(
    source_name: str,
    target_name: str,
    declared_by_name: dict[str, Node],
    live_by_name: dict[str, Node],
) -> str | None:
    """Classify live edges that are known runtime fallback artifacts.

    Architectural compliance edges (Option C, 2026-05-02 spec amendment):

    - `private-track-fenced-via-s4-out-1` covers the Option C private
      monitor route. Edges from a `private_monitor_bridge=true` source
      to a `private_monitor_endpoint=true` target whose `option_c_route`
      param is `private-track-fenced-via-s4-out-1` belong to the
      track-fenced S-4 path. The runtime edge from the bridge to the
      S-4 USB IN sink is the privacy-preserving path: the S-4 internal
      scene then routes Track 1 input → analog OUT 1/2 (operator-side
      monitor patch). This classification keeps the topology audit
      from flagging the new edge as unclassified `+ edges only in right`.
    - `private-monitor-runtime-output-binding` is retained for the
      legacy Yeti pin (only active when the operator has reverted to
      `56-hapax-private-pin-yeti.conf.disabled-2026-05-02-option-c`).
    """
    source = declared_by_name.get(source_name)
    target = declared_by_name.get(target_name)
    if (
        source is not None
        and target is not None
        and source.params.get("private_monitor_bridge") is True
        and target.params.get("private_monitor_endpoint") is True
        and source.target_object == target_name
    ):
        # Option C — track-fenced route via S-4 OUT 1.
        if target.params.get("option_c_route") == "private-track-fenced-via-s4-out-1":
            return "private-track-fenced-via-s4-out-1"
        return "private-monitor-runtime-output-binding"

    if (
        target_name == "hapax-m8-instrument-capture"
        and source_name.startswith("alsa_input.usb-ZOOM_Corporation_L-12")
        and target is not None
        and target.target_object not in live_by_name
    ):
        return "runtime-fallback-m8-source-absent"

    # MPC-centric topology (2026-05-04): PipeWire sometimes resolves
    # private-monitor playback links to the MPC USB multichannel output
    # in addition to the declared S-4 target. This occurs when the MPC
    # is on the same USB bus and PipeWire's link graph exposes both
    # endpoints. The S-4 WirePlumber pin remains authoritative for the
    # privacy invariant; the MPC link is a runtime artifact that the
    # topology audit should classify rather than flag as unclassified drift.
    if (
        source_name
        in (
            "hapax-private-playback",
            "hapax-notification-private-playback",
        )
        and "Akai_Professional_MPC" in target_name
    ):
        return "runtime-mpc-private-playback-artifact"

    # L-12 USB-return capture: edges feeding runtime-classified nodes
    # should inherit a classification so they don't appear as unclassified
    # drift. The l12-usb-return-capture node is classified as a runtime
    # node above; its feed edge from L-12 capture is the same provenance.
    if target_name == "hapax-l12-usb-return-capture":
        return "runtime-l12-usb-return-capture-feed"

    return None


def _classify_declared_missing_edge(
    source_name: str,
    target_name: str,
    declared_by_name: dict[str, Node],
) -> str | None:
    """Classify declared edges that cannot exist until optional hardware is present."""
    source = declared_by_name.get(source_name)
    target = declared_by_name.get(target_name)
    for node in (source, target):
        if node is None:
            continue
        classification = _classify_declared_missing_node(node)
        if classification:
            return f"depends-on-{classification}"
    return None


def cmd_verify(args: argparse.Namespace) -> int:
    """Compare descriptor against live pw-dump graph (or a saved dump).

    With ``--profile vinyl`` (D-24 §11.4), additionally runs
    ``shared.vinyl_chain_verify.verify_vinyl_chain`` to surface
    vinyl-broadcast-specific chain findings (L6 multitrack presence,
    Handytraxx under Mode D, broadcast tap, S-4 USB-direct). The
    vinyl profile fails the verify call if the chain carries any
    ERROR-severity finding.

    Audit-A#5 follow-up flags:
      ``--strict``  — fail on any drift (matches default behaviour
                      but also exits non-zero when classified-only
                      changes accumulate above zero).
      ``--json``    — print the structured drift report as JSON to
                      stdout in addition to the human-readable diff.
      ``--output PATH`` — write the structured drift report to PATH
                      (used by the boot-time/periodic systemd timer).
      ``--prometheus-textfile PATH`` — additionally render
                      Prometheus textfile-collector compatible metrics
                      to PATH (defaults to
                      ``/var/lib/node_exporter/textfile_collector/
                      hapax_audio_topology.prom`` when --output is
                      provided and writing the prom file is permitted).
    """
    declared = _load(args.descriptor)
    try:
        if args.dump_file:
            live = descriptor_from_dump_file(args.dump_file)
        else:
            live = descriptor_from_live()
    except FileNotFoundError:
        print(
            f"error: pw-dump file not found: {args.dump_file}",
            file=sys.stderr,
        )
        return 1
    except Exception as exc:
        print(f"error: failed to load live graph: {exc}", file=sys.stderr)
        return 1

    collect: dict = {}
    drift = _diff_descriptors(declared, live, collect=collect)

    vinyl_ok = True
    vinyl_summary: dict | None = None
    if getattr(args, "profile", None) == "vinyl":
        from shared.vinyl_chain_verify import (
            format_report,
            verify_vinyl_chain,
        )

        print("\n── vinyl profile — broadcast chain verification ──")
        result = verify_vinyl_chain(live)
        print(format_report(result))
        vinyl_ok = result.ok
        vinyl_summary = {"ok": vinyl_ok}

    # L-12 invariant + TTS-broadcast-path check are also surfaced
    # in the structured report so the systemd timer's textfile
    # metrics gauge them without each one needing its own probe.
    l12_check = check_l12_forward_invariant(declared)
    tts_check = check_tts_broadcast_path(live)

    structured = _build_verify_report(
        descriptor_path=args.descriptor,
        declared=declared,
        live=live,
        drift_records=collect,
        live_matches_canonical=not drift,
        l12_check=l12_check,
        tts_check=tts_check,
        vinyl_summary=vinyl_summary,
        strict=bool(getattr(args, "strict", False)),
    )

    output_path = getattr(args, "output", None)
    if output_path:
        _write_verify_json(Path(output_path), structured)

    prom_path = getattr(args, "prometheus_textfile", None)
    if prom_path is None and output_path:
        prom_path = "/var/lib/node_exporter/textfile_collector/hapax_audio_topology.prom"
    if prom_path:
        _write_topology_prom(Path(prom_path), structured)

    if getattr(args, "json", False):
        import json

        print(json.dumps(structured, indent=2, sort_keys=True))

    if drift:
        print(
            "\nlive graph differs from descriptor — "
            "see diff above + rerun 'generate' if descriptor is authoritative."
        )
        return 2
    if not vinyl_ok:
        print("\nvinyl profile FAIL — see report above")
        return 2
    # L-12 + TTS-broadcast invariants influence exit code only under --strict
    # (the boot-time/periodic systemd timer). Outside --strict the existing
    # CLI semantics — only descriptor-vs-live drift gates exit code — are
    # preserved so test fixtures and operator ad-hoc invocations don't trip
    # on synthetic descriptors that legitimately omit the L-12 / TTS chain.
    if getattr(args, "strict", False) and not l12_check.ok:
        print("\nL-12 forward invariant FAIL — see report above")
        return 2
    if getattr(args, "strict", False) and not tts_check.ok:
        print("\nTTS broadcast path FAIL — see report above")
        return 2
    if getattr(args, "strict", False):
        # --strict tightens the success criteria: classified-only
        # diffs (M8 fallback, external HDMI, etc.) also count as
        # drift the operator should be informed about. They never
        # block — but the boot-time timer's exit code reflects them.
        classified_count = sum(
            len(structured["drift"].get(key, []))
            for key in (
                "classified_added_nodes",
                "classified_missing_nodes",
                "classified_added_edges",
                "classified_missing_edges",
            )
        )
        if classified_count > 0:
            print(
                f"\n--strict: {classified_count} classified-only change(s); "
                "see drift above (timer-only signal)."
            )
            # Classified-only drift returns 0 because operators have
            # explicitly classified those edges/nodes — the report is
            # still published for observability. Reserved 2 for true
            # unclassified drift above.
    print("live graph matches descriptor (no unclassified drift)")
    return 0


def _build_verify_report(
    *,
    descriptor_path: str,
    declared: TopologyDescriptor,
    live: TopologyDescriptor,
    drift_records: dict,
    live_matches_canonical: bool,
    l12_check,
    tts_check,
    vinyl_summary: dict | None,
    strict: bool,
) -> dict:
    """Assemble the structured drift report consumed by --json / --output."""
    import time as _time
    from datetime import UTC, datetime

    edge_count_by_classification: dict[str, int] = {}
    for key in (
        "classified_added_edges",
        "classified_missing_edges",
        "unclassified_added_edges",
        "unclassified_missing_edges",
    ):
        for record in drift_records.get(key, []):
            classification = (
                record.get("classification")
                if "classified" in key and "unclassified" not in key
                else "unclassified"
            )
            classification = classification or "unclassified"
            edge_count_by_classification[classification] = (
                edge_count_by_classification.get(classification, 0) + 1
            )

    return {
        "schema_version": 1,
        "generated_at": datetime.fromtimestamp(_time.time(), tz=UTC)
        .isoformat()
        .replace("+00:00", "Z"),
        "descriptor": descriptor_path,
        "declared_node_count": len(declared.nodes),
        "declared_edge_count": len(declared.edges),
        "live_node_count": len(live.nodes),
        "live_edge_count": len(live.edges),
        "live_matches_canonical": bool(live_matches_canonical),
        "strict": bool(strict),
        "l12_forward_invariant": {
            "ok": bool(l12_check.ok),
            "violations": [{"code": v.code, "message": v.message} for v in l12_check.violations],
        },
        "tts_broadcast_path": {
            "ok": bool(tts_check.ok),
            "missing_nodes": list(tts_check.missing_nodes),
            "missing_edges": list(tts_check.missing_edges),
        },
        "vinyl_profile": vinyl_summary,
        "drift": drift_records,
        "edge_count_by_classification": edge_count_by_classification,
    }


def _write_verify_json(path: Path, payload: dict) -> None:
    """Atomically publish the structured drift report."""
    import json

    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f"{path.name}.tmp")
    tmp.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    tmp.replace(path)


def _write_topology_prom(path: Path, payload: dict) -> None:
    """Render Prometheus textfile-collector metrics for the topology verify.

    Layout matches what node_exporter's textfile collector reads at
    ``/var/lib/node_exporter/textfile_collector/``. We avoid pulling
    ``prometheus_client`` into this script's hot path — the format is
    trivial and stable.

    Best-effort: if the textfile_collector directory is not writable
    (developer workstation without node_exporter installed), the failure
    is logged to stderr and the verify subcommand continues. The systemd
    timer carries the writable path; CI does not write the file.
    """
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
    except OSError as exc:
        print(
            f"prometheus textfile not writable: {exc} (skipping metrics)",
            file=sys.stderr,
        )
        return

    lines: list[str] = [
        "# HELP hapax_audio_topology_live_matches_canonical "
        "1 when live PipeWire graph matches the canonical descriptor with no unclassified drift",
        "# TYPE hapax_audio_topology_live_matches_canonical gauge",
        f"hapax_audio_topology_live_matches_canonical "
        f"{1 if payload.get('live_matches_canonical') else 0}",
        "# HELP hapax_audio_topology_drift_edge_count "
        "Count of drift edges (live - canonical), labelled by classification",
        "# TYPE hapax_audio_topology_drift_edge_count counter",
    ]
    edge_counts = payload.get("edge_count_by_classification", {})
    if not edge_counts:
        lines.append('hapax_audio_topology_drift_edge_count{classification="none"} 0')
    else:
        for classification, count in sorted(edge_counts.items()):
            safe = classification.replace('"', '\\"')
            lines.append(
                f'hapax_audio_topology_drift_edge_count{{classification="{safe}"}} {count}'
            )

    l12_violations = len(payload.get("l12_forward_invariant", {}).get("violations", []))
    lines.extend(
        [
            "# HELP hapax_audio_topology_l12_invariant_violations "
            "Count of static L-12 forward/private directionality violations",
            "# TYPE hapax_audio_topology_l12_invariant_violations gauge",
            f"hapax_audio_topology_l12_invariant_violations {l12_violations}",
        ]
    )

    tts_ok = 1 if payload.get("tts_broadcast_path", {}).get("ok") else 0
    lines.extend(
        [
            "# HELP hapax_audio_topology_tts_broadcast_path_ok "
            "1 when hapax-tts-duck → hapax-tts-broadcast-* → livestream tap path is intact",
            "# TYPE hapax_audio_topology_tts_broadcast_path_ok gauge",
            f"hapax_audio_topology_tts_broadcast_path_ok {tts_ok}",
        ]
    )

    # cc-task audio-audit-E-topology-prometheus-metrics (Auditor E, 2026-05-03):
    # surface declared / live edge accounting + present|missing|extra split so
    # Grafana can render drift trends and alert when live > declared (= unexpected
    # link, possible leak). Existing metrics above cover the classification axis;
    # these add the topology-as-set axis.
    declared_edges = int(payload.get("declared_edge_count", 0))
    drift = payload.get("drift", {}) or {}
    missing_count = sum(
        len(drift.get(key, []) or [])
        for key in ("classified_missing_edges", "unclassified_missing_edges")
    )
    extra_count = sum(
        len(drift.get(key, []) or [])
        for key in ("classified_added_edges", "unclassified_added_edges")
    )
    # Present = declared edges that ALSO appear live = declared - missing.
    # Clamp at 0 in the pathological case that the descriptor was tampered
    # mid-run and the math under-counts.
    present_count = max(0, declared_edges - missing_count)

    lines.extend(
        [
            "# HELP hapax_audio_topology_declared_links_total "
            "Count of edges in the canonical descriptor (config/audio-topology.yaml)",
            "# TYPE hapax_audio_topology_declared_links_total gauge",
            f"hapax_audio_topology_declared_links_total {declared_edges}",
            "# HELP hapax_audio_topology_live_links_total "
            "Live PipeWire edges grouped by state vs the canonical descriptor",
            "# TYPE hapax_audio_topology_live_links_total gauge",
            f'hapax_audio_topology_live_links_total{{state="present"}} {present_count}',
            f'hapax_audio_topology_live_links_total{{state="missing"}} {missing_count}',
            f'hapax_audio_topology_live_links_total{{state="extra"}} {extra_count}',
            "# HELP hapax_audio_topology_drift_total "
            "Total drift edges (missing + extra) at this verify tick",
            "# TYPE hapax_audio_topology_drift_total counter",
            f"hapax_audio_topology_drift_total {missing_count + extra_count}",
        ]
    )

    tmp = path.with_name(f"{path.name}.tmp")
    try:
        tmp.write_text("\n".join(lines) + "\n", encoding="utf-8")
        tmp.replace(path)
    except OSError as exc:
        print(
            f"prometheus textfile write failed: {exc} (skipping metrics)",
            file=sys.stderr,
        )


def cmd_audit(args: argparse.Namespace) -> int:
    """Print a full drift report between descriptor and live graph.

    Same logic as ``verify``, different framing for operator use — exit
    code always 0 so it can be piped into logs/ntfy without tripping
    CI.
    """
    declared = _load(args.descriptor)
    try:
        if args.dump_file:
            live = descriptor_from_dump_file(args.dump_file)
        else:
            live = descriptor_from_live()
    except Exception as exc:
        print(f"error: failed to load live graph: {exc}", file=sys.stderr)
        return 1

    print(f"# audit — descriptor={args.descriptor}")
    print(f"  declared nodes: {len(declared.nodes)}, edges: {len(declared.edges)}")
    print(f"  live nodes:     {len(live.nodes)}, edges: {len(live.edges)}")
    print()
    drift = _diff_descriptors(declared, live)
    if not drift:
        print("\naudit clean — no unclassified drift.")
    return 0


def cmd_tts_broadcast_check(args: argparse.Namespace) -> int:
    """Verify the live TTS loopback reaches the livestream tap."""
    try:
        if args.dump_file:
            live = descriptor_from_dump_file(args.dump_file)
        else:
            live = descriptor_from_live()
    except FileNotFoundError:
        print(
            f"error: pw-dump file not found: {args.dump_file}",
            file=sys.stderr,
        )
        return 1
    except Exception as exc:
        print(f"error: failed to load live graph: {exc}", file=sys.stderr)
        return 1

    result = check_tts_broadcast_path(live)
    print(result.format())
    return 0 if result.ok else 2


def cmd_l12_forward_check(args: argparse.Namespace) -> int:
    """Verify the static L-12 forward/private directionality contract."""
    descriptor = _load(args.descriptor)
    result = check_l12_forward_invariant(descriptor)
    print(result.format())
    return 0 if result.ok else 2


def cmd_l12_scene_check(args: argparse.Namespace) -> int:
    """Verify the live L-12 BROADCAST-V2 scene signal assertion."""
    descriptor = _load(args.descriptor)
    pcm = None
    if args.raw_pcm_file:
        try:
            pcm = Path(args.raw_pcm_file).read_bytes()
        except OSError as exc:
            print(f"error: failed to read raw PCM file: {exc}", file=sys.stderr)
            return 1
    result = check_l12_broadcast_scene_active(
        descriptor,
        duration_s=args.duration_s,
        pcm_int16=pcm,
    )
    print(result.format())
    return 0 if result.ok else 2


_DEFAULT_PIN_GLITCH_STATE_FILE = Path("/run/user/1000/hapax-pin-glitch-state.json")


def _load_pin_glitch_state(path: Path) -> dict:
    """Read the persisted pin-glitch detector state. Missing file → empty."""
    if not path.exists():
        return {}
    try:
        import json

        return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, ValueError):
        # Corrupt state file — start fresh rather than crash the timer.
        return {}


def _save_pin_glitch_state(path: Path, payload: dict) -> None:
    """Atomic-write detector state via tmp+rename."""
    import json

    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(payload, sort_keys=True) + "\n", encoding="utf-8")
    tmp.replace(path)


def cmd_pin_check(args: argparse.Namespace) -> int:
    """Single-shot pin-glitch detection with persisted silence-window state.

    Designed for systemd-timer invocation: each tick passes the live
    sink probe (state, has_active_input, RMS dB) as flags; this
    subcommand reconstructs the PinGlitchDetector with persisted
    silence_started_at so consecutive symptomatic ticks accumulate
    elapsed time toward the min_silence_s threshold.

    Probe inputs are flags rather than auto-discovered so the CLI is
    composable, testable, and free of pactl/pw-cat dependencies. A
    follow-on wrapper script (or the operator's hand) supplies the
    probe values from the live PipeWire graph.

    Exit codes:
      - 0 — sink healthy (no diagnostic)
      - 1 — PIN_GLITCH detected (auto-fix suppressed or failed)
      - 0 — PIN_GLITCH detected AND --auto-fix succeeded (recovery applied)

    With ``--auto-fix``, on PIN_GLITCH the watchdog recovery sequence
    runs and exit code is 0 if recovery succeeded, 1 otherwise.
    """
    from shared.audio_pin_glitch import (
        DIAGNOSTIC_PIN_GLITCH,
        PinGlitchDetector,
        SinkProbe,
    )

    state_path = Path(args.state_file) if args.state_file else _DEFAULT_PIN_GLITCH_STATE_FILE
    persisted = _load_pin_glitch_state(state_path)

    detector = PinGlitchDetector(
        silence_threshold_db=args.silence_threshold_db,
        min_silence_s=args.min_silence_s,
    )
    if persisted.get("silence_started_at") is not None:
        detector._silence_started_at = float(persisted["silence_started_at"])  # noqa: SLF001

    probe = SinkProbe(
        state=args.state,
        has_active_input=args.has_active_input,
        monitor_rms_db=args.rms_db,
    )
    result = detector.detect(probe)

    _save_pin_glitch_state(
        state_path,
        {"silence_started_at": detector.silence_started_at},
    )

    print(
        f"sink={args.sink} state={probe.state} "
        f"active_input={probe.has_active_input} rms_db={probe.monitor_rms_db:.2f} "
        f"elapsed_silent_s={result.elapsed_silent_s:.2f} "
        f"diagnostic={result.diagnostic or 'OK'}"
    )

    if result.diagnostic != DIAGNOSTIC_PIN_GLITCH:
        return 0

    if not args.auto_fix:
        print(f"PIN_GLITCH detected on {args.sink} (auto-fix disabled)", file=sys.stderr)
        return 1

    # Delegate to the existing watchdog recovery sequence.
    print("PIN_GLITCH detected — running auto-fix recovery", file=sys.stderr)
    fix_args = argparse.Namespace(
        card=args.card,
        profile=args.profile,
        dry_run=False,
    )
    fix_rc = cmd_watchdog(fix_args)
    if fix_rc != 0:
        print("auto-fix recovery FAILED", file=sys.stderr)
        return 1
    # Reset silence-window state after a successful recovery so the
    # next tick starts fresh (the symptom should be gone).
    _save_pin_glitch_state(state_path, {"silence_started_at": None})
    return 0


def cmd_watchdog(args: argparse.Namespace) -> int:
    """Run the Ryzen HDA codec pin-routing-stale recovery sequence.

    See ``reference_ryzen_codec_pin_glitch`` memory / research §5 of
    2026-04-20-unified-audio-architecture-design.md. The Ryzen codec's
    pin multiplexer silently desynchronises from PipeWire after a
    PipeWire restart that also enumerates a new USB audio device
    (operator report: S-4 plug-in 2026-04-20). ``pactl`` reports the
    sink as RUNNING and unmuted but physical output stays silent until
    the card profile is toggled off and back on.

    This subcommand runs the known-good recovery. Intentionally thin
    — no RMS monitoring yet (deferred to a proper watchdog loop).
    Operator invokes this when voice goes silent post-restart; CI
    doesn't run it.

    With ``--dry-run``, prints the pactl commands without executing.
    """
    card = args.card or "alsa_card.pci-0000_73_00.6"
    profile = args.profile or "output:analog-stereo"
    commands = [
        ["pactl", "set-card-profile", card, "off"],
        ["pactl", "set-card-profile", card, profile],
    ]
    if args.dry_run:
        for cmd in commands:
            print(" ".join(cmd))
        return 0

    import subprocess
    import time as _time

    for cmd in commands:
        print("$ " + " ".join(cmd))
        result = subprocess.run(cmd, capture_output=True, text=True, check=False)
        if result.returncode != 0:
            print(f"error: {result.stderr}", file=sys.stderr)
            return 1
        _time.sleep(0.2)  # let the codec settle between toggles
    print(f"pin-routing recovery applied to {card} → {profile}")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="hapax-audio-topology",
        description="Manage the declarative PipeWire audio topology descriptor.",
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_describe = sub.add_parser("describe", help="Summarise a descriptor.")
    p_describe.add_argument("descriptor")
    p_describe.set_defaults(func=cmd_describe)

    p_generate = sub.add_parser("generate", help="Generate PipeWire conf fragments.")
    p_generate.add_argument("descriptor")
    p_generate.add_argument(
        "--output-dir",
        help="Directory to write pipewire/<node>.conf files. "
        "If omitted, fragments print to stdout.",
    )
    p_generate.set_defaults(func=cmd_generate)

    p_diff = sub.add_parser("diff", help="Structural diff between two descriptors.")
    p_diff.add_argument("left")
    p_diff.add_argument("right")
    p_diff.set_defaults(func=cmd_diff)

    p_verify = sub.add_parser(
        "verify",
        help="Compare descriptor against the live PipeWire graph (or --dump-file).",
    )
    p_verify.add_argument("descriptor")
    p_verify.add_argument(
        "--dump-file",
        help="Saved pw-dump JSON path instead of invoking pw-dump live.",
    )
    p_verify.add_argument(
        "--profile",
        choices=("vinyl",),
        default=None,
        help=(
            "Additional profile-specific verification (D-24 §11.4). "
            "'vinyl' runs shared.vinyl_chain_verify.verify_vinyl_chain "
            "and fails the invocation on any ERROR-severity finding."
        ),
    )
    p_verify.add_argument(
        "--strict",
        action="store_true",
        help=(
            "Audit-A#5: tighten verify to also report on classified-only drift; "
            "the boot-time/periodic systemd timer uses this for textfile metrics."
        ),
    )
    p_verify.add_argument(
        "--json",
        action="store_true",
        help="Print the structured drift report as JSON to stdout.",
    )
    p_verify.add_argument(
        "--output",
        default=None,
        help=(
            "Write the structured drift report to this path (atomic tmp+rename). "
            "Default: not written."
        ),
    )
    p_verify.add_argument(
        "--prometheus-textfile",
        dest="prometheus_textfile",
        default=None,
        help=(
            "Path for Prometheus textfile-collector metrics. Defaults to "
            "/var/lib/node_exporter/textfile_collector/hapax_audio_topology.prom "
            "when --output is provided. Pass an explicit empty value to skip."
        ),
    )
    p_verify.set_defaults(func=cmd_verify)

    p_audit = sub.add_parser(
        "audit",
        help="Full drift report — same comparison as verify, exit 0 always.",
    )
    p_audit.add_argument("descriptor")
    p_audit.add_argument(
        "--dump-file",
        help="Saved pw-dump JSON path instead of invoking pw-dump live.",
    )
    p_audit.set_defaults(func=cmd_audit)

    p_tts_broadcast = sub.add_parser(
        "tts-broadcast-check",
        help="Verify hapax-tts-duck forwards through hapax-tts-broadcast-* to livestream tap.",
    )
    p_tts_broadcast.add_argument(
        "--dump-file",
        help="Saved pw-dump JSON path instead of invoking pw-dump live.",
    )
    p_tts_broadcast.set_defaults(func=cmd_tts_broadcast_check)

    p_l12_forward = sub.add_parser(
        "l12-forward-check",
        help=(
            "Static CI guard: verify L-12 producers have allowed forward "
            "paths and private routes cannot reach broadcast."
        ),
    )
    p_l12_forward.add_argument("descriptor")
    p_l12_forward.set_defaults(func=cmd_l12_forward_check)

    p_l12_scene = sub.add_parser(
        "l12-scene-check",
        help="Verify the live L-12 BROADCAST-V2 scene signal assertion.",
    )
    p_l12_scene.add_argument(
        "descriptor",
        nargs="?",
        default="config/audio-topology.yaml",
        help="Topology descriptor path (default: config/audio-topology.yaml).",
    )
    p_l12_scene.add_argument(
        "--duration-s",
        dest="duration_s",
        type=float,
        default=30.0,
        help="Capture duration for live parec probe; must be at least 30s.",
    )
    p_l12_scene.add_argument(
        "--raw-pcm-file",
        dest="raw_pcm_file",
        default=None,
        help=(
            "Read interleaved signed-16 14-channel PCM from this file instead "
            "of running parec. Intended for tests and captured evidence only."
        ),
    )
    p_l12_scene.set_defaults(func=cmd_l12_scene_check)

    p_watchdog = sub.add_parser(
        "watchdog",
        help=(
            "Run the Ryzen HDA codec pin-routing recovery "
            "(see reference_ryzen_codec_pin_glitch memory)."
        ),
    )
    p_watchdog.add_argument(
        "--card",
        help="ALSA card id to reset (default: alsa_card.pci-0000_73_00.6).",
    )
    p_watchdog.add_argument(
        "--profile",
        help="Profile to re-activate (default: output:analog-stereo).",
    )
    p_watchdog.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the pactl commands without executing.",
    )
    p_watchdog.set_defaults(func=cmd_watchdog)

    p_pin_check = sub.add_parser(
        "pin-check",
        help=(
            "Single-shot Ryzen pin-glitch detection (with persisted "
            "silence-window state for systemd-timer composition)."
        ),
    )
    p_pin_check.add_argument(
        "--sink",
        default="ryzen-analog-out",
        help="Sink id this probe describes (label only; default: ryzen-analog-out).",
    )
    p_pin_check.add_argument(
        "--state",
        choices=("RUNNING", "IDLE", "SUSPENDED"),
        required=True,
        help="Sink state from `pactl list sinks`.",
    )
    p_pin_check.add_argument(
        "--has-active-input",
        dest="has_active_input",
        action="store_true",
        help="Set when at least one sink-input is currently bound.",
    )
    p_pin_check.add_argument(
        "--no-active-input",
        dest="has_active_input",
        action="store_false",
        help="Set when no sink-input is bound (alternative to --has-active-input).",
    )
    p_pin_check.set_defaults(has_active_input=False)
    p_pin_check.add_argument(
        "--rms-db",
        dest="rms_db",
        type=float,
        required=True,
        help=(
            "Monitor port RMS in dBFS. Pass NaN or -inf to indicate "
            "no signal at all (treated as silent by the detector)."
        ),
    )
    p_pin_check.add_argument(
        "--silence-threshold-db",
        dest="silence_threshold_db",
        type=float,
        default=-50.0,
        help="RMS dBFS below which the sink is considered silent (default: -50).",
    )
    p_pin_check.add_argument(
        "--min-silence-s",
        dest="min_silence_s",
        type=float,
        default=5.0,
        help="Seconds of persistent silence before PIN_GLITCH fires (default: 5).",
    )
    p_pin_check.add_argument(
        "--state-file",
        dest="state_file",
        help=(
            "Path to the persisted silence-window state JSON. "
            "Defaults to /run/user/1000/hapax-pin-glitch-state.json."
        ),
    )
    p_pin_check.add_argument(
        "--auto-fix",
        dest="auto_fix",
        action="store_true",
        help=(
            "On PIN_GLITCH, invoke the watchdog recovery automatically. "
            "Exit 0 if recovery succeeds, 1 otherwise."
        ),
    )
    p_pin_check.add_argument(
        "--card",
        help="ALSA card id for --auto-fix (default: alsa_card.pci-0000_73_00.6).",
    )
    p_pin_check.add_argument(
        "--profile",
        help="Profile to re-activate for --auto-fix (default: output:analog-stereo).",
    )
    p_pin_check.set_defaults(func=cmd_pin_check)

    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
