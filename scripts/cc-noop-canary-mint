#!/usr/bin/env python3
"""cc-noop-canary-mint — mint the month's no-op canary cc-tasks.

Monthly idempotent per (month, platform tier). Normally ridden by the
cc-task-offer-ready reconcile tick; this CLI exists for manual runs and
backfill. See config/failure-taxonomy/noop-canaries.yaml.
"""

from __future__ import annotations

import argparse
import sys
from datetime import UTC, datetime
from pathlib import Path

_SCRIPTS = Path(__file__).resolve().parent
if str(_SCRIPTS) not in sys.path:
    sys.path.insert(0, str(_SCRIPTS))

from noop_canary.mint import mint_month  # noqa: E402
from noop_canary.reconcile import DEFAULT_REGISTRY, REPO_ROOT  # noqa: E402
from noop_canary.registry import load_registry  # noqa: E402

DEFAULT_VAULT = Path.home() / "Documents" / "Personal" / "20-projects" / "hapax-cc-tasks"


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--registry", type=Path, default=DEFAULT_REGISTRY)
    parser.add_argument("--repo-root", type=Path, default=REPO_ROOT)
    parser.add_argument("--vault-root", type=Path, default=DEFAULT_VAULT)
    parser.add_argument("--state", type=Path, default=None)
    parser.add_argument("--ledger", type=Path, default=None)
    parser.add_argument("--month", default=None, help="YYYY-MM (default: current)")
    parser.add_argument("--now", default=None, help="ISO timestamp override (testing)")
    args = parser.parse_args(argv)

    vault = args.vault_root.expanduser()
    now = args.now or datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%SZ")
    month = args.month or now[:7]
    state = args.state or vault / "_evidence" / "noop-canary" / "state.yaml"
    ledger = args.ledger or vault / "_evidence" / "failure-ledger" / "events.jsonl"

    result = mint_month(
        load_registry(args.registry.expanduser()),
        month=month,
        repo_root=args.repo_root.expanduser(),
        vault_root=vault,
        state_path=state,
        ledger_path=ledger,
        now=now,
    )
    print(
        f"cc-noop-canary-mint: {month} — minted {len(result.minted)}, "
        f"skipped {len(result.skipped)}, probe-errors {len(result.probe_errors)}"
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
