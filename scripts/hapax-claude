#!/usr/bin/env bash
# Launch Claude Code as a first-class Hapax coding interface.
#
# Lighter sibling of scripts/hapax-codex for the greek-named Claude
# lanes (alpha/beta/delta/epsilon). Three jobs:
#
#   1. Identity: set HAPAX_AGENT_INTERFACE=claude, HAPAX_AGENT_NAME=$role,
#      CLAUDE_ROLE=$role, HAPAX_WORKTREE_ROLE=$role.
#   2. Worktree: cd to the role's canonical worktree (alpha = primary
#      hapax-council/, others = hapax-council--$role/, with a couple of
#      legacy aliases honored).
#   3. Visibility: spawn a tmux session named hapax-claude-$role and
#      optionally a foot window with that class, so hapax-claude-send
#      can find the lane via either transport.
#
# We do NOT bake MCP server config into the spawn — Claude Code reads
# ~/.claude/settings.json + .claude.json itself. We do NOT hard-fail
# on a stale relay marker; the cleanup is the operator's call. We do
# refuse to relaunch a protected lane while it is already alive.

set -euo pipefail

usage() {
  cat <<'EOF'
usage: hapax-claude [--role alpha|…|theta | dev|dev2|…] [--cd DIR]
                    [--terminal none|tmux|foot] [--force] [--task TASK_ID|--readonly]
                    [--] [claude args...]

Roles:
  - greek alpha..theta : the supervised headless reform lanes
  - dev / dev2 / …     : interactive operator pool (visible sessions; see
                         hapax-dev). Operator-driven, so no cc-task binding is
                         required; defaults its worktree to the current dir.

Defaults:
  - role inferred from HAPAX_AGENT_NAME / CLAUDE_ROLE / cwd basename
  - worktree selected from the role when --cd is omitted
  - terminal=none: exec claude in the current terminal
  - terminal=tmux: detach into a tmux session named hapax-claude-<role>
  - terminal=foot: tmux + a foot window attached to the same session
EOF
}

ROLE=""
WORKDIR=""
TERMINAL="${HAPAX_CLAUDE_TERMINAL:-none}"
FORCE=0
CLAUDE_TASK="${HAPAX_METHODOLOGY_DISPATCH_TASK:-}"
READONLY=0
CLAUDE_EXTRA=()

while [ $# -gt 0 ]; do
  case "$1" in
    --role|--session|--name)
      ROLE="${2:-}"
      shift 2
      ;;
    --role=*|--session=*|--name=*)
      ROLE="${1#*=}"
      shift
      ;;
    --cd|-C)
      WORKDIR="${2:-}"
      shift 2
      ;;
    --cd=*)
      WORKDIR="${1#--cd=}"
      shift
      ;;
    --terminal)
      TERMINAL="${2:-}"
      shift 2
      ;;
    --terminal=*)
      TERMINAL="${1#--terminal=}"
      shift
      ;;
    --force)
      FORCE=1
      shift
      ;;
    --task)
      CLAUDE_TASK="${2:-}"
      shift 2
      ;;
    --task=*)
      CLAUDE_TASK="${1#--task=}"
      shift
      ;;
    --readonly|--read-only)
      READONLY=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      CLAUDE_EXTRA+=("$@")
      break
      ;;
    alpha|beta|gamma|delta|epsilon|zeta|eta|theta)
      if [ -z "$ROLE" ]; then
        ROLE="$1"
      else
        CLAUDE_EXTRA+=("$1")
      fi
      shift
      ;;
    *)
      CLAUDE_EXTRA+=("$1")
      shift
      ;;
  esac
done

if [ -z "$ROLE" ]; then
  ROLE="${HAPAX_AGENT_NAME:-${CLAUDE_ROLE:-${HAPAX_AGENT_ROLE:-}}}"
fi
if [ -z "$ROLE" ]; then
  case "$(basename "$PWD")" in
    hapax-council) ROLE="alpha" ;;
    hapax-council--beta*|*--main-red*) ROLE="beta" ;;
    hapax-council--delta*) ROLE="delta" ;;
    hapax-council--epsilon*) ROLE="epsilon" ;;
  esac
fi

# IS_DEV_POOL marks the non-greek interactive operator pool (dev, dev2, …).
# These lanes are distinct from the supervised headless greek fleet, so they
# never collide with a reform dispatch and are exempt from the mandatory
# cc-task binding below (the operator drives them in person).
IS_DEV_POOL=0
case "$ROLE" in
  alpha|beta|gamma|delta|epsilon|zeta|eta|theta) ;;
  dev|dev[0-9]*) IS_DEV_POOL=1 ;;
  *)
    echo "hapax-claude: invalid role '$ROLE' (expected alpha|beta|gamma|delta|epsilon|zeta|eta|theta, or interactive pool dev|dev2|…)" >&2
    exit 2
    ;;
esac

case "$TERMINAL" in
  none|tmux|foot) ;;
  *)
    echo "hapax-claude: invalid terminal '$TERMINAL'" >&2
    exit 2
    ;;
esac

claude_default_worktree() {
  local role="$1"
  local root="${HAPAX_CLAUDE_WORKTREE_ROOT:-$HOME/projects}"
  case "$role" in
    alpha) printf '%s\n' "$root/hapax-council" ;;
    beta)
      # Honor the legacy hapax-council--main-red alias when --beta worktree
      # is missing — beta's worktree has been renamed across the project's
      # lifetime and operator scripts still live in either.
      if [ -d "$root/hapax-council--beta" ]; then
        printf '%s\n' "$root/hapax-council--beta"
      elif [ -d "$root/hapax-council--main-red" ]; then
        printf '%s\n' "$root/hapax-council--main-red"
      else
        printf '%s\n' "$root/hapax-council--beta"
      fi
      ;;
    delta)
      if [ -d "$root/hapax-council--delta" ]; then
        printf '%s\n' "$root/hapax-council--delta"
      elif [ -d "$root/hapax-council--delta-omg" ]; then
        printf '%s\n' "$root/hapax-council--delta-omg"
      else
        printf '%s\n' "$root/hapax-council--delta"
      fi
      ;;
    epsilon) printf '%s\n' "$root/hapax-council--epsilon" ;;
    gamma|zeta|eta|theta) printf '%s\n' "$root/hapax-council--$role" ;;
    # Interactive dev pool has no fixed greek worktree. Default to the invoking
    # cwd — hapax-dev passes --cd explicitly; this is the standalone fallback.
    dev|dev[0-9]*) printf '%s\n' "$PWD" ;;
  esac
}

if [ -z "$WORKDIR" ]; then
  WORKDIR="$(claude_default_worktree "$ROLE")"
fi

if [ ! -d "$WORKDIR" ]; then
  echo "hapax-claude: worktree not found for role '$ROLE': $WORKDIR" >&2
  echo "  pass --cd <DIR> to override, or git worktree add it first" >&2
  exit 3
fi
WORKDIR="$(cd "$WORKDIR" && pwd)"

resume_session_id_is_safe() {
  python3 - "$1" <<'PYEOF'
import re
import sys

value = sys.argv[1]
tail = value.rsplit("-", 1)[-1]
safe = (
    8 <= len(value) <= 128
    and re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9._-]*", value) is not None
    and not value.isdigit()
    and not (tail.isdigit() and len(tail) <= 7)
)
raise SystemExit(0 if safe else 1)
PYEOF
}

RESUME_SESSION_UUID="${HAPAX_CLAIM_RESUME_SESSION_ID:-}"
if [ -n "$RESUME_SESSION_UUID" ]; then
  if ! resume_session_id_is_safe "$RESUME_SESSION_UUID"; then
    echo "hapax-claude: refusing unsafe resume-session identity" >&2
    exit 17
  fi
  SESSION_UUID="$RESUME_SESSION_UUID"
  CLAIM_RESUME=1
else
  SESSION_UUID="$(cat /proc/sys/kernel/random/uuid 2>/dev/null \
    || uuidgen 2>/dev/null \
    || python3 -c 'import uuid; print(uuid.uuid4())' 2>/dev/null \
    || printf 'sid%sx%s%s' "$(date +%s%N)" "$RANDOM" "$RANDOM")"
  CLAIM_RESUME=0
fi
export HAPAX_AGENT_INTERFACE="claude"
export HAPAX_AGENT_NAME="$ROLE"
export CLAUDE_ROLE="$ROLE"
export HAPAX_AGENT_ROLE="$ROLE"
export HAPAX_WORKTREE_ROLE="$ROLE"
export HAPAX_SESSION_ID="$SESSION_UUID"
mkdir -p "$HOME/.cache/hapax" 2>/dev/null || true
printf '%s\n' "$ROLE" >"$HOME/.cache/hapax/session-role-$SESSION_UUID" 2>/dev/null || true
export HAPAX_IDLE_UPDATE_SECONDS="${HAPAX_IDLE_UPDATE_SECONDS:-270}"

SOURCE_ACTIVATION_WORKTREE="${HAPAX_SOURCE_ACTIVATION_WORKTREE:-$HOME/.cache/hapax/source-activation/worktree}"
SOURCE_ACTIVATION_RECEIPT="${HAPAX_SOURCE_ACTIVATION_RECEIPT:-$HOME/.cache/hapax/source-activation/current.json}"
CC_CLAIM="$SOURCE_ACTIVATION_WORKTREE/scripts/cc-claim"
CC_CLAIM_PROTOCOL_VERSION="hapax-claim-dispatch-v1"
CC_CLAIM_PROTOCOL_CHECKED=0

require_checked_cc_claim() {
  local observed=""
  if [ "$CC_CLAIM_PROTOCOL_CHECKED" -eq 1 ]; then
    return 0
  fi
  if ! python3 - "$SOURCE_ACTIVATION_WORKTREE" "$SOURCE_ACTIVATION_RECEIPT" <<'PYEOF'
import json
import os
import re
import stat
import subprocess
import sys
from pathlib import Path

try:
    target = Path(sys.argv[1]).resolve(strict=True)
    receipt_path = Path(sys.argv[2])
    receipt_metadata = receipt_path.lstat()
    if stat.S_ISLNK(receipt_metadata.st_mode) or not stat.S_ISREG(receipt_metadata.st_mode):
        raise ValueError("activation receipt is not a regular file")
    receipt = json.loads(receipt_path.read_text(encoding="utf-8"))
    head = receipt["active_source_head"]
    if not isinstance(head, str) or not re.fullmatch(r"[0-9a-f]{40}", head):
        raise ValueError("malformed activation head")
    if target != Path(receipt["active_source_target"]).resolve(strict=True):
        raise ValueError("activation target mismatch")
    last_success_path = receipt_path.parent / "last-success-sha"
    last_success_metadata = last_success_path.lstat()
    if stat.S_ISLNK(last_success_metadata.st_mode) or not stat.S_ISREG(last_success_metadata.st_mode):
        raise ValueError("last-success-sha is not a regular file")
    last_success = last_success_path.read_text(encoding="ascii").strip()
    if last_success != head or target.name != head:
        raise ValueError("activation release identity mismatch")
    observed = subprocess.run(["git", "-C", str(target), "rev-parse", "HEAD"], check=True, capture_output=True, text=True).stdout.strip()
    shared_kind = subprocess.run(["git", "-C", str(target), "cat-file", "-t", f"{head}:shared"], check=True, capture_output=True, text=True).stdout.strip()
    surface_status = subprocess.run(["git", "-C", str(target), "status", "--porcelain=v1", "--untracked-files=all", "--", "scripts/cc-claim", "shared"], check=True, capture_output=True, text=True).stdout
    claim = target / "scripts" / "cc-claim"
    metadata = claim.lstat()
    tracked = subprocess.run(["git", "-C", str(target), "rev-parse", f"{head}:scripts/cc-claim"], check=True, capture_output=True, text=True).stdout.strip()
    actual = subprocess.run(["git", "-C", str(target), "hash-object", str(claim)], check=True, capture_output=True, text=True).stdout.strip()
    if observed != head or tracked != actual or shared_kind != "tree" or surface_status:
        raise ValueError("activated implementation identity mismatch")
    if stat.S_ISLNK(metadata.st_mode) or not stat.S_ISREG(metadata.st_mode) or not os.access(claim, os.X_OK):
        raise ValueError("activated cc-claim is not a regular executable")
except (KeyError, OSError, ValueError, json.JSONDecodeError, subprocess.SubprocessError) as exc:
    print(f"{type(exc).__name__}: {exc}", file=sys.stderr)
    raise SystemExit(1)
PYEOF
  then
    echo "hapax-claude: refusing unverified source-activation cc-claim at $CC_CLAIM" >&2
    exit 14
  fi
  if ! observed="$(cd "$WORKDIR" && "$CC_CLAIM" --dispatch-protocol-version)"; then
    echo "hapax-claude: activated cc-claim protocol probe failed at $CC_CLAIM" >&2
    exit 14
  fi
  if [ "$observed" != "$CC_CLAIM_PROTOCOL_VERSION" ]; then
    echo "hapax-claude: refusing activated cc-claim with unsupported protocol at $CC_CLAIM (expected $CC_CLAIM_PROTOCOL_VERSION, got ${observed:-<empty>})" >&2
    exit 14
  fi
  CC_CLAIM_PROTOCOL_CHECKED=1
}

verify_dispatch_binding_if_required() {
  local task="$1"
  [ -n "${HAPAX_CLAIM_DISPATCH_MESSAGE_ID:-}" ] || return 0
  require_checked_cc_claim
  if ! (cd "$WORKDIR" && "$CC_CLAIM" --verify-dispatch-binding "$task"); then
    echo "hapax-claude: refusing task '$task'; exact dispatch binding verification failed" >&2
    exit 18
  fi
}

session_is_protected() {
  local role="$1"
  local protection_file="${HAPAX_SESSION_PROTECTION_FILE:-$HOME/.cache/hapax/relay/session-protection.md}"
  [ -f "$protection_file" ] || return 1
  awk -v role="$role" '
    {
      line = tolower($0)
      needle = "`" role "`"
      if (index($0, needle) && line ~ /protected/) found = 1
    }
    END { exit(found ? 0 : 1) }
  ' "$protection_file"
}

live_claude_session_exists() {
  local role="$1"
  local class="hapax-claude-$role"
  local tmux_name="hapax-claude-$role"
  if command -v hyprctl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    if hyprctl clients -j 2>/dev/null \
      | jq -e --arg class "$class" 'any(.[]?; .class == $class)' >/dev/null 2>&1; then
      return 0
    fi
  fi
  if command -v tmux >/dev/null 2>&1 && tmux has-session -t "$tmux_name" 2>/dev/null; then
    return 0
  fi
  return 1
}

if [ "$FORCE" -ne 1 ] && [ "$TERMINAL" != "none" ]; then
  if session_is_protected "$ROLE" && live_claude_session_exists "$ROLE"; then
    echo "hapax-claude: refusing to relaunch protected live role '$ROLE' (pass --force to override)" >&2
    exit 12
  fi
fi

CLAUDE_BIN="$(command -v claude || true)"
if [ -z "$CLAUDE_BIN" ]; then
  echo "hapax-claude: claude not found in PATH" >&2
  exit 4
fi
export PATH="$WORKDIR/scripts:$PATH"

# Operator default: spawn lanes at max effort with permission prompts
# bypassed. Override per-spawn via env: HAPAX_CLAUDE_EFFORT=xhigh,
# HAPAX_CLAUDE_SKIP_PERMS=0. Anything passed after `--` wins over the
# defaults because the user-supplied args trail CLAUDE_DEFAULT_ARGS.
if [ "$READONLY" -eq 1 ] && [ -z "${HAPAX_CLAUDE_SKIP_PERMS+x}" ]; then
  HAPAX_CLAUDE_SKIP_PERMS=0
fi
CLAUDE_DEFAULT_ARGS=()
CLAUDE_EFFORT="${HAPAX_CLAUDE_EFFORT:-max}"
case "$CLAUDE_EFFORT" in
  low|medium|high|xhigh|max)
    CLAUDE_DEFAULT_ARGS+=("--effort" "$CLAUDE_EFFORT")
    ;;
  '') ;;  # explicit opt-out — caller passed empty
  *)
    echo "hapax-claude: invalid HAPAX_CLAUDE_EFFORT '$CLAUDE_EFFORT'" >&2
    exit 2
    ;;
esac
if [ "${HAPAX_CLAUDE_SKIP_PERMS:-1}" = "1" ]; then
  CLAUDE_DEFAULT_ARGS+=("--dangerously-skip-permissions")
fi

TMUX_NAME="hapax-claude-$ROLE"

if [ "$TERMINAL" != "none" ]; then
  TMUX_BIN="$(command -v tmux || true)"
  if [ -z "$TMUX_BIN" ]; then
    echo "hapax-claude: tmux not found; --terminal=$TERMINAL requires tmux" >&2
    exit 10
  fi
  if "$TMUX_BIN" has-session -t "$TMUX_NAME" 2>/dev/null && [ "$FORCE" -ne 1 ]; then
    echo "hapax-claude: tmux session already exists: $TMUX_NAME (pass --force to recreate)" >&2
    exit 11
  fi
fi

SESSION_CLAIM_FILE="$HOME/.cache/hapax/cc-active-task-$ROLE-$SESSION_UUID"
CLAIM_FILE="$HOME/.cache/hapax/cc-active-task-$ROLE"
CLAIMED_TASK=""
SESSION_CLAIMED_TASK=""
LEGACY_CLAIMED_TASK=""
[ ! -s "$SESSION_CLAIM_FILE" ] || SESSION_CLAIMED_TASK="$(head -n1 "$SESSION_CLAIM_FILE" | tr -d '[:space:]')"
[ ! -s "$CLAIM_FILE" ] || LEGACY_CLAIMED_TASK="$(head -n1 "$CLAIM_FILE" | tr -d '[:space:]')"
if [ -n "$SESSION_CLAIMED_TASK" ] || [ -n "$LEGACY_CLAIMED_TASK" ]; then
  if [ -z "$SESSION_CLAIMED_TASK" ] || [ -z "$LEGACY_CLAIMED_TASK" ] ||
     [ "$SESSION_CLAIMED_TASK" != "$LEGACY_CLAIMED_TASK" ]; then
    echo "hapax-claude: refusing incomplete or divergent role/session claim projection for '$ROLE'" >&2
    exit 16
  fi
  CLAIMED_TASK="$SESSION_CLAIMED_TASK"
fi
if [ -z "$CLAUDE_TASK" ] && [ -n "$CLAIMED_TASK" ]; then
  CLAUDE_TASK="$CLAIMED_TASK"
fi
if [ -n "${HAPAX_CLAIM_DISPATCH_MESSAGE_ID:-}" ] && [ -z "$CLAUDE_TASK" ]; then
  echo "hapax-claude: refusing dispatch binding without an exact task id" >&2
  exit 15
fi
if [ "$READONLY" -ne 1 ]; then
  if [ -n "$CLAUDE_TASK" ]; then
    if [ -n "$CLAIMED_TASK" ] && [ "$CLAIMED_TASK" != "$CLAUDE_TASK" ]; then
      echo "hapax-claude: refusing mutating launch; role '$ROLE' already claims '$CLAIMED_TASK', not dispatch task '$CLAUDE_TASK'" >&2
      echo "  Close or resolve the existing claim before launching a new visible lane." >&2
      exit 13
    fi
    export HAPAX_METHODOLOGY_DISPATCH_TASK="$CLAUDE_TASK"
    if [ -z "$CLAIMED_TASK" ] && [ "$CLAIM_RESUME" -eq 1 ]; then
      echo "hapax-claude: resume requires an existing exact-session claim for '$ROLE'" >&2
      exit 17
    elif [ -z "$CLAIMED_TASK" ]; then
      require_checked_cc_claim
      (cd "$WORKDIR" && "$CC_CLAIM" "$CLAUDE_TASK")
      if [ ! -s "$SESSION_CLAIM_FILE" ] || [ ! -s "$CLAIM_FILE" ] ||
         [ "$(head -n1 "$SESSION_CLAIM_FILE" | tr -d '[:space:]')" != "$CLAUDE_TASK" ] ||
         [ "$(head -n1 "$CLAIM_FILE" | tr -d '[:space:]')" != "$CLAUDE_TASK" ]; then
        echo "hapax-claude: refusing launch; cc-claim did not publish one exact role/session projection" >&2
        exit 17
      fi
      CLAIMED_TASK="$CLAUDE_TASK"
    fi
    verify_dispatch_binding_if_required "$CLAUDE_TASK"
  elif [ "$IS_DEV_POOL" -eq 1 ]; then
    : # interactive operator dev pool — operator-driven, governed by operator
      # presence; a visible dev lane needs no cc-task binding to launch.
  else
    cat >&2 <<EOF
hapax-claude: refusing mutating visible lane without governed task binding.

  Visible Claude lanes must be launched with --task <cc-task-id> from
  hapax-methodology-dispatch, or with an existing active claim for this role.

  For inspection only, pass --readonly. Read-only mode does not add
  --dangerously-skip-permissions by default.
EOF
    exit 13
  fi
elif [ -n "$CLAUDE_TASK" ]; then
  export HAPAX_METHODOLOGY_DISPATCH_TASK="$CLAUDE_TASK"
  verify_dispatch_binding_if_required "$CLAUDE_TASK"
fi

RELAY_RETIRE="$WORKDIR/scripts/hapax-relay-retire"

if [ "$TERMINAL" = "none" ]; then
  trap '"$RELAY_RETIRE" "$ROLE" --reason "clean exit (terminal=none)" 2>/dev/null || true' EXIT
  cd "$WORKDIR"
  exec "$CLAUDE_BIN" "${CLAUDE_DEFAULT_ARGS[@]}" "${CLAUDE_EXTRA[@]}"
fi

# tmux/foot path: pin governed identity and dispatch state into a runner so
# worker startup does not depend on a tmux server's inherited environment.
SPAWN_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/hapax/claude-spawns"
mkdir -p "$SPAWN_DIR"
RUNNER="$SPAWN_DIR/run-$(date -u +%Y%m%dT%H%M%SZ)-$ROLE.sh"
{
  printf '%s\n' '#!/usr/bin/env bash'
  printf '%s\n' 'set -euo pipefail'
  printf 'trap '\''%q %q --reason "clean exit (tmux)" 2>/dev/null || true'\'' EXIT\n' "$RELAY_RETIRE" "$ROLE"
  printf 'cd %q\n' "$WORKDIR"
  printf 'export HAPAX_AGENT_INTERFACE=claude\n'
  printf 'export HAPAX_AGENT_NAME=%q\n' "$ROLE"
  printf 'export CLAUDE_ROLE=%q\n' "$ROLE"
  printf 'export HAPAX_AGENT_ROLE=%q\n' "$ROLE"
  printf 'export HAPAX_WORKTREE_ROLE=%q\n' "$ROLE"
  printf 'export HAPAX_SESSION_ID=%q\n' "$SESSION_UUID"
  printf 'export HAPAX_IDLE_UPDATE_SECONDS=%q\n' "$HAPAX_IDLE_UPDATE_SECONDS"
  # $PATH expands when the generated runner starts.
  # shellcheck disable=SC2016
  printf 'export PATH=%q:$PATH\n' "$WORKDIR/scripts"
  if [ -n "$CLAUDE_TASK" ]; then
    printf 'export HAPAX_METHODOLOGY_DISPATCH_TASK=%q\n' "$CLAUDE_TASK"
  fi
  for env_name in \
    HAPAX_METHODOLOGY_DISPATCH_MESSAGE_ID \
    HAPAX_DISPATCH_CLAIM_SWEEP \
    HAPAX_CLAIM_LEASE_TTL_SECS \
    HAPAX_CLAIM_DISPATCH_MESSAGE_ID \
    HAPAX_CLAIM_DISPATCH_BINDING_HASH \
    HAPAX_CLAIM_DISPATCH_PLATFORM \
    HAPAX_CLAIM_DISPATCH_MODE \
    HAPAX_CLAIM_DISPATCH_PROFILE \
    HAPAX_CLAIM_DISPATCH_AUTHORITY_CASE \
    HAPAX_CLAIM_DISPATCH_IDEMPOTENCY_KEY \
    HAPAX_CLAIM_DISPATCH_TASK_PATH \
    HAPAX_CLAIM_DISPATCH_TASK_SHA256 \
    HAPAX_CLAIM_DISPATCH_PARENT_SPEC \
    HAPAX_CLAIM_DISPATCH_PARENT_SPEC_SHA256 \
    HAPAX_CLAIM_DISPATCH_LANE_SESSION \
    HAPAX_CLAIM_DISPATCH_LANE_GENERATION \
    HAPAX_CLAIM_DISPATCH_LANE_PID \
    HAPAX_CLAIM_DISPATCH_LANE_PID_GENERATION \
    HAPAX_CLAIM_DISPATCH_CLAIM_PROJECTION_SHA256 \
    HAPAX_CLAIM_DISPATCH_RELAY_PROJECTION_SHA256
  do
    if [[ -v "$env_name" ]]; then
      printf 'export %s=%q\n' "$env_name" "${!env_name}"
    fi
  done
  printf 'exec %q' "$CLAUDE_BIN"
  for arg in "${CLAUDE_DEFAULT_ARGS[@]}"; do
    printf ' %q' "$arg"
  done
  for arg in "${CLAUDE_EXTRA[@]}"; do
    printf ' %q' "$arg"
  done
  printf '\n'
} >"$RUNNER"
chmod 700 "$RUNNER"

case "$TERMINAL" in
  tmux)
    "$TMUX_BIN" new-session -d -s "$TMUX_NAME" -c "$WORKDIR" "$RUNNER"
    printf '%s\n' "$TMUX_NAME"
    ;;
  foot)
    FOOT_BIN="$(command -v footclient || command -v foot || true)"
    if [ -z "$FOOT_BIN" ]; then
      echo "hapax-claude: footclient/foot not found" >&2
      exit 10
    fi
    if ! "$TMUX_BIN" has-session -t "$TMUX_NAME" 2>/dev/null; then
      "$TMUX_BIN" new-session -d -s "$TMUX_NAME" -c "$WORKDIR" "$RUNNER"
    fi
    case "$(basename "$FOOT_BIN")" in
      footclient)
        "$FOOT_BIN" -E -N \
          --app-id "hapax-claude-$ROLE" \
          --title "$ROLE" \
          --working-directory "$WORKDIR" \
          "$TMUX_BIN" attach-session -t "$TMUX_NAME"
        ;;
      *)
        setsid -f "$FOOT_BIN" \
          --app-id "hapax-claude-$ROLE" \
          --title "$ROLE" \
          --working-directory "$WORKDIR" \
          "$TMUX_BIN" attach-session -t "$TMUX_NAME" >/dev/null 2>&1
        ;;
    esac
    ;;
esac
