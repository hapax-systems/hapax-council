#!/usr/bin/env bash
# Launch Antigravity CLI (agy) as a Hapax audited full-worker lane.
#
# Antigravity CLI is Google's Go-based terminal agent (successor to Gemini CLI).
# It runs in tmux sessions with Claude Opus or Gemini models.
#
# This launcher:
#   - Resolves/creates the antigrav worktree
#   - Refreshes per-worktree AGENTS.md
#   - Optionally pre-stages a task-assignment inflection
#   - Optionally runs cc-claim
#   - Launches agy in a tmux session
#
# Usage:
#   hapax-antigrav                                # open antigrav worktree in Antigravity
#   hapax-antigrav --task <cc-task-id>            # claim task + open IDE
#   hapax-antigrav --task <id> --inflection FILE  # pre-stage assignment file
#   hapax-antigrav --workdir /path                # explicit cwd

set -euo pipefail

COUNCIL_DIR="${HAPAX_COUNCIL_DIR:-$HOME/projects/hapax-council}"
WORKTREE_ROOT="${HAPAX_VIBE_WORKTREE_ROOT:-$HOME/projects}"
RELAY_DIR="$HOME/.cache/hapax/relay"
SPAWN_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/hapax/antigrav-spawns"
mkdir -p "$SPAWN_DIR"

usage() {
  cat <<'EOF'
usage: hapax-antigrav [--session antigrav] [--task TASK_ID] [--cd DIR]
                      [--inflection FILE] [--no-claim] [--no-open]
                      [--] [antigravity args...]

Launches Google Antigravity IDE on the Hapax antigrav worktree, with
identity envvars wired and (optionally) cc-claim run.

Antigrav is an audited full-worker lane. Onboarding:
  ~/.cache/hapax/relay/onboarding-antigrav.md

Examples:
  hapax-antigrav                          # just open the worktree
  hapax-antigrav --task add-tests-foo     # claim + open
  hapax-antigrav --no-open                # provision worktree only, don't launch IDE

Environment exports:
  HAPAX_AGENT_INTERFACE=antigravity
  HAPAX_AGENT_NAME=antigrav
  HAPAX_AGENT_SLOT=antigrav
EOF
}

SESSION="antigrav"
TASK_ID=""
WORKDIR=""
WORKDIR_EXPLICIT=0
INFLECTION_FILE=""
CLAIM_TASK=1
OPEN_IDE=1
ANTIGRAV_EXTRA=()

while [ $# -gt 0 ]; do
  case "$1" in
    --session|--name|--lane)
      SESSION="${2:-}"; shift 2 ;;
    --session=*|--name=*|--lane=*)
      SESSION="${1#*=}"; shift ;;
    --task)
      TASK_ID="${2:-}"; shift 2 ;;
    --task=*)
      TASK_ID="${1#--task=}"; shift ;;
    --cd|-C|--workdir)
      WORKDIR="${2:-}"; WORKDIR_EXPLICIT=1; shift 2 ;;
    --cd=*|--workdir=*)
      WORKDIR="${1#*=}"; WORKDIR_EXPLICIT=1; shift ;;
    --inflection)
      INFLECTION_FILE="${2:-}"; shift 2 ;;
    --inflection=*)
      INFLECTION_FILE="${1#--inflection=}"; shift ;;
    --no-claim)
      CLAIM_TASK=0; shift ;;
    --no-open)
      OPEN_IDE=0; shift ;;
    --help|-h)
      usage; exit 0 ;;
    --)
      shift; ANTIGRAV_EXTRA+=("$@"); break ;;
    *)
      ANTIGRAV_EXTRA+=("$1"); shift ;;
  esac
done

if ! [[ "$SESSION" =~ ^antigrav(-[a-z0-9-]+)?$|^antigravity$ ]]; then
  echo "hapax-antigrav: invalid session '$SESSION' (expected antigrav or antigrav-*)" >&2
  exit 2
fi

# Map legacy 'antigravity' to 'antigrav' for relay/claim consistency.
if [ "$SESSION" = "antigravity" ]; then
  echo "hapax-antigrav: normalizing legacy 'antigravity' → 'antigrav' for relay/claim" >&2
  SESSION="antigrav"
fi

ANTIGRAV_BIN="$(command -v agy || true)"
if [ -z "$ANTIGRAV_BIN" ]; then
  echo "hapax-antigrav: agy binary not found (install: curl -fsSL https://antigravity.google/cli/install.sh | bash)" >&2
  exit 4
fi

# ---- worktree ------------------------------------------------------------

if [ -z "$WORKDIR" ]; then
  WORKDIR="$WORKTREE_ROOT/hapax-council--$SESSION"
fi

ensure_worktree() {
  local target="$1"
  local base_ref="${HAPAX_ANTIGRAV_WORKTREE_BASE:-main}"
  local branch="${HAPAX_ANTIGRAV_BRANCH_PREFIX:-antigrav}/scratch"

  [ ! -d "$target" ] || return 0
  git -C "$COUNCIL_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
    echo "hapax-antigrav: $COUNCIL_DIR is not a git worktree" >&2
    return 1
  }
  mkdir -p "$(dirname "$target")"

  if git -C "$COUNCIL_DIR" rev-parse --verify --quiet "origin/$base_ref" >/dev/null; then
    base_ref="origin/$base_ref"
  elif ! git -C "$COUNCIL_DIR" rev-parse --verify --quiet "$base_ref" >/dev/null; then
    base_ref="HEAD"
  fi

  if git -C "$COUNCIL_DIR" show-ref --verify --quiet "refs/heads/$branch"; then
    git -C "$COUNCIL_DIR" worktree add "$target" "$branch" >/dev/null
  else
    git -C "$COUNCIL_DIR" worktree add -b "$branch" "$target" "$base_ref" >/dev/null
  fi
  echo "hapax-antigrav: created worktree $target on $branch (from $base_ref)" >&2
}

if [ ! -d "$WORKDIR" ]; then
  if [ "$WORKDIR_EXPLICIT" -eq 1 ]; then
    echo "hapax-antigrav: --cd '$WORKDIR' does not exist" >&2
    exit 3
  fi
  if ! ensure_worktree "$WORKDIR"; then
    echo "hapax-antigrav: could not create worktree at $WORKDIR" >&2
    exit 3
  fi
fi
WORKDIR="$(cd "$WORKDIR" && pwd)"

# ---- per-worktree AGENTS.md (managed) -------------------------------------

WORKTREE_AGENTS="$WORKDIR/AGENTS.md"
if [ ! -f "$WORKTREE_AGENTS" ] || head -1 "$WORKTREE_AGENTS" 2>/dev/null | grep -qF '<!-- HAPAX-ANTIGRAV-MANAGED'; then
  cat > "$WORKTREE_AGENTS" <<EOF_AGENTS
<!-- HAPAX-ANTIGRAV-MANAGED: regenerated on every hapax-antigrav launch. Do not hand-edit. -->

# Hapax Antigrav Lane — $SESSION

You are running inside Antigravity IDE with the latest Opus model and thinking
enabled as the **$SESSION** lane in the Hapax quad+ relay protocol.
Your tier is **audited full worker**: broad cc-task pickup is allowed and
Claude Code/Codex audit later is expected.

## Your identity

- Lane: \`$SESSION\`
- Worktree: \`$WORKDIR\`
- Interface: \`antigravity\`
- Model: \`opus-latest-thinking\`

## Where to read first

1. \`~/.cache/hapax/relay/onboarding-antigrav.md\` — full lane onboarding (READ FIRST)
2. \`~/.cache/hapax/relay/PROTOCOL.md\` — quad+ relay protocol spec
3. \`~/projects/CLAUDE.md\` — workspace governance
4. \`~/projects/hapax-council/CLAUDE.md\` — council architecture (the audio invariants section is mandatory)

## Active task (if any)

\$(cat ~/.cache/hapax/cc-active-task-$SESSION 2>/dev/null \\
  || cat ~/.cache/hapax/cc-active-task-antigravity 2>/dev/null \\
  || echo "no active task — wait for alpha-to-antigrav inflection or operator dispatch")

## Recent inflections

\$(ls -t ~/.cache/hapax/relay/alpha-to-antigrav-*.yaml \\
        ~/.cache/hapax/relay/alpha-to-antigravity-*.yaml 2>/dev/null | head -3)

## Scope

All cc-task surfaces are in scope, including governance, audio, director,
privacy, CODEOWNERS, refusal briefs, and instruction files. Treat sensitive
surfaces as higher-audit work: cite the governing invariant, keep edits narrow,
run focused verification, and document residual risk in the PR.

## Hard rules (operator standing directives)

- Never stall — revert acceptable. 2 attempts + revert + relay note > stall.
- If no explicit task is assigned, wait for operator or alpha dispatch. Do not self-claim from the WSJF queue.
- Always PR; never merge your own. Co-author trailer required.
- No \`git stash pop\`, no force-push.
- While idle or blocked, use the coordination timer to check queue/relay and leave status.
- Do not self-assign RTE; accept it only if the operator or active train protocol explicitly assigns it.

## On exit

1. Final status to \`~/.cache/hapax/relay/$SESSION.yaml\` (and legacy \`antigravity.yaml\` for compat)
2. PR opened or task moved back to offered with reason
3. Print PR URL to relay so alpha can find it
EOF_AGENTS
  echo "hapax-antigrav: refreshed $WORKTREE_AGENTS" >&2
fi

# Antigravity reads workspace rules from .agent/rules/. The normal council
# AGENTS.md is Codex-oriented, so keep an Antigravity-specific rule beside it
# without clobbering the repo's cross-tool AGENTS.md.
RULE_DIR="$WORKDIR/.agent/rules"
RULE_PATH="$RULE_DIR/hapax-antigrav-lane.md"
mkdir -p "$RULE_DIR"
cat > "$RULE_PATH" <<EOF_RULE
# Hapax Antigrav Lane Rule

Use the latest Opus model with thinking enabled in Antigravity.

You are \`$SESSION\`, an audited full-worker implementation lane. Work in:

\`$WORKDIR\`

Read first every session:

1. \`~/.cache/hapax/relay/onboarding-antigrav.md\`
2. \`~/.cache/hapax/relay/PROTOCOL.md\`
3. \`~/projects/CLAUDE.md\`
4. \`~/projects/hapax-council/CLAUDE.md\`

Active task pointer:

\`\`\`
$(cat "$HOME/.cache/hapax/cc-active-task-$SESSION" "$HOME/.cache/hapax/cc-active-task-antigravity" 2>/dev/null || echo "none")
\`\`\`

Recent alpha-to-antigrav inflections:

\`\`\`
$(find "$RELAY_DIR" -maxdepth 1 \( -name 'alpha-to-antigrav-*.yaml' -o -name 'alpha-to-antigravity-*.yaml' \) -printf '%f %p\n' 2>/dev/null | sed -nE 's/^alpha-to-antigrav(ity)?-([0-9]{8}T[0-9]+Z)[^ ]* (.*)$/\2 \3/p' | sort -r | cut -d' ' -f2- | head -5)
\`\`\`

Recent codex/antigrav transfer notes:

\`\`\`
$(find "$RELAY_DIR" -maxdepth 1 \( -name 'codex-to-antigrav-*.md' -o -name 'codex-antigrav-transfer-*.md' -o -name 'codex-hn-readiness-antigrav-transfer-*.md' \) -printf '%f %p\n' 2>/dev/null | sed -nE 's/^.*-([0-9]{8}T[0-9]+Z).* (.*)$/\1 \2/p' | sort -r | cut -d' ' -f2- | head -7)
\`\`\`

Operational contract:

- Accept explicit operator/alpha tasking only. If no task or inflection is waiting, remain idle and write a relay status indicating readiness. Do not self-claim from the WSJF queue.
- If an active task pointer or alpha-to-antigrav inflection is present, treat it as explicit tasking.
- Latest operator/alpha inflection controls sequencing. A handoff can be mandatory context or standing strictures without being the first execution path.
- Start by reading the active cc-task, latest alpha-to-antigrav inflection, relay status, and branch state.
- Code edits, tests, commits, and PRs are allowed only inside assigned scope.
- Always PR; never merge your own PR.
- When directed to clean up or continue outstanding workstreams, bring them to natural completion: verified and PR'd/mergeable or merged through normal checks, correctly closed/returned to queue, or made safe with exact blocker evidence and next action.
- Co-author trailer: \`Co-Authored-By: Antigravity <noreply@google.com>\`.
- Never use \`git stash pop\`, force-push, or commit with hook bypass.
- If two fix attempts fail, revert your own changes for the task and write a relay note rather than stalling.

All cc-task surfaces are in scope, including governance, audio, director,
privacy, CODEOWNERS, refusal briefs, and instruction files. Treat sensitive
surfaces as higher-audit work: cite the governing invariant, keep edits narrow,
run focused verification, and document residual risk in the PR.

Livestream incident strictures:

- Read the latest codex/antigrav transfer note before acting on compositor/source-activation state.
- Do not declare livestream restored until final public egress is smooth, stable, visually coherent, and functionally complete.
- Fallback layout is not an acceptable solution state.
- Disabling effects, wards, preset chains, transitions, or capabilities is not a final fix.
- No full-frame visual pumping, dimming, or cyclic brightness collapse is acceptable.
- Preserve segment actionability while preventing at-a-glance positive identity recognition.
- If a gate appears wrong, prove it with instrumentation and tests, then fix the gate or probe. Do not bypass gates to create false green.
- Do not release source-activation HOLD until the complete incident stack is upstream on \`origin/main\`.
- Do not edit or revert unrelated dirty Gemini/JR files named in the Codex handoff.

Status writes:

- Write \`~/.cache/hapax/relay/$SESSION.yaml\` at session start, after each PR, and before exit.
- Include task id, branch, PR URL/number, tests run, blocked state, and any path claims.
EOF_RULE
echo "hapax-antigrav: refreshed $RULE_PATH" >&2

# ---- claim task ----------------------------------------------------------

if [ -n "$TASK_ID" ] && [ "$CLAIM_TASK" -eq 1 ]; then
  CC_CLAIM="$(command -v cc-claim || echo "$COUNCIL_DIR/scripts/cc-claim")"
  if [ ! -x "$CC_CLAIM" ]; then
    echo "hapax-antigrav: cc-claim not executable at $CC_CLAIM; skipping claim" >&2
  else
    HAPAX_AGENT_NAME="$SESSION" CLAUDE_ROLE="$SESSION" \
      "$CC_CLAIM" "$TASK_ID" || {
      echo "hapax-antigrav: cc-claim failed for '$TASK_ID' — refusing to launch" >&2
      exit 8
    }
  fi
fi

# ---- inflection staging --------------------------------------------------

if [ -n "$INFLECTION_FILE" ]; then
  if [ ! -f "$INFLECTION_FILE" ]; then
    echo "hapax-antigrav: --inflection file not found: $INFLECTION_FILE" >&2
    exit 9
  fi
  # Symlink/copy into the relay dir so the lane's session-start reads it
  base="$(basename "$INFLECTION_FILE")"
  case "$base" in
    alpha-to-antigrav-*.yaml|alpha-to-antigravity-*.yaml) ;;
    *)
      ts="$(date -u +%Y%m%dT%H%M%SZ)"
      base="alpha-to-antigrav-${ts}-staged.yaml"
      ;;
  esac
  cp "$INFLECTION_FILE" "$RELAY_DIR/$base"
  echo "hapax-antigrav: staged inflection at $RELAY_DIR/$base" >&2
fi

# ---- export identity envs (for downstream tools that read $HAPAX_*) -----

export HAPAX_AGENT_INTERFACE="antigravity"
export HAPAX_AGENT_NAME="$SESSION"
export HAPAX_AGENT_SLOT="$SESSION"
export HAPAX_AGENT_ROLE="$SESSION"
export HAPAX_WORKTREE_ROLE="$SESSION"
export CLAUDE_ROLE="$SESSION"
export PASSWORD_STORE_DIR="${PASSWORD_STORE_DIR:-$HOME/.password-store}"
export LOGOS_BASE_URL="${LOGOS_BASE_URL:-http://localhost:8051/api}"

# ---- spawn record --------------------------------------------------------

stamp="$(date -u +%Y%m%dT%H%M%SZ)"
slug="$(printf '%s\n' "$SESSION-${TASK_ID:-no-task}" | tr -cs 'A-Za-z0-9_.-' '-' | sed 's/^-//; s/-$//')"
SPAWN_RECORD="$SPAWN_DIR/$stamp-$slug.yaml"
cat >"$SPAWN_RECORD" <<EOF
spawn:
  ts_utc: $stamp
  session: $SESSION
  task: ${TASK_ID:-none}
  workdir: $WORKDIR
  inflection: ${INFLECTION_FILE:-none}
  open_ide: $OPEN_IDE
EOF

# ---- launch CLI ----------------------------------------------------------

if [ "$OPEN_IDE" -eq 0 ]; then
  echo "hapax-antigrav: --no-open; provisioning complete (worktree=$WORKDIR)"
  exit 0
fi

cd "$WORKDIR"

TMUX_SESSION="hapax-antigrav-$SESSION"

if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
  echo "hapax-antigrav: tmux session '$TMUX_SESSION' already exists" >&2
  exit 0
fi

tmux new-session -d -s "$TMUX_SESSION" -c "$WORKDIR" \
  "HAPAX_AGENT_INTERFACE=antigravity HAPAX_AGENT_NAME=$SESSION HAPAX_AGENT_ROLE=$SESSION CLAUDE_ROLE=$SESSION $ANTIGRAV_BIN --dangerously-skip-permissions ${ANTIGRAV_EXTRA[*]}"

echo "hapax-antigrav: launched agy in tmux session '$TMUX_SESSION' (worktree=$WORKDIR)" >&2
