#!/usr/bin/env bash
# Deprecated compatibility stub for the retired Antigrav/agy live worker.
#
# Antigrav is not an admitted Hapax dispatch platform, lane, route family, or
# supply leaf. Historical hook/adapter artifacts may remain for evidence review,
# but this wrapper must not provision worktrees, wire agy hooks, claim tasks, or
# spawn `agy`.

set -euo pipefail

cat >&2 <<'EOF'
hapax-antigrav: retired
reason_code=antigrav_worker_stub_refusal

Antigrav/agy live worker launch is deprecated and excised from Hapax dispatch.
Use Claude, Codex, or Vibe for worker dispatch. For read-only review-plane work,
use agy.review.direct through scripts/hapax-agy-reviewer after route-specific
admission receipts exist. This compatibility stub intentionally refuses before hooks, claims, worktrees, tmux, or agy can run.
EOF

exit 2
