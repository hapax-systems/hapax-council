#!/usr/bin/env bash
# Launch Antigravity CLI as a Hapax audited full-worker coding interface.
#
# Antigravity is installed locally as the `agy` terminal CLI. Hapax intentionally
# does not fall back to legacy `antigravity` or `gemini` binaries.
#
# This launcher:
#   - Resolves/creates the antigrav worktree
#   - Refreshes per-worktree AGENTS.md
#   - Optionally pre-stages a governed dispatch/bootstrap inflection
#   - Optionally runs cc-claim
#   - Starts `agy --prompt-interactive` in a tmux lane by default
#
# Usage:
#   hapax-antigrav                                # open antigrav worktree in agy
#   hapax-antigrav --task <cc-task-id>            # claim task + start agy
#   hapax-antigrav --task <id> --inflection FILE  # pre-stage assignment file
#   hapax-antigrav --workdir /path                # explicit cwd

set -euo pipefail

COUNCIL_DIR="${HAPAX_COUNCIL_DIR:-$HOME/projects/hapax-council}"
WORKTREE_ROOT="${HAPAX_VIBE_WORKTREE_ROOT:-$HOME/projects}"
RELAY_DIR="$HOME/.cache/hapax/relay"
SPAWN_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/hapax/antigrav-spawns"
mkdir -p "$SPAWN_DIR" "$RELAY_DIR"

usage() {
  cat <<'EOF'
usage: hapax-antigrav [--session antigrav] [--task TASK_ID] [--cd DIR]
                      [--inflection FILE] [--no-claim] [--no-open]
                      [--terminal tmux|current] [--] [agy args...]

Launches Google Antigravity CLI on the Hapax antigrav worktree, with
identity envvars wired and (optionally) cc-claim run.

Antigrav is an audited full-worker lane. Onboarding:
  ~/.cache/hapax/relay/onboarding-antigrav.md

Examples:
  hapax-antigrav                          # just open the worktree in tmux
  hapax-antigrav --task add-tests-foo     # claim + start agy in tmux
  hapax-antigrav --terminal current       # run agy in the current terminal
  hapax-antigrav --no-open                # provision worktree only, don't launch agy

Environment exports:
  HAPAX_AGENT_INTERFACE=antigravity
  HAPAX_AGENT_NAME=antigrav
  HAPAX_AGENT_SLOT=antigrav
EOF
}

# ---- agy enforcing hook wiring (Antigrav parity P0) -----------------------
#
# Antigravity CLI (`agy`) loads Claude-compatible hooks from
#   $HOME/.gemini/antigravity-cli/hooks.json
# This path and format were verified empirically (strace of `agy`): at session
# start agy opens exactly that file and parses it through its jsonhook /
# backend.HooksFile loader, which honors Claude `matcher` semantics and applies
# PreToolUse results (the binary exports applyPreToolHooks +
# EXECUTOR_TERMINATION_REASON_TERMINAL_CUSTOM_HOOK, i.e. a hook may block a
# tool call). `agy plugin import` even accepts Claude plugins directly.
#
# Until this file exists, agy runs with NO Hapax hook: its
# run_command/write_to_file/replace_file_content tools bypass every gate — the
# reform's opening P0 ("Antigravity has NO enforcing gate"). Drop-in env-style
# shell hooks previously left in the hooks/ dir never fired (agy delivers a JSON
# payload, not ANTIGRAV_* env vars), so they asserted false parity.
#
# We register the Hapax guardrail chain for PreToolUse: antigrav-hook-adapter.sh
# normalizes agy's payload into Claude hook JSON, then delegates to
# cc-task-gate.sh — the same governance chokepoint Claude Code and Codex enforce.
# The matcher lists agy's native mutation tool names (gate runs pre-translation).
#
# Returns 0 when the gate is (now) wired; non-zero when wiring is refused (a
# foreign, non-Hapax hooks.json is present) or the adapter/gate are missing. The
# normal launch path tolerates a non-zero return (the warning is advisory);
# `--wire-hooks-only` surfaces it as the process exit code. The wire-only path
# lets the gate be activated live (writing the real hooks.json) WITHOUT launching
# the interactive agy IDE — see tests/hooks/AGY_LIVE_GATE_WITNESS.md for the
# captured live witness of agy being gate-blocked once the file is in place.
wire_agy_hooks() {
  local config_dir="${HAPAX_ANTIGRAV_CONFIG_DIR:-$HOME/.gemini/antigravity-cli}"
  local hooks_json="$config_dir/hooks.json"
  local adapter="$COUNCIL_DIR/hooks/scripts/antigrav-hook-adapter.sh"
  local pre_gate="$COUNCIL_DIR/hooks/scripts/cc-task-gate.sh"

  if [ -f "$hooks_json" ] && ! grep -q 'antigrav-hook-adapter' "$hooks_json" 2>/dev/null; then
    echo "hapax-antigrav: WARNING existing non-Hapax hooks.json at $hooks_json — not overwriting; agy gate NOT wired" >&2
    return 1
  fi
  if [ ! -x "$adapter" ] || [ ! -x "$pre_gate" ]; then
    echo "hapax-antigrav: WARNING adapter/gate missing or not executable ($adapter, $pre_gate) — agy gate NOT wired" >&2
    return 1
  fi

  mkdir -p "$config_dir"
  cat > "$hooks_json" <<EOF_HOOKS
{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "run_command|run_shell_command|write_to_file|create_file|delete_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          { "type": "command", "command": "$adapter $pre_gate" }
        ]
      }
    ]
  }
}
EOF_HOOKS
  echo "hapax-antigrav: wired agy PreToolUse gate → $hooks_json" >&2
  return 0
}

SESSION="antigrav"
TASK_ID=""
WORKDIR=""
WORKDIR_EXPLICIT=0
INFLECTION_FILE=""
CLAIM_TASK=1
OPEN_IDE=1
WIRE_HOOKS_ONLY=0
TERMINAL="tmux"
ANTIGRAV_EXTRA=()

while [ $# -gt 0 ]; do
  case "$1" in
    --session|--name|--lane)
      SESSION="${2:-}"; shift 2 ;;
    --session=*|--name=*|--lane=*)
      SESSION="${1#*=}"; shift ;;
    --task)
      TASK_ID="${2:-}"; shift 2 ;;
    --task=*)
      TASK_ID="${1#--task=}"; shift ;;
    --cd|-C|--workdir)
      WORKDIR="${2:-}"; WORKDIR_EXPLICIT=1; shift 2 ;;
    --cd=*|--workdir=*)
      WORKDIR="${1#*=}"; WORKDIR_EXPLICIT=1; shift ;;
    --inflection)
      INFLECTION_FILE="${2:-}"; shift 2 ;;
    --inflection=*)
      INFLECTION_FILE="${1#--inflection=}"; shift ;;
    --no-claim)
      CLAIM_TASK=0; shift ;;
    --no-open)
      OPEN_IDE=0; shift ;;
    --wire-hooks-only|--install-hooks)
      WIRE_HOOKS_ONLY=1; shift ;;
    --terminal)
      TERMINAL="${2:-}"; shift 2 ;;
    --terminal=*)
      TERMINAL="${1#--terminal=}"; shift ;;
    --help|-h)
      usage; exit 0 ;;
    --)
      shift; ANTIGRAV_EXTRA+=("$@"); break ;;
    *)
      ANTIGRAV_EXTRA+=("$1"); shift ;;
  esac
done

# --wire-hooks-only: activate the agy enforcing gate (write the live hooks.json)
# and exit, WITHOUT resolving the agy binary, provisioning a worktree, refreshing
# AGENTS.md, or launching the IDE. This is how the gate is turned on live without
# popping an unsolicited Antigravity window. Exit non-zero if wiring is refused.
if [ "$WIRE_HOOKS_ONLY" -eq 1 ]; then
  if wire_agy_hooks; then
    exit 0
  fi
  exit 6
fi

case "$TERMINAL" in
  tmux|current) ;;
  *)
    echo "hapax-antigrav: invalid --terminal '$TERMINAL' (expected tmux or current)" >&2
    exit 2
    ;;
esac

if ! [[ "$SESSION" =~ ^antigrav(-[a-z0-9-]+)?$|^antigravity$ ]]; then
  echo "hapax-antigrav: invalid session '$SESSION' (expected antigrav or antigrav-*)" >&2
  exit 2
fi

# Map legacy 'antigravity' to 'antigrav' for relay/claim consistency.
if [ "$SESSION" = "antigravity" ]; then
  echo "hapax-antigrav: normalizing legacy 'antigravity' → 'antigrav' for relay/claim" >&2
  SESSION="antigrav"
fi

resolve_antigrav_bin() {
  if [ -n "${HAPAX_ANTIGRAV_BIN:-}" ]; then
    if [ "$(basename "$HAPAX_ANTIGRAV_BIN")" != "agy" ]; then
      echo "hapax-antigrav: HAPAX_ANTIGRAV_BIN must point to an agy executable" >&2
      return 1
    fi
    [ -x "$HAPAX_ANTIGRAV_BIN" ] || return 1
    printf '%s\n' "$HAPAX_ANTIGRAV_BIN"
    return 0
  fi

  local candidate
  if command -v agy >/dev/null 2>&1; then
    command -v agy
    return 0
  fi
  for candidate in /usr/bin/agy; do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

ANTIGRAV_BIN="$(resolve_antigrav_bin || true)"
if [ -z "$ANTIGRAV_BIN" ] && [ "$OPEN_IDE" -eq 1 ]; then
  echo "hapax-antigrav: Antigravity CLI not found (expected agy or HAPAX_ANTIGRAV_BIN=/path/to/agy)" >&2
  exit 4
fi
if [ -n "$ANTIGRAV_BIN" ]; then
  echo "hapax-antigrav: using Antigravity CLI: $ANTIGRAV_BIN" >&2
fi

# ---- worktree ------------------------------------------------------------

if [ -z "$WORKDIR" ]; then
  WORKDIR="$WORKTREE_ROOT/hapax-council--$SESSION"
fi

ensure_worktree() {
  local target="$1"
  local base_ref="${HAPAX_ANTIGRAV_WORKTREE_BASE:-main}"
  local branch="${HAPAX_ANTIGRAV_BRANCH_PREFIX:-antigrav}/scratch"

  [ ! -d "$target" ] || return 0
  git -C "$COUNCIL_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
    echo "hapax-antigrav: $COUNCIL_DIR is not a git worktree" >&2
    return 1
  }
  mkdir -p "$(dirname "$target")"

  if git -C "$COUNCIL_DIR" rev-parse --verify --quiet "origin/$base_ref" >/dev/null; then
    base_ref="origin/$base_ref"
  elif ! git -C "$COUNCIL_DIR" rev-parse --verify --quiet "$base_ref" >/dev/null; then
    base_ref="HEAD"
  fi

  if git -C "$COUNCIL_DIR" show-ref --verify --quiet "refs/heads/$branch"; then
    git -C "$COUNCIL_DIR" worktree add "$target" "$branch" >/dev/null
  else
    git -C "$COUNCIL_DIR" worktree add -b "$branch" "$target" "$base_ref" >/dev/null
  fi
  echo "hapax-antigrav: created worktree $target on $branch (from $base_ref)" >&2
}

if [ ! -d "$WORKDIR" ]; then
  if [ "$WORKDIR_EXPLICIT" -eq 1 ]; then
    echo "hapax-antigrav: --cd '$WORKDIR' does not exist" >&2
    exit 3
  fi
  if ! ensure_worktree "$WORKDIR"; then
    echo "hapax-antigrav: could not create worktree at $WORKDIR" >&2
    exit 3
  fi
fi
WORKDIR="$(cd "$WORKDIR" && pwd)"

# ---- per-worktree AGENTS.md (managed) -------------------------------------

WORKTREE_AGENTS="$WORKDIR/AGENTS.md"
if [ ! -f "$WORKTREE_AGENTS" ] || head -1 "$WORKTREE_AGENTS" 2>/dev/null | grep -qF '<!-- HAPAX-ANTIGRAV-MANAGED'; then
  cat > "$WORKTREE_AGENTS" <<EOF_AGENTS
<!-- HAPAX-ANTIGRAV-MANAGED: regenerated on every hapax-antigrav launch. Do not hand-edit. -->

# Hapax Antigrav Lane — $SESSION

You are running inside Antigravity CLI (\`agy\`) as the **$SESSION** lane in the
Hapax quad+ relay protocol. Your tier is **audited full worker**: governed
cc-task work is allowed only from an explicit dispatch packet.

## Your identity

- Lane: \`$SESSION\`
- Worktree: \`$WORKDIR\`
- Interface: \`antigravity-cli\`
- Model: \`agy configured model\`

## Where to read first

1. \`~/.cache/hapax/relay/onboarding-antigrav.md\` — full lane onboarding (READ FIRST)
2. \`~/.cache/hapax/relay/PROTOCOL.md\` — quad+ relay protocol spec
3. \`~/projects/CLAUDE.md\` — workspace governance
4. \`~/projects/hapax-council/CLAUDE.md\` — council architecture (the audio invariants section is mandatory)

## Active task (if any)

This file is generated at launch and may be stale. Resolve dynamic state from:

\`\`\`bash
cat ~/.cache/hapax/cc-active-task-$SESSION 2>/dev/null || true
find ~/.cache/hapax/relay -maxdepth 1 -name 'alpha-to-antigrav-*.yaml' -mmin -120 -print
\`\`\`

## Scope

Respect the task's declared mutation surface, prohibited platforms, protected
repo instructions, and local CLAUDE/AGENTS/GEMINI rules. Sensitive or protected
surfaces require narrow edits, explicit invariant/risk notes, focused
verification, and independent PR review.

## Hard rules (operator standing directives)

- Never stall — revert acceptable. 2 attempts + revert + relay note > stall.
- If no explicit governed dispatch packet is assigned, wait for operator or alpha dispatch. Do not self-claim from the WSJF queue.
- Always PR; never merge your own. Co-author trailer required.
- No \`git stash pop\`, no force-push.
- While idle or blocked, use the coordination timer to check queue/relay and leave status.
- Do not self-assign RTE; accept it only if the operator or active train protocol explicitly assigns it.

## On exit

1. Final status to \`~/.cache/hapax/relay/$SESSION.yaml\` (and legacy \`antigravity.yaml\` for compat)
2. PR opened or task moved back to offered with reason
3. Print PR URL to relay so alpha can find it
EOF_AGENTS
  echo "hapax-antigrav: refreshed $WORKTREE_AGENTS" >&2
fi

# Antigravity CLI reads workspace customization from .agents/. Keep .agent as a
# compatibility shim only; new protocol content is emitted under .agents.
RULE_DIR="$WORKDIR/.agents/rules"
WORKFLOW_DIR="$WORKDIR/.agents/workflows"
RULE_PATH="$RULE_DIR/hapax-antigrav-lane.md"
WORKFLOW_PATH="$WORKFLOW_DIR/governed-dispatch-first.md"
COMPAT_RULE_DIR="$WORKDIR/.agent/rules"
COMPAT_RULE_PATH="$COMPAT_RULE_DIR/hapax-antigrav-lane.md"
mkdir -p "$RULE_DIR" "$WORKFLOW_DIR" "$COMPAT_RULE_DIR"
cat > "$RULE_PATH" <<EOF_RULE
# Hapax Antigrav Lane Rule

Use Antigravity CLI (\`agy\`) through Hapax governed dispatch.

You are \`$SESSION\`, an audited full-worker implementation lane. Work in:

\`$WORKDIR\`

Read first every session:

1. \`~/.cache/hapax/relay/onboarding-antigrav.md\`
2. \`~/.cache/hapax/relay/PROTOCOL.md\`
3. \`~/projects/CLAUDE.md\`
4. \`~/projects/hapax-council/CLAUDE.md\`

Dynamic active task pointer:

\`\`\`
cat "$HOME/.cache/hapax/cc-active-task-$SESSION" "$HOME/.cache/hapax/cc-active-task-antigravity" 2>/dev/null || true
\`\`\`

Recent alpha-to-antigrav inflections are intake only unless they name an active
cc-task and match the current dispatch packet:

\`\`\`
find "$RELAY_DIR" -maxdepth 1 \( -name 'alpha-to-antigrav-*.yaml' -o -name 'alpha-to-antigravity-*.yaml' \) -mmin -120 -print
\`\`\`

Recent codex/antigrav transfer notes:

\`\`\`
find "$RELAY_DIR" -maxdepth 1 \( -name 'codex-to-antigrav-*.md' -o -name 'codex-antigrav-transfer-*.md' -o -name 'codex-hn-readiness-antigrav-transfer-*.md' \) -mmin -1440 -print
\`\`\`

Operational contract:

- Accept explicit governed dispatch packets only. If no current dispatch packet is waiting, remain idle and write a relay status indicating readiness. Do not self-claim from the WSJF queue.
- Treat stale relay notes as context, not authority. A relay inflection is actionable only when it names a current active cc-task and matches the dispatch packet.
- Latest operator/alpha inflection controls sequencing. A handoff can be mandatory context or standing strictures without being the first execution path.
- Start by reading the active cc-task, latest alpha-to-antigrav inflection, relay status, and branch state.
- Code edits, tests, commits, and PRs are allowed only inside assigned scope.
- Always PR; never merge your own PR.
- When directed to clean up or continue outstanding workstreams, bring them to natural completion: verified and PR'd/mergeable or merged through normal checks, correctly closed/returned to queue, or made safe with exact blocker evidence and next action.
- Co-author trailer: \`Co-Authored-By: Antigravity <noreply@anthropic.com>\`.
- Never use \`git stash pop\`, force-push, or commit with hook bypass.
- If two fix attempts fail, revert your own changes for the task and write a relay note rather than stalling.

Respect protected surfaces in local CLAUDE/AGENTS/GEMINI instructions and the
task's route constraints. If a task conflicts with those instructions, stop and
write a blocker receipt rather than widening scope.

Livestream incident strictures:

- Read the latest codex/antigrav transfer note before acting on compositor/source-activation state.
- Do not declare livestream restored until final public egress is smooth, stable, visually coherent, and functionally complete.
- Fallback layout is not an acceptable solution state.
- Disabling effects, wards, preset chains, transitions, or capabilities is not a final fix.
- No full-frame visual pumping, dimming, or cyclic brightness collapse is acceptable.
- Preserve segment actionability while preventing at-a-glance positive identity recognition.
- If a gate appears wrong, prove it with instrumentation and tests, then fix the gate or probe. Do not bypass gates to create false green.
- Do not release source-activation HOLD until the complete incident stack is upstream on \`origin/main\`.
- Do not edit or revert unrelated dirty Gemini/JR files named in the Codex handoff.

Status writes:

- Write \`~/.cache/hapax/relay/$SESSION.yaml\` at session start, after each PR, and before exit.
- Include task id, branch, PR URL/number, tests run, blocked state, and any path claims.
EOF_RULE
echo "hapax-antigrav: refreshed $RULE_PATH" >&2

cat > "$WORKFLOW_PATH" <<EOF_WORKFLOW
# Governed Dispatch First

Before mutating source, vault notes, runtime state, branches, PRs, or services:

1. Read the dispatch packet supplied to \`agy --prompt-interactive\`.
2. Confirm it names task id, lane, platform, mode/profile, AuthorityCase, parent spec, worktree, claim command, close command, route evidence, and current blockers.
3. Confirm the active claim file for this lane contains the same task id, or run only the claim command named by the dispatch packet.
4. If any field is missing, stale, contradictory, or not current in the cc-task note, stop and write relay status. Do not infer authority from operator prose, stale relay files, dashboard text, or a generic queue.
5. Never choose "next", "highest WSJF", or unrelated queue work from inside Antigravity.

Generic prompts are intake only. Mutating work requires a current governed dispatch packet.
EOF_WORKFLOW
echo "hapax-antigrav: refreshed $WORKFLOW_PATH" >&2

cat > "$COMPAT_RULE_PATH" <<EOF_COMPAT
# Compatibility Pointer

Canonical Antigravity CLI rules live at:

\`$RULE_PATH\`

Use \`.agents/rules/\` and \`.agents/workflows/\` for current protocol content.
This \`.agent/\` file exists only for older Antigravity builds.
EOF_COMPAT
echo "hapax-antigrav: refreshed compatibility $COMPAT_RULE_PATH" >&2

# ---- agy enforcing hook wiring (Antigrav parity P0) -----------------------
# Activate the PreToolUse gate on every launch (idempotent re-write). Full
# rationale + strace provenance live on wire_agy_hooks() above. A foreign
# hooks.json or a missing adapter is advisory here (the launch still proceeds);
# `hapax-antigrav --wire-hooks-only` is the path that surfaces wiring failure as
# a non-zero exit and is how the gate is activated live without an IDE window.
wire_agy_hooks || true

# ---- export identity envs (for cc-claim and downstream tools) -------------

# Per-session id (coordination reform Phase 1): stable uuid for FM-2 lease keying.
SESSION_UUID="${HAPAX_SESSION_ID:-$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen 2>/dev/null || printf '%s-%s' "$SESSION" "$$")}"
export HAPAX_AGENT_INTERFACE="antigravity"
export HAPAX_AGENT_NAME="$SESSION"
export HAPAX_AGENT_SLOT="$SESSION"
export HAPAX_AGENT_ROLE="$SESSION"
export HAPAX_WORKTREE_ROLE="$SESSION"
export HAPAX_SESSION_ID="$SESSION_UUID"
export CLAUDE_ROLE="$SESSION"
export PASSWORD_STORE_DIR="${PASSWORD_STORE_DIR:-$HOME/.password-store}"
export LOGOS_BASE_URL="${LOGOS_BASE_URL:-http://localhost:8051/api}"

# ---- claim task ----------------------------------------------------------

if [ -n "$TASK_ID" ] && [ "$CLAIM_TASK" -eq 1 ]; then
  CC_CLAIM="$(command -v cc-claim || echo "$COUNCIL_DIR/scripts/cc-claim")"
  if [ ! -x "$CC_CLAIM" ]; then
    echo "hapax-antigrav: cc-claim not executable at $CC_CLAIM; skipping claim" >&2
  else
    HAPAX_AGENT_NAME="$SESSION" \
      HAPAX_AGENT_ROLE="$SESSION" \
      HAPAX_SESSION_ID="$SESSION_UUID" \
      CLAUDE_ROLE="$SESSION" \
      "$CC_CLAIM" "$TASK_ID" || {
      echo "hapax-antigrav: cc-claim failed for '$TASK_ID' — refusing to launch" >&2
      exit 8
    }
  fi
fi

# ---- inflection staging --------------------------------------------------

PROMPT_FILE=""
if [ -n "$INFLECTION_FILE" ]; then
  if [ ! -f "$INFLECTION_FILE" ]; then
    echo "hapax-antigrav: --inflection file not found: $INFLECTION_FILE" >&2
    exit 9
  fi
  # Symlink/copy into the relay dir so the lane's session-start reads it
  base="$(basename "$INFLECTION_FILE")"
  case "$base" in
    alpha-to-antigrav-*.yaml|alpha-to-antigravity-*.yaml) ;;
    *)
      ts="$(date -u +%Y%m%dT%H%M%SZ)"
      base="alpha-to-antigrav-${ts}-staged.yaml"
      ;;
  esac
  cp "$INFLECTION_FILE" "$RELAY_DIR/$base"
  PROMPT_FILE="$RELAY_DIR/$base"
  echo "hapax-antigrav: staged inflection at $RELAY_DIR/$base" >&2
fi

# ---- spawn record --------------------------------------------------------

stamp="$(date -u +%Y%m%dT%H%M%SZ)"
slug="$(printf '%s\n' "$SESSION-${TASK_ID:-no-task}" | tr -cs 'A-Za-z0-9_.-' '-' | sed 's/^-//; s/-$//')"
SPAWN_RECORD="$SPAWN_DIR/$stamp-$slug.yaml"
cat >"$SPAWN_RECORD" <<EOF
spawn:
  ts_utc: $stamp
  session: $SESSION
  task: ${TASK_ID:-none}
  workdir: $WORKDIR
  inflection: ${INFLECTION_FILE:-none}
  prompt_file: ${PROMPT_FILE:-none}
  terminal: $TERMINAL
  open_cli: $OPEN_IDE
EOF

# ---- launch CLI ----------------------------------------------------------

if [ "$OPEN_IDE" -eq 0 ]; then
  echo "hapax-antigrav: --no-open; provisioning complete (worktree=$WORKDIR)"
  exit 0
fi

if [ -z "$PROMPT_FILE" ] && [ -n "$TASK_ID" ]; then
  PROMPT_FILE="$SPAWN_DIR/$stamp-$slug-manual-bootstrap.md"
  cat >"$PROMPT_FILE" <<EOF_PROMPT
SDLC GOVERNED DISPATCH BOOTSTRAP.

Task: $TASK_ID
Lane: $SESSION
Worktree: $WORKDIR

This manual bootstrap is weaker than hapax-methodology-dispatch. Before
mutation, read the active cc-task and parent_spec, verify AuthorityCase and
route metadata, and confirm the claim file belongs to this lane. If any piece is
missing, stop and write relay status.
EOF_PROMPT
fi

# Keep cwd aligned with the lane worktree so agy does not inherit the broad
# ~/projects workspace.
cd "$WORKDIR"

RUN_SCRIPT="$SPAWN_DIR/$stamp-$slug-run.sh"
cat >"$RUN_SCRIPT" <<EOF_RUN
#!/usr/bin/env bash
set -euo pipefail
cd "$WORKDIR"
export HAPAX_AGENT_INTERFACE="antigravity"
export HAPAX_AGENT_NAME="$SESSION"
export HAPAX_AGENT_SLOT="$SESSION"
export HAPAX_AGENT_ROLE="$SESSION"
export HAPAX_WORKTREE_ROLE="$SESSION"
export HAPAX_SESSION_ID="$SESSION_UUID"
export CLAUDE_ROLE="$SESSION"
prompt=""
if [ -n "$PROMPT_FILE" ] && [ -f "$PROMPT_FILE" ]; then
  prompt="\$(cat "$PROMPT_FILE")"
fi
args=(--add-dir "$WORKDIR")
if [ "\${HAPAX_ANTIGRAV_SANDBOX:-0}" = "1" ]; then
  args+=(--sandbox)
fi
if [ -n "\$prompt" ]; then
  args+=(--prompt-interactive "\$prompt")
else
  args+=(--prompt-interactive)
fi
exec "$ANTIGRAV_BIN" "\${args[@]}" "\$@"
EOF_RUN
chmod 700 "$RUN_SCRIPT"

if [ "$TERMINAL" = "current" ]; then
  exec "$RUN_SCRIPT" "${ANTIGRAV_EXTRA[@]}"
fi

if ! command -v tmux >/dev/null 2>&1; then
  echo "hapax-antigrav: tmux not found; use --terminal current or install tmux" >&2
  exit 5
fi

TMUX_SESSION="hapax-antigrav-$SESSION"
TMUX_WINDOW="$(printf '%s\n' "${TASK_ID:-antigrav}" | tr -cs 'A-Za-z0-9_.-' '-' | cut -c1-40)"
tmux_cmd="$(printf '%q ' "$RUN_SCRIPT" "${ANTIGRAV_EXTRA[@]}")"
if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
  tmux new-window -t "$TMUX_SESSION" -n "$TMUX_WINDOW" -c "$WORKDIR" "$tmux_cmd" >/dev/null
else
  tmux new-session -d -s "$TMUX_SESSION" -n "$TMUX_WINDOW" -c "$WORKDIR" "$tmux_cmd" >/dev/null
fi

echo "hapax-antigrav: launched agy in tmux session $TMUX_SESSION (worktree=$WORKDIR)" >&2
