#!/usr/bin/env python3
"""Project a capability-dispatch request into an inert Gate-0A carrier.

``cc-dispatch`` is an intake surface.  It resolves catalogue identity and reports
typed current capability evidence, but it does not validate a task, admit an action,
write a ledger or MQ record, invoke a launcher, or materialize work.  The historical
``--launch`` spelling is accepted only as a compatibility request field; its output
remains ``held_not_admitted`` and ``not_materialized``.
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
_REPO_ROOT = _HERE.parent
if str(_REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(_REPO_ROOT))

from shared.capability_dispatch import (  # noqa: E402
    CapabilityState,
    build_dispatch_carrier,
    canonical_json,
    catalogued_aliases,
    load_capability_registry,
    resolve_capability,
    utilization_status,
)
from shared.platform_capability_registry import (  # noqa: E402
    PlatformCapabilityRegistry,
    PlatformCapabilityRegistryError,
)


def _registry_or_hold() -> PlatformCapabilityRegistry | None:
    try:
        return load_capability_registry()
    except PlatformCapabilityRegistryError as exc:
        print(f"cc-dispatch: HOLD registry_unknown: {exc}", file=sys.stderr)
        return None


def print_list() -> int:
    """Print catalogue aliases with separately evaluated current evidence state."""

    registry = _registry_or_hold()
    if registry is None:
        return 1
    aliases = catalogued_aliases(registry.required_route_ids)
    if not aliases:
        print("cc-dispatch: HOLD empty_capability_catalogue", file=sys.stderr)
        return 1
    for alias, route_id in sorted(aliases.items()):
        resolution = resolve_capability(alias, registry=registry)
        print(f"{alias:20s} -> {route_id:38s} [{resolution.state.value}]")
    return 0


def print_utilization() -> int:
    """Fail visibly instead of treating a legacy lifetime ledger as current truth."""

    status = utilization_status()
    print(f"capability utilization: {status.state.value.upper()}")
    print(f"reason: {status.reason}")
    print(f"legacy source: {status.legacy_source_authority}")
    return 3


def _parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="cc-dispatch",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "capability", nargs="?", help="capability alias or raw catalogued route_id"
    )
    parser.add_argument("cc_task", nargs="?", help="cc-task identifier carried as intake")
    parser.add_argument("--lane", help="requested recipient lane carried as intake")
    parser.add_argument(
        "--launch",
        action="store_true",
        help="compatibility spelling only; emits an inert launch-request carrier",
    )
    parser.add_argument(
        "--utilization",
        action="store_true",
        help="report UNKNOWN until canonical lifecycle outcomes are bound",
    )
    parser.add_argument(
        "--list",
        action="store_true",
        dest="list_caps",
        help="list catalogued aliases and their separately evaluated evidence state",
    )
    parser.add_argument(
        "--mq-message-id",
        help="correlation value only; this command performs no MQ operation",
    )
    parser.add_argument(
        "--idempotency-key",
        help="correlation value only; this command performs no persistence",
    )
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = _parser()
    args = parser.parse_args(argv)

    if args.list_caps:
        return print_list()
    if args.utilization:
        return print_utilization()
    if not args.capability or not args.cc_task:
        parser.error("capability and cc_task are required (or use --list / --utilization)")
    if not args.lane:
        parser.error("--lane is required as an intake recipient")

    registry = _registry_or_hold()
    if registry is None:
        return 1
    resolution = resolve_capability(args.capability, registry=registry)
    if resolution.route_id is None:
        print(
            f"cc-dispatch: HOLD capability_{resolution.state.value}: {resolution.reason}",
            file=sys.stderr,
        )
        return 2

    carrier = build_dispatch_carrier(
        resolution=resolution,
        task_id=args.cc_task,
        lane=args.lane,
        requested_operation="launch" if args.launch else "validate",
        mq_message_id=args.mq_message_id,
        idempotency_key=args.idempotency_key,
    )
    if args.launch:
        print(
            "cc-dispatch: HOLD --launch is compatibility-only; no admission or "
            "materialization occurred",
            file=sys.stderr,
        )
    elif resolution.state is not CapabilityState.AVAILABLE:
        print(
            f"cc-dispatch: HOLD route_{resolution.state.value}; carrier is intake only",
            file=sys.stderr,
        )
    print(canonical_json(carrier))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
