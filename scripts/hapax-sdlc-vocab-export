#!/usr/bin/env python3
"""Export the SDLC vocabulary for consumers (RC-4 / consume-don't-rederive).

The trainyard (hapax-coord) consumes this JSON instead of re-deriving stage
and status vocabularies in Lisp — the audit found its hand-coded enum matched
0/253 live tasks. The export is GENERATED from the owning SSOTs:
  * stages: shared.sdlc_lifecycle (STAGE_RE + the ladder-token bridge)
  * observed vocab: the live task corpus (so consumers can parity-check)
Writes ~/.cache/hapax/coord/sdlc-vocab.json atomically.
"""

from __future__ import annotations

import json
import os
import re
import sys
from datetime import UTC, datetime
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from shared.sdlc_lifecycle import STAGE_RE, stage_token  # noqa: E402

VAULT = Path.home() / "Documents/Personal/20-projects/hapax-cc-tasks/active"
OUT = Path.home() / ".cache/hapax/coord/sdlc-vocab.json"
LADDER = ["S0", "S1", "S2", "S3", "S3_5", "S4", "S5", "S6", "S7", "S8", "S9", "S10", "S11"]
_FM_FIELD = re.compile(r"^(stage|status):\s*(\S+)", re.M)


def observed_vocab() -> tuple[dict[str, int], dict[str, int]]:
    stages: dict[str, int] = {}
    statuses: dict[str, int] = {}
    for note in VAULT.glob("*.md"):
        try:
            head = note.read_text(encoding="utf-8", errors="replace")[:4000]
        except OSError:
            continue
        for field, value in _FM_FIELD.findall(head):
            value = value.strip().strip('"')
            target = stages if field == "stage" else statuses
            target[value] = target.get(value, 0) + 1
    return stages, statuses


def main() -> int:
    stages, statuses = observed_vocab()
    payload = {
        "schema": 1,
        "generated_at": datetime.now(UTC).isoformat(),
        "stage_re": STAGE_RE.pattern,
        "ladder_tokens": LADDER,
        "observed_stages": {
            raw: {"count": n, "ladder_token": stage_token(raw) or "unknown"}
            for raw, n in sorted(stages.items())
        },
        "observed_statuses": dict(sorted(statuses.items())),
        "source": "shared.sdlc_lifecycle + live task corpus",
    }
    OUT.parent.mkdir(parents=True, exist_ok=True)
    tmp = OUT.with_suffix(".tmp")
    tmp.write_text(json.dumps(payload, indent=1))
    os.replace(tmp, OUT)
    print(f"sdlc-vocab: {len(stages)} stage forms, {len(statuses)} statuses -> {OUT}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
