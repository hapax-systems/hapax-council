#!/usr/bin/env bash
# Send an instruction to a live Hapax Codex session and optionally submit it.

set -euo pipefail

usage() {
  cat <<'EOF'
usage: hapax-codex-send --session cx-color [--transport auto|foot|tmux]
                         [--no-submit] [--append] [--require-ack]
                         [--ack-timeout SECONDS] [--json] [--stdin]
                         [--] MESSAGE...

Sends MESSAGE to a visible Hapax Codex session. The default transport prefers a
tmux session named hapax-codex-cx-color and falls back to a visible foot window
named hapax-codex-cx-color. Visible foot delivery targets the window address
directly when Hyprland supports it, avoiding focus-follow-mouse paste/Return
races.
EOF
}

SESSION=""
TRANSPORT="auto"
SUBMIT=1
CLEAR_INPUT=1
REQUIRE_ACK=0
ACK_INSTRUCTION=1
ACK_TIMEOUT="${HAPAX_CODEX_SEND_ACK_TIMEOUT:-60}"
ACK_NUDGE_SECONDS="${HAPAX_CODEX_SEND_ACK_NUDGE_SECONDS:-5}"
ACK_NUDGE_LIMIT="${HAPAX_CODEX_SEND_ACK_NUDGE_LIMIT:-3}"
ACK_FILE=""
ACK_TOKEN=""
ALLOW_LEGACY_ACK=0
JSON_OUTPUT=0
USED_TRANSPORT=""
READ_STDIN=0
RTE_BYPASS=0
MESSAGE_PARTS=()
TMP_FILES=()

cleanup_tmp_files() {
  if [ "${#TMP_FILES[@]}" -gt 0 ]; then
    rm -f "${TMP_FILES[@]}"
  fi
}
trap cleanup_tmp_files EXIT

while [ $# -gt 0 ]; do
  case "$1" in
    --session|--thread|--name)
      SESSION="${2:-}"
      shift 2
      ;;
    --session=*|--thread=*|--name=*)
      SESSION="${1#*=}"
      shift
      ;;
    --transport)
      TRANSPORT="${2:-}"
      shift 2
      ;;
    --transport=*)
      TRANSPORT="${1#--transport=}"
      shift
      ;;
    --no-submit)
      SUBMIT=0
      shift
      ;;
    --append)
      CLEAR_INPUT=0
      shift
      ;;
    --require-ack)
      REQUIRE_ACK=1
      shift
      ;;
    --no-ack-instruction)
      ACK_INSTRUCTION=0
      shift
      ;;
    --ack-timeout)
      ACK_TIMEOUT="${2:-}"
      shift 2
      ;;
    --ack-timeout=*)
      ACK_TIMEOUT="${1#--ack-timeout=}"
      shift
      ;;
    --ack-file)
      ACK_FILE="${2:-}"
      shift 2
      ;;
    --ack-file=*)
      ACK_FILE="${1#--ack-file=}"
      shift
      ;;
    --ack-token)
      ACK_TOKEN="${2:-}"
      shift 2
      ;;
    --ack-token=*)
      ACK_TOKEN="${1#--ack-token=}"
      shift
      ;;
    --allow-legacy-ack)
      ALLOW_LEGACY_ACK=1
      shift
      ;;
    --json)
      JSON_OUTPUT=1
      shift
      ;;
    --stdin)
      READ_STDIN=1
      shift
      ;;
    --rte-bypass)
      RTE_BYPASS=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      MESSAGE_PARTS+=("$@")
      break
      ;;
    *)
      MESSAGE_PARTS+=("$1")
      shift
      ;;
  esac
done

case "$SESSION" in
  cx-[a-z]*)
    ;;
  *)
    echo "hapax-codex-send: invalid or missing session '$SESSION' (expected cx-<color>)" >&2
    exit 2
    ;;
esac

case "$TRANSPORT" in
  auto|foot|tmux)
    ;;
  *)
    echo "hapax-codex-send: invalid transport '$TRANSPORT'" >&2
    exit 2
    ;;
esac

if [ "$READ_STDIN" -eq 1 ]; then
  MESSAGE="$(cat)"
else
  if [ "${#MESSAGE_PARTS[@]}" -eq 0 ]; then
    echo "hapax-codex-send: missing MESSAGE" >&2
    exit 2
  fi
  MESSAGE="${MESSAGE_PARTS[*]}"
fi

if [ -z "$MESSAGE" ]; then
  echo "hapax-codex-send: refusing to send an empty message" >&2
  exit 2
fi

# RTE authority gate (operator directive 2026-05-06): when the active RTE has
# declared red or ops-distress in their latest tick log, refuse new dispatches.
# Bypass with --rte-bypass for operator emergencies (logged to stderr).
if [ "$RTE_BYPASS" -ne 1 ] && command -v hapax-rte-state >/dev/null 2>&1; then
  rte_status="$(hapax-rte-state --status-only 2>/dev/null || echo unknown)"
  case "$rte_status" in
    red)
      echo "hapax-codex-send: BLOCKED by RTE — status=red, dispatch refused. Override with --rte-bypass (operator only)." >&2
      exit 4
      ;;
    ops-distress)
      echo "hapax-codex-send: BLOCKED by RTE — status=ops-distress, dispatch refused. Override with --rte-bypass (operator emergency only)." >&2
      exit 4
      ;;
  esac
fi
if [ "$RTE_BYPASS" -eq 1 ]; then
  echo "hapax-codex-send: NOTE — RTE gate bypassed via --rte-bypass" >&2
fi

case "$ACK_TIMEOUT" in
  ''|*[!0-9.]*)
    echo "hapax-codex-send: invalid --ack-timeout '$ACK_TIMEOUT'" >&2
    exit 2
    ;;
esac

case "$ACK_NUDGE_SECONDS" in
  ''|*[!0-9.]*)
    echo "hapax-codex-send: invalid HAPAX_CODEX_SEND_ACK_NUDGE_SECONDS '$ACK_NUDGE_SECONDS'" >&2
    exit 2
    ;;
esac

case "$ACK_NUDGE_LIMIT" in
  ''|*[!0-9]*)
    echo "hapax-codex-send: invalid HAPAX_CODEX_SEND_ACK_NUDGE_LIMIT '$ACK_NUDGE_LIMIT'" >&2
    exit 2
    ;;
esac

json_string() {
  python3 -c 'import json, sys; print(json.dumps(sys.argv[1]))' "$1"
}

ack_setup() {
  [ "$REQUIRE_ACK" -eq 1 ] || return 0
  if [ -z "$ACK_TOKEN" ]; then
    ACK_TOKEN="ack-$(date -u +%Y%m%dT%H%M%SZ)-$$-$RANDOM"
  fi
  if [ -z "$ACK_FILE" ]; then
    ACK_FILE="${XDG_RUNTIME_DIR:-/tmp}/hapax-codex-acks/$SESSION-$ACK_TOKEN"
  fi
  mkdir -p "$(dirname "$ACK_FILE")"
  rm -f "$ACK_FILE"
  export HAPAX_CODEX_SEND_ACK_FILE="$ACK_FILE"
  export HAPAX_CODEX_SEND_ACK_TOKEN="$ACK_TOKEN"
  if [ "$ACK_INSTRUCTION" -eq 1 ]; then
    MESSAGE="$MESSAGE

ACK REQUIRED: before substantial work, write this exact token to this exact path:
mkdir -p '$(dirname "$ACK_FILE")' && printf '%s\n' '$ACK_TOKEN' > '$ACK_FILE'"
  fi
}

wait_for_ack() {
  [ "$REQUIRE_ACK" -eq 1 ] || return 0
  local start now elapsed nudge_after nudges
  start="$(date +%s)"
  nudges=0
  while true; do
    if [ -f "$ACK_FILE" ] && grep -Fxq "$ACK_TOKEN" "$ACK_FILE" 2>/dev/null; then
      return 0
    fi
    now="$(date +%s)"
    elapsed=$((now - start))
    if [ "$USED_TRANSPORT" = "tmux" ] && [ "$SUBMIT" -eq 1 ] && [ "$nudges" -lt "$ACK_NUDGE_LIMIT" ]; then
      nudge_after="$(awk -v n="$nudges" -v s="$ACK_NUDGE_SECONDS" 'BEGIN { print (n + 1) * s }')"
      if awk -v elapsed="$elapsed" -v nudge_after="$nudge_after" 'BEGIN { exit !(elapsed >= nudge_after) }'; then
        tmux send-keys -t "hapax-codex-$SESSION" C-m 2>/dev/null || true
        nudges=$((nudges + 1))
      fi
    fi
    if awk "BEGIN { exit !($elapsed >= $ACK_TIMEOUT) }"; then
      echo "hapax-codex-send: ack timeout for $SESSION after ${ACK_TIMEOUT}s ($ACK_FILE)" >&2
      return 12
    fi
    sleep 0.25
  done
}

emit_status() {
  [ "$JSON_OUTPUT" -eq 1 ] || return 0
  printf '{"session":%s,"transport":%s,"submitted":%s,"cleared_input":%s,"ack_required":%s' \
    "$(json_string "$SESSION")" \
    "$(json_string "$USED_TRANSPORT")" \
    "$SUBMIT" \
    "$CLEAR_INPUT" \
    "$REQUIRE_ACK"
  if [ "$REQUIRE_ACK" -eq 1 ]; then
    printf ',"ack_file":%s,"ack_token":%s' "$(json_string "$ACK_FILE")" "$(json_string "$ACK_TOKEN")"
  fi
  printf '}\n'
}

ack_setup

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

tmux_target_exists() {
  have_cmd tmux || return 1
  tmux has-session -t "hapax-codex-$SESSION" 2>/dev/null
}

foot_window_address() {
  have_cmd hyprctl || return 1
  have_cmd jq || return 1
  local class="hapax-codex-$SESSION"
  hyprctl clients -j 2>/dev/null \
    | jq -r --arg class "$class" '[.[]? | select(.class == $class) | .address][0] // empty'
}

foot_target_exists() {
  [ -n "$(foot_window_address 2>/dev/null || true)" ]
}

foot_window_center() {
  have_cmd hyprctl || return 1
  have_cmd jq || return 1
  local class="hapax-codex-$SESSION"
  hyprctl clients -j 2>/dev/null \
    | jq -r --arg class "$class" '[.[]? | select(.class == $class) | [
        (.at[0] + ((.size[0] / 2) | floor)),
        (.at[1] + ((.size[1] / 2) | floor))
      ] | @tsv][0] // empty'
}

send_tmux() {
  local target="hapax-codex-$SESSION"
  local tmp buffer
  if [ "$REQUIRE_ACK" -eq 1 ] && [ "${HAPAX_CODEX_SEND_ALLOW_BUSY:-0}" != "1" ]; then
    if tmux capture-pane -pt "$target" -S -30 2>/dev/null \
      | grep -Eq 'Working \(|Messages to be submitted after next tool call'; then
      echo "hapax-codex-send: $SESSION appears busy; refusing to queue ACK-gated message" >&2
      exit 14
    fi
  fi

  tmp="$(mktemp)"
  buffer="hapax-codex-send-$SESSION-$$-$RANDOM"
  TMP_FILES+=("$tmp")
  printf '%s' "$MESSAGE" >"$tmp"

  tmux load-buffer -b "$buffer" "$tmp"
  if [ "$CLEAR_INPUT" -eq 1 ]; then
    tmux send-keys -t "$target" C-u
    sleep "${HAPAX_CODEX_SEND_CLEAR_DELAY:-0.05}"
  fi
  tmux paste-buffer -b "$buffer" -t "$target"
  tmux delete-buffer -b "$buffer" 2>/dev/null || true
  if [ "$SUBMIT" -eq 1 ]; then
    sleep "${HAPAX_CODEX_SEND_SUBMIT_DELAY:-1.10}"
    tmux send-keys -t "$target" C-m
  fi
}

send_foot_return() {
  local address="$1"
  wait_for_focus "$address" || {
    echo "hapax-codex-send: focus moved before submit for $SESSION" >&2
    exit 11
  }
  wtype -P Return -s "${HAPAX_CODEX_SEND_RETURN_HOLD_MS:-80}" -p Return
  sleep "${HAPAX_CODEX_SEND_AFTER_SUBMIT_DELAY:-0.35}"
}

send_hypr_shortcut() {
  local address="$1"
  local modifiers="$2"
  local key="$3"
  local out
  out="$(hyprctl dispatch sendshortcut "$modifiers,$key,address:$address" 2>&1 || true)"
  [ "$out" = "ok" ]
}

send_wtype_clear() {
  [ "$CLEAR_INPUT" -eq 1 ] || return 0
  wtype -M ctrl -k u -m ctrl
  sleep "${HAPAX_CODEX_SEND_CLEAR_DELAY:-0.05}"
}

wait_for_focus() {
  local address="$1"
  local active=""
  local _
  for _ in {1..30}; do
    active="$(hyprctl activewindow -j 2>/dev/null | jq -r '.address // empty' 2>/dev/null || true)"
    if [ "$active" = "$address" ]; then
      return 0
    fi
    sleep 0.05
  done
  return 1
}

save_text_clipboard() {
  local dest="$1"
  have_cmd wl-paste || return 1
  if ! wl-paste --list-types 2>/dev/null | grep -Eqx 'text/plain;charset=utf-8|text/plain'; then
    return 1
  fi
  wl-paste --no-newline >"$dest" 2>/dev/null
}

restore_text_clipboard() {
  local src="$1"
  wl-copy --type text/plain <"$src" || true
}

send_foot_targeted() {
  local address="$1"
  have_cmd wl-copy || return 1

  local msg old
  msg="$(mktemp)"
  old="$(mktemp)"
  TMP_FILES+=("$msg" "$old")
  local restore_clipboard=0
  printf '%s' "$MESSAGE" >"$msg"
  if save_text_clipboard "$old"; then
    restore_clipboard=1
  fi

  if [ "$CLEAR_INPUT" -eq 1 ]; then
    if ! send_hypr_shortcut "$address" "CTRL" "U"; then
      if [ "$restore_clipboard" -eq 1 ]; then
        restore_text_clipboard "$old"
      fi
      return 1
    fi
    sleep "${HAPAX_CODEX_SEND_CLEAR_DELAY:-0.05}"
  fi

  wl-copy --type text/plain <"$msg"
  sleep "${HAPAX_CODEX_SEND_PASTE_DELAY:-0.25}"
  if ! send_hypr_shortcut "$address" "CTRL SHIFT" "V"; then
    if [ "$restore_clipboard" -eq 1 ]; then
      restore_text_clipboard "$old"
    fi
    return 1
  fi

  sleep "${HAPAX_CODEX_SEND_SUBMIT_DELAY:-0.60}"
  if [ "$SUBMIT" -eq 1 ]; then
    if ! send_hypr_shortcut "$address" "" "Return"; then
      if [ "$restore_clipboard" -eq 1 ]; then
        restore_text_clipboard "$old"
      fi
      return 1
    fi
    sleep "${HAPAX_CODEX_SEND_AFTER_SUBMIT_DELAY:-0.35}"
  fi

  sleep "${HAPAX_CODEX_SEND_RESTORE_DELAY:-0.35}"
  if [ "$restore_clipboard" -eq 1 ]; then
    restore_text_clipboard "$old"
  fi
}

move_cursor_to_foot_center() {
  local center
  center="$(foot_window_center 2>/dev/null || true)"
  [ -n "$center" ] || return 0
  local x y
  IFS=$'\t' read -r x y <<EOF
$center
EOF
  [ -n "${x:-}" ] && [ -n "${y:-}" ] || return 0
  hyprctl dispatch movecursor "$x" "$y" >/dev/null 2>&1 || true
}

send_foot() {
  have_cmd hyprctl || { echo "hapax-codex-send: hyprctl not found" >&2; exit 10; }
  have_cmd jq || { echo "hapax-codex-send: jq not found" >&2; exit 10; }

  local address
  address="$(foot_window_address)"
  if [ -z "$address" ]; then
    echo "hapax-codex-send: no visible foot window for $SESSION" >&2
    exit 11
  fi

  if send_foot_targeted "$address"; then
    return
  fi

  have_cmd wtype || { echo "hapax-codex-send: targeted delivery failed and wtype not found" >&2; exit 10; }

  local previous_address
  previous_address="$(hyprctl activewindow -j 2>/dev/null | jq -r '.address // empty' 2>/dev/null || true)"

  move_cursor_to_foot_center
  hyprctl dispatch focuswindow "address:$address" >/dev/null
  wait_for_focus "$address" || {
    echo "hapax-codex-send: failed to focus $SESSION at $address" >&2
    exit 11
  }

  if have_cmd wl-copy; then
    local msg old
    msg="$(mktemp)"
    old="$(mktemp)"
    TMP_FILES+=("$msg" "$old")
    local restore_clipboard=0
    printf '%s' "$MESSAGE" >"$msg"
    if save_text_clipboard "$old"; then
      restore_clipboard=1
    fi

    send_wtype_clear
    wl-copy --type text/plain <"$msg"
    sleep "${HAPAX_CODEX_SEND_PASTE_DELAY:-0.25}"
    wtype -M ctrl -M shift -k v -m shift -m ctrl
    sleep "${HAPAX_CODEX_SEND_SUBMIT_DELAY:-1.10}"
    if [ "$SUBMIT" -eq 1 ]; then
      move_cursor_to_foot_center
      send_foot_return "$address"
    fi
    sleep "${HAPAX_CODEX_SEND_RESTORE_DELAY:-0.35}"
    if [ "$restore_clipboard" -eq 1 ]; then
      restore_text_clipboard "$old"
    fi
  else
    send_wtype_clear
    wtype "$MESSAGE"
    sleep "${HAPAX_CODEX_SEND_SUBMIT_DELAY:-1.10}"
    if [ "$SUBMIT" -eq 1 ]; then
      move_cursor_to_foot_center
      send_foot_return "$address"
    fi
  fi

  if [ -n "$previous_address" ] && [ "$previous_address" != "$address" ]; then
    hyprctl dispatch focuswindow "address:$previous_address" >/dev/null 2>&1 || true
  fi
}

case "$TRANSPORT" in
  foot)
    if [ "$REQUIRE_ACK" -eq 1 ] && [ "$ALLOW_LEGACY_ACK" -ne 1 ]; then
      echo "hapax-codex-send: --require-ack needs a tmux-backed session; refusing legacy foot transport for $SESSION" >&2
      exit 13
    fi
    USED_TRANSPORT="foot"
    send_foot
    ;;
  tmux)
    tmux_target_exists || {
      echo "hapax-codex-send: no tmux session hapax-codex-$SESSION" >&2
      exit 11
    }
    USED_TRANSPORT="tmux"
    send_tmux
    ;;
  auto)
    if tmux_target_exists; then
      USED_TRANSPORT="tmux"
      send_tmux
    elif foot_target_exists; then
      if [ "$REQUIRE_ACK" -eq 1 ] && [ "$ALLOW_LEGACY_ACK" -ne 1 ]; then
        echo "hapax-codex-send: --require-ack needs a tmux-backed session; refusing legacy foot fallback for $SESSION" >&2
        exit 13
      fi
      USED_TRANSPORT="foot"
      send_foot
    else
      echo "hapax-codex-send: no live target for $SESSION" >&2
      exit 11
    fi
    ;;
esac

wait_for_ack
emit_status
