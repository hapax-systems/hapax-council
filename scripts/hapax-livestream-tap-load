#!/usr/bin/env bash
# Load the hapax-livestream-tap null-sink + loopback via pactl.
# Used by hapax-livestream-tap-loopback.service.
#
# Migrated from conf-file (pipewire.conf.d/hapax-livestream-tap.conf) to
# pactl-load as part of audio-graph-ssot Phase 0.
#
# Motivation: conf-file module-loopback loads fail when WirePlumber policies
# aren't fully loaded during PipeWire startup; pactl-load happens after
# both daemons are stable. Three of the 11 broadcast failures on 2026-05-03
# involved this conf-file path.
#
# Architecture:
#   1. Null-sink "hapax-livestream-tap" — OBS captures from its monitor port.
#      Filter-chain sinks suspend when all links are passive, starving the
#      monitor; null-sinks don't, so the monitor stays live.
#   2. Loopback tap → "hapax-livestream" — forwards tap output to the main
#      broadcast chain.
#
# Prerequisites:
#   - hapax-livestream sink must exist (created by the filter-chain conf)
#   - PipeWire and WirePlumber must be stable

set -euo pipefail

LIVESTREAM_SINK="hapax-livestream"
TAP_NAME="hapax-livestream-tap"
TAP_LOOPBACK_SRC="hapax-livestream-tap-src"
TAP_LOOPBACK_DST="hapax-livestream-tap-dst"

log() { echo "hapax-livestream-tap-load: $*"; }
err() { echo "hapax-livestream-tap-load: $*" >&2; }

# ── Wait for hapax-livestream sink to exist ──────────────────────────────

livestream_present=0
for i in $(seq 1 30); do
    if pactl list sinks short | grep -q "${LIVESTREAM_SINK}"; then
        livestream_present=1
        break
    fi
    sleep 2
done

if [ "$livestream_present" -ne 1 ]; then
    err "hapax-livestream sink not present after 60s — refusing to load"
    err "The filter-chain that creates '${LIVESTREAM_SINK}' may not be running."
    exit 0  # exit 0 so systemd doesn't loop; operator action required
fi

# ── Idempotent: check if tap null-sink already exists ────────────────────

if pactl list sinks short | grep -q "${TAP_NAME}"; then
    log "null-sink '${TAP_NAME}' already exists — checking loopback"
else
    # Load the null-sink
    log "loading null-sink '${TAP_NAME}'..."
    pactl load-module module-null-sink \
        sink_name="${TAP_NAME}" \
        sink_properties="device.description='Hapax Livestream (OBS monitor tap)' media.class=Audio/Sink" \
        channels=2 \
        channel_map=front-left,front-right

    # Verify the sink appeared
    sleep 0.5
    if ! pactl list sinks short | grep -q "${TAP_NAME}"; then
        err "null-sink '${TAP_NAME}' did not appear after load-module — aborting"
        exit 1
    fi
    log "null-sink '${TAP_NAME}' loaded successfully"
fi

# ── Idempotent: check if tap→livestream loopback already exists ──────────

existing_loopback=$(pactl list modules 2>/dev/null | awk -v tap="${TAP_NAME}" -v ls="${LIVESTREAM_SINK}" '
    /^Module #/{idx=substr($2,2)}
    /^\tName: module-loopback/{is_lb=1; next}
    /^\tName:/{is_lb=0}
    is_lb && $0 ~ tap && $0 ~ ls {print idx; is_lb=0}
')

if [ -n "$existing_loopback" ]; then
    log "loopback tap→livestream already loaded (id=${existing_loopback}); nothing to do"
    exit 0
fi

# ── Load the loopback: tap → hapax-livestream ────────────────────────────

log "loading loopback: ${TAP_NAME} → ${LIVESTREAM_SINK}..."
loaded_id=$(pactl load-module module-loopback \
    source="${TAP_NAME}.monitor" \
    sink="${LIVESTREAM_SINK}" \
    source_dont_move=true \
    sink_dont_move=true \
    latency_msec=20 \
    sink_input_properties="media.name='tap → hapax-livestream (P0 pactl-load)'")

# Post-load verification: confirm the module references our target sink.
loaded_arg=$(pactl list modules 2>/dev/null | awk -v m="Module #${loaded_id}" '
    $0 == m {found=1; next}
    found && /^\tArgument:/{print; exit}
')
if ! echo "$loaded_arg" | grep -q "$LIVESTREAM_SINK"; then
    err "post-load verification FAILED — module ${loaded_id} did not bind to ${LIVESTREAM_SINK}"
    err "argument was: $loaded_arg"
    pactl unload-module "$loaded_id"
    exit 1
fi

log "loopback loaded: id=${loaded_id} source=${TAP_NAME}.monitor sink=${LIVESTREAM_SINK}"
