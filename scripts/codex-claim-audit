#!/usr/bin/env bash
# codex-claim-audit - projection-only claim and lane coherence diagnostics.
#
# The audit reports stale, quota-blocked, cache-incoherent, and process-
# incoherent candidates. It never rewrites task notes, clears local or remote
# claim state, or detaches ownership. Legacy release/reconcile options are
# explicit fail-closed refusals until a separate governed effect mechanism is
# implemented.

set -euo pipefail

SCRIPT_VERSION=3
FINDINGS_EXIT=10
REFUSAL_EXIT=2

VAULT_ROOT="${HAPAX_CLAIM_AUDIT_VAULT_ROOT:-$HOME/Documents/Personal/20-projects/hapax-cc-tasks}"
CLAIM_CACHE_DIR="${HAPAX_CLAIM_CACHE_DIR:-$HOME/.cache/hapax}"
RELAY_RECEIPT_DIR="${HAPAX_RELAY_RECEIPT_DIR:-$HOME/.cache/hapax/relay/receipts}"
ORCHESTRATION_LEDGER_DIR="${HAPAX_ORCHESTRATION_LEDGER_DIR:-$HOME/.cache/hapax/orchestration}"
QUOTA_BLOCKED_LOOKBACK_SECONDS="${HAPAX_QUOTA_BLOCKED_LOOKBACK_SECONDS:-86400}"
STALE_HOURS="${CODEX_CLAIM_STALE_HOURS:-6}"
PS_FIXTURE="${HAPAX_CLAIM_AUDIT_PS_FIXTURE:-}"
EFFECT_OPTIONS=()

usage() {
  cat <<'EOF'
Usage: codex-claim-audit [--stale-hours=HOURS] [--dry-run] [--version]

Report claim/lane coherence candidates without changing task, claim, epoch,
binding, process, or remote-host state.

Legacy effect options are refused:
  --release
  --release-quota-blocked
  --reconcile-host=HOST
  --reconcile-cache-dir=PATH
EOF
}

for arg in "$@"; do
  case "$arg" in
    --release|--release-quota-blocked|--reconcile-host=*|--reconcile-cache-dir=*)
      EFFECT_OPTIONS+=("$arg")
      ;;
    --stale-hours=*) STALE_HOURS="${arg#*=}" ;;
    --dry-run) ;;
    --version)
      printf 'codex-claim-audit v%s (projection-only)\n' "$SCRIPT_VERSION"
      exit 0
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf 'codex-claim-audit: unknown argument: %s\n' "$arg" >&2
      usage >&2
      exit 64
      ;;
  esac
done

case "$STALE_HOURS" in
  ''|*[!0-9]*)
    printf 'codex-claim-audit: --stale-hours must be a non-negative integer\n' >&2
    exit 64
    ;;
esac
case "$QUOTA_BLOCKED_LOOKBACK_SECONDS" in
  ''|*[!0-9]*)
    printf 'codex-claim-audit: HAPAX_QUOTA_BLOCKED_LOOKBACK_SECONDS must be a non-negative integer\n' >&2
    exit 64
    ;;
esac

if [ "${#EFFECT_OPTIONS[@]}" -gt 0 ]; then
  printf 'codex-claim-audit: REFUSED_EFFECT options=%s\n' "${EFFECT_OPTIONS[*]}" >&2
  printf 'codex-claim-audit: release/reconciliation authority is absent; this audit is projection-only and performed no effects\n' >&2
  exit "$REFUSAL_EXIT"
fi

REPO_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")")/.." 2>/dev/null && pwd || true)"
if [ -z "$REPO_DIR" ] || [ ! -d "$REPO_DIR/shared" ]; then
  printf 'codex-claim-audit: AUDIT_ERROR activated source root unavailable: %s\n' "${REPO_DIR:-<unknown>}" >&2
  exit 2
fi

exec python3 - \
  "$REPO_DIR" \
  "$VAULT_ROOT" \
  "$CLAIM_CACHE_DIR" \
  "$RELAY_RECEIPT_DIR" \
  "$ORCHESTRATION_LEDGER_DIR" \
  "$((STALE_HOURS * 3600))" \
  "$QUOTA_BLOCKED_LOOKBACK_SECONDS" \
  "$PS_FIXTURE" \
  "$FINDINGS_EXIT" <<'PY'
from __future__ import annotations

import json
import re
import subprocess
import sys
from collections import defaultdict
from dataclasses import dataclass
from datetime import UTC, date, datetime, timedelta
from pathlib import Path
from typing import Any

repo_root = Path(sys.argv[1])
vault_root = Path(sys.argv[2])
cache_dir = Path(sys.argv[3])
receipt_dir = Path(sys.argv[4])
ledger_dir = Path(sys.argv[5])
stale_threshold = int(sys.argv[6])
quota_lookback = int(sys.argv[7])
ps_fixture = Path(sys.argv[8]) if sys.argv[8] else None
findings_exit = int(sys.argv[9])

sys.path.insert(0, str(repo_root))

try:
    from shared.sdlc_owner_identity import owner_matches, parse_task_owner
    from shared.strict_yaml import strict_safe_load
except Exception as exc:  # pragma: no cover - deployment failure path
    print(f"codex-claim-audit: AUDIT_ERROR strict parser unavailable: {exc}", file=sys.stderr)
    raise SystemExit(2)


CLAIM_STATUSES = {"claimed", "in_progress"}
UNASSIGNED = {"", "null", "none", "~", "unassigned"}


@dataclass(frozen=True)
class TaskNote:
    path: Path
    task_id: str
    status: str
    assigned_to: str
    pr: str
    branch: str
    claimed_at: str


class TaskStoreError(RuntimeError):
    """The authoritative active-task snapshot could not be read completely."""


findings: list[tuple[str, str]] = []


def add(kind: str, detail: str) -> None:
    findings.append((kind, detail))


def scalar_text(value: Any, *, field: str, allow_null: bool = True) -> str:
    if value is None and allow_null:
        return ""
    if isinstance(value, bool) or not isinstance(value, (str, int)):
        raise ValueError(f"{field} must be scalar")
    return str(value).strip()


def timestamp_text(value: Any, *, field: str) -> str:
    if isinstance(value, (date, datetime)):
        return value.isoformat()
    return scalar_text(value, field=field)


def read_frontmatter(path: Path) -> dict[str, Any]:
    text = path.read_text(encoding="utf-8")
    if not text.startswith("---"):
        raise ValueError("missing frontmatter")
    parts = text.split("---", 2)
    if len(parts) < 3:
        raise ValueError("unclosed frontmatter")
    loaded = strict_safe_load(parts[1])
    if not isinstance(loaded, dict):
        raise ValueError("frontmatter is not a mapping")
    return loaded


def load_tasks() -> dict[str, TaskNote]:
    active = vault_root / "active"
    tasks: dict[str, TaskNote] = {}
    if not active.is_dir():
        raise TaskStoreError(f"path={active} error=missing-or-not-directory")
    try:
        paths = sorted(path for path in active.iterdir() if path.name.endswith(".md"))
    except OSError as exc:
        raise TaskStoreError(f"path={active} error={exc}") from exc

    for path in paths:
        try:
            data = read_frontmatter(path)
            task_id = scalar_text(data.get("task_id"), field="task_id", allow_null=False)
            status = scalar_text(data.get("status"), field="status", allow_null=False).lower()
            owner = scalar_text(data.get("assigned_to"), field="assigned_to")
            if owner and owner.lower() not in UNASSIGNED:
                parse_task_owner(owner)
            pr = scalar_text(data.get("pr"), field="pr")
            branch = scalar_text(data.get("branch"), field="branch")
            claimed_at = timestamp_text(data.get("claimed_at"), field="claimed_at")
            if not task_id or not status:
                raise ValueError("task_id and status must be non-empty strings")
            if task_id in tasks:
                raise ValueError(f"duplicate active task_id {task_id}")
            tasks[task_id] = TaskNote(
                path=path,
                task_id=task_id,
                status=status,
                assigned_to=owner,
                pr=pr,
                branch=branch,
                claimed_at=claimed_at,
            )
        except (OSError, TypeError, ValueError) as exc:
            raise TaskStoreError(f"path={path} error={exc}") from exc
    return tasks


def read_caches() -> dict[Path, tuple[str, str]]:
    caches: dict[Path, tuple[str, str]] = {}
    if not cache_dir.is_dir():
        return caches
    try:
        paths = sorted(cache_dir.glob("cc-active-task-*"))
    except OSError as exc:
        add("CACHE_SCAN_ERROR", f"path={cache_dir} error={exc} action=HOLD")
        return caches
    for path in paths:
        if ".audit-claim." in path.name or not path.is_file():
            continue
        role = path.name.removeprefix("cc-active-task-")
        try:
            lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
        except OSError as exc:
            add("CACHE_SCAN_ERROR", f"cache={path.name} error={exc} action=HOLD")
            continue
        task_id = lines[0].strip() if lines else ""
        if not task_id:
            add("CACHE_MALFORMED", f"cache={path.name} task=<empty> action=HOLD")
            continue
        caches[path] = (role, task_id)
    return caches


def task_owner_role(owner: str) -> str:
    identity = parse_task_owner(owner)
    return identity.role if identity is not None else ""


def inferred_platform(role: str) -> str | None:
    if role.startswith("cx-") or role.startswith("codex"):
        return "codex"
    if role.startswith("vbe-"):
        return "vibe"
    if role in {"alpha", "beta", "gamma", "delta", "epsilon", "zeta", "eta", "theta"}:
        return "claude"
    return None


def role_matches(cache_role: str, note_owner: str) -> bool:
    identity = parse_task_owner(note_owner)
    if identity is None:
        return False
    if cache_role != identity.role and not cache_role.startswith(f"{identity.role}-"):
        return False
    return identity.platform is None or identity.platform == inferred_platform(identity.role)


def parse_timestamp(raw: str) -> datetime | None:
    if not raw or raw.lower() in UNASSIGNED:
        return None
    try:
        return datetime.fromisoformat(raw.replace("Z", "+00:00")).astimezone(UTC)
    except ValueError:
        return None


def receipt_quota_evidence(role: str, now: datetime) -> str:
    receipt = receipt_dir / f"{role}-quota-wall.yaml"
    if not receipt.is_file():
        return ""
    try:
        data = strict_safe_load(receipt.read_text(encoding="utf-8"))
        if not isinstance(data, dict):
            raise ValueError("receipt is not a mapping")
        status = scalar_text(data.get("status"), field="status").lower()
        if status and status != "quota_blocked":
            return ""
        resets = timestamp_text(data.get("resets_at"), field="resets_at")
        if not resets or resets.lower() in UNASSIGNED | {"unknown"}:
            return f"quota-wall-receipt:{receipt}"
        reset_at = parse_timestamp(resets)
        if reset_at is None:
            add("QUOTA_EVIDENCE_ERROR", f"path={receipt} resets_at={resets!r} action=HOLD")
            return ""
        if reset_at >= now:
            return f"quota-wall-receipt:{receipt}"
    except (OSError, TypeError, ValueError) as exc:
        add("QUOTA_EVIDENCE_ERROR", f"path={receipt} error={exc} action=HOLD")
    return ""


def dispatch_quota_evidence(role: str, task_id: str, now: datetime) -> str:
    cutoff = now - timedelta(seconds=max(0, quota_lookback))
    matches: list[tuple[datetime, str, str]] = []
    for ledger in (
        ledger_dir / "methodology-dispatch.jsonl",
        ledger_dir / "route-decisions.jsonl",
    ):
        if not ledger.is_file():
            continue
        try:
            lines = ledger.read_text(encoding="utf-8").splitlines()[-5000:]
        except OSError as exc:
            add("QUOTA_EVIDENCE_ERROR", f"path={ledger} error={exc} action=HOLD")
            continue
        for raw in lines:
            try:
                record = json.loads(raw)
            except json.JSONDecodeError:
                continue
            if not isinstance(record, dict):
                continue
            if record.get("lane") != role or record.get("task_id") != task_id:
                continue
            timestamp_raw = str(record.get("timestamp") or record.get("created_at") or "")
            timestamp = parse_timestamp(timestamp_raw)
            if timestamp is None or timestamp < cutoff:
                continue
            reason_codes = record.get("route_policy_reason_codes") or record.get("reason_codes") or []
            if not isinstance(reason_codes, list):
                reason_codes = [reason_codes]
            text = " ".join(
                str(value)
                for value in (
                    record.get("reason"),
                    record.get("message"),
                    record.get("decision"),
                    record.get("policy_outcome"),
                    record.get("route_policy_action"),
                    record.get("route_policy_outcome"),
                    " ".join(str(item) for item in reason_codes),
                )
                if value is not None
            ).lower()
            quotaish = any(
                marker in text
                for marker in ("quota", "account_live_quota", "usage limit", "rate_limit")
            )
            blocked = record.get("ok") is False or "hold" in text or "refuse" in text
            if quotaish and blocked:
                ident = str(
                    record.get("route_decision_id")
                    or record.get("decision_id")
                    or timestamp_raw
                )
                matches.append((timestamp, ledger.stem, ident))
    if not matches:
        return ""
    _timestamp, source, ident = sorted(matches)[-1]
    return f"{source}:{ident}"


def is_codexish(owner: str) -> bool:
    identity = parse_task_owner(owner)
    return bool(identity) and (
        identity.platform == "codex"
        or identity.role.startswith("cx-")
        or identity.role.startswith("codex")
    )


def pr_absent(pr: str) -> bool:
    return not pr or pr.lower() in UNASSIGNED


def audit_tasks(
    tasks: dict[str, TaskNote], caches: dict[Path, tuple[str, str]], now: datetime
) -> None:
    for task in tasks.values():
        if task.status not in CLAIM_STATUSES:
            continue
        owner = task.assigned_to
        if not owner or owner.lower() in UNASSIGNED:
            add(
                "CLAIM_OWNER_MISSING",
                f"task={task.task_id} status={task.status} assigned={owner or '<null>'} action=HOLD",
            )
            continue

        matching = [
            (path, role)
            for path, (role, cached_task) in caches.items()
            if cached_task == task.task_id and role_matches(role, owner)
        ]
        role = task_owner_role(owner)
        canonical = cache_dir / f"cc-active-task-{role}"
        if not matching:
            if canonical in caches:
                cached_task = caches[canonical][1]
                add(
                    "CACHE_MISMATCH",
                    f"task={task.task_id} assigned={owner} cache={canonical.name} cache_task={cached_task} action=HOLD",
                )
            else:
                add(
                    "CACHE_MISSING",
                    f"task={task.task_id} assigned={owner} status={task.status} expected={canonical.name} action=HOLD",
                )

        evidence = receipt_quota_evidence(role, now)
        if not evidence:
            evidence = dispatch_quota_evidence(role, task.task_id, now)
        if evidence:
            add(
                "QUOTA_BLOCKED",
                f"task={task.task_id} assigned={owner} status={task.status} evidence={evidence} pr={task.pr or 'null'} branch={task.branch or 'null'} action=HOLD",
            )

        if not is_codexish(owner):
            continue
        claimed = parse_timestamp(task.claimed_at)
        if claimed is None:
            age_seconds = stale_threshold + 1
            age_label = "unknown"
        else:
            age_seconds = max(0, int((now - claimed).total_seconds()))
            age_label = f"{age_seconds // 3600}h"
        if age_seconds >= stale_threshold and pr_absent(task.pr):
            add(
                "PHANTOM_CANDIDATE",
                f"task={task.task_id} assigned={owner} status={task.status} age={age_label} pr={task.pr or 'null'} branch={task.branch or 'null'} action=HOLD",
            )


def audit_caches(tasks: dict[str, TaskNote], caches: dict[Path, tuple[str, str]]) -> None:
    for path, (role, task_id) in caches.items():
        task = tasks.get(task_id)
        if task is None:
            add(
                "CACHE_STALE_CANDIDATE",
                f"cache={path.name} task={task_id} status=not_active action=HOLD",
            )
            continue
        if task.status not in CLAIM_STATUSES or not role_matches(role, task.assigned_to):
            add(
                "CACHE_STALE_CANDIDATE",
                f"cache={path.name} task={task_id} note_assigned={task.assigned_to or '<null>'} note_status={task.status} action=HOLD",
            )


def process_snapshot() -> str:
    if ps_fixture is not None:
        try:
            return ps_fixture.read_text(encoding="utf-8", errors="replace")
        except OSError as exc:
            add("PROCESS_SCAN_ERROR", f"fixture={ps_fixture} error={exc} action=HOLD")
            return ""
    try:
        result = subprocess.run(
            ["ps", "-eo", "pid=,etimes=,args="],
            capture_output=True,
            text=True,
            check=False,
            timeout=20,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        add("PROCESS_SCAN_ERROR", f"error={exc} action=HOLD")
        return ""
    if result.returncode != 0:
        add("PROCESS_SCAN_ERROR", f"returncode={result.returncode} action=HOLD")
        return ""
    return result.stdout


def audit_processes(tasks: dict[str, TaskNote], caches: dict[Path, tuple[str, str]]) -> None:
    seen: set[tuple[str, str, str]] = set()
    for line in process_snapshot().splitlines():
        if "Resume governed task " not in line:
            continue
        task_match = re.search(r"Resume governed task ([^ ]+)", line)
        if task_match is None:
            continue
        task_id = task_match.group(1)
        role_match = re.search(r"(HAPAX_AGENT_ROLE|CODEX_ROLE|CLAUDE_ROLE)=([^ ]+)", line)
        role = role_match.group(2) if role_match else "<unknown>"
        interface_match = re.search(r"HAPAX_AGENT_INTERFACE=([^ ]+)", line)
        if interface_match is not None:
            platform = interface_match.group(1).strip().lower()
        elif role_match is not None and role_match.group(1) == "CODEX_ROLE":
            platform = "codex"
        elif role_match is not None and role_match.group(1) == "CLAUDE_ROLE":
            platform = "claude"
        else:
            platform = inferred_platform(role)
        columns = line.strip().split(maxsplit=2)
        pid = columns[0] if columns else "?"
        age = columns[1] if len(columns) > 1 else "?"
        task = tasks.get(task_id)
        reason = ""
        detail = ""
        if task is None:
            reason = "PROCESS_TASK_NOT_ACTIVE"
            detail = "task_state=missing"
        elif task.status not in CLAIM_STATUSES:
            reason = "PROCESS_TASK_NOT_CLAIMED"
            detail = f"task_status={task.status}"
        elif role != "<unknown>" and not owner_matches(
            task.assigned_to,
            role,
            platform,
        ):
            reason = "PROCESS_ASSIGNEE_MISMATCH"
            detail = f"note_assigned={task.assigned_to or '<null>'}"
        elif role != "<unknown>" and not any(
            cached_task == task_id and role_matches(cache_role, role)
            for cache_role, cached_task in caches.values()
        ):
            reason = "PROCESS_CACHE_MISMATCH"
            detail = "cache_task=<missing>"
        if not reason:
            continue
        key = (role, task_id, reason)
        if key in seen:
            continue
        seen.add(key)
        add(
            reason,
            f"pid={pid} age_s={age} role={role} task={task_id} {detail} action=HOLD",
        )


def render() -> int:
    if not findings:
        print("codex-claim-audit: no claim/lane coherence candidates found")
        print("codex-claim-audit: projection-only; effects=0")
        return 0

    labels = {
        "QUOTA_BLOCKED": "quota-blocked claim candidate(s)",
        "PHANTOM_CANDIDATE": "phantom claim candidate(s)",
        "CACHE_STALE_CANDIDATE": "stale claim cache candidate(s)",
    }
    grouped: dict[str, list[str]] = defaultdict(list)
    for kind, detail in findings:
        grouped[kind].append(detail)
    for kind in sorted(grouped):
        label = labels.get(kind, "diagnostic finding(s)")
        print(f"codex-claim-audit: {len(grouped[kind])} {label} [{kind}]")
        for detail in grouped[kind]:
            print(f"  {kind}: {detail}")
    print(f"codex-claim-audit: findings={len(findings)} effects=0")
    print(
        "codex-claim-audit: all candidates HOLD; no task, claim, epoch, binding, process, or remote-host state was changed"
    )
    return findings_exit


try:
    now = datetime.now(UTC)
    tasks = load_tasks()
    caches = read_caches()
    audit_tasks(tasks, caches, now)
    audit_caches(tasks, caches)
    audit_processes(tasks, caches)
    raise SystemExit(render())
except TaskStoreError as exc:
    print(
        f"codex-claim-audit: AUDIT_ERROR authoritative task-store input incomplete: {exc}",
        file=sys.stderr,
    )
    raise SystemExit(2)
except SystemExit:
    raise
except Exception as exc:  # pragma: no cover - unexpected deployment failure
    print(f"codex-claim-audit: AUDIT_ERROR {type(exc).__name__}: {exc}", file=sys.stderr)
    raise SystemExit(2)
PY
