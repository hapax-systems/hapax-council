#!/usr/bin/env bash
# codex-claim-audit — detect phantom task claims (claimed but no implementation progress).
#
# Scans all active tasks assigned to cx-* or codex-* roles. For each, checks:
#   1. Is the task claimed/in_progress for > STALE_HOURS without a PR or branch?
#   2. Does the assigned role have a matching cc-active-task cache marker?
#   3. Are live resumed lane processes still coherent with active task state?
#
# Reports phantom claims and optionally releases them (--release).
#
# Intended to run as a systemd timer (codex-claim-audit.timer) or ad-hoc.

set -euo pipefail

VAULT_ROOT="$HOME/Documents/Personal/20-projects/hapax-cc-tasks"
CLAIM_CACHE_DIR="${HAPAX_CLAIM_CACHE_DIR:-$HOME/.cache/hapax}"
STALE_HOURS="${CODEX_CLAIM_STALE_HOURS:-6}"
RELEASE=false
NTFY_URL="${NTFY_URL:-https://ntfy.sh}"
NTFY_TOPIC="${NTFY_TOPIC:-hapax-ops}"

for arg in "$@"; do
  case "$arg" in
    --release) RELEASE=true ;;
    --stale-hours=*) STALE_HOURS="${arg#*=}" ;;
  esac
done

stale_threshold=$((STALE_HOURS * 3600))
now_epoch=$(date +%s)
phantom_count=0
cache_mismatch_count=0
stale_cache_count=0
coherence_count=0
process_count=0
report=""
cache_report=""
coherence_report=""
process_report=""

_strip_scalar() {
  printf '%s' "$1" | sed -E "s/^[[:space:]]+//; s/[[:space:]]+$//; s/^['\"]//; s/['\"]$//"
}

_fm_value() {
  local key="$1"
  local path="$2"
  grep -oP "^${key}:\s*\\K.*" "$path" 2>/dev/null | head -n1 | sed -E "s/^[[:space:]]+//; s/[[:space:]]+$//; s/^['\"]//; s/['\"]$//" || true
}

_is_claim_status() {
  case "$1" in
    claimed|in_progress) return 0 ;;
    *) return 1 ;;
  esac
}

_is_unassigned_role() {
  case "$(_strip_scalar "$1" | tr '[:upper:]' '[:lower:]')" in
    ""|null|none|"~"|unassigned|"[]") return 0 ;;
    *) return 1 ;;
  esac
}

_is_codexish_role() {
  case "$1" in
    cx-*|codex*) return 0 ;;
    *) return 1 ;;
  esac
}

_claim_file_for() {
  printf '%s/cc-active-task-%s' "$CLAIM_CACHE_DIR" "$1"
}

_claim_file_task() {
  local claim_file="$1"
  [ -f "$claim_file" ] || return 0
  sed -n '1p' "$claim_file" 2>/dev/null | tr -d '[:space:]' || true
}

_active_note_for() {
  local task_id="$1"
  local exact="$VAULT_ROOT/active/$task_id.md"
  if [ -f "$exact" ]; then
    printf '%s' "$exact"
    return 0
  fi
  for candidate in "$VAULT_ROOT/active/$task_id-"*.md; do
    [ -f "$candidate" ] || continue
    printf '%s' "$candidate"
    return 0
  done
  return 1
}

_any_note_status_for() {
  local task_id="$1"
  local note=""
  note="$(_active_note_for "$task_id" 2>/dev/null || true)"
  if [ -n "$note" ]; then
    printf 'active:%s' "$(_fm_value status "$note")"
    return 0
  fi
  local exact="$VAULT_ROOT/closed/$task_id.md"
  if [ -f "$exact" ]; then
    printf 'closed:%s' "$(_fm_value status "$exact")"
    return 0
  fi
  for candidate in "$VAULT_ROOT/closed/$task_id-"*.md; do
    [ -f "$candidate" ] || continue
    printf 'closed:%s' "$(_fm_value status "$candidate")"
    return 0
  done
  printf 'missing:not_found'
}

_record_coherence() {
  coherence_count=$((coherence_count + 1))
  coherence_report="${coherence_report}  $1\n"
}

_record_process() {
  process_count=$((process_count + 1))
  process_report="${process_report}  $1\n"
}

for note in "$VAULT_ROOT/active/"*.md; do
  [ -f "$note" ] || continue

  assigned="$(_fm_value assigned_to "$note")"
  status="$(_fm_value status "$note")"
  _is_claim_status "$status" || continue

  task_id="$(_fm_value task_id "$note")"
  [ -n "$task_id" ] || task_id="$(basename "$note" .md)"
  pr="$(_fm_value pr "$note")"
  branch="$(_fm_value branch "$note")"
  claimed_at="$(_fm_value claimed_at "$note")"

  if ! _is_unassigned_role "$assigned"; then
    claim_file="$(_claim_file_for "$assigned")"
    claimed_task="$(_claim_file_task "$claim_file")"
    if [ ! -f "$claim_file" ]; then
      _record_coherence "CACHE_MISSING: ${task_id} assigned=${assigned} status=${status} expected=$(basename "$claim_file")"
    elif [ "$claimed_task" != "$task_id" ]; then
      _record_coherence "CACHE_MISMATCH: ${task_id} assigned=${assigned} status=${status} cache=$(basename "$claim_file") cache_task=${claimed_task:-<empty>}"
    fi
  fi

  _is_codexish_role "$assigned" || continue

  if [ -n "$claimed_at" ] && [ "$claimed_at" != "null" ]; then
    claimed_epoch=$(date -d "$claimed_at" +%s 2>/dev/null || echo 0)
    age=$((now_epoch - claimed_epoch))
  else
    age=$((stale_threshold + 1))
  fi

  has_pr=false
  [ "$pr" != "null" ] && [ -n "$pr" ] && has_pr=true

  has_branch=false
  [ "$branch" != "null" ] && [ -n "$branch" ] && has_branch=true

  if [ "$age" -ge "$stale_threshold" ] && [ "$has_pr" = false ]; then
    phantom_count=$((phantom_count + 1))
    age_h=$((age / 3600))
    report="${report}  PHANTOM: ${task_id} assigned=${assigned} status=${status} age=${age_h}h pr=${pr} branch=${branch}\n"

    if [ "$RELEASE" = true ]; then
      now_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      sed -i "s/^status:.*/status: offered/" "$note"
      sed -i "s/^assigned_to:.*/assigned_to: unassigned/" "$note"
      sed -i "s/^updated_at:.*/updated_at: $now_iso/" "$note"
      sed -i "/^## Session log$/a\\- $now_iso codex-claim-audit released phantom claim (${assigned}, ${age_h}h stale)" "$note"
      report="${report}    → RELEASED back to offered\n"
      claim_file="$CLAIM_CACHE_DIR/cc-active-task-$assigned"
      if [ -f "$claim_file" ]; then
        claimed_task=$(sed -n '1p' "$claim_file" 2>/dev/null || true)
        if [ "$claimed_task" = "$task_id" ]; then
          rm -f "$claim_file"
          report="${report}    → CLEARED stale claim cache $(basename "$claim_file")\n"
        else
          cache_mismatch_count=$((cache_mismatch_count + 1))
          report="${report}    → KEPT claim cache $(basename "$claim_file") because it names ${claimed_task:-<empty>}\n"
        fi
      fi
    fi
  fi
done

if [ -d "$CLAIM_CACHE_DIR" ]; then
  for claim_file in "$CLAIM_CACHE_DIR"/cc-active-task-*; do
    [ -f "$claim_file" ] || continue
    assigned="${claim_file##*/cc-active-task-}"
    claimed_task=$(sed -n '1p' "$claim_file" 2>/dev/null || true)
    [ -n "$claimed_task" ] || continue

    note="$VAULT_ROOT/active/$claimed_task.md"
    if [ ! -f "$note" ]; then
      note="$(_active_note_for "$claimed_task" 2>/dev/null || true)"
    fi
    if [ ! -f "$note" ]; then
      if [ "$RELEASE" = true ]; then
        rm -f "$claim_file"
        stale_cache_count=$((stale_cache_count + 1))
        cache_report="${cache_report}  CLEARED stale claim cache $(basename "$claim_file") task=${claimed_task} status=not_active\n"
      else
        _record_coherence "CACHE_STALE: $(basename "$claim_file") task=${claimed_task} status=not_active"
      fi
      continue
    fi

    note_assigned="$(_fm_value assigned_to "$note")"
    note_status="$(_fm_value status "$note")"
    if _is_claim_status "$note_status"; then
      note_is_active_claim=true
    else
      note_is_active_claim=false
    fi

    if [ "$note_is_active_claim" = false ] || [ "$note_assigned" != "$assigned" ]; then
      if [ "$RELEASE" = true ]; then
        rm -f "$claim_file"
        stale_cache_count=$((stale_cache_count + 1))
        cache_report="${cache_report}  CLEARED stale claim cache $(basename "$claim_file") task=${claimed_task} assigned=${note_assigned:-<none>} status=${note_status:-<none>}\n"
      else
        _record_coherence "CACHE_STALE: $(basename "$claim_file") task=${claimed_task} assigned=${note_assigned:-<none>} status=${note_status:-<none>}"
      fi
    fi
  done
fi

process_input=""
if [ -n "${HAPAX_CLAIM_AUDIT_PS_FIXTURE:-}" ]; then
  process_input="$(cat "$HAPAX_CLAIM_AUDIT_PS_FIXTURE" 2>/dev/null || true)"
else
  process_input="$(ps -eo pid=,etimes=,args= 2>/dev/null || true)"
fi

declare -A seen_process_issue=()
while IFS= read -r proc_line; do
  case "$proc_line" in
    *"Resume governed task "*) ;;
    *) continue ;;
  esac
  task_id="$(printf '%s\n' "$proc_line" | sed -nE 's/.*Resume governed task ([^ ]+).*/\1/p' | head -n1)"
  [ -n "$task_id" ] || continue
  role="$(printf '%s\n' "$proc_line" | grep -oP '(HAPAX_AGENT_ROLE|CODEX_ROLE|CLAUDE_ROLE)=\K[^ ]+' | head -n1 || true)"
  if [ -z "$role" ]; then
    role="$(printf '%s\n' "$proc_line" | grep -oP 'cc-active-task-\K[^ /]+' | head -n1 || true)"
  fi
  [ -n "$role" ] || role="<unknown>"
  pid="$(printf '%s\n' "$proc_line" | awk '{print $1}')"
  age_s="$(printf '%s\n' "$proc_line" | awk '{print $2}')"
  claim_file="$(_claim_file_for "$role")"
  claimed_task="$(_claim_file_task "$claim_file")"
  active_note="$(_active_note_for "$task_id" 2>/dev/null || true)"
  reason=""
  detail=""

  if [ -z "$active_note" ]; then
    reason="PROCESS_TASK_NOT_ACTIVE"
    detail="task_state=$(_any_note_status_for "$task_id")"
  elif ! _is_claim_status "$(_fm_value status "$active_note")"; then
    reason="PROCESS_TASK_NOT_CLAIMED"
    detail="task_status=$(_fm_value status "$active_note")"
  elif [ "$role" != "<unknown>" ] && [ "$(_fm_value assigned_to "$active_note")" != "$role" ]; then
    reason="PROCESS_ASSIGNEE_MISMATCH"
    detail="note_assigned=$(_fm_value assigned_to "$active_note")"
  elif [ "$claimed_task" != "$task_id" ]; then
    reason="PROCESS_CACHE_MISMATCH"
    detail="cache_task=${claimed_task:-<missing>}"
  fi

  [ -n "$reason" ] || continue
  key="${role}|${task_id}|${reason}|${detail}"
  if [ -n "${seen_process_issue[$key]:-}" ]; then
    continue
  fi
  seen_process_issue[$key]=1
  _record_process "${reason}: pid=${pid:-?} age_s=${age_s:-?} role=${role} task=${task_id} ${detail}"
done <<< "$process_input"

issue_count=$((phantom_count + coherence_count + process_count))

if [ "$issue_count" -gt 0 ]; then
  if [ "$phantom_count" -gt 0 ]; then
    printf "codex-claim-audit: %d phantom claim(s) found\n" "$phantom_count"
    printf '%b' "$report"
  fi
  if [ "$coherence_count" -gt 0 ]; then
    printf "codex-claim-audit: %d claim coherence issue(s) found\n" "$coherence_count"
    printf '%b' "$coherence_report"
  fi
  if [ "$process_count" -gt 0 ]; then
    printf "codex-claim-audit: %d live process coherence issue(s) found\n" "$process_count"
    printf '%b' "$process_report"
  fi
  if [ "$stale_cache_count" -gt 0 ]; then
    printf "codex-claim-audit: %d stale claim cache file(s) cleared\n" "$stale_cache_count"
    printf '%b' "$cache_report"
  fi

  if command -v curl >/dev/null 2>&1; then
    curl -s \
      -d "codex-claim-audit: $issue_count claim/lane issue(s) detected" \
      -H "Title: Codex Claim/Lane Coherence" \
      -H "Priority: default" \
      -H "Tags: warning,robot" \
      "$NTFY_URL/$NTFY_TOPIC" >/dev/null 2>&1 || true
  fi
  if [ "$RELEASE" = true ] && [ "$cache_mismatch_count" -eq 0 ] && [ "$coherence_count" -eq 0 ] && [ "$process_count" -eq 0 ]; then
    exit 0
  fi
  exit 1
else
  if [ "$stale_cache_count" -gt 0 ]; then
    printf "codex-claim-audit: %d stale claim cache file(s) cleared\n" "$stale_cache_count"
    printf '%b' "$cache_report"
  fi
  echo "codex-claim-audit: no phantom claims or claim/lane coherence issues found"
  exit 0
fi
