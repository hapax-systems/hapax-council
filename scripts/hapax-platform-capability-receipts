#!/usr/bin/env python3
"""Refresh local platform capability receipts without persisting secrets."""

from __future__ import annotations

import argparse
import hashlib
import json
import math
import os
import re
import shlex
import shutil
import socket
import subprocess
import sys
from datetime import UTC, datetime
from pathlib import Path
from typing import Any

REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from shared.platform_capability_receipts import (  # noqa: E402
    DEFAULT_PLATFORM_CAPABILITY_RECEIPT_DIR,
    PLATFORM_CAPABILITY_RECEIPT_DIR_ENV,
    CliEvidence,
    ConfigEvidence,
    EvidenceStatus,
    PlatformCapabilityReceipt,
    ProviderDocsEvidence,
    SurfaceEvidence,
    ToolEvidence,
    WrapperEvidence,
    receipt_reference,
)
from shared.platform_capability_registry import (  # noqa: E402
    PLATFORM_CAPABILITY_REGISTRY,
    PlatformCapabilityRoute,
    load_platform_capability_registry,
)

BINARY_BY_PLATFORM = {
    "agy": "agy",
    "api": "python3",
    "claude": "claude",
    "codex": "codex",
    "glmcp": "scripts/hapax-glmcp-reviewer",
    "vibe": "vibe",
}
VERSION_ARGS_BY_PLATFORM = {
    "agy": ["--version"],
    "api": ["--version"],
    "claude": ["--version"],
    "codex": ["--version"],
    "glmcp": ["--check"],
    "vibe": ["--version"],
}
CODEX_EXEC_AUTH_SENTINEL = "HAPAX_CODEX_EXEC_AUTH_OK"
HOST_ALIASES = {"appendix": "hapax-appendix", "podium": "hapax-podium"}
CONFIG_REFS_BY_PLATFORM = {
    "agy": [
        "~/.gemini/antigravity-cli/builtin/skills/antigravity_guide/references/cli.md",
        "scripts/hapax-agy-reviewer",
    ],
    "api": [
        "~/llm-stack/litellm-config.yaml",
        "~/llm-stack/docker-compose.yml",
        "~/llm-stack/.env",
        "scripts/hapax-methodology-dispatch",
        "config/quota-spend-ledger-fixtures.json",
    ],
    "claude": ["~/.claude/settings.json", "~/.claude.json", "CLAUDE.md"],
    "codex": ["~/.codex/config.toml", "~/.codex/AGENTS.md", "AGENTS.md"],
    "glmcp": [
        "scripts/hapax-glmcp-reviewer",
        "scripts/hapax-glmcp-quota-admission",
        "scripts/hapax-quota-telemetry-writer",
        "config/platform-capability-registry.json",
        "config/quota-spend-ledger-fixtures.json",
    ],
    "vibe": [
        "~/.vibe/config.toml",
        "~/.vibe/.env",
        "~/.cache/hapax/relay/onboarding-vbe.md",
    ],
}
SECRETISH_RE = re.compile(r"(?i)(api[_-]?key|token|secret|password|credential)([=:])(\S+)")
RETIRED_ANTIGRAV_PLATFORMS = frozenset({"antigrav", "antigravity", "gemini-cli"})


def parse_utc(value: str) -> datetime:
    raw = value.strip()
    if raw.endswith("Z"):
        raw = raw[:-1] + "+00:00"
    parsed = datetime.fromisoformat(raw)
    if parsed.tzinfo is None:
        return parsed.replace(tzinfo=UTC)
    return parsed.astimezone(UTC)


def iso_z(value: datetime) -> str:
    return value.astimezone(UTC).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def safe_text(value: str | None, *, limit: int = 500) -> str | None:
    if value is None:
        return None
    home = str(Path.home())
    sanitized = value.replace("\x00", "").replace(home, "~")
    sanitized = SECRETISH_RE.sub(r"\1\2<redacted>", sanitized)
    sanitized = " ".join(sanitized.split())
    if len(sanitized) > limit:
        return sanitized[: limit - 3] + "..."
    return sanitized


def display_path(path: Path) -> str:
    try:
        return str(path.expanduser().resolve()).replace(str(Path.home()), "~")
    except OSError:
        return str(path.expanduser()).replace(str(Path.home()), "~")


def resolve_ref(path_ref: str) -> Path:
    expanded = Path(path_ref).expanduser()
    if expanded.is_absolute():
        return expanded
    return REPO_ROOT / expanded


def launcher_command_path(route: PlatformCapabilityRoute) -> Path:
    try:
        command = shlex.split(route.sanctioned_wrapper)[0]
    except (IndexError, ValueError):
        command = route.sanctioned_wrapper.split()[0]
    return resolve_ref(command)


def sha256_file(path: Path) -> str | None:
    if not path.is_file():
        return None
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def candidate_binaries(platform: str) -> list[str]:
    override = os.environ.get(f"HAPAX_{platform.upper()}_BIN", "").strip()
    if platform == "codex":
        candidates = []
        candidates.append(BINARY_BY_PLATFORM[platform])
        path_override = os.environ.get("HAPAX_CODEX_BIN_PATH", "").strip()
        if path_override:
            candidates.append(path_override)
        candidates.extend(
            [
                str(Path.home() / ".npm-global" / "bin" / "codex"),
                *(
                    [f"{os.environ['NPM_CONFIG_PREFIX'].rstrip('/')}/bin/codex"]
                    if os.environ.get("NPM_CONFIG_PREFIX")
                    else []
                ),
                str(Path.home() / ".local" / "share" / "npm" / "bin" / "codex"),
                "/usr/local/bin/codex",
            ]
        )
        return list(dict.fromkeys(candidates))
    candidates = [BINARY_BY_PLATFORM[platform]]
    if override:
        candidates.insert(0, override)
    return list(dict.fromkeys(candidates))


def resolve_binary(binary: str) -> str | None:
    path = Path(binary).expanduser()
    if path.is_absolute():
        return str(path) if path.is_file() and os.access(path, os.X_OK) else None
    if "/" in binary:
        resolved = resolve_ref(binary)
        return str(resolved) if resolved.is_file() and os.access(resolved, os.X_OK) else None
    return shutil.which(binary)


def resolve_platform_binary(platform: str) -> tuple[str, str | None, list[str]]:
    attempted: list[str] = []
    binary = BINARY_BY_PLATFORM[platform]
    resolved = None
    for candidate in candidate_binaries(platform):
        attempted.append(candidate)
        resolved = resolve_binary(candidate)
        if resolved is not None:
            binary = candidate
            break
    return binary, resolved, attempted


def observe_cli(platform: str, *, timeout: float) -> CliEvidence:
    binary, resolved, attempted = resolve_platform_binary(platform)
    if resolved is None:
        return CliEvidence(
            binary=binary,
            available=False,
            error=f"{binary} not found; tried {', '.join(attempted)}",
        )
    command = [resolved, *VERSION_ARGS_BY_PLATFORM[platform]]
    try:
        result = subprocess.run(
            command,
            check=False,
            text=True,
            capture_output=True,
            timeout=timeout,
            env={**os.environ, "NO_COLOR": "1"},
        )
    except (OSError, subprocess.TimeoutExpired) as exc:
        return CliEvidence(binary=binary, available=False, error=safe_text(str(exc)))
    output = safe_text(result.stdout or result.stderr)
    if result.returncode != 0:
        return CliEvidence(
            binary=binary,
            available=False,
            version=output,
            error=safe_text(result.stderr or result.stdout or f"exit {result.returncode}"),
        )
    return CliEvidence(binary=binary, available=True, version=output)


def codex_exec_auth_sentinel_observed(stdout: str) -> bool:
    for line in stdout.splitlines():
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        if codex_exec_auth_event_text(event).strip() == CODEX_EXEC_AUTH_SENTINEL:
            return True
    return False


def codex_exec_auth_event_text(event: Any) -> str:
    if not isinstance(event, dict):
        return ""
    if event.get("type") == "item.completed":
        item = event.get("item")
        if isinstance(item, dict) and item.get("type") == "agent_message":
            text = item.get("text")
            return text if isinstance(text, str) else ""
    if event.get("type") == "response.output_text.done":
        text = event.get("text")
        return text if isinstance(text, str) else ""
    if event.get("role") == "assistant":
        return assistant_content_text(event.get("content"))
    message = event.get("message")
    if isinstance(message, dict) and message.get("role") == "assistant":
        return assistant_content_text(message.get("content"))
    return ""


def assistant_content_text(content: Any) -> str:
    if isinstance(content, str):
        return content
    if not isinstance(content, list):
        return ""
    parts = []
    for part in content:
        if isinstance(part, str):
            parts.append(part)
        elif isinstance(part, dict) and part.get("type") in {"text", "output_text"}:
            text = part.get("text")
            if isinstance(text, str):
                parts.append(text)
    return "\n".join(parts)


def normalize_host(value: str) -> str:
    return HOST_ALIASES.get(value.strip(), value.strip())


def current_host() -> str:
    return normalize_host(socket.gethostname().split(".", 1)[0])


def codex_exec_auth_host() -> str:
    explicit = os.environ.get("HAPAX_CODEX_EXEC_AUTH_HOST", "").strip()
    if explicit:
        return explicit
    dispatch_host = os.environ.get("HAPAX_DISPATCH_HOST", "").strip()
    if dispatch_host:
        return dispatch_host
    default_host = os.environ.get("HAPAX_DEFAULT_DISPATCH_HOST", "").strip()
    if default_host:
        return default_host
    return "appendix"


def codex_exec_auth_command(*, codex_bin: str, cwd: Path) -> list[str]:
    return [
        codex_bin,
        "exec",
        "--ephemeral",
        "--skip-git-repo-check",
        "--ignore-rules",
        "--sandbox",
        "read-only",
        "--json",
        "--cd",
        str(cwd),
        "Reply exactly: HAPAX_CODEX_EXEC_AUTH_OK",
    ]


def codex_exec_auth_env() -> dict[str, str]:
    env = {
        key: value
        for key in (
            "ALL_PROXY",
            "HOME",
            "HTTP_PROXY",
            "HTTPS_PROXY",
            "LANG",
            "LC_ALL",
            "NO_PROXY",
            "PATH",
            "REQUESTS_CA_BUNDLE",
            "SSL_CERT_FILE",
        )
        if (value := os.environ.get(key)) is not None
    }
    env["NO_COLOR"] = "1"
    env.pop("CODEX_ACCESS_TOKEN", None)
    env.pop("CODEX_HOME", None)
    env.pop("CODEX_API_KEY", None)
    env.pop("OPENAI_API_KEY", None)
    return env


def classify_codex_exec_auth_failure(output: str) -> list[str]:
    reasons = ["codex_exec_auth_failed"]
    if "agent identity JWT payload is not valid JSON" in output:
        reasons.append("codex_exec_auth_agent_identity_jwt_invalid_json")
    if "refresh_token_invalidated" in output:
        reasons.append("codex_exec_auth_refresh_token_invalidated")
    if re.search(r"(?<!refresh_)token_invalidated", output):
        reasons.append("codex_exec_auth_token_invalidated")
    if re.search(r"(?i)(login required|required to log in|please log in|not logged in)", output):
        reasons.append("codex_exec_auth_login_required")
    return reasons


def remote_codex_exec_auth_command(*, cwd: Path) -> str:
    inner = "unset CODEX_ACCESS_TOKEN CODEX_HOME CODEX_API_KEY OPENAI_API_KEY; exec " + shlex.join(
        codex_exec_auth_command(codex_bin="codex", cwd=cwd)
    )
    return "bash -lc " + shlex.quote(inner)


def observe_codex_exec_auth(*, enabled: bool, timeout: float) -> tuple[list[str], list[str]]:
    if not enabled:
        return [], ["codex_exec_auth_probe_not_requested"]
    if not math.isfinite(timeout) or timeout <= 0:
        return [], ["codex_exec_auth_invalid_timeout"]
    target_host = codex_exec_auth_host()
    normalized_target = normalize_host(target_host)
    try:
        if normalized_target in {"", "local", current_host()}:
            _, resolved, _ = resolve_platform_binary("codex")
            if resolved is None:
                return [], ["codex_exec_auth_binary_missing"]
            command = codex_exec_auth_command(codex_bin=resolved, cwd=REPO_ROOT)
            result = subprocess.run(
                command,
                check=False,
                text=True,
                capture_output=True,
                timeout=timeout,
                env=codex_exec_auth_env(),
            )
        else:
            remote_cwd = Path(os.environ.get("HAPAX_CODEX_EXEC_AUTH_REMOTE_CWD", str(Path.home())))
            remote_command = remote_codex_exec_auth_command(cwd=remote_cwd)
            result = subprocess.run(
                [
                    "ssh",
                    "-o",
                    "BatchMode=yes",
                    "-o",
                    f"ConnectTimeout={max(1, int(timeout))}",
                    target_host,
                    remote_command,
                ],
                check=False,
                text=True,
                capture_output=True,
                timeout=max(timeout + 5, 10),
                env=codex_exec_auth_env(),
            )
    except subprocess.TimeoutExpired:
        return [], ["codex_exec_auth_timeout"]
    except OSError:
        return [], ["codex_exec_auth_exec_failed"]
    if result.returncode == 0:
        if codex_exec_auth_sentinel_observed(result.stdout):
            host_ref = f"host:{normalized_target}:codex:exec:auth:saved-login:observed"
            if normalized_target in {"", "local", current_host()}:
                return ["local:codex:exec:auth:observed", host_ref], []
            return [f"remote:{normalized_target}:codex:exec:auth:observed", host_ref], []
        return [], ["codex_exec_auth_sentinel_missing"]

    output = safe_text("\n".join([result.stderr or "", result.stdout or ""]), limit=2000) or ""
    return [], classify_codex_exec_auth_failure(output)


def observe_wrapper(route: PlatformCapabilityRoute) -> WrapperEvidence:
    path = launcher_command_path(route)
    return WrapperEvidence(
        path=display_path(path),
        exists=path.exists(),
        executable=os.access(path, os.X_OK),
        sha256=sha256_file(path),
    )


def observe_wrappers(routes: list[PlatformCapabilityRoute]) -> list[WrapperEvidence]:
    wrappers: dict[str, WrapperEvidence] = {}
    for route in routes:
        wrapper = observe_wrapper(route)
        wrappers.setdefault(wrapper.path, wrapper)
    return [wrappers[path] for path in sorted(wrappers)]


def wrapper_reason_label(wrapper: WrapperEvidence) -> str:
    label = Path(wrapper.path).name or wrapper.path
    return re.sub(r"[^A-Za-z0-9_.-]+", "-", label).strip("-") or "unknown-wrapper"


def config_refs(platform: str) -> list[ConfigEvidence]:
    refs: list[ConfigEvidence] = []
    for path_ref in CONFIG_REFS_BY_PLATFORM[platform]:
        path = resolve_ref(path_ref)
        refs.append(ConfigEvidence(path=display_path(path), exists=path.exists()))
    return refs


def provider_doc_refs(routes: list[PlatformCapabilityRoute]) -> list[str]:
    refs: list[str] = []
    for route in routes:
        refs.extend(route.freshness.evidence.provider_docs.evidence_refs)
    return list(dict.fromkeys(refs))


def tool_state(routes: list[PlatformCapabilityRoute]) -> list[ToolEvidence]:
    by_tool: dict[str, ToolEvidence] = {}
    for route in routes:
        for tool in route.tool_state:
            by_tool.setdefault(
                tool.tool_id,
                ToolEvidence(
                    tool_id=tool.tool_id,
                    available=tool.available,
                    authority_use=[item.value for item in tool.authority_use],
                    evidence_ref=f"platform-capability-registry:{route.route_id}:tool:{tool.tool_id}",
                ),
            )
    return [by_tool[tool_id] for tool_id in sorted(by_tool)]


def surface_evidence(
    *,
    status: EvidenceStatus,
    source: str,
    observed_at: datetime,
    stale_after: str,
    evidence_refs: list[str] | None = None,
    reason_codes: list[str] | None = None,
) -> SurfaceEvidence:
    return SurfaceEvidence(
        status=status,
        source=source,
        observed_at=observed_at,
        stale_after=stale_after,
        evidence_refs=evidence_refs or [],
        reason_codes=reason_codes or [],
    )


def build_receipt(
    *,
    platform: str,
    routes: list[PlatformCapabilityRoute],
    observed_at: datetime,
    stale_after: str,
    provider_docs_stale_after: str,
    timeout: float,
    codex_exec_auth_timeout: float,
    codex_exec_auth_probe: bool,
) -> PlatformCapabilityReceipt:
    primary_route = routes[0]
    cli = observe_cli(platform, timeout=timeout)
    wrappers = observe_wrappers(routes)
    wrapper = wrappers[0] if wrappers else observe_wrapper(primary_route)
    route_ids = sorted(route.route_id for route in routes)
    receipt_id = f"{platform}-{observed_at.strftime('%Y%m%dT%H%M%SZ')}"
    capability_reasons: list[str] = []
    capability_refs: list[str] = []
    unusable_wrappers = [
        item for item in wrappers if not (item.exists and item.executable and item.sha256)
    ]
    wrapper_usable = not unusable_wrappers
    if cli.available:
        capability_refs.append(f"local:{platform}:cli-version:{cli.version or 'available'}")
    else:
        capability_reasons.append("cli_missing_or_unusable")
    capability_refs.extend(
        f"local:{item.path}:sha256:{item.sha256}" for item in wrappers if item.sha256
    )
    if not wrapper_usable:
        non_executable = [
            item
            for item in unusable_wrappers
            if item.exists and item.sha256 and not item.executable
        ]
        missing_or_unreadable = [
            item for item in unusable_wrappers if not item.exists or not item.sha256
        ]
        if non_executable:
            capability_reasons.append("sanctioned_wrapper_not_executable")
            capability_reasons.extend(
                f"sanctioned_wrapper_not_executable:{wrapper_reason_label(item)}"
                for item in non_executable
            )
        if missing_or_unreadable:
            capability_reasons.append("sanctioned_wrapper_missing_or_unreadable")
            capability_reasons.extend(
                f"sanctioned_wrapper_missing_or_unreadable:{wrapper_reason_label(item)}"
                for item in missing_or_unreadable
            )
    if platform == "codex":
        exec_auth_refs, exec_auth_reasons = observe_codex_exec_auth(
            enabled=codex_exec_auth_probe,
            timeout=codex_exec_auth_timeout,
        )
        capability_refs.extend(exec_auth_refs)
        capability_reasons.extend(exec_auth_reasons)
    capability_status = (
        EvidenceStatus.OBSERVED if not capability_reasons else EvidenceStatus.BLOCKED
    )
    if wrapper_usable:
        resource_status = EvidenceStatus.OBSERVED
        resource_reasons: list[str] = []
    elif any(item.exists and not item.executable for item in unusable_wrappers):
        resource_status = EvidenceStatus.BLOCKED
        resource_reasons = ["wrapper_not_executable"]
    else:
        resource_status = EvidenceStatus.MISSING
        resource_reasons = ["wrapper_missing"]
    resource_refs = [
        ref
        for item in wrappers
        for ref in (
            f"local:{item.path}:exists:{str(item.exists).lower()}",
            f"local:{item.path}:executable:{str(item.executable).lower()}",
        )
    ]
    quota_reason = "account_live_quota_receipt_absent"
    quota = surface_evidence(
        status=EvidenceStatus.UNOBSERVABLE,
        source="local_receipt_probe",
        observed_at=observed_at,
        stale_after="15m",
        evidence_refs=[f"local:{platform}:quota-probe:unobservable"],
        reason_codes=[quota_reason],
    )
    provider_refs = provider_doc_refs(routes)
    if not provider_refs:
        provider_refs = [f"platform-capability-registry:{platform}:provider-docs:absent"]
    receipt = PlatformCapabilityReceipt(
        receipt_id=receipt_id,
        platform=platform,
        routes=route_ids,
        observed_at=observed_at,
        stale_after=stale_after,
        cli=cli,
        wrapper=wrapper,
        config_refs=config_refs(platform),
        tool_state=tool_state(routes),
        mcp_status=sorted({mcp for route in routes for mcp in route.tool_access.mcp}),
        capability=surface_evidence(
            status=capability_status,
            source="local_receipt_probe",
            observed_at=observed_at,
            stale_after=stale_after,
            evidence_refs=capability_refs,
            reason_codes=capability_reasons,
        ),
        resource=surface_evidence(
            status=resource_status,
            source="local_receipt_probe",
            observed_at=observed_at,
            stale_after=stale_after,
            evidence_refs=resource_refs,
            reason_codes=resource_reasons,
        ),
        quota=quota,
        provider_docs=ProviderDocsEvidence(
            refs=provider_refs,
            fetched_at=observed_at,
            stale_after=provider_docs_stale_after,
            fetch_status=EvidenceStatus.OBSERVED,
        ),
        known_unknowns=known_unknowns_for(platform),
    )
    receipt.capability.evidence_refs.append(receipt_reference(receipt))
    receipt.resource.evidence_refs.append(receipt_reference(receipt))
    receipt.quota.evidence_refs.append(receipt_reference(receipt))
    return receipt


def known_unknowns_for(platform: str) -> list[str]:
    unknowns = []
    if platform == "api":
        unknowns.insert(
            0,
            "Provider spend is authorized by the quota/spend ledger, not by this local receipt.",
        )
        unknowns.append(
            "Receipt command records config paths and existence only; it never reads secret values."
        )
    elif platform == "glmcp":
        unknowns.extend(
            [
                "GLMCP quota freshness is admitted by short-lived quota-spend-ledger receipts; this local receipt only checks wrapper/config/docs/resource surfaces.",
                "GLMCP receipt refresh may read the pass-backed secret to verify wrapper availability; it records only redacted metadata and never persists the secret value.",
            ]
        )
    elif platform == "codex":
        unknowns.insert(
            0,
            "Account-live subscription quota is not exposed by the local receipt probe.",
        )
        unknowns.append(
            "Codex exec-auth probe runs a bounded saved-login codex exec sentinel on the effective dispatch host; it never injects or persists bearer tokens."
        )
    else:
        unknowns.insert(
            0,
            "Account-live subscription quota is not exposed by the local receipt probe.",
        )
        unknowns.append(
            "Receipt command records config paths and existence only; it never reads secret values."
        )
    return unknowns


def platform_routes(
    registry_routes: list[PlatformCapabilityRoute],
) -> dict[str, list[PlatformCapabilityRoute]]:
    routes: dict[str, list[PlatformCapabilityRoute]] = {}
    for route in registry_routes:
        platform = route.platform.value
        if platform in BINARY_BY_PLATFORM:
            routes.setdefault(platform, []).append(route)
    return routes


def write_receipt(receipt: PlatformCapabilityReceipt, receipt_dir: Path) -> Path:
    receipt_dir.mkdir(parents=True, exist_ok=True)
    path = receipt_dir / f"{receipt.platform}.json"
    path.write_text(
        json.dumps(receipt.model_dump(mode="json"), indent=2, sort_keys=True), encoding="utf-8"
    )
    return path


def positive_float_env_default(name: str, default: float) -> float:
    raw = os.environ.get(name)
    if raw is None or raw == "":
        return default
    try:
        value = float(raw)
    except (TypeError, ValueError):
        print(
            f"hapax-platform-capability-receipts: invalid {name}={raw!r}; using {default:g}s",
            file=sys.stderr,
        )
        return default
    if not math.isfinite(value):
        print(
            f"hapax-platform-capability-receipts: invalid {name}={raw!r}; using {default:g}s",
            file=sys.stderr,
        )
        return default
    if value <= 0:
        print(
            f"hapax-platform-capability-receipts: nonpositive {name}={raw!r}; using {default:g}s",
            file=sys.stderr,
        )
        return default
    return value


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--registry", type=Path, default=PLATFORM_CAPABILITY_REGISTRY)
    parser.add_argument(
        "--receipt-dir",
        type=Path,
        default=Path(
            os.environ.get(
                PLATFORM_CAPABILITY_RECEIPT_DIR_ENV,
                str(DEFAULT_PLATFORM_CAPABILITY_RECEIPT_DIR),
            )
        ),
    )
    parser.add_argument("--platform", action="append", default=[])
    parser.add_argument("--all", action="store_true", help="Refresh every known coding platform")
    parser.add_argument("--now", help="Override observation time as ISO-8601 UTC")
    parser.add_argument("--stale-after", default="24h")
    parser.add_argument("--provider-docs-stale-after", default="30d")
    parser.add_argument("--timeout", type=float, default=5.0)
    parser.add_argument(
        "--codex-exec-auth-timeout",
        type=float,
        default=positive_float_env_default("HAPAX_CODEX_EXEC_AUTH_TIMEOUT_SECONDS", 30.0),
        help=(
            "Timeout in seconds for the bounded Codex exec-auth sentinel. "
            "Defaults to HAPAX_CODEX_EXEC_AUTH_TIMEOUT_SECONDS or 30."
        ),
    )
    parser.add_argument(
        "--codex-exec-auth-probe",
        action="store_true",
        help=(
            "For Codex receipts, run a bounded codex exec probe and only emit "
            "exec-auth evidence if the dispatch auth path succeeds."
        ),
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help=(
            "Do not write receipts. Observation probes still run, including "
            "--codex-exec-auth-probe when that flag is supplied."
        ),
    )
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args(argv)

    observed_at = parse_utc(args.now) if args.now else datetime.now(UTC).replace(microsecond=0)
    registry = load_platform_capability_registry(args.registry)
    routes_by_platform = platform_routes(registry.routes)
    selected = (
        sorted(routes_by_platform)
        if args.all or not args.platform
        else [platform.lower() for platform in args.platform]
    )
    unknown = sorted(set(selected) - set(routes_by_platform))
    if unknown:
        retired = [platform for platform in unknown if platform in RETIRED_ANTIGRAV_PLATFORMS]
        for platform in retired:
            print(
                f"platform '{platform}' is retired/excised; use agy.review.direct for "
                "the live read-only review route",
                file=sys.stderr,
            )
        if retired:
            retired_set = set(retired)
            unknown = [platform for platform in unknown if platform not in retired_set]
        if unknown:
            print(f"unknown platform(s): {', '.join(unknown)}", file=sys.stderr)
        return 2

    outputs: list[dict[str, Any]] = []
    for platform in selected:
        receipt = build_receipt(
            platform=platform,
            routes=routes_by_platform[platform],
            observed_at=observed_at,
            stale_after=args.stale_after,
            provider_docs_stale_after=args.provider_docs_stale_after,
            timeout=args.timeout,
            codex_exec_auth_timeout=args.codex_exec_auth_timeout,
            codex_exec_auth_probe=args.codex_exec_auth_probe,
        )
        path = None if args.dry_run else write_receipt(receipt, args.receipt_dir)
        outputs.append(
            {
                "platform": platform,
                "receipt_id": receipt.receipt_id,
                "path": str(path) if path else None,
                "cli_available": receipt.cli.available,
                "wrapper_exists": receipt.wrapper.exists,
                "capability_status": receipt.capability.status.value,
                "capability_reason_codes": receipt.capability.reason_codes,
                "resource_status": receipt.resource.status.value,
                "resource_reason_codes": receipt.resource.reason_codes,
                "quota_status": receipt.quota.status.value,
                "quota_reason_codes": receipt.quota.reason_codes,
            }
        )

    payload = {
        "ok": True,
        "observed_at": iso_z(observed_at),
        "receipt_dir": str(args.receipt_dir),
        "dry_run": args.dry_run,
        "receipts": outputs,
    }
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        for item in outputs:
            target = item["path"] or "<dry-run>"
            print(
                f"{item['platform']}: wrote {target} "
                f"cli={item['cli_available']} wrapper={item['wrapper_exists']} "
                f"quota={item['quota_status']}"
            )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
