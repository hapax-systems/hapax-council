#!/usr/bin/env bash
# hapax-codex-headless - Launch a Codex lane non-interactively via `codex exec`.
#
# The genuine headless analog to hapax-claude-headless: NO tmux pane. Codex runs
# non-interactively, JSONL events stream to a log the headless-staleness watchdog
# can read, a PID file marks the run live, and the same identity-env + governed
# task-gate + hook wiring as hapax-codex applies. Default-deny: headless lanes
# mutate source autonomously, so a governed enable must exist first.

set -euo pipefail

COUNCIL_DIR="${HAPAX_COUNCIL_DIR:-$HOME/projects/hapax-council}"
if ! declare -F hapax_agent_is_codex_name >/dev/null 2>&1; then
  hapax_agent_is_codex_name() {
    case "${1:-}" in
      cx-[a-z]*) return 0 ;;
      *) return 1 ;;
    esac
  }
fi

DISABLE_FILE="${HAPAX_CODEX_HEADLESS_DISABLE_FILE:-$HOME/.cache/hapax/disable-codex-headless}"
ENABLE_FILE="${HAPAX_CODEX_HEADLESS_ENABLE_FILE:-$HOME/.cache/hapax/enable-codex-headless}"

headless_allowed() {
  [[ "${HAPAX_CODEX_HEADLESS_ALLOW:-}" == "1" || -e "$ENABLE_FILE" ]]
}

relay_retired() {
  local relay_name="$1"
  local relay_file="${HAPAX_RELAY_DIR:-$HOME/.cache/hapax/relay}/$relay_name.yaml"
  local value
  [ -f "$relay_file" ] || return 1
  while IFS= read -r value; do
    if relay_value_is_retired "$value"; then
      return 0
    fi
  done < <(relay_current_values "$relay_file")
  return 1
}

relay_current_values() {
  local relay_file="$1"
  awk '
    BEGIN { in_session_status = 0 }

    in_session_status {
      if ($0 ~ /^[[:space:]]*$/) {
        next
      }
      if ($0 !~ /^[[:space:]]+/) {
        in_session_status = 0
      } else {
        value = $0
        sub(/^[[:space:]]+/, "", value)
        print value
        in_session_status = 0
        next
      }
    }

    /^(status|state|relay_status|session_state|role):[[:space:]]*/ {
      value = $0
      sub(/^[^:]+:[[:space:]]*/, "", value)
      if (value !~ /^[|>]/) {
        print value
      }
      next
    }

    /^session_status:[[:space:]]*/ {
      value = $0
      sub(/^session_status:[[:space:]]*/, "", value)
      if (value ~ /^[|>]/) {
        in_session_status = 1
        next
      }
      print value
      next
    }
  ' "$relay_file"
}

relay_value_is_retired() {
  local value="$1"
  local normalized first_word
  normalized="$(printf '%s' "$value" | sed "s/^[[:space:]\"']*//; s/[[:space:]\"']*$//" | tr '[:lower:]' '[:upper:]')"
  first_word="${normalized%%[[:space:]]*}"
  case "$first_word" in
    RETIRED*|SUPERSEDED*|CLOSED*|IDLE_WOUND_DOWN*|WIND_DOWN_IDLE*|WOUND_DOWN*|WIND_DOWN*|WINDING_DOWN*|ANTIGRAVITY_TAKEOVER)
      return 0
      ;;
  esac
  case "$normalized" in
    RETIRED*|SUPERSEDED*|CLOSED*|IDLE_WOUND_DOWN*|WIND_DOWN_IDLE*|WOUND_DOWN*|WIND_DOWN*|WINDING_DOWN*|ANTIGRAVITY_TAKEOVER)
      return 0
      ;;
  esac
  return 1
}

dispatch_host_is_local() {
  local host="${1:-}" short="" fqdn="" local_ip="" resolved_ip=""
  [[ -z "$host" || "$host" == "local" || "$host" == "localhost" ]] && return 0
  [[ "$host" == "127.0.0.1" || "$host" == "::1" ]] && return 0
  short="$(hostname -s 2>/dev/null || hostname 2>/dev/null || true)"
  fqdn="$(hostname -f 2>/dev/null || true)"
  [[ "$host" == "appendix" ]] && host="hapax-appendix"
  [[ "$host" == "podium" ]] && host="hapax-podium"
  [[ -n "$short" && "$host" == "$short" ]] && return 0
  [[ -n "$fqdn" && "$host" == "$fqdn" ]] && return 0
  for local_ip in $(hostname -I 2>/dev/null || true); do
    [[ "$host" == "$local_ip" ]] && return 0
  done
  if command -v getent >/dev/null 2>&1; then
    for resolved_ip in $(getent ahosts "$host" 2>/dev/null | awk '{print $1}'); do
      for local_ip in $(hostname -I 2>/dev/null || true); do
        [[ "$resolved_ip" == "$local_ip" ]] && return 0
      done
    done
  fi
  return 1
}

launcher_source_root() {
  local launcher="${BASH_SOURCE[0]}" root="" activation_root="$HOME/.cache/hapax/source-activation/worktree"
  if [[ -x /usr/bin/readlink ]]; then
    launcher="$(/usr/bin/readlink -f "$launcher" 2>/dev/null || printf '%s' "$launcher")"
  fi
  if root="$(cd "$(dirname "$launcher")/.." 2>/dev/null && pwd -P)"; then
    if [[ -r "$root/shared/governance/dispatch_redemption.py" ]]; then
      printf '%s\n' "$root"
      return 0
    fi
  fi
  if [[ -r "$activation_root/shared/governance/dispatch_redemption.py" ]]; then
    (cd "$activation_root" && pwd -P)
    return 0
  fi
  printf '%s\n' "$root"
}

remote_python_command() {
  local payload="$1" code="$2"
  local code_b64="" bash_script="" quoted_script="" quoted_payload="" quoted_code=""
  code_b64="$(printf '%s' "$code" | python3 -c 'import base64,sys; print(base64.b64encode(sys.stdin.buffer.read()).decode())')"
  # shellcheck disable=SC2016
  bash_script='export HAPAX_REMOTE_PAYLOAD="$1"; export HAPAX_REMOTE_CODE="$2"; exec python3 -c "import base64,os; exec(base64.b64decode(os.environ[\"HAPAX_REMOTE_CODE\"]))"'
  quoted_script="${bash_script//\'/\'\\\'\'}"
  quoted_payload="${payload//\'/\'\\\'\'}"
  quoted_code="${code_b64//\'/\'\\\'\'}"
  printf "bash -c '%s' bash '%s' '%s'" "$quoted_script" "$quoted_payload" "$quoted_code"
}

remote_preflight_payload_b64() {
  python3 - "$WORKDIR" "$COUNCIL_DIR" "$HOME/projects/hapax-mcp" <<'PYEOF'
import base64
import json
import sys

workdir, council_dir, mcp_dir = sys.argv[1:4]
payload = {
    "required_dirs": [workdir, council_dir, mcp_dir],
    "executables": [f"{council_dir}/hooks/scripts/codex-hook-adapter.sh"],
    "binaries": ["python3", "codex"],
}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

remote_worktree_payload_b64() {
  python3 - "$WORKDIR" "$COUNCIL_DIR" "$SESSION" \
    "${HAPAX_CODEX_WORKTREE_BASE:-main}" "${HAPAX_CODEX_BRANCH_PREFIX:-codex}" \
    "${HAPAX_CODEX_CREATE_WORKTREE:-1}" "$WORKDIR_EXPLICIT" <<'PYEOF'
import base64
import json
import sys

workdir, council_dir, session, base_ref, branch_prefix, create_worktree, workdir_explicit = (
    sys.argv[1:8]
)
payload = {
    "workdir": workdir,
    "council_dir": council_dir,
    "session": session,
    "base_ref": base_ref or "main",
    "branch": f"{branch_prefix or 'codex'}/{session}",
    "create_worktree": create_worktree == "1",
    "workdir_explicit": workdir_explicit == "1",
}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

remote_exec_payload_b64() {
  local proof_file="$1"
  shift
  python3 - "$WORKDIR" "$proof_file" "${DISPATCH_HOST_REQUESTED:-}" "$LOGOS_BASE_URL" \
    "$COCKPIT_BASE_URL" "$SESSION" "$CODEX_TASK" "$@" <<'PYEOF'
import base64
import json
import os
import sys

workdir, proof_file, requested_host, logos_url, cockpit_url, session, task_id = sys.argv[1:8]
argv = sys.argv[8:]
env = {
    "LOGOS_BASE_URL": logos_url,
    "COCKPIT_BASE_URL": cockpit_url,
    "HAPAX_DISPATCH_HOST": "local",
    "HAPAX_DISPATCH_REQUESTED_HOST": requested_host,
    "HAPAX_DISPATCH_LOGOS_URL": logos_url,
    "HAPAX_DISPATCH_PROOF_FILE": proof_file,
    "HAPAX_DISPATCH_REMOTE_INNER": "1",
    "HAPAX_AGENT_INTERFACE": "codex",
    "HAPAX_AGENT_NAME": session,
    "CODEX_THREAD_NAME": session,
    "CODEX_ROLE": session,
    "HAPAX_AGENT_ROLE": session,
}
for name in (
    "CLAUDE_ROLE",
    "HAPAX_AGENT_SLOT",
    "HAPAX_WORKTREE_ROLE",
    "HAPAX_SESSION_ID",
    "HAPAX_PARENT_AGENT_INTERFACE",
    "HAPAX_PARENT_AGENT_NAME",
    "HAPAX_METHODOLOGY_DISPATCH_TASK",
    "HAPAX_IDLE_UPDATE_SECONDS",
    "PASSWORD_STORE_DIR",
):
    value = os.environ.get(name)
    if value is not None:
        env[name] = value
payload = {
    "workdir": workdir,
    "proof_file": proof_file,
    "requested_host": requested_host,
    "session": session,
    "task_id": task_id,
    "env": env,
    "argv": argv,
}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

REMOTE_PREFLIGHT_PY='import base64,json,os,shutil,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"]));
missing_dirs=[path for path in p.get("required_dirs",()) if not os.path.isdir(path)]
missing_exec=[path for path in p.get("executables",()) if not (os.path.isfile(path) and os.access(path, os.X_OK))]
missing_bins=[binary for binary in p.get("binaries",()) if not shutil.which(binary)]
if missing_dirs or missing_exec or missing_bins:
    print("remote preflight failed: missing_dirs="+json.dumps(missing_dirs)+" missing_executables="+json.dumps(missing_exec)+" missing_binaries="+json.dumps(missing_bins)+"; next action: ssh to the dispatch host and install or repair the missing paths before retrying", file=sys.stderr)
    sys.exit(1)
sys.exit(0)'
REMOTE_WORKTREE_PY='import base64,json,os,shutil,subprocess,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); workdir=p["workdir"]; council=p["council_dir"];
def fail(message):
    print("remote worktree bootstrap refused: "+message+"; next action: ssh to the dispatch host and verify the council checkout, target worktree path, git binary, and HAPAX_CODEX_CREATE_WORKTREE before retrying", file=sys.stderr)
    sys.exit(1)
if os.path.isdir(workdir):
    sys.exit(0)
if p.get("workdir_explicit"):
    fail("explicit HAPAX_CODEX_HEADLESS_WORKDIR is missing on dispatch host: "+workdir)
if not p.get("create_worktree"):
    fail("worktree creation disabled by HAPAX_CODEX_CREATE_WORKTREE=0 and default workdir is missing on dispatch host: "+workdir)
if not os.path.isdir(council):
    fail("council checkout missing on dispatch host: "+council)
if shutil.which("git") is None:
    fail("git binary missing on dispatch host")
if subprocess.run(["git","-C",council,"rev-parse","--is-inside-work-tree"],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL).returncode != 0:
    fail("council checkout is not a git worktree: "+council)
os.makedirs(os.path.dirname(workdir),exist_ok=True)
base=p.get("base_ref") or "main"
if subprocess.run(["git","-C",council,"rev-parse","--verify","--quiet",base],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL).returncode != 0:
    base="HEAD"
branch=p.get("branch") or "codex/"+p.get("session","cx-headless")
if subprocess.run(["git","-C",council,"show-ref","--verify","--quiet","refs/heads/"+branch],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL).returncode == 0:
    cmd=["git","-C",council,"worktree","add",workdir,branch]
else:
    cmd=["git","-C",council,"worktree","add","-b",branch,workdir,base]
result=subprocess.run(cmd,stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL)
if result.returncode != 0 or not os.path.isdir(workdir):
    fail("git worktree add failed for "+workdir+" using branch "+branch+" (rc="+str(result.returncode)+")")
sys.exit(0)'
REMOTE_EXEC_PY='import base64,json,os,socket,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); os.chdir(p["workdir"]); os.environ.update(p.get("env",{})); proof=p.get("proof_file",""); cgroup="";
try:
    cgroup=open("/proc/self/cgroup",encoding="utf-8").read()
except OSError:
    pass
# Exec-host identity materialization mirrors hapax-claude-headless: the
# session-keyed claim must exist where codex exec runs, or the worker can fall
# back to stale legacy lane state and reject the governed dispatch.
sid=os.environ.get("HAPAX_SESSION_ID",""); role=os.environ.get("HAPAX_AGENT_ROLE",""); task=os.environ.get("HAPAX_METHODOLOGY_DISPATCH_TASK",""); keyable=False; materialized=False
try:
    sys.path.insert(0, p["workdir"])
    from shared.session_identity import is_claim_keyable_session_id
    keyable=is_claim_keyable_session_id(sid)
except Exception:
    keyable=bool(sid) and "/" not in sid and not sid.isdigit() and not sid.rsplit("-",1)[-1].isdigit()
try:
    if keyable and role:
        cache=os.path.join(os.path.expanduser("~"),".cache","hapax")
        os.makedirs(cache,exist_ok=True)
        open(os.path.join(cache,"session-role-"+sid),"w",encoding="utf-8").write(role+"\n")
        if task:
            import time as _time
            epoch_line=str(int(_time.time()))+" "+task+"\n"
            open(os.path.join(cache,"cc-claim-epoch-"+role),"w",encoding="utf-8").write(epoch_line)
            open(os.path.join(cache,"cc-claim-epoch-"+role+"-"+sid),"w",encoding="utf-8").write(epoch_line)
            open(os.path.join(cache,"cc-active-task-"+role),"w",encoding="utf-8").write(task+"\n")
            open(os.path.join(cache,"cc-active-task-"+role+"-"+sid),"w",encoding="utf-8").write(task+"\n")
            materialized=True
except Exception:
    pass
if proof:
    os.makedirs(os.path.dirname(proof), exist_ok=True)
    data={"schema_version":1,"event":"dispatch_remote_exec","platform":"codex-headless","session":p.get("session"),"task_id":p.get("task_id"),"requested_host":p.get("requested_host"),"actual_host":socket.gethostname(),"pid":os.getpid(),"cgroup":cgroup,"workdir":p.get("workdir"),"logos_base_url":os.environ.get("LOGOS_BASE_URL"),"argv0":p["argv"][0] if p.get("argv") else None,"argc":len(p.get("argv",[])),"session_id":sid or None,"role":role or None,"claim_materialized":materialized}; open(proof,"w",encoding="utf-8").write(json.dumps(data,sort_keys=True)+"\n")
argv=p["argv"]; os.execvp(argv[0], argv)'

usage() {
  cat >&2 <<'EOF'
usage: hapax-codex-headless [--task TASK_ID] [--no-claim] [--force] <cx-session> <governed-initial-message> [-- codex exec args...]

Default-deny: enable with `touch ~/.cache/hapax/enable-codex-headless` or
HAPAX_CODEX_HEADLESS_ALLOW=1. The governed initial message is the codex exec
prompt; everything after `--` is passed through to `codex exec`.
EOF
}

SESSION=""
CODEX_TASK="${HAPAX_METHODOLOGY_DISPATCH_TASK:-}"
CLAIM_TASK=1
FORCE=0
CODEX_EXTRA=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --task)
      CODEX_TASK="${2:-}"
      shift 2
      ;;
    --task=*)
      CODEX_TASK="${1#--task=}"
      shift
      ;;
    --no-claim)
      CLAIM_TASK=0
      shift
      ;;
    --force)
      FORCE=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      SESSION="$1"
      shift
      break
      ;;
  esac
done

if [[ -z "$SESSION" ]]; then
  usage
  exit 1
fi
if ! hapax_agent_is_codex_name "$SESSION"; then
  echo "hapax-codex-headless: invalid session '$SESSION' (expected cx-<color>)" >&2
  exit 2
fi

INITIAL_MSG="${1:-}"
[[ $# -gt 0 ]] && shift
# Strip an optional `--` separator, then pass the rest through to `codex exec`.
[[ "${1:-}" == "--" ]] && shift
if [[ $# -gt 0 ]]; then
  CODEX_EXTRA+=("$@")
fi

if [[ -z "$INITIAL_MSG" ]]; then
  echo "hapax-codex-headless: governed initial message required" >&2
  exit 5
fi

if [[ -e "$DISABLE_FILE" ]]; then
  echo "hapax-codex-headless: disabled by $DISABLE_FILE" >&2
  exit 77
fi
if ! headless_allowed; then
  echo "hapax-codex-headless: disabled until governed enable exists at $ENABLE_FILE or HAPAX_CODEX_HEADLESS_ALLOW=1 is set" >&2
  echo "  enable with: touch $ENABLE_FILE" >&2
  exit 77
fi

RELAY_STATUS_FILE="${HAPAX_RELAY_DIR:-$HOME/.cache/hapax/relay}/$SESSION.yaml"
if [[ "$FORCE" -ne 1 ]] && relay_retired "$SESSION"; then
  echo "hapax-codex-headless: relay '$SESSION' is retired/wound-down ($RELAY_STATUS_FILE); recheck: sed -n '1,80p' \"$RELAY_STATUS_FILE\"; pass --force to reactivate (P0 drain lanes do this automatically)" >&2
  exit 6
fi

# Worktree selection mirrors hapax-codex's codex-native default.
WORKDIR_EXPLICIT=0
if [[ -n "${HAPAX_CODEX_HEADLESS_WORKDIR:-}" ]]; then
  WORKDIR="$HAPAX_CODEX_HEADLESS_WORKDIR"
  WORKDIR_EXPLICIT=1
else
  WORKDIR="$HOME/projects/hapax-council--$SESSION"
fi
if [[ ! -d "$WORKDIR" && "$WORKDIR_EXPLICIT" -eq 0 ]]; then
  WORKDIR="$COUNCIL_DIR"
fi
[[ -d "$WORKDIR" ]] || { echo "hapax-codex-headless: worktree not found: $WORKDIR" >&2; exit 3; }
# Physical resolution (-P): redemption classification must see what the path
# RESOLVES to, matching dispatcher-side is_external_project_worktree. A
# council-prefixed symlink or /../ spelling of an external tree must not be
# exempted by its textual name.
WORKDIR="$(cd "$WORKDIR" && pwd -P)"

HOOK="$COUNCIL_DIR/hooks/scripts/codex-hook-adapter.sh"
[[ -x "$HOOK" ]] || { echo "hapax-codex-headless: hook adapter not executable: $HOOK" >&2; exit 6; }

# Identity env — same contract as hapax-codex so the gate keys a session-scoped
# claim lease (reform Phase 1, FM-2) and the hooks recover this lane's role.
PARENT_INTERFACE="${HAPAX_PARENT_AGENT_INTERFACE:-${HAPAX_AGENT_INTERFACE:-unknown}}"
PARENT_NAME="${HAPAX_PARENT_AGENT_NAME:-${HAPAX_AGENT_NAME:-unknown}}"
SESSION_UUID="${HAPAX_SESSION_ID:-$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen 2>/dev/null || printf '%s-%s' "$SESSION" "$$")}"
export HAPAX_PARENT_AGENT_INTERFACE="$PARENT_INTERFACE"
export HAPAX_PARENT_AGENT_NAME="$PARENT_NAME"
export HAPAX_AGENT_INTERFACE="codex"
export HAPAX_AGENT_NAME="$SESSION"
export CODEX_THREAD_NAME="$SESSION"
export CODEX_ROLE="$SESSION"
export HAPAX_AGENT_ROLE="$SESSION"
export HAPAX_AGENT_SLOT="${HAPAX_AGENT_SLOT:-alpha}"
export HAPAX_WORKTREE_ROLE="$HAPAX_AGENT_SLOT"
export HAPAX_SESSION_ID="$SESSION_UUID"
export CLAUDE_ROLE="${CLAUDE_ROLE:-$SESSION}"
export HAPAX_IDLE_UPDATE_SECONDS="${HAPAX_IDLE_UPDATE_SECONDS:-270}"
export PASSWORD_STORE_DIR="${PASSWORD_STORE_DIR:-$HOME/.password-store}"
export LOGOS_BASE_URL
export COCKPIT_BASE_URL

# Governed task gate (mirrors hapax-claude-headless): refuse a mutating launch
# without an explicit task or an existing session claim, and never launch onto a
# claim that belongs to a different task.
SESSION_CLAIM_FILE="$HOME/.cache/hapax/cc-active-task-$SESSION-$SESSION_UUID"
CLAIM_FILE="$HOME/.cache/hapax/cc-active-task-$SESSION"
CLAIMED_TASK=""
if [[ -s "$SESSION_CLAIM_FILE" ]]; then
  CLAIMED_TASK="$(head -n1 "$SESSION_CLAIM_FILE" | tr -d '[:space:]')"
elif [[ -s "$CLAIM_FILE" ]]; then
  CLAIMED_TASK="$(head -n1 "$CLAIM_FILE" | tr -d '[:space:]')"
fi
if [[ -z "$CODEX_TASK" && -n "$CLAIMED_TASK" ]]; then
  CODEX_TASK="$CLAIMED_TASK"
fi
if [[ -z "$CODEX_TASK" ]]; then
  echo "hapax-codex-headless: refusing mutating launch without --task <cc-task-id> or existing active claim for '$SESSION'" >&2
  exit 15
fi
if [[ -n "$CLAIMED_TASK" && "$CLAIMED_TASK" != "$CODEX_TASK" ]]; then
  echo "hapax-codex-headless: refusing launch; '$SESSION' already claims '$CLAIMED_TASK', not dispatch task '$CODEX_TASK'" >&2
  exit 13
fi

workdir_requires_dispatch_redemption() {
  [[ "${HAPAX_METHODOLOGY_DISPATCH_EXTERNAL:-}" == "1" ]] && return 0
  case "$WORKDIR" in
    "$HOME/projects/hapax-council"|"$HOME/projects/hapax-council--"*) return 1 ;;
    *) return 0 ;;
  esac
}

validate_dispatch_redemption_authority() {
  # Redemption parity with hapax-claude-headless: the verifier imports from
  # this launcher's physical council checkout, never from caller-controlled
  # HAPAX_COUNCIL_DIR, PATH, the external WORKDIR, or cwd (`python -` puts cwd
  # at sys.path[0]).
  local council_dir python_bin="/usr/bin/python3" profile="${HAPAX_METHODOLOGY_DISPATCH_PROFILE:-full}"
  council_dir="$(launcher_source_root)"
  if ! "$python_bin" - "$council_dir" "$CODEX_TASK" "$SESSION" "$WORKDIR" codex headless "$profile" <<'PYEOF'
import os
import sys
import time

council_dir, task_id, lane, worktree, platform, mode, profile = sys.argv[1:]
sys.path = [council_dir] + [p for p in sys.path if p not in ("", os.getcwd())]

try:
    from shared.governance.dispatch_redemption import (
        LaunchRedemptionContext,
        LaunchRedemptionRequest,
        redeem_launch_via_socket,
    )
except Exception as exc:  # noqa: BLE001
    print(f"cannot import dispatch redemption verifier: {exc}", file=sys.stderr)
    raise SystemExit(1)

token = os.environ.get("HAPAX_METHODOLOGY_DISPATCH_REDEMPTION_TOKEN", "").strip()
message_id = os.environ.get("HAPAX_METHODOLOGY_DISPATCH_MESSAGE_ID", "").strip()
route_decision_ref = os.environ.get(
    "HAPAX_METHODOLOGY_DISPATCH_ROUTE_DECISION_REF", ""
).strip()
authority_case = os.environ.get("HAPAX_METHODOLOGY_DISPATCH_AUTHORITY_CASE", "").strip()
parent_spec = os.environ.get("HAPAX_METHODOLOGY_DISPATCH_PARENT_SPEC", "").strip() or None

missing = [
    name
    for name, value in (
        ("HAPAX_METHODOLOGY_DISPATCH_REDEMPTION_TOKEN", token),
        ("HAPAX_METHODOLOGY_DISPATCH_MESSAGE_ID", message_id),
        ("HAPAX_METHODOLOGY_DISPATCH_ROUTE_DECISION_REF", route_decision_ref),
        ("HAPAX_METHODOLOGY_DISPATCH_AUTHORITY_CASE", authority_case),
    )
    if not value
]
if missing:
    print(
        "missing dispatch redemption binding env: " + ", ".join(missing),
        file=sys.stderr,
    )
    raise SystemExit(1)

context = LaunchRedemptionContext(
    task_id=task_id,
    lane=lane,
    platform=platform,
    mode=mode,
    profile=profile,
    worktree=worktree,
    purpose="external_launch",
    dispatch_message_id=message_id,
    route_decision_ref=route_decision_ref,
    authority_case=authority_case,
    parent_spec=parent_spec,
)
response = redeem_launch_via_socket(
    LaunchRedemptionRequest(
        token=token,
        context=context,
        wrapper="hapax-codex-headless",
        wrapper_pid=os.getpid(),
        observed_at=time.time(),
    )
)
if not response.ok:
    print(f"dispatch redemption refused: {response.reason}", file=sys.stderr)
    raise SystemExit(1)
PYEOF
  then
    echo "hapax-codex-headless: external workdir requires live methodology dispatch redemption; next action: launch external worktrees through hapax-methodology-dispatch with an active dispatch-redemption authority" >&2
    exit 17
  fi
}

scrub_dispatch_redemption_binding_env() {
  unset HAPAX_METHODOLOGY_DISPATCH_REDEMPTION_TOKEN
  unset HAPAX_METHODOLOGY_DISPATCH_MESSAGE_ID
  unset HAPAX_METHODOLOGY_DISPATCH_ROUTE_DECISION_REF
  unset HAPAX_METHODOLOGY_DISPATCH_AUTHORITY_CASE
  unset HAPAX_METHODOLOGY_DISPATCH_PARENT_SPEC
}

DISPATCH_REDEEMED=0
if workdir_requires_dispatch_redemption; then
  validate_dispatch_redemption_authority
  scrub_dispatch_redemption_binding_env
  DISPATCH_REDEEMED=1
fi
if [[ -z "$CLAIMED_TASK" && "$CLAIM_TASK" -eq 1 && "$DISPATCH_REDEEMED" -eq 0 ]]; then
  [[ -x "$WORKDIR/scripts/cc-claim" ]] || { echo "hapax-codex-headless: missing cc-claim in $WORKDIR" >&2; exit 14; }
  (cd "$WORKDIR" && "$WORKDIR/scripts/cc-claim" "$CODEX_TASK")
fi
export HAPAX_METHODOLOGY_DISPATCH_TASK="$CODEX_TASK"

# Keep the lane from becoming a credential sink (same scrub as hapax-codex).
unset GITHUB_PERSONAL_ACCESS_TOKEN
unset CODEX_GITHUB_PERSONAL_ACCESS_TOKEN
unset TAVILY_API_KEY
unset CONTEXT7_API_KEY
MCP_CONFIG_SCRUB="$COUNCIL_DIR/scripts/hapax-codex-mcp-config-scrub"
[[ -x "$MCP_CONFIG_SCRUB" ]] && "$MCP_CONFIG_SCRUB"

LOG_DIR="$HOME/.cache/hapax/codex-headless/$SESSION"
PID_DIR="${HAPAX_CODEX_HEADLESS_PID_DIR:-/run/user/$(id -u)/hapax-codex}"
mkdir -p "$LOG_DIR" "$PID_DIR" 2>/dev/null || true
[[ -d "$PID_DIR" ]] || PID_DIR="$LOG_DIR"
LOG_FILE="$LOG_DIR/output.jsonl"
PID_FILE="$PID_DIR/$SESSION.pid"
DISPATCH_PROOF_DIR="${HAPAX_DISPATCH_PROOF_DIR:-$HOME/.cache/hapax/orchestration/dispatch-host-proofs}"
DISPATCH_PROOF_BASENAME="$(date -u +%Y%m%dT%H%M%SZ)-$SESSION-${CODEX_TASK:-no-task}-headless"
DISPATCH_PROOF_FILE="$DISPATCH_PROOF_DIR/$DISPATCH_PROOF_BASENAME-remote.json"
DISPATCH_LOCAL_PROOF_FILE="$DISPATCH_PROOF_DIR/$DISPATCH_PROOF_BASENAME-local.json"

RELAY_RETIRE="$COUNCIL_DIR/scripts/hapax-relay-retire"
CODEX_PID=""
# shellcheck disable=SC2329
cleanup() {
  local current_pid=""
  if [[ -n "${CODEX_PID:-}" && -f "$PID_FILE" ]]; then
    current_pid="$(cat "$PID_FILE" 2>/dev/null || true)"
    if [[ "$current_pid" == "$CODEX_PID" ]]; then
      rm -f "$PID_FILE"
      [[ -x "$RELAY_RETIRE" ]] && "$RELAY_RETIRE" "$SESSION" --reason "clean exit (codex headless)" 2>/dev/null || true
    fi
  fi
}
trap cleanup EXIT

write_local_dispatch_proof() {
  local pid="$1" fallback="$2" reason="${3:-}" cgroup=""
  mkdir -p "$(dirname "$DISPATCH_LOCAL_PROOF_FILE")" 2>/dev/null || return 0
  if [[ -n "$pid" && -r "/proc/$pid/cgroup" ]]; then
    cgroup="$(cat "/proc/$pid/cgroup" 2>/dev/null || true)"
  else
    cgroup="$(cat /proc/self/cgroup 2>/dev/null || true)"
  fi
  python3 - "$DISPATCH_LOCAL_PROOF_FILE" "$SESSION" "$CODEX_TASK" "${DISPATCH_HOST_REQUESTED:-}" \
    "$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf local)" "$pid" "$fallback" \
    "$reason" "$WORKDIR" "$LOGOS_BASE_URL" "$cgroup" <<'PYEOF'
import json
import sys

(
    proof_file,
    session,
    task_id,
    requested_host,
    actual_host,
    pid,
    fallback,
    reason,
    workdir,
    logos_url,
    cgroup,
) = sys.argv[1:12]
payload = {
    "schema_version": 1,
    "event": "dispatch_local_exec",
    "platform": "codex-headless",
    "session": session,
    "task_id": task_id,
    "requested_host": requested_host,
    "actual_host": actual_host,
    "pid": int(pid) if pid.isdigit() else None,
    "fallback": fallback == "1",
    "fallback_reason": reason or None,
    "cgroup": cgroup,
    "workdir": workdir,
    "logos_base_url": logos_url,
}
with open(proof_file, "w", encoding="utf-8") as fh:
    fh.write(json.dumps(payload, sort_keys=True) + "\n")
PYEOF
}

# Refuse to double-launch a live lane before any remote dispatch-host mutation.
# --force only reactivates retired relay state; it must not bypass the
# single-live-headless-lane invariant.
if [[ -f "$PID_FILE" ]]; then
  EXISTING_PID="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [[ -n "$EXISTING_PID" ]] && kill -0 "$EXISTING_PID" 2>/dev/null; then
    echo "hapax-codex-headless: lane '$SESSION' already live (pid=$EXISTING_PID); stop the live lane or remove the stale pid after verifying it is gone" >&2
    exit 11
  fi
fi

DISPATCH_HOST_REQUESTED="${HAPAX_DISPATCH_HOST:-}"
DISPATCH_HOST=""
DISPATCH_FALLBACK_REASON=""
if [[ -n "$DISPATCH_HOST_REQUESTED" ]]; then
  if dispatch_host_is_local "$DISPATCH_HOST_REQUESTED"; then
    DISPATCH_HOST_REQUESTED=""
  else
    WORKTREE_PAYLOAD="$(remote_worktree_payload_b64)"
    WORKTREE_COMMAND="$(remote_python_command "$WORKTREE_PAYLOAD" "$REMOTE_WORKTREE_PY")"
    PREFLIGHT_PAYLOAD="$(remote_preflight_payload_b64)"
    PREFLIGHT_COMMAND="$(remote_python_command "$PREFLIGHT_PAYLOAD" "$REMOTE_PREFLIGHT_PY")"
    WORKTREE_ERR=""
    PREFLIGHT_ERR=""
    if ! WORKTREE_ERR="$(
      ssh -o BatchMode=yes -o ConnectTimeout=4 -i "$HOME/.ssh/id_ed25519" \
        -o ControlPath="$HOME/.ssh/cm-%r@%h:%p" "$DISPATCH_HOST_REQUESTED" \
        "$WORKTREE_COMMAND" 2>&1 >/dev/null
    )"; then
      DISPATCH_FALLBACK_REASON="dispatch_host_unready:$DISPATCH_HOST_REQUESTED"
      echo "hapax-codex-headless: remote worktree bootstrap failed ($DISPATCH_HOST_REQUESTED)" >&2
      [[ -n "$WORKTREE_ERR" ]] && printf '  detail: %s\n' "$WORKTREE_ERR" >&2
      if [[ "${HAPAX_DISPATCH_HOST_FALLBACK:-}" == "local" ]]; then
        echo "hapax-codex-headless: dispatch_host_unready ($DISPATCH_HOST_REQUESTED) -- explicit local fallback" >&2
      else
        echo "  next action: ssh $DISPATCH_HOST_REQUESTED and verify $WORKDIR, $COUNCIL_DIR, git, and HAPAX_CODEX_CREATE_WORKTREE before retrying; refusing local fallback without HAPAX_DISPATCH_HOST_FALLBACK=local" >&2
        exit 75
      fi
    elif ! PREFLIGHT_ERR="$(
      ssh -o BatchMode=yes -o ConnectTimeout=4 -i "$HOME/.ssh/id_ed25519" \
        -o ControlPath="$HOME/.ssh/cm-%r@%h:%p" "$DISPATCH_HOST_REQUESTED" \
        "$PREFLIGHT_COMMAND" 2>&1 >/dev/null
    )"; then
      DISPATCH_FALLBACK_REASON="dispatch_host_unready:$DISPATCH_HOST_REQUESTED"
      echo "hapax-codex-headless: remote preflight failed ($DISPATCH_HOST_REQUESTED)" >&2
      [[ -n "$PREFLIGHT_ERR" ]] && printf '  detail: %s\n' "$PREFLIGHT_ERR" >&2
      if [[ "${HAPAX_DISPATCH_HOST_FALLBACK:-}" == "local" ]]; then
        echo "hapax-codex-headless: dispatch_host_unready ($DISPATCH_HOST_REQUESTED) -- explicit local fallback" >&2
      else
        echo "  next action: ssh $DISPATCH_HOST_REQUESTED and verify $WORKDIR, $COUNCIL_DIR, $HOME/projects/hapax-mcp, python3, codex, and the hook adapter before retrying; refusing local fallback without HAPAX_DISPATCH_HOST_FALLBACK=local" >&2
        exit 75
      fi
    else
      DISPATCH_HOST="$DISPATCH_HOST_REQUESTED"
      echo "hapax-codex-headless: dispatch -> $DISPATCH_HOST (codex exec on appendix)" >&2
    fi
  fi
fi

if [[ -n "$DISPATCH_HOST" ]]; then
  LOGOS_BASE_URL="${HAPAX_DISPATCH_LOGOS_URL:-http://192.168.68.85:8051/api}"
else
  LOGOS_BASE_URL="${LOGOS_BASE_URL:-http://localhost:8051/api}"
fi
COCKPIT_BASE_URL="${COCKPIT_BASE_URL:-$LOGOS_BASE_URL}"

CODEX_BIN=""
if [[ -z "$DISPATCH_HOST" ]]; then
  CODEX_BIN="$(command -v codex || true)"
  [[ -n "$CODEX_BIN" ]] || { echo "hapax-codex-headless: codex not found in PATH" >&2; exit 4; }
else
  CODEX_BIN="codex"
fi

SDLC_PREAMBLE="SDLC DISCIPLINE (MANDATORY):
1. Work only on the task named in this dispatch.
2. Run cc-claim for that exact task before mutation.
3. If cc-claim rejects, stop and write a relay receipt.
4. Use only the AuthorityCase and parent spec named in this dispatch.
5. Do not create, select, or claim other work from the task pool.
6. When the task is complete or blocked, report status and idle.

DISPATCH:
"
INITIAL_MSG="${SDLC_PREAMBLE}${INITIAL_MSG}"

# Config mirrors hapax-codex's governed CODEX_ARGS (shared contract — keep in
# sync): full-access sandbox under external governance, the codex-hook-adapter on
# every phase, and the hapax MCP surface. `--json` streams JSONL events; `--cd`
# binds the worktree; trust is scoped to the worktree.
CODEX_ARGS=(
  exec
  --dangerously-bypass-approvals-and-sandbox
  --skip-git-repo-check
  --json
  --cd "$WORKDIR"
  -c 'model="gpt-5.5"'
  -c 'model_reasoning_effort="xhigh"'
  -c 'approval_policy="never"'
  -c 'sandbox_mode="danger-full-access"'
  -c "projects.\"$HOME/projects\".trust_level=\"trusted\""
  -c "projects.\"$WORKDIR\".trust_level=\"trusted\""
  -c "hooks.SessionStart=[{command=\"$HOOK\",timeout=20,statusMessage=\"Loading Hapax context\"}]"
  -c "hooks.PreToolUse=[{command=\"$HOOK\",timeout=20,include_apply_patch_tool=true,statusMessage=\"Hapax guardrails\"}]"
  -c "hooks.PostToolUse=[{command=\"$HOOK\",timeout=20,include_apply_patch_tool=true,statusMessage=\"Hapax audit\"}]"
  -c "hooks.Stop=[{command=\"$HOOK\",timeout=20,statusMessage=\"Writing Hapax session summary\"}]"
  -c "mcp_servers.hapax.command=\"$HOME/.local/bin/uv\""
  -c "mcp_servers.hapax.args=[\"--directory\",\"$HOME/projects/hapax-mcp\",\"run\",\"hapax-mcp\"]"
  -c "mcp_servers.hapax.env.LOGOS_BASE_URL=\"$LOGOS_BASE_URL\""
  -c "mcp_servers.github.command=\"$COUNCIL_DIR/scripts/hapax-github-mcp\""
  -c "mcp_servers.context7.command=\"$COUNCIL_DIR/scripts/hapax-context7-mcp\""
)
CODEX_ARGS+=("${CODEX_EXTRA[@]}")
CODEX_ARGS+=("$INITIAL_MSG")

echo "hapax-codex-headless: starting $SESSION (task=$CODEX_TASK) in $WORKDIR"
echo "  log: $LOG_FILE"
echo "  pid: $PID_FILE"

cd "$WORKDIR"
if [[ -n "$DISPATCH_HOST" ]]; then
  REMOTE_EXEC_PAYLOAD="$(remote_exec_payload_b64 "$DISPATCH_PROOF_FILE" codex "${CODEX_ARGS[@]}")"
  REMOTE_EXEC_COMMAND="$(remote_python_command "$REMOTE_EXEC_PAYLOAD" "$REMOTE_EXEC_PY")"
  ssh -o BatchMode=yes -o RequestTTY=no -o ServerAliveInterval=30 -o ServerAliveCountMax=6 \
    -o ControlPath=none -i "$HOME/.ssh/id_ed25519" "$DISPATCH_HOST" "$REMOTE_EXEC_COMMAND" \
    >>"$LOG_FILE" 2>&1 &
else
  "$CODEX_BIN" "${CODEX_ARGS[@]}" >>"$LOG_FILE" 2>&1 &
fi
CODEX_PID=$!
echo "$CODEX_PID" >"$PID_FILE"
echo "hapax-codex-headless: pid=$CODEX_PID"
if [[ -z "$DISPATCH_HOST" && -n "$DISPATCH_FALLBACK_REASON" ]]; then
  write_local_dispatch_proof "$CODEX_PID" "1" "$DISPATCH_FALLBACK_REASON"
fi

if wait "$CODEX_PID"; then
  EXIT_CODE=0
else
  EXIT_CODE=$?
fi
echo "hapax-codex-headless: $SESSION exited (code=$EXIT_CODE)"
exit "$EXIT_CODE"
