#!/usr/bin/env bash
# hapax-codex-headless - Launch a Codex lane non-interactively via `codex exec`.
#
# The genuine headless analog to hapax-claude-headless: NO tmux pane. Codex runs
# non-interactively, JSONL events stream to a log the headless-staleness watchdog
# can read, a PID file marks the run live, and the same identity-env + governed
# task-gate + hook wiring as hapax-codex applies. Default-deny: headless lanes
# mutate source autonomously, so a governed enable must exist first.

set -euo pipefail

COUNCIL_DIR="${HAPAX_COUNCIL_DIR:-$HOME/projects/hapax-council}"
ROLE_HELPER="$COUNCIL_DIR/hooks/scripts/agent-role.sh"
if [ -f "$ROLE_HELPER" ]; then
  # shellcheck source=../hooks/scripts/agent-role.sh
  # shellcheck disable=SC1091
  . "$ROLE_HELPER"
fi
if ! declare -F hapax_agent_is_codex_name >/dev/null 2>&1; then
  hapax_agent_is_codex_name() {
    [[ "${1:-}" =~ ^cx-[a-z][a-z-]*$ ]]
  }
fi

DISABLE_FILE="${HAPAX_CODEX_HEADLESS_DISABLE_FILE:-$HOME/.cache/hapax/disable-codex-headless}"
ENABLE_FILE="${HAPAX_CODEX_HEADLESS_ENABLE_FILE:-$HOME/.cache/hapax/enable-codex-headless}"

headless_allowed() {
  [[ "${HAPAX_CODEX_HEADLESS_ALLOW:-}" == "1" || -e "$ENABLE_FILE" ]]
}

relay_retired() {
  # Delegate to the single-source predicate (shared/relay_lifecycle.lane_is_retired)
  # so the launcher agrees with the dispatch gate + the coordinator: one
  # broad-9 vocabulary, freshest-of-candidates resolution, multi-doc
  # latest-wins. The legacy awk (relay_current_values/relay_value_is_retired
  # below) over-refused SUPERSEDED/CLOSED lane relays (task/claim states that
  # leaked); dead code retained for a minimal diff — remove later. FAIL-OPEN on
  # tooling error (python missing / import fail): the gate at
  # coord_dispatch.run_atomic_dispatch_launch is authoritative on the governed
  # path, so a fail-open launcher only ever sees gate-allowed lanes.
  local relay_name="$1"
  local council_root
  local relay_dir="${HAPAX_RELAY_DIR:-$HOME/.cache/hapax/relay}"
  council_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  PYTHONPATH="$council_root${PYTHONPATH:+:$PYTHONPATH}" python3 -c '
import sys
from pathlib import Path
from shared.relay_lifecycle import lane_is_retired
sys.exit(0 if lane_is_retired(sys.argv[1], relay_dir=Path(sys.argv[2])) else 1)
' "$relay_name" "$relay_dir" 2>/dev/null
  case $? in
    0) return 0 ;;
    *) return 1 ;;  # 1 = not retired; any other = tooling error -> fail-open
  esac
}

relay_current_values() {
  local relay_file="$1"
  awk '
    BEGIN { in_session_status = 0 }

    in_session_status {
      if ($0 ~ /^[[:space:]]*$/) {
        next
      }
      if ($0 !~ /^[[:space:]]+/) {
        in_session_status = 0
      } else {
        value = $0
        sub(/^[[:space:]]+/, "", value)
        print value
        in_session_status = 0
        next
      }
    }

    /^(status|state|relay_status|session_state|role):[[:space:]]*/ {
      value = $0
      sub(/^[^:]+:[[:space:]]*/, "", value)
      if (value !~ /^[|>]/) {
        print value
      }
      next
    }

    /^session_status:[[:space:]]*/ {
      value = $0
      sub(/^session_status:[[:space:]]*/, "", value)
      if (value ~ /^[|>]/) {
        in_session_status = 1
        next
      }
      print value
      next
    }
  ' "$relay_file"
}

relay_value_is_retired() {
  local value="$1"
  local normalized first_word
  normalized="$(printf '%s' "$value" | sed "s/^[[:space:]\"']*//; s/[[:space:]\"']*$//" | tr '[:lower:]' '[:upper:]')"
  first_word="${normalized%%[[:space:]]*}"
  case "$first_word" in
    RETIRED*|SUPERSEDED*|CLOSED*|IDLE_WOUND_DOWN*|WIND_DOWN_IDLE*|WOUND_DOWN*|WIND_DOWN*|WINDING_DOWN*|ANTIGRAVITY_TAKEOVER)
      return 0
      ;;
  esac
  case "$normalized" in
    RETIRED*|SUPERSEDED*|CLOSED*|IDLE_WOUND_DOWN*|WIND_DOWN_IDLE*|WOUND_DOWN*|WIND_DOWN*|WINDING_DOWN*|ANTIGRAVITY_TAKEOVER)
      return 0
      ;;
  esac
  return 1
}

dispatch_host_is_local() {
  local host="${1:-}" short="" fqdn="" local_ip="" resolved_ip=""
  [[ -z "$host" || "$host" == "local" || "$host" == "localhost" ]] && return 0
  [[ "$host" == "127.0.0.1" || "$host" == "::1" ]] && return 0
  short="$(hostname -s 2>/dev/null || hostname 2>/dev/null || true)"
  fqdn="$(hostname -f 2>/dev/null || true)"
  [[ "$host" == "appendix" ]] && host="hapax-appendix"
  [[ "$host" == "podium" ]] && host="hapax-podium"
  [[ -n "$short" && "$host" == "$short" ]] && return 0
  [[ -n "$fqdn" && "$host" == "$fqdn" ]] && return 0
  for local_ip in $(hostname -I 2>/dev/null || true); do
    [[ "$host" == "$local_ip" ]] && return 0
  done
  if command -v getent >/dev/null 2>&1; then
    for resolved_ip in $(getent ahosts "$host" 2>/dev/null | awk '{print $1}'); do
      for local_ip in $(hostname -I 2>/dev/null || true); do
        [[ "$resolved_ip" == "$local_ip" ]] && return 0
      done
    done
  fi
  return 1
}

token_handoff_component() {
  local component
  component="$(printf '%s\n' "$1" | tr -cs 'A-Za-z0-9_-' '-' | sed 's/^-//; s/-$//' | cut -c1-96)"
  if [[ -z "$component" ]]; then
    component="session"
  fi
  printf '%s\n' "$component"
}

remote_token_handoff_seal_key() {
  python3 - <<'PYEOF'
import secrets

print(secrets.token_hex(32))
PYEOF
}

session_id_is_safe() {
  local sid="${1:-}" tail=""
  [[ "${#sid}" -ge 8 && "${#sid}" -le 128 ]] || return 1
  case "$sid" in
    [A-Za-z0-9]*) ;;
    *) return 1 ;;
  esac
  case "$sid" in
    *[!A-Za-z0-9._-]*) return 1 ;;
  esac
  case "$sid" in
    *[!0-9]*) ;;
    *) return 1 ;;
  esac
  tail="${sid##*-}"
  if [[ "$tail" =~ ^[0-9]{1,7}$ ]]; then
    return 1
  fi
  return 0
}

mint_session_uuid() {
  cat /proc/sys/kernel/random/uuid 2>/dev/null \
    || uuidgen 2>/dev/null \
    || python3 -c 'import uuid; print(uuid.uuid4())' 2>/dev/null \
    || printf '%s-%s-p%sx\n' "$(token_handoff_component "$SESSION")" "$(date -u +%Y%m%dT%H%M%SZ)" "$$"
}

normalize_session_uuid() {
  local raw="${1:-}" minted=""
  if [[ -n "$raw" ]] && session_id_is_safe "$raw"; then
    printf '%s\n' "$raw"
    return 0
  fi
  minted="$(mint_session_uuid)"
  if [[ -n "$raw" ]]; then
    echo "hapax-codex-headless: ignoring unsafe HAPAX_SESSION_ID; minted safe session id for coordination paths" >&2
  fi
  printf '%s\n' "$minted"
}

claim_epoch_for_task() {
  local role="$1" sid="$2" task="$3" suffix="" epoch_path="" claim_path="" line="" epoch="" epoch_task="" active_task=""
  for suffix in "$role-$sid" "$role"; do
    epoch_path="$HOME/.cache/hapax/cc-claim-epoch-$suffix"
    claim_path="$HOME/.cache/hapax/cc-active-task-$suffix"
    [[ -s "$epoch_path" && -s "$claim_path" ]] || continue
    active_task="$(head -n1 "$claim_path" | tr -d '[:space:]')"
    [[ "$active_task" == "$task" ]] || continue
    IFS= read -r line <"$epoch_path" || true
    epoch="${line%% *}"
    epoch_task="${line#* }"
    [[ "$line" != "$epoch" ]] || continue
    if [[ "$epoch" =~ ^[0-9]+$ && "$epoch_task" == "$task" ]]; then
      printf '%s\n' "$line"
      return 0
    fi
  done
  return 1
}

remote_python_command() {
  local payload="$1" code="$2"
  local code_b64="" bash_script="" quoted_script="" quoted_payload="" quoted_code=""
  code_b64="$(printf '%s' "$code" | python3 -c 'import base64,sys; print(base64.b64encode(sys.stdin.buffer.read()).decode())')"
  # shellcheck disable=SC2016
  bash_script='export HAPAX_REMOTE_PAYLOAD="$1"; export HAPAX_REMOTE_CODE="$2"; exec python3 -c "import base64,os; exec(base64.b64decode(os.environ[\"HAPAX_REMOTE_CODE\"]))"'
  quoted_script="${bash_script//\'/\'\\\'\'}"
  quoted_payload="${payload//\'/\'\\\'\'}"
  quoted_code="${code_b64//\'/\'\\\'\'}"
  printf "bash -c '%s' bash '%s' '%s'" "$quoted_script" "$quoted_payload" "$quoted_code"
}

load_local_codex_access_token() {
  local token_file="${HAPAX_CODEX_OAUTH_ACCESS_TOKEN_FILE:-$HOME/.cache/hapax/codex-oauth/access_token}"
  local token=""
  local token_rc=0
  token="$(
    PYTHONPATH="$COUNCIL_DIR${PYTHONPATH:+:$PYTHONPATH}" python3 - "$token_file" <<'PYEOF'
import sys
from pathlib import Path

from shared.codex_oauth_refresher import (
    load_published_access_token,
    needs_refresh,
)

path = Path(sys.argv[1]).expanduser()
token = load_published_access_token(token_file=path)
if token is None:
    print(
        "hapax-codex-headless: missing or unsafe published Codex OAuth access token at "
        f"{path}; expected a regular owner-only token file owned by the current user; "
        "next action: run the codex OAuth refresher or reauth on appendix before "
        "dispatching Codex lanes",
        file=sys.stderr,
    )
    raise SystemExit(78)
if needs_refresh(token):
    print(
        "hapax-codex-headless: published Codex OAuth access token is missing a fresh "
        "expiry; next action: run the codex OAuth refresher or reauth on appendix "
        "before dispatching Codex lanes",
        file=sys.stderr,
    )
    raise SystemExit(78)
print(token.raw)
PYEOF
  )" || token_rc=$?
  if [[ "$token_rc" -ne 0 ]]; then
    return "$token_rc"
  fi
  export CODEX_ACCESS_TOKEN="$token"
}

resolve_local_codex_bin() {
  if [[ -n "${HAPAX_CODEX_BIN:-}" ]]; then
    [[ -x "$HAPAX_CODEX_BIN" ]] || {
      echo "hapax-codex-headless: configured HAPAX_CODEX_BIN is not executable: $HAPAX_CODEX_BIN; next action: set HAPAX_CODEX_BIN to an executable codex binary or repair PATH before retrying" >&2
      exit 4
    }
    printf '%s\n' "$HAPAX_CODEX_BIN"
    return 0
  fi
  local codex_bin=""
  codex_bin="$(command -v codex || true)"
  [[ -n "$codex_bin" ]] || {
    echo "hapax-codex-headless: codex not found in PATH; next action: install the Codex CLI, repair PATH, or set HAPAX_CODEX_BIN to the executable before retrying" >&2
    exit 4
  }
  printf '%s\n' "$codex_bin"
}

prove_local_codex_bearer_actuation() {
  local codex_bin="$1" tmp_codex_home="" models_file="" rc=0 timeout_s=""
  timeout_s="${HAPAX_CODEX_BEARER_ACTUATION_TIMEOUT_SECONDS:-15}"
  tmp_codex_home="$(mktemp -d "${TMPDIR:-/tmp}/hapax-codex-actuation.XXXXXX")" || {
    echo "hapax-codex-headless: failed to create temporary Codex actuation home; next action: verify TMPDIR or /tmp permissions before retrying" >&2
    exit 78
  }
  models_file="$tmp_codex_home/models.json"
  timeout "${timeout_s}s" env -i \
    ALL_PROXY="${ALL_PROXY:-}" \
    HOME="$HOME" \
    HTTP_PROXY="${HTTP_PROXY:-}" \
    HTTPS_PROXY="${HTTPS_PROXY:-}" \
    LANG="${LANG:-C}" \
    LC_ALL="${LC_ALL:-}" \
    NO_COLOR=1 \
    NO_PROXY="${NO_PROXY:-}" \
    PATH="$PATH" \
    REQUESTS_CA_BUNDLE="${REQUESTS_CA_BUNDLE:-}" \
    SSL_CERT_FILE="${SSL_CERT_FILE:-}" \
    CODEX_ACCESS_TOKEN="$CODEX_ACCESS_TOKEN" \
    CODEX_HOME="$tmp_codex_home" \
    "$codex_bin" debug models >"$models_file" || rc=$?
  if [[ "$rc" -ne 0 ]]; then
    rm -rf "$tmp_codex_home"
    echo "hapax-codex-headless: published Codex OAuth access token was rejected by codex debug models (rc=$rc); next action: run the codex OAuth refresher or reauth on the dispatch host before dispatching Codex lanes" >&2
    exit 78
  fi
  if ! python3 - "$models_file" <<'PYEOF'
import json
import sys
from pathlib import Path

try:
    payload = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
except (OSError, json.JSONDecodeError):
    raise SystemExit(1)
models = payload.get("models") if isinstance(payload, dict) else None
if not isinstance(models, list) or not models:
    raise SystemExit(1)
PYEOF
  then
    rm -rf "$tmp_codex_home"
    echo "hapax-codex-headless: codex debug models returned no parseable model catalog; next action: verify the Codex CLI/auth substrate before dispatching Codex lanes" >&2
    exit 78
  fi
  rm -rf "$tmp_codex_home"
}

prove_local_fallback_before_claim() {
  if [[ "${HAPAX_DISPATCH_HOST_FALLBACK:-}" != "local" ]]; then
    return 0
  fi
  if [[ "$LOCAL_FALLBACK_BEARER_PROVEN" == "1" ]]; then
    return 0
  fi
  load_local_codex_access_token
  CODEX_BIN="$(resolve_local_codex_bin)"
  prove_local_codex_bearer_actuation "$CODEX_BIN"
  LOCAL_FALLBACK_BEARER_PROVEN=1
}

remote_preflight_payload_b64() {
  local token_only="${1:-0}" token_handoff_file="${2:-}"
  python3 - "$WORKDIR" "$COUNCIL_DIR" "$HOME/projects/hapax-mcp" "$token_only" \
    "$token_handoff_file" <<'PYEOF'
import base64
import json
import os
import sys

def token_handoff_ttl_seconds():
    raw = os.environ.get("HAPAX_REMOTE_TOKEN_HANDOFF_TTL_SECONDS", "900")
    try:
        ttl = int(raw)
    except ValueError:
        print(
            "hapax-codex-headless: invalid HAPAX_REMOTE_TOKEN_HANDOFF_TTL_SECONDS="
            + raw
            + "; next action: set a positive integer between 1 and 3600 before remote dispatch",
            file=sys.stderr,
        )
        raise SystemExit(78)
    if ttl < 1 or ttl > 3600:
        print(
            "hapax-codex-headless: invalid HAPAX_REMOTE_TOKEN_HANDOFF_TTL_SECONDS="
            + raw
            + "; next action: set a positive integer between 1 and 3600 before remote dispatch",
            file=sys.stderr,
        )
        raise SystemExit(78)
    return ttl

workdir, council_dir, mcp_dir, token_only, token_handoff_file = sys.argv[1:6]
token_file = (
    os.environ.get("HAPAX_CODEX_OAUTH_ACCESS_TOKEN_FILE")
    or "~/.cache/hapax/codex-oauth/access_token"
)
payload = {
    "required_dirs": [] if token_only == "1" else [workdir, council_dir, mcp_dir],
    "executables": [] if token_only == "1" else [f"{council_dir}/hooks/scripts/codex-hook-adapter.sh"],
    "binaries": ["codex"] if token_only == "1" else ["python3", "codex"],
    "token_file": token_file,
    "token_handoff_file": "" if token_only == "1" else token_handoff_file,
    "token_handoff_seal_key": "" if token_only == "1" else os.environ.get("HAPAX_REMOTE_TOKEN_HANDOFF_SEAL_KEY", ""),
    "token_handoff_ttl_seconds": token_handoff_ttl_seconds(),
}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

remote_worktree_payload_b64() {
  python3 - "$WORKDIR" "$COUNCIL_DIR" "$SESSION" \
    "${HAPAX_CODEX_WORKTREE_BASE:-main}" "${HAPAX_CODEX_BRANCH_PREFIX:-codex}" \
    "${HAPAX_CODEX_CREATE_WORKTREE:-1}" "$WORKDIR_EXPLICIT" <<'PYEOF'
import base64
import json
import sys

workdir, council_dir, session, base_ref, branch_prefix, create_worktree, workdir_explicit = (
    sys.argv[1:8]
)
payload = {
    "workdir": workdir,
    "council_dir": council_dir,
    "session": session,
    "base_ref": base_ref or "main",
    "branch": f"{branch_prefix or 'codex'}/{session}",
    "create_worktree": create_worktree == "1",
    "workdir_explicit": workdir_explicit == "1",
}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

remote_exec_payload_b64() {
  local proof_file="$1"
  shift
  python3 - "$WORKDIR" "$proof_file" "${DISPATCH_HOST_REQUESTED:-}" "$LOGOS_BASE_URL" \
    "$COCKPIT_BASE_URL" "$SESSION" "$CODEX_TASK" "${REMOTE_TOKEN_HANDOFF:-}" \
    "${REMOTE_TOKEN_HANDOFF_SEAL_KEY:-}" "$@" <<'PYEOF'
import base64
import json
import os
import sys

workdir, proof_file, requested_host, logos_url, cockpit_url, session, task_id, token_handoff, seal_key = (
    sys.argv[1:10]
)
argv = sys.argv[10:]
env = {
    "LOGOS_BASE_URL": logos_url,
    "COCKPIT_BASE_URL": cockpit_url,
    "HAPAX_DISPATCH_HOST": "local",
    "HAPAX_DISPATCH_REQUESTED_HOST": requested_host,
    "HAPAX_DISPATCH_LOGOS_URL": logos_url,
    "HAPAX_DISPATCH_PROOF_FILE": proof_file,
    "HAPAX_DISPATCH_REMOTE_INNER": "1",
    "HAPAX_AGENT_INTERFACE": "codex",
    "HAPAX_AGENT_NAME": session,
    "CODEX_THREAD_NAME": session,
    "CODEX_ROLE": session,
    "HAPAX_AGENT_ROLE": session,
}
for name in (
    "CLAUDE_ROLE",
    "HAPAX_AGENT_SLOT",
    "HAPAX_WORKTREE_ROLE",
    "HAPAX_SESSION_ID",
    "HAPAX_PARENT_AGENT_INTERFACE",
    "HAPAX_PARENT_AGENT_NAME",
    "HAPAX_METHODOLOGY_DISPATCH_TASK",
    "HAPAX_METHODOLOGY_DISPATCH_CLAIM_EPOCH",
    "HAPAX_IDLE_UPDATE_SECONDS",
    "HAPAX_CODEX_OAUTH_ACCESS_TOKEN_FILE",
    "PASSWORD_STORE_DIR",
):
    value = os.environ.get(name)
    if value is not None:
        env[name] = value
payload = {
    "workdir": workdir,
    "proof_file": proof_file,
    "requested_host": requested_host,
    "session": session,
    "task_id": task_id,
    "token_handoff_file": token_handoff,
    "token_handoff_seal_key": seal_key,
    "env": env,
    "argv": argv,
}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

remote_token_cleanup_payload_b64() {
  python3 - "${REMOTE_TOKEN_HANDOFF:-}" <<'PYEOF'
import base64
import json
import sys

payload = {"path": sys.argv[1]}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

REMOTE_PREFLIGHT_PY='import base64,hashlib,hmac,json,os,shutil,subprocess,sys,tempfile,time; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"]));
missing_dirs=[path for path in p.get("required_dirs",()) if not os.path.isdir(path)]
missing_exec=[path for path in p.get("executables",()) if not (os.path.isfile(path) and os.access(path, os.X_OK))]
missing_bins=[binary for binary in p.get("binaries",()) if not shutil.which(binary)]
def _jwt_exp(token):
    try:
        payload=token.split(".")[1]; payload += "=" * (-len(payload) % 4)
        return float(json.loads(base64.urlsafe_b64decode(payload.encode("ascii"))).get("exp",0))
    except Exception:
        print("hapax-codex-headless: preflight-proven Codex OAuth token handoff is unparseable; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
def _seal_token(token,key_hex):
    try:
        key=bytes.fromhex(key_hex)
    except ValueError:
        key=b""
    if not key:
        print("hapax-codex-headless: missing Codex OAuth token handoff seal key; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    plain=token.encode("utf-8")
    stream=hashlib.shake_256(key+b":hapax-codex-token-handoff-v1").digest(len(plain))
    cipher=bytes(a^b for a,b in zip(plain,stream))
    mac=hmac.new(key,b"hapax-codex-token-handoff-v1\0"+cipher,hashlib.sha256).hexdigest()
    return "hapax-token-sealed-v1."+base64.urlsafe_b64encode(cipher).decode("ascii").rstrip("=")+"."+mac
token_file=os.path.expanduser(p.get("token_file") or "~/.cache/hapax/codex-oauth/access_token")
token_error=""
actuation_error=""
def _read_owner_only_token(path):
    flags=os.O_RDONLY
    if hasattr(os,"O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    try:
        fd=os.open(path,flags)
    except OSError:
        return None,"missing_codex_oauth_access_token:"+path
    try:
        info=os.fstat(fd)
        if info.st_uid != os.getuid() or (info.st_mode & 0o170000) != 0o100000 or (info.st_mode & 0o077):
            return None,"unsafe_codex_oauth_access_token:"+path
        with os.fdopen(fd,encoding="utf-8") as handle:
            fd=-1
            return handle.read().strip(),""
    except OSError:
        return None,"missing_codex_oauth_access_token:"+path
    finally:
        if fd >= 0:
            os.close(fd)
token,token_error=_read_owner_only_token(token_file)
if not token_error:
    if not token or _jwt_exp(token) - time.time() <= 300:
        token_error="codex_oauth_access_token_absent_or_expiring:"+token_file
if not token_error:
    codex_bin=shutil.which("codex")
    if codex_bin is None:
        actuation_error="codex_binary_missing"
    else:
        with tempfile.TemporaryDirectory(prefix="hapax-codex-actuation-") as codex_home:
            env={k:v for k in ("ALL_PROXY","HOME","HTTP_PROXY","HTTPS_PROXY","LANG","LC_ALL","NO_PROXY","PATH","REQUESTS_CA_BUNDLE","SSL_CERT_FILE") if (v:=os.environ.get(k)) is not None}
            env.update({"CODEX_ACCESS_TOKEN":token,"CODEX_HOME":codex_home,"NO_COLOR":"1"})
            try:
                result=subprocess.run([codex_bin,"debug","models"],text=True,capture_output=True,timeout=15,env=env)
            except (OSError,subprocess.TimeoutExpired) as exc:
                actuation_error="codex_bearer_actuation_failed:"+type(exc).__name__
            else:
                if result.returncode != 0:
                    actuation_error="codex_bearer_actuation_failed:rc="+str(result.returncode)
                else:
                    try:
                        payload=json.loads(result.stdout)
                    except json.JSONDecodeError:
                        actuation_error="codex_bearer_actuation_unparseable"
                    else:
                        models=payload.get("models") if isinstance(payload,dict) else None
                        if not isinstance(models,list) or not models:
                            actuation_error="codex_bearer_actuation_unparseable"
if missing_dirs or missing_exec or missing_bins or token_error or actuation_error:
    print("remote preflight failed: missing_dirs="+json.dumps(missing_dirs)+" missing_executables="+json.dumps(missing_exec)+" missing_binaries="+json.dumps(missing_bins)+" token_error="+json.dumps(token_error)+" actuation_error="+json.dumps(actuation_error)+"; next action: ssh to the dispatch host and run the codex OAuth refresher or reauth, then verify required paths before retrying", file=sys.stderr)
    sys.exit(1)
handoff=p.get("token_handoff_file") or ""
if handoff:
    seal_key=p.get("token_handoff_seal_key") or ""
    handoff=os.path.abspath(os.path.expanduser(handoff))
    if os.path.dirname(handoff)!="/tmp" or not os.path.basename(handoff).startswith("hapax-codex-token-"):
        print("hapax-codex-headless: refused invalid Codex OAuth token handoff path "+handoff+"; next action: rerun remote preflight with a sanitized session id", file=sys.stderr)
        sys.exit(78)
    directory=os.path.dirname(handoff)
    if directory:
        os.makedirs(directory,exist_ok=True)
    flags=os.O_WRONLY|os.O_CREAT|os.O_EXCL
    if hasattr(os,"O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    try:
        fd=os.open(handoff,flags,0o600)
    except OSError as exc:
        print("hapax-codex-headless: refused unsafe preflight-proven Codex OAuth token handoff at "+handoff+" ("+exc.__class__.__name__+"); next action: remove stale hapax-codex-token files owned by this user and rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    try:
        ttl=int(p.get("token_handoff_ttl_seconds"))
    except (TypeError,ValueError):
        os.close(fd)
        try:
            os.unlink(handoff)
        except FileNotFoundError:
            pass
        print("hapax-codex-headless: refused invalid Codex OAuth token handoff TTL; next action: set HAPAX_REMOTE_TOKEN_HANDOFF_TTL_SECONDS to a positive integer between 1 and 3600", file=sys.stderr)
        sys.exit(78)
    if ttl < 1 or ttl > 3600:
        os.close(fd)
        try:
            os.unlink(handoff)
        except FileNotFoundError:
            pass
        print("hapax-codex-headless: refused invalid Codex OAuth token handoff TTL; next action: set HAPAX_REMOTE_TOKEN_HANDOFF_TTL_SECONDS to a positive integer between 1 and 3600", file=sys.stderr)
        sys.exit(78)
    try:
        pid=os.fork()
    except (AttributeError,OSError) as exc:
        os.close(fd)
        try:
            os.unlink(handoff)
        except FileNotFoundError:
            pass
        print("hapax-codex-headless: failed to schedule Codex OAuth token handoff self-cleanup ("+exc.__class__.__name__+"); next action: verify remote process limits/fork availability and rerun before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    if pid == 0:
        token=""
        seal_key=""
        p={}
        try:
            os.close(fd)
        except OSError:
            pass
        try:
            os.setsid()
        except OSError:
            pass
        try:
            devnull=os.open(os.devnull,os.O_RDWR)
            for fdno in (0,1,2):
                try:
                    os.dup2(devnull,fdno)
                except OSError:
                    pass
            if devnull > 2:
                os.close(devnull)
        except OSError:
            pass
        try:
            time.sleep(ttl)
            try:
                os.unlink(handoff)
            except FileNotFoundError:
                pass
        finally:
            os._exit(0)
    with os.fdopen(fd,"w",encoding="utf-8") as fh:
        fh.write(_seal_token(token,seal_key))
sys.exit(0)'
REMOTE_TOKEN_CLEANUP_PY='import base64,json,os,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); path=os.path.expanduser(p.get("path") or "");
# token_handoff_cleanup: unlink only the governed short-lived handoff path.
path=os.path.abspath(path) if path else ""
if not path or os.path.dirname(path)!="/tmp" or not os.path.basename(path).startswith("hapax-codex-token-"):
    print("hapax-codex-headless: refusing invalid Codex OAuth token handoff cleanup path "+(path or "<empty>"), file=sys.stderr)
    sys.exit(78)
