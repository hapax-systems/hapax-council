# Governed task gate (mirrors hapax-claude-headless): refuse a mutating launch
# without an explicit task or an existing session claim, and never launch onto a
# claim that belongs to a different task.
SESSION_CLAIM_FILE="$HOME/.cache/hapax/cc-active-task-$SESSION-$SESSION_UUID"
CLAIM_FILE="$HOME/.cache/hapax/cc-active-task-$SESSION"
CLAIMED_TASK=""
if [[ -s "$SESSION_CLAIM_FILE" ]]; then
  CLAIMED_TASK="$(head -n1 "$SESSION_CLAIM_FILE" | tr -d '[:space:]')"
elif [[ -s "$CLAIM_FILE" ]]; then
  CLAIMED_TASK="$(head -n1 "$CLAIM_FILE" | tr -d '[:space:]')"
fi
if [[ -z "$CODEX_TASK" && -n "$CLAIMED_TASK" ]]; then
  CODEX_TASK="$CLAIMED_TASK"
fi
if [[ -z "$CODEX_TASK" ]]; then
  echo "hapax-codex-headless: refusing mutating launch without --task <cc-task-id> or existing active claim for '$SESSION'" >&2
  exit 15
fi
if [[ -n "$CLAIMED_TASK" && "$CLAIMED_TASK" != "$CODEX_TASK" ]]; then
  echo "hapax-codex-headless: refusing launch; '$SESSION' already claims '$CLAIMED_TASK', not dispatch task '$CODEX_TASK'" >&2
  exit 13
fi
export HAPAX_METHODOLOGY_DISPATCH_TASK="$CODEX_TASK"
CLAIM_EPOCH_LINE="$(claim_epoch_for_task "$SESSION" "$SESSION_UUID" "$CODEX_TASK" || true)"
if [[ -n "$CLAIM_EPOCH_LINE" ]]; then
  export HAPAX_METHODOLOGY_DISPATCH_CLAIM_EPOCH="$CLAIM_EPOCH_LINE"
fi

# Keep the lane from becoming a credential sink (same scrub as hapax-codex).
unset GITHUB_PERSONAL_ACCESS_TOKEN
unset CODEX_GITHUB_PERSONAL_ACCESS_TOKEN
unset TAVILY_API_KEY
unset CONTEXT7_API_KEY
MCP_CONFIG_SCRUB="$COUNCIL_DIR/scripts/hapax-codex-mcp-config-scrub"
[[ -x "$MCP_CONFIG_SCRUB" ]] && "$MCP_CONFIG_SCRUB"

LOG_DIR="$HOME/.cache/hapax/codex-headless/$SESSION"
PID_DIR="${HAPAX_CODEX_HEADLESS_PID_DIR:-/run/user/$(id -u)/hapax-codex}"
mkdir -p "$LOG_DIR" "$PID_DIR" 2>/dev/null || true
[[ -d "$PID_DIR" ]] || PID_DIR="$LOG_DIR"
LOG_FILE="$LOG_DIR/output.jsonl"
PID_FILE="$PID_DIR/$SESSION.pid"
DISPATCH_PROOF_DIR="${HAPAX_DISPATCH_PROOF_DIR:-$HOME/.cache/hapax/orchestration/dispatch-host-proofs}"
DISPATCH_PROOF_BASENAME="$(date -u +%Y%m%dT%H%M%SZ)-$SESSION-${CODEX_TASK:-no-task}-headless"
DISPATCH_PROOF_FILE="$DISPATCH_PROOF_DIR/$DISPATCH_PROOF_BASENAME-remote.json"
DISPATCH_LOCAL_PROOF_FILE="$DISPATCH_PROOF_DIR/$DISPATCH_PROOF_BASENAME-local.json"

RELAY_RETIRE="$COUNCIL_DIR/scripts/hapax-relay-retire"
CODEX_PID=""
CODEX_BIN=""
LOCAL_FALLBACK_AUTH_PROVEN=0
# shellcheck disable=SC2329
cleanup() {
  local current_pid=""
  if [[ -n "${CODEX_PID:-}" && -f "$PID_FILE" ]]; then
    current_pid="$(cat "$PID_FILE" 2>/dev/null || true)"
    if [[ "$current_pid" == "$CODEX_PID" ]]; then
      rm -f "$PID_FILE"
      [[ -x "$RELAY_RETIRE" ]] && "$RELAY_RETIRE" "$SESSION" --reason "clean exit (codex headless)" 2>/dev/null || true
    fi
  fi
}
trap cleanup EXIT

write_local_dispatch_proof() {
  local pid="$1" fallback="$2" reason="${3:-}" cgroup=""
  mkdir -p "$(dirname "$DISPATCH_LOCAL_PROOF_FILE")" 2>/dev/null || return 0
  if [[ -n "$pid" && -r "/proc/$pid/cgroup" ]]; then
    cgroup="$(cat "/proc/$pid/cgroup" 2>/dev/null || true)"
  else
    cgroup="$(cat /proc/self/cgroup 2>/dev/null || true)"
  fi
  python3 - "$DISPATCH_LOCAL_PROOF_FILE" "$SESSION" "$CODEX_TASK" "${DISPATCH_HOST_ORIGINAL:-$DISPATCH_HOST_REQUESTED}" \
    "$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf local)" "$pid" "$fallback" \
    "$reason" "$WORKDIR" "$LOGOS_BASE_URL" "$cgroup" <<'PYEOF'
import json
import sys

(
    proof_file,
    session,
    task_id,
    requested_host,
    actual_host,
    pid,
    fallback,
    reason,
    workdir,
    logos_url,
    cgroup,
) = sys.argv[1:12]
payload = {
    "schema_version": 1,
    "event": "dispatch_local_exec",
    "platform": "codex-headless",
    "session": session,
    "task_id": task_id,
    "requested_host": requested_host,
    "actual_host": actual_host,
    "pid": int(pid) if pid.isdigit() else None,
    "fallback": fallback == "1",
    "fallback_reason": reason or None,
    "cgroup": cgroup,
    "workdir": workdir,
    "logos_base_url": logos_url,
}
with open(proof_file, "w", encoding="utf-8") as fh:
    fh.write(json.dumps(payload, sort_keys=True) + "\n")
PYEOF
}

# Refuse to double-launch a live lane before any remote dispatch-host mutation.
# --force only reactivates retired relay state; it must not bypass the
# single-live-headless-lane invariant.
if [[ -f "$PID_FILE" ]]; then
  EXISTING_PID="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [[ -n "$EXISTING_PID" ]] && kill -0 "$EXISTING_PID" 2>/dev/null; then
    echo "hapax-codex-headless: lane '$SESSION' already live (pid=$EXISTING_PID); stop the live lane or remove the stale pid after verifying it is gone" >&2
    exit 11
  fi
fi

if [[ -n "$DISPATCH_HOST_REQUESTED" && -z "$CLAIMED_TASK" && "$CLAIM_TASK" -eq 1 ]]; then
  prove_local_fallback_before_claim
  [[ -x "$WORKDIR/scripts/cc-claim" ]] || { echo "hapax-codex-headless: missing cc-claim in $WORKDIR" >&2; exit 14; }
  (cd "$WORKDIR" && "$WORKDIR/scripts/cc-claim" "$CODEX_TASK")
  CLAIMED_TASK="$CODEX_TASK"
fi

if [[ -n "$DISPATCH_HOST_REQUESTED" ]]; then
  CLAIM_EPOCH_LINE="$(claim_epoch_for_task "$SESSION" "$SESSION_UUID" "$CODEX_TASK" || true)"
  if [[ -z "$CLAIM_EPOCH_LINE" ]]; then
    echo "hapax-codex-headless: refusing remote dispatch without a matching local cc-claim epoch for '$SESSION' task '$CODEX_TASK'; next action: run governed cc-claim locally for the dispatch task or omit --no-claim before remote dispatch" >&2
    exit 78
  fi
  export HAPAX_METHODOLOGY_DISPATCH_CLAIM_EPOCH="$CLAIM_EPOCH_LINE"
fi

if [[ -n "$DISPATCH_HOST_REQUESTED" ]]; then
  TOKEN_PREFLIGHT_PAYLOAD="$(remote_preflight_payload_b64 1)"
  TOKEN_PREFLIGHT_COMMAND="$(remote_python_command "$TOKEN_PREFLIGHT_PAYLOAD" "$REMOTE_PREFLIGHT_PY")"
  TOKEN_PREFLIGHT_ERR=""
  if ! TOKEN_PREFLIGHT_ERR="$(
    ssh -o BatchMode=yes -o ConnectTimeout=4 -i "$HOME/.ssh/id_ed25519" \
      -o ControlPath="$HOME/.ssh/cm-%r@%h:%p" "$DISPATCH_HOST_REQUESTED" \
      "$TOKEN_PREFLIGHT_COMMAND" 2>&1 >/dev/null
  )"; then
    DISPATCH_FALLBACK_REASON="dispatch_host_unready:$DISPATCH_HOST_REQUESTED"
    echo "hapax-codex-headless: remote Codex auth preflight failed ($DISPATCH_HOST_REQUESTED)" >&2
    [[ -n "$TOKEN_PREFLIGHT_ERR" ]] && printf '  detail: %s\n' "$TOKEN_PREFLIGHT_ERR" >&2
    if [[ "${HAPAX_DISPATCH_HOST_FALLBACK:-}" == "local" ]]; then
      echo "hapax-codex-headless: dispatch_host_unready ($DISPATCH_HOST_REQUESTED) -- explicit local fallback" >&2
      DISPATCH_HOST_REQUESTED=""
    else
      echo "  next action: ssh $DISPATCH_HOST_REQUESTED and run codex login, then retry; refusing local fallback without HAPAX_DISPATCH_HOST_FALLBACK=local" >&2
      exit 75
    fi
  fi
fi

if [[ -n "$DISPATCH_HOST_REQUESTED" ]]; then
  WORKTREE_PAYLOAD="$(remote_worktree_payload_b64)"
  WORKTREE_COMMAND="$(remote_python_command "$WORKTREE_PAYLOAD" "$REMOTE_WORKTREE_PY")"
  PREFLIGHT_PAYLOAD="$(remote_preflight_payload_b64 0 "")"
  PREFLIGHT_COMMAND="$(remote_python_command "$PREFLIGHT_PAYLOAD" "$REMOTE_PREFLIGHT_PY")"
  WORKTREE_ERR=""
  PREFLIGHT_ERR=""
  if ! WORKTREE_ERR="$(
    ssh -o BatchMode=yes -o ConnectTimeout=4 -i "$HOME/.ssh/id_ed25519" \
      -o ControlPath="$HOME/.ssh/cm-%r@%h:%p" "$DISPATCH_HOST_REQUESTED" \
      "$WORKTREE_COMMAND" 2>&1 >/dev/null
  )"; then
    DISPATCH_FALLBACK_REASON="dispatch_host_unready:$DISPATCH_HOST_REQUESTED"
    echo "hapax-codex-headless: remote worktree bootstrap failed ($DISPATCH_HOST_REQUESTED)" >&2
    [[ -n "$WORKTREE_ERR" ]] && printf '  detail: %s\n' "$WORKTREE_ERR" >&2
    if [[ "${HAPAX_DISPATCH_HOST_FALLBACK:-}" == "local" ]]; then
      echo "hapax-codex-headless: dispatch_host_unready ($DISPATCH_HOST_REQUESTED) -- explicit local fallback" >&2
      DISPATCH_HOST_REQUESTED=""
    else
      echo "  next action: ssh $DISPATCH_HOST_REQUESTED and verify $WORKDIR, $COUNCIL_DIR, git, and HAPAX_CODEX_CREATE_WORKTREE before retrying; refusing local fallback without HAPAX_DISPATCH_HOST_FALLBACK=local" >&2
      exit 75
    fi
  elif ! PREFLIGHT_ERR="$(
    ssh -o BatchMode=yes -o ConnectTimeout=4 -i "$HOME/.ssh/id_ed25519" \
      -o ControlPath="$HOME/.ssh/cm-%r@%h:%p" "$DISPATCH_HOST_REQUESTED" \
      "$PREFLIGHT_COMMAND" 2>&1 >/dev/null
  )"; then
    DISPATCH_FALLBACK_REASON="dispatch_host_unready:$DISPATCH_HOST_REQUESTED"
    echo "hapax-codex-headless: remote preflight failed ($DISPATCH_HOST_REQUESTED)" >&2
    [[ -n "$PREFLIGHT_ERR" ]] && printf '  detail: %s\n' "$PREFLIGHT_ERR" >&2
    if [[ "${HAPAX_DISPATCH_HOST_FALLBACK:-}" == "local" ]]; then
      echo "hapax-codex-headless: dispatch_host_unready ($DISPATCH_HOST_REQUESTED) -- explicit local fallback" >&2
      DISPATCH_HOST_REQUESTED=""
    else
      echo "  next action: ssh $DISPATCH_HOST_REQUESTED and verify $WORKDIR, $COUNCIL_DIR, $HOME/projects/hapax-mcp, python3, codex, the hook adapter, and saved Codex auth before retrying; refusing local fallback without HAPAX_DISPATCH_HOST_FALLBACK=local" >&2
      exit 75
    fi
  else
    DISPATCH_HOST="$DISPATCH_HOST_REQUESTED"
  fi
fi

if [[ -z "$DISPATCH_HOST_REQUESTED" && -z "$DISPATCH_HOST" ]]; then
  if [[ "$LOCAL_FALLBACK_AUTH_PROVEN" != "1" ]]; then
    strip_inherited_codex_access_token
    CODEX_BIN="$(resolve_local_codex_bin)"
    prove_local_codex_exec_auth "$CODEX_BIN"
    LOCAL_FALLBACK_AUTH_PROVEN=1
  fi
  if [[ -z "$CLAIMED_TASK" && "$CLAIM_TASK" -eq 1 ]]; then
    [[ -x "$WORKDIR/scripts/cc-claim" ]] || { echo "hapax-codex-headless: missing cc-claim in $WORKDIR" >&2; exit 14; }
    (cd "$WORKDIR" && "$WORKDIR/scripts/cc-claim" "$CODEX_TASK")
    CLAIMED_TASK="$CODEX_TASK"
  fi
fi

if [[ -n "$DISPATCH_HOST" ]]; then
  CLAIM_EPOCH_LINE="$(claim_epoch_for_task "$SESSION" "$SESSION_UUID" "$CODEX_TASK" || true)"
  if [[ -z "$CLAIM_EPOCH_LINE" ]]; then
    echo "hapax-codex-headless: refusing remote dispatch without a matching local cc-claim epoch for '$SESSION' task '$CODEX_TASK'; next action: run governed cc-claim locally for the dispatch task or omit --no-claim before remote dispatch" >&2
    exit 78
  fi
  export HAPAX_METHODOLOGY_DISPATCH_CLAIM_EPOCH="$CLAIM_EPOCH_LINE"
  POST_CLAIM_PREFLIGHT_PAYLOAD="$(remote_preflight_payload_b64 0)"
  POST_CLAIM_PREFLIGHT_COMMAND="$(remote_python_command "$POST_CLAIM_PREFLIGHT_PAYLOAD" "$REMOTE_PREFLIGHT_PY")"
  POST_CLAIM_PREFLIGHT_ERR=""
  if ! POST_CLAIM_PREFLIGHT_ERR="$(
    ssh -o BatchMode=yes -o ConnectTimeout=4 -i "$HOME/.ssh/id_ed25519" \
      -o ControlPath="$HOME/.ssh/cm-%r@%h:%p" "$DISPATCH_HOST" \
      "$POST_CLAIM_PREFLIGHT_COMMAND" 2>&1 >/dev/null
  )"; then
    echo "hapax-codex-headless: remote Codex auth preflight failed after claim ($DISPATCH_HOST)" >&2
    [[ -n "$POST_CLAIM_PREFLIGHT_ERR" ]] && printf '  detail: %s\n' "$POST_CLAIM_PREFLIGHT_ERR" >&2
    echo "  next action: ssh $DISPATCH_HOST and run codex login, then rerun remote preflight before dispatching Codex lanes" >&2
    exit 75
  fi
  echo "hapax-codex-headless: dispatch -> $DISPATCH_HOST (codex exec on appendix)" >&2
fi

if [[ -n "$DISPATCH_HOST" ]]; then
  LOGOS_BASE_URL="${HAPAX_DISPATCH_LOGOS_URL:-http://192.168.68.85:8051/api}"
else
  LOGOS_BASE_URL="${LOGOS_BASE_URL:-http://localhost:8051/api}"
fi
COCKPIT_BASE_URL="${COCKPIT_BASE_URL:-$LOGOS_BASE_URL}"

if [[ -z "$DISPATCH_HOST" ]]; then
  CODEX_BIN="${CODEX_BIN:-$(resolve_local_codex_bin)}"
else
  CODEX_BIN="codex"
fi

SDLC_PREAMBLE="SDLC DISCIPLINE (MANDATORY):
1. Work only on the task named in this dispatch.
2. Before mutation, verify this lane owns the task claim. If the task is still offered, run $WORKDIR/scripts/cc-claim $CODEX_TASK. If the launcher already claimed it, confirm $SESSION_CLAIM_FILE or $CLAIM_FILE contains $CODEX_TASK and the task note is assigned to this lane.
3. If claim ownership is absent, cc-claim rejects for another reason, or the task is assigned to another lane, stop and write a relay receipt.
4. Use only the AuthorityCase and parent spec named in this dispatch.
5. Do not create, select, or claim other work from the task pool.
6. When the task is complete or blocked, report status and idle.

DISPATCH:
"
INITIAL_MSG="${SDLC_PREAMBLE}${INITIAL_MSG}"

# Config mirrors hapax-codex's governed CODEX_ARGS (shared contract — keep in
# sync): full-access sandbox under external governance, the codex-hook-adapter on
# every phase, and the hapax MCP surface. `--json` streams JSONL events; `--cd`
# binds the worktree; trust is scoped to the worktree.
CODEX_ARGS=(
  exec
  --dangerously-bypass-approvals-and-sandbox
  --skip-git-repo-check
  --json
  --cd "$WORKDIR"
  -c 'model="gpt-5.5"'
  -c 'model_reasoning_effort="xhigh"'
  -c 'approval_policy="never"'
  -c 'sandbox_mode="danger-full-access"'
  -c "projects.\"$HOME/projects\".trust_level=\"trusted\""
  -c "projects.\"$WORKDIR\".trust_level=\"trusted\""
  -c "hooks.SessionStart=[{command=\"$HOOK\",timeout=20,statusMessage=\"Loading Hapax context\"}]"
  -c "hooks.PreToolUse=[{command=\"$HOOK\",timeout=20,include_apply_patch_tool=true,statusMessage=\"Hapax guardrails\"}]"
  -c "hooks.PostToolUse=[{command=\"$HOOK\",timeout=20,include_apply_patch_tool=true,statusMessage=\"Hapax audit\"}]"
  -c "hooks.Stop=[{command=\"$HOOK\",timeout=20,statusMessage=\"Writing Hapax session summary\"}]"
  -c "mcp_servers.hapax.command=\"$HOME/.local/bin/uv\""
  -c "mcp_servers.hapax.args=[\"--directory\",\"$HOME/projects/hapax-mcp\",\"run\",\"hapax-mcp\"]"
  -c "mcp_servers.hapax.env.LOGOS_BASE_URL=\"$LOGOS_BASE_URL\""
  -c "mcp_servers.github.command=\"$COUNCIL_DIR/scripts/hapax-github-mcp\""
  -c "mcp_servers.context7.command=\"$COUNCIL_DIR/scripts/hapax-context7-mcp\""
)
CODEX_ARGS+=("${CODEX_EXTRA[@]}")
CODEX_ARGS+=("$INITIAL_MSG")

echo "hapax-codex-headless: starting $SESSION (task=$CODEX_TASK) in $WORKDIR"
echo "  log: $LOG_FILE"
echo "  pid: $PID_FILE"

cd "$WORKDIR"
if [[ -n "$DISPATCH_HOST" ]]; then
  CLAIM_EPOCH_LINE="$(claim_epoch_for_task "$SESSION" "$SESSION_UUID" "$CODEX_TASK" || true)"
  if [[ -z "$CLAIM_EPOCH_LINE" ]]; then
    echo "hapax-codex-headless: refusing remote dispatch without a matching local cc-claim epoch for '$SESSION' task '$CODEX_TASK'; next action: run governed cc-claim locally for the dispatch task or omit --no-claim before remote dispatch" >&2
    exit 78
  fi
  export HAPAX_METHODOLOGY_DISPATCH_CLAIM_EPOCH="$CLAIM_EPOCH_LINE"
  REMOTE_EXEC_PAYLOAD="$(remote_exec_payload_b64 "$DISPATCH_PROOF_FILE" codex "${CODEX_ARGS[@]}")"
  REMOTE_EXEC_COMMAND="$(remote_python_command "$REMOTE_EXEC_PAYLOAD" "$REMOTE_EXEC_PY")"
  ssh -o BatchMode=yes -o RequestTTY=no -o ServerAliveInterval=30 -o ServerAliveCountMax=6 \
    -o ControlPath=none -i "$HOME/.ssh/id_ed25519" "$DISPATCH_HOST" "$REMOTE_EXEC_COMMAND" \
    >>"$LOG_FILE" 2>&1 &
else
  "$CODEX_BIN" "${CODEX_ARGS[@]}" >>"$LOG_FILE" 2>&1 &
fi
CODEX_PID=$!
echo "$CODEX_PID" >"$PID_FILE"
echo "hapax-codex-headless: pid=$CODEX_PID"
if [[ -z "$DISPATCH_HOST" && -n "$DISPATCH_FALLBACK_REASON" ]]; then
  write_local_dispatch_proof "$CODEX_PID" "1" "$DISPATCH_FALLBACK_REASON"
fi

if wait "$CODEX_PID"; then
  EXIT_CODE=0
else
  EXIT_CODE=$?
fi
echo "hapax-codex-headless: $SESSION exited (code=$EXIT_CODE)"
exit "$EXIT_CODE"
