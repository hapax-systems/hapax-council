    os.unlink(path)
except FileNotFoundError:
    pass
sys.exit(0)'
REMOTE_WORKTREE_PY='import base64,json,os,shutil,subprocess,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); workdir=p["workdir"]; council=p["council_dir"];
def fail(message):
    print("remote worktree bootstrap refused: "+message+"; next action: ssh to the dispatch host and verify the council checkout, target worktree path, git binary, and HAPAX_CODEX_CREATE_WORKTREE before retrying", file=sys.stderr)
    sys.exit(1)
if os.path.isdir(workdir):
    sys.exit(0)
if p.get("workdir_explicit"):
    fail("explicit HAPAX_CODEX_HEADLESS_WORKDIR is missing on dispatch host: "+workdir)
if not p.get("create_worktree"):
    fail("worktree creation disabled by HAPAX_CODEX_CREATE_WORKTREE=0 and default workdir is missing on dispatch host: "+workdir)
if not os.path.isdir(council):
    fail("council checkout missing on dispatch host: "+council)
if shutil.which("git") is None:
    fail("git binary missing on dispatch host")
if subprocess.run(["git","-C",council,"rev-parse","--is-inside-work-tree"],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL).returncode != 0:
    fail("council checkout is not a git worktree: "+council)
os.makedirs(os.path.dirname(workdir),exist_ok=True)
base=p.get("base_ref") or "main"
if subprocess.run(["git","-C",council,"rev-parse","--verify","--quiet",base],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL).returncode != 0:
    base="HEAD"
branch=p.get("branch") or "codex/"+p.get("session","cx-headless")
if subprocess.run(["git","-C",council,"show-ref","--verify","--quiet","refs/heads/"+branch],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL).returncode == 0:
    cmd=["git","-C",council,"worktree","add",workdir,branch]
else:
    cmd=["git","-C",council,"worktree","add","-b",branch,workdir,base]
result=subprocess.run(cmd,stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL)
if result.returncode != 0 or not os.path.isdir(workdir):
    fail("git worktree add failed for "+workdir+" using branch "+branch+" (rc="+str(result.returncode)+")")
sys.exit(0)'
REMOTE_EXEC_PY='import base64,hashlib,hmac,json,os,socket,sys,time; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); os.chdir(p["workdir"]); os.environ.update(p.get("env",{})); proof=p.get("proof_file",""); cgroup="";
try:
    cgroup=open("/proc/self/cgroup",encoding="utf-8").read()
except OSError:
    pass
def _jwt_exp(token):
    try:
        payload=token.split(".")[1]; payload += "=" * (-len(payload) % 4)
        return float(json.loads(base64.urlsafe_b64decode(payload.encode("ascii"))).get("exp",0))
    except Exception:
        return 0.0
def _unseal_token(blob,key_hex):
    try:
        key=bytes.fromhex(key_hex)
    except ValueError:
        key=b""
    if not key:
        print("hapax-codex-headless: missing Codex OAuth token handoff seal key; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    try:
        prefix,cipher_b64,mac=blob.split(".",2)
    except ValueError:
        print("hapax-codex-headless: preflight-proven Codex OAuth token handoff is unsealed; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    if prefix != "hapax-token-sealed-v1":
        print("hapax-codex-headless: preflight-proven Codex OAuth token handoff has unknown seal format; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    try:
        cipher=base64.urlsafe_b64decode((cipher_b64+"="*(-len(cipher_b64)%4)).encode("ascii"))
    except Exception:
        print("hapax-codex-headless: preflight-proven Codex OAuth token handoff seal is unparseable; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    expected=hmac.new(key,b"hapax-codex-token-handoff-v1\0"+cipher,hashlib.sha256).hexdigest()
    if not hmac.compare_digest(mac,expected):
        print("hapax-codex-headless: preflight-proven Codex OAuth token handoff seal failed authentication; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
        sys.exit(78)
    stream=hashlib.shake_256(key+b":hapax-codex-token-handoff-v1").digest(len(cipher))
    return bytes(a^b for a,b in zip(cipher,stream)).decode("utf-8")
token_handoff=p.get("token_handoff_file") or ""
if not token_handoff:
    print("hapax-codex-headless: missing preflight-proven Codex OAuth token handoff; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
    sys.exit(78)
token_path=os.path.expanduser(token_handoff)
try:
    token_blob=open(token_path,encoding="utf-8").read().strip()
except OSError:
    print("hapax-codex-headless: missing preflight-proven Codex OAuth token handoff at "+token_path+"; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
    sys.exit(78)
try:
    os.unlink(token_path)
except OSError as exc:
    print("hapax-codex-headless: failed to delete preflight-proven Codex OAuth token handoff at "+token_path+" ("+exc.__class__.__name__+"); next action: remove the handoff file on the dispatch host before retrying", file=sys.stderr)
    sys.exit(78)
token=_unseal_token(token_blob,p.get("token_handoff_seal_key") or "")
if not token:
    print("hapax-codex-headless: preflight-proven Codex OAuth token handoff is absent; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
    sys.exit(78)
if _jwt_exp(token) - time.time() <= 300:
    print("hapax-codex-headless: preflight-proven Codex OAuth token handoff is expiring; next action: rerun remote preflight before dispatching Codex lanes", file=sys.stderr)
    sys.exit(78)
os.environ["CODEX_ACCESS_TOKEN"]=token
# Exec-host identity materialization mirrors hapax-claude-headless: the
# session-keyed claim must exist where codex exec runs, or the worker can fall
# back to stale legacy lane state and reject the governed dispatch.
sid=os.environ.get("HAPAX_SESSION_ID",""); role=os.environ.get("HAPAX_AGENT_ROLE",""); task=os.environ.get("HAPAX_METHODOLOGY_DISPATCH_TASK",""); claim_epoch=os.environ.get("HAPAX_METHODOLOGY_DISPATCH_CLAIM_EPOCH",""); keyable=False; materialized=False; claim_epoch_verified=False
try:
    sys.path.insert(0, p["workdir"])
    from shared.session_identity import is_claim_keyable_session_id
    keyable=is_claim_keyable_session_id(sid)
except Exception:
    keyable=bool(sid) and "/" not in sid and not sid.isdigit() and not sid.rsplit("-",1)[-1].isdigit()
try:
    if keyable and role:
        cache=os.path.join(os.path.expanduser("~"),".cache","hapax")
        os.makedirs(cache,exist_ok=True)
        open(os.path.join(cache,"session-role-"+sid),"w",encoding="utf-8").write(role+"\n")
        if task:
            epoch,sep,epoch_task=claim_epoch.partition(" ")
            if not sep or not epoch.isdigit() or epoch_task != task:
                print("hapax-codex-headless: refusing remote claim materialization without matching local cc-claim epoch; next action: run governed cc-claim locally for the dispatch task or omit --no-claim before remote dispatch", file=sys.stderr)
                sys.exit(78)
            epoch_line=claim_epoch+"\n"
            open(os.path.join(cache,"cc-claim-epoch-"+role),"w",encoding="utf-8").write(epoch_line)
            open(os.path.join(cache,"cc-claim-epoch-"+role+"-"+sid),"w",encoding="utf-8").write(epoch_line)
            open(os.path.join(cache,"cc-active-task-"+role),"w",encoding="utf-8").write(task+"\n")
            open(os.path.join(cache,"cc-active-task-"+role+"-"+sid),"w",encoding="utf-8").write(task+"\n")
            materialized=True; claim_epoch_verified=True
except Exception as exc:
    print("hapax-codex-headless: failed to materialize remote claim cache ("+exc.__class__.__name__+"); next action: repair ~/.cache/hapax permissions on the dispatch host before retrying", file=sys.stderr)
    sys.exit(78)
if proof:
    os.makedirs(os.path.dirname(proof), exist_ok=True)
    data={"schema_version":1,"event":"dispatch_remote_exec","platform":"codex-headless","session":p.get("session"),"task_id":p.get("task_id"),"requested_host":p.get("requested_host"),"actual_host":socket.gethostname(),"pid":os.getpid(),"cgroup":cgroup,"workdir":p.get("workdir"),"logos_base_url":os.environ.get("LOGOS_BASE_URL"),"argv0":p["argv"][0] if p.get("argv") else None,"argc":len(p.get("argv",[])),"session_id":sid or None,"role":role or None,"claim_materialized":materialized,"claim_epoch_verified":claim_epoch_verified}; open(proof,"w",encoding="utf-8").write(json.dumps(data,sort_keys=True)+"\n")
argv=p["argv"]; os.execvp(argv[0], argv)'

usage() {
  cat >&2 <<'EOF'
usage: hapax-codex-headless [--task TASK_ID] [--no-claim] [--force] <cx-session> <governed-initial-message> [-- codex exec args...]

Default-deny: enable with `touch ~/.cache/hapax/enable-codex-headless` or
HAPAX_CODEX_HEADLESS_ALLOW=1. The governed initial message is the codex exec
prompt; everything after `--` is passed through to `codex exec`.
EOF
}

SESSION=""
CODEX_TASK="${HAPAX_METHODOLOGY_DISPATCH_TASK:-}"
CLAIM_TASK=1
FORCE=0
CODEX_EXTRA=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --task)
      CODEX_TASK="${2:-}"
      shift 2
      ;;
    --task=*)
      CODEX_TASK="${1#--task=}"
      shift
      ;;
    --no-claim)
      CLAIM_TASK=0
      shift
      ;;
    --force)
      FORCE=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      SESSION="$1"
      shift
      break
      ;;
  esac
done

if [[ -z "$SESSION" ]]; then
  usage
  exit 1
fi
if ! hapax_agent_is_codex_name "$SESSION"; then
  echo "hapax-codex-headless: invalid session '$SESSION' (expected cx-<color>)" >&2
  exit 2
fi

INITIAL_MSG="${1:-}"
[[ $# -gt 0 ]] && shift
# Strip an optional `--` separator, then pass the rest through to `codex exec`.
[[ "${1:-}" == "--" ]] && shift
if [[ $# -gt 0 ]]; then
  CODEX_EXTRA+=("$@")
fi

if [[ -z "$INITIAL_MSG" ]]; then
  echo "hapax-codex-headless: governed initial message required" >&2
  exit 5
fi

if [[ -e "$DISABLE_FILE" ]]; then
  echo "hapax-codex-headless: disabled by $DISABLE_FILE" >&2
  exit 77
fi
if ! headless_allowed; then
  echo "hapax-codex-headless: disabled until governed enable exists at $ENABLE_FILE or HAPAX_CODEX_HEADLESS_ALLOW=1 is set" >&2
  echo "  enable with: touch $ENABLE_FILE" >&2
  exit 77
fi

RELAY_STATUS_FILE="${HAPAX_RELAY_DIR:-$HOME/.cache/hapax/relay}/$SESSION.yaml"
if [[ "$FORCE" -ne 1 ]] && relay_retired "$SESSION"; then
  echo "hapax-codex-headless: relay '$SESSION' is retired/wound-down ($RELAY_STATUS_FILE); recheck: sed -n '1,80p' \"$RELAY_STATUS_FILE\"; pass --force to reactivate (P0 drain lanes do this automatically)" >&2
  exit 6
fi

