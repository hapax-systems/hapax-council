if subprocess.run(["git","-C",council,"show-ref","--verify","--quiet","refs/heads/"+branch],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL).returncode == 0:
    cmd=["git","-C",council,"worktree","add",workdir,branch]
else:
    cmd=["git","-C",council,"worktree","add","-b",branch,workdir,base]
result=subprocess.run(cmd,stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL)
if result.returncode != 0 or not os.path.isdir(workdir):
    fail("git worktree add failed for "+workdir+" using branch "+branch+" (rc="+str(result.returncode)+")")
sys.exit(0)'
REMOTE_EXEC_PY='import base64,hashlib,hmac,json,os,shutil,socket,sys,time; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); os.chdir(p["workdir"]); os.environ.update(p.get("env",{})); proof=p.get("proof_file",""); cgroup="";
try:
    cgroup=open("/proc/self/cgroup",encoding="utf-8").read()
except OSError:
    pass
def _resolve_path(binary):
    path=os.path.expanduser(binary)
    if os.path.isabs(path) or os.sep in path:
        return os.path.abspath(path) if os.path.isfile(path) and os.access(path,os.X_OK) else None
    return shutil.which(binary)
def _resolve_codex_bin():
    codex_bin=shutil.which("codex")
    if codex_bin:
        return codex_bin,""
    npm_prefix=(p.get("npm_config_prefix") or os.environ.get("NPM_CONFIG_PREFIX","")).rstrip("/")
    for candidate in ((p.get("codex_bin_path") or os.environ.get("HAPAX_CODEX_BIN_PATH") or "").strip(),os.path.expanduser("~/.npm-global/bin/codex"),(npm_prefix+"/bin/codex") if npm_prefix else "",os.path.expanduser("~/.local/share/npm/bin/codex"),"/usr/local/bin/codex"):
        if candidate:
            resolved=_resolve_path(candidate)
            if resolved:
                return resolved,""
    return None,"codex_binary_missing"
os.environ.pop("CODEX_ACCESS_TOKEN",None); os.environ.pop("CODEX_HOME",None); os.environ.pop("CODEX_API_KEY",None); os.environ.pop("OPENAI_API_KEY",None)
# Exec-host identity materialization mirrors hapax-claude-headless: the
# session-keyed claim must exist where codex exec runs, or the worker can fall
# back to stale legacy lane state and reject the governed dispatch.
sid=os.environ.get("HAPAX_SESSION_ID",""); role=os.environ.get("HAPAX_AGENT_ROLE",""); task=os.environ.get("HAPAX_METHODOLOGY_DISPATCH_TASK",""); claim_epoch=os.environ.get("HAPAX_METHODOLOGY_DISPATCH_CLAIM_EPOCH",""); keyable=False; materialized=False; claim_epoch_verified=False
try:
    sys.path.insert(0, p["workdir"])
    from shared.session_identity import is_claim_keyable_session_id
    keyable=is_claim_keyable_session_id(sid)
except Exception:
    keyable=bool(sid) and "/" not in sid and not sid.isdigit() and not sid.rsplit("-",1)[-1].isdigit()
try:
    if keyable and role:
        cache=os.path.join(os.path.expanduser("~"),".cache","hapax")
        os.makedirs(cache,exist_ok=True)
        open(os.path.join(cache,"session-role-"+sid),"w",encoding="utf-8").write(role+"\n")
        if task:
            epoch,sep,epoch_task=claim_epoch.partition(" ")
            if not sep or not epoch.isdigit() or epoch_task != task:
                print("hapax-codex-headless: refusing remote claim materialization without matching local cc-claim epoch; next action: run governed cc-claim locally for the dispatch task or omit --no-claim before remote dispatch", file=sys.stderr)
                sys.exit(78)
            epoch_line=claim_epoch+"\n"
            open(os.path.join(cache,"cc-claim-epoch-"+role),"w",encoding="utf-8").write(epoch_line)
            open(os.path.join(cache,"cc-claim-epoch-"+role+"-"+sid),"w",encoding="utf-8").write(epoch_line)
            open(os.path.join(cache,"cc-active-task-"+role),"w",encoding="utf-8").write(task+"\n")
            open(os.path.join(cache,"cc-active-task-"+role+"-"+sid),"w",encoding="utf-8").write(task+"\n")
            materialized=True; claim_epoch_verified=True
except Exception as exc:
    print("hapax-codex-headless: failed to materialize remote claim cache ("+exc.__class__.__name__+"); next action: repair ~/.cache/hapax permissions on the dispatch host before retrying", file=sys.stderr)
    sys.exit(78)
codex_bin,codex_resolution_error=_resolve_codex_bin()
if codex_bin is None:
    print("hapax-codex-headless: remote Codex binary is unavailable: "+codex_resolution_error+"; next action: repair PATH on the dispatch host or set HAPAX_CODEX_BIN_PATH to the executable before retrying", file=sys.stderr)
    sys.exit(78)
if proof:
    os.makedirs(os.path.dirname(proof), exist_ok=True)
    data={"schema_version":1,"event":"dispatch_remote_exec","platform":"codex-headless","session":p.get("session"),"task_id":p.get("task_id"),"requested_host":p.get("requested_host"),"actual_host":socket.gethostname(),"pid":os.getpid(),"cgroup":cgroup,"workdir":p.get("workdir"),"logos_base_url":os.environ.get("LOGOS_BASE_URL"),"argv0":codex_bin,"argc":len(p.get("argv",[])),"session_id":sid or None,"role":role or None,"claim_materialized":materialized,"claim_epoch_verified":claim_epoch_verified}; open(proof,"w",encoding="utf-8").write(json.dumps(data,sort_keys=True)+"\n")
argv=p["argv"]; argv[0]=codex_bin; os.execv(codex_bin, argv)'

usage() {
  cat >&2 <<'EOF'
usage: hapax-codex-headless [--task TASK_ID] [--no-claim] [--force] <cx-session> <governed-initial-message> [-- codex exec args...]

Default-deny: enable with `touch ~/.cache/hapax/enable-codex-headless` or
HAPAX_CODEX_HEADLESS_ALLOW=1. The governed initial message is the codex exec
prompt; everything after `--` is passed through to `codex exec`.
EOF
}

SESSION=""
CODEX_TASK="${HAPAX_METHODOLOGY_DISPATCH_TASK:-}"
CLAIM_TASK=1
FORCE=0
CODEX_EXTRA=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --task)
      CODEX_TASK="${2:-}"
      shift 2
      ;;
    --task=*)
      CODEX_TASK="${1#--task=}"
      shift
      ;;
    --no-claim)
      CLAIM_TASK=0
      shift
      ;;
    --force)
      FORCE=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      SESSION="$1"
      shift
      break
      ;;
  esac
done

if [[ -z "$SESSION" ]]; then
  usage
  exit 1
fi
if ! hapax_agent_is_codex_name "$SESSION"; then
  echo "hapax-codex-headless: invalid session '$SESSION' (expected cx-<color>)" >&2
  exit 2
fi

INITIAL_MSG="${1:-}"
[[ $# -gt 0 ]] && shift
# Strip an optional `--` separator, then pass the rest through to `codex exec`.
[[ "${1:-}" == "--" ]] && shift
if [[ $# -gt 0 ]]; then
  CODEX_EXTRA+=("$@")
fi

if [[ -z "$INITIAL_MSG" ]]; then
  echo "hapax-codex-headless: governed initial message required" >&2
  exit 5
fi

if [[ -e "$DISABLE_FILE" ]]; then
  echo "hapax-codex-headless: disabled by $DISABLE_FILE" >&2
  exit 77
fi
if ! headless_allowed; then
  echo "hapax-codex-headless: disabled until governed enable exists at $ENABLE_FILE or HAPAX_CODEX_HEADLESS_ALLOW=1 is set" >&2
  echo "  enable with: touch $ENABLE_FILE" >&2
  exit 77
fi

RELAY_STATUS_FILE="${HAPAX_RELAY_DIR:-$HOME/.cache/hapax/relay}/$SESSION.yaml"
if [[ "$FORCE" -ne 1 ]] && relay_retired "$SESSION"; then
  echo "hapax-codex-headless: relay '$SESSION' is retired/wound-down ($RELAY_STATUS_FILE); recheck: sed -n '1,80p' \"$RELAY_STATUS_FILE\"; pass --force to reactivate (P0 drain lanes do this automatically)" >&2
  exit 6
fi

# Worktree selection mirrors hapax-codex's codex-native default.
WORKDIR_EXPLICIT=0
if [[ -n "${HAPAX_CODEX_HEADLESS_WORKDIR:-}" ]]; then
  WORKDIR="$HAPAX_CODEX_HEADLESS_WORKDIR"
  WORKDIR_EXPLICIT=1
else
  WORKDIR="$HOME/projects/hapax-council--$SESSION"
fi
if [[ ! -d "$WORKDIR" && "$WORKDIR_EXPLICIT" -eq 0 ]]; then
  WORKDIR="$COUNCIL_DIR"
fi
[[ -d "$WORKDIR" ]] || { echo "hapax-codex-headless: worktree not found: $WORKDIR" >&2; exit 3; }
WORKDIR="$(cd "$WORKDIR" && pwd)"

HOOK="$COUNCIL_DIR/hooks/scripts/codex-hook-adapter.sh"
[[ -x "$HOOK" ]] || { echo "hapax-codex-headless: hook adapter not executable: $HOOK" >&2; exit 6; }

DISPATCH_HOST_REQUESTED="${HAPAX_DISPATCH_HOST:-}"
DISPATCH_HOST_ORIGINAL="$DISPATCH_HOST_REQUESTED"
DISPATCH_HOST=""
DISPATCH_FALLBACK_REASON=""
if [[ -n "$DISPATCH_HOST_REQUESTED" ]] && dispatch_host_is_local "$DISPATCH_HOST_REQUESTED"; then
  DISPATCH_HOST_REQUESTED=""
fi

strip_inherited_codex_access_token

# Identity env — same contract as hapax-codex so the gate keys a session-scoped
# claim lease (reform Phase 1, FM-2) and the hooks recover this lane's role.
PARENT_INTERFACE="${HAPAX_PARENT_AGENT_INTERFACE:-${HAPAX_AGENT_INTERFACE:-unknown}}"
PARENT_NAME="${HAPAX_PARENT_AGENT_NAME:-${HAPAX_AGENT_NAME:-unknown}}"
SESSION_UUID="$(normalize_session_uuid "${HAPAX_SESSION_ID:-}")"
export HAPAX_PARENT_AGENT_INTERFACE="$PARENT_INTERFACE"
export HAPAX_PARENT_AGENT_NAME="$PARENT_NAME"
export HAPAX_AGENT_INTERFACE="codex"
