#!/usr/bin/env bash
# hapax-codex-headless - Launch a Codex lane non-interactively via `codex exec`.
#
# The genuine headless analog to hapax-claude-headless: NO tmux pane. Codex runs
# non-interactively, JSONL events stream to a log the headless-staleness watchdog
# can read, a PID file marks the run live, and the same identity-env + governed
# task-gate + hook wiring as hapax-codex applies. Default-deny: headless lanes
# mutate source autonomously, so a governed enable must exist first.

set -euo pipefail

COUNCIL_DIR="${HAPAX_COUNCIL_DIR:-$HOME/projects/hapax-council}"
ROLE_HELPER="$COUNCIL_DIR/hooks/scripts/agent-role.sh"
if [ -f "$ROLE_HELPER" ]; then
  # shellcheck source=../hooks/scripts/agent-role.sh
  # shellcheck disable=SC1091
  . "$ROLE_HELPER"
fi
if ! declare -F hapax_agent_is_codex_name >/dev/null 2>&1; then
  hapax_agent_is_codex_name() {
    [[ "${1:-}" =~ ^cx-[a-z][a-z-]*$ ]]
  }
fi

DISABLE_FILE="${HAPAX_CODEX_HEADLESS_DISABLE_FILE:-$HOME/.cache/hapax/disable-codex-headless}"
ENABLE_FILE="${HAPAX_CODEX_HEADLESS_ENABLE_FILE:-$HOME/.cache/hapax/enable-codex-headless}"

headless_allowed() {
  [[ "${HAPAX_CODEX_HEADLESS_ALLOW:-}" == "1" || -e "$ENABLE_FILE" ]]
}

relay_retired() {
  # Delegate to the single-source predicate (shared/relay_lifecycle.lane_is_retired)
  # so the launcher agrees with the dispatch gate + the coordinator: one
  # broad-9 vocabulary, freshest-of-candidates resolution, multi-doc
  # latest-wins. The legacy awk (relay_current_values/relay_value_is_retired
  # below) over-refused SUPERSEDED/CLOSED lane relays (task/claim states that
  # leaked); dead code retained for a minimal diff — remove later. FAIL-OPEN on
  # tooling error (python missing / import fail): the gate at
  # coord_dispatch.run_atomic_dispatch_launch is authoritative on the governed
  # path, so a fail-open launcher only ever sees gate-allowed lanes.
  local relay_name="$1"
  local council_root
  local relay_dir="${HAPAX_RELAY_DIR:-$HOME/.cache/hapax/relay}"
  council_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  PYTHONPATH="$council_root${PYTHONPATH:+:$PYTHONPATH}" python3 -c '
import sys
from pathlib import Path
from shared.relay_lifecycle import lane_is_retired
sys.exit(0 if lane_is_retired(sys.argv[1], relay_dir=Path(sys.argv[2])) else 1)
' "$relay_name" "$relay_dir" 2>/dev/null
  case $? in
    0) return 0 ;;
    *) return 1 ;;  # 1 = not retired; any other = tooling error -> fail-open
  esac
}

relay_current_values() {
  local relay_file="$1"
  awk '
    BEGIN { in_session_status = 0 }

    in_session_status {
      if ($0 ~ /^[[:space:]]*$/) {
        next
      }
      if ($0 !~ /^[[:space:]]+/) {
        in_session_status = 0
      } else {
        value = $0
        sub(/^[[:space:]]+/, "", value)
        print value
        in_session_status = 0
        next
      }
    }

    /^(status|state|relay_status|session_state|role):[[:space:]]*/ {
      value = $0
      sub(/^[^:]+:[[:space:]]*/, "", value)
      if (value !~ /^[|>]/) {
        print value
      }
      next
    }

    /^session_status:[[:space:]]*/ {
      value = $0
      sub(/^session_status:[[:space:]]*/, "", value)
      if (value ~ /^[|>]/) {
        in_session_status = 1
        next
      }
      print value
      next
    }
  ' "$relay_file"
}

relay_value_is_retired() {
  local value="$1"
  local normalized first_word
  normalized="$(printf '%s' "$value" | sed "s/^[[:space:]\"']*//; s/[[:space:]\"']*$//" | tr '[:lower:]' '[:upper:]')"
  first_word="${normalized%%[[:space:]]*}"
  case "$first_word" in
    RETIRED*|SUPERSEDED*|CLOSED*|IDLE_WOUND_DOWN*|WIND_DOWN_IDLE*|WOUND_DOWN*|WIND_DOWN*|WINDING_DOWN*|ANTIGRAVITY_TAKEOVER)
      return 0
      ;;
  esac
  case "$normalized" in
    RETIRED*|SUPERSEDED*|CLOSED*|IDLE_WOUND_DOWN*|WIND_DOWN_IDLE*|WOUND_DOWN*|WIND_DOWN*|WINDING_DOWN*|ANTIGRAVITY_TAKEOVER)
      return 0
      ;;
  esac
  return 1
}

dispatch_host_is_local() {
  local host="${1:-}" short="" fqdn="" local_ip="" resolved_ip=""
  [[ -z "$host" || "$host" == "local" || "$host" == "localhost" ]] && return 0
  [[ "$host" == "127.0.0.1" || "$host" == "::1" ]] && return 0
  short="$(hostname -s 2>/dev/null || hostname 2>/dev/null || true)"
  fqdn="$(hostname -f 2>/dev/null || true)"
  [[ "$host" == "appendix" ]] && host="hapax-appendix"
  [[ "$host" == "podium" ]] && host="hapax-podium"
  [[ -n "$short" && "$host" == "$short" ]] && return 0
  [[ -n "$fqdn" && "$host" == "$fqdn" ]] && return 0
  for local_ip in $(hostname -I 2>/dev/null || true); do
    [[ "$host" == "$local_ip" ]] && return 0
  done
  if command -v getent >/dev/null 2>&1; then
    for resolved_ip in $(getent ahosts "$host" 2>/dev/null | awk '{print $1}'); do
      for local_ip in $(hostname -I 2>/dev/null || true); do
        [[ "$resolved_ip" == "$local_ip" ]] && return 0
      done
    done
  fi
  return 1
}

safe_path_component() {
  local component
  component="$(printf '%s\n' "$1" | tr -cs 'A-Za-z0-9_-' '-' | sed 's/^-//; s/-$//' | cut -c1-96)"
  if [[ -z "$component" ]]; then
    component="session"
  fi
  printf '%s\n' "$component"
}

session_id_is_safe() {
  local sid="${1:-}" tail=""
  [[ "${#sid}" -ge 8 && "${#sid}" -le 128 ]] || return 1
  case "$sid" in
    [A-Za-z0-9]*) ;;
    *) return 1 ;;
  esac
  case "$sid" in
    *[!A-Za-z0-9._-]*) return 1 ;;
  esac
  case "$sid" in
    *[!0-9]*) ;;
    *) return 1 ;;
  esac
  tail="${sid##*-}"
  if [[ "$tail" =~ ^[0-9]{1,7}$ ]]; then
    return 1
  fi
  return 0
}

mint_session_uuid() {
  cat /proc/sys/kernel/random/uuid 2>/dev/null \
    || uuidgen 2>/dev/null \
    || python3 -c 'import uuid; print(uuid.uuid4())' 2>/dev/null \
    || printf '%s-%s-p%sx\n' "$(safe_path_component "$SESSION")" "$(date -u +%Y%m%dT%H%M%SZ)" "$$"
}

normalize_session_uuid() {
  local raw="${1:-}" minted=""
  if [[ -n "$raw" ]] && session_id_is_safe "$raw"; then
    printf '%s\n' "$raw"
    return 0
  fi
  minted="$(mint_session_uuid)"
  if [[ -n "$raw" ]]; then
    echo "hapax-codex-headless: ignoring unsafe HAPAX_SESSION_ID; minted safe session id for coordination paths" >&2
  fi
  printf '%s\n' "$minted"
}

claim_epoch_for_task() {
  local role="$1" sid="$2" task="$3" suffix="" epoch_path="" claim_path="" line="" epoch="" epoch_task="" active_task=""
  for suffix in "$role-$sid" "$role"; do
    epoch_path="$HOME/.cache/hapax/cc-claim-epoch-$suffix"
    claim_path="$HOME/.cache/hapax/cc-active-task-$suffix"
    [[ -s "$epoch_path" && -s "$claim_path" ]] || continue
    active_task="$(head -n1 "$claim_path" | tr -d '[:space:]')"
    [[ "$active_task" == "$task" ]] || continue
    IFS= read -r line <"$epoch_path" || true
    epoch="${line%% *}"
    epoch_task="${line#* }"
    [[ "$line" != "$epoch" ]] || continue
    if [[ "$epoch" =~ ^[0-9]+$ && "$epoch_task" == "$task" ]]; then
      printf '%s\n' "$line"
      return 0
    fi
  done
  return 1
}

remote_python_command() {
  local payload="$1" code="$2"
  local code_b64="" bash_script="" quoted_script="" quoted_payload="" quoted_code=""
  code_b64="$(printf '%s' "$code" | python3 -c 'import base64,sys; print(base64.b64encode(sys.stdin.buffer.read()).decode())')"
  # shellcheck disable=SC2016
  bash_script='export HAPAX_REMOTE_PAYLOAD="$1"; export HAPAX_REMOTE_CODE="$2"; exec python3 -c "import base64,os; exec(base64.b64decode(os.environ[\"HAPAX_REMOTE_CODE\"]))"'
  quoted_script="${bash_script//\'/\'\\\'\'}"
  quoted_payload="${payload//\'/\'\\\'\'}"
  quoted_code="${code_b64//\'/\'\\\'\'}"
  printf "bash -c '%s' bash '%s' '%s'" "$quoted_script" "$quoted_payload" "$quoted_code"
}

strip_inherited_codex_access_token() {
  if [[ -n "${CODEX_ACCESS_TOKEN:-}" ]]; then
    echo "hapax-codex-headless: ignoring inherited CODEX_ACCESS_TOKEN; governed Codex lanes use saved ChatGPT auth on the dispatch host" >&2
    unset CODEX_ACCESS_TOKEN
  fi
  if [[ -n "${CODEX_HOME:-}" ]]; then
    echo "hapax-codex-headless: ignoring inherited CODEX_HOME; governed Codex lanes use the dispatch host default saved ChatGPT auth cache" >&2
    unset CODEX_HOME
  fi
  if [[ -n "${CODEX_API_KEY:-}" ]]; then
    echo "hapax-codex-headless: ignoring inherited CODEX_API_KEY; governed Codex lanes must not use API-key auth" >&2
    unset CODEX_API_KEY
  fi
  if [[ -n "${OPENAI_API_KEY:-}" ]]; then
    echo "hapax-codex-headless: ignoring inherited OPENAI_API_KEY; governed Codex lanes must not use API-key auth" >&2
    unset OPENAI_API_KEY
  fi
}

codex_exec_auth_sentinel_observed() {
  local output_file="$1"
  python3 - "$output_file" <<'PYEOF'
import json
import sys
from pathlib import Path

sentinel = "HAPAX_CODEX_EXEC_AUTH_OK"


def assistant_content_text(content):
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        pieces = []
        for item in content:
            if isinstance(item, dict):
                text = item.get("text")
                if isinstance(text, str):
                    pieces.append(text)
        return "".join(pieces)
    return ""


def event_text(event):
    if not isinstance(event, dict):
        return ""
    if event.get("type") == "item.completed":
        item = event.get("item")
        if isinstance(item, dict) and item.get("type") == "agent_message":
            text = item.get("text")
            return text if isinstance(text, str) else ""
    if event.get("type") == "response.output_text.done":
        text = event.get("text")
        return text if isinstance(text, str) else ""
    if event.get("role") == "assistant":
        return assistant_content_text(event.get("content"))
    message = event.get("message")
    if isinstance(message, dict) and message.get("role") == "assistant":
        return assistant_content_text(message.get("content"))
    return ""


stdout = Path(sys.argv[1]).read_text(encoding="utf-8", errors="replace")
for line in stdout.splitlines():
    try:
        event = json.loads(line)
    except json.JSONDecodeError:
        continue
    if event_text(event).strip() == sentinel:
        raise SystemExit(0)
raise SystemExit(1)
PYEOF
}

resolve_local_codex_bin() {
  local codex_bin=""
  codex_bin="$(command -v codex || true)"
  if [[ -z "$codex_bin" ]]; then
    for candidate in \
      "${HAPAX_CODEX_BIN_PATH:-}" \
      "$HOME/.npm-global/bin/codex" \
      "${NPM_CONFIG_PREFIX:+$NPM_CONFIG_PREFIX/bin/codex}" \
      "$HOME/.local/share/npm/bin/codex" \
      "/usr/local/bin/codex"; do
      if [[ -n "$candidate" && -f "$candidate" && -x "$candidate" ]]; then
        codex_bin="$candidate"
        break
      fi
    done
  fi
  [[ -n "$codex_bin" ]] || {
    echo "hapax-codex-headless: codex not found in PATH; next action: install the Codex CLI, repair PATH, or set HAPAX_CODEX_BIN_PATH to the executable before retrying" >&2
    exit 4
  }
  printf '%s\n' "$codex_bin"
}

prove_local_codex_exec_auth() {
  local codex_bin="$1" output_file="" error_file="" rc=0 timeout_s="" auth_output="" auth_error=""
  timeout_s="${HAPAX_CODEX_EXEC_AUTH_TIMEOUT_SECONDS:-30}"
  if ! python3 - "$timeout_s" <<'PYEOF' >/dev/null 2>&1
import math
import sys

value = float(sys.argv[1])
if not math.isfinite(value) or value <= 0:
    raise ValueError("timeout must be positive and finite")
PYEOF
  then
    echo "hapax-codex-headless: invalid HAPAX_CODEX_EXEC_AUTH_TIMEOUT_SECONDS='$timeout_s'; using 30s for the saved-login auth witness" >&2
    timeout_s="30"
  fi
  output_file="$(mktemp "${TMPDIR:-/tmp}/hapax-codex-exec-auth.XXXXXX")" || {
    echo "hapax-codex-headless: failed to create temporary Codex auth witness file; next action: verify TMPDIR or /tmp permissions before retrying" >&2
    exit 78
  }
  error_file="$(mktemp "${TMPDIR:-/tmp}/hapax-codex-exec-auth-err.XXXXXX")" || {
    rm -f "$output_file"
    echo "hapax-codex-headless: failed to create temporary Codex auth witness file; next action: verify TMPDIR or /tmp permissions before retrying" >&2
    exit 78
  }
  timeout "${timeout_s}s" env -i \
    ALL_PROXY="${ALL_PROXY:-}" \
    HOME="$HOME" \
    HTTP_PROXY="${HTTP_PROXY:-}" \
    HTTPS_PROXY="${HTTPS_PROXY:-}" \
    LANG="${LANG:-C}" \
    LC_ALL="${LC_ALL:-}" \
    NO_COLOR=1 \
    NO_PROXY="${NO_PROXY:-}" \
    PATH="$PATH" \
    REQUESTS_CA_BUNDLE="${REQUESTS_CA_BUNDLE:-}" \
    SSL_CERT_FILE="${SSL_CERT_FILE:-}" \
    "$codex_bin" exec \
      --ephemeral \
      --skip-git-repo-check \
      --ignore-rules \
      --sandbox read-only \
      --json \
      --cd "${WORKDIR:-$COUNCIL_DIR}" \
      "Reply exactly: HAPAX_CODEX_EXEC_AUTH_OK" \
      >"$output_file" 2>"$error_file" || rc=$?
  if [[ "$rc" -ne 0 ]]; then
    auth_output="$(cat "$output_file" "$error_file" 2>/dev/null || true)"
    auth_output_lc="${auth_output,,}"
    auth_error="codex_saved_auth_exec_failed:rc=$rc"
    case "$auth_output_lc" in
      *refresh_token_invalidated*)
        auth_error="codex_saved_auth_refresh_token_invalidated"
        ;;
      *token_invalidated*)
        auth_error="codex_saved_auth_token_invalidated"
        ;;
      *"login required"*|*"required to log in"*|*"please log in"*|*"not logged in"*)
        auth_error="codex_saved_auth_login_required"
        ;;
    esac
    echo "hapax-codex-headless: saved Codex auth was rejected by codex exec ($auth_error; rc=$rc); next action: repair saved Codex login on the dispatch host via codex login or the documented auth-cache transfer fallback, then retry governed dispatch" >&2
    sed -n '1,4p' "$error_file" >&2 || true
    rm -f "$output_file" "$error_file"
    exit 78
  fi
  if ! codex_exec_auth_sentinel_observed "$output_file"; then
    echo "hapax-codex-headless: codex exec auth witness did not return the expected sentinel; next action: re-run the Codex auth receipt probe before dispatching Codex lanes" >&2
    rm -f "$output_file" "$error_file"
    exit 78
  fi
  rm -f "$output_file" "$error_file"
}

prove_local_fallback_before_claim() {
  if [[ "${HAPAX_DISPATCH_HOST_FALLBACK:-}" != "local" ]]; then
    return 0
  fi
  if [[ "$LOCAL_FALLBACK_AUTH_PROVEN" == "1" ]]; then
    return 0
  fi
  strip_inherited_codex_access_token
  CODEX_BIN="$(resolve_local_codex_bin)"
  prove_local_codex_exec_auth "$CODEX_BIN"
  LOCAL_FALLBACK_AUTH_PROVEN=1
}

remote_preflight_payload_b64() {
  local token_only="${1:-0}"
  python3 - "$WORKDIR" "$COUNCIL_DIR" "$HOME/projects/hapax-mcp" "$token_only" <<'PYEOF'
import base64
import json
import os
import sys

workdir, council_dir, mcp_dir, token_only = sys.argv[1:5]
payload = {
    "required_dirs": [] if token_only == "1" else [workdir, council_dir, mcp_dir],
    "executables": [] if token_only == "1" else [f"{council_dir}/hooks/scripts/codex-hook-adapter.sh"],
    "binaries": ["codex"] if token_only == "1" else ["python3", "codex"],
    "workdir": workdir,
    "codex_bin_path": os.environ.get("HAPAX_CODEX_BIN_PATH", ""),
    "npm_config_prefix": os.environ.get("NPM_CONFIG_PREFIX", ""),
    "codex_exec_auth_timeout": os.environ.get("HAPAX_CODEX_EXEC_AUTH_TIMEOUT_SECONDS", "30"),
}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

remote_worktree_payload_b64() {
  python3 - "$WORKDIR" "$COUNCIL_DIR" "$SESSION" \
    "${HAPAX_CODEX_WORKTREE_BASE:-main}" "${HAPAX_CODEX_BRANCH_PREFIX:-codex}" \
    "${HAPAX_CODEX_CREATE_WORKTREE:-1}" "$WORKDIR_EXPLICIT" <<'PYEOF'
import base64
import json
import sys

workdir, council_dir, session, base_ref, branch_prefix, create_worktree, workdir_explicit = (
    sys.argv[1:8]
)
payload = {
    "workdir": workdir,
    "council_dir": council_dir,
    "session": session,
    "base_ref": base_ref or "main",
    "branch": f"{branch_prefix or 'codex'}/{session}",
    "create_worktree": create_worktree == "1",
    "workdir_explicit": workdir_explicit == "1",
}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

remote_exec_payload_b64() {
  local proof_file="$1"
  shift
  python3 - "$WORKDIR" "$proof_file" "${DISPATCH_HOST_REQUESTED:-}" "$LOGOS_BASE_URL" \
    "$COCKPIT_BASE_URL" "$SESSION" "$CODEX_TASK" "$@" <<'PYEOF'
import base64
import json
import os
import sys

workdir, proof_file, requested_host, logos_url, cockpit_url, session, task_id = (
    sys.argv[1:8]
)
argv = sys.argv[8:]
env = {
    "LOGOS_BASE_URL": logos_url,
    "COCKPIT_BASE_URL": cockpit_url,
    "HAPAX_DISPATCH_HOST": "local",
    "HAPAX_DISPATCH_REQUESTED_HOST": requested_host,
    "HAPAX_DISPATCH_LOGOS_URL": logos_url,
    "HAPAX_DISPATCH_PROOF_FILE": proof_file,
    "HAPAX_DISPATCH_REMOTE_INNER": "1",
    "HAPAX_AGENT_INTERFACE": "codex",
    "HAPAX_AGENT_NAME": session,
    "CODEX_THREAD_NAME": session,
    "CODEX_ROLE": session,
    "HAPAX_AGENT_ROLE": session,
}
for name in (
    "CLAUDE_ROLE",
    "HAPAX_AGENT_SLOT",
    "HAPAX_WORKTREE_ROLE",
    "HAPAX_SESSION_ID",
    "HAPAX_PARENT_AGENT_INTERFACE",
    "HAPAX_PARENT_AGENT_NAME",
    "HAPAX_METHODOLOGY_DISPATCH_TASK",
    "HAPAX_METHODOLOGY_DISPATCH_CLAIM_EPOCH",
    "HAPAX_IDLE_UPDATE_SECONDS",
    "HAPAX_CODEX_BIN_PATH",
    "NPM_CONFIG_PREFIX",
    "PASSWORD_STORE_DIR",
):
    value = os.environ.get(name)
    if value is not None:
        env[name] = value
payload = {
    "workdir": workdir,
    "proof_file": proof_file,
    "requested_host": requested_host,
    "session": session,
    "task_id": task_id,
    "env": env,
    "argv": argv,
}
print(base64.b64encode(json.dumps(payload, separators=(",", ":")).encode()).decode())
PYEOF
}

REMOTE_PREFLIGHT_PY='import base64,json,math,os,shutil,subprocess,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"]));
missing_dirs=[path for path in p.get("required_dirs",()) if not os.path.isdir(path)]
missing_exec=[path for path in p.get("executables",()) if not (os.path.isfile(path) and os.access(path, os.X_OK))]
missing_bins=[binary for binary in p.get("binaries",()) if binary!="codex" and not shutil.which(binary)]
def _resolve_path(binary):
    path=os.path.expanduser(binary)
    if os.path.isabs(path) or os.sep in path:
        return os.path.abspath(path) if os.path.isfile(path) and os.access(path,os.X_OK) else None
    return shutil.which(binary)
def _resolve_codex_bin():
    codex_bin=shutil.which("codex")
    if codex_bin:
        return codex_bin,""
    npm_prefix=(p.get("npm_config_prefix") or os.environ.get("NPM_CONFIG_PREFIX","")).rstrip("/")
    for candidate in ((p.get("codex_bin_path") or os.environ.get("HAPAX_CODEX_BIN_PATH") or "").strip(),os.path.expanduser("~/.npm-global/bin/codex"),(npm_prefix+"/bin/codex") if npm_prefix else "",os.path.expanduser("~/.local/share/npm/bin/codex"),"/usr/local/bin/codex"):
        if candidate:
            resolved=_resolve_path(candidate)
            if resolved:
                return resolved,""
    return None,"codex_binary_missing"
def _assistant_content_text(content):
    if isinstance(content,str):
        return content
    if isinstance(content,list):
        pieces=[]
        for item in content:
            if isinstance(item,dict):
                text=item.get("text")
                if isinstance(text,str):
                    pieces.append(text)
        return "".join(pieces)
    return ""
def _auth_event_text(event):
    if not isinstance(event,dict):
        return ""
    if event.get("type")=="item.completed":
        item=event.get("item")
        if isinstance(item,dict) and item.get("type")=="agent_message":
            text=item.get("text")
            return text if isinstance(text,str) else ""
    if event.get("type")=="response.output_text.done":
        text=event.get("text")
        return text if isinstance(text,str) else ""
    if event.get("role")=="assistant":
        return _assistant_content_text(event.get("content"))
    message=event.get("message")
    if isinstance(message,dict) and message.get("role")=="assistant":
        return _assistant_content_text(message.get("content"))
    return ""
def _sentinel_observed(stdout):
    for line in stdout.splitlines():
        try:
            event=json.loads(line)
        except json.JSONDecodeError:
            continue
        if _auth_event_text(event).strip()==sentinel:
            return True
    return False
def _auth_error(output, default):
    if "refresh_token_invalidated" in output:
        return "codex_saved_auth_refresh_token_invalidated"
    if "token_invalidated" in output:
        return "codex_saved_auth_token_invalidated"
    lowered=output.lower()
    if (
        "login required" in lowered
        or "required to log in" in lowered
        or "please log in" in lowered
        or "not logged in" in lowered
    ):
        return "codex_saved_auth_login_required"
    return default
actuation_error=""
codex_bin,codex_resolution_error=_resolve_codex_bin()
if codex_bin is None:
    actuation_error=codex_resolution_error
else:
    try:
        auth_timeout=float(p.get("codex_exec_auth_timeout") or 30)
    except (TypeError,ValueError):
        auth_timeout=30.0
    if not math.isfinite(auth_timeout) or auth_timeout <= 0:
        auth_timeout=30.0
    env={k:v for k in ("ALL_PROXY","HOME","HTTP_PROXY","HTTPS_PROXY","LANG","LC_ALL","NO_PROXY","PATH","REQUESTS_CA_BUNDLE","SSL_CERT_FILE") if (v:=os.environ.get(k)) is not None}
    env["NO_COLOR"]="1"
    env.pop("CODEX_ACCESS_TOKEN",None); env.pop("CODEX_HOME",None); env.pop("CODEX_API_KEY",None); env.pop("OPENAI_API_KEY",None)
    sentinel="HAPAX_CODEX_EXEC_AUTH_OK"
    auth_workdir=p.get("workdir") or os.getcwd()
    if not os.path.isdir(auth_workdir):
        auth_workdir=os.path.expanduser("~")
    try:
        result=subprocess.run([codex_bin,"exec","--ephemeral","--skip-git-repo-check","--ignore-rules","--sandbox","read-only","--json","--cd",auth_workdir,"Reply exactly: "+sentinel],text=True,capture_output=True,timeout=auth_timeout,env=env)
    except (OSError,subprocess.TimeoutExpired) as exc:
        actuation_error="codex_saved_auth_exec_failed:"+type(exc).__name__
    else:
        output=(result.stdout or "")+"\n"+(result.stderr or "")
        if result.returncode != 0:
            actuation_error=_auth_error(output,"codex_saved_auth_exec_failed:rc="+str(result.returncode))
        elif not _sentinel_observed(result.stdout):
            actuation_error=_auth_error(output,"codex_saved_auth_sentinel_missing")
if missing_dirs or missing_exec or missing_bins or actuation_error:
    print("remote preflight failed: missing_dirs="+json.dumps(missing_dirs)+" missing_executables="+json.dumps(missing_exec)+" missing_binaries="+json.dumps(missing_bins)+" auth_error="+json.dumps(actuation_error)+"; next action: repair saved Codex login on the dispatch host via codex login or the documented auth-cache transfer fallback, then verify required paths before retrying", file=sys.stderr)
    sys.exit(1)
sys.exit(0)'
REMOTE_WORKTREE_PY='import base64,json,os,shutil,subprocess,sys; p=json.loads(base64.b64decode(os.environ["HAPAX_REMOTE_PAYLOAD"])); workdir=p["workdir"]; council=p["council_dir"];
def fail(message):
    print("remote worktree bootstrap refused: "+message+"; next action: ssh to the dispatch host and verify the council checkout, target worktree path, git binary, and HAPAX_CODEX_CREATE_WORKTREE before retrying", file=sys.stderr)
    sys.exit(1)
if os.path.isdir(workdir):
    sys.exit(0)
if p.get("workdir_explicit"):
    fail("explicit HAPAX_CODEX_HEADLESS_WORKDIR is missing on dispatch host: "+workdir)
if not p.get("create_worktree"):
    fail("worktree creation disabled by HAPAX_CODEX_CREATE_WORKTREE=0 and default workdir is missing on dispatch host: "+workdir)
if not os.path.isdir(council):
    fail("council checkout missing on dispatch host: "+council)
if shutil.which("git") is None:
    fail("git binary missing on dispatch host")
if subprocess.run(["git","-C",council,"rev-parse","--is-inside-work-tree"],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL).returncode != 0:
    fail("council checkout is not a git worktree: "+council)
os.makedirs(os.path.dirname(workdir),exist_ok=True)
base=p.get("base_ref") or "main"
if subprocess.run(["git","-C",council,"rev-parse","--verify","--quiet",base],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL).returncode != 0:
    base="HEAD"
