#!/usr/bin/env python3
"""Fold the SDLC feeds into the rails event log (rails-map spec §2).

One tick = one idempotent fold (shadow-diff -> append transition events).
Run by hapax-rails-event-log.timer; safe to run by hand any time.
"""

from __future__ import annotations

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from shared.rails_event_log import EVENT_LOG, fold_once  # noqa: E402


def main() -> int:
    n = fold_once()
    print(f"rails-event-log: {n} event(s) appended -> {EVENT_LOG}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
