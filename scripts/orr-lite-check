#!/usr/bin/env python3
"""ORR-lite check — operational readiness review before merge.

Reads a case ID and PR number, checks CI status, evidence ledger,
rollback plan presence, and reports pass/fail with blockers.

ISAP: SLICE-006-RELEASE-OPS (CASE-SDLC-REFORM-001)

Usage:
    scripts/orr-lite-check <case-id> [--pr N] [--tier T0|T1|T2|T3] [--json]
"""

from __future__ import annotations

import argparse
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from shared.release_gate import run_orr_lite


def _ci_green(pr_number: int | None) -> bool:
    if pr_number is None:
        return False
    try:
        result = subprocess.run(
            ["gh", "pr", "checks", str(pr_number)],
            capture_output=True,
            text=True,
            timeout=30,
        )
        lines = result.stdout.strip().splitlines()
        for line in lines:
            if "\tfail\t" in line:
                return False
            if "\tpending\t" in line:
                return False
        return len(lines) > 0
    except Exception:
        return False


def _has_evidence(case_id: str) -> bool:
    try:
        from shared.evidence_ledger import EvidenceLedger

        ledger = EvidenceLedger()
        return len(ledger.fresh_entries(case_id)) > 0
    except ImportError:
        ledger_dir = Path.home() / ".cache" / "hapax" / "evidence-ledger"
        safe = case_id.replace("/", "_").replace(" ", "_")
        path = ledger_dir / f"{safe}.jsonl"
        return path.exists() and path.stat().st_size > 0


def main() -> None:
    parser = argparse.ArgumentParser(description="ORR-lite check")
    parser.add_argument("case_id", help="AuthorityCase ID")
    parser.add_argument("--pr", type=int, default=None, help="PR number")
    parser.add_argument("--tier", default="T0", choices=["T0", "T1", "T2", "T3"])
    parser.add_argument("--json", action="store_true", help="JSON output")
    args = parser.parse_args()

    ci = _ci_green(args.pr)

    result = run_orr_lite(
        case_id=args.case_id,
        pr_number=args.pr,
        risk_tier=args.tier,
        has_tests=ci,
        ci_green=ci,
        has_readback_plan=args.tier == "T0",
        has_rollback_plan=True,
        has_evidence=_has_evidence(args.case_id),
        has_review=args.tier in ("T0", "T1"),
        has_axiom_scan=args.tier in ("T0", "T1"),
        reviewer="orr-lite-check",
    )

    if args.json:
        print(result.model_dump_json(indent=2))
    else:
        status = "PASS" if result.passed else "FAIL"
        print(f"ORR-lite: {status} ({args.case_id}, {args.tier})")
        for name, ok in result.checks.items():
            mark = "ok" if ok else "BLOCKED"
            print(f"  [{mark:7s}] {name}")
        if result.blockers:
            print(f"\nBlockers ({len(result.blockers)}):")
            for b in result.blockers:
                print(f"  - {b}")

    sys.exit(0 if result.passed else 1)


if __name__ == "__main__":
    main()
