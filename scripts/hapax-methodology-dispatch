@dataclass
class TaskNote:
    path: Path
    fields: dict[str, Any]


@dataclass
class Validation:
    ok: bool
    reason: str
    task: TaskNote | None = None
    parent_spec_path: Path | None = None
    exempt_read_only: bool = False


@dataclass(frozen=True)
class DurableDispatchBinding:
    ok: bool
    advisory_only: bool
    reason: str
    message_id: str | None = None


@dataclass(frozen=True)
class DispatchCanonContext:
    binding: dict[str, Any]
    rendered_payload: str
    expected_canon_identity_hash: str
    expected_position_hash: str


class DispatchCanonError(RuntimeError):
    def __init__(self, reason_code: str, repair_action: str) -> None:
        super().__init__(reason_code)
        self.reason_code = reason_code
        self.repair_action = repair_action


def now_utc() -> str:
    return datetime.now(UTC).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def strip_scalar(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in {"'", '"'}:
        return value[1:-1]
    return value


def is_nullish(value: str | list[str] | None) -> bool:
    if value is None:
        return True
    if isinstance(value, list):
        return len(value) == 0
    if not isinstance(value, str):
        return False
    return strip_scalar(value).lower() in NULLISH


def field_tokens(value: str | list[str] | None) -> set[str]:
    if value is None:
        return set()
    if isinstance(value, list):
        raw = " ".join(str(item) for item in value)
    elif not isinstance(value, str):
        return set()
    else:
        raw = value
    raw = strip_scalar(raw).lower()
    for ch in "[],:;":
        raw = raw.replace(ch, " ")
    return {part.strip() for part in raw.split() if part.strip()}


def split_lane_list(value: str | None) -> set[str]:
    if not value:
        return set()
    return {part for part in re.split(r"[\s,]+", value.strip()) if part}


def p0_codex_drain_lanes() -> set[str]:
    for name in (
        "HAPAX_P0_CODEX_DRAIN_LANES",
        "HAPAX_SUPERVISOR_P0_CODEX_LANES",
        "HAPAX_SUPERVISOR_P0_CODEX_LANE",
    ):
        if name in os.environ:
            return split_lane_list(os.environ.get(name))
    return set(DEFAULT_P0_CODEX_DRAIN_LANES)


def _field_value_text(value: Any) -> str:
    if isinstance(value, list):
        return " ".join(_field_value_text(item) for item in value)
    if isinstance(value, dict):
        return " ".join(_field_value_text(item) for item in value.values())
    return strip_scalar(str(value)) if value is not None else ""


def task_is_p0_incident(task_id: str, validation: Validation) -> bool:
    if validation.task is None:
        return False
    fields = validation.task.fields
    priority = strip_scalar(str(fields.get("priority", ""))).lower()
    if priority != "p0":
        return False
    raw = " ".join(
        [
            task_id,
            _field_value_text(fields.get("title")),
            _field_value_text(fields.get("kind")),
            _field_value_text(fields.get("tags")),
            _field_value_text(fields.get("incident_kind")),
            _field_value_text(fields.get("incident_fingerprint")),
        ]
    ).lower()
    normalized = raw.replace("_", "-")
    return any(
        marker in normalized
        for marker in (
            "p0-incident",
            "incident-intake",
            "technical-alert",
            "sdlc-task-stalled",
        )
    )


def allow_codex_p0_local_dispatch_fallback(
    task_id: str,
    lane: str,
    validation: Validation,
) -> bool:
    return lane in p0_codex_drain_lanes() and task_is_p0_incident(task_id, validation)


def allow_codex_governed_relay_reactivation(
    *,
    route: PlatformPath,
    route_decision: RouteDecision,
    durable_binding: DurableDispatchBinding,
    validation: Validation,
) -> bool:
    """Permit retired-relay reactivation only for a fully bound mutable launch.

    The fail-safe default is false: read-only exemptions, advisory MQ checks,
    missing message IDs, non-launch route decisions, non-Codex routes, or
    immutable routes must leave the launcher without ``--force`` so the relay
    lifecycle guard remains the next authority boundary.
    """
    return (
        route.platform == "codex"
        and route.mode == "headless"
        and route.mutable
        and not validation.exempt_read_only
        and route_decision.action is DispatchAction.LAUNCH
        and durable_binding.ok
        and not durable_binding.advisory_only
        and durable_binding.message_id is not None
    )


def parse_frontmatter(text: str) -> dict[str, Any]:
    fields, _body = parse_document_frontmatter(text)
    return dict(fields)


def _glob_to_regex(glob: str) -> re.Pattern[str]:
    out: list[str] = []
    i = 0
    while i < len(glob):
        if glob.startswith("**/", i):
            out.append("(?:.*/)?")
            i += 3
        elif glob.startswith("**", i):
            out.append(".*")
            i += 2
        elif glob[i] == "*":
            out.append("[^/]*")
            i += 1
        elif glob[i] == "?":
            out.append("[^/]")
            i += 1
        else:
            out.append(re.escape(glob[i]))
            i += 1
    return re.compile("^" + "".join(out) + "$")


def _path_matches_glob(path: str, glob: str) -> bool:
    return _glob_to_regex(glob).match(path) is not None


def _scalar_list(value: Any) -> list[str]:
    if value is None:
        return []
    if isinstance(value, str):
        text = strip_scalar(value)
        return [] if is_nullish(text) else [text]
    if isinstance(value, (list, tuple, set, frozenset)):
        return [strip_scalar(str(item)) for item in value if not is_nullish(str(item))]
    return [strip_scalar(str(value))]


def _canonical_json_bytes(value: Any) -> bytes:
    try:
        rendered = json.dumps(
            value,
            allow_nan=False,
            ensure_ascii=True,
            separators=(",", ":"),
            sort_keys=True,
        )
    except (TypeError, ValueError) as exc:
        raise DispatchCanonError(
            "dispatch_canon_noncanonical_value",
            "replace the dispatch binding value with canonical JSON data",
        ) from exc
    return rendered.encode("ascii")


def _content_hash(value: Any) -> str:
    return hashlib.sha256(_canonical_json_bytes(value)).hexdigest()


def _safe_dispatch_scalar(value: Any, *, field: str, allow_blank: bool = False) -> str:
    text = strip_scalar(str(value))
    unsafe = any(
        ord(char) < 32 or 127 <= ord(char) <= 159 or char in DISPATCH_UNSAFE_CODEPOINTS
        for char in text
    )
    if unsafe or (not allow_blank and not text):
        raise DispatchCanonError(
            f"dispatch_{field}_unsafe",
            f"provide a nonblank {field} without control or bidi formatting characters",
        )
    return text


def _dispatch_identifier(value: Any, *, field: str) -> str:
    if not isinstance(value, str):
        raise DispatchCanonError(
            f"dispatch_{field}_invalid",
            f"declare {field} as a scalar string",
        )
    text = _safe_dispatch_scalar(value, field=field)
    if DISPATCH_IDENTIFIER_RE.fullmatch(text) is None:
        raise DispatchCanonError(
            f"dispatch_{field}_invalid",
            f"use 1-256 ASCII letters, digits, dot, underscore, or hyphen for {field}",
        )
    return text


def _declared_bool(fields: dict[str, Any], name: str) -> dict[str, Any]:
    declared = name in fields
    raw = fields.get(name, False)
    if isinstance(raw, bool):
        value = raw
    elif raw is None or (isinstance(raw, str) and raw.strip().lower() in NULLISH):
        value = False
    elif isinstance(raw, str) and raw.strip().lower() in {"true", "false"}:
        value = raw.strip().lower() == "true"
    else:
        raise DispatchCanonError(
            "dispatch_authorization_flag_malformed",
            f"declare {name} as true or false",
        )
    return {"declared": declared, "name": name, "value": value}


def _declared_mutation_scope_refs(fields: dict[str, Any]) -> tuple[str, ...]:
    declarations: list[Any] = []
    if "mutation_scope_refs" in fields:
        declarations.append(fields["mutation_scope_refs"])
    nested = fields.get("route_metadata")
    if isinstance(nested, dict) and "mutation_scope_refs" in nested:
        declarations.append(nested["mutation_scope_refs"])
    if len(declarations) > 1 and declarations[0] != declarations[1]:
        raise DispatchCanonError(
            "dispatch_mutation_scope_refs_ambiguous",
            "declare mutation_scope_refs once, or make top-level and nested declarations identical",
        )
    raw = declarations[-1] if declarations else []
    if not isinstance(raw, (list, tuple)) or any(not isinstance(item, str) for item in raw):
        raise DispatchCanonError(
            "dispatch_mutation_scope_refs_malformed",
            "declare mutation_scope_refs as a list of path strings",
        )
    refs = tuple(sorted({_safe_dispatch_scalar(item, field="mutation_scope_ref") for item in raw}))
    if any(".." in Path(ref).parts for ref in refs):
        raise DispatchCanonError(
            "dispatch_mutation_scope_ref_escapes_root",
            "declare mutation scope references without parent-directory traversal",
        )
    return refs


def _dispatch_source_path() -> Path | None:
    configured = os.environ.get("HAPAX_COORDINATION_CANON_SOURCE_PATH", "").strip()
    return Path(configured).expanduser() if configured else None


def _build_dispatch_canon_context(
    *,
    task_id: str,
    lane: str,
    platform: str,
    mode: str,
    profile: str,
    validation: Validation,
    route: PlatformPath,
    route_decision: RouteDecision,
    route_decision_ref: str,
    requested_route: dict[str, str],
    policy_requested_route_id: str,
    dispatch_message_id: str | None = None,
) -> DispatchCanonContext:
    try:
        from shared.session_context_canon import (
            CanonBundle,
            build_canon_bundle,
            checked_bundle_json_schema_bytes,
        )

        checked_bundle_json_schema_bytes()
        generated_bundle = build_canon_bundle(source_path=_dispatch_source_path())
        bundle = CanonBundle.model_validate(generated_bundle.model_dump(mode="json", by_alias=True))
    except (ImportError, OSError, RuntimeError, ValueError) as exc:
        reason_code = getattr(exc, "reason_code", "dispatch_canon_unavailable")
        repair_action = getattr(
            exc,
            "repair_action",
            "restore the checked canon sources, schema, encoder, and package dependencies",
        )
        raise DispatchCanonError(str(reason_code), str(repair_action)) from exc

    if bundle.canon_hash != EXPECTED_GATE0_CANON_HASH:
        raise DispatchCanonError(
            "dispatch_canon_hash_drift",
            "reconcile the canon semantic postimage and update its independently accepted pin",
        )
    if bundle.bundle_hash != EXPECTED_GATE0_CANON_BUNDLE_HASH:
        raise DispatchCanonError(
            "dispatch_canon_bundle_hash_drift",
            "replay the accepted canon bundle and update its independently accepted pin",
        )
    if validation.task is None:
        raise DispatchCanonError(
            "dispatch_task_missing_after_validation",
            "restore the validated task note before constructing dispatch context",
        )

    fields = validation.task.fields
    raw_stage = fields.get("stage")
    if raw_stage is None:
        raise DispatchCanonError(
            "dispatch_stage_missing",
            "declare one exact canonical SDLC stage token in the task frontmatter",
        )
    try:
        canonical_stage = stage_token(_safe_dispatch_scalar(raw_stage, field="stage"))
    except DispatchCanonError:
        raise
    except ValueError as exc:
        raise DispatchCanonError(
            getattr(exc, "reason_code", "dispatch_stage_invalid"),
            getattr(exc, "repair_action", "use an exact canonical SDLC stage token"),
        ) from exc

    image = next(
        (
            candidate
            for candidate in bundle.images
            if candidate.stage_token == canonical_stage
            and candidate.level.value == DISPATCH_CANON_LEVEL
        ),
        None,
    )
    if image is None:
        raise DispatchCanonError(
            "dispatch_canon_image_missing",
            "materialize the exact stage and projection level in the accepted canon bundle",
        )
    if image.kernel.omitted_atom_ids:
        raise DispatchCanonError(
            "dispatch_pi0_kernel_not_empty",
            "restore the lossless pi0 projection with an empty omission kernel",
        )
    payload_hash = hashlib.sha256(image.rendered_payload.encode("utf-8")).hexdigest()

    task_id = _dispatch_identifier(task_id, field="task_id")
    lane = _dispatch_identifier(lane, field="lane")
    raw_authority_case = fields.get("authority_case")
    authority_case = _dispatch_identifier(
        "read-only-exempt" if is_nullish(raw_authority_case) else raw_authority_case,
        field="authority_case",
    )
    authorization_flags = tuple(
        _declared_bool(fields, name) for name in DISPATCH_AUTHORIZATION_FLAGS
    )
    mutation_scope_refs = _declared_mutation_scope_refs(fields)
    unscoped_authorities = sorted(
        item["name"]
        for item in authorization_flags
        if item["name"] in DISPATCH_SCOPED_MUTATION_FLAGS and item["value"]
    )
    if unscoped_authorities and not mutation_scope_refs:
        raise DispatchCanonError(
            "dispatch_scoped_authority_scope_empty",
            "declare at least one mutation_scope_ref or remove scoped mutation authority: "
            + ",".join(unscoped_authorities),
        )

    stage_definition = next(
        stage for stage in bundle.lifecycle_definition.stages if stage.token == canonical_stage
    )
    legal_successors = tuple(
        dict.fromkeys(edge.to for edge in (*stage_definition.next, *stage_definition.fall))
    )
    constraints = {
        "authority_case": authority_case,
        "authorization_flags": authorization_flags,
        "mutation_scope_refs": mutation_scope_refs,
    }
    constraint_hash = _content_hash(constraints)
    worktree = _safe_dispatch_scalar(lane_worktree(lane, platform), field="worktree")
    claim_file = _safe_dispatch_scalar(
        Path(os.environ.get("HAPAX_CC_CLAIMS_DIR", str(Path.home() / ".cache" / "hapax")))
        / f"cc-active-task-{lane}",
        field="claim_file",
    )
    claim_command = _safe_dispatch_scalar(
        Path(worktree) / "scripts" / "cc-claim", field="claim_command"
    )
    close_command = _safe_dispatch_scalar(
        Path(worktree) / "scripts" / "cc-close", field="close_command"
    )
    task_status = _safe_dispatch_scalar(fields.get("status", ""), field="task_status")
    raw_assigned_to = fields.get("assigned_to")
    assigned_to = _safe_dispatch_scalar(
        "unassigned" if is_nullish(raw_assigned_to) else raw_assigned_to,
        field="assigned_to",
    )
    claim_state = {
        "assigned_to": assigned_to,
        "binding_sidecar_state": "required_on_claim" if dispatch_message_id else "advisory_unbound",
        "claim_command": claim_command,
        "claim_file": claim_file,
        "dispatch_message_id": dispatch_message_id,
        "expected_task_id": task_id,
        "state": "absent_preclaim" if task_status == "offered" else "present_declared_must_verify",
        "task_status": task_status,
        "verified_active_claim": False,
    }
    route_state = {
        "decision_id": route_decision.decision_id,
        "decision_ref": _safe_dispatch_scalar(route_decision_ref, field="route_decision_ref"),
        "final_route": {
            "mode": route.mode,
            "platform": route.platform,
            "profile": route.profile,
        },
        "invocation_requested_route": requested_route,
        "policy_action": route_decision.action.value,
        "policy_decision_route_id": route_decision.route_id,
        "policy_requested_route_id": policy_requested_route_id,
        "requested_state": "requested_receipt_only"
        if requested_route["mode"] == "receipt-only"
        else "requested_dispatch_route",
        "decision_state": "decided",
        "selected_route_id": _decision_selected_route_id(route_decision),
        "state": "policy_selected_nonadmitting_carriage",
    }
    canon_identity = {
        "bundle_hash": bundle.bundle_hash,
        "bundle_ref": bundle.bundle_ref,
        "canon_hash": bundle.canon_hash,
        "canon_id": image.canon_id,
        "canon_version": bundle.canon_version,
        "channel": DISPATCH_CANON_CHANNEL,
        "image_hash": image.image_hash,
        "image_ref": f"canon-image@sha256:{image.image_hash}",
        "kernel": image.kernel.model_dump(mode="json"),
        "level": image.level.value,
        "lifecycle_definition_ref": bundle.lifecycle_definition.definition_ref,
        "may_authorize": False,
        "payload_bytes": len(image.rendered_payload.encode("utf-8")),
        "payload_sha256": payload_hash,
        "reference_token_count": image.reference_token_count,
        "selection_state": "bootstrap_lossless_unmeasured_nonadmitting",
        "stage_token": canonical_stage,
    }
    position_body = {
        "schema": DISPATCH_POSITION_SCHEMA,
        "authority_case": authority_case,
        "authorized_flags": authorization_flags,
        "claim": claim_state,
        "close": {
            "command": close_command,
            "state": "independently_gated_by_worktree_local_cc_close",
            "terminal_conditions": bundle.lifecycle_definition.terminal_conditions,
            "terminal_stages": bundle.lifecycle_definition.terminal_stages,
            "verified_ready": False,
        },
        "declared_task_constraint_digest": constraint_hash,
        "declared_task_constraint_ref": f"task-local-constraints@sha256:{constraint_hash}",
        "effective_constraint_state": "unresolved_scope_chain",
        "lane": lane,
        "legal_successors": legal_successors,
        "may_authorize": False,
        "mutation_scope_refs": mutation_scope_refs,
        "route": route_state,
        "stage_token": canonical_stage,
        "task_id": task_id,
        "task_note": _safe_dispatch_scalar(validation.task.path, field="task_path"),
        "parent_spec_path": _safe_dispatch_scalar(
            validation.parent_spec_path, field="parent_spec_path"
        )
        if validation.parent_spec_path is not None
        else None,
        "worktree": worktree,
    }
    position_hash = _content_hash(position_body)
    position = {
        **position_body,
        "position_hash": position_hash,
        "position_ref": f"dispatch-position@sha256:{position_hash}",
    }
    binding_body = {
        "schema": DISPATCH_CANON_BINDING_SCHEMA,
        "advisory_carriage": True,
        "canon": canon_identity,
        "may_authorize": False,
        "position": position,
        "receipt_is_admission": False,
    }
    binding_hash = _content_hash(binding_body)
    binding = {
        **binding_body,
        "binding_hash": binding_hash,
        "binding_ref": f"dispatch-canon-binding@sha256:{binding_hash}",
    }
    context = DispatchCanonContext(
        binding=binding,
        rendered_payload=image.rendered_payload,
        expected_canon_identity_hash=_content_hash(canon_identity),
        expected_position_hash=position_hash,
    )
    _verify_dispatch_canon_context(context)
    return context


def _verify_dispatch_canon_context(context: DispatchCanonContext) -> None:
    binding = context.binding
    try:
        binding_hash = str(binding["binding_hash"])
        binding_ref = str(binding["binding_ref"])
        binding_body = {
            key: value
            for key, value in binding.items()
            if key not in {"binding_hash", "binding_ref"}
        }
        position = dict(binding["position"])
        position_hash = str(position.pop("position_hash"))
        position_ref = str(position.pop("position_ref"))
        canon = binding["canon"]
    except (KeyError, TypeError, ValueError) as exc:
        raise DispatchCanonError(
            "dispatch_canon_binding_malformed",
            "rebuild the dispatch canon binding from checked typed sources",
        ) from exc
    binding_keys = {
        "advisory_carriage",
        "binding_hash",
        "binding_ref",
        "canon",
        "may_authorize",
        "position",
        "receipt_is_admission",
        "schema",
    }
    position_keys = {
        "authority_case",
        "authorized_flags",
        "claim",
        "close",
        "declared_task_constraint_digest",
        "declared_task_constraint_ref",
        "effective_constraint_state",
        "lane",
        "legal_successors",
        "may_authorize",
        "mutation_scope_refs",
        "parent_spec_path",
        "route",
        "schema",
        "stage_token",
        "task_id",
        "task_note",
        "worktree",
    }
    canon_keys = {
        "bundle_hash",
        "bundle_ref",
        "canon_hash",
        "canon_id",
        "canon_version",
        "channel",
        "image_hash",
        "image_ref",
        "kernel",
        "level",
        "lifecycle_definition_ref",
        "may_authorize",
        "payload_bytes",
        "payload_sha256",
        "reference_token_count",
        "selection_state",
        "stage_token",
    }
    claim_keys = {
        "assigned_to",
        "binding_sidecar_state",
        "claim_command",
        "claim_file",
        "dispatch_message_id",
        "expected_task_id",
        "state",
        "task_status",
        "verified_active_claim",
    }
    close_keys = {
        "command",
        "state",
        "terminal_conditions",
        "terminal_stages",
        "verified_ready",
    }
    route_keys = {
        "decision_id",
        "decision_ref",
        "decision_state",
        "final_route",
        "invocation_requested_route",
        "policy_action",
        "policy_decision_route_id",
        "policy_requested_route_id",
        "requested_state",
        "selected_route_id",
        "state",
    }
    if (
        set(binding) != binding_keys
        or set(position) != position_keys
        or not isinstance(canon, dict)
        or set(canon) != canon_keys
        or binding.get("schema") != DISPATCH_CANON_BINDING_SCHEMA
        or position.get("schema") != DISPATCH_POSITION_SCHEMA
    ):
        raise DispatchCanonError(
            "dispatch_canon_binding_malformed",
            "rebuild the exact dispatch canon and position schema",
        )
    claim = position.get("claim")
    close = position.get("close")
    route_state = position.get("route")
    if (
        not isinstance(claim, dict)
        or set(claim) != claim_keys
        or not isinstance(close, dict)
        or set(close) != close_keys
        or not isinstance(route_state, dict)
        or set(route_state) != route_keys
    ):
        raise DispatchCanonError(
            "dispatch_position_shape_malformed",
            "rebuild the exact claim, route, and close position states",
        )
    final_route = route_state.get("final_route")
    invocation_route = route_state.get("invocation_requested_route")
    expected_requested_state = (
        "requested_receipt_only"
        if isinstance(invocation_route, dict) and invocation_route.get("mode") == "receipt-only"
        else "requested_dispatch_route"
    )
    position_semantics_ok = (
        isinstance(final_route, dict)
        and set(final_route) == {"mode", "platform", "profile"}
        and isinstance(invocation_route, dict)
        and set(invocation_route) == {"mode", "platform", "profile"}
        and position.get("stage_token") == canon.get("stage_token")
        and claim.get("expected_task_id") == position.get("task_id")
        and claim.get("state") in {"absent_preclaim", "present_declared_must_verify"}
        and claim.get("verified_active_claim") is False
        and close.get("state") == "independently_gated_by_worktree_local_cc_close"
        and close.get("verified_ready") is False
        and isinstance(close.get("terminal_stages"), (list, tuple))
        and tuple(close.get("terminal_stages", ())) == ("S11",)
        and isinstance(close.get("terminal_conditions"), (list, tuple))
        and tuple(close.get("terminal_conditions", ()))
        == ("cc_close_ready", "closure_receipts_present")
        and route_state.get("decision_state") == "decided"
        and route_state.get("requested_state") == expected_requested_state
        and route_state.get("state") == "policy_selected_nonadmitting_carriage"
        and route_state.get("policy_action") == "launch"
        and route_state.get("selected_route_id")
        == ".".join(
            [
                str(final_route.get("platform")),
                str(final_route.get("mode")),
                str(final_route.get("profile")),
            ]
        )
        and isinstance(position.get("legal_successors"), (list, tuple))
        and bool(position["legal_successors"])
        and all(isinstance(item, str) for item in position["legal_successors"])
    )
    if not position_semantics_ok:
        raise DispatchCanonError(
            "dispatch_position_semantic_mismatch",
            "rebuild position fields from one validated stage, route decision, claim state, and close gate",
        )
    if _content_hash(binding_body) != binding_hash or binding_ref != (
        f"dispatch-canon-binding@sha256:{binding_hash}"
    ):
        raise DispatchCanonError(
            "dispatch_canon_binding_hash_mismatch",
            "rebuild the dispatch canon binding without caller mutation",
        )
    if (
        _content_hash(position) != position_hash
        or position_hash != context.expected_position_hash
        or position_ref != f"dispatch-position@sha256:{position_hash}"
    ):
        raise DispatchCanonError(
            "dispatch_position_hash_mismatch",
            "rebuild the dispatch position from the validated task and route decision",
        )
    if not isinstance(canon, dict):
        raise DispatchCanonError(
            "dispatch_canon_binding_malformed",
            "rebuild the dispatch canon binding from checked typed sources",
        )
    observed_payload_hash = hashlib.sha256(context.rendered_payload.encode("utf-8")).hexdigest()
    if canon.get("payload_sha256") != observed_payload_hash:
        raise DispatchCanonError(
            "dispatch_canon_payload_hash_mismatch",
            "restore the exact rendered canon payload selected by the image",
        )
    try:
        expected_constraints = {
            "authority_case": position["authority_case"],
            "authorization_flags": position["authorized_flags"],
            "mutation_scope_refs": position["mutation_scope_refs"],
        }
    except KeyError as exc:
        raise DispatchCanonError(
            "dispatch_canon_binding_malformed",
            "rebuild the dispatch canon binding from checked typed sources",
        ) from exc
    expected_constraint_hash = _content_hash(expected_constraints)
    if (
        position.get("declared_task_constraint_digest") != expected_constraint_hash
        or position.get("declared_task_constraint_ref")
        != f"task-local-constraints@sha256:{expected_constraint_hash}"
    ):
        raise DispatchCanonError(
            "dispatch_declared_constraint_hash_mismatch",
            "rebuild the task-local declared constraint binding",
        )
    kernel = canon.get("kernel")
    image_hash = canon.get("image_hash")
    canon_invariants_ok = (
        _content_hash(canon) == context.expected_canon_identity_hash
        and canon.get("canon_hash") == EXPECTED_GATE0_CANON_HASH
        and canon.get("canon_id") == f"coordination-canon@sha256:{EXPECTED_GATE0_CANON_HASH}"
        and canon.get("bundle_hash") == EXPECTED_GATE0_CANON_BUNDLE_HASH
        and canon.get("bundle_ref") == f"canon-bundle@sha256:{EXPECTED_GATE0_CANON_BUNDLE_HASH}"
        and canon.get("canon_version") == 1
        and canon.get("level") == DISPATCH_CANON_LEVEL
        and canon.get("channel") == DISPATCH_CANON_CHANNEL
        and canon.get("may_authorize") is False
        and isinstance(image_hash, str)
        and re.fullmatch(r"[0-9a-f]{64}", image_hash) is not None
        and canon.get("image_ref") == f"canon-image@sha256:{image_hash}"
        and isinstance(canon.get("lifecycle_definition_ref"), str)
        and re.fullmatch(
            r"lifecycle-definition@sha256:[0-9a-f]{64}",
            canon["lifecycle_definition_ref"],
        )
        is not None
        and canon.get("payload_bytes") == len(context.rendered_payload.encode("utf-8"))
        and isinstance(canon.get("reference_token_count"), int)
        and canon["reference_token_count"] > 0
        and canon.get("selection_state") == "bootstrap_lossless_unmeasured_nonadmitting"
        and isinstance(kernel, dict)
        and kernel.get("name") == "pi0-none"
        and kernel.get("omitted_atom_ids") == []
        and kernel.get("omitted_digest") == _content_hash([])
        and kernel.get("distortion_class") == "none"
    )
    authority_invariants_ok = (
        binding.get("advisory_carriage") is True
        and binding.get("may_authorize") is False
        and binding.get("receipt_is_admission") is False
        and position.get("may_authorize") is False
        and position.get("effective_constraint_state") == "unresolved_scope_chain"
        and position.get("claim", {}).get("verified_active_claim") is False
    )
    if not canon_invariants_ok:
        raise DispatchCanonError(
            "dispatch_canon_invariant_mismatch",
            "restore the pinned lossless pi0 inline non-authorizing canon identity",
        )
    if not authority_invariants_ok:
        raise DispatchCanonError(
            "dispatch_canon_authority_escalation",
            "keep dispatch context carriage explicitly non-authorizing and non-admitting",
        )


def _claim_dispatch_environment(
    *,
    task: TaskNote,
    message_id: str,
    canon_context: DispatchCanonContext,
    platform: str,
    mode: str,
    profile: str,
    idempotency_key: str | None,
) -> dict[str, str]:
    """Environment consumed by cc-claim to bind the claim to this dispatch root."""

    if os.environ.get("HAPAX_CANON_ECHO_ENFORCEMENT") != "1":
        return {}
    authority_case = strip_scalar(str(task.fields.get("authority_case", "")))
    if not authority_case:
        raise DispatchCanonError(
            "claim_dispatch_authority_case_missing",
            "restore the exact task AuthorityCase before launch",
        )
    return {
        "HAPAX_CANON_ECHO_ENFORCEMENT": "1",
        "HAPAX_CLAIM_DISPATCH_MESSAGE_ID": message_id,
        "HAPAX_CLAIM_DISPATCH_BINDING_HASH": str(canon_context.binding["binding_hash"]),
        "HAPAX_CLAIM_DISPATCH_PLATFORM": platform,
        "HAPAX_CLAIM_DISPATCH_MODE": mode,
        "HAPAX_CLAIM_DISPATCH_PROFILE": profile,
        "HAPAX_CLAIM_DISPATCH_AUTHORITY_CASE": authority_case,
        "HAPAX_CLAIM_DISPATCH_IDEMPOTENCY_KEY": idempotency_key or "",
    }


def _repo_relative_ref(value: str) -> str:
    text = strip_scalar(value).replace("\\", "/").strip()
    if text.startswith("./"):
        text = text[2:]
    path = Path(text).expanduser()
    if path.is_absolute():
        try:
            return path.resolve().relative_to(REPO_ROOT_FOR_IMPORTS.resolve()).as_posix()
        except ValueError:
            return path.as_posix().lstrip("/")
    return text.lstrip("/")


def _reason_slug(value: str) -> str:
    chars = [ch if ch.isalnum() or ch in {"_", ".", "-"} else "-" for ch in value.lower()]
    slug = "".join(chars).strip("-")
    while "--" in slug:
        slug = slug.replace("--", "-")
    return slug or "unknown"


def invariant_manifest_path() -> Path:
    configured = os.environ.get("HAPAX_INVARIANT_MANIFEST", "").strip()
    return Path(configured).expanduser() if configured else DEFAULT_INVARIANT_MANIFEST


def _operator_coupled_manifest_entries() -> tuple[tuple[str, tuple[str, ...]], ...]:
    try:
        import yaml
    except ModuleNotFoundError as exc:  # pragma: no cover - project env dependency guard
        raise RuntimeError("PyYAML unavailable for invariant-manifest operator gate") from exc
    manifest_path = invariant_manifest_path()
    try:
        raw = yaml.safe_load(manifest_path.read_text(encoding="utf-8"))
    except yaml.YAMLError as exc:
        raise RuntimeError("invariant manifest parse error") from exc
    if not isinstance(raw, dict):
        raise RuntimeError("invariant manifest is not a mapping")
    classes = raw.get("classes")
    if not isinstance(classes, dict):
        raise RuntimeError("invariant manifest missing classes mapping")
    operator_class = classes.get("operator_coupled")
    if not isinstance(operator_class, dict):
        raise RuntimeError("invariant manifest missing operator_coupled class")
    policy = operator_class.get("policy")
    if not isinstance(policy, dict) or policy.get("dispatch_mode") != "interactive_only":
        raise RuntimeError("operator_coupled manifest policy is not interactive_only")
    entries: list[tuple[str, tuple[str, ...]]] = []
    invariants = raw.get("invariants")
    if not isinstance(invariants, list):
        raise RuntimeError("invariant manifest missing invariants list")
    for entry in invariants:
        if not isinstance(entry, dict) or entry.get("class") != "operator_coupled":
            continue
        inv_id = str(entry.get("id") or "operator_coupled")
        globs = entry.get("globs")
        if not isinstance(globs, list):
            raise RuntimeError(f"operator_coupled invariant {inv_id} globs is not a list")
        cleaned_items: list[str] = []
        for glob in globs:
            if not isinstance(glob, str):
                raise RuntimeError(f"operator_coupled invariant {inv_id} has non-string glob")
            text = glob.strip()
            if text:
                cleaned_items.append(text)
        cleaned = tuple(cleaned_items)
        if cleaned:
            entries.append((inv_id, cleaned))
    if not entries:
        raise RuntimeError("invariant manifest has no operator_coupled globs")
    return tuple(entries)


def _operator_gate_mutation_scope_refs(fields: dict[str, Any]) -> list[str]:
    metadata = assess_route_metadata(fields).metadata
    if metadata is not None:
        return metadata.mutation_scope_refs
    return _scalar_list(fields.get("mutation_scope_refs"))


def operator_coupled_path_matches(fields: dict[str, Any]) -> tuple[str, ...]:
    refs = [_repo_relative_ref(ref) for ref in _operator_gate_mutation_scope_refs(fields)]
    if not refs:
        return ()
    try:
        entries = _operator_coupled_manifest_entries()
    except (OSError, RuntimeError) as exc:
        return (f"manifest_unavailable:{type(exc).__name__}:{_reason_slug(str(exc))}",)
    matches: list[str] = []
    for ref in refs:
        for inv_id, globs in entries:
            if any(_path_matches_glob(ref, glob) for glob in globs):
                matches.append(f"{ref}#{inv_id}")
                break
    return tuple(dict.fromkeys(matches))


def read_task(task_root: Path, task_id: str) -> TaskNote | None:
    try:
        snapshot = resolve_task_note(task_root, task_id, state="active")
    except TaskStoreError as exc:
        if exc.reason_code == "task_note_not_found":
            return None
        raise
    return TaskNote(snapshot.path, dict(snapshot.frontmatter))


def _task_store_hold_reason(exc: TaskStoreError) -> str:
    detail = f"; detail={exc.detail}" if exc.detail else ""
    return (
        f"task identity hold: {exc.reason_code}; repair={exc.repair_action}{detail}"
    )


def is_authority_exempt(fields: dict[str, Any]) -> bool:
    tokens: set[str] = set()
    for key in ("kind", "task_type", "work_type", "tier", "tags"):
        tokens.update(field_tokens(fields.get(key)))
    if tokens & MUTATION_TOKENS:
        return False
    return bool(tokens & NON_MUTATING_TOKENS)


def resolve_declared_path(raw: str | list[str] | None, *, base: Path) -> Path | None:
    if is_nullish(raw):
        return None
    if not isinstance(raw, str):
        return None
    value = strip_scalar(raw)
    path = Path(value).expanduser()
    if path.is_absolute():
        return path
    return base / path


def lane_worktree(lane: str, platform: str) -> Path:
    return dispatch_worktree(lane, platform)


def is_claude_operator_pool_lane(lane: str, platform: str) -> bool:
    """True for visible Claude dev-pool sessions that are not dispatch lanes."""

    return strip_scalar(platform).lower() == "claude" and is_claude_operator_pool_role(lane)


# --- capability-gated SYSTEM drain of an orphaned dead-lane task --------------
# (dn-validate-task-relax; CASE-SDLC-REFORM-001). A narrow, ADDITIVE admit edge:
# the reserved __system__ actor may advance an orphaned pr_open/claimed/in_progress
# task IFF its owning lane is VERIFIABLY dead and a single-use capability consumes.
# A LIVE lane is never drainable — that guard is the whole point.

#: Reserved sentinel actor for a system drain. NOT a launchable lane.
SYSTEM_DRAIN_LANE = "__system__"

#: Statuses a system drain may advance. ``pr_open`` is the motivating case (a RED
#: PR orphaned by a dead lane); ``claimed``/``in_progress`` cover a lane that died
#: mid-work. ``offered`` is intentionally excluded (no owner that could be dead).
DRAINABLE_STATUSES = frozenset({"pr_open", "claimed", "in_progress"})

#: Lanes whose live-session PID is published at ``<pid-dir>/<lane>.pid`` by
#: scripts/hapax-claude-headless (grounding: beta/delta/epsilon/eta/theta/zeta
#: confirmed live on this substrate). The drain only acts where it can PROVE
#: liveness; any other lane (codex/vibe use a different substrate, not verified
#: here) is refused fail-closed (reviewer must-fix #6).
KNOWN_CLAUDE_LANES = frozenset(
    {"alpha", "beta", "gamma", "delta", "epsilon", "zeta", "eta", "theta"}
)


def _lane_pid_dir() -> Path:
    """Directory where the headless launcher publishes ``<lane>.pid``. Injectable
    via ``HAPAX_LANE_PID_DIR`` so liveness tests never touch a real lane's pid file
    (reviewer must-fix #7)."""
    override = os.environ.get("HAPAX_LANE_PID_DIR")
    if override:
        return Path(override).expanduser()
    return Path(f"/run/user/{os.getuid()}/hapax-claude")


def normalize_lane_name(lane: str) -> str:
    """Bare launcher ROLE for a possibly platform-qualified ``assigned_to``.

    The pid file is named by the bare role (``delta.pid``), so a qualified
    ``claude/delta`` MUST reduce to ``delta`` before the liveness probe — otherwise
    it would look up a nonexistent ``claude/delta.pid``, read absent, and could
    drain a LIVE lane (reviewer must-fix #6).
    """
    lane = strip_scalar(str(lane)).strip()
    if "/" in lane:
        lane = lane.rsplit("/", 1)[-1]
    return lane


def lane_process_absent(lane: str) -> tuple[bool, str]:
    """``(True, why)`` iff lane ``lane``'s claude session is verifiably NOT running.

    Mirrors scripts/hapax-claude-headless: the live session PID is written to
    ``<pid-dir>/<lane>.pid`` and removed by its EXIT trap. Absent file => retired/
    dead. Present file + dead PID => crashed (stale). Present file + live PID =>
    ALIVE, and draining it is forbidden. Fail-CLOSED: any ambiguity (unreadable,
    foreign-owned, alive) returns ``absent=False`` so the drain is refused. Uses
    ``os.kill(pid, 0)`` as a liveness probe ONLY — signal 0 never terminates a
    process, and this never sends a process-group or otherwise terminating signal.
    """
    pid_file = _lane_pid_dir() / f"{lane}.pid"
    try:
        raw = pid_file.read_text(encoding="utf-8").strip()
    except FileNotFoundError:
        return True, f"lane {lane!r} pid file absent (retired/dead)"
    except OSError as exc:
        return False, f"lane {lane!r} pid file unreadable: {exc!r}; refusing drain"
    if not raw.isdigit():
        return True, f"lane {lane!r} pid file malformed ({raw!r}); treating as dead"
    pid = int(raw)
    try:
        os.kill(pid, 0)  # liveness probe ONLY; signal 0 never terminates a process
    except ProcessLookupError:
        return True, f"lane {lane!r} pid {pid} not running (crashed; stale pid file)"
    except PermissionError:
        return False, f"lane {lane!r} pid {pid} owned by another user; refusing drain"
    return False, f"lane {lane!r} pid {pid} is ALIVE; refusing to drain a live lane"


def lane_active_task_lease(lane: str) -> str | None:
    """The task id lane ``lane`` currently claims, or None.

    cc-claim writes both a legacy ``cc-active-task-<lane>`` file and a
    session-keyed ``cc-active-task-<lane>-<uuid>`` file. Mutation-moment TOCTOU
    checks must treat either as an active lane claim because crash/reap paths can
    leave only the session-keyed file behind.
    """
    claims_dir = Path(os.environ.get("HAPAX_CC_CLAIMS_DIR", str(Path.home() / ".cache" / "hapax")))
    legacy = claims_dir / f"cc-active-task-{lane}"
    candidates = [legacy]
    candidates.extend(sorted(claims_dir.glob(f"cc-active-task-{lane}-*")))
    for claim in sorted(
        [path for path in candidates if path.is_file()],
        key=lambda path: path.stat().st_mtime,
        reverse=True,
    ):
        try:
            text = claim.read_text(encoding="utf-8").strip()
        except OSError:
            continue
        if text:
            return text
    return None


# --- Cross-role stale-claim sweeper (reform-identity-coherence, cluster 11) -----
# codex-claim-audit reaps phantom cx-*/codex-* claims and cc-claim's lease-expiry
# only frees a claim when the SAME role re-claims; nothing reaps a greek-slot /
# test-probe / role-less claim left by a dead or wedged lane (the 12-day
# council-eqi-phase0-run test-probe slot; the zeta dead-lane stale slot). This
# sweep closes that gap: it scans EVERY cc-active-task-* file and frees the dead
# ones independent of any role re-claiming.
_CLAIM_PREFIX = "cc-active-task-"
_UUID_SUFFIX_RE = re.compile(
    r"-[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
)
_TERMINAL_CLAIM_STATUSES = {"done", "completed", "closed", "withdrawn", "superseded"}
_UNASSIGNED_VALUES = {"", "null", "none", "~", "unassigned"}
DEFAULT_CLAIM_LEASE_TTL = 21600  # matches cc-claim's HAPAX_CLAIM_LEASE_TTL_SECS default


def _claim_role(filename: str) -> str:
    """The lane role from a cc-active-task-<role>[-<session_id>] filename."""
    return _UUID_SUFFIX_RE.sub("", filename[len(_CLAIM_PREFIX) :])


def _claim_task_dead_reason(task_id: str, active_dir: Path) -> str | None:
    """Reason the claim is dead, if the lane slot can be freed."""
    if not task_id:
        return "terminal-or-missing"
    note = active_dir / f"{task_id}.md"
    if not note.exists():
        variants = sorted(active_dir.glob(f"{task_id}-*.md"))
        if not variants:
            return "terminal-or-missing"
        note = variants[0]
    try:
        text = note.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return None  # unreadable -> do not reap on this basis
    fields, _body = parse_document_frontmatter(text)
    status = str(fields.get("status", "")).strip().strip("\"'").lower()
    assigned_to = str(fields.get("assigned_to", "")).strip().strip("\"'").lower()
    if status in _TERMINAL_CLAIM_STATUSES:
        return "terminal-or-missing"
    if status == "blocked" and assigned_to in _UNASSIGNED_VALUES:
        return "blocked-unassigned"
    return None


def sweep_stale_claims(
    claims_dir: Path,
    active_dir: Path,
    *,
    lease_ttl: int = DEFAULT_CLAIM_LEASE_TTL,
    grace_secs: int = 300,
    now: float | None = None,
) -> list[tuple[str, str, str]]:
    del claims_dir, active_dir, lease_ttl, grace_secs, now
    _hold_gate0a_effect("claim.sweep")


def run_claim_sweep(task_root: Path, *, notify: bool = True) -> list[tuple[str, str, str]]:
    del task_root, notify
    _hold_gate0a_effect("claim.sweep")


def check_worktree_claim_guard(worktree: Path) -> tuple[bool, str]:
    script = worktree / "scripts" / "cc-claim"
    if not script.is_file():
        return False, f"missing cc-claim at {script}"
    text = script.read_text(encoding="utf-8", errors="replace")
    required = DISPATCH_CLAIM_GUARD_MARKERS
    missing = [needle for needle in required if needle not in text]
    if missing:
        return False, f"stale cc-claim in {worktree}: missing {', '.join(missing)}"
    return True, "worktree cc-claim authority/spec guard present"


def check_worktree_close_guard(worktree: Path) -> tuple[bool, str]:
    script = worktree / "scripts" / "cc-close"
    if not script.is_file():
        return False, f"missing cc-close at {script}"
    text = script.read_text(encoding="utf-8", errors="replace")
    required = DISPATCH_CLOSE_GUARD_MARKERS
    missing = [needle for needle in required if needle not in text]
    if missing:
        return False, f"stale cc-close in {worktree}: missing {', '.join(missing)}"
    return True, "worktree cc-close exact-duplicate guard present"


def check_worktree_cc_task_tool_guards(worktree: Path) -> tuple[bool, str]:
    claim_ok, claim_reason = check_worktree_claim_guard(worktree)
    if not claim_ok:
        return False, claim_reason
    close_ok, close_reason = check_worktree_close_guard(worktree)
    if not close_ok:
        return False, close_reason
    return True, f"{claim_reason}; {close_reason}"


def _relay_mq_db_path() -> Path:
    return Path(
        os.environ.get(
            "HAPAX_RELAY_MQ_DB",
            str(Path.home() / ".cache" / "hapax" / "relay" / "messages.db"),
        )
    ).expanduser()


def _parse_mq_datetime(raw: object) -> datetime | None:
    if raw is None:
        return None
    if not isinstance(raw, str) or not raw.strip():
        return None
    try:
        dt = datetime.fromisoformat(raw.replace("Z", "+00:00"))
    except ValueError:
        return None
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=UTC)
    return dt.astimezone(UTC)


def check_durable_dispatch_binding(
    *,
    task_id: str,
    lane: str,
    validation: Validation,
    message_id: str | None = None,
    db_path: Path | None = None,
) -> DurableDispatchBinding:
    if validation.exempt_read_only:
        return DurableDispatchBinding(True, False, "read_only_exempt")
    if validation.task is None:
        return DurableDispatchBinding(False, True, "task_missing")

    authority_case = strip_scalar(str(validation.task.fields.get("authority_case", "")))
    authority_item = strip_scalar(str(validation.task.fields.get("authority_item", "")))
    if is_nullish(authority_case):
        return DurableDispatchBinding(False, True, "authority_case_missing")

    db_path = db_path or _relay_mq_db_path()
    if not db_path.exists():
        return DurableDispatchBinding(False, True, "durable_mq_database_missing")

    recipient = lane.strip().lower().replace("_", "-")
    now = datetime.now(UTC)
    params: dict[str, object] = {
        "authority_case": authority_case,
        "recipient": recipient,
        "task_id": task_id,
        "authority_item": authority_item,
    }
    message_clause = ""
    if message_id:
        message_clause = "AND m.message_id = :message_id"
        params["message_id"] = message_id

    try:
        with sqlite3.connect(f"file:{db_path}?mode=ro", uri=True, timeout=1.0) as conn:
            conn.row_factory = sqlite3.Row
            conn.execute("PRAGMA query_only = ON")
            conn.execute("PRAGMA busy_timeout = 1000")
            rows = conn.execute(
                f"""
                SELECT m.message_id, m.authority_case, m.authority_item, m.subject,
                       m.stale_after, m.expires_at, r.recipient, r.state
                FROM messages m
                JOIN recipients r ON r.message_id = m.message_id
                WHERE m.message_type = 'dispatch'
                  AND m.authority_case = :authority_case
                  AND r.recipient = :recipient
                  {message_clause}
                  AND (
                      m.authority_item = :task_id
                      OR m.authority_item = :authority_item
                      OR m.subject = :task_id
                  )
                ORDER BY m.id DESC
                LIMIT 5
                """,
                params,
            ).fetchall()
    except sqlite3.Error as exc:
        return DurableDispatchBinding(False, True, f"durable_mq_unreadable:{exc}")

    if not rows:
        return DurableDispatchBinding(False, True, "durable_mq_authority_binding_missing")

    fallback_reason = "durable_mq_freshness_unknown"
    for row in rows:
        stale_after = _parse_mq_datetime(row["stale_after"])
        expires_at = _parse_mq_datetime(row["expires_at"])
        if stale_after is None or expires_at is None:
            fallback_reason = "durable_mq_freshness_unknown"
            continue
        if expires_at < now:
            fallback_reason = "durable_mq_dispatch_expired"
            continue
        if stale_after < now:
            fallback_reason = "durable_mq_dispatch_stale"
            continue
        return DurableDispatchBinding(
            True,
            False,
            "durable_mq_dispatch_bound",
            message_id=str(row["message_id"]),
        )
    return DurableDispatchBinding(False, True, fallback_reason)


def _system_drain_audit_path() -> Path:
    override = os.environ.get("HAPAX_SYSTEM_DRAIN_AUDIT")
    if override:
        return Path(override).expanduser()
    return Path.home() / ".cache" / "hapax" / "validate-task-system-drain.jsonl"


def _write_system_drain_audit(
    *,
    task_id: str,
    drained_from_lane: str,
    capability_id: str,
    liveness: str,
    prior_status: str,
    operation_outcome: str,
    capability_consumed: bool,
    edge_class: str,
    guard_evidence: dict[str, tuple[str, ...]],
) -> bool:
    del (
        task_id,
        drained_from_lane,
        capability_id,
        liveness,
        prior_status,
        operation_outcome,
        capability_consumed,
        edge_class,
        guard_evidence,
    )
    _hold_gate0a_effect("system-drain.audit")


def _capability_consumption_count(path: str | Path, capability_id: str) -> int:
    ledger = Path(path)
    try:
        text = ledger.read_text(encoding="utf-8")
    except FileNotFoundError:
        return 0
    except OSError:
        return -1
    count = 0
    for line in text.splitlines():
        if not line.strip():
            continue
        try:
            record = json.loads(line)
        except json.JSONDecodeError:
            return -1
        if not isinstance(record, dict) or not isinstance(record.get("capability_id"), str):
            return -1
        if record["capability_id"] == capability_id:
            count += 1
    return count


def _validate_system_drain(
    *,
    task: TaskNote,
    task_id: str,
    status: str,
    assigned_to: str,
    capability_path: Path | None,
) -> Validation:
    """Admit an orphaned task for SYSTEM drain IFF its owning lane is verifiably
    dead AND a single-use ``(task_id, __system__)`` capability verifies. Consumption
    occurs only at the mutation boundary after guard and Echo preflight.

    Fail-closed at every step: a non-drainable status, no assigned lane, an
    unverifiable substrate lane, a LIVE lane, or an invalid/replayed capability all
    refuse the drain. Authority is auditable-single-use: the operator-provisioned
    0600 grant-key is the root of trust and the mint+consume+audit chain is the
    trail (see the task's open question on mint-authority separation, reviewer
    must-fix #4).
    """
    from shared.coord_event_log import default_grant_key
    from shared.governance.coord_capabilities import (
        DEFAULT_CONSUMPTION_LEDGER,
        read_capability_file,
        verify_dispatch_capability,
    )

    if status not in DRAINABLE_STATUSES:
        return Validation(False, f"system drain refused: status {status!r} not drainable", task)
    if is_nullish(assigned_to) or assigned_to == "unassigned":
        return Validation(False, "system drain refused: task has no assigned lane to verify", task)

    authority_case = strip_scalar(str(task.fields.get("authority_case", "")))
    parent_spec_path = resolve_declared_path(
        task.fields.get("parent_spec"),
        base=Path.home() / "Documents" / "Personal",
    )
    if is_nullish(authority_case) or parent_spec_path is None:
        return Validation(
            False,
            "system drain refused: missing required AuthorityCase/ISAP fields",
            task,
            parent_spec_path,
        )
    if not parent_spec_path.is_file():
        return Validation(
            False,
            f"system drain refused: parent_spec does not exist: {parent_spec_path}",
            task,
            parent_spec_path,
        )
    spec_fields = parse_frontmatter(parent_spec_path.read_text(encoding="utf-8"))
    spec_case = strip_scalar(str(spec_fields.get("case_id", "")))
    if spec_case and spec_case != authority_case:
        return Validation(
            False,
            f"system drain refused: parent_spec case_id {spec_case!r} does not match "
            f"task authority_case {authority_case!r}",
            task,
            parent_spec_path,
        )

    lane_name = normalize_lane_name(assigned_to)
    if lane_name not in KNOWN_CLAUDE_LANES:
        return Validation(
            False,
            f"system drain refused: assigned lane {assigned_to!r} is not a known "
            "claude-substrate lane; liveness unverifiable",
            task,
        )

    absent, why = lane_process_absent(lane_name)
    if not absent:
        return Validation(False, f"system drain refused: {why}", task)

    if capability_path is None:
        return Validation(False, "system drain requires --dispatch-capability <file>", task)
    cap = read_capability_file(capability_path)
    now = datetime.now(UTC).timestamp()
    try:
        key = default_grant_key().read_bytes()
    except OSError:
        return Validation(False, "system drain refused: signing key unavailable", task)
    if not verify_dispatch_capability(
        cap, key=key, now=now, task_id=task_id, lane=SYSTEM_DRAIN_LANE
    ):
        return Validation(
            False,
            "system drain refused: dispatch capability invalid/expired/mismatched",
            task,
        )
    assert cap is not None  # verify_dispatch_capability returns False for None
    ledger_path = os.environ.get("HAPAX_COORD_CONSUMPTION_LEDGER") or DEFAULT_CONSUMPTION_LEDGER
    consumption_count = _capability_consumption_count(ledger_path, cap.capability_id)
    if consumption_count < 0:
        return Validation(False, "system drain refused: consumption ledger unreadable", task)
    if consumption_count:
        return Validation(False, "system drain refused: capability already consumed (replay)", task)
    return Validation(
        True,
        f"system-drain preflight eligible ({why})",
        task,
        parent_spec_path,
        exempt_read_only=False,
    )


def validate_task(
    *,
    task_id: str,
    lane: str,
    platform: str,
    task_root: Path,
    strict_worktree: bool,
    dispatch_capability_path: Path | None = None,
) -> Validation:
    try:
        task = read_task(task_root, task_id)
    except TaskStoreError as exc:
        if exc.reason_code == "task_note_identity_mismatch":
            return Validation(
                False,
                "task frontmatter task_id does not match requested "
                f"{task_id!r}; repair={exc.repair_action}"
                + (f"; detail={exc.detail}" if exc.detail else ""),
            )
        return Validation(
            False,
            _task_store_hold_reason(exc),
        )
    if task is None:
        return Validation(False, f"task not found in {task_root / 'active'}")

    fields = task.fields
    try:
        declared_task_id = _dispatch_identifier(fields.get("task_id", ""), field="task_id")
    except DispatchCanonError as exc:
        return Validation(
            False,
            f"task frontmatter identity invalid: {exc.reason_code}; repair={exc.repair_action}",
            task,
        )
    if declared_task_id != task_id:
        return Validation(
            False,
            f"task frontmatter task_id {declared_task_id!r} does not match requested {task_id!r}",
            task,
        )
    scalar_types = {
        "status": fields.get("status"),
        "assigned_to": fields.get("assigned_to"),
        "authority_case": fields.get("authority_case"),
        "parent_spec": fields.get("parent_spec"),
    }
    malformed_scalars = sorted(
        name
        for name, value in scalar_types.items()
        if value is not None and not isinstance(value, str)
    )
    if malformed_scalars:
        return Validation(
            False,
            "task frontmatter fields must be scalar strings or null: "
            + ", ".join(malformed_scalars),
            task,
        )
    status = strip_scalar(str(fields.get("status", "")))
    assigned_to = strip_scalar(str(fields.get("assigned_to", "")))

    # Capability-gated SYSTEM drain (dn-validate-task-relax). A narrow, additive
    # admit edge for the reserved __system__ actor; it short-circuits BEFORE the
    # legacy status gate, so every normal-lane decision stays byte-for-byte
    # unchanged (a normal lane attempting a pr_open task still gets the reject).
    if lane == SYSTEM_DRAIN_LANE:
        return _validate_system_drain(
            task=task,
            task_id=task_id,
            status=status,
            assigned_to=assigned_to,
            capability_path=dispatch_capability_path,
        )

    if status not in TASK_DISPATCHABLE_STATUSES:
        return Validation(False, f"task status {status!r} is not dispatchable", task)
    if status == "offered" and not (
        is_nullish(fields.get("assigned_to")) or assigned_to == "unassigned"
    ):
        return Validation(
            False,
            f"offered task assigned_to {assigned_to!r} is not claimable; "
            "target-lane routing belongs in dispatch, while task ownership "
            "must remain unassigned until cc-claim",
            task,
        )
    if status in {"claimed", "in_progress"} and assigned_to != lane:
        return Validation(
            False,
            f"task already assigned to {assigned_to!r}; claimed/in_progress "
            f"tasks may only be dispatched to assigned lane {lane!r}",
            task,
        )

    exempt = is_authority_exempt(fields)
    parent_spec_path = resolve_declared_path(
        fields.get("parent_spec"), base=Path.home() / "Documents" / "Personal"
    )
    if not exempt:
        missing = []
        if is_nullish(fields.get("authority_case")):
            missing.append("authority_case")
        if parent_spec_path is None:
            missing.append("parent_spec")
        if missing:
            return Validation(
                False,
                "missing required AuthorityCase/ISAP fields: " + ", ".join(missing),
                task,
                parent_spec_path,
                exempt,
            )
        if not parent_spec_path.is_file():
            return Validation(
                False,
                f"parent_spec does not exist: {parent_spec_path}",
                task,
                parent_spec_path,
            )
        spec_fields = parse_frontmatter(parent_spec_path.read_text(encoding="utf-8"))
        spec_case = strip_scalar(str(spec_fields.get("case_id", "")))
        task_case = strip_scalar(str(fields.get("authority_case", "")))
        if spec_case and task_case and spec_case != task_case:
            return Validation(
                False,
                f"parent_spec case_id {spec_case!r} does not match task authority_case {task_case!r}",
                task,
                parent_spec_path,
                exempt,
            )

    if is_claude_operator_pool_lane(lane, platform):
        return Validation(
            False,
            f"lane {lane!r} is an interactive Claude operator pool, not a governed "
            "dispatch lane; use a supervised Claude lane or a Codex cx-* lane; "
            "recheck governed lane availability with: scripts/hapax-codex-health "
            "--json <cx-lane> for Codex lanes or scripts/hapax-claude-health "
            "--json <lane> for supervised Claude lanes; verify the target is not dev/devN",
            task,
            parent_spec_path,
            exempt,
        )

    if strict_worktree:
        ok, reason = check_worktree_cc_task_tool_guards(lane_worktree(lane, platform))
        if not ok:
            return Validation(False, reason, task, parent_spec_path, exempt)

    return Validation(True, "eligible", task, parent_spec_path, exempt)


def build_prompt(
    task_id: str,
    lane: str,
    platform: str,
    mode: str,
    profile: str,
    validation: Validation,
    route: PlatformPath,
    canon_context: DispatchCanonContext | None = None,
    *,
    advisory_only: bool = False,
    requested_mode: str | None = None,
) -> str:
    if lane == SYSTEM_DRAIN_LANE:
        raise ValueError(
            "__system__ is the drain sentinel, not a launchable lane; a system drain "
            "advances an orphaned task via cc-stage-advance, never a lane launch"
        )
    if canon_context is None:
        raise DispatchCanonError(
            "dispatch_canon_context_missing",
            "construct and verify one canon context before building a dispatch prompt",
        )
    assert validation.task is not None
    safe_task_id = _dispatch_identifier(task_id, field="task_id")
    safe_lane = _dispatch_identifier(lane, field="lane")
    claim_instruction = (
        "2. Before mutation, verify this lane owns the task claim. "
        "If the task is still offered, run the exact argv represented by "
        "position.claim.claim_command and position.task_id in the final canonical data. "
        "If the launcher already claimed it, confirm position.claim.claim_file contains "
        f"{safe_task_id} "
        "and the task note is assigned to this lane. "
        "If claim ownership is absent, rejected for another reason, or assigned to another lane, "
        "stop and write a relay receipt."
    )
    binding = canon_context.binding
    canon_header = {
        "advisory_carriage": binding["advisory_carriage"],
        "canon": binding["canon"],
        "may_authorize": binding["may_authorize"],
        "receipt_is_admission": binding["receipt_is_admission"],
        "schema": binding["schema"],
    }
    position_carriage = {
        "binding_hash": binding["binding_hash"],
        "binding_ref": binding["binding_ref"],
        "position": binding["position"],
    }
    invocation_effect = (
        "ADVISORY ONLY; no launch or mutation admission requested"
        if advisory_only
        else "launch requested; canon carriage remains non-authorizing"
    )
    base = "\n".join(
        [
            "SDLC GOVERNED DISPATCH.",
            "DISPATCH CANON STABLE PREFIX (NON-AUTHORIZING).",
            _canonical_json_bytes(canon_header).decode("ascii"),
            canon_context.rendered_payload,
            "END DISPATCH CANON STABLE PREFIX.",
            "",
            f"Invocation effect: {invocation_effect}.",
            f"Requested mode: {requested_mode or mode}",
            f"Lane: {safe_lane}",
            f"Platform: {platform}",
            f"Mode: {mode}",
            f"Profile: {profile}",
            f"Platform path: {route.summary}",
            f"Capacity invariant: {CAPACITY_INVARIANT}",
            f"Task: {safe_task_id}",
            "",
            "Instructions:",
            f"1. Work only on task {safe_task_id}.",
            claim_instruction
            if route.mutable
            else "2. This route is read-only. Do not mutate files, claims, PRs, services, or runtime state.",
            "3. Use only the authority and mutation scope in the parent spec.",
            "4. Do not create or claim another task from the pool.",
            "5. Do not select work from the pool. Do not continue after this task without a new dispatch.",
            "6. Close this task only with position.close.command from the final canonical data; "
            "do not use bare cc-close or canonical cc-close.",
            "7. If blocked, report the blocker and idle.",
            "8. Do not downgrade profile or platform unless quota, resource pressure, or explicit operator hold requires it and the resulting route remains quality-equivalent for this task.",
            "",
            "DISPATCH POSITION DELTA (NON-AUTHORIZING; FINAL SECTION).",
            _canonical_json_bytes(position_carriage).decode("ascii"),
        ]
    )
    return base


def build_dispatch_carrier(
    *,
    task_id: str,
    lane: str,
    platform: str,
    mode: str,
    profile: str,
    route: PlatformPath | None,
    validation: Validation,
    prompt: str | None,
    launched: bool,
    launch_returncode: int | None = None,
    route_decision: RouteDecision | None = None,
    route_decision_ref: str | None = None,
    durable_binding: DurableDispatchBinding | None = None,
    dispatch_launch: DispatchLaunchResult | None = None,
    route_policy_reason_codes: list[str] | None = None,
    gate_event_candidate: dict[str, Any] | None = None,
    canon_context: DispatchCanonContext | None = None,
    canon_failure_code: str | None = None,
    canon_repair_action: str | None = None,
    requested_route: dict[str, str] | None = None,
    launch_requested: bool = False,
    preview_only: bool = False,
    system_drain: dict[str, Any] | None = None,
) -> dict[str, Any]:
    if launched:
        raise ValueError("Gate-0A carriers cannot represent a launched effect")
    created_at = now_utc()

    def source_sha256(path: Path | None) -> str | None:
        if path is None:
            return None
        try:
            return hashlib.sha256(path.read_bytes()).hexdigest()
        except OSError:
            return None

    def fact(
        code: str,
        value: object,
        *,
        kind: str = "diagnostic",
        source_ref: str | None = None,
        source_sha: str | None = None,
        freshness_state: str = "not_applicable",
        loss_state: str = "lossless",
    ) -> dict[str, object]:
        return build_dispatch_support_fact(
            kind=kind,
            code=code,
            value=value,
            source_ref=source_ref,
            source_sha256=source_sha,
            observed_at=created_at,
            freshness_state=freshness_state,
            loss_state=loss_state,
        )

    task_path = validation.task.path if validation.task else None
    support: list[dict[str, object]] = [
        fact("validation.ok", validation.ok, kind="evidence"),
        fact("validation.reason", validation.reason),
        fact(
            "task.source",
            None,
            kind="evidence",
            source_ref=str(task_path) if task_path else None,
            source_sha=source_sha256(task_path),
        ),
        fact(
            "task.parent_spec",
            None,
            kind="evidence",
            source_ref=str(validation.parent_spec_path) if validation.parent_spec_path else None,
            source_sha=source_sha256(validation.parent_spec_path),
        ),
        fact("validation.exempt_read_only", validation.exempt_read_only, kind="evidence"),
        fact(
            "task.validation_state",
            "validated" if validation.ok else "held",
            kind="candidate",
        ),
        fact(
            "route.path_summary",
            route.summary if route else None,
            kind="evidence",
            loss_state="bounded" if route else "unknown",
        ),
        fact("capacity.invariant", CAPACITY_INVARIANT, kind="evidence"),
        fact("prompt.bytes", len(prompt.encode("utf-8")) if prompt else None),
        fact(
            "prompt.sha256",
            hashlib.sha256(prompt.encode("utf-8")).hexdigest() if prompt else None,
            kind="evidence",
        ),
        fact("request.preview_only", preview_only, kind="candidate"),
        fact(
            "request.advisory_only",
            preview_only or bool(durable_binding and durable_binding.advisory_only),
            kind="candidate",
        ),
        fact(
            "request.route_platform",
            requested_route.get("platform") if requested_route else platform,
            kind="candidate",
        ),
        fact(
            "request.route_mode",
            requested_route.get("mode") if requested_route else mode,
            kind="candidate",
        ),
        fact(
            "request.route_profile",
            requested_route.get("profile") if requested_route else profile,
            kind="candidate",
        ),
        fact(
            "route.target_host_candidate",
            effective_dispatch_host(platform, mode),
            kind="candidate",
        ),
        fact("canon.failure_code", canon_failure_code),
        fact("canon.repair_action", canon_repair_action),
    ]
    if canon_context is not None:
        binding_hash = canon_context.binding["binding_hash"]
        position_hash = canon_context.binding["position"]["position_hash"]
        support.extend(
            [
                fact(
                    "canon.binding",
                    None,
                    kind="evidence",
                    source_ref=canon_context.binding["binding_ref"],
                    source_sha=binding_hash,
                ),
                fact(
                    "canon.image_sha256",
                    canon_context.binding["canon"]["image_hash"],
                    kind="evidence",
                ),
                fact(
                    "canon.payload_sha256",
                    canon_context.binding["canon"]["payload_sha256"],
                    kind="evidence",
                ),
                fact(
                    "canon.position",
                    None,
                    kind="evidence",
                    source_ref=canon_context.binding["position"]["position_ref"],
                    source_sha=position_hash,
                ),
            ]
        )
    if durable_binding is not None:
        support.extend(
            [
                fact("durable_mq.bound", durable_binding.ok, kind="evidence"),
                fact(
                    "durable_mq.advisory_only",
                    durable_binding.advisory_only,
                    kind="evidence",
                ),
                fact("durable_mq.reason", durable_binding.reason),
            ]
        )
    if dispatch_launch is not None:
        support.extend(
            [
                fact("coord_dispatch.replayed", dispatch_launch.replayed, kind="evidence"),
                fact("coord_dispatch.reason", dispatch_launch.reason),
                fact(
                    "coord_dispatch.event_ref",
                    dispatch_launch.event_id,
                    kind="evidence",
                ),
                fact("coord_dispatch.cleanup_state", dispatch_launch.cleanup_state),
            ]
        )
    if route_decision is not None:
        decision_hash = _content_hash(route_decision.model_dump(mode="json"))
        support.append(
            fact(
                "route.decision",
                route_decision.decision_id,
                kind="candidate",
                source_ref=route_decision_ref,
                source_sha=decision_hash,
                freshness_state="current",
                loss_state="bounded",
            )
        )
        route_facts: tuple[tuple[str, str, object], ...] = (
            ("route_policy.action", "candidate", route_decision.action.value),
            ("route_policy.outcome", "candidate", route_decision.policy_outcome),
            ("route_policy.launch_allowed", "candidate", route_decision.launch_allowed),
            ("route_policy.green", "candidate", route_decision.route_policy_green),
            ("route_policy.clog_state", "diagnostic", route_decision.clog_state.value),
            (
                "route_policy.compatibility_mode",
                "diagnostic",
                route_decision.compatibility_mode,
            ),
            ("route_policy.degraded_state", "diagnostic", route_decision.degraded_state),
            (
                "route_policy.registry_freshness_green",
                "evidence",
                route_decision.registry_freshness_green,
            ),
            (
                "route_policy.quota_freshness_green",
                "evidence",
                route_decision.quota_freshness_green,
            ),
            (
                "route_policy.quota_evidence_refs",
                "evidence",
                list(route_decision.quota_evidence_refs),
            ),
            (
                "route_policy.resource_freshness_green",
                "evidence",
                route_decision.resource_freshness_green,
            ),
            (
                "route_policy.route_selection_authority",
                "candidate",
                route_decision.route_selection_authority,
            ),
            (
                "route_policy.quality_floor_satisfied",
                "evidence",
                route_decision.quality_floor_satisfied,
            ),
            (
                "route_policy.authority_allowed",
                "candidate",
                route_decision.authority_allowed,
            ),
            (
                "route_policy.cloud_burst_eligible",
                "candidate",
                route_decision.cloud_burst_eligible,
            ),
            (
                "route_policy.cloud_burst_guard_state",
                "diagnostic",
                route_decision.cloud_burst_guard_state,
            ),
            (
                "route_policy.cloud_burst_spike_reasons",
                "diagnostic",
                list(route_decision.cloud_burst_spike_reasons),
            ),
            (
                "route_policy.cloud_burst_guard_reasons",
                "diagnostic",
                list(route_decision.cloud_burst_guard_reasons),
            ),
        )
        support.extend(
            fact(code, value, kind=kind, freshness_state="current")
            for code, kind, value in route_facts
        )
        if route_decision.dimensional_receipt is not None:
            dimensional = route_decision.dimensional_receipt
            support.extend(
                [
                    fact(
                        "dimensional.route_receipt_schema",
                        dimensional.dimensional_route_receipt_schema,
                        kind="evidence",
                    ),
                    fact(
                        "dimensional.selected_route_id",
                        dimensional.selected_route_id,
                        kind="candidate",
                    ),
                    fact(
                        "dimensional.candidate_count",
                        len(dimensional.candidates),
                        kind="evidence",
                    ),
                    fact(
                        "dimensional.degraded_mode",
                        dimensional.degraded_mode,
                        kind="diagnostic",
                    ),
                    fact(
                        "dimensional.evidence_refs",
                        [
                            ref
                            for ref in (
                                dimensional.demand_vector_ref.artifact_path,
                                dimensional.candidate_snapshot_ref.artifact_path,
                            )
                            if ref
                        ],
                        kind="evidence",
                        loss_state="bounded",
                    ),
                ]
            )
    effective_reason_codes = (
        route_policy_reason_codes
        if route_policy_reason_codes is not None
        else list(route_decision.reason_codes)
        if route_decision is not None
        else None
    )
    if effective_reason_codes is not None:
        support.append(fact("route_policy.reason_codes", effective_reason_codes))
    if gate_event_candidate is not None:
        gate_hash = _content_hash(gate_event_candidate)
        support.append(
            fact(
                "gate.candidate",
                gate_event_candidate.get("gate_result"),
                kind="candidate",
                source_ref=f"gate-event-candidate@sha256:{gate_hash}",
                source_sha=gate_hash,
                loss_state="bounded",
            )
        )

    record: dict[str, Any] = {
        "event": "methodology_dispatch",
        "created_at": created_at,
        "task_id": task_id,
        "lane": lane,
        "platform": platform,
        "mode": mode,
        "profile": profile,
        "requested_operation": "launch" if launch_requested else "validate",
        "correlation": {
            "schema": DISPATCH_CORRELATION_SCHEMA,
            "mq_message_id": durable_binding.message_id if durable_binding else None,
            "idempotency_key": dispatch_launch.idempotency_key if dispatch_launch else None,
        },
        "support": support,
        "launched": False,
        "may_authorize": False,
        "receipt_is_admission": False,
        "effect_state": "held_not_admitted",
        "materialization_state": "not_materialized",
    }
    del launch_returncode, requested_route, system_drain
    return seal_methodology_dispatch_carrier(record)


def write_receipt(**kwargs: Any) -> None:
    del kwargs
    _hold_gate0a_effect("methodology-receipt.publish")


def slugify(value: str) -> str:
    chars = [ch if ch.isalnum() or ch in {"_", ".", "-"} else "-" for ch in value]
    slug = "".join(chars).strip("-")
    while "--" in slug:
        slug = slug.replace("--", "-")
    return slug or "item"


def _sliced_call(args: list[str], env: dict[str, str] | None = None) -> int:
    del args, env
    _hold_gate0a_effect("process.launch")


def effective_dispatch_host(platform: str, mode: str) -> str:
    explicit = os.environ.get("HAPAX_DISPATCH_HOST", "").strip()
    if explicit:
        return explicit
    default = os.environ.get("HAPAX_DEFAULT_DISPATCH_HOST", "").strip()
    if default:
        return default
    if platform in {"claude", "codex"} and mode == "headless":
        return "appendix"
    return "local"


def _write_delayed_receipt(args: argparse.Namespace, decision: AdmissionDecision) -> None:
    del args, decision
    _hold_gate0a_effect("dispatch-pressure-receipt.publish")


def _await_sdlc_admission(args: argparse.Namespace) -> None:
    del args
    _hold_gate0a_effect("dispatch.pressure-wait")


# Worker-lane terminal-failure classification -> guarded family-availability witness
# (cc-task capability-adapter-worker-path-classify-failure). Best-effort + strictly FAIL-OPEN:
# classification NEVER changes the dispatch returncode or outcome. The guard, single-key write, and
# no-sibling-flip invariants live in shared.worker_failure_witness.
_WORKER_FAILURE_ADAPTERS: dict[str, type[WorkerAdapter]] = {
    "agy": AgyAdapter,
    "claude": ClaudeAdapter,
    "codex": CodexAdapter,
    "vibe": VibeAdapter,
}


def _capability_adapter_for_admission(platform: str) -> CapabilityAdapter:
    """Return the adapter used for the admission call.

    Worker platforms use the existing worker-adapter map. Non-worker routes still go through the
    final ``CapabilityAdapter.admit`` delegation so methodology dispatch no longer calls the policy
    spine directly.
    """

    adapter_cls = _WORKER_FAILURE_ADAPTERS.get(platform)
    if adapter_cls is not None:
        return adapter_cls()
    return CapabilityAdapter()


def _worker_adapter_for_launch(platform: str) -> WorkerAdapter:
    """Return the launch-capable adapter for ``platform`` or fail closed."""

    adapter_cls = _WORKER_FAILURE_ADAPTERS.get(platform)
    if adapter_cls is None:
        raise AuthorityViolation(
            f"launch not authorized for platform {platform}: no WorkerAdapter registered. "
            "Next: route mutable dispatch through a governed WorkerAdapter before attempting "
            "CapabilityAdapter.launch."
        )
    return adapter_cls()


def _read_worker_failure_text(platform: str, mode: str, lane: str) -> str:
    """Best-available worker error text. Claude headless writes a per-lane output.jsonl
    (LOG_DIR=~/.cache/hapax/claude-headless/<role>); read its tail so the adapter can classify the
    quota/auth/transient signature. Soft coupling — a missing/unreadable file yields '' (-> UNKNOWN,
    no witness), never an error."""

    if platform == "claude" and mode == "headless":
        out = Path.home() / ".cache" / "hapax" / "claude-headless" / lane / "output.jsonl"
        try:
            return "\n".join(out.read_text(encoding="utf-8").splitlines()[-50:])
        except OSError:
            return ""
    return ""


def _classify_and_witness_terminal_failure(
    rc: int, *, task_id: str, lane: str, platform: str, mode: str, profile: str
) -> None:
    del rc, task_id, lane, platform, mode, profile
    _hold_gate0a_effect("worker-failure.publish")


def classify_and_witness_launch(
    launch_fn: Callable[[], int],
    *,
    task_id: str,
    lane: str,
    platform: str,
    mode: str,
    profile: str,
) -> int:
    del launch_fn, task_id, lane, platform, mode, profile
    _hold_gate0a_effect("worker.launch-and-witness")


#: Registry-declared model pin per claude dispatch profile — the launch-side half of the
#: CapabilityExecutionInvariant. Values are Claude Code ``--model`` aliases. Mirrors the
#: registry ExecutionDescriptors (claude.headless.full/opus -> claude-opus-4-8 => "opus";
#: claude.headless.sonnet -> claude-sonnet-* => "sonnet"; claude.headless.haiku => "haiku").
#: A profile absent here fails closed rather than inheriting the CLI default model.
CLAUDE_PROFILE_MODEL_PIN: dict[str, str] = {
    "full": "opus",
    "opus": "opus",
    "sonnet": "sonnet",
    "haiku": "haiku",
}


def launch_claude_headless(
    task_id: str,
    lane: str,
    prompt: str,
    route: PlatformPath,
    claim_dispatch_env: dict[str, str] | None = None,
) -> int:
    launcher = Path(
        os.environ.get(
            "HAPAX_METHODOLOGY_CLAUDE_HEADLESS",
            str(Path.home() / ".local" / "bin" / "hapax-claude-headless"),
        )
    )
    env = os.environ.copy()
    env.update(claim_dispatch_env or {})
    # Never propagate the dispatcher's own session id: each lane mints its own
    # per-spawn HAPAX_SESSION_ID so two same-role re-dispatched lanes never share a
    # claim key (reform-identity-coherence cluster 11, AC1).
    env.pop("HAPAX_SESSION_ID", None)
    # CapabilityExecutionInvariant drift guard (R0-pin): pin --model for EVERY claude
    # profile to its registry-declared model. Never let a profile inherit the Claude Code
    # CLI default (~/.claude/settings.json model=fable), which can silently drop fable->opus
    # under indeterminate conditions — an observed != sanctioned execution drift. `full`
    # declares claude-opus-4-8, so it pins "opus"; unknown profiles FAIL CLOSED rather than
    # inherit the default.
    pinned_model = CLAUDE_PROFILE_MODEL_PIN.get(route.profile)
    if pinned_model is None:
        print(
            f"claude profile '{route.profile}' has no declared model pin; refusing to launch "
            "(CEI drift guard — a launch must never inherit the CLI default model)",
            file=sys.stderr,
        )
        return 9
    env["HAPAX_CLAUDE_MODEL"] = pinned_model
    env["HAPAX_METHODOLOGY_DISPATCH_TASK"] = task_id
    env["HAPAX_CLAUDE_HEADLESS_WORKDIR"] = str(lane_worktree(lane, "claude"))
    env["HAPAX_DISPATCH_HOST"] = effective_dispatch_host("claude", "headless")
    return _sliced_call([str(launcher), "--task", task_id, lane, prompt], env)


def launch_claude_interactive(
    task_id: str,
    lane: str,
    validation: Validation,
    prompt: str = "",
    claim_dispatch_env: dict[str, str] | None = None,
) -> int:
    launcher = Path(
        os.environ.get(
            "HAPAX_METHODOLOGY_CLAUDE_LAUNCHER",
            str(Path(__file__).resolve().parent / "hapax-claude"),
        )
    )
    if not launcher.is_file():
        print(f"Claude launcher not found: {launcher}", file=sys.stderr)
        return 8

    status = ""
    if validation.task is not None:
        status = strip_scalar(str(validation.task.fields.get("status", "")))
    args = [
        str(launcher),
        "--role",
        lane,
        "--terminal",
        "tmux",
        "--task",
        task_id,
        "--",
        prompt,
    ]
    # Always hand the lane a scrubbed env: drop any inherited HAPAX_SESSION_ID so it
    # mints its own per-spawn id (reform-identity-coherence cluster 11, AC1).
    # hapax-claude pins the freshly minted id into its tmux runner script.
    env = os.environ.copy()
    env.update(claim_dispatch_env or {})
    env.pop("HAPAX_SESSION_ID", None)
    if status in {"claimed", "in_progress"}:
        env["HAPAX_METHODOLOGY_DISPATCH_TASK"] = task_id
    return _sliced_call(args, env=env)


def normalize_profile(platform: str, profile: str) -> str:
    profile = profile.strip().lower().replace("_", "-")
    if platform == "api" and profile in {
        "api-frontier",
        "cloud",
        "cloud-burst",
        "frontier",
    }:
        return "api_frontier"
    if platform == "api" and profile in {"or", "open-router", "openrouter"}:
        return "openrouter"
    if platform == "api" and profile in {
        "provider-gateway",
        "gateway",
        "provider_spend",
    }:
        return "provider_gateway"
    if profile in {"default", "max", "pro", "full-capability"}:
        return "full"
    if profile == "quota-fallback":
        if platform == "claude":
            return "sonnet"
        if platform == "codex":
            return "spark"
    return profile


def route_for(platform: str, mode: str, profile: str) -> PlatformPath | None:
    normalized_profile = normalize_profile(platform, profile)
    if (platform, mode, normalized_profile) == (
        RECEIPT_ONLY_ROUTE.platform,
        RECEIPT_ONLY_ROUTE.mode,
        RECEIPT_ONLY_ROUTE.profile,
    ):
        return RECEIPT_ONLY_ROUTE
    return PLATFORM_PATHS.get((platform, mode, normalized_profile))


def _route_for_route_id(route_id: str) -> PlatformPath | None:
    parts = route_id.split(".", 2)
    if len(parts) != 3:
        return None
    return route_for(parts[0], parts[1], parts[2])


def _decision_selected_route_id(route_decision: RouteDecision) -> str:
    return (
        route_decision.dimensional_receipt.selected_route_id
        if route_decision.dimensional_receipt is not None
        else None
    ) or route_decision.route_id


def _decision_selected_route(route_decision: RouteDecision) -> PlatformPath | None:
    return _route_for_route_id(_decision_selected_route_id(route_decision))


def _unsupported_selected_route_reason(route_decision: RouteDecision) -> str | None:
    selected_route = _decision_selected_route(route_decision)
    if selected_route is not None:
        return None
    unsupported_route_id = _decision_selected_route_id(route_decision)
    return (
        f"route policy selected unsupported route: {unsupported_route_id}; "
        "next action: inspect dimensional_selected_route_id in the route decision receipt "
        "and either add a matching governed PLATFORM_PATHS launcher entry or constrain "
        "the candidate set to supported governed routes."
    )


def supported_route_lines() -> list[str]:
    lines = [CAPACITY_INVARIANT, ""]
    for _, route in sorted(PLATFORM_PATHS.items()):
        mutability = "mutable" if route.mutable else "read-only"
        lines.append(
            f"{route.platform}/{route.mode}/{route.profile}: {route.summary} "
            f"({mutability}) -> {route.launcher}"
        )
        lines.append(f"  {route.notes}")
    return lines


def platform_route_validation(
    route: PlatformPath | None, validation: Validation
) -> tuple[bool, str]:
    if route is None:
        return False, "unsupported platform/mode/profile route"
    if not route.mutable and not validation.exempt_read_only:
        return (
            False,
            f"{route.platform}/{route.mode}/{route.profile} is read-only; "
            "mutation tasks must route to a mutable platform profile",
        )
    return True, "eligible platform route"


def platform_lane_compatibility_reason(lane: str, route: PlatformPath) -> str | None:
    """Fail closed when route recomposition changes the platform under a stale lane id."""

    normalized = normalize_lane_name(lane)
    route_id = f"{route.platform}.{route.mode}.{route.profile}"
    if route.platform == "codex" and not normalized.startswith("cx-"):
        return (
            f"route/lane mismatch: selected route {route_id} requires a Codex cx-* "
            f"lane/session identity, got lane {lane!r}. Next action: dispatch this "
            "Codex route to an available cx-* lane/worktree or rerun route selection "
            "for a route compatible with the requested lane before consuming MQ."
        )
    if route.platform == "claude" and normalized not in KNOWN_CLAUDE_LANES:
        return (
            f"route/lane mismatch: selected route {route_id} requires a Claude "
            f"headless role in {sorted(KNOWN_CLAUDE_LANES)!r}, got lane {lane!r}. "
            "Next action: dispatch this Claude route to a supervised Claude lane or "
            "rerun route selection for a route compatible with the requested lane "
            "before consuming MQ."
        )
    if route.platform == "vibe" and not (
        normalized.startswith("vbe") or normalized.startswith("vibe")
    ):
        return (
            f"route/lane mismatch: selected route {route_id} requires a Vibe "
            f"vbe-* session identity, got lane {lane!r}. Next action: dispatch this "
            "Vibe route to an available vbe-* lane/worktree or rerun route selection "
            "for a route compatible with the requested lane before consuming MQ."
        )
    return None


def _availability_recomposition_candidate_requests(
    primary: DispatchRequest,
    *,
    task_fields: dict[str, Any],
    policy_sources: DispatchPolicySources,
    validation: Validation,
    rollback_mode: bool,
) -> tuple[DispatchRequest, ...] | None:
    capability = primary.capability
    if capability is None or not capability.availability_recomposition_required:
        return None
    registry = policy_sources.registry
    if registry is None:
        return ()

    candidates: list[DispatchRequest] = []
    for route_descriptor in sorted(registry.routes, key=lambda item: item.route_id):
        if route_descriptor.route_id == primary.route_id:
            continue
        platform = route_descriptor.platform.value
        mode = route_descriptor.mode.value
        profile = route_descriptor.profile.value
        route = route_for(platform, mode, profile)
        if route is None or not supports_route(platform, mode):
            continue
        if not route.mutable and not validation.exempt_read_only:
            continue
        candidates.append(
            build_dispatch_request(
                task_id=primary.task_id,
                lane=primary.lane,
                platform=platform,
                mode=mode,
                profile=profile,
                task_fields=task_fields,
                registry=registry,
                registry_error=policy_sources.registry_error,
                quota_ledger=policy_sources.quota_ledger,
                quota_error=policy_sources.quota_error,
                route_authority_receipts=policy_sources.route_authority_receipts,
                surface_delta_refs_by_route=policy_sources.surface_delta_refs_by_route,
                surface_delta_blockers_by_route=policy_sources.surface_delta_blockers_by_route,
                rollback_mode=rollback_mode,
                legacy_route_supported=True,
                legacy_route_mutable=route.mutable,
            )
        )
    return tuple(candidates)


def route_metadata_validation_reason(validation: Validation) -> str | None:
    assessment = assess_route_metadata(policy_task_fields(validation))
    if assessment.dispatchable:
        return None
    if (
        not route_envelope_gate_enforced()
        and not assessment.missing_fields
        and not assessment.validation_errors
    ):
        # SHADOW (HAPAX_ROUTE_ENVELOPE_GATE != enforce): a well-formed but non-dispatchable
        # derived envelope (hold-only) does not block dispatch; malformed/incomplete
        # metadata still blocks. The non-route admission stays observable.
        return None
    details = [
        *assessment.hold_reasons,
        *assessment.missing_fields,
        *assessment.validation_errors,
    ]
    detail_text = "; ".join(details) or assessment.status.value
    return f"route metadata not dispatchable: {detail_text}"


def env_flag(name: str) -> bool:
    return os.environ.get(name, "").strip().lower() in {"1", "true", "yes", "on"}


def optional_env_path(name: str) -> Path | None:
    value = os.environ.get(name, "").strip()
    return Path(value).expanduser() if value else None


def dispatch_message_id(cli_value: str | None) -> str | None:
    value = (cli_value or os.environ.get("HAPAX_METHODOLOGY_DISPATCH_MESSAGE_ID", "")).strip()
    return value or None


def coord_event_log_from_env() -> None:
    _hold_gate0a_effect("coord-event-log.open")


def orchestration_ledger_dir() -> Path:
    return Path(
        os.environ.get(
            "HAPAX_ORCHESTRATION_LEDGER_DIR",
            str(Path.home() / ".cache" / "hapax" / "orchestration"),
        )
    )


def policy_task_fields(validation: Validation) -> dict[str, Any]:
    if validation.task is None:
        return {}
    fields, _body = parse_document_frontmatter(validation.task.path)
    payload = dict(fields or validation.task.fields)
    payload["__task_note_path"] = str(validation.task.path)
    path_matches = operator_coupled_path_matches(payload)
    if path_matches:
        payload["__operator_coupled_path_matches"] = list(path_matches)
    return payload


def _emit_gate_event(
    route_decision: RouteDecision,
    policy_request: DispatchRequest,
    task_fields: dict[str, Any],
    *,
    gate_result: str,
) -> dict[str, Any]:
    """Build non-materialized observational GateEvent candidate data."""

    route = route_decision.selected_descriptor_leaf or route_decision.route_id
    event = build_gate_event(
        task_fields,
        route=route,
        demand_vector=policy_request.demand_vector,
        gate_result=gate_result,
    )
    return event.model_dump(mode="json")


def launch_codex_headless(
    task_id: str,
    lane: str,
    prompt: str,
    validation: Validation,
    route: PlatformPath,
    *,
    reactivate_retired_relay: bool = False,
    claim_dispatch_env: dict[str, str] | None = None,
) -> int:
    # Genuine headless path (reform §6 P0): `codex exec` via hapax-codex-headless,
    # NOT a tmux pane. The tmux launcher (hapax-codex) remains the interactive
    # analog (launch_codex_interactive).
    launcher = Path(
        os.environ.get(
            "HAPAX_METHODOLOGY_CODEX_HEADLESS",
            str(Path(__file__).resolve().parent / "hapax-codex-headless"),
        )
    )
    if not launcher.is_file():
        print(f"Codex headless launcher not found: {launcher}", file=sys.stderr)
        return 8

    status = ""
    if validation.task is not None:
        status = strip_scalar(str(validation.task.fields.get("status", "")))
    args = [str(launcher), "--task", task_id]
    local_fallback_allowed = allow_codex_p0_local_dispatch_fallback(task_id, lane, validation)
    if reactivate_retired_relay or local_fallback_allowed:
        args.append("--force")
    if status in {"claimed", "in_progress"}:
        args.append("--no-claim")
    args.extend([lane, prompt])
    if route.profile == "spark":
        args.extend(
            [
                "--",
                "-c",
                'model="gpt-5.3-codex-spark"',
                "-c",
                'model_reasoning_effort="high"',
            ]
        )
    env = os.environ.copy()
    env.update(claim_dispatch_env or {})
    env["HAPAX_METHODOLOGY_DISPATCH_TASK"] = task_id
    env["HAPAX_DISPATCH_HOST"] = effective_dispatch_host("codex", "headless")
    if local_fallback_allowed:
        # Preserve a caller/operator-provided fallback value; the P0 drain rule
        # only supplies the default local fallback when the env is otherwise unset.
        env.setdefault("HAPAX_DISPATCH_HOST_FALLBACK", "local")
    return _sliced_call(args, env)


def launch_vibe_headless(
    task_id: str,
    lane: str,
    prompt: str,
    validation: Validation,
    claim_dispatch_env: dict[str, str] | None = None,
) -> int:
    launcher = Path(
        os.environ.get(
            "HAPAX_METHODOLOGY_VIBE_LAUNCHER",
            str(Path.home() / ".local" / "bin" / "hapax-vibe"),
        )
    )
    if not launcher.is_file():
        print(f"Vibe launcher not found: {launcher}", file=sys.stderr)
        return 8

    status = ""
    if validation.task is not None:
        status = strip_scalar(str(validation.task.fields.get("status", "")))
    args = [
        str(launcher),
        "--session",
        lane,
        "--terminal",
        "tmux",
        "--task",
        task_id,
        "--prompt",
        prompt,
        "--output",
        "streaming",
        "--force",
    ]
    if status in {"claimed", "in_progress"}:
        args.append("--no-claim")
    env = os.environ.copy()
    env.update(claim_dispatch_env or {})
    return _sliced_call(args, env)


def _parse_system_drain_guard_evidence(
    raw_values: list[str],
) -> tuple[dict[str, tuple[str, ...]] | None, str | None]:
    collected: dict[str, list[str]] = {}
    durable_prefixes = ("coord:", "file:", "mq:", "receipt:", "task:")
    for raw in raw_values:
        guard, separator, evidence_ref = raw.partition("=")
        if not separator or not guard or not evidence_ref:
            return None, "system_drain_guard_evidence_malformed"
        if not evidence_ref.startswith(durable_prefixes):
            return None, "system_drain_guard_evidence_not_durable"
        collected.setdefault(guard, []).append(evidence_ref)
    return {key: tuple(value) for key, value in collected.items()}, None


def _preflight_system_drain_transition(
    task: TaskNote,
    *,
    target_stage: str,
    edge_class: str,
    raw_guard_evidence: list[str],
) -> tuple[LifecycleTransitionIntent | None, str | None]:
    guard_evidence, reason = _parse_system_drain_guard_evidence(raw_guard_evidence)
    if guard_evidence is None:
        return None, reason
    fields = task.fields
    no_go = {
        key: fields.get(key) is True or strip_scalar(str(fields.get(key, ""))).lower() == "true"
        for key in NO_GO_BOOLEANS
    }
    try:
        intent = LifecycleTransitionIntent.create(
            task_id=strip_scalar(str(fields.get("task_id", ""))),
            from_stage=strip_scalar(str(fields.get("stage", ""))),
            to_stage=target_stage,
            edge_class=edge_class,
            authority_case=strip_scalar(str(fields.get("authority_case", ""))),
            actor=SYSTEM_DRAIN_LANE,
            no_go_snapshot=no_go,
            guard_evidence=guard_evidence,
            parent_spec=strip_scalar(str(fields.get("parent_spec", ""))) or None,
            evidence_type="system_drain_capability",
            evidence_summary="preflight only; capability not consumed",
            origin="hapax-methodology-dispatch:system-drain",
        )
    except (LifecycleTransitionError, ValueError) as exc:
        return None, getattr(exc, "reason_code", "system_drain_transition_preflight_refused")
    return intent, None


def advance_task_stage(
    task_id: str,
    stage: str,
    *,
    edge_class: str,
    guard_evidence: dict[str, tuple[str, ...]],
) -> int:
    del task_id, stage, edge_class, guard_evidence
    _hold_gate0a_effect("lifecycle.advance-stage")


def reverify_lane_dead_for_drain(lane: str, task_id: str) -> tuple[bool, str]:
    """Mutation-moment re-verification (TOCTOU / pid-reuse guard, reviewer must-fix #5).

    Liveness is re-read at the instant before the mutation and cross-checked against
    the active-task lease — not the bare pid captured at admission. A lane that
    respawned (a new live pid now in the file) or re-claimed a *different* task
    between admission and here is treated as live and the drain aborts. A recycled
    pid reads alive too, so it also aborts (fail-safe). Only a still-dead lane whose
    lease has not moved to other work proceeds.
    """
    absent, why = lane_process_absent(lane)
    if not absent:
        return False, f"lane respawned before mutation: {why}"
    lease = lane_active_task_lease(lane)
    if lease is not None and lease != task_id:
        return False, (
            f"lane {lane!r} re-claimed a different task {lease!r} before mutation; "
            "treating as live, drain aborted"
        )
    return True, why


def run_system_drain(args: argparse.Namespace, task_root: Path) -> int:
    del args, task_root
    _hold_gate0a_effect("system-drain.execute")


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--task", help="Explicit cc-task id to dispatch")
    parser.add_argument("--lane", help="Target lane, e.g. beta or cx-red")
    parser.add_argument(
        "--platform",
        default="claude",
        type=str.lower,
        choices=[
            "agy",
            "antigrav",
            "antigravity",
            "api",
            "claude",
            "codex",
            "gemini-cli",
            "vibe",
        ],
    )
    parser.add_argument(
        "--mode",
        default="headless",
        choices=["headless", "interactive", "receipt-only"],
    )
    parser.add_argument(
        "--profile",
        default="full",
        help=(
            "Capability profile. Use full by default; quota-fallback maps to "
            "the platform's constrained analogue when one exists. Codex also "
            "supports spark."
        ),
    )
    parser.add_argument("--launch", action="store_true", help="Launch after validation")
    parser.add_argument(
        "--list-platform-paths",
        action="store_true",
        help="List governed platform/mode/profile launch paths and exit",
    )
    parser.add_argument(
        "--capabilities",
        action="store_true",
        help="Print the Executor adapter capability registry as JSON and exit",
    )
    parser.add_argument(
        "--sweep-stale-claims",
        action="store_true",
        help=(
            "Legacy claim-maintenance entry point; HOLD until represented by an admitted "
            "lifecycle action"
        ),
    )
    parser.add_argument(
        "--print-prompt", action="store_true", help="Print the governed launch prompt"
    )
    parser.add_argument(
        "--no-receipt",
        action="store_true",
        help="Legacy flag; governed dispatch refuses unwitnessed prompt or launch paths",
    )
    parser.add_argument(
        "--skip-worktree-check",
        action="store_true",
        help="Do not require target worktree cc-claim guard",
    )
    parser.add_argument(
        "--policy-rollback",
        action="store_true",
        help=(
            "DEPRECATED — rollback is retired (#3792). This flag is a no-op alias "
            "that now HOLDs all routes (policy_rollback_retired); a frontier route "
            "un-degrades only with a signed route-authority receipt. Mint one with "
            "scripts/hapax-mint-route-authority-receipt."
        ),
    )
    parser.add_argument(
        "--mq-message-id",
        help="Durable relay MQ dispatch message id to bind this governed dispatch to",
    )
    parser.add_argument(
        "--idempotency-key",
        help="Stable idempotency key for atomic bind/consume/launch replay",
    )
    parser.add_argument(
        "--dispatch-capability",
        help=(
            "Legacy SYSTEM-drain input retained for compatibility; the CLI HOLDs until "
            "the drain is represented by an admitted lifecycle action"
        ),
    )
    parser.add_argument(
        "--drain-to-stage",
        help="Legacy SYSTEM-drain target retained for compatibility; no stage is advanced",
    )
    parser.add_argument(
        "--drain-edge-class",
        default="auto",
        choices=["auto", "next", "fall"],
        help="Legacy SYSTEM-drain edge class retained for compatibility",
    )
    parser.add_argument(
        "--guard-evidence",
        action="append",
        default=[],
        metavar="GUARD=DURABLE_REF",
        help="Legacy SYSTEM-drain guard evidence retained for compatibility",
    )
    args = parser.parse_args(argv)
    requested_profile = args.profile
    args.profile = normalize_profile(args.platform, args.profile)

    if args.list_platform_paths:
        print("\n".join(supported_route_lines()))
        return 0

    if args.capabilities:
        print(json.dumps(capabilities_payload(), indent=2))
        return 0

    if args.sweep_stale_claims:
        return _hold_for_admitted_lifecycle_action("claim_sweep")

    if not args.task or not args.lane:
        parser.error(
            "--task and --lane are required unless --list-platform-paths or --capabilities is used"
        )

    try:
        args.task = _dispatch_identifier(args.task, field="task_id")
        if strip_scalar(args.lane) != SYSTEM_DRAIN_LANE:
            args.lane = _dispatch_identifier(args.lane, field="lane")
            requested_profile = _dispatch_identifier(requested_profile, field="profile")
            args.profile = _dispatch_identifier(args.profile, field="profile")
    except DispatchCanonError as exc:
        print(
            f"BLOCKED: {exc.reason_code}; repair={exc.repair_action}",
            file=sys.stderr,
        )
        return 10

    requested_route = {
        "platform": args.platform,
        "mode": args.mode,
        "profile": requested_profile,
    }
    requested_mode = args.mode
    preview_only = not args.launch

    ordinary_dispatch = strip_scalar(args.lane) != SYSTEM_DRAIN_LANE
    if ordinary_dispatch and args.launch and args.no_receipt:
        print(
            "BLOCKED: dispatch_launch_without_receipt_forbidden; "
            "repair=remove --no-receipt from the launch request",
            file=sys.stderr,
        )
        return 10
    if ordinary_dispatch and args.no_receipt:
        print(
            "BLOCKED: dispatch_preview_without_receipt_forbidden; "
            "repair=remove --no-receipt so route and canon decisions remain witnessed",
            file=sys.stderr,
        )
        return 10
    if ordinary_dispatch and args.launch and args.skip_worktree_check:
        print(
            "BLOCKED: dispatch_launch_worktree_check_bypass_forbidden; "
            "repair=remove --skip-worktree-check from the launch request",
            file=sys.stderr,
        )
        return 10
    if ordinary_dispatch and requested_mode == "receipt-only":
        if args.launch:
            print(
                "BLOCKED: receipt-only is a preview intent and cannot launch; "
                "repair=use --mode headless with --launch",
                file=sys.stderr,
            )
            return 10
        if (args.platform, args.profile) != ("codex", "full"):
            print(
                "BLOCKED: receipt-only preview is retained only for codex/full; "
                "repair=use an existing real platform/mode/profile preview route",
                file=sys.stderr,
            )
            return 10
        args.mode = "headless"

    gate_event_candidate: dict[str, Any] | None = None

    def write_main_receipt(**kwargs: Any) -> dict[str, Any]:
        kwargs.setdefault("requested_route", requested_route)
        kwargs.setdefault("launch_requested", args.launch)
        kwargs.setdefault("preview_only", preview_only)
        kwargs.setdefault("gate_event_candidate", gate_event_candidate)
        carrier = build_dispatch_carrier(**kwargs)
        print(_canonical_json_bytes(carrier).decode("ascii"))
        return carrier

    task_root = Path(
        os.environ.get(
            "HAPAX_CC_TASK_ROOT",
            str(Path.home() / "Documents" / "Personal" / "20-projects" / "hapax-cc-tasks"),
        )
    )

    # The legacy SYSTEM drain bypasses admission and is contained until the
    # lifecycle action is represented and consumed by the Gate-0 spine.
    if not ordinary_dispatch:
        return _hold_for_admitted_lifecycle_action("system_drain")

    # Claim maintenance is a lifecycle effect, not launch preflight. Ordinary
    # dispatch therefore performs no opportunistic sweep; maintenance must enter
    # through the same admitted lifecycle-action boundary as every other effect.

    if args.platform in {"agy", "antigrav", "antigravity", "gemini-cli"}:
        if args.platform == "agy":
            reason = (
                "platform 'agy' is the non-launchable read-only agy.review.direct review route, "
                "not a methodology-dispatch worker lane. Use scripts/hapax-agy-reviewer for "
                "review-plane work."
            )
        else:
            reason = (
                f"platform '{args.platform}' is retired/excised; do not dispatch it as live supply. "
                "Use admitted Claude, Codex, or Vibe routes, or agy.review.direct for the live "
                "read-only review route."
            )
        try:
            task_for_receipt = read_task(task_root, args.task)
        except TaskStoreError:
            task_for_receipt = None
        if not args.no_receipt:
            write_main_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=None,
                validation=Validation(False, reason, task_for_receipt),
                prompt=None,
                launched=False,
                route_policy_reason_codes=[
                    "review_route_not_launchable"
                    if args.platform == "agy"
                    else "retired_platform_not_dispatchable"
                ],
            )
        print(f"BLOCKED: {reason}", file=sys.stderr)
        return 10

    validation = validate_task(
        task_id=args.task,
        lane=args.lane,
        platform=args.platform,
        task_root=task_root,
        strict_worktree=not args.skip_worktree_check,
    )
    route = route_for(args.platform, args.mode, args.profile)
    prompt: str | None = None

    if not validation.ok:
        if not args.no_receipt:
            write_main_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=route,
                validation=validation,
                prompt=prompt,
                launched=False,
            )
        print(f"BLOCKED: {validation.reason}", file=sys.stderr)
        return 10

    policy_sources = load_dispatch_policy_sources(
        registry_path=optional_env_path("HAPAX_PLATFORM_CAPABILITY_REGISTRY"),
        quota_ledger_path=optional_env_path("HAPAX_QUOTA_SPEND_LEDGER"),
    )
    task_fields = policy_task_fields(validation)
    rollback_mode = args.policy_rollback or env_flag("HAPAX_DISPATCH_POLICY_ROLLBACK")
    policy_request = build_dispatch_request(
        task_id=args.task,
        lane=args.lane,
        platform=args.platform,
        mode=args.mode,
        profile=args.profile,
        task_fields=task_fields,
        registry=policy_sources.registry,
        registry_error=policy_sources.registry_error,
        quota_ledger=policy_sources.quota_ledger,
        quota_error=policy_sources.quota_error,
        route_authority_receipts=policy_sources.route_authority_receipts,
        surface_delta_refs_by_route=policy_sources.surface_delta_refs_by_route,
        surface_delta_blockers_by_route=policy_sources.surface_delta_blockers_by_route,
        rollback_mode=rollback_mode,
        legacy_route_supported=route is not None,
        legacy_route_mutable=route.mutable if route else False,
    )
    candidate_requests = _availability_recomposition_candidate_requests(
        policy_request,
        task_fields=task_fields,
        policy_sources=policy_sources,
        validation=validation,
        rollback_mode=rollback_mode,
    )
    adapter = _capability_adapter_for_admission(args.platform)
    route_decision = adapter.admit(
        policy_request,
        now=datetime.now(UTC),
        candidate_requests=candidate_requests,
    )
    route_decision_hash = _content_hash(route_decision.model_dump(mode="json"))
    route_decision_ref = f"route-decision@sha256:{route_decision_hash}"

    if route_decision.action is not DispatchAction.LAUNCH:
        if args.launch:
            gate_event_candidate = _emit_gate_event(
                route_decision,
                policy_request,
                task_fields,
                gate_result="reject",
            )
        route_reason = f"route policy {route_decision.action.value}: {route_decision.message}"
        blocked = Validation(
            False,
            route_reason,
            validation.task,
            validation.parent_spec_path,
            validation.exempt_read_only,
        )
        if not args.no_receipt:
            write_main_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=route,
                validation=blocked,
                prompt=None,
                launched=False,
                route_decision=route_decision,
                route_decision_ref=route_decision_ref,
            )
        print(f"BLOCKED: {route_reason}", file=sys.stderr)
        if route is None:
            print("Supported governed routes:", file=sys.stderr)
            print("\n".join(supported_route_lines()), file=sys.stderr)
        return 10

    selected_route = _decision_selected_route(route_decision)
    if selected_route is None:
        reason = _unsupported_selected_route_reason(route_decision)
        assert reason is not None
        blocked = Validation(
            False,
            reason,
            validation.task,
            validation.parent_spec_path,
            validation.exempt_read_only,
        )
        if not args.no_receipt:
            write_main_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=route,
                validation=blocked,
                prompt=None,
                launched=False,
                route_decision=route_decision,
                route_decision_ref=route_decision_ref,
            )
        print(f"BLOCKED: {reason}", file=sys.stderr)
        print("Supported governed routes:", file=sys.stderr)
        print("\n".join(supported_route_lines()), file=sys.stderr)
        return 10
    compatibility_reason = platform_lane_compatibility_reason(args.lane, selected_route)
    if compatibility_reason is not None:
        blocked = Validation(
            False,
            compatibility_reason,
            validation.task,
            validation.parent_spec_path,
            validation.exempt_read_only,
        )
        if not args.no_receipt:
            write_main_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=selected_route.platform,
                mode=selected_route.mode,
                profile=selected_route.profile,
                route=selected_route,
                validation=blocked,
                prompt=None,
                launched=False,
                route_decision=route_decision,
                route_decision_ref=route_decision_ref,
            )
        print(f"BLOCKED: {compatibility_reason}", file=sys.stderr)
        return 10
    route = selected_route
    args.platform = route.platform
    args.mode = route.mode
    args.profile = route.profile
    selected_validation = validate_task(
        task_id=args.task,
        lane=args.lane,
        platform=args.platform,
        task_root=task_root,
        strict_worktree=not args.skip_worktree_check,
    )
    if not selected_validation.ok:
        reason = f"selected route preflight failed: {selected_validation.reason}"
        if not args.no_receipt:
            write_main_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=route,
                validation=Validation(
                    False,
                    reason,
                    selected_validation.task,
                    selected_validation.parent_spec_path,
                    selected_validation.exempt_read_only,
                ),
                prompt=None,
                launched=False,
                route_decision=route_decision,
                route_decision_ref=route_decision_ref,
            )
        print(f"BLOCKED: {reason}", file=sys.stderr)
        return 10
    validation = selected_validation
    if args.launch:
        gate_event_candidate = _emit_gate_event(
            route_decision,
            policy_request,
            task_fields,
            gate_result="accept",
        )
    mq_message_id = dispatch_message_id(args.mq_message_id)
    if args.launch and route.mutable and not validation.exempt_read_only and mq_message_id is None:
        durable_binding = DurableDispatchBinding(
            False,
            True,
            "strict_mq_message_id_required",
        )
    else:
        durable_binding = check_durable_dispatch_binding(
            task_id=args.task,
            lane=args.lane,
            validation=validation,
            message_id=mq_message_id,
        )
    if not durable_binding.ok and args.launch:
        reason = f"durable MQ authority binding required: {durable_binding.reason}"
        blocked = Validation(
            False,
            reason,
            validation.task,
            validation.parent_spec_path,
            validation.exempt_read_only,
        )
        if not args.no_receipt:
            write_main_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=route,
                validation=blocked,
                prompt=None,
                launched=False,
                route_decision=route_decision,
                route_decision_ref=route_decision_ref,
                durable_binding=durable_binding,
            )
        print(f"BLOCKED: {reason}", file=sys.stderr)
        return 10

    try:
        canon_context = _build_dispatch_canon_context(
            task_id=args.task,
            lane=args.lane,
            platform=args.platform,
            mode=args.mode,
            profile=args.profile,
            validation=validation,
            route=route,
            route_decision=route_decision,
            route_decision_ref=route_decision_ref,
            requested_route=requested_route,
            policy_requested_route_id=policy_request.route_id,
            dispatch_message_id=mq_message_id,
        )
        prompt = build_prompt(
            args.task,
            args.lane,
            args.platform,
            args.mode,
            args.profile,
            validation,
            route,
            canon_context,
            advisory_only=preview_only,
            requested_mode=requested_mode,
        )
    except DispatchCanonError as exc:
        reason = f"canon carriage refused: {exc.reason_code}; repair={exc.repair_action}"
        blocked = Validation(
            False,
            reason,
            validation.task,
            validation.parent_spec_path,
            validation.exempt_read_only,
        )
        if not args.no_receipt:
            write_main_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=route,
                validation=blocked,
                prompt=None,
                launched=False,
                route_decision=route_decision,
                route_decision_ref=route_decision_ref,
                durable_binding=durable_binding,
                canon_failure_code=exc.reason_code,
                canon_repair_action=exc.repair_action,
            )
        print(f"BLOCKED: {reason}", file=sys.stderr)
        return 10

    if args.print_prompt and preview_only:
        print("ADVISORY_ONLY: non_launch_invocation")
        print(prompt)

    if args.launch:
        _verify_dispatch_canon_context(canon_context)

        refreshed_validation = validate_task(
            task_id=args.task,
            lane=args.lane,
            platform=args.platform,
            task_root=task_root,
            strict_worktree=True,
        )
        if not refreshed_validation.ok:
            reason = (
                f"dispatch context changed during admission wait: {refreshed_validation.reason}"
            )
            if not args.no_receipt:
                write_main_receipt(
                    task_id=args.task,
                    lane=args.lane,
                    platform=args.platform,
                    mode=args.mode,
                    profile=args.profile,
                    route=route,
                    validation=Validation(
                        False,
                        reason,
                        refreshed_validation.task,
                        refreshed_validation.parent_spec_path,
                        refreshed_validation.exempt_read_only,
                    ),
                    prompt=None,
                    launched=False,
                    route_decision=route_decision,
                    route_decision_ref=route_decision_ref,
                    durable_binding=durable_binding,
                    canon_failure_code="dispatch_context_drift_after_admission",
                    canon_repair_action="re-dispatch from freshly validated task state",
                )
            print(f"BLOCKED: {reason}", file=sys.stderr)
            return 10
        try:
            refreshed_context = _build_dispatch_canon_context(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                validation=refreshed_validation,
                route=route,
                route_decision=route_decision,
                route_decision_ref=route_decision_ref,
                requested_route=requested_route,
                policy_requested_route_id=policy_request.route_id,
                dispatch_message_id=mq_message_id,
            )
            refreshed_prompt = build_prompt(
                args.task,
                args.lane,
                args.platform,
                args.mode,
                args.profile,
                refreshed_validation,
                route,
                refreshed_context,
                advisory_only=False,
                requested_mode=requested_mode,
            )
        except DispatchCanonError as exc:
            reason = (
                f"dispatch context refresh refused: {exc.reason_code}; repair={exc.repair_action}"
            )
            if not args.no_receipt:
                write_main_receipt(
                    task_id=args.task,
                    lane=args.lane,
                    platform=args.platform,
                    mode=args.mode,
                    profile=args.profile,
                    route=route,
                    validation=Validation(
                        False,
                        reason,
                        refreshed_validation.task,
                        refreshed_validation.parent_spec_path,
                        refreshed_validation.exempt_read_only,
                    ),
                    prompt=None,
                    launched=False,
                    route_decision=route_decision,
                    route_decision_ref=route_decision_ref,
                    durable_binding=durable_binding,
                    canon_failure_code=exc.reason_code,
                    canon_repair_action=exc.repair_action,
                )
            print(f"BLOCKED: {reason}", file=sys.stderr)
            return 10
        if (
            refreshed_context.binding["binding_hash"] != canon_context.binding["binding_hash"]
            or hashlib.sha256(refreshed_prompt.encode("utf-8")).hexdigest()
            != hashlib.sha256(prompt.encode("utf-8")).hexdigest()
        ):
            reason = "dispatch context changed during admission wait"
            if not args.no_receipt:
                write_main_receipt(
                    task_id=args.task,
                    lane=args.lane,
                    platform=args.platform,
                    mode=args.mode,
                    profile=args.profile,
                    route=route,
                    validation=Validation(
                        False,
                        reason,
                        refreshed_validation.task,
                        refreshed_validation.parent_spec_path,
                        refreshed_validation.exempt_read_only,
                    ),
                    prompt=None,
                    launched=False,
                    route_decision=route_decision,
                    route_decision_ref=route_decision_ref,
                    durable_binding=durable_binding,
                    canon_context=refreshed_context,
                    canon_failure_code="dispatch_context_drift_after_admission",
                    canon_repair_action="re-dispatch from freshly validated task and canon state",
                )
            print(f"BLOCKED: {reason}", file=sys.stderr)
            return 10
        validation = refreshed_validation
        canon_context = refreshed_context
        prompt = refreshed_prompt
        if args.print_prompt:
            print(prompt)

        if route.mutable and not validation.exempt_read_only:
            hold_code = "execution_admission_prerequisites_unavailable"
            hold_repair = (
                "materialize and consume the exact admitted lifecycle action after completing "
                "the accepted operational-fact ContextSelection/ContextPosition and "
                "authenticated sovereign-act carriers; atomically consume "
                "ClaimAdmissionConsumption with publish_admitted_claim before MQ acceptance"
            )
            reason = (
                f"{hold_code}: operational-fact context selection is unavailable; "
                "authority holds AWAIT_SOVEREIGN_ACT and AUTHORITY_TRUST_UNESTABLISHED"
            )
            if not args.no_receipt:
                write_main_receipt(
                    task_id=args.task,
                    lane=args.lane,
                    platform=args.platform,
                    mode=args.mode,
                    profile=args.profile,
                    route=route,
                    validation=Validation(
                        False,
                        reason,
                        validation.task,
                        validation.parent_spec_path,
                        validation.exempt_read_only,
                    ),
                    prompt=None,
                    launched=False,
                    route_decision=route_decision,
                    route_decision_ref=route_decision_ref,
                    durable_binding=durable_binding,
                    canon_context=canon_context,
                    canon_failure_code=hold_code,
                    canon_repair_action=hold_repair,
                )
            print(f"HOLD: {reason}; repair={hold_repair}", file=sys.stderr)
            return 10

        reason = (
            "execution_admission_prerequisites_unavailable: process execution cannot "
            "bypass the composition-issued invocation-pointer boundary"
        )
        blocked = Validation(
            False,
            reason,
            validation.task,
            validation.parent_spec_path,
            validation.exempt_read_only,
        )
        if not args.no_receipt:
            write_main_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=route,
                validation=blocked,
                prompt=prompt,
                launched=False,
                route_decision=route_decision,
                route_decision_ref=route_decision_ref,
                durable_binding=durable_binding,
                canon_context=canon_context,
            )
        print(f"HOLD: {reason}", file=sys.stderr)
        return 10

    if not args.no_receipt:
        write_main_receipt(
            task_id=args.task,
            lane=args.lane,
            platform=args.platform,
            mode=args.mode,
            profile=args.profile,
            route=route,
            validation=validation,
            prompt=prompt,
            launched=False,
            route_decision=route_decision,
            route_decision_ref=route_decision_ref,
            durable_binding=durable_binding,
            canon_context=canon_context,
        )

    print("advisory_only: non_launch_invocation")
    print(f"preview: {args.task} -> {args.platform}/{args.mode}/{args.profile}/{args.lane}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
