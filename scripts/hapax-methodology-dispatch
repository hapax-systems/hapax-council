    sys.path.insert(0, str(_SCRIPTS_DIR_FOR_IMPORTS))


def _project_runtime_ready() -> bool:
    project_root = Path(__file__).resolve().parents[1]
    expected_prefix = (project_root / ".venv").resolve()
    expected_executable = str(project_root / ".venv" / "bin" / "python")
    if Path(sys.prefix).resolve() != expected_prefix:
        return False
    if os.path.abspath(sys.executable) != expected_executable or sys.flags.isolated != 1:
        return False
    if os.environ.get("PYTHONPATH") or os.environ.get("PYTHONHOME"):
        return False
    try:
        package_present = importlib.util.find_spec("hapax.context_canon") is not None
        encoder_version = importlib_metadata.version("python-toon")
    except (ImportError, ModuleNotFoundError, importlib_metadata.PackageNotFoundError):
        return False
    return package_present and encoder_version == "0.1.3"


def _require_project_runtime() -> None:
    """Refuse an unpinned interpreter without probing, syncing, or re-execing."""

    if _project_runtime_ready():
        return
    project_python = Path(__file__).resolve().parents[1] / ".venv" / "bin" / "python"
    raise SystemExit(
        "methodology_dispatch_runtime_unready: invoke the pre-provisioned pinned "
        f"interpreter directly: {project_python} -I {Path(__file__).resolve()}"
    )


class Gate0AEffectHold(RuntimeError):
    """Unconditional boundary for every legacy methodology actuation helper."""

    reason_code = "admitted_lifecycle_action_required"

    def __init__(self, operation: str, repair: str) -> None:
        self.operation = operation
        self.repair = repair
        super().__init__(f"{self.reason_code}:{operation}:{repair}")


def _hold_gate0a_effect(operation: str) -> None:
    raise Gate0AEffectHold(
        operation,
        "dispatch one exact composition-issued invocation pointer after Gate-0B activation",
    )


if __name__ == "__main__":
    _require_project_runtime()

