@dataclass
class TaskNote:
    path: Path
    fields: dict[str, Any]


@dataclass
class Validation:
    ok: bool
    reason: str
    task: TaskNote | None = None
    parent_spec_path: Path | None = None
    exempt_read_only: bool = False


@dataclass(frozen=True)
class DurableDispatchBinding:
    ok: bool
    advisory_only: bool
    reason: str
    message_id: str | None = None


def now_utc() -> str:
    return datetime.now(UTC).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def strip_scalar(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in {"'", '"'}:
        return value[1:-1]
    return value


def is_nullish(value: str | list[str] | None) -> bool:
    if value is None:
        return True
    if isinstance(value, list):
        return len(value) == 0
    return strip_scalar(value).lower() in NULLISH


def field_tokens(value: str | list[str] | None) -> set[str]:
    if value is None:
        return set()
    if isinstance(value, list):
        raw = " ".join(value)
    else:
        raw = value
    raw = strip_scalar(raw).lower()
    for ch in "[],:;":
        raw = raw.replace(ch, " ")
    return {part.strip() for part in raw.split() if part.strip()}


def split_lane_list(value: str | None) -> set[str]:
    if not value:
        return set()
    return {part for part in re.split(r"[\s,]+", value.strip()) if part}


def p0_codex_drain_lanes() -> set[str]:
    for name in (
        "HAPAX_P0_CODEX_DRAIN_LANES",
        "HAPAX_SUPERVISOR_P0_CODEX_LANES",
        "HAPAX_SUPERVISOR_P0_CODEX_LANE",
    ):
        if name in os.environ:
            return split_lane_list(os.environ.get(name))
    return set(DEFAULT_P0_CODEX_DRAIN_LANES)


def _field_value_text(value: Any) -> str:
    if isinstance(value, list):
        return " ".join(_field_value_text(item) for item in value)
    if isinstance(value, dict):
        return " ".join(_field_value_text(item) for item in value.values())
    return strip_scalar(str(value)) if value is not None else ""


def task_is_p0_incident(task_id: str, validation: Validation) -> bool:
    if validation.task is None:
        return False
    fields = validation.task.fields
    priority = strip_scalar(str(fields.get("priority", ""))).lower()
    if priority != "p0":
        return False
    raw = " ".join(
        [
            task_id,
            _field_value_text(fields.get("title")),
            _field_value_text(fields.get("kind")),
            _field_value_text(fields.get("tags")),
            _field_value_text(fields.get("incident_kind")),
            _field_value_text(fields.get("incident_fingerprint")),
        ]
    ).lower()
    normalized = raw.replace("_", "-")
    return any(
        marker in normalized
        for marker in (
            "p0-incident",
            "incident-intake",
            "technical-alert",
            "sdlc-task-stalled",
        )
    )


def allow_codex_p0_local_dispatch_fallback(
    task_id: str,
    lane: str,
    validation: Validation,
) -> bool:
    return lane in p0_codex_drain_lanes() and task_is_p0_incident(task_id, validation)


def allow_codex_governed_relay_reactivation(
    *,
    route: PlatformPath,
    route_decision: RouteDecision,
    durable_binding: DurableDispatchBinding,
    validation: Validation,
) -> bool:
    """Permit retired-relay reactivation only for a fully bound mutable launch.

    The fail-safe default is false: read-only exemptions, advisory MQ checks,
    missing message IDs, non-launch route decisions, non-Codex routes, or
    immutable routes must leave the launcher without ``--force`` so the relay
    lifecycle guard remains the next authority boundary.
    """
    return (
        route.platform == "codex"
        and route.mode == "headless"
        and route.mutable
        and not validation.exempt_read_only
        and route_decision.action is DispatchAction.LAUNCH
        and durable_binding.ok
        and not durable_binding.advisory_only
        and durable_binding.message_id is not None
    )


def parse_frontmatter(text: str) -> dict[str, Any]:
    fields, _body = parse_document_frontmatter(text)
    return dict(fields)


def _glob_to_regex(glob: str) -> re.Pattern[str]:
    out: list[str] = []
    i = 0
    while i < len(glob):
        if glob.startswith("**/", i):
            out.append("(?:.*/)?")
            i += 3
        elif glob.startswith("**", i):
            out.append(".*")
            i += 2
        elif glob[i] == "*":
            out.append("[^/]*")
            i += 1
        elif glob[i] == "?":
            out.append("[^/]")
            i += 1
        else:
            out.append(re.escape(glob[i]))
            i += 1
    return re.compile("^" + "".join(out) + "$")


def _path_matches_glob(path: str, glob: str) -> bool:
    return _glob_to_regex(glob).match(path) is not None


def _scalar_list(value: Any) -> list[str]:
    if value is None:
        return []
    if isinstance(value, str):
        text = strip_scalar(value)
        return [] if is_nullish(text) else [text]
    if isinstance(value, (list, tuple, set, frozenset)):
        return [strip_scalar(str(item)) for item in value if not is_nullish(str(item))]
    return [strip_scalar(str(value))]


def _repo_relative_ref(value: str) -> str:
    text = strip_scalar(value).replace("\\", "/").strip()
    if text.startswith("./"):
        text = text[2:]
    path = Path(text).expanduser()
    if path.is_absolute():
        try:
            return path.resolve().relative_to(REPO_ROOT_FOR_IMPORTS.resolve()).as_posix()
        except ValueError:
            return path.as_posix().lstrip("/")
    return text.lstrip("/")


def _reason_slug(value: str) -> str:
    chars = [ch if ch.isalnum() or ch in {"_", ".", "-"} else "-" for ch in value.lower()]
    slug = "".join(chars).strip("-")
    while "--" in slug:
        slug = slug.replace("--", "-")
    return slug or "unknown"


def invariant_manifest_path() -> Path:
    configured = os.environ.get("HAPAX_INVARIANT_MANIFEST", "").strip()
    return Path(configured).expanduser() if configured else DEFAULT_INVARIANT_MANIFEST


def _operator_coupled_manifest_entries() -> tuple[tuple[str, tuple[str, ...]], ...]:
    try:
        import yaml
    except ModuleNotFoundError as exc:  # pragma: no cover - project env dependency guard
        raise RuntimeError("PyYAML unavailable for invariant-manifest operator gate") from exc
    manifest_path = invariant_manifest_path()
    try:
        raw = yaml.safe_load(manifest_path.read_text(encoding="utf-8"))
    except yaml.YAMLError as exc:
        raise RuntimeError("invariant manifest parse error") from exc
    if not isinstance(raw, dict):
        raise RuntimeError("invariant manifest is not a mapping")
    classes = raw.get("classes")
    if not isinstance(classes, dict):
        raise RuntimeError("invariant manifest missing classes mapping")
    operator_class = classes.get("operator_coupled")
    if not isinstance(operator_class, dict):
        raise RuntimeError("invariant manifest missing operator_coupled class")
    policy = operator_class.get("policy")
    if not isinstance(policy, dict) or policy.get("dispatch_mode") != "interactive_only":
        raise RuntimeError("operator_coupled manifest policy is not interactive_only")
    entries: list[tuple[str, tuple[str, ...]]] = []
    invariants = raw.get("invariants")
    if not isinstance(invariants, list):
        raise RuntimeError("invariant manifest missing invariants list")
    for entry in invariants:
        if not isinstance(entry, dict) or entry.get("class") != "operator_coupled":
            continue
        inv_id = str(entry.get("id") or "operator_coupled")
        globs = entry.get("globs")
        if not isinstance(globs, list):
            raise RuntimeError(f"operator_coupled invariant {inv_id} globs is not a list")
        cleaned_items: list[str] = []
        for glob in globs:
            if not isinstance(glob, str):
                raise RuntimeError(f"operator_coupled invariant {inv_id} has non-string glob")
            text = glob.strip()
            if text:
                cleaned_items.append(text)
        cleaned = tuple(cleaned_items)
        if cleaned:
            entries.append((inv_id, cleaned))
    if not entries:
        raise RuntimeError("invariant manifest has no operator_coupled globs")
    return tuple(entries)


def _operator_gate_mutation_scope_refs(fields: dict[str, Any]) -> list[str]:
    metadata = assess_route_metadata(fields).metadata
    if metadata is not None:
        return metadata.mutation_scope_refs
    return _scalar_list(fields.get("mutation_scope_refs"))


def operator_coupled_path_matches(fields: dict[str, Any]) -> tuple[str, ...]:
    refs = [_repo_relative_ref(ref) for ref in _operator_gate_mutation_scope_refs(fields)]
    if not refs:
        return ()
    try:
        entries = _operator_coupled_manifest_entries()
    except (OSError, RuntimeError) as exc:
        return (f"manifest_unavailable:{type(exc).__name__}:{_reason_slug(str(exc))}",)
    matches: list[str] = []
    for ref in refs:
        for inv_id, globs in entries:
            if any(_path_matches_glob(ref, glob) for glob in globs):
                matches.append(f"{ref}#{inv_id}")
                break
    return tuple(dict.fromkeys(matches))


def read_task(task_root: Path, task_id: str) -> TaskNote | None:
    active = task_root / "active"
    candidates = [active / f"{task_id}.md", *sorted(active.glob(f"{task_id}-*.md"))]
    for candidate in candidates:
        if candidate.is_file():
            return TaskNote(candidate, parse_frontmatter(candidate.read_text(encoding="utf-8")))
    return None


def is_authority_exempt(fields: dict[str, Any]) -> bool:
    tokens: set[str] = set()
    for key in ("kind", "task_type", "work_type", "tier", "tags"):
        tokens.update(field_tokens(fields.get(key)))
    if tokens & MUTATION_TOKENS:
        return False
    return bool(tokens & NON_MUTATING_TOKENS)


def resolve_declared_path(raw: str | list[str] | None, *, base: Path) -> Path | None:
    if is_nullish(raw):
        return None
    if isinstance(raw, list):
        return None
    value = strip_scalar(raw)
    path = Path(value).expanduser()
    if path.is_absolute():
        return path
    return base / path


def lane_worktree(lane: str, platform: str) -> Path:
    return dispatch_worktree(lane, platform)


def is_claude_operator_pool_lane(lane: str, platform: str) -> bool:
    """True for visible Claude dev-pool sessions that are not dispatch lanes."""

    return strip_scalar(platform).lower() == "claude" and is_claude_operator_pool_role(lane)


# --- capability-gated SYSTEM drain of an orphaned dead-lane task --------------
# (dn-validate-task-relax; CASE-SDLC-REFORM-001). A narrow, ADDITIVE admit edge:
# the reserved __system__ actor may advance an orphaned pr_open/claimed/in_progress
# task IFF its owning lane is VERIFIABLY dead and a single-use capability consumes.
# A LIVE lane is never drainable — that guard is the whole point.

#: Reserved sentinel actor for a system drain. NOT a launchable lane.
SYSTEM_DRAIN_LANE = "__system__"

#: Statuses a system drain may advance. ``pr_open`` is the motivating case (a RED
#: PR orphaned by a dead lane); ``claimed``/``in_progress`` cover a lane that died
#: mid-work. ``offered`` is intentionally excluded (no owner that could be dead).
DRAINABLE_STATUSES = frozenset({"pr_open", "claimed", "in_progress"})

#: Lanes whose live-session PID is published at ``<pid-dir>/<lane>.pid`` by
#: scripts/hapax-claude-headless (grounding: beta/delta/epsilon/eta/theta/zeta
#: confirmed live on this substrate). The drain only acts where it can PROVE
#: liveness; any other lane (codex/vibe use a different substrate, not verified
#: here) is refused fail-closed (reviewer must-fix #6).
KNOWN_CLAUDE_LANES = frozenset(
    {"alpha", "beta", "gamma", "delta", "epsilon", "zeta", "eta", "theta"}
)


def _lane_pid_dir() -> Path:
    """Directory where the headless launcher publishes ``<lane>.pid``. Injectable
    via ``HAPAX_LANE_PID_DIR`` so liveness tests never touch a real lane's pid file
    (reviewer must-fix #7)."""
    override = os.environ.get("HAPAX_LANE_PID_DIR")
    if override:
        return Path(override).expanduser()
    return Path(f"/run/user/{os.getuid()}/hapax-claude")


def normalize_lane_name(lane: str) -> str:
    """Bare launcher ROLE for a possibly platform-qualified ``assigned_to``.

    The pid file is named by the bare role (``delta.pid``), so a qualified
    ``claude/delta`` MUST reduce to ``delta`` before the liveness probe — otherwise
    it would look up a nonexistent ``claude/delta.pid``, read absent, and could
    drain a LIVE lane (reviewer must-fix #6).
    """
    lane = strip_scalar(str(lane)).strip()
    if "/" in lane:
        lane = lane.rsplit("/", 1)[-1]
    return lane


def lane_process_absent(lane: str) -> tuple[bool, str]:
    """``(True, why)`` iff lane ``lane``'s claude session is verifiably NOT running.

    Mirrors scripts/hapax-claude-headless: the live session PID is written to
    ``<pid-dir>/<lane>.pid`` and removed by its EXIT trap. Absent file => retired/
    dead. Present file + dead PID => crashed (stale). Present file + live PID =>
    ALIVE, and draining it is forbidden. Fail-CLOSED: any ambiguity (unreadable,
    foreign-owned, alive) returns ``absent=False`` so the drain is refused. Uses
    ``os.kill(pid, 0)`` as a liveness probe ONLY — signal 0 never terminates a
    process, and this never sends a process-group or otherwise terminating signal.
    """
    pid_file = _lane_pid_dir() / f"{lane}.pid"
    try:
        raw = pid_file.read_text(encoding="utf-8").strip()
    except FileNotFoundError:
        return True, f"lane {lane!r} pid file absent (retired/dead)"
    except OSError as exc:
        return False, f"lane {lane!r} pid file unreadable: {exc!r}; refusing drain"
    if not raw.isdigit():
        return True, f"lane {lane!r} pid file malformed ({raw!r}); treating as dead"
    pid = int(raw)
    try:
        os.kill(pid, 0)  # liveness probe ONLY; signal 0 never terminates a process
    except ProcessLookupError:
        return True, f"lane {lane!r} pid {pid} not running (crashed; stale pid file)"
    except PermissionError:
        return False, f"lane {lane!r} pid {pid} owned by another user; refusing drain"
    return False, f"lane {lane!r} pid {pid} is ALIVE; refusing to drain a live lane"


def lane_active_task_lease(lane: str) -> str | None:
    """The task id lane ``lane`` currently claims, or None.

    cc-claim writes both a legacy ``cc-active-task-<lane>`` file and a
    session-keyed ``cc-active-task-<lane>-<uuid>`` file. Mutation-moment TOCTOU
    checks must treat either as an active lane claim because crash/reap paths can
    leave only the session-keyed file behind.
    """
    claims_dir = Path(os.environ.get("HAPAX_CC_CLAIMS_DIR", str(Path.home() / ".cache" / "hapax")))
    legacy = claims_dir / f"cc-active-task-{lane}"
    candidates = [legacy]
    candidates.extend(sorted(claims_dir.glob(f"cc-active-task-{lane}-*")))
    for claim in sorted(
        [path for path in candidates if path.is_file()],
        key=lambda path: path.stat().st_mtime,
        reverse=True,
    ):
        try:
            text = claim.read_text(encoding="utf-8").strip()
        except OSError:
            continue
        if text:
            return text
    return None


# --- Cross-role stale-claim sweeper (reform-identity-coherence, cluster 11) -----
# codex-claim-audit reaps phantom cx-*/codex-* claims and cc-claim's lease-expiry
# only frees a claim when the SAME role re-claims; nothing reaps a greek-slot /
# test-probe / role-less claim left by a dead or wedged lane (the 12-day
# council-eqi-phase0-run test-probe slot; the zeta dead-lane stale slot). This
# sweep closes that gap: it scans EVERY cc-active-task-* file and frees the dead
# ones independent of any role re-claiming.
_CLAIM_PREFIX = "cc-active-task-"
_UUID_SUFFIX_RE = re.compile(
    r"-[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
)
_TERMINAL_CLAIM_STATUSES = {"done", "completed", "closed", "withdrawn", "superseded"}
_UNASSIGNED_VALUES = {"", "null", "none", "~", "unassigned"}
DEFAULT_CLAIM_LEASE_TTL = 21600  # matches cc-claim's HAPAX_CLAIM_LEASE_TTL_SECS default


def _claim_role(filename: str) -> str:
    """The lane role from a cc-active-task-<role>[-<session_id>] filename."""
    return _UUID_SUFFIX_RE.sub("", filename[len(_CLAIM_PREFIX) :])


def _claim_task_dead_reason(task_id: str, active_dir: Path) -> str | None:
    """Reason the claim is dead, if the lane slot can be freed."""
    if not task_id:
        return "terminal-or-missing"
    note = active_dir / f"{task_id}.md"
    if not note.exists():
        variants = sorted(active_dir.glob(f"{task_id}-*.md"))
        if not variants:
            return "terminal-or-missing"
        note = variants[0]
    try:
        text = note.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return None  # unreadable -> do not reap on this basis
    fields, _body = parse_document_frontmatter(text)
    status = str(fields.get("status", "")).strip().strip("\"'").lower()
    assigned_to = str(fields.get("assigned_to", "")).strip().strip("\"'").lower()
    if status in _TERMINAL_CLAIM_STATUSES:
        return "terminal-or-missing"
    if status == "blocked" and assigned_to in _UNASSIGNED_VALUES:
        return "blocked-unassigned"
    return None


def sweep_stale_claims(
    claims_dir: Path,
    active_dir: Path,
    *,
    lease_ttl: int = DEFAULT_CLAIM_LEASE_TTL,
    grace_secs: int = 300,
    now: float | None = None,
) -> list[tuple[str, str, str]]:
    """Reap cc-active-task-* claim files across ALL roles. A file is reaped when its
    task is terminal/missing (and it has settled past ``grace_secs``, so a mid
    cc-close transition is not raced) or its lease has expired AND its role has no
    live sibling lease — a live role whose legacy file aged (the gate heartbeats
    only the session-keyed file) is preserved. Returns (filename, task_id, reason)."""
    now = time.time() if now is None else now
    try:
        files = sorted(p for p in claims_dir.glob(f"{_CLAIM_PREFIX}*") if p.is_file())
    except OSError:
        return []
    metas: list[tuple[Path, str, float, str]] = []
    freshest_by_role: dict[str, float] = {}
    for f in files:
        try:
            mtime = f.stat().st_mtime
            raw = f.read_text(encoding="utf-8", errors="ignore").strip()
        except OSError:
            continue
        task_id = raw.splitlines()[0].strip() if raw else ""
        role = _claim_role(f.name)
        freshest_by_role[role] = max(freshest_by_role.get(role, 0.0), mtime)
        metas.append((f, role, mtime, task_id))
    reaped: list[tuple[str, str, str]] = []
    for f, role, mtime, task_id in metas:
        age = now - mtime
        role_is_live = (now - freshest_by_role.get(role, 0.0)) <= lease_ttl
        dead_reason = _claim_task_dead_reason(task_id, active_dir)
        if dead_reason and age > grace_secs:
            reason = dead_reason
        elif age > lease_ttl and not role_is_live:
            reason = "lease-expired"
        else:
            continue
        try:
            f.unlink()
        except OSError:
            continue
        reaped.append((f.name, task_id, reason))
    return reaped


def run_claim_sweep(task_root: Path, *, notify: bool = True) -> list[tuple[str, str, str]]:
    """Wire the sweep to the live claims dir + vault, reap, and (best-effort) ntfy."""
    claims_dir = Path(os.environ.get("HAPAX_CC_CLAIMS_DIR", str(Path.home() / ".cache" / "hapax")))
    reaped = sweep_stale_claims(claims_dir, task_root / "active")
    if reaped and notify:
        try:
            from shared.notify import send_notification

            body = "\n".join(
                f"- {name} → {reason} ({task or '∅'})" for name, task, reason in reaped
            )
            send_notification(
                f"Reaped {len(reaped)} stale cc-task claim(s)",
                body,
                tags=["broom", "sdlc"],
            )
        except Exception:
            pass
    return reaped


def check_worktree_claim_guard(worktree: Path) -> tuple[bool, str]:
    script = worktree / "scripts" / "cc-claim"
    if not script.is_file():
        return False, f"missing cc-claim at {script}"
    text = script.read_text(encoding="utf-8", errors="replace")
    required = DISPATCH_CLAIM_GUARD_MARKERS
    missing = [needle for needle in required if needle not in text]
    if missing:
        return False, f"stale cc-claim in {worktree}: missing {', '.join(missing)}"
    return True, "worktree cc-claim authority/spec guard present"


def check_worktree_close_guard(worktree: Path) -> tuple[bool, str]:
    script = worktree / "scripts" / "cc-close"
    if not script.is_file():
        return False, f"missing cc-close at {script}"
    text = script.read_text(encoding="utf-8", errors="replace")
    required = DISPATCH_CLOSE_GUARD_MARKERS
    missing = [needle for needle in required if needle not in text]
    if missing:
        return False, f"stale cc-close in {worktree}: missing {', '.join(missing)}"
    return True, "worktree cc-close exact-duplicate guard present"


def check_worktree_cc_task_tool_guards(worktree: Path) -> tuple[bool, str]:
    claim_ok, claim_reason = check_worktree_claim_guard(worktree)
    if not claim_ok:
        return False, claim_reason
    close_ok, close_reason = check_worktree_close_guard(worktree)
    if not close_ok:
        return False, close_reason
    return True, f"{claim_reason}; {close_reason}"


def _relay_mq_db_path() -> Path:
    return Path(
        os.environ.get(
            "HAPAX_RELAY_MQ_DB",
            str(Path.home() / ".cache" / "hapax" / "relay" / "messages.db"),
        )
    ).expanduser()


def _parse_mq_datetime(raw: object) -> datetime | None:
    if raw is None:
        return None
    if not isinstance(raw, str) or not raw.strip():
        return None
    try:
        dt = datetime.fromisoformat(raw.replace("Z", "+00:00"))
    except ValueError:
        return None
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=UTC)
    return dt.astimezone(UTC)


def check_durable_dispatch_binding(
    *,
    task_id: str,
    lane: str,
    validation: Validation,
    message_id: str | None = None,
    db_path: Path | None = None,
) -> DurableDispatchBinding:
    if validation.exempt_read_only:
        return DurableDispatchBinding(True, False, "read_only_exempt")
    if validation.task is None:
        return DurableDispatchBinding(False, True, "task_missing")

    authority_case = strip_scalar(str(validation.task.fields.get("authority_case", "")))
    authority_item = strip_scalar(str(validation.task.fields.get("authority_item", "")))
    if is_nullish(authority_case):
        return DurableDispatchBinding(False, True, "authority_case_missing")

    db_path = db_path or _relay_mq_db_path()
    if not db_path.exists():
        return DurableDispatchBinding(False, True, "durable_mq_database_missing")

    recipient = lane.strip().lower().replace("_", "-")
    now = datetime.now(UTC)
    params: dict[str, object] = {
        "authority_case": authority_case,
        "recipient": recipient,
        "task_id": task_id,
        "authority_item": authority_item,
    }
    message_clause = ""
    if message_id:
        message_clause = "AND m.message_id = :message_id"
        params["message_id"] = message_id

    try:
        with sqlite3.connect(f"file:{db_path}?mode=ro", uri=True, timeout=1.0) as conn:
            conn.row_factory = sqlite3.Row
            conn.execute("PRAGMA query_only = ON")
            conn.execute("PRAGMA busy_timeout = 1000")
            rows = conn.execute(
                f"""
                SELECT m.message_id, m.authority_case, m.authority_item, m.subject,
                       m.stale_after, m.expires_at, r.recipient, r.state
                FROM messages m
                JOIN recipients r ON r.message_id = m.message_id
                WHERE m.message_type = 'dispatch'
                  AND m.authority_case = :authority_case
                  AND r.recipient = :recipient
                  {message_clause}
                  AND (
                      m.authority_item = :task_id
                      OR m.authority_item = :authority_item
                      OR m.subject = :task_id
                  )
                ORDER BY m.id DESC
                LIMIT 5
                """,
                params,
            ).fetchall()
    except sqlite3.Error as exc:
        return DurableDispatchBinding(False, True, f"durable_mq_unreadable:{exc}")

    if not rows:
        return DurableDispatchBinding(False, True, "durable_mq_authority_binding_missing")

    fallback_reason = "durable_mq_freshness_unknown"
    for row in rows:
        stale_after = _parse_mq_datetime(row["stale_after"])
        expires_at = _parse_mq_datetime(row["expires_at"])
        if stale_after is None or expires_at is None:
            fallback_reason = "durable_mq_freshness_unknown"
            continue
        if expires_at < now:
            fallback_reason = "durable_mq_dispatch_expired"
            continue
        if stale_after < now:
            fallback_reason = "durable_mq_dispatch_stale"
            continue
        return DurableDispatchBinding(
            True,
            False,
            "durable_mq_dispatch_bound",
            message_id=str(row["message_id"]),
        )
    return DurableDispatchBinding(False, True, fallback_reason)


def _system_drain_audit_path() -> Path:
    override = os.environ.get("HAPAX_SYSTEM_DRAIN_AUDIT")
    if override:
        return Path(override).expanduser()
    return Path.home() / ".cache" / "hapax" / "validate-task-system-drain.jsonl"


def _write_system_drain_audit(
    *, task_id: str, drained_from_lane: str, capability_id: str, liveness: str, prior_status: str
) -> None:
    """Append-only audit of every admitted system drain. Best-effort: an IO error
    never blocks a verified drain (the consume + audit chain is the authority trail)."""
    rec = {
        "ts": datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "task_id": task_id,
        "drained_from_lane": drained_from_lane,
        "prior_status": prior_status,
        "capability_id": capability_id,
        "liveness_verdict": liveness,
        "actor": SYSTEM_DRAIN_LANE,
    }
    path = _system_drain_audit_path()
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        with path.open("a", encoding="utf-8") as fh:
            fh.write(json.dumps(rec) + "\n")
    except OSError:
        pass


def _validate_system_drain(
    *,
    task: TaskNote,
    task_id: str,
    status: str,
    assigned_to: str,
    capability_path: Path | None,
) -> Validation:
    """Admit an orphaned task for SYSTEM drain IFF its owning lane is verifiably
    dead AND a single-use ``(task_id, __system__)`` capability verifies and consumes.

    Fail-closed at every step: a non-drainable status, no assigned lane, an
    unverifiable substrate lane, a LIVE lane, or an invalid/replayed capability all
    refuse the drain. Authority is auditable-single-use: the operator-provisioned
    0600 grant-key is the root of trust and the mint+consume+audit chain is the
    trail (see the task's open question on mint-authority separation, reviewer
    must-fix #4).
    """
    from shared.coord_event_log import default_grant_key
    from shared.governance.coord_capabilities import (
        DEFAULT_CONSUMPTION_LEDGER,
        CapabilityConsumptionLedger,
        read_capability_file,
        verify_dispatch_capability,
    )

    if status not in DRAINABLE_STATUSES:
        return Validation(False, f"system drain refused: status {status!r} not drainable", task)
    if is_nullish(assigned_to) or assigned_to == "unassigned":
        return Validation(False, "system drain refused: task has no assigned lane to verify", task)

    lane_name = normalize_lane_name(assigned_to)
    if lane_name not in KNOWN_CLAUDE_LANES:
        return Validation(
            False,
            f"system drain refused: assigned lane {assigned_to!r} is not a known "
            "claude-substrate lane; liveness unverifiable",
            task,
        )

    absent, why = lane_process_absent(lane_name)
    if not absent:
        return Validation(False, f"system drain refused: {why}", task)

    if capability_path is None:
        return Validation(False, "system drain requires --dispatch-capability <file>", task)
    cap = read_capability_file(capability_path)
    now = datetime.now(UTC).timestamp()
    try:
        key = default_grant_key().read_bytes()
    except OSError:
        return Validation(False, "system drain refused: signing key unavailable", task)
    if not verify_dispatch_capability(
        cap, key=key, now=now, task_id=task_id, lane=SYSTEM_DRAIN_LANE
    ):
        return Validation(
            False, "system drain refused: dispatch capability invalid/expired/mismatched", task
        )
    assert cap is not None  # verify_dispatch_capability returns False for None
    ledger_path = os.environ.get("HAPAX_COORD_CONSUMPTION_LEDGER") or DEFAULT_CONSUMPTION_LEDGER
    if not CapabilityConsumptionLedger(ledger_path).consume(cap.capability_id):
        return Validation(False, "system drain refused: capability already consumed (replay)", task)

    _write_system_drain_audit(
        task_id=task_id,
        drained_from_lane=lane_name,
        capability_id=cap.capability_id,
        liveness=why,
        prior_status=status,
    )
    return Validation(True, f"system-drain eligible ({why})", task, None, exempt_read_only=True)


def validate_task(
    *,
    task_id: str,
    lane: str,
    platform: str,
    task_root: Path,
    strict_worktree: bool,
    dispatch_capability_path: Path | None = None,
) -> Validation:
    task = read_task(task_root, task_id)
    if task is None:
        return Validation(False, f"task not found in {task_root / 'active'}")

    fields = task.fields
    status = strip_scalar(str(fields.get("status", "")))
    assigned_to = strip_scalar(str(fields.get("assigned_to", "")))

    # Capability-gated SYSTEM drain (dn-validate-task-relax). A narrow, additive
    # admit edge for the reserved __system__ actor; it short-circuits BEFORE the
    # legacy status gate, so every normal-lane decision stays byte-for-byte
    # unchanged (a normal lane attempting a pr_open task still gets the reject).
    if lane == SYSTEM_DRAIN_LANE:
        return _validate_system_drain(
            task=task,
            task_id=task_id,
            status=status,
            assigned_to=assigned_to,
            capability_path=dispatch_capability_path,
        )

    if status not in TASK_DISPATCHABLE_STATUSES:
        return Validation(False, f"task status {status!r} is not dispatchable", task)
    if status == "offered" and not (
        is_nullish(fields.get("assigned_to")) or assigned_to == "unassigned"
    ):
        return Validation(
            False,
            f"offered task assigned_to {assigned_to!r} is not claimable; "
            "target-lane routing belongs in dispatch, while task ownership "
            "must remain unassigned until cc-claim",
            task,
        )
    if status in {"claimed", "in_progress"} and assigned_to != lane:
        return Validation(
            False,
            f"task already assigned to {assigned_to!r}; claimed/in_progress "
            f"tasks may only be dispatched to assigned lane {lane!r}",
            task,
        )

    exempt = is_authority_exempt(fields)
    parent_spec_path = resolve_declared_path(
        fields.get("parent_spec"), base=Path.home() / "Documents" / "Personal"
    )
    if not exempt:
        missing = []
        if is_nullish(fields.get("authority_case")):
            missing.append("authority_case")
        if parent_spec_path is None:
            missing.append("parent_spec")
        if missing:
            return Validation(
                False,
                "missing required AuthorityCase/ISAP fields: " + ", ".join(missing),
                task,
                parent_spec_path,
                exempt,
            )
        if not parent_spec_path.is_file():
            return Validation(
                False, f"parent_spec does not exist: {parent_spec_path}", task, parent_spec_path
            )
        spec_fields = parse_frontmatter(parent_spec_path.read_text(encoding="utf-8"))
        spec_case = strip_scalar(str(spec_fields.get("case_id", "")))
        task_case = strip_scalar(str(fields.get("authority_case", "")))
        if spec_case and task_case and spec_case != task_case:
            return Validation(
                False,
                f"parent_spec case_id {spec_case!r} does not match task authority_case {task_case!r}",
                task,
                parent_spec_path,
                exempt,
            )

    if is_claude_operator_pool_lane(lane, platform):
        return Validation(
            False,
            f"lane {lane!r} is an interactive Claude operator pool, not a governed "
            "dispatch lane; use a supervised Claude lane or a Codex cx-* lane; "
            "recheck governed lane availability with: scripts/hapax-codex-health "
            "--json <cx-lane> for Codex lanes or scripts/hapax-claude-health "
            "--json <lane> for supervised Claude lanes; verify the target is not dev/devN",
            task,
            parent_spec_path,
            exempt,
        )

    if strict_worktree:
        ok, reason = check_worktree_cc_task_tool_guards(lane_worktree(lane, platform))
        if not ok:
            return Validation(False, reason, task, parent_spec_path, exempt)

    return Validation(True, "eligible", task, parent_spec_path, exempt)


def build_prompt(
    task_id: str,
    lane: str,
    platform: str,
    mode: str,
    profile: str,
    validation: Validation,
    route: PlatformPath,
) -> str:
    if lane == SYSTEM_DRAIN_LANE:
        raise ValueError(
            "__system__ is the drain sentinel, not a launchable lane; a system drain "
            "advances an orphaned task via cc-stage-advance, never a lane launch"
        )
    assert validation.task is not None
    fields = validation.task.fields
    authority_case = fields.get("authority_case")
    parent_spec = fields.get("parent_spec")
    title = fields.get("title")
    worktree = lane_worktree(lane, platform)
    claim_cmd = worktree / "scripts" / "cc-claim"
    close_cmd = worktree / "scripts" / "cc-close"
    claim_file = (
        Path(os.environ.get("HAPAX_CC_CLAIMS_DIR", str(Path.home() / ".cache" / "hapax")))
        / f"cc-active-task-{lane}"
    )
    claim_instruction = (
        "2. Before mutation, verify this lane owns the task claim. "
        f"If the task is still offered, run {claim_cmd} {task_id}. "
        f"If the launcher already claimed it, confirm {claim_file} contains {task_id} "
        "and the task note is assigned to this lane. "
        "If claim ownership is absent, rejected for another reason, or assigned to another lane, "
        "stop and write a relay receipt."
    )
    base = "\n".join(
        [
            "SDLC GOVERNED DISPATCH.",
            f"Lane: {lane}",
            f"Platform: {platform}",
            f"Mode: {mode}",
            f"Profile: {profile}",
            f"Platform path: {route.summary}",
            f"Capacity invariant: {CAPACITY_INVARIANT}",
            f"Task: {task_id}",
            f"Title: {strip_scalar(str(title or task_id))}",
            f"AuthorityCase: {strip_scalar(str(authority_case or 'read-only-exempt'))}",
            f"Parent spec: {strip_scalar(str(parent_spec or 'read-only-exempt'))}",
            f"Task note: {validation.task.path}",
            "",
            "Instructions:",
            f"1. Work only on task {task_id}.",
            claim_instruction
            if route.mutable
            else "2. This route is read-only. Do not mutate files, claims, PRs, services, or runtime state.",
            "3. Use only the authority and mutation scope in the parent spec.",
            "4. Do not create or claim another task from the pool.",
            "5. Do not select work from the pool. Do not continue after this task without a new dispatch.",
            f"6. Close this task only with {close_cmd}; do not use bare cc-close or canonical cc-close.",
            "7. If blocked, report the blocker and idle.",
            "8. Do not downgrade profile or platform unless quota, resource pressure, or explicit operator hold requires it and the resulting route remains quality-equivalent for this task.",
        ]
    )
    # Optional, fail-open HKP support context (projection, not authority). Never
    # blocks dispatch: any failure yields no section.
    try:
        from shared.hkp_prompt_context import context_for_task

        hkp = context_for_task(task_id)
    except Exception:  # noqa: BLE001 — HKP is optional support; never break dispatch
        hkp = ""
    if hkp:
        base += (
            "\n\nHKP support context (projection, NOT authority — advisory; verify "
            "against the cited source before acting):\n" + hkp
        )
    return base


def write_receipt(
    *,
    task_id: str,
    lane: str,
    platform: str,
    mode: str,
    profile: str,
    route: PlatformPath | None,
    validation: Validation,
    prompt: str | None,
    launched: bool,
    launch_returncode: int | None = None,
    route_decision: RouteDecision | None = None,
    route_decision_receipt_path: Path | None = None,
    durable_binding: DurableDispatchBinding | None = None,
    dispatch_launch: DispatchLaunchResult | None = None,
) -> Path:
    ledger_dir = orchestration_ledger_dir()
    ledger_dir.mkdir(parents=True, exist_ok=True)
    path = ledger_dir / "methodology-dispatch.jsonl"
    record: dict[str, Any] = {
        "schema_version": 1,
        "event": "methodology_dispatch",
        "timestamp": now_utc(),
        "task_id": task_id,
        "lane": lane,
        "platform": platform,
        "mode": mode,
        "profile": profile,
        "platform_path": route.launcher if route else None,
        "platform_path_summary": route.summary if route else None,
        "capacity_invariant": CAPACITY_INVARIANT,
        "ok": validation.ok,
        "reason": validation.reason,
        "task_path": str(validation.task.path) if validation.task else None,
        "parent_spec_path": str(validation.parent_spec_path)
        if validation.parent_spec_path
        else None,
        "exempt_read_only": validation.exempt_read_only,
        "launched": launched,
        "launch_returncode": launch_returncode,
        "prompt": prompt,
    }
    if durable_binding is not None:
        record["durable_mq_dispatch_bound"] = durable_binding.ok
        record["advisory_only"] = durable_binding.advisory_only
        record["durable_mq_reason"] = durable_binding.reason
        record["durable_mq_message_id"] = durable_binding.message_id
    if dispatch_launch is not None:
        record["coord_dispatch_idempotency_key"] = dispatch_launch.idempotency_key
        record["coord_dispatch_replayed"] = dispatch_launch.replayed
        record["coord_dispatch_reason"] = dispatch_launch.reason
        record["coord_dispatch_event_id"] = dispatch_launch.event_id
        record["coord_dispatch_cleanup_state"] = dispatch_launch.cleanup_state
    if route_decision is not None:
        record.update(route_decision_receipt_payload(route_decision))
        record["route_decision_receipt_path"] = (
            str(route_decision_receipt_path) if route_decision_receipt_path else None
        )
    record["dispatch_host"] = effective_dispatch_host(platform, mode)
    with path.open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(record, sort_keys=True) + "\n")
    return path


def slugify(value: str) -> str:
    chars = [ch if ch.isalnum() or ch in {"_", ".", "-"} else "-" for ch in value]
    slug = "".join(chars).strip("-")
    while "--" in slug:
        slug = slug.replace("--", "-")
    return slug or "item"


def _sliced_call(args: list[str], env: dict[str, str] | None = None) -> int:
    """subprocess.call that drops the launched lane — and its git/pytest/cargo
    grandchildren — into hapax-sdlc.slice (L1 attachment point b) when the fence
    is available. cpu.idle + the cpuset inherit to every descendant. No-op + run
    un-sliced when systemd-run/the slice is unavailable, so dispatch never fails
    on the fence."""
    base_env = dict(os.environ) if env is None else env
    if os.environ.get("PYTEST_CURRENT_TEST"):
        return subprocess.call(list(args), env=base_env)  # don't probe/create scopes in tests
    explicit_env = {
        key: value
        for key, value in base_env.items()
        if key.startswith(("HAPAX_", "CLAUDE_")) and os.environ.get(key) != value
    }
    explicit_env["HAPAX_SDLC_SLICE_ATTACHED"] = "1"
    wrapped = sdlc_slice_wrap(args, setenv=explicit_env)
    if wrapped != list(args):
        base_env = {**base_env, "HAPAX_SDLC_SLICE_ATTACHED": "1"}
    return subprocess.call(wrapped, env=base_env)


def effective_dispatch_host(platform: str, mode: str) -> str:
    explicit = os.environ.get("HAPAX_DISPATCH_HOST", "").strip()
    if explicit:
        return explicit
    default = os.environ.get("HAPAX_DEFAULT_DISPATCH_HOST", "").strip()
    if default:
        return default
    if platform in {"claude", "codex"} and mode == "headless":
        return "appendix"
    return "local"


def _write_delayed_receipt(args: argparse.Namespace, decision: AdmissionDecision) -> None:
    """Record that a dispatch is QUEUED (not refused) under CPU pressure."""
    try:
        ledger = orchestration_ledger_dir()
        ledger.mkdir(parents=True, exist_ok=True)
        (ledger / f"delayed-{slugify(args.lane)}-{slugify(args.task)}.json").write_text(
            json.dumps(
                {
                    "kind": "sdlc-pressure-delayed",
                    "task_id": args.task,
                    "lane": args.lane,
                    "platform": args.platform,
                    "mode": args.mode,
                    "profile": args.profile,
                    "admission_state": decision.state,
                    "reasons": decision.reasons,
                    "queued_not_dropped": True,
                    "ts": now_utc(),
                },
                indent=2,
            ),
            encoding="utf-8",
        )
    except OSError:
        pass  # a missing DELAYED receipt must never block the queued dispatch


def _await_sdlc_admission(args: argparse.Namespace) -> None:
    """L3 chokepoint: block-and-wait while CPU pressure has admission CLOSED.
    The dispatch is QUEUED then RUN — never skipped. Slows the fleet, drops
    nothing. Disabled via HAPAX_SDLC_PRESSURE_GATE_OFF; also never blocks a test
    process on the real host's pressure (the wait logic is unit-tested directly
    via wait_until_admitted)."""
    if env_flag("HAPAX_SDLC_PRESSURE_GATE_OFF") or os.environ.get("PYTEST_CURRENT_TEST"):
        return
    # Admit on the pressure of the host the work will RUN on — a dispatch bound
    # for appendix must never starve on podium PSI (2026-06-10: 4h silent queue).
    target = effective_dispatch_host(args.platform, args.mode)
    gate = functools.partial(admission_state, target_host=target)
    decision = gate()
    if decision.state != "closed":
        return
    print(
        f"sdlc-pressure CLOSED for target={target}: queuing dispatch of {args.task} "
        f"(resumes on clear) — {'; '.join(decision.reasons)}",
        file=sys.stderr,
    )
    final = wait_until_admitted(
        gate,
        sleep=time.sleep,
        on_delay=lambda decision: _write_delayed_receipt(args, decision),
        poll_interval=float(os.environ.get("HAPAX_SDLC_PRESSURE_POLL_S", "10")),
        max_wait_s=float(os.environ.get("HAPAX_SDLC_PRESSURE_MAX_WAIT_S", "1800")),
    )
    print(f"sdlc-pressure cleared ({final.state}): proceeding with {args.task}", file=sys.stderr)


# Worker-lane terminal-failure classification -> guarded family-availability witness
# (cc-task capability-adapter-worker-path-classify-failure). Best-effort + strictly FAIL-OPEN:
# classification NEVER changes the dispatch returncode or outcome. The guard, single-key write, and
# no-sibling-flip invariants live in shared.worker_failure_witness.
_WORKER_FAILURE_ADAPTERS: dict[str, type[WorkerAdapter]] = {
    "agy": AgyAdapter,
    "claude": ClaudeAdapter,
    "codex": CodexAdapter,
    "vibe": VibeAdapter,
}


def _capability_adapter_for_admission(platform: str) -> CapabilityAdapter:
    """Return the adapter used for the admission call.

    Worker platforms use the existing worker-adapter map. Non-worker routes still go through the
    final ``CapabilityAdapter.admit`` delegation so methodology dispatch no longer calls the policy
    spine directly.
    """

    adapter_cls = _WORKER_FAILURE_ADAPTERS.get(platform)
    if adapter_cls is not None:
        return adapter_cls()
    return CapabilityAdapter()


def _worker_adapter_for_launch(platform: str) -> WorkerAdapter:
    """Return the launch-capable adapter for ``platform`` or fail closed."""

    adapter_cls = _WORKER_FAILURE_ADAPTERS.get(platform)
    if adapter_cls is None:
        raise AuthorityViolation(
            f"launch not authorized for platform {platform}: no WorkerAdapter registered. "
            "Next: route mutable dispatch through a governed WorkerAdapter before attempting "
            "CapabilityAdapter.launch."
        )
    return adapter_cls()


def _read_worker_failure_text(platform: str, mode: str, lane: str) -> str:
    """Best-available worker error text. Claude headless writes a per-lane output.jsonl
    (LOG_DIR=~/.cache/hapax/claude-headless/<role>); read its tail so the adapter can classify the
    quota/auth/transient signature. Soft coupling — a missing/unreadable file yields '' (-> UNKNOWN,
    no witness), never an error."""

    if platform == "claude" and mode == "headless":
        out = Path.home() / ".cache" / "hapax" / "claude-headless" / lane / "output.jsonl"
        try:
            return "\n".join(out.read_text(encoding="utf-8").splitlines()[-50:])
        except OSError:
            return ""
    return ""


def _classify_and_witness_terminal_failure(
    rc: int, *, task_id: str, lane: str, platform: str, mode: str, profile: str
) -> None:
    """Append a classification receipt + a GUARDED family-availability witness for a terminal worker
    failure. Caller wraps this in try/except (fail-open)."""

    route_id = f"{platform}.{mode}.{profile}"
    text = _read_worker_failure_text(platform, mode, lane)
    adapter_cls = _WORKER_FAILURE_ADAPTERS.get(platform)
    if adapter_cls is not None:
        # Text-classifier adapters classify from the output text; exit_code remains
        # available for adapter-specific launch wrappers that need it.
        receipt = adapter_cls().classify_failure(
            text, process_failed=True, route_id=route_id, exit_code=rc
        )
    else:
        receipt = FailureReceipt(
            code=FailureCode.UNKNOWN, raw_signal=text, platform=platform, route_id=route_id
        )
    # The headless supervisor's quota-wall exit code is a high-confidence QUOTA signal even when the
    # output.jsonl tail did not capture the rate-limit line (fast terminal failure).
    code = FailureCode.QUOTA_EXHAUSTION if rc == QUOTA_WALL_EXIT_CODE else receipt.code
    if code is not receipt.code:
        receipt = receipt.model_copy(update={"code": code})
    now_iso = datetime.now(UTC).isoformat()
    append_failure_receipt_record(
        task_id=task_id, lane=lane, returncode=rc, receipt=receipt, now_iso=now_iso
    )
    update_worker_family_availability(family=platform, code=code, now_iso=now_iso)


def classify_and_witness_launch(
    launch_fn: Callable[[], int],
    *,
    task_id: str,
    lane: str,
    platform: str,
    mode: str,
    profile: str,
) -> int:
    """Run the worker spawn ``launch_fn``; on a TERMINAL failure (rc != 0) classify it + write the
    guarded family-availability witness. Strictly FAIL-OPEN — classification NEVER changes the
    returncode or the dispatch outcome (coord_dispatch still records the terminal event). Returns
    ``launch_fn``'s returncode verbatim. Module-level (not nested) so it is unit-testable."""

    rc = launch_fn()
    if rc != 0:
        try:
            _classify_and_witness_terminal_failure(
                rc,
                task_id=task_id,
                lane=lane,
                platform=platform,
                mode=mode,
                profile=profile,
            )
        except Exception:  # noqa: BLE001 — classification must never break dispatch
            pass
    return rc


#: Registry-declared model pin per claude dispatch profile — the launch-side half of the
#: CapabilityExecutionInvariant. Values are Claude Code ``--model`` aliases. Mirrors the
#: registry ExecutionDescriptors (claude.headless.full/opus -> claude-opus-4-8 => "opus";
#: claude.headless.sonnet -> claude-sonnet-* => "sonnet"; claude.headless.haiku => "haiku").
#: A profile absent here fails closed rather than inheriting the CLI default model.
CLAUDE_PROFILE_MODEL_PIN: dict[str, str] = {
    "full": "opus",
    "opus": "opus",
    "sonnet": "sonnet",
    "haiku": "haiku",
}


def launch_claude_headless(task_id: str, lane: str, prompt: str, route: PlatformPath) -> int:
    launcher = Path(
        os.environ.get(
            "HAPAX_METHODOLOGY_CLAUDE_HEADLESS",
            str(Path.home() / ".local" / "bin" / "hapax-claude-headless"),
        )
    )
    env = os.environ.copy()
    # Never propagate the dispatcher's own session id: each lane mints its own
    # per-spawn HAPAX_SESSION_ID so two same-role re-dispatched lanes never share a
    # claim key (reform-identity-coherence cluster 11, AC1).
    env.pop("HAPAX_SESSION_ID", None)
    # CapabilityExecutionInvariant drift guard (R0-pin): pin --model for EVERY claude
    # profile to its registry-declared model. Never let a profile inherit the Claude Code
    # CLI default (~/.claude/settings.json model=fable), which can silently drop fable->opus
    # under indeterminate conditions — an observed != sanctioned execution drift. `full`
    # declares claude-opus-4-8, so it pins "opus"; unknown profiles FAIL CLOSED rather than
    # inherit the default.
    pinned_model = CLAUDE_PROFILE_MODEL_PIN.get(route.profile)
    if pinned_model is None:
        print(
            f"claude profile '{route.profile}' has no declared model pin; refusing to launch "
            "(CEI drift guard — a launch must never inherit the CLI default model)",
            file=sys.stderr,
        )
        return 9
    env["HAPAX_CLAUDE_MODEL"] = pinned_model
    env["HAPAX_METHODOLOGY_DISPATCH_TASK"] = task_id
    env["HAPAX_CLAUDE_HEADLESS_WORKDIR"] = str(lane_worktree(lane, "claude"))
    env["HAPAX_DISPATCH_HOST"] = effective_dispatch_host("claude", "headless")
    return _sliced_call([str(launcher), "--task", task_id, lane, prompt], env)


def launch_claude_interactive(task_id: str, lane: str, validation: Validation) -> int:
    launcher = Path(
        os.environ.get(
            "HAPAX_METHODOLOGY_CLAUDE_LAUNCHER",
            str(Path(__file__).resolve().parent / "hapax-claude"),
        )
    )
    if not launcher.is_file():
        print(f"Claude launcher not found: {launcher}", file=sys.stderr)
        return 8

    status = ""
    if validation.task is not None:
        status = strip_scalar(str(validation.task.fields.get("status", "")))
    args = [str(launcher), "--role", lane, "--terminal", "tmux", "--task", task_id]
    # Always hand the lane a scrubbed env: drop any inherited HAPAX_SESSION_ID so it
    # mints its own per-spawn id (reform-identity-coherence cluster 11, AC1).
    # hapax-claude pins the freshly minted id into its tmux runner script.
    env = os.environ.copy()
    env.pop("HAPAX_SESSION_ID", None)
    if status in {"claimed", "in_progress"}:
        env["HAPAX_METHODOLOGY_DISPATCH_TASK"] = task_id
    return subprocess.call(args, env=env)


def normalize_profile(platform: str, profile: str) -> str:
    profile = profile.strip().lower().replace("_", "-")
    if platform == "api" and profile in {"api-frontier", "cloud", "cloud-burst", "frontier"}:
        return "api_frontier"
    if platform == "api" and profile in {"or", "open-router", "openrouter"}:
        return "openrouter"
    if platform == "api" and profile in {"provider-gateway", "gateway", "provider_spend"}:
        return "provider_gateway"
    if profile in {"default", "max", "pro", "full-capability"}:
        return "full"
    if profile == "quota-fallback":
        if platform == "claude":
            return "sonnet"
        if platform == "codex":
            return "spark"
    return profile


def route_for(platform: str, mode: str, profile: str) -> PlatformPath | None:
    normalized_profile = normalize_profile(platform, profile)
    if (platform, mode, normalized_profile) == (
        RECEIPT_ONLY_ROUTE.platform,
        RECEIPT_ONLY_ROUTE.mode,
        RECEIPT_ONLY_ROUTE.profile,
    ):
        return RECEIPT_ONLY_ROUTE
    return PLATFORM_PATHS.get((platform, mode, normalized_profile))


def _route_for_route_id(route_id: str) -> PlatformPath | None:
    parts = route_id.split(".", 2)
    if len(parts) != 3:
        return None
    return route_for(parts[0], parts[1], parts[2])


def _decision_selected_route_id(route_decision: RouteDecision) -> str:
    return (
        route_decision.dimensional_receipt.selected_route_id
        if route_decision.dimensional_receipt is not None
        else None
    ) or route_decision.route_id


def _decision_selected_route(route_decision: RouteDecision) -> PlatformPath | None:
    return _route_for_route_id(_decision_selected_route_id(route_decision))


def supported_route_lines() -> list[str]:
    lines = [CAPACITY_INVARIANT, ""]
    for _, route in sorted(PLATFORM_PATHS.items()):
        mutability = "mutable" if route.mutable else "read-only"
        lines.append(
            f"{route.platform}/{route.mode}/{route.profile}: {route.summary} "
            f"({mutability}) -> {route.launcher}"
        )
        lines.append(f"  {route.notes}")
    return lines


def platform_route_validation(
    route: PlatformPath | None, validation: Validation
) -> tuple[bool, str]:
    if route is None:
        return False, "unsupported platform/mode/profile route"
    if not route.mutable and not validation.exempt_read_only:
        return (
            False,
            f"{route.platform}/{route.mode}/{route.profile} is read-only; "
            "mutation tasks must route to a mutable platform profile",
        )
    return True, "eligible platform route"


def _availability_recomposition_candidate_requests(
    primary: DispatchRequest,
    *,
    task_fields: dict[str, Any],
    policy_sources: DispatchPolicySources,
    validation: Validation,
    rollback_mode: bool,
) -> tuple[DispatchRequest, ...] | None:
    capability = primary.capability
    if capability is None or not capability.availability_recomposition_required:
        return None
    registry = policy_sources.registry
    if registry is None:
        return ()

    candidates: list[DispatchRequest] = []
    for route_descriptor in sorted(registry.routes, key=lambda item: item.route_id):
        if route_descriptor.route_id == primary.route_id:
            continue
        platform = route_descriptor.platform.value
        mode = route_descriptor.mode.value
        profile = route_descriptor.profile.value
        route = route_for(platform, mode, profile)
        if route is None or not supports_route(platform, mode):
            continue
        if not route.mutable and not validation.exempt_read_only:
            continue
        candidates.append(
            build_dispatch_request(
                task_id=primary.task_id,
                lane=primary.lane,
                platform=platform,
                mode=mode,
                profile=profile,
                task_fields=task_fields,
                registry=registry,
                registry_error=policy_sources.registry_error,
                quota_ledger=policy_sources.quota_ledger,
                quota_error=policy_sources.quota_error,
                route_authority_receipts=policy_sources.route_authority_receipts,
                surface_delta_refs_by_route=policy_sources.surface_delta_refs_by_route,
                surface_delta_blockers_by_route=policy_sources.surface_delta_blockers_by_route,
                rollback_mode=rollback_mode,
                legacy_route_supported=True,
                legacy_route_mutable=route.mutable,
            )
        )
    return tuple(candidates)


def route_metadata_validation_reason(validation: Validation) -> str | None:
    assessment = assess_route_metadata(policy_task_fields(validation))
    if assessment.dispatchable:
        return None
    if (
        not route_envelope_gate_enforced()
        and not assessment.missing_fields
        and not assessment.validation_errors
    ):
        # SHADOW (HAPAX_ROUTE_ENVELOPE_GATE != enforce): a well-formed but non-dispatchable
        # derived envelope (hold-only) does not block dispatch; malformed/incomplete
        # metadata still blocks. The non-route admission stays observable.
        return None
    details = [
        *assessment.hold_reasons,
        *assessment.missing_fields,
        *assessment.validation_errors,
    ]
    detail_text = "; ".join(details) or assessment.status.value
    return f"route metadata not dispatchable: {detail_text}"


def env_flag(name: str) -> bool:
    return os.environ.get(name, "").strip().lower() in {"1", "true", "yes", "on"}


def optional_env_path(name: str) -> Path | None:
    value = os.environ.get(name, "").strip()
    return Path(value).expanduser() if value else None


def dispatch_message_id(cli_value: str | None) -> str | None:
    value = (cli_value or os.environ.get("HAPAX_METHODOLOGY_DISPATCH_MESSAGE_ID", "")).strip()
    return value or None


def coord_event_log_from_env() -> CoordEventLog:
    # Per-surface overrides still win (test isolation sets them explicitly); the
    # bare default is the single user-writable coord SSOT (coord_base_dir() →
    # ~/.cache/hapax/coord), NOT the dead root-owned /var/lib tree that uid 1000
    # could never mkdir — that default HARD-BLOCKED the launch coord write.
    base = coord_base_dir()
    return CoordEventLog(
        db_path=os.environ.get("HAPAX_COORD_LEDGER_DB", str(base / "ledger.db")),
        jsonl_path=os.environ.get("HAPAX_COORD_JSONL_MIRROR", str(base / "ledger.jsonl")),
        spool_dir=os.environ.get("HAPAX_COORD_SPOOL_DIR", str(base / "spool")),
    )


def orchestration_ledger_dir() -> Path:
    return Path(
        os.environ.get(
            "HAPAX_ORCHESTRATION_LEDGER_DIR",
            str(Path.home() / ".cache" / "hapax" / "orchestration"),
        )
    )


def policy_task_fields(validation: Validation) -> dict[str, Any]:
    if validation.task is None:
        return {}
    fields, _body = parse_document_frontmatter(validation.task.path)
    payload = dict(fields or validation.task.fields)
    payload["__task_note_path"] = str(validation.task.path)
    path_matches = operator_coupled_path_matches(payload)
    if path_matches:
        payload["__operator_coupled_path_matches"] = list(path_matches)
    return payload


def _emit_gate_event(
    route_decision: RouteDecision,
    policy_request: DispatchRequest,
    task_fields: dict[str, Any],
    *,
    gate_result: str,
) -> None:
    """Fail-safe: emit one observational GateEvent for the dispatch admission decision.

    KEYSTONE (cc-task-gate-event-producer-20260626). A gate-event write failure is logged
    and swallowed — the measurement is best-effort and must NEVER break dispatch.
    """
    try:
        route = route_decision.selected_descriptor_leaf or route_decision.route_id
        append_gate_event(
            build_gate_event(
                task_fields,
                route=route,
                demand_vector=policy_request.demand_vector,
                gate_result=gate_result,
            )
        )
    except Exception as exc:  # noqa: BLE001 - measurement must never break dispatch
        print(f"gate-event emit failed (non-fatal): {exc}", file=sys.stderr)


def launch_codex_headless(
    task_id: str,
    lane: str,
    prompt: str,
    validation: Validation,
    route: PlatformPath,
    *,
    reactivate_retired_relay: bool = False,
) -> int:
    # Genuine headless path (reform §6 P0): `codex exec` via hapax-codex-headless,
    # NOT a tmux pane. The tmux launcher (hapax-codex) remains the interactive
    # analog (launch_codex_interactive).
    launcher = Path(
        os.environ.get(
            "HAPAX_METHODOLOGY_CODEX_HEADLESS",
            str(Path(__file__).resolve().parent / "hapax-codex-headless"),
        )
    )
    if not launcher.is_file():
        print(f"Codex headless launcher not found: {launcher}", file=sys.stderr)
        return 8

    status = ""
    if validation.task is not None:
        status = strip_scalar(str(validation.task.fields.get("status", "")))
    args = [str(launcher), "--task", task_id]
    local_fallback_allowed = allow_codex_p0_local_dispatch_fallback(task_id, lane, validation)
    if reactivate_retired_relay or local_fallback_allowed:
        args.append("--force")
    if status in {"claimed", "in_progress"}:
        args.append("--no-claim")
    args.extend([lane, prompt])
    if route.profile == "spark":
        args.extend(
            [
                "--",
                "-c",
                'model="gpt-5.3-codex-spark"',
                "-c",
                'model_reasoning_effort="high"',
            ]
        )
    env = os.environ.copy()
    env["HAPAX_METHODOLOGY_DISPATCH_TASK"] = task_id
    env["HAPAX_DISPATCH_HOST"] = effective_dispatch_host("codex", "headless")
    if local_fallback_allowed:
        # Preserve a caller/operator-provided fallback value; the P0 drain rule
        # only supplies the default local fallback when the env is otherwise unset.
        env.setdefault("HAPAX_DISPATCH_HOST_FALLBACK", "local")
    return _sliced_call(args, env)


def launch_vibe_headless(task_id: str, lane: str, prompt: str, validation: Validation) -> int:
    launcher = Path(
        os.environ.get(
            "HAPAX_METHODOLOGY_VIBE_LAUNCHER",
            str(Path.home() / ".local" / "bin" / "hapax-vibe"),
        )
    )
    if not launcher.is_file():
        print(f"Vibe launcher not found: {launcher}", file=sys.stderr)
        return 8

    status = ""
    if validation.task is not None:
        status = strip_scalar(str(validation.task.fields.get("status", "")))
    args = [
        str(launcher),
        "--session",
        lane,
        "--terminal",
        "tmux",
        "--task",
        task_id,
        "--prompt",
        prompt,
        "--output",
        "streaming",
        "--force",
    ]
    if status in {"claimed", "in_progress"}:
        args.append("--no-claim")
    return _sliced_call(args)


def advance_task_stage(task_id: str, stage: str) -> int:
    """Perform the drain mutation: advance the orphan's stage via the canonical
    governed setter (scripts/cc-stage-advance). Returns its exit code (0 advanced /
    already-there; 2 refused; 3 not-found/IO). Forward-only — no --allow-backward."""
    script = Path(__file__).resolve().parent / "cc-stage-advance"
    return subprocess.call([sys.executable, str(script), task_id, stage])


def reverify_lane_dead_for_drain(lane: str, task_id: str) -> tuple[bool, str]:
    """Mutation-moment re-verification (TOCTOU / pid-reuse guard, reviewer must-fix #5).

    Liveness is re-read at the instant before the mutation and cross-checked against
    the active-task lease — not the bare pid captured at admission. A lane that
    respawned (a new live pid now in the file) or re-claimed a *different* task
    between admission and here is treated as live and the drain aborts. A recycled
    pid reads alive too, so it also aborts (fail-safe). Only a still-dead lane whose
    lease has not moved to other work proceeds.
    """
    absent, why = lane_process_absent(lane)
    if not absent:
        return False, f"lane respawned before mutation: {why}"
    lease = lane_active_task_lease(lane)
    if lease is not None and lease != task_id:
        return False, (
            f"lane {lane!r} re-claimed a different task {lease!r} before mutation; "
            "treating as live, drain aborted"
        )
    return True, why


def run_system_drain(args: argparse.Namespace, task_root: Path) -> int:
    """Capability-gated SYSTEM drain of an orphaned task whose owning lane is
    verifiably dead. This path NEVER reaches the normal launch ladder (reviewer
    must-fix #3): the ``__system__`` sentinel is not a launchable lane, so a phantom
    worktree can never be built. The actual drain is a real mutation — it advances
    the orphan's stage via cc-stage-advance once liveness + capability pass and a
    mutation-moment liveness re-check confirms the lane is still dead."""
    if not args.dispatch_capability:
        print("BLOCKED: system drain requires --dispatch-capability <file>", file=sys.stderr)
        return 10
    if not args.drain_to_stage:
        print("BLOCKED: system drain requires --drain-to-stage <stage>", file=sys.stderr)
        return 10

    validation = validate_task(
        task_id=args.task,
        lane=SYSTEM_DRAIN_LANE,
        platform=args.platform,
        task_root=task_root,
        strict_worktree=False,
        dispatch_capability_path=Path(args.dispatch_capability).expanduser(),
    )

    def _blocked_receipt(reason: str, *, rc: int | None = None) -> None:
        if args.no_receipt:
            return
        write_receipt(
            task_id=args.task,
            lane=SYSTEM_DRAIN_LANE,
            platform=args.platform,
            mode=args.mode,
            profile=args.profile,
            route=None,
            validation=Validation(
                False,
                reason,
                validation.task,
                validation.parent_spec_path,
                validation.exempt_read_only,
            ),
            prompt=None,
            launched=False,
            launch_returncode=rc,
        )

    if not validation.ok:
        _blocked_receipt(validation.reason)
        print(f"BLOCKED: {validation.reason}", file=sys.stderr)
        return 10

    assert validation.task is not None
    drained_lane = normalize_lane_name(str(validation.task.fields.get("assigned_to", "")))
    safe, why = reverify_lane_dead_for_drain(drained_lane, args.task)
    if not safe:
        reason = f"system drain aborted at mutation: {why}"
        _blocked_receipt(reason)
        print(f"BLOCKED: {reason}", file=sys.stderr)
        return 10

    rc = advance_task_stage(args.task, args.drain_to_stage)
    if rc != 0:
        reason = f"system drain cc-stage-advance failed (rc={rc})"
        _blocked_receipt(reason, rc=rc)
        print(f"BLOCKED: {reason}", file=sys.stderr)
        return 10

    if not args.no_receipt:
        write_receipt(
            task_id=args.task,
            lane=SYSTEM_DRAIN_LANE,
            platform=args.platform,
            mode=args.mode,
            profile=args.profile,
            route=None,
            validation=validation,
            prompt=None,
            launched=True,
            launch_returncode=rc,
        )
    print(f"system-drained: {args.task} ({drained_lane} dead) -> stage {args.drain_to_stage}")
    return 0


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--task", help="Explicit cc-task id to dispatch")
    parser.add_argument("--lane", help="Target lane, e.g. beta or cx-red")
    parser.add_argument(
        "--platform",
        default="claude",
        type=str.lower,
        choices=[
            "agy",
            "antigrav",
            "antigravity",
            "api",
            "claude",
            "codex",
            "gemini-cli",
            "vibe",
        ],
    )
    parser.add_argument(
        "--mode", default="headless", choices=["headless", "interactive", "receipt-only"]
    )
    parser.add_argument(
        "--profile",
        default="full",
        help=(
            "Capability profile. Use full by default; quota-fallback maps to "
            "the platform's constrained analogue when one exists. Codex also "
            "supports spark."
        ),
    )
    parser.add_argument("--launch", action="store_true", help="Launch after validation")
    parser.add_argument(
        "--list-platform-paths",
        action="store_true",
        help="List governed platform/mode/profile launch paths and exit",
    )
    parser.add_argument(
        "--capabilities",
        action="store_true",
        help="Print the Executor adapter capability registry as JSON and exit",
    )
    parser.add_argument(
        "--sweep-stale-claims",
        action="store_true",
        help="Reap lease-expired / terminal cc-task claim files across ALL lanes, then exit",
    )
    parser.add_argument(
        "--print-prompt", action="store_true", help="Print the governed launch prompt"
    )
    parser.add_argument(
        "--no-receipt", action="store_true", help="Do not append dispatch ledger receipt"
    )
    parser.add_argument(
        "--skip-worktree-check",
        action="store_true",
        help="Do not require target worktree cc-claim guard",
    )
    parser.add_argument(
        "--policy-rollback",
        action="store_true",
        help=(
            "DEPRECATED — rollback is retired (#3792). This flag is a no-op alias "
            "that now HOLDs all routes (policy_rollback_retired); a frontier route "
            "un-degrades only with a signed route-authority receipt. Mint one with "
            "scripts/hapax-mint-route-authority-receipt."
        ),
    )
    parser.add_argument(
        "--mq-message-id",
        help="Durable relay MQ dispatch message id to bind this governed dispatch to",
    )
    parser.add_argument(
        "--idempotency-key",
        help="Stable idempotency key for atomic bind/consume/launch replay",
    )
    parser.add_argument(
        "--dispatch-capability",
        help="Path to a single-use DispatchCapability file authorizing a SYSTEM drain "
        "(--lane __system__) of an orphaned task whose owning lane is verifiably dead.",
    )
    parser.add_argument(
        "--drain-to-stage",
        help="Target stage for a SYSTEM drain (--lane __system__); the orphaned task's "
        "stage is advanced here via cc-stage-advance once liveness + capability pass.",
    )
    args = parser.parse_args(argv)
    args.profile = normalize_profile(args.platform, args.profile)

    if args.list_platform_paths:
        print("\n".join(supported_route_lines()))
        return 0

    if args.capabilities:
        print(json.dumps(capabilities_payload(), indent=2))
        return 0

    if args.sweep_stale_claims:
        sweep_root = Path(
            os.environ.get(
                "HAPAX_CC_TASK_ROOT",
                str(Path.home() / "Documents" / "Personal" / "20-projects" / "hapax-cc-tasks"),
            )
        )
        reaped = run_claim_sweep(sweep_root)
        for name, task_id, reason in reaped:
            print(f"reaped {name} ({reason}: {task_id or '∅'})")
        print(f"cc-claim sweep: reaped {len(reaped)} stale claim(s)")
        return 0

    if not args.task or not args.lane:
        parser.error(
            "--task and --lane are required unless --list-platform-paths or --capabilities is used"
        )

    task_root = Path(
        os.environ.get(
            "HAPAX_CC_TASK_ROOT",
            str(Path.home() / "Documents" / "Personal" / "20-projects" / "hapax-cc-tasks"),
        )
    )

    # Opportunistic cross-role stale-claim sweep: every dispatch frees lease-expired
    # / terminal claims fleet-wide so a dead or wedged lane never parks a slot
    # indefinitely (reform-identity-coherence cluster 11). Best-effort — it must
    # never block a dispatch; opt out with HAPAX_DISPATCH_CLAIM_SWEEP=0.
    if os.environ.get("HAPAX_DISPATCH_CLAIM_SWEEP", "1") != "0":
        try:
            run_claim_sweep(task_root, notify=True)
        except Exception:
            pass

    if args.platform in {"antigrav", "antigravity", "gemini-cli"}:
        reason = (
            f"platform '{args.platform}' is retired/excised; do not dispatch it as live supply. "
            "Use admitted Claude, Codex, or Vibe routes. Agy adapter support is live, but a "
            "spawnable agy route still requires governed route/resource receipts before dispatch."
        )
        task_for_receipt = read_task(task_root, args.task)
        if not args.no_receipt:
            write_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=None,
                validation=Validation(False, reason, task_for_receipt),
                prompt=None,
                launched=False,
            )
        print(f"BLOCKED: {reason}", file=sys.stderr)
        return 10

    # SYSTEM drain is a distinct, capability-gated mutation path — it advances an
    # orphaned dead-lane task via cc-stage-advance and returns. It must intercept
    # BEFORE route_for/build_prompt/the launch ladder so the __system__ sentinel can
    # never resolve to a phantom lane worktree (reviewer must-fix #3).
    if strip_scalar(args.lane) == SYSTEM_DRAIN_LANE:
        return run_system_drain(args, task_root)

    validation = validate_task(
        task_id=args.task,
        lane=args.lane,
        platform=args.platform,
        task_root=task_root,
        strict_worktree=not args.skip_worktree_check,
    )
    route = route_for(args.platform, args.mode, args.profile)
    prompt: str | None = None

    if not validation.ok:
        if not args.no_receipt:
            write_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=route,
                validation=validation,
                prompt=prompt,
                launched=False,
            )
        print(f"BLOCKED: {validation.reason}", file=sys.stderr)
        return 10

    if args.mode == "receipt-only":
        ok, reason = platform_route_validation(route, validation)
        if ok:
            metadata_reason = route_metadata_validation_reason(validation)
            if metadata_reason is not None:
                ok = False
                reason = metadata_reason
        if not ok:
            blocked = Validation(
                False,
                reason,
                validation.task,
                validation.parent_spec_path,
                validation.exempt_read_only,
            )
            if not args.no_receipt:
                write_receipt(
                    task_id=args.task,
                    lane=args.lane,
                    platform=args.platform,
                    mode=args.mode,
                    profile=args.profile,
                    route=route,
                    validation=blocked,
                    prompt=None,
                    launched=False,
                )
            print(f"BLOCKED: {reason}", file=sys.stderr)
            if route is None:
                print("Supported governed routes:", file=sys.stderr)
                print("\n".join(supported_route_lines()), file=sys.stderr)
            return 10
        assert route is not None
        if args.launch:
            reason = "receipt-only mode does not launch lanes"
            blocked = Validation(
                False,
                reason,
                validation.task,
                validation.parent_spec_path,
                validation.exempt_read_only,
            )
            if not args.no_receipt:
                write_receipt(
                    task_id=args.task,
                    lane=args.lane,
                    platform=args.platform,
                    mode=args.mode,
                    profile=args.profile,
                    route=route,
                    validation=blocked,
                    prompt=None,
                    launched=False,
                )
            print(f"BLOCKED: {reason}", file=sys.stderr)
            return 10

        prompt = build_prompt(
            args.task,
            args.lane,
            args.platform,
            args.mode,
            args.profile,
            validation,
            route,
        )
        if args.print_prompt:
            print(prompt)
        if not args.no_receipt:
            write_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=route,
                validation=validation,
                prompt=prompt,
                launched=False,
            )
        print(f"eligible: {args.task} -> {args.platform}/{args.mode}/{args.profile}/{args.lane}")
        return 0

    policy_sources = load_dispatch_policy_sources(
        registry_path=optional_env_path("HAPAX_PLATFORM_CAPABILITY_REGISTRY"),
        quota_ledger_path=optional_env_path("HAPAX_QUOTA_SPEND_LEDGER"),
    )
    task_fields = policy_task_fields(validation)
    rollback_mode = args.policy_rollback or env_flag("HAPAX_DISPATCH_POLICY_ROLLBACK")
    policy_request = build_dispatch_request(
        task_id=args.task,
        lane=args.lane,
        platform=args.platform,
        mode=args.mode,
        profile=args.profile,
        task_fields=task_fields,
        registry=policy_sources.registry,
        registry_error=policy_sources.registry_error,
        quota_ledger=policy_sources.quota_ledger,
        quota_error=policy_sources.quota_error,
        route_authority_receipts=policy_sources.route_authority_receipts,
        surface_delta_refs_by_route=policy_sources.surface_delta_refs_by_route,
        surface_delta_blockers_by_route=policy_sources.surface_delta_blockers_by_route,
        rollback_mode=rollback_mode,
        legacy_route_supported=route is not None,
        legacy_route_mutable=route.mutable if route else False,
    )
    candidate_requests = _availability_recomposition_candidate_requests(
        policy_request,
        task_fields=task_fields,
        policy_sources=policy_sources,
        validation=validation,
        rollback_mode=rollback_mode,
    )
    adapter = _capability_adapter_for_admission(args.platform)
    route_decision = adapter.admit(policy_request, candidate_requests=candidate_requests)
    route_decision_receipt_path = write_route_decision_receipt(
        route_decision,
        ledger_dir=orchestration_ledger_dir(),
    )

    if route_decision.action is not DispatchAction.LAUNCH:
        _emit_gate_event(route_decision, policy_request, task_fields, gate_result="reject")
        route_reason = f"route policy {route_decision.action.value}: {route_decision.message}"
        blocked = Validation(
            False,
            route_reason,
            validation.task,
            validation.parent_spec_path,
            validation.exempt_read_only,
        )
        if not args.no_receipt:
            write_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=route,
                validation=blocked,
                prompt=None,
                launched=False,
                route_decision=route_decision,
                route_decision_receipt_path=route_decision_receipt_path,
            )
        print(f"BLOCKED: {route_reason}", file=sys.stderr)
        if route is None:
            print("Supported governed routes:", file=sys.stderr)
            print("\n".join(supported_route_lines()), file=sys.stderr)
        return 10

    selected_route = _decision_selected_route(route_decision)
    if selected_route is None:
        unsupported_route_id = _decision_selected_route_id(route_decision)
        reason = (
            f"route policy selected unsupported route: {unsupported_route_id}; "
            "next action: inspect dimensional_selected_route_id in the route decision receipt "
            "and either add a matching governed PLATFORM_PATHS launcher entry or constrain "
            "the candidate set to supported governed routes."
        )
        blocked = Validation(
            False,
            reason,
            validation.task,
            validation.parent_spec_path,
            validation.exempt_read_only,
        )
        if not args.no_receipt:
            write_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=route,
                validation=blocked,
                prompt=None,
                launched=False,
                route_decision=route_decision,
                route_decision_receipt_path=route_decision_receipt_path,
            )
        print(f"BLOCKED: {reason}", file=sys.stderr)
        print("Supported governed routes:", file=sys.stderr)
        print("\n".join(supported_route_lines()), file=sys.stderr)
        return 10
    route = selected_route
    args.platform = route.platform
    args.mode = route.mode
    args.profile = route.profile
    _emit_gate_event(route_decision, policy_request, task_fields, gate_result="accept")
    mq_message_id = dispatch_message_id(args.mq_message_id)
    if args.launch and route.mutable and not validation.exempt_read_only and mq_message_id is None:
        durable_binding = DurableDispatchBinding(
            False,
            True,
            "strict_mq_message_id_required",
        )
    else:
        durable_binding = check_durable_dispatch_binding(
            task_id=args.task,
            lane=args.lane,
            validation=validation,
            message_id=mq_message_id,
        )
    if not durable_binding.ok and args.launch:
        reason = f"durable MQ authority binding required: {durable_binding.reason}"
        blocked = Validation(
            False,
            reason,
            validation.task,
            validation.parent_spec_path,
            validation.exempt_read_only,
        )
        if not args.no_receipt:
            write_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=route,
                validation=blocked,
                prompt=None,
                launched=False,
                route_decision=route_decision,
                route_decision_receipt_path=route_decision_receipt_path,
                durable_binding=durable_binding,
            )
        print(f"BLOCKED: {reason}", file=sys.stderr)
        return 10

    prompt = build_prompt(
        args.task,
        args.lane,
        args.platform,
        args.mode,
        args.profile,
        validation,
        route,
    )

    if args.print_prompt:
        if durable_binding.advisory_only:
            print(f"ADVISORY_ONLY: {durable_binding.reason}")
        print(prompt)

    if args.launch:
        # L3 SDLC pressure admission gate — block-and-wait (QUEUE, never skip)
        # while the box is under sustained CPU pressure, then proceed. The fleet
        # slows; no dispatch is dropped.
        _await_sdlc_admission(args)

        # Launchable (platform, mode) -> adapter call. Eligibility is decided by
        # the Executor capability registry (supports_route), NOT a hard if-ladder
        # (reform §6 P1) — adding a runtime/mode is a one-line table + registry edit.
        reactivate_retired_codex_relay = allow_codex_governed_relay_reactivation(
            route=route,
            route_decision=route_decision,
            durable_binding=durable_binding,
            validation=validation,
        )
        launchers: dict[tuple[str, str], Any] = {
            ("claude", "headless"): lambda: launch_claude_headless(
                args.task, args.lane, prompt or "", route
            ),
            ("claude", "interactive"): lambda: launch_claude_interactive(
                args.task, args.lane, validation
            ),
            ("codex", "headless"): lambda: launch_codex_headless(
                args.task,
                args.lane,
                prompt or "",
                validation,
                route,
                reactivate_retired_relay=reactivate_retired_codex_relay,
            ),
            ("vibe", "headless"): lambda: launch_vibe_headless(
                args.task, args.lane, prompt or "", validation
            ),
        }

        def run_platform_launch() -> int:
            launch = launchers.get((args.platform, args.mode))
            if launch is None or not supports_route(args.platform, args.mode):
                caps = capabilities(args.platform)
                print(
                    "launch unsupported for "
                    f"--platform {args.platform} --mode {args.mode} --profile {args.profile}",
                    file=sys.stderr,
                )
                if caps is not None:
                    print(
                        f"  {args.platform} capabilities: modes={list(caps.modes)} "
                        f"mutates={caps.mutates} hooks_wired={caps.hooks_wired} "
                        f"headless={caps.headless}",
                        file=sys.stderr,
                    )
                print("Supported governed routes:", file=sys.stderr)
                print("\n".join(supported_route_lines()), file=sys.stderr)
                return 2
            return launch()

        dispatch_launch: DispatchLaunchResult | None = None
        if route.mutable and not validation.exempt_read_only:
            assert validation.task is not None
            assert mq_message_id is not None
            fields = validation.task.fields
            try:
                launch_adapter = _worker_adapter_for_launch(args.platform)
                dispatch_launch = launch_adapter.launch(
                    decision=route_decision,
                    request=DispatchLaunchRequest(
                        task_id=args.task,
                        lane=args.lane,
                        platform=args.platform,
                        mode=args.mode,
                        profile=args.profile,
                        authority_case=strip_scalar(str(fields.get("authority_case", ""))),
                        authority_item=strip_scalar(str(fields.get("authority_item", ""))),
                        parent_spec=strip_scalar(str(fields.get("parent_spec", ""))),
                        message_id=mq_message_id,
                        mq_db_path=_relay_mq_db_path(),
                        event_log=coord_event_log_from_env(),
                        idempotency_key=args.idempotency_key,
                        reactivate_retired=reactivate_retired_codex_relay,
                    ),
                    launch_callable=functools.partial(
                        classify_and_witness_launch,
                        run_platform_launch,
                        task_id=args.task,
                        lane=args.lane,
                        platform=args.platform,
                        mode=args.mode,
                        profile=args.profile,
                    ),
                )
                rc = dispatch_launch.launch_returncode
            except AuthorityViolation as exc:
                reason = f"capability adapter launch refused: {exc}"
                blocked = Validation(
                    False,
                    reason,
                    validation.task,
                    validation.parent_spec_path,
                    validation.exempt_read_only,
                )
                if not args.no_receipt:
                    write_receipt(
                        task_id=args.task,
                        lane=args.lane,
                        platform=args.platform,
                        mode=args.mode,
                        profile=args.profile,
                        route=route,
                        validation=blocked,
                        prompt=prompt,
                        launched=False,
                        route_decision=route_decision,
                        route_decision_receipt_path=route_decision_receipt_path,
                        durable_binding=durable_binding,
                    )
                print(f"BLOCKED: {reason}", file=sys.stderr)
                return 10
            except CoordDispatchError as exc:
                reason = f"atomic dispatch launch failed: {exc.reason}"
                blocked = Validation(
                    False,
                    reason,
                    validation.task,
                    validation.parent_spec_path,
                    validation.exempt_read_only,
                )
                if not args.no_receipt:
                    write_receipt(
                        task_id=args.task,
                        lane=args.lane,
                        platform=args.platform,
                        mode=args.mode,
                        profile=args.profile,
                        route=route,
                        validation=blocked,
                        prompt=prompt,
                        launched=False,
                        route_decision=route_decision,
                        route_decision_receipt_path=route_decision_receipt_path,
                        durable_binding=durable_binding,
                    )
                print(f"BLOCKED: {reason}", file=sys.stderr)
                return 10
        else:
            rc = run_platform_launch()

        if not args.no_receipt:
            write_receipt(
                task_id=args.task,
                lane=args.lane,
                platform=args.platform,
                mode=args.mode,
                profile=args.profile,
                route=route,
                validation=validation,
                prompt=prompt,
                launched=rc == 0,
                launch_returncode=rc,
                route_decision=route_decision,
                route_decision_receipt_path=route_decision_receipt_path,
                durable_binding=durable_binding,
                dispatch_launch=dispatch_launch,
            )
        return rc

    if not args.no_receipt:
        write_receipt(
            task_id=args.task,
            lane=args.lane,
            platform=args.platform,
            mode=args.mode,
            profile=args.profile,
            route=route,
            validation=validation,
            prompt=prompt,
            launched=False,
            route_decision=route_decision,
            route_decision_receipt_path=route_decision_receipt_path,
            durable_binding=durable_binding,
        )

    if durable_binding.advisory_only:
        print(f"advisory_only: {durable_binding.reason}")
    print(f"eligible: {args.task} -> {args.platform}/{args.mode}/{args.profile}/{args.lane}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
