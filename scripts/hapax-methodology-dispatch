def _hold_for_admitted_lifecycle_action(operation: str) -> int:
    repair = (
        "materialize and consume the exact admitted lifecycle action through the "
        "Gate-0 spine before retrying; legacy effect ingress is disabled"
    )
    print(
        f"HOLD: {ADMITTED_LIFECYCLE_ACTION_REQUIRED}; operation={operation}; repair={repair}",
        file=sys.stderr,
    )
    return 10


