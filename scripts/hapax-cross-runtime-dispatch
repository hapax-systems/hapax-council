#!/usr/bin/bash
# hapax-cross-runtime-dispatch - thin cross-runtime entrypoint for methodology dispatch.
#
# Task-bearing requests have no local policy or effect path. They are tail-delegated
# to the sanctioned methodology dispatcher, which owns admission, receipts, and
# runtime actuation. The list/check modes below are read-only observations only.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
[[ "$SCRIPT_PATH" == /* ]] || SCRIPT_PATH="$PWD/$SCRIPT_PATH"
SCRIPT_DIR="$(cd -P -- "${SCRIPT_PATH%/*}" && printf '%s\n' "$PWD")"
REPO_ROOT="$(cd -P -- "$SCRIPT_DIR/.." && printf '%s\n' "$PWD")"

REGISTRY_DIR="${HAPAX_TEAM_REGISTRY_DIR:-$HOME/.cache/hapax/team-registry}"
PROTECTION_FILE="${HAPAX_SESSION_PROTECTION:-$HOME/.cache/hapax/relay/session-protection.md}"

usage() {
    /usr/bin/cat <<'USAGE'
hapax-cross-runtime-dispatch - delegate cross-runtime requests to methodology dispatch

Task-bearing options:
  --lane LANE          Target lane (for example beta, cx-red, vbe-1)
  --platform PLATFORM  Target platform (passed to methodology dispatch)
  --task TASK_ID       Explicit cc-task to dispatch
  --mode MODE          Methodology mode: headless|interactive|receipt-only
  --runtime-mode MODE  Alias for --mode
  --profile PROFILE    Methodology capability profile
  --mq-message-id ID   Durable relay MQ dispatch message id
  --policy-rollback    Forward the methodology rollback request
  --dry-run            Request methodology receipt-only evaluation

Read-only options:
  --list-eligible      List observed dispatch candidates without mutation
  --check-lane LANE    Show freshness and protection observations without mutation
  -h, --help           Show this help
USAGE
}

hold() {
    printf 'HOLD: %s\n' "$*" >&2
    exit 10
}

require_value() {
    local option="$1" value="${2-}"
    if [[ -z "$value" ]]; then
        printf 'error: %s requires a value\n' "$option" >&2
        exit 2
    fi
}

check_lane_freshness() {
    local lane="$1"
    local meta_file="$REGISTRY_DIR/${lane}.json"

    if [[ ! -f "$meta_file" ]]; then
        printf 'UNKNOWN: no metadata for lane %s\n' "$lane"
        return 1
    fi

    /usr/bin/python3 -I - "$meta_file" <<'PY'
import json
import sys
import time

with open(sys.argv[1], encoding="utf-8") as stream:
    metadata = json.load(stream)

try:
    age = time.time() - float(metadata.get("last_probe_utc", 0))
    ttl = float(metadata.get("freshness_ttl_s", 3600))
except (TypeError, ValueError):
    print("UNKNOWN: malformed freshness metadata")
    raise SystemExit(1)

if age > ttl:
    print(f"STALE: {age:.0f}s old (ttl={ttl:.0f}s)")
    raise SystemExit(1)

print(f"FRESH: {age:.0f}s old (ttl={ttl:.0f}s)")
PY
}

check_protection() {
    local lane="$1"
    if [[ -f "$PROTECTION_FILE" ]] \
        && /usr/bin/grep -q "\`${lane}\`.*protected" "$PROTECTION_FILE" 2>/dev/null; then
        printf 'PROTECTED: lane %s is protected\n' "$lane"
        return 1
    fi
    printf 'OK: lane %s not protected\n' "$lane"
}

is_observed_worker_platform() {
    local platform="${1,,}"
    [[ "$platform" == "claude" \
        || "$platform" == "claude-code" \
        || "$platform" == "codex" \
        || "$platform" == "vibe" ]]
}

LANE=""
PLATFORM=""
TASK=""
RUNTIME_MODE="headless"
PROFILE="full"
MQ_MESSAGE_ID=""
POLICY_ROLLBACK=false
DRY_RUN=false
LIST_ELIGIBLE=false
CHECK_LANE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --lane)
            require_value "$1" "${2-}"
            LANE="$2"
            shift 2
            ;;
        --platform)
            require_value "$1" "${2-}"
            PLATFORM="$2"
            shift 2
            ;;
        --task)
            require_value "$1" "${2-}"
            TASK="$2"
            shift 2
            ;;
        --mode|--runtime-mode|--methodology-mode)
            require_value "$1" "${2-}"
            RUNTIME_MODE="$2"
            shift 2
            ;;
        --profile)
            require_value "$1" "${2-}"
            PROFILE="$2"
            shift 2
            ;;
        --mq-message-id)
            require_value "$1" "${2-}"
            MQ_MESSAGE_ID="$2"
            shift 2
            ;;
        --policy-rollback)
            POLICY_ROLLBACK=true
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --list-eligible)
            LIST_ELIGIBLE=true
            shift
            ;;
        --check-lane)
            require_value "$1" "${2-}"
            CHECK_LANE="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            printf 'error: unknown argument: %s\n' "$1" >&2
            exit 2
            ;;
    esac
done

if $LIST_ELIGIBLE; then
    printf '=== Eligible dispatch lanes ===\n'
    for meta_file in "$REGISTRY_DIR"/*.json; do
        [[ -f "$meta_file" ]] || continue
        lane="$(basename "$meta_file" .json)"
        platform="$(/usr/bin/python3 -I - "$meta_file" <<'PY'
import json
import sys

with open(sys.argv[1], encoding="utf-8") as stream:
    print(json.load(stream).get("platform", "?"))
PY
)" || platform="?"
        if ! is_observed_worker_platform "$platform"; then
            continue
        fi
        freshness="$(check_lane_freshness "$lane" 2>&1)" || true
        protection="$(check_protection "$lane" 2>&1)" || true
        status="unknown"
        [[ "$freshness" == FRESH* ]] && status="eligible"
        [[ "$freshness" == STALE* ]] && status="stale"
        [[ "$protection" == PROTECTED* ]] && status="protected"
        printf '  %-12s %-12s %-8s  %s\n' "$lane" "$platform" "$status" "$freshness"
    done
    exit 0
fi

if [[ -n "$CHECK_LANE" ]]; then
    printf '=== Lane check: %s ===\n' "$CHECK_LANE"
    check_lane_freshness "$CHECK_LANE" 2>&1 || true
    check_protection "$CHECK_LANE" 2>&1 || true
    exit 0
fi

# Structural preconditions are the wrapper's entire task-bearing behavior. All
# policy, authority, state, receipt, and effect decisions belong downstream.
[[ -n "$TASK" ]] || hold "task_required: task-bearing dispatch requires --task"
[[ -n "$LANE" ]] || hold "lane_required: task-bearing dispatch requires --lane"
[[ -n "$PLATFORM" ]] || hold "platform_required: task-bearing dispatch requires --platform"

METHODOLOGY_DISPATCH="$SCRIPT_DIR/hapax-methodology-dispatch"
[[ -f "$METHODOLOGY_DISPATCH" && -x "$METHODOLOGY_DISPATCH" && ! -L "$METHODOLOGY_DISPATCH" ]] \
    || hold "methodology_dispatch_unavailable: exact repository dispatcher unavailable at $METHODOLOGY_DISPATCH"

PLATFORM="${PLATFORM,,}"
if $DRY_RUN; then
    RUNTIME_MODE="receipt-only"
fi

DELEGATE_ARGS=(
    --task "$TASK"
    --lane "$LANE"
    --platform "$PLATFORM"
    --mode "$RUNTIME_MODE"
    --profile "$PROFILE"
)
if [[ "$RUNTIME_MODE" != "receipt-only" ]]; then
    DELEGATE_ARGS+=(--launch)
fi
if [[ -n "$MQ_MESSAGE_ID" ]]; then
    DELEGATE_ARGS+=(--mq-message-id "$MQ_MESSAGE_ID")
fi
if $POLICY_ROLLBACK; then
    DELEGATE_ARGS+=(--policy-rollback)
fi

PROJECT_PYTHON="$REPO_ROOT/.venv/bin/python"
[[ -f "$PROJECT_PYTHON" && -x "$PROJECT_PYTHON" ]] \
    || hold "methodology_runtime_unavailable: pinned interpreter unavailable at $PROJECT_PYTHON"
unset PYTHONPATH PYTHONHOME
exec "$PROJECT_PYTHON" -I "$METHODOLOGY_DISPATCH" "${DELEGATE_ARGS[@]}"
