{
  "name": "Chromakey Lift",
  "description": "Chromatic-key lineage (1/2): chroma_key + color_map creates a color-replaced overlay aesthetic — keyed regions become palette-mapped surfaces. Lineage: chromatic-key.",
  "lineage": "chromatic-key",
  "transition_ms": 1500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.12,
        "saturation": 1.25,
        "hue_rotate": 0
      }
    },
    "chroma_key_lift": {
      "type": "chroma_key",
      "params": {
        "key_color": "green",
        "tolerance": 0.3,
        "edge_softness": 0.06
      }
    },
    "color_map_replace": {
      "type": "color_map",
      "params": {
        "amount": 0.6,
        "palette": "warm"
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "intensity": 0.32,
        "radius": 0.72
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
}
