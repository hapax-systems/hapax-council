{
  "name": "Chromakey Lift",
  "description": "Chromatic-key lineage (1/2): chroma_key + color_map creates a color-replaced overlay aesthetic \u2014 keyed regions become palette-mapped surfaces. Lineage: chromatic-key.",
  "lineage": "chromatic-key",
  "transition_ms": 1500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.12,
        "saturation": 1.25,
        "hue_rotate": 0
      }
    },
    "chroma_key_lift": {
      "type": "chroma_key",
      "params": {
        "tolerance": 0.3,
        "softness": 0.06
      }
    },
    "color_map_replace": {
      "type": "color_map",
      "params": {
        "blend": 0.6
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.32,
        "radius": 0.72
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "posterize_subtle": {
      "type": "posterize",
      "params": {
        "levels": 8
      }
    }
  },
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "node": "vignette",
      "param": "radius",
      "source": "audio_beat",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.4
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "colorgrade"
    }
  ],
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "posterize_subtle"
    ],
    [
      "posterize_subtle",
      "chroma_key_lift:a"
    ],
    [
      "colorgrade",
      "chroma_key_lift:b"
    ],
    [
      "chroma_key_lift",
      "color_map_replace"
    ],
    [
      "color_map_replace",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ]
}
