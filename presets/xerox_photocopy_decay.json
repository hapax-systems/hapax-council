{
  "name": "Xerox Photocopy Decay",
  "description": "Xerox-degraded lineage (1/2): heavy threshold + grain + posterize creates a degenerated-photocopy aesthetic \u2014 image becomes 17th-generation copy of itself. Lineage: xerox-degraded.",
  "lineage": "xerox-degraded",
  "transition_ms": 1300,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.92,
        "contrast": 1.55,
        "saturation": 0.05,
        "hue_rotate": 0
      }
    },
    "threshold_xerox": {
      "type": "threshold",
      "params": {
        "level": 0.35,
        "softness": 0.15
      }
    },
    "grain_xerox": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.45
      }
    },
    "posterize_xerox": {
      "type": "posterize",
      "params": {
        "levels": 3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "threshold_xerox"
    ],
    [
      "threshold_xerox",
      "grain_xerox"
    ],
    [
      "grain_xerox",
      "posterize_xerox"
    ],
    [
      "posterize_xerox",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": []
}
