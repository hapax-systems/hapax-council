{
  "name": "Xerox Photocopy Decay",
  "description": "Xerox-degraded lineage (1/2): heavy threshold + grain + posterize creates a degenerated-photocopy aesthetic — image becomes 17th-generation copy of itself. Lineage: xerox-degraded.",
  "lineage": "xerox-degraded",
  "transition_ms": 1300,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.92,
        "contrast": 1.55,
        "saturation": 0.05,
        "hue_rotate": 0
      }
    },
    "threshold_xerox": {
      "type": "threshold",
      "params": {
        "threshold": 0.55,
        "smoothness": 0.05
      }
    },
    "grain_xerox": {
      "type": "grain_bump",
      "params": {
        "amount": 0.45,
        "scale": 600
      }
    },
    "posterize_xerox": {
      "type": "posterize",
      "params": {
        "levels": 3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
}
