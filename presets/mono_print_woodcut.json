{
  "name": "Mono Print Woodcut",
  "description": "Monochrome-print lineage (1/2): high-contrast threshold + heavy halftone + sharpen creates a woodcut/linocut printmaking aesthetic. Lineage: monochrome-print.",
  "lineage": "monochrome-print",
  "transition_ms": 1300,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.92,
        "contrast": 1.7,
        "saturation": 0.0,
        "hue_rotate": 0
      }
    },
    "threshold_woodcut": {
      "type": "threshold",
      "params": {
        "level": 0.45,
        "softness": 0.04
      }
    },
    "halftone_coarse": {
      "type": "halftone",
      "params": {
        "dot_size": 0.018
      }
    },
    "sharpen_edge": {
      "type": "sharpen",
      "params": {
        "amount": 0.55
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "threshold_woodcut"
    ],
    [
      "threshold_woodcut",
      "halftone_coarse"
    ],
    [
      "halftone_coarse",
      "sharpen_edge"
    ],
    [
      "sharpen_edge",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "brightness",
      "source": "audio_rms",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.6
    }
  ]
}