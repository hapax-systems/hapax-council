{
  "name": "Cellular Reaction",
  "description": "Organic-cellular lineage (1/2): reaction_diffusion + voronoi_overlay creates a Turing-pattern / cellular-automaton biological aesthetic. The image becomes a substrate for self-organising chemistry. Lineage: organic-cellular.",
  "lineage": "organic-cellular",
  "transition_ms": 3200,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.08,
        "saturation": 1.15,
        "hue_rotate": -6
      }
    },
    "reaction": {
      "type": "reaction_diffusion",
      "params": {
        "feed_rate": 0.058,
        "kill_rate": 0.062
      }
    },
    "voronoi_cells": {
      "type": "voronoi_overlay",
      "params": {
        "cell_count": 0.05,
        "edge_width": 0.3,
        "animation_speed": 0.12
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "reaction"
    ],
    [
      "reaction",
      "voronoi_cells"
    ],
    [
      "voronoi_cells",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "brightness",
      "source": "audio_rms",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.6
    }
  ]
}