{
  "name": "Chromakey Luma Split",
  "description": "Chromatic-key lineage (2/2): luma_key + invert at low intensity + color_map creates luminance-isolated chromatic-split aesthetic \u2014 bright regions get color-mapped while dark regions invert. Lineage: chromatic-key.",
  "lineage": "chromatic-key",
  "transition_ms": 1700,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.98,
        "contrast": 1.18,
        "saturation": 1.22,
        "hue_rotate": -2
      }
    },
    "luma_key_split": {
      "type": "luma_key",
      "params": {
        "threshold": 0.55,
        "softness": 0.12
      }
    },
    "color_map_luma": {
      "type": "color_map",
      "params": {
        "amount": 0.55,
        "palette": "cool"
      }
    },
    "invert_dark": {
      "type": "invert",
      "params": {
        "amount": 0.32
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "modulations": [],
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "luma_key_split:a"
    ],
    [
      "colorgrade",
      "luma_key_split:b"
    ],
    [
      "luma_key_split",
      "color_map_luma"
    ],
    [
      "color_map_luma",
      "invert_dark"
    ],
    [
      "invert_dark",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ]
}
