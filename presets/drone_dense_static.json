{
  "name": "Drone Dense Static",
  "description": "Drone-noise-static lineage (2/2): denser noise + grain + posterize at low levels creates a wall-of-sound visual aesthetic. Heavier than drone_static_drift. Lineage: drone-noise-static.",
  "lineage": "drone-noise-static",
  "transition_ms": 5000,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.85,
        "contrast": 1.12,
        "saturation": 0.55,
        "hue_rotate": 0
      }
    },
    "noise_dense": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.42,
        "animated": 1.0
      }
    },
    "grain_dense": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.4
      }
    },
    "posterize_drone": {
      "type": "posterize",
      "params": {
        "levels": 6
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "noise_dense"
    ],
    [
      "noise_dense",
      "grain_dense"
    ],
    [
      "grain_dense",
      "posterize_drone"
    ],
    [
      "posterize_drone",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "node": "noise_dense",
      "param": "hue_rotate",
      "source": "audio_energy",
      "scale": 30.0,
      "offset": 0.0,
      "smoothing": 0.5
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "colorgrade"
    }
  ]
}
