{
  "name": "Drone Dense Static",
  "description": "Drone-noise-static lineage (2/2): denser noise + grain + posterize at low levels creates a wall-of-sound visual aesthetic. Heavier than drone_static_drift. Lineage: drone-noise-static.",
  "lineage": "drone-noise-static",
  "transition_ms": 5000,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.85,
        "contrast": 1.12,
        "saturation": 0.55,
        "hue_rotate": 0
      }
    },
    "noise_dense": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.42,
        "scale": 1100,
        "speed": 0.08
      }
    },
    "grain_dense": {
      "type": "grain_bump",
      "params": {
        "amount": 0.4,
        "scale": 850
      }
    },
    "posterize_drone": {
      "type": "posterize",
      "params": {
        "levels": 6
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
}
