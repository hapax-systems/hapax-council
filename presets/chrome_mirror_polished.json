{
  "name": "Chrome Mirror Polished",
  "description": "Chrome-mirror lineage (1/2): heavy mirror + chromatic_aberration + bloom creates a polished-chrome surface aesthetic — image becomes reflective metal. Lineage: chrome-mirror.",
  "lineage": "chrome-mirror",
  "transition_ms": 1800,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.08,
        "contrast": 1.22,
        "saturation": 1.12,
        "hue_rotate": -6
      }
    },
    "mirror_chrome": {
      "type": "mirror",
      "params": {
        "axis": "vertical",
        "amount": 0.45
      }
    },
    "chroma_chrome": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 4,
        "offset_y": 2
      }
    },
    "bloom_chrome": {
      "type": "bloom",
      "params": {
        "intensity": 0.42,
        "threshold": 0.55,
        "radius": 0.14
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
}
