{
  "name": "Heartbeat",
  "description": "Breathing and drift",
  "transition_ms": 500,
  "nodes": {
    "breathing": {
      "type": "drift",
      "params": {
        "speed": 1.0,
        "amplitude": 2,
        "frequency": 0.3,
        "coherence": 0.6
      }
    },
    "drift": {
      "type": "drift",
      "params": {
        "speed": 0.3,
        "amplitude": 8
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.4,
        "radius": 10,
        "alpha": 0.25
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.9,
        "contrast": 1.0,
        "saturation": 1.0
      }
    },
    "posterize": {
      "type": "posterize",
      "params": {
        "levels": 3,
        "gamma": 1.0
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "posterize"
    ],
    [
      "posterize",
      "breathing"
    ],
    [
      "breathing",
      "drift"
    ],
    [
      "drift",
      "bloom"
    ],
    [
      "bloom",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "breathing"
    },
    {
      "source": "audio_beat",
      "param": "chromatic_aberration",
      "scale": 0.5,
      "offset": 0.0,
      "attack": 0.05,
      "decay": 0.6,
      "node": "breathing"
    }
  ]
}
