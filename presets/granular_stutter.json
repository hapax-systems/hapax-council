{
  "name": "Granular Stutter",
  "description": "Granular-loop lineage (1/2): rapid stutter + slitscan creates fragmented temporal patterns \u2014 the visual twin of granular synthesis at small grain sizes. Lineage: granular-loop.",
  "lineage": "granular-loop",
  "transition_ms": 700,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.06,
        "contrast": 1.14,
        "saturation": 1.05,
        "hue_rotate": 2
      }
    },
    "stutter_rapid": {
      "type": "stutter",
      "params": {
        "freeze_chance": 0.18,
        "replay_frames": 1
      }
    },
    "slitscan_thin": {
      "type": "slitscan",
      "params": {
        "speed": 0.14,
        "direction": 24
      }
    },
    "displacement_grain": {
      "type": "displacement_map",
      "params": {
        "strength_x": 0.08,
        "strength_y": 0.35
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "modulations": [],
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "stutter_rapid"
    ],
    [
      "stutter_rapid",
      "slitscan_thin"
    ],
    [
      "slitscan_thin",
      "displacement_grain:a"
    ],
    [
      "slitscan_thin",
      "displacement_grain:b"
    ],
    [
      "displacement_grain",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ]
}
