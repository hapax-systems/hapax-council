{
  "name": "Tunnel Vision",
  "description": "Tunnel vision",
  "transition_ms": 500,
  "nodes": {
    "tunnel": {
      "type": "tunnel",
      "params": {
        "speed": 1.5,
        "twist": 0.4,
        "radius": 0.5
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.4,
        "radius": 10,
        "alpha": 0.3
      }
    },
    "chroma": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "tunnel"
    ],
    [
      "tunnel",
      "bloom"
    ],
    [
      "bloom",
      "chroma"
    ],
    [
      "chroma",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "tunnel",
      "param": "speed",
      "source": "audio_rms",
      "scale": 2,
      "offset": 0.5,
      "smoothing": 0.8
    },
    {
      "source": "audio_energy",
      "param": "displacement",
      "scale": 0.35,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.7,
      "node": "tunnel"
    },
    {
      "source": "audio_beat",
      "param": "chromatic_aberration",
      "scale": 0.5,
      "offset": 0.0,
      "attack": 0.05,
      "decay": 0.6,
      "node": "tunnel"
    }
  ]
}
