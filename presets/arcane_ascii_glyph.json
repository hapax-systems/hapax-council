{
  "name": "Arcane ASCII Glyph",
  "description": "Arcane-glyph lineage (1/2): ASCII conversion + heavy dither \u2014 text-as-image aesthetic where every pixel becomes character. Lineage: arcane-glyph. Distinct from existing 'ascii_preset' by lower-density baseline + edge-detect overlay.",
  "lineage": "arcane-glyph",
  "transition_ms": 1100,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.98,
        "contrast": 1.32,
        "saturation": 0.4,
        "hue_rotate": 0
      }
    },
    "ascii_glyph": {
      "type": "ascii",
      "params": {
        "cell_size": 0.02
      }
    },
    "dither_arcane": {
      "type": "dither",
      "params": {
        "color_levels": 0.32
      }
    },
    "edge_arcane": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.22
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "ascii_glyph"
    ],
    [
      "ascii_glyph",
      "dither_arcane"
    ],
    [
      "dither_arcane",
      "edge_arcane"
    ],
    [
      "edge_arcane",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    }
  ]
}