{
  "name": "Pixsort Glitch Vertical",
  "description": "Pixsort-glitch lineage (2/2): vertical pixsort + glitch_block + stutter \u2014 image collapses vertically along sorted luminance bands. Lineage: pixsort-glitch.",
  "lineage": "pixsort-glitch",
  "transition_ms": 1000,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.02,
        "contrast": 1.22,
        "saturation": 1.2,
        "hue_rotate": -4
      }
    },
    "pixsort_v": {
      "type": "pixsort",
      "params": {
        "direction": 1.0,
        "threshold_low": 0.42,
        "sort_length": 0.5
      }
    },
    "glitch_pixsort": {
      "type": "glitch_block",
      "params": {
        "intensity": 0.32,
        "rgb_split": 0.2,
        "block_size": 6
      }
    },
    "stutter_pixsort": {
      "type": "stutter",
      "params": {
        "freeze_chance": 0.06,
        "replay_frames": 2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "pixsort_v"
    ],
    [
      "pixsort_v",
      "glitch_pixsort"
    ],
    [
      "glitch_pixsort",
      "stutter_pixsort"
    ],
    [
      "stutter_pixsort",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "brightness",
      "source": "audio_rms",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.6
    }
  ]
}