{
  "name": "Arcane Dither Sigil",
  "description": "Arcane-glyph lineage (2/2): heavy dither + edge_detect + invert at low intensity creates a sigil-on-vellum aesthetic \u2014 image becomes ritual mark. Lineage: arcane-glyph.",
  "lineage": "arcane-glyph",
  "transition_ms": 1400,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.94,
        "contrast": 1.45,
        "saturation": 0.15,
        "hue_rotate": 0
      }
    },
    "dither_heavy": {
      "type": "dither",
      "params": {
        "color_levels": 0.55
      }
    },
    "edge_sigil": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.18
      }
    },
    "invert_partial": {
      "type": "invert",
      "params": {
        "strength": 0.28
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "dither_heavy"
    ],
    [
      "dither_heavy",
      "edge_sigil"
    ],
    [
      "edge_sigil",
      "invert_partial"
    ],
    [
      "invert_partial",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    }
  ]
}