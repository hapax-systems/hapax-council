{
  "name": "Night Vision",
  "description": "Gen 3 image intensifier",
  "transition_ms": 500,
  "nodes": {
    "nvtint": {
      "type": "nightvision_tint",
      "params": {
        "green_intensity": 0.9,
        "brightness": 3.0,
        "contrast": 1.6
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.1,
        "radius": 25,
        "alpha": 0.7
      }
    },
    "noise": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.15,
        "animated": true
      }
    },
    "mask": {
      "type": "circular_mask",
      "params": {
        "radius": 0.35,
        "softness": 0.04
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.4,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    ["@live", "nvtint"],
    ["nvtint", "bloom"],
    ["bloom", "noise"],
    ["noise", "mask"],
    ["mask", "content_layer"],
    ["content_layer", "postprocess"],
    ["postprocess", "out"]
  ],
  "modulations": [],
  "layer_palettes": {}
}
