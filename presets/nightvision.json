{
  "name": "Night Vision",
  "description": "Gen 3 image intensifier",
  "transition_ms": 500,
  "nodes": {
    "nvtint": {
      "type": "nightvision_tint",
      "params": {
        "green_intensity": 0.95,
        "brightness": 2.0,
        "contrast": 1.8
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.1,
        "radius": 15,
        "alpha": 0.5
      }
    },
    "noise": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.2,
        "animated": 1
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.2,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    [
      "@live",
      "nvtint"
    ],
    [
      "nvtint",
      "bloom"
    ],
    [
      "bloom",
      "noise"
    ],
    [
      "noise",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "noise",
      "param": "hue_rotate",
      "source": "audio_energy",
      "scale": 30.0,
      "offset": 0.0,
      "smoothing": 0.5
    },
    {
      "source": "audio_beat",
      "param": "chromatic_aberration",
      "scale": 0.5,
      "offset": 0.0,
      "attack": 0.05,
      "decay": 0.6,
      "node": "nvtint"
    },
    {
      "source": "audio_energy",
      "param": "saturation",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.75,
      "node": "nvtint"
    }
  ]
}
