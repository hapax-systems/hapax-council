{
  "name": "Vinyl Pop Static",
  "description": "Heavy vinyl-noise lineage: louder pops + scratches + occasional dropout via stutter. Lineage: vinyl-noise (2/4). Companion to vinyl_dust at higher intensity.",
  "lineage": "vinyl-noise",
  "transition_ms": 2200,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.92,
        "contrast": 1.12,
        "saturation": 0.78,
        "hue_rotate": 10
      }
    },
    "noise_static": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.32,
        "animated": 1.0
      }
    },
    "grain": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.34
      }
    },
    "stutter": {
      "type": "stutter",
      "params": {
        "freeze_chance": 0.04,
        "replay_frames": 1
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.45,
        "radius": 0.65
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "noise_static"
    ],
    [
      "noise_static",
      "grain"
    ],
    [
      "grain",
      "stutter"
    ],
    [
      "stutter",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "node": "vignette",
      "param": "radius",
      "source": "audio_beat",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.4
    },
    {
      "node": "noise_static",
      "param": "intensity",
      "source": "audio_energy",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.5
    }
  ]
}