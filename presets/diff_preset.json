{
  "name": "Motion Detection",
  "description": "Frame differencing \u2014 only motion is visible. Double-ghost contour with leading and trailing edges. Daniel Rozin Mechanical Mirrors reference.",
  "transition_ms": 500,
  "nodes": {
    "diff": {
      "type": "diff",
      "params": {
        "threshold": 0.06,
        "color_mode": 0
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "contrast": 1.2,
        "brightness": 1.2,
        "saturation": 0.9
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.15,
        "radius": 12,
        "alpha": 0.4
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.35,
        "sediment_strength": 0.05
      }
    },
    "posterize_subtle": {
      "type": "posterize",
      "params": {
        "levels": 8
      }
    }
  },
  "edges": [
    [
      "@live",
      "diff"
    ],
    [
      "diff",
      "colorgrade"
    ],
    [
      "colorgrade",
      "posterize_subtle"
    ],
    [
      "posterize_subtle",
      "bloom"
    ],
    [
      "bloom",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_energy",
      "param": "hue_rotate",
      "scale": 25.0,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.8,
      "node": "diff"
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "diff"
    }
  ]
}
