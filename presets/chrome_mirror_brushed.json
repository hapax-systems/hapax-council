{
  "name": "Chrome Mirror Brushed",
  "description": "Chrome-mirror lineage (2/2): mirror + slitscan at low frequency + emboss creates a brushed-aluminum mirror aesthetic. Lineage: chrome-mirror.",
  "lineage": "chrome-mirror",
  "transition_ms": 2000,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.04,
        "contrast": 1.18,
        "saturation": 0.85,
        "hue_rotate": -2
      }
    },
    "mirror_brushed": {
      "type": "mirror",
      "params": {
        "axis": "horizontal",
        "amount": 0.32
      }
    },
    "slitscan_brushed": {
      "type": "slitscan",
      "params": {
        "amount": 0.08,
        "frequency": 4
      }
    },
    "emboss_brushed": {
      "type": "emboss",
      "params": {
        "amount": 0.32,
        "angle": 90
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "mirror_brushed"
    ],
    [
      "mirror_brushed",
      "slitscan_brushed"
    ],
    [
      "slitscan_brushed",
      "emboss_brushed"
    ],
    [
      "emboss_brushed",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": []
}
