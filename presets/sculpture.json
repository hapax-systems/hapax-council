{
  "name": "Sculpture",
  "description": "Rutt-Etra wireframe terrain",
  "transition_ms": 500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.2,
        "contrast": 1.2,
        "saturation": 0.7
      }
    },
    "rutt_etra": {
      "type": "rutt_etra",
      "params": {
        "displacement": 40,
        "line_density": 5,
        "line_width": 3.0,
        "color_mode": 0.0
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.15,
        "radius": 12,
        "alpha": 0.4
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.2,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "rutt_etra"
    ],
    [
      "rutt_etra",
      "bloom"
    ],
    [
      "bloom",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "colorgrade"
    },
    {
      "source": "audio_beat",
      "param": "chromatic_aberration",
      "scale": 0.5,
      "offset": 0.0,
      "attack": 0.05,
      "decay": 0.6,
      "node": "colorgrade"
    }
  ]
}
