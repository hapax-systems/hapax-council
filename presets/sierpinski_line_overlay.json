{
  "name": "Sierpinski Line Overlay",
  "description": "Sierpinski lineage (2/2): sierpinski_lines + edge_detect creates a wireframe-sierpinski overlay aesthetic — geometric line architecture composited on the content. Lineage: sierpinski.",
  "lineage": "sierpinski",
  "transition_ms": 2000,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.22,
        "saturation": 0.85,
        "hue_rotate": 0
      }
    },
    "sierpinski_lines_main": {
      "type": "sierpinski_lines",
      "params": {
        "depth": 5,
        "thickness": 1.5
      }
    },
    "edge_sierpinski": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.18,
        "amount": 0.4
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
}
