{
  "name": "Sierpinski Line Overlay",
  "description": "Sierpinski lineage (2/2): sierpinski_lines + edge_detect creates a wireframe-sierpinski overlay aesthetic \u2014 geometric line architecture composited on the content. Lineage: sierpinski.",
  "lineage": "sierpinski",
  "transition_ms": 2000,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.22,
        "saturation": 0.85,
        "hue_rotate": 0
      }
    },
    "sierpinski_lines_main": {
      "type": "sierpinski_lines",
      "params": {
        "line_width": 1.5
      }
    },
    "edge_sierpinski": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.18
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "sierpinski_lines_main"
    ],
    [
      "sierpinski_lines_main",
      "edge_sierpinski"
    ],
    [
      "edge_sierpinski",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": []
}
