{
  "name": "Bloom Neon Night",
  "description": "Chromatic-bloom lineage (1/2): heavy bloom + saturated colorgrade + soft chromatic aberration creates neon-night-photography aesthetic. Lineage: chromatic-bloom.",
  "lineage": "chromatic-bloom",
  "transition_ms": 2400,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.12,
        "contrast": 1.18,
        "saturation": 1.45,
        "hue_rotate": -10
      }
    },
    "bloom_neon": {
      "type": "bloom",
      "params": {
        "alpha": 0.6,
        "threshold": 0.5,
        "radius": 0.18
      }
    },
    "chroma_soft": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 2,
        "offset_y": 1
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.42,
        "radius": 0.6
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "bloom_neon"
    ],
    [
      "bloom_neon",
      "chroma_soft"
    ],
    [
      "chroma_soft",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "brightness",
      "source": "audio_rms",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "node": "vignette",
      "param": "strength",
      "source": "audio_beat",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.4
    }
  ]
}