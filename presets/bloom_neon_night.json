{
  "name": "Bloom Neon Night",
  "description": "Chromatic-bloom lineage (1/2): heavy bloom + saturated colorgrade + soft chromatic aberration creates neon-night-photography aesthetic. Lineage: chromatic-bloom.",
  "lineage": "chromatic-bloom",
  "transition_ms": 2400,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.12,
        "contrast": 1.18,
        "saturation": 1.45,
        "hue_rotate": -10
      }
    },
    "bloom_neon": {
      "type": "bloom",
      "params": {
        "intensity": 0.6,
        "threshold": 0.5,
        "radius": 0.18
      }
    },
    "chroma_soft": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 2,
        "offset_y": 1
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "intensity": 0.42,
        "radius": 0.6
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
}
