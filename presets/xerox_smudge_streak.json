{
  "name": "Xerox Smudge Streak",
  "description": "Xerox-degraded lineage (2/2): displacement_map + threshold + slitscan creates ink-smudge / paper-jam-streak aesthetic. Lineage: xerox-degraded.",
  "lineage": "xerox-degraded",
  "transition_ms": 1500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.94,
        "contrast": 1.4,
        "saturation": 0.1,
        "hue_rotate": 0
      }
    },
    "displacement_smudge": {
      "type": "displacement_map",
      "params": {
        "strength_x": 0.18,
        "strength_y": 0.5
      }
    },
    "threshold_smudge": {
      "type": "threshold",
      "params": {
        "level": 0.5,
        "softness": 0.12
      }
    },
    "slitscan_streak": {
      "type": "slitscan",
      "params": {
        "speed": 0.16,
        "direction": 8
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "modulations": [
    {
      "node": "colorgrade",
      "param": "brightness",
      "source": "audio_rms",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.6
    }
  ],
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "displacement_smudge:a"
    ],
    [
      "colorgrade",
      "displacement_smudge:b"
    ],
    [
      "displacement_smudge",
      "threshold_smudge"
    ],
    [
      "threshold_smudge",
      "slitscan_streak"
    ],
    [
      "slitscan_streak",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ]
}