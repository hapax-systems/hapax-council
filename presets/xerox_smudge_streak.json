{
  "name": "Xerox Smudge Streak",
  "description": "Xerox-degraded lineage (2/2): displacement_map + threshold + slitscan creates ink-smudge / paper-jam-streak aesthetic. Lineage: xerox-degraded.",
  "lineage": "xerox-degraded",
  "transition_ms": 1500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.94,
        "contrast": 1.4,
        "saturation": 0.1,
        "hue_rotate": 0
      }
    },
    "displacement_smudge": {
      "type": "displacement_map",
      "params": {
        "amount": 0.18,
        "scale": 0.5
      }
    },
    "threshold_smudge": {
      "type": "threshold",
      "params": {
        "threshold": 0.5,
        "smoothness": 0.12
      }
    },
    "slitscan_streak": {
      "type": "slitscan",
      "params": {
        "amount": 0.16,
        "frequency": 8
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
}
