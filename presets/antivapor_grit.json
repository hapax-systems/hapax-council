{
  "name": "Antivapor Grit",
  "description": "Anti-vaporwave lineage (1/4): desaturated palette + high-contrast threshold + edge detection. Explicitly avoids the pink/teal vaporwave color signature. References gritty post-punk zine + early monochrome pen-and-ink aesthetics. Lineage: anti-vaporwave.",
  "lineage": "anti-vaporwave",
  "transition_ms": 1400,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.88,
        "contrast": 1.45,
        "saturation": 0.18,
        "hue_rotate": 0
      }
    },
    "edge": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.18
      }
    },
    "grain_grit": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.42
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.55,
        "radius": 0.6
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "edge"
    ],
    [
      "edge",
      "grain_grit"
    ],
    [
      "grain_grit",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "brightness",
      "source": "audio_rms",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "node": "vignette",
      "param": "strength",
      "source": "audio_beat",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.4
    },
    {
      "node": "grain_grit",
      "param": "intensity",
      "source": "audio_energy",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.5
    }
  ]
}