{
  "name": "Ambient",
  "description": "Warm atmospheric wash",
  "tags": [
    "atmospheric",
    "minimal"
  ],
  "transition_ms": 1000,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.85,
        "saturation": 0.85,
        "contrast": 0.7,
        "sepia": 0.2
      }
    },
    "drift": {
      "type": "drift",
      "params": {
        "speed": 0.4,
        "amplitude": 12,
        "frequency": 0.3,
        "coherence": 0.6
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.15,
        "radius": 25,
        "alpha": 0.5
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.4
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.0,
        "sediment_strength": 0.1
      }
    },
    "noise": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.12
      }
    },
    "posterize_subtle": {
      "type": "posterize",
      "params": {
        "levels": 8
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "posterize_subtle"
    ],
    [
      "posterize_subtle",
      "bloom"
    ],
    [
      "bloom",
      "drift"
    ],
    [
      "drift",
      "noise"
    ],
    [
      "noise",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "node": "vignette",
      "param": "radius",
      "source": "audio_beat",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.4
    },
    {
      "node": "noise",
      "param": "intensity",
      "source": "audio_energy",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.5
    }
  ]
}