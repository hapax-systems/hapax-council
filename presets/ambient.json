{
  "name": "Ambient",
  "description": "Warm atmospheric wash",
  "transition_ms": 1000,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.8,
        "saturation": 0.5,
        "contrast": 0.7,
        "sepia": 0.3
      }
    },
    "drift": {
      "type": "drift",
      "params": {
        "speed": 0.1,
        "amplitude": 3,
        "frequency": 0.5,
        "coherence": 0.8
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.15,
        "radius": 20,
        "alpha": 0.4
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.4
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    ["@live", "colorgrade"],
    ["colorgrade", "bloom"],
    ["bloom", "drift"],
    ["drift", "vignette"],
    ["vignette", "content_layer"],
    ["content_layer", "postprocess"],
    ["postprocess", "out"]
