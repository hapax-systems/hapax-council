{
  "name": "Liquid Flow Fluid",
  "description": "Liquid-flow lineage (1/2): fluid_sim + syrup distortion \u2014 organic, breath-driven motion that channels Bachelard amendments 7+8 (roundness/miniature) without the static intimacy of those amendments. Lineage: liquid-flow.",
  "lineage": "liquid-flow",
  "transition_ms": 3800,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.05,
        "saturation": 1.12,
        "hue_rotate": -4
      }
    },
    "fluid_motion": {
      "type": "fluid_sim",
      "params": {
        "viscosity": 0.6,
        "speed": 0.25,
        "amount": 0.32
      }
    },
    "syrup_thick": {
      "type": "syrup",
      "params": {}
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.3,
        "radius": 0.78
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "fluid_motion"
    ],
    [
      "fluid_motion",
      "syrup_thick"
    ],
    [
      "syrup_thick",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "brightness",
      "source": "audio_rms",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "node": "vignette",
      "param": "strength",
      "source": "audio_beat",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.4
    }
  ]
}