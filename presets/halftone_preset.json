{
  "name": "Halftone",
  "description": "Print dots",
  "transition_ms": 500,
  "nodes": {
    "halftone": {
      "type": "halftone",
      "params": {
        "dot_size": 8,
        "color_mode": 1
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.2,
        "contrast": 1.2,
        "saturation": 1.3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "halftone"
    ],
    [
      "halftone",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_energy",
      "param": "hue_rotate",
      "scale": 25.0,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.8,
      "node": "halftone"
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "halftone"
    }
  ]
}
