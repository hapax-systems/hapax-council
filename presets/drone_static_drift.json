{
  "name": "Drone Static Drift",
  "description": "Drone-noise-static lineage (1/2): sustained low-frequency noise + slow drift + heavy vignette creates drone-music visual aesthetic. Time stretches; nothing moves quickly. Lineage: drone-noise-static.",
  "lineage": "drone-noise-static",
  "transition_ms": 4500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.92,
        "contrast": 1.04,
        "saturation": 0.7,
        "hue_rotate": -2
      }
    },
    "noise_drone": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.18,
        "animated": 1.0
      }
    },
    "drift_drone": {
      "type": "drift",
      "params": {
        "amplitude": 0.008,
        "frequency": 0.03
      }
    },
    "vignette_heavy": {
      "type": "vignette",
      "params": {
        "strength": 0.45,
        "radius": 0.55
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "posterize_drone": {
      "type": "posterize",
      "params": {
        "levels": 7
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "posterize_drone"
    ],
    [
      "posterize_drone",
      "noise_drone"
    ],
    [
      "noise_drone",
      "drift_drone"
    ],
    [
      "drift_drone",
      "vignette_heavy"
    ],
    [
      "vignette_heavy",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "node": "noise_drone",
      "param": "hue_rotate",
      "source": "audio_energy",
      "scale": 30.0,
      "offset": 0.0,
      "smoothing": 0.5
    },
    {
      "source": "audio_beat",
      "param": "chromatic_aberration",
      "scale": 0.5,
      "offset": 0.0,
      "attack": 0.05,
      "decay": 0.6,
      "node": "colorgrade"
    }
  ]
}
