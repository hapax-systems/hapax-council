{
  "name": "Pixsort Glitch Horizontal",
  "description": "Pixsort-glitch lineage (1/2): pixsort + slitscan + chromatic_aberration creates a horizontal pixel-sort glitch \u2014 image breaks down by luminance bands. Lineage: pixsort-glitch.",
  "lineage": "pixsort-glitch",
  "transition_ms": 800,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.18,
        "saturation": 1.18,
        "hue_rotate": 0
      }
    },
    "pixsort_h": {
      "type": "pixsort",
      "params": {
        "direction": 0.0,
        "threshold_low": 0.3,
        "sort_length": 0.55
      }
    },
    "slitscan_h": {
      "type": "slitscan",
      "params": {
        "speed": 0.18,
        "direction": 12
      }
    },
    "chroma_pixsort": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 4,
        "offset_y": 2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "pixsort_h"
    ],
    [
      "pixsort_h",
      "slitscan_h"
    ],
    [
      "slitscan_h",
      "chroma_pixsort"
    ],
    [
      "chroma_pixsort",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    }
  ]
}