{
  "name": "Chamber Feedback Dense",
  "description": "Chamber-feedback lineage (1/2): heavy feedback + trail + echo creates a deep recursive feedback chamber \u2014 image trails into itself across many frames. Lineage: chamber-feedback.",
  "lineage": "chamber-feedback",
  "transition_ms": 3500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.96,
        "contrast": 1.08,
        "saturation": 1.18,
        "hue_rotate": -4
      }
    },
    "feedback_chamber": {
      "type": "feedback",
      "params": {
        "decay": 0.91
      }
    },
    "trail_chamber": {
      "type": "trail",
      "params": {
        "fade": 0.88,
        "opacity": 0.4
      }
    },
    "echo_chamber": {
      "type": "echo",
      "params": {
        "decay_curve": 0.42
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "posterize_subtle": {
      "type": "posterize",
      "params": {
        "levels": 8
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "posterize_subtle"
    ],
    [
      "posterize_subtle",
      "feedback_chamber"
    ],
    [
      "feedback_chamber",
      "trail_chamber"
    ],
    [
      "trail_chamber",
      "echo_chamber"
    ],
    [
      "echo_chamber",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_energy",
      "param": "displacement",
      "scale": 0.35,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.7,
      "node": "colorgrade"
    },
    {
      "source": "audio_beat",
      "param": "chromatic_aberration",
      "scale": 0.5,
      "offset": 0.0,
      "attack": 0.05,
      "decay": 0.6,
      "node": "colorgrade"
    }
  ]
}
