{
  "name": "Chamber Feedback Breathing",
  "description": "Chamber-feedback lineage (2/2): feedback + breathing + drift creates a respiratory feedback aesthetic \u2014 image inhales/exhales through delay loops. Lineage: chamber-feedback.",
  "lineage": "chamber-feedback",
  "transition_ms": 3800,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.06,
        "saturation": 1.22,
        "hue_rotate": 2
      }
    },
    "feedback_breath": {
      "type": "feedback",
      "params": {
        "decay": 0.93
      }
    },
    "breathing_chamber": {
      "type": "drift",
      "params": {
        "speed": 0.22,
        "amplitude": 9,
        "frequency": 0.3,
        "coherence": 0.6
      }
    },
    "drift_chamber": {
      "type": "drift",
      "params": {
        "amplitude": 0.014,
        "frequency": 0.12
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "posterize_subtle": {
      "type": "posterize",
      "params": {
        "levels": 8
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "posterize_subtle"
    ],
    [
      "posterize_subtle",
      "feedback_breath"
    ],
    [
      "feedback_breath",
      "breathing_chamber"
    ],
    [
      "breathing_chamber",
      "drift_chamber"
    ],
    [
      "drift_chamber",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_energy",
      "param": "hue_rotate",
      "scale": 25.0,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.8,
      "node": "colorgrade"
    },
    {
      "source": "audio_beat",
      "param": "chromatic_aberration",
      "scale": 0.5,
      "offset": 0.0,
      "attack": 0.05,
      "decay": 0.6,
      "node": "colorgrade"
    }
  ]
}
