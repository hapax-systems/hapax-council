{
  "name": "Broadcast Static Carrier",
  "description": "Broadcast-degraded lineage (2/2): vhs + noise_overlay + thermal-style colormap creates dead-channel static carrier aesthetic \u2014 broadcast at edge of signal. Lineage: broadcast-degraded.",
  "lineage": "broadcast-degraded",
  "transition_ms": 1800,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.88,
        "contrast": 1.22,
        "saturation": 0.85,
        "hue_rotate": -4
      }
    },
    "vhs_static": {
      "type": "vhs",
      "params": {
        "chroma_shift": 0.45,
        "noise_band_y": 0.42
      }
    },
    "noise_static": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.42,
        "animated": 1.0
      }
    },
    "thermal_carrier": {
      "type": "thermal",
      "params": {
        "intensity": 0.28,
        "palette": 2.0
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.5,
        "radius": 0.62
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "vhs_static"
    ],
    [
      "vhs_static",
      "noise_static"
    ],
    [
      "noise_static",
      "thermal_carrier"
    ],
    [
      "thermal_carrier",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": []
}
