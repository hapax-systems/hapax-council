{
  "name": "Kaleidoscope Dream",
  "description": "Kaleidoscope dream",
  "tags": [
    "rotation",
    "spiral",
    "geometric"
  ],
  "transition_ms": 500,
  "nodes": {
    "kaleidoscope": {
      "type": "kaleidoscope",
      "params": {
        "segments": 6,
        "rotation": 0
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.1,
        "contrast": 1.2,
        "saturation": 1.2
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.2,
        "radius": 15,
        "alpha": 0.4
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "kaleidoscope"
    ],
    [
      "kaleidoscope",
      "colorgrade"
    ],
    [
      "colorgrade",
      "bloom"
    ],
    [
      "bloom",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "kaleidoscope",
      "param": "rotation",
      "source": "audio_rms",
      "scale": 180,
      "offset": 0,
      "smoothing": 0.9
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "kaleidoscope"
    },
    {
      "source": "audio_beat",
      "param": "chromatic_aberration",
      "scale": 0.5,
      "offset": 0.0,
      "attack": 0.05,
      "decay": 0.6,
      "node": "kaleidoscope"
    }
  ]
}
