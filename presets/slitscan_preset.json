{
  "name": "Slit-scan",
  "description": "Temporal slit-scan \u2014 each column represents a different moment in time. Douglas Trumbull Stargate reference.",
  "transition_ms": 500,
  "nodes": {
    "slitscan": {
      "type": "slitscan",
      "params": {
        "speed": 0.4,
        "direction": 0
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.2,
        "contrast": 1.2,
        "saturation": 1.0
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.08
      }
    }
  },
  "edges": [
    [
      "@live",
      "slitscan"
    ],
    [
      "slitscan",
      "colorgrade"
    ],
    [
      "colorgrade",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "slitscan"
    },
    {
      "source": "audio_energy",
      "param": "hue_rotate",
      "scale": 25.0,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.8,
      "node": "slitscan"
    }
  ]
}
