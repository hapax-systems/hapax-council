{
  "name": "Antivapor Thresh",
  "description": "Anti-vaporwave lineage (2/4): pure threshold + halftone + monochrome posterize. Anti-aesthetic to vaporwave's pastel gradient nostalgia: stark binary contrast, no smooth tonality. Lineage: anti-vaporwave.",
  "lineage": "anti-vaporwave",
  "transition_ms": 1200,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.95,
        "contrast": 1.6,
        "saturation": 0.05,
        "hue_rotate": 0
      }
    },
    "threshold_bin": {
      "type": "threshold",
      "params": {
        "threshold": 0.5,
        "smoothness": 0.1
      }
    },
    "halftone_grid": {
      "type": "halftone",
      "params": {
        "scale": 0.012,
        "angle": 45
      }
    },
    "posterize_mono": {
      "type": "posterize",
      "params": {
        "levels": 3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
}
