{
  "name": "Antivapor Thresh",
  "description": "Anti-vaporwave lineage (2/4): pure threshold + halftone + monochrome posterize. Anti-aesthetic to vaporwave's pastel gradient nostalgia: stark binary contrast, no smooth tonality. Lineage: anti-vaporwave.",
  "lineage": "anti-vaporwave",
  "transition_ms": 1200,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.95,
        "contrast": 1.6,
        "saturation": 0.05,
        "hue_rotate": 0
      }
    },
    "threshold_bin": {
      "type": "threshold",
      "params": {
        "level": 0.5,
        "softness": 0.1
      }
    },
    "halftone_grid": {
      "type": "halftone",
      "params": {
        "dot_size": 0.012
      }
    },
    "posterize_mono": {
      "type": "posterize",
      "params": {
        "levels": 3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "threshold_bin"
    ],
    [
      "threshold_bin",
      "halftone_grid"
    ],
    [
      "halftone_grid",
      "posterize_mono"
    ],
    [
      "posterize_mono",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": []
}
