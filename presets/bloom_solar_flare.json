{
  "name": "Bloom Solar Flare",
  "description": "Chromatic-bloom lineage (2/2): heavier bloom + emboss-relief + warm color tilt \u2014 anamorphic-flare astrophotography aesthetic. Lineage: chromatic-bloom.",
  "lineage": "chromatic-bloom",
  "transition_ms": 2800,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.18,
        "contrast": 1.12,
        "saturation": 1.3,
        "hue_rotate": 8
      }
    },
    "bloom_intense": {
      "type": "bloom",
      "params": {
        "alpha": 0.85,
        "threshold": 0.4,
        "radius": 0.24
      }
    },
    "emboss_relief": {
      "type": "emboss",
      "params": {
        "strength": 0.15,
        "angle": 45
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.5,
        "radius": 0.55
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "bloom_intense"
    ],
    [
      "bloom_intense",
      "emboss_relief"
    ],
    [
      "emboss_relief",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "node": "vignette",
      "param": "radius",
      "source": "audio_beat",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.4
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "colorgrade"
    }
  ]
}
