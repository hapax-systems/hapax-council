{
  "name": "Mono Print Newsprint",
  "description": "Monochrome-print lineage (2/2): finer halftone + posterize at low levels + heavy grain creates newspaper-photo aesthetic. Subtler than woodcut. Lineage: monochrome-print.",
  "lineage": "monochrome-print",
  "transition_ms": 1500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.95,
        "contrast": 1.4,
        "saturation": 0.05,
        "hue_rotate": 0
      }
    },
    "halftone_fine": {
      "type": "halftone",
      "params": {
        "scale": 0.008,
        "angle": 45
      }
    },
    "posterize_print": {
      "type": "posterize",
      "params": {
        "levels": 5
      }
    },
    "grain_print": {
      "type": "grain_bump",
      "params": {
        "amount": 0.32,
        "scale": 700
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "intensity": 0.4,
        "radius": 0.7
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
}
