{
  "name": "Mono Print Newsprint",
  "description": "Monochrome-print lineage (2/2): finer halftone + posterize at low levels + heavy grain creates newspaper-photo aesthetic. Subtler than woodcut. Lineage: monochrome-print.",
  "lineage": "monochrome-print",
  "transition_ms": 1500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.95,
        "contrast": 1.4,
        "saturation": 0.05,
        "hue_rotate": 0
      }
    },
    "halftone_fine": {
      "type": "halftone",
      "params": {
        "dot_size": 0.014
      }
    },
    "posterize_print": {
      "type": "posterize",
      "params": {
        "levels": 5
      }
    },
    "grain_print": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.32
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.4,
        "radius": 0.7
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "halftone_fine"
    ],
    [
      "halftone_fine",
      "posterize_print"
    ],
    [
      "posterize_print",
      "grain_print"
    ],
    [
      "grain_print",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "brightness",
      "source": "audio_rms",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "node": "vignette",
      "param": "strength",
      "source": "audio_beat",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.4
    },
    {
      "node": "grain_print",
      "param": "intensity",
      "source": "audio_energy",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.5
    }
  ]
}