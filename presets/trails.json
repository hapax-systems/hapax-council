{
  "name": "Trails",
  "description": "Additive motion persistence",
  "transition_ms": 500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.1,
        "saturation": 1.2
      }
    },
    "trail": {
      "type": "trail",
      "params": {
        "fade": 0.03,
        "blend_mode": "lighter",
        "opacity": 0.45,
        "drift_x": 5,
        "drift_y": 3
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.25,
        "radius": 12,
        "alpha": 0.35
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.25,
        "sediment_strength": 0.08
      }
    },
    "noise": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.1
      }
    },
    "posterize_subtle": {
      "type": "posterize",
      "params": {
        "levels": 8
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "posterize_subtle"
    ],
    [
      "posterize_subtle",
      "trail"
    ],
    [
      "trail",
      "bloom"
    ],
    [
      "bloom",
      "noise"
    ],
    [
      "noise",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "trail",
      "param": "chromatic_aberration",
      "source": "audio_rms",
      "scale": 0.4,
      "offset": 0.0,
      "smoothing": 0.7
    },
    {
      "source": "audio_energy",
      "param": "hue_rotate",
      "scale": 25.0,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.8,
      "node": "colorgrade"
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "colorgrade"
    }
  ]
}
