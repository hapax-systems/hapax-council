{
  "name": "Dub Echo Spatial",
  "description": "Dub-spectral lineage (1/2): heavy echo + trail + spatial mirror. Channels the dub-reggae echo-chamber aesthetic where sound becomes spatial architecture. Lineage: dub-spectral.",
  "lineage": "dub-spectral",
  "transition_ms": 2600,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.02,
        "contrast": 1.1,
        "saturation": 1.18,
        "hue_rotate": -12
      }
    },
    "echo_dub": {
      "type": "echo",
      "params": {
        "decay_curve": 0.55
      }
    },
    "trail_long": {
      "type": "trail",
      "params": {
        "fade": 0.93,
        "opacity": 0.35
      }
    },
    "mirror_spatial": {
      "type": "mirror",
      "params": {
        "axis": "vertical",
        "position": 0.18
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.32,
        "radius": 0.72
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "echo_dub"
    ],
    [
      "echo_dub",
      "trail_long"
    ],
    [
      "trail_long",
      "mirror_spatial"
    ],
    [
      "mirror_spatial",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "node": "vignette",
      "param": "radius",
      "source": "audio_beat",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.4
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "colorgrade"
    }
  ]
}
