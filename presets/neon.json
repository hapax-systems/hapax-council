{
  "name": "Neon",
  "description": "Glowing edge contours on black",
  "transition_ms": 500,
  "nodes": {
    "edge": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.04
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.02,
        "radius": 20,
        "alpha": 0.8
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 2.0,
        "saturation": 2.5,
        "hue_rotate": 3.5
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.2,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    ["@live", "edge"],
    ["edge", "colorgrade"],
    ["colorgrade", "bloom"],
    ["bloom", "content_layer"],
    ["content_layer", "postprocess"],
    ["postprocess", "out"]
  ],
  "modulations": [],
  "layer_palettes": {}
}
