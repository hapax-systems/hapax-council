{
  "name": "Circular Porthole View",
  "description": "Circular-mask-focus lineage (2/2): tighter circular_mask + fisheye + chromatic creates a porthole / submarine periscope aesthetic \u2014 image viewed through curved aperture. Lineage: circular-mask-focus.",
  "lineage": "circular-mask-focus",
  "transition_ms": 1900,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.94,
        "contrast": 1.18,
        "saturation": 1.08,
        "hue_rotate": -10
      }
    },
    "circular_porthole": {
      "type": "circular_mask",
      "params": {
        "radius": 0.32,
        "softness": 0.05
      }
    },
    "fisheye_porthole": {
      "type": "fisheye",
      "params": {
        "strength": 0.28,
        "center_x": 0.5,
        "center_y": 0.5
      }
    },
    "chroma_porthole": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 3,
        "offset_y": 2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "posterize_subtle": {
      "type": "posterize",
      "params": {
        "levels": 8
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "posterize_subtle"
    ],
    [
      "posterize_subtle",
      "circular_porthole"
    ],
    [
      "circular_porthole",
      "fisheye_porthole"
    ],
    [
      "fisheye_porthole",
      "chroma_porthole"
    ],
    [
      "chroma_porthole",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_beat",
      "param": "chromatic_aberration",
      "scale": 0.5,
      "offset": 0.0,
      "attack": 0.05,
      "decay": 0.6,
      "node": "colorgrade"
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "colorgrade"
    }
  ]
}
