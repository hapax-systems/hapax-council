{
  "name": "Circular Porthole View",
  "description": "Circular-mask-focus lineage (2/2): tighter circular_mask + fisheye + chromatic creates a porthole / submarine periscope aesthetic — image viewed through curved aperture. Lineage: circular-mask-focus.",
  "lineage": "circular-mask-focus",
  "transition_ms": 1900,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.94,
        "contrast": 1.18,
        "saturation": 1.08,
        "hue_rotate": -10
      }
    },
    "circular_porthole": {
      "type": "circular_mask",
      "params": {
        "radius": 0.32,
        "softness": 0.05,
        "center_x": 0.5,
        "center_y": 0.5
      }
    },
    "fisheye_porthole": {
      "type": "fisheye",
      "params": {
        "amount": 0.28,
        "center_x": 0.5,
        "center_y": 0.5
      }
    },
    "chroma_porthole": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 3,
        "offset_y": 2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
}
