{
  "name": "Broadcast VHS Decay",
  "description": "Broadcast-degraded lineage (1/2): heavy VHS + scanlines + chroma drift creates analog-broadcast-tape decay aesthetic. Lineage: broadcast-degraded.",
  "lineage": "broadcast-degraded",
  "transition_ms": 1600,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.96,
        "contrast": 1.05,
        "saturation": 1.18,
        "hue_rotate": 4
      }
    },
    "vhs_decay": {
      "type": "vhs",
      "params": {
        "chroma_shift": 0.55,
        "noise_band_y": 0.22
      }
    },
    "scanlines_broadcast": {
      "type": "scanlines",
      "params": {
        "opacity": 0.32,
        "spacing": 540,
        "thickness": 0.15
      }
    },
    "chroma_broadcast": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 4,
        "offset_y": 2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "vhs_decay"
    ],
    [
      "vhs_decay",
      "scanlines_broadcast"
    ],
    [
      "scanlines_broadcast",
      "chroma_broadcast"
    ],
    [
      "chroma_broadcast",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    }
  ]
}