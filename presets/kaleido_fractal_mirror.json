{
  "name": "Kaleido Fractal Mirror",
  "description": "Kaleidoscope-fractal lineage (1/2): kaleidoscope + mirror + droste at moderate depth creates a multi-axis kaleidoscope-fractal aesthetic. Lineage: kaleidoscope-fractal.",
  "lineage": "kaleidoscope-fractal",
  "transition_ms": 2200,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.04,
        "contrast": 1.18,
        "saturation": 1.32,
        "hue_rotate": 4
      }
    },
    "kaleido": {
      "type": "kaleidoscope",
      "params": {
        "segments": 8,
        "rotation": 0.15
      }
    },
    "mirror_axis": {
      "type": "mirror",
      "params": {
        "axis": "horizontal",
        "position": 0.4
      }
    },
    "droste_recursive": {
      "type": "droste",
      "params": {
        "branches": 2,
        "zoom_speed": 0.78
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "kaleido"
    ],
    [
      "kaleido",
      "mirror_axis"
    ],
    [
      "mirror_axis",
      "droste_recursive"
    ],
    [
      "droste_recursive",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    }
  ]
}