{
  "name": "Diff Motion Thermal",
  "description": "Diff-motion lineage (2/2): diff + thermal palette + trail creates a thermal-camera motion aesthetic \u2014 moving regions glow as heat traces. Lineage: diff-motion.",
  "lineage": "diff-motion",
  "transition_ms": 1500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.92,
        "contrast": 1.28,
        "saturation": 1.05,
        "hue_rotate": 0
      }
    },
    "diff_thermal": {
      "type": "diff",
      "params": {
        "threshold": 0.16
      }
    },
    "thermal_motion": {
      "type": "thermal",
      "params": {
        "intensity": 0.55,
        "palette": 2.0
      }
    },
    "trail_thermal": {
      "type": "trail",
      "params": {
        "fade": 0.78,
        "opacity": 0.45
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "posterize_subtle": {
      "type": "posterize",
      "params": {
        "levels": 8
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "posterize_subtle"
    ],
    [
      "posterize_subtle",
      "diff_thermal"
    ],
    [
      "diff_thermal",
      "thermal_motion"
    ],
    [
      "thermal_motion",
      "trail_thermal"
    ],
    [
      "trail_thermal",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_beat",
      "param": "chromatic_aberration",
      "scale": 0.5,
      "offset": 0.0,
      "attack": 0.05,
      "decay": 0.6,
      "node": "colorgrade"
    },
    {
      "source": "audio_energy",
      "param": "hue_rotate",
      "scale": 25.0,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.8,
      "node": "colorgrade"
    }
  ]
}
