{
  "name": "Tape Wow Flutter",
  "description": "Tape-saturation lineage (2/4): pronounced wow/flutter via drift + warp + heavier feedback decay. Operator-perceptible 'tape almost slipping' character. Lineage: tape-saturation.",
  "lineage": "tape-saturation",
  "transition_ms": 3000,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.02,
        "contrast": 1.06,
        "saturation": 1.08,
        "hue_rotate": -4
      }
    },
    "drift_wow": {
      "type": "drift",
      "params": {
        "amplitude": 0.025,
        "frequency": 0.18
      }
    },
    "warp_flutter": {
      "type": "warp",
      "params": {
        "slice_amplitude": 0.018,
        "slice_count": 0.7,
        "breath": 0.32
      }
    },
    "feedback_wow": {
      "type": "feedback",
      "params": {
        "decay": 0.88
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "drift_wow"
    ],
    [
      "drift_wow",
      "warp_flutter"
    ],
    [
      "warp_flutter",
      "feedback_wow"
    ],
    [
      "feedback_wow",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_beat",
      "param": "chromatic_aberration",
      "scale": 0.5,
      "offset": 0.0,
      "attack": 0.05,
      "decay": 0.6,
      "node": "colorgrade"
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "colorgrade"
    }
  ]
}
