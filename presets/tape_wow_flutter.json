      "type": "warp",
      "params": {
        "amplitude": 0.018,
        "frequency": 0.7,
        "speed": 0.32
      }
    },
    "feedback_wow": {
      "type": "feedback",
      "params": {
        "amount": 0.28,
        "decay": 0.88
      }
