        "brightness": 1.02,
        "contrast": 1.06,
        "saturation": 1.08,
        "hue_rotate": -4
      }
    },
    "drift_wow": {
      "type": "drift",
      "params": {
        "amplitude": 0.025,
        "frequency": 0.18
      }
