{
  "name": "Thermal IR",
  "description": "FLIR iron bow thermography",
  "tags": [
    "electric",
    "detail",
    "macro"
  ],
  "transition_ms": 500,
  "nodes": {
    "thermal": {
      "type": "thermal",
      "params": {
        "edge_glow": 0.6,
        "intensity": 0.4,
        "palette": 0.0
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.0,
        "saturation": 1.0
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.15,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    [
      "@live",
      "thermal"
    ],
    [
      "thermal",
      "colorgrade"
    ],
    [
      "colorgrade",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_energy",
      "param": "displacement",
      "scale": 0.35,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.7,
      "node": "thermal"
    },
    {
      "source": "audio_energy",
      "param": "hue_rotate",
      "scale": 25.0,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.8,
      "node": "thermal"
    }
  ]
}
