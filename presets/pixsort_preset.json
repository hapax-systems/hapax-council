{
  "name": "Pixel Sorting",
  "description": "Pixel sorting",
  "transition_ms": 500,
  "nodes": {
    "pixsort": {
      "type": "pixsort",
      "params": {
        "threshold_low": 0.02,
        "threshold_high": 0.95,
        "sort_length": 400,
        "direction": 0.0
      }
    },
    "scanlines": {
      "type": "scanlines",
      "params": {
        "opacity": 0.08
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "saturation": 1.0,
        "brightness": 1.0,
        "contrast": 1.0,
        "sepia": 0.0,
        "hue_rotate": 0.0
      }
    }
  },
  "edges": [
    [
      "@live",
      "pixsort"
    ],
    [
      "pixsort",
      "scanlines"
    ],
    [
      "scanlines",
      "colorgrade"
    ],
    [
      "colorgrade",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}