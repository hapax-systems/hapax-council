{
  "name": "Pixel Sorting",
  "description": "Pixel sorting",
  "transition_ms": 500,
  "nodes": {
    "pixsort": {
      "type": "pixsort",
      "params": {
        "threshold_low": 0.02,
        "threshold_high": 0.95,
        "sort_length": 500,
        "direction": 0.0
      }
    },
    "scanlines": {
      "type": "scanlines",
      "params": {
        "opacity": 0.08
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.2,
        "contrast": 1.2,
        "saturation": 1.2
      }
    }
  },
  "edges": [
    [
      "@live",
      "pixsort"
    ],
    [
      "pixsort",
      "scanlines"
    ],
    [
      "scanlines",
      "colorgrade"
    ],
    [
      "colorgrade",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_energy",
      "param": "hue_rotate",
      "scale": 25.0,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.8,
      "node": "pixsort"
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "pixsort"
    }
  ]
}
