{
  "name": "Granular Tile Grid",
  "description": "Granular-loop lineage (2/2): tile grid + glitch_block at low intensity creates a sampler-pad / grain-window aesthetic. Each tile is a re-triggered sample. Lineage: granular-loop.",
  "lineage": "granular-loop",
  "transition_ms": 900,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.04,
        "contrast": 1.18,
        "saturation": 1.12,
        "hue_rotate": 6
      }
    },
    "tile_grid": {
      "type": "tile",
      "params": {
        "count_y": 8,
        "count_x": 16,
        "gap": 0.04
      }
    },
    "glitch_subtle": {
      "type": "glitch_block",
      "params": {
        "intensity": 0.22,
        "rgb_split": 0.12,
        "block_size": 4
      }
    },
    "stutter_grain": {
      "type": "stutter",
      "params": {
        "freeze_chance": 0.06,
        "replay_frames": 3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "tile_grid"
    ],
    [
      "tile_grid",
      "glitch_subtle"
    ],
    [
      "glitch_subtle",
      "stutter_grain"
    ],
    [
      "stutter_grain",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    }
  ]
}