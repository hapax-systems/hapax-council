{
  "name": "Glitch Y2K Chroma",
  "description": "Early-2000s digital-glitch lineage (2/4): heavier chromatic aberration + slitscan + dither. References the 'first-decoder-on-low-bandwidth' aesthetic. Lineage: glitch-y2k.",
  "lineage": "glitch-y2k",
  "transition_ms": 800,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.05,
        "contrast": 1.25,
        "saturation": 1.3,
        "hue_rotate": -8
      }
    },
    "chroma_heavy": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 7,
        "offset_y": 4
      }
    },
    "slitscan_strip": {
      "type": "slitscan",
      "params": {
        "speed": 0.22,
        "direction": 6
      }
    },
    "dither_y2k": {
      "type": "dither",
      "params": {
        "color_levels": 0.18
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "chroma_heavy"
    ],
    [
      "chroma_heavy",
      "slitscan_strip"
    ],
    [
      "slitscan_strip",
      "dither_y2k"
    ],
    [
      "dither_y2k",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "colorgrade"
    },
    {
      "source": "audio_beat",
      "param": "chromatic_aberration",
      "scale": 0.5,
      "offset": 0.0,
      "attack": 0.05,
      "decay": 0.6,
      "node": "colorgrade"
    }
  ]
}
