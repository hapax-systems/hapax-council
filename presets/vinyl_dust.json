{
  "name": "Vinyl Dust",
  "description": "Soft vinyl-noise lineage: subtle high-frequency crackle + warm color tilt + minimal saturation. Lineage: vinyl-noise (1/4). The 9-dim parametric envelope expects intensity to drive noise_overlay strength; coherence drives the grain anchor, drift drives the temporal motion.",
  "lineage": "vinyl-noise",
  "transition_ms": 2400,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.95,
        "contrast": 1.05,
        "saturation": 0.85,
        "hue_rotate": 8
      }
    },
    "noise_dust": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.22,
        "animated": 1.0
      }
    },
    "grain": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.22
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.35,
        "radius": 0.7
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "noise_dust"
    ],
    [
      "noise_dust",
      "grain"
    ],
    [
      "grain",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "node": "vignette",
      "param": "radius",
      "source": "audio_beat",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.4
    },
    {
      "node": "noise_dust",
      "param": "intensity",
      "source": "audio_energy",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.5
    }
  ]
}