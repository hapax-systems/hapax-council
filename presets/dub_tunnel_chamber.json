{
  "name": "Dub Tunnel Chamber",
  "description": "Dub-spectral lineage (2/2): tunnel + droste + heavy feedback. Recursive spatial echo-chamber where the image becomes its own delay return. Companion to dub_echo_spatial at deeper space. Lineage: dub-spectral.",
  "lineage": "dub-spectral",
  "transition_ms": 3200,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.96,
        "contrast": 1.08,
        "saturation": 1.22,
        "hue_rotate": -16
      }
    },
    "tunnel_dub": {
      "type": "tunnel",
      "params": {
        "depth": 0.45,
        "speed": 0.12,
        "twist": 0.08
      }
    },
    "droste_recursive": {
      "type": "droste",
      "params": {
        "depth": 3,
        "scale": 0.85
      }
    },
    "feedback_chamber": {
      "type": "feedback",
      "params": {
        "amount": 0.42,
        "decay": 0.88
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "intensity": 0.4,
        "radius": 0.65
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
}
