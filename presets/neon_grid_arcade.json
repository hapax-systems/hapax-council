{
  "name": "Neon Grid Arcade",
  "description": "Neon-grid lineage (1/2): scanlines + edge_detect + chromatic_aberration on saturated colorgrade creates arcade-cabinet light-grid aesthetic \u2014 Tron + Robotron. Lineage: neon-grid. Distinct from chromatic-bloom by the explicit grid + edge structure.",
  "lineage": "neon-grid",
  "transition_ms": 1500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.05,
        "contrast": 1.32,
        "saturation": 1.5,
        "hue_rotate": -8
      }
    },
    "scanlines_grid": {
      "type": "scanlines",
      "params": {
        "opacity": 0.4,
        "spacing": 480,
        "thickness": 0.0
      }
    },
    "edge_grid": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.16
      }
    },
    "chroma_neon": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 3,
        "offset_y": 2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "scanlines_grid"
    ],
    [
      "scanlines_grid",
      "edge_grid"
    ],
    [
      "edge_grid",
      "chroma_neon"
    ],
    [
      "chroma_neon",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "colorgrade"
    },
    {
      "source": "audio_energy",
      "param": "displacement",
      "scale": 0.35,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.7,
      "node": "colorgrade"
    }
  ]
}
