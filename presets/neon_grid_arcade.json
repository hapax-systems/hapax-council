{
  "name": "Neon Grid Arcade",
  "description": "Neon-grid lineage (1/2): scanlines + edge_detect + chromatic_aberration on saturated colorgrade creates arcade-cabinet light-grid aesthetic — Tron + Robotron. Lineage: neon-grid. Distinct from chromatic-bloom by the explicit grid + edge structure.",
  "lineage": "neon-grid",
  "transition_ms": 1500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.05,
        "contrast": 1.32,
        "saturation": 1.5,
        "hue_rotate": -8
      }
    },
    "scanlines_grid": {
      "type": "scanlines",
      "params": {
        "amount": 0.4,
        "frequency": 480,
        "speed": 0.0
      }
    },
    "edge_grid": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.16,
        "amount": 0.5
      }
    },
    "chroma_neon": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 3,
        "offset_y": 2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
}
