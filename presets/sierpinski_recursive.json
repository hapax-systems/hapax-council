{
  "name": "Sierpinski Recursive",
  "description": "Sierpinski lineage (1/2): sierpinski_content + droste creates a recursive sierpinski-triangle composition where the sierpinski form contains itself. Lineage: sierpinski.",
  "lineage": "sierpinski",
  "transition_ms": 2500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.02,
        "contrast": 1.14,
        "saturation": 1.2,
        "hue_rotate": 2
      }
    },
    "sierpinski_main": {
      "type": "sierpinski_content",
      "params": {
        "depth": 4,
        "rotation": 0.0
      }
    },
    "droste_sierpinski": {
      "type": "droste",
      "params": {
        "depth": 2,
        "scale": 0.85
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "intensity": 0.35,
        "radius": 0.68
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "sierpinski_main"
    ],
    [
      "sierpinski_main",
      "droste_sierpinski"
    ],
    [
      "droste_sierpinski",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": []
}
