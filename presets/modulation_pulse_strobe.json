      "params": {
        "frequency": 4.5,
        "duty_cycle": 0.4,
        "depth": 0.55
      }
    },
    "breathing_slow": {
      "type": "breathing",
      "params": {
        "frequency": 0.25,
        "depth": 0.18
      }
    },
    "scanlines_pulse": {
      "type": "scanlines",
      "params": {
        "amount": 0.22,
        "frequency": 480,
        "speed": 0.3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
