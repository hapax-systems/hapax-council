{
  "name": "Modulation Pulse Strobe",
  "description": "Modulation-pulse lineage (1/2): smooth breathing + scanlines \u2014 analog pulse-width-modulation aesthetic via amplitude swell, NOT hard flash. Operator invariant feedback_no_blinking_homage_wards forbids strobe nodes; pulse character preserved via faster breathing rate. Lineage: modulation-pulse.",
  "lineage": "modulation-pulse",
  "transition_ms": 1100,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.22,
        "saturation": 1.0,
        "hue_rotate": 0
      }
    },
    "breathing_pulse": {
      "type": "drift",
      "params": {
        "speed": 0.85,
        "amplitude": 9,
        "frequency": 0.3,
        "coherence": 0.6
      }
    },
    "scanlines_pulse": {
      "type": "scanlines",
      "params": {
        "opacity": 0.22,
        "spacing": 480,
        "thickness": 0.3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "breathing_pulse"
    ],
    [
      "breathing_pulse",
      "scanlines_pulse"
    ],
    [
      "scanlines_pulse",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    }
  ]
}
