{
  "name": "Silhouette",
  "description": "High contrast",
  "tags": [
    "intimate",
    "portrait",
    "minimal"
  ],
  "transition_ms": 500,
  "nodes": {
    "threshold": {
      "type": "threshold",
      "params": {
        "level": 0.2
      }
    },
    "invert": {
      "type": "invert",
      "params": {
        "strength": 1.0
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.1,
        "saturation": 0.7
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "threshold"
    ],
    [
      "threshold",
      "invert"
    ],
    [
      "invert",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_energy",
      "param": "hue_rotate",
      "scale": 25.0,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.8,
      "node": "threshold"
    },
    {
      "source": "audio_energy",
      "param": "displacement",
      "scale": 0.35,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.7,
      "node": "threshold"
    }
  ]
}
