{
  "name": "Diff Motion Trail",
  "description": "Diff-motion lineage (1/2): diff (frame-difference) + trail creates a motion-detection visualization — only moving pixels persist; static pixels fade. Lineage: diff-motion.",
  "lineage": "diff-motion",
  "transition_ms": 1400,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.32,
        "saturation": 1.15,
        "hue_rotate": -8
      }
    },
    "diff_motion": {
      "type": "diff",
      "params": {
        "threshold": 0.12,
        "amount": 0.85
      }
    },
    "trail_motion": {
      "type": "trail",
      "params": {
        "decay": 0.85,
        "amount": 0.55
      }
    },
    "edge_motion": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.2,
        "amount": 0.32
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
}
