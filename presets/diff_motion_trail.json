{
  "name": "Diff Motion Trail",
  "description": "Diff-motion lineage (1/2): diff (frame-difference) + trail creates a motion-detection visualization \u2014 only moving pixels persist; static pixels fade. Lineage: diff-motion.",
  "lineage": "diff-motion",
  "transition_ms": 1400,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.32,
        "saturation": 1.15,
        "hue_rotate": -8
      }
    },
    "diff_motion": {
      "type": "diff",
      "params": {
        "threshold": 0.12
      }
    },
    "trail_motion": {
      "type": "trail",
      "params": {
        "fade": 0.85,
        "opacity": 0.55
      }
    },
    "edge_motion": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "diff_motion"
    ],
    [
      "diff_motion",
      "trail_motion"
    ],
    [
      "trail_motion",
      "edge_motion"
    ],
    [
      "edge_motion",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "brightness",
      "source": "audio_rms",
      "scale": 0.08,
      "offset": 0.0,
      "smoothing": 0.6
    }
  ]
}