  "edges": [
    [
      "@live",
      "ascii"
    ],
    [
      "ascii",
      "scanlines"
    ],
    [
      "scanlines",
      "colorgrade"
    ],
    [
      "colorgrade",
      "bloom"
    ],
    [
      "bloom",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "saturation",
      "source": "audio_rms",
      "scale": 0.1,
      "offset": 0.0,
      "smoothing": 0.6
    },
    {
      "source": "audio_rms",
      "param": "slice_amplitude",
      "scale": 0.4,
      "offset": 0.0,
      "attack": 0.08,
      "decay": 0.65,
      "node": "ascii"
    },
    {
      "source": "audio_energy",
      "param": "displacement",
      "scale": 0.35,
      "offset": 0.0,
      "attack": 0.1,
      "decay": 0.7,
      "node": "ascii"
    }
