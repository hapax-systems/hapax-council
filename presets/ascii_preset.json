{
  "name": "ASCII Art",
  "description": "ASCII art",
  "transition_ms": 500,
  "nodes": {
    "ascii": {
      "type": "ascii",
      "params": {
        "cell_size": 8,
        "color_mode": 1
      }
    },
    "scanlines": {
      "type": "scanlines",
      "params": {
        "opacity": 0.08
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.0,
        "saturation": 0.5
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.2,
        "radius": 8,
        "alpha": 0.4
      }
    }
