{
  "name": "Circular Lens Focus",
  "description": "Circular-mask-focus lineage (1/2): circular_mask + bloom + vignette creates a lens-focus / spotlight aesthetic \u2014 only the centered region is sharp + bright. Lineage: circular-mask-focus.",
  "lineage": "circular-mask-focus",
  "transition_ms": 1700,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.04,
        "contrast": 1.12,
        "saturation": 1.18,
        "hue_rotate": 0
      }
    },
    "circular_mask_focus": {
      "type": "circular_mask",
      "params": {
        "radius": 0.42,
        "softness": 0.18
      }
    },
    "bloom_focus": {
      "type": "bloom",
      "params": {
        "alpha": 0.4,
        "threshold": 0.5,
        "radius": 0.12
      }
    },
    "vignette_heavy": {
      "type": "vignette",
      "params": {
        "strength": 0.55,
        "radius": 0.5
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "posterize_subtle": {
      "type": "posterize",
      "params": {
        "levels": 7
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "posterize_subtle"
    ],
    [
      "posterize_subtle",
      "circular_mask_focus"
    ],
    [
      "circular_mask_focus",
      "bloom_focus"
    ],
    [
      "bloom_focus",
      "vignette_heavy"
    ],
    [
      "vignette_heavy",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": []
}