{
  "name": "Cellular Kuwahara Paint",
  "description": "Organic-cellular lineage (2/2): kuwahara filter (preserves edges, smooths interiors) + reaction_diffusion at low intensity creates a painted-cell biological aesthetic \u2014 the image looks like an oil-painted petri dish. Lineage: organic-cellular.",
  "lineage": "organic-cellular",
  "transition_ms": 3000,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.04,
        "contrast": 1.06,
        "saturation": 1.22,
        "hue_rotate": 4
      }
    },
    "kuwahara_paint": {
      "type": "kuwahara",
      "params": {
        "radius": 4
      }
    },
    "reaction_subtle": {
      "type": "reaction_diffusion",
      "params": {
        "feed_rate": 0.038,
        "kill_rate": 0.061
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "kuwahara_paint"
    ],
    [
      "kuwahara_paint",
      "reaction_subtle"
    ],
    [
      "reaction_subtle",
      "content_layer"
    ],
    [
      "content_layer",
      "out"
    ]
  ],
  "modulations": []
}
