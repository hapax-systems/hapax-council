        "contrast": 1.06,
        "saturation": 1.22,
        "hue_rotate": 4
      }
    },
    "kuwahara_paint": {
      "type": "kuwahara",
      "params": {
        "radius": 4,
        "amount": 0.7
      }
    },
    "reaction_subtle": {
      "type": "reaction_diffusion",
      "params": {
        "feed_rate": 0.038,
        "kill_rate": 0.061,
        "iterations": 2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    }
  }
