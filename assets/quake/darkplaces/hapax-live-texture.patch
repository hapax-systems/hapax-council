+typedef struct hapax_live_texture_slot_state_s
+{
+	unsigned char *pixels;
+	size_t pixels_size;
+	time_t mtime_sec;
+	long mtime_nsec;
+	off_t file_size;
+	qbool uploaded;
+}
+hapax_live_texture_slot_state_t;
+static hapax_live_texture_slot_state_t hapax_live_texture_slot_state[HAPAX_LIVE_TEXTURE_SLOT_COUNT];
+
+static void R_HapaxLiveTexture_Debug(const char *stage, const char *name, const char *path, int width, int height, int texwidth, int texheight)
+{
+	FILE *file;
+
+	if ((r_textureframe % 120) != 0 &&
+		(!name || strcmp(name, "progs/aoa.mdl_0") || (stage && !strcmp(stage, "slot-active"))))
+		return;
+
+	file = fopen("/tmp/hapax-live-texture-debug.log", "a");
+	if (!file)
+		return;
+	fprintf(file, "frame=%d stage=%s name=%s path=%s width=%d height=%d texwidth=%d texheight=%d\n",
+		r_textureframe, stage, name ? name : "", path ? path : "", width, height, texwidth, texheight);
+	fclose(file);
+}
+
+static qbool R_HapaxLiveTexture_ReadFrame(const char *path, unsigned char *pixels, size_t size)
+{
+	FILE *file;
+	size_t bytes_read;
+
+	file = fopen(path, "rb");
+	if (!file)
+		return false;
+	bytes_read = fread(pixels, 1, size, file);
+	fclose(file);
+	return bytes_read == size;
+}
+
+static skinframe_t *R_HapaxLiveTexture_FindWorldSkinFrame(const char *name)
+{
+	int i;
+	static qbool dumped_texture_names = false;
+	model_t *model = r_refdef.scene.worldmodel ? r_refdef.scene.worldmodel : cl.worldmodel;
+	texture_t *texture;
+	FILE *dump;
+
+	if (!model || !model->data_textures)
+		return NULL;
+	if (!dumped_texture_names)
+	{
+		dumped_texture_names = true;
+		dump = fopen("/tmp/hapax-live-texture-names.log", "w");
+		if (dump)
+		{
+			fprintf(dump, "num_textures=%d model=%s\n", model->num_textures, model->name);
+			for (i = 0; i < model->num_textures; ++i)
+			{
+				texture = model->data_textures + i;
+				fprintf(dump, "%03d %s skinframe=%p material=%p\n", i, texture->name, (void *)texture->currentskinframe, (void *)texture->materialshaderpass);
+			}
+			fclose(dump);
+		}
+	}
+	for (i = 0; i < model->num_textures; ++i)
+	{
+		texture = model->data_textures + i;
+		if (strcmp(texture->name, name))
+			continue;
+		if (texture->currentskinframe)
+			return texture->currentskinframe;
+		if (texture->materialshaderpass && texture->materialshaderpass->numframes > 0)
+			return texture->materialshaderpass->skinframes[0];
+		return NULL;
+	}
+	return NULL;
+}
+
+static void R_HapaxLiveTexture_UpdateSlot(int slot, cvar_t *enable, cvar_t *name_cvar, cvar_t *path_cvar, cvar_t *width_cvar, cvar_t *height_cvar)
+{
+	const char *name;
+	const char *path;
+	int width;
+	int height;
+	size_t size;
+	struct stat st;
+	time_t mtime_sec;
+	long mtime_nsec;
+	hapax_live_texture_slot_state_t *state;
+	skinframe_t *skinframe;
+	rtexture_t *texture;
+	char identifier[MAX_QPATH];
+
+	if (!enable->integer || cls.state == ca_dedicated)
+	{
+		R_HapaxLiveTexture_Debug("disabled", name_cvar->string, path_cvar->string, width_cvar->integer, height_cvar->integer, enable->integer, cls.state);
+		return;
+	}
+
+	name = name_cvar->string;
+	path = path_cvar->string;
+	width = width_cvar->integer;
+	height = height_cvar->integer;
+	if (!name[0] || !path[0] || width <= 0 || height <= 0 || width > 4096 || height > 4096)
+	{
+		R_HapaxLiveTexture_Debug("invalid", name, path, width, height, -1, -1);
+		return;
+	}
+	if (slot == HAPAX_LIVE_TEXTURE_SLOT_COUNT - 1)
+		R_HapaxLiveTexture_Debug("slot-active", name, path, width, height, enable->integer, slot + 1);
+
+	size = (size_t)width * (size_t)height * 4;
+	if (stat(path, &st) != 0)
+	{
+		R_HapaxLiveTexture_Debug("stat-failed", name, path, width, height, -1, -1);
+		return;
+	}
+	if ((size_t)st.st_size != size)
+	{
+		R_HapaxLiveTexture_Debug("size-mismatch", name, path, width, height, (int)st.st_size, (int)size);
+		return;
+	}
+	mtime_sec = st.st_mtim.tv_sec;
+	mtime_nsec = st.st_mtim.tv_nsec;
+	state = &hapax_live_texture_slot_state[slot];
+	if (state->uploaded && state->file_size == st.st_size && state->mtime_sec == mtime_sec && state->mtime_nsec == mtime_nsec)
+		return;
+	if (state->pixels_size != size || !state->pixels)
+	{
+		if (state->pixels)
+			Mem_Free(state->pixels);
+		state->pixels = (unsigned char *)Mem_Alloc(r_main_mempool, size);
+		state->pixels_size = size;
+	}
+	if (!state->pixels)
+	{
+		R_HapaxLiveTexture_Debug("alloc-failed", name, path, width, height, -1, -1);
+		return;
+	}
+	if (!R_HapaxLiveTexture_ReadFrame(path, state->pixels, size))
+	{
+		R_HapaxLiveTexture_Debug("read-failed", name, path, width, height, -1, -1);
+		return;
+	}
+	skinframe = R_SkinFrame_FindNextByName(NULL, name);
+	if (!skinframe)
+		skinframe = R_HapaxLiveTexture_FindWorldSkinFrame(name);
+	if (!skinframe)
+	{
+		R_HapaxLiveTexture_Debug("skinframe-missing", name, path, width, height, -1, -1);
+		return;
+	}
+	R_SkinFrame_MarkUsed(skinframe);
+
+	texture = skinframe->merged ? skinframe->merged : skinframe->base;
+	if (!texture || R_TextureWidth(texture) != width || R_TextureHeight(texture) != height)
+	{
+		if (skinframe->qpixels)
+		{
+			Mem_Free(skinframe->qpixels);
+			skinframe->qpixels = NULL;
+		}
+		skinframe->qgeneratebase = false;
+		skinframe->qgeneratemerged = false;
+		skinframe->qgeneratenmap = false;
+		skinframe->qgenerateglow = false;
+		dpsnprintf(identifier, sizeof(identifier), "hapax_live_%s", skinframe->basename);
+		skinframe->base = skinframe->merged = R_LoadTexture2D(
+			r_main_texturepool,
+			identifier,
+			width,
+			height,
+			state->pixels,
+			TEXTYPE_BGRA,
+			TEXF_FORCELINEAR | TEXF_PERSISTENT | TEXF_ALLOWUPDATES,
+			-1,
+			NULL);
+		texture = skinframe->merged;
+		if (!texture)
+		{
+			R_HapaxLiveTexture_Debug("load-failed", name, path, width, height, -1, -1);
+			return;
+		}
+		R_HapaxLiveTexture_Debug("replaced", name, path, width, height, R_TextureWidth(texture), R_TextureHeight(texture));
+	}
+	else
+		R_HapaxLiveTexture_Debug("updating", name, path, width, height, R_TextureWidth(texture), R_TextureHeight(texture));
+
+	R_UpdateTexture(texture, state->pixels, 0, 0, 0, width, height, 1, 0);
+	if (skinframe->base && skinframe->base != texture &&
+		R_TextureWidth(skinframe->base) == width && R_TextureHeight(skinframe->base) == height)
+		R_UpdateTexture(skinframe->base, state->pixels, 0, 0, 0, width, height, 1, 0);
+	state->file_size = st.st_size;
+	state->mtime_sec = mtime_sec;
+	state->mtime_nsec = mtime_nsec;
+	state->uploaded = true;
+}
+
+static void R_HapaxLiveTexture_Update(void)
+{
+	int slot;
+
+	for (slot = 0; slot < HAPAX_LIVE_TEXTURE_SLOT_COUNT; ++slot)
+		R_HapaxLiveTexture_UpdateSlot(slot, &hapax_live_texture_enable[slot], &hapax_live_texture_name[slot], &hapax_live_texture_path[slot], &hapax_live_texture_width[slot], &hapax_live_texture_height[slot]);
+}
