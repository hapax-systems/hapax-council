+			identifier,
+			width,
+			height,
+			state->pixels,
+			TEXTYPE_BGRA,
+			TEXF_FORCELINEAR | TEXF_PERSISTENT | TEXF_ALLOWUPDATES,
+			-1,
+			NULL);
+		texture = skinframe->merged;
+		if (!texture)
+		{
+			R_HapaxLiveTexture_Debug("load-failed", name, path, width, height, -1, -1);
+			return;
+		}
+		R_HapaxLiveTexture_Debug("replaced", name, path, width, height, R_TextureWidth(texture), R_TextureHeight(texture));
+	}
+	else
+		R_HapaxLiveTexture_Debug("updating", name, path, width, height, R_TextureWidth(texture), R_TextureHeight(texture));
+
+	R_UpdateTexture(texture, state->pixels, 0, 0, 0, width, height, 1, 0);
+	if (skinframe->base && skinframe->base != texture &&
+		R_TextureWidth(skinframe->base) == width && R_TextureHeight(skinframe->base) == height)
+		R_UpdateTexture(skinframe->base, state->pixels, 0, 0, 0, width, height, 1, 0);
+	state->file_size = st.st_size;
+	state->mtime_sec = mtime_sec;
+	state->mtime_nsec = mtime_nsec;
+	state->uploaded = true;
+}
+
+static void R_HapaxLiveTexture_Update(void)
+{
+	int slot;
+
+	for (slot = 0; slot < HAPAX_LIVE_TEXTURE_SLOT_COUNT; ++slot)
+		R_HapaxLiveTexture_UpdateSlot(slot, &hapax_live_texture_enable[slot], &hapax_live_texture_name[slot], &hapax_live_texture_path[slot], &hapax_live_texture_width[slot], &hapax_live_texture_height[slot]);
+}
+
+typedef struct hapax_driftfield_state_s
+{
+	unsigned char *pixels;
+	size_t pixels_size;
+	time_t mtime_sec;
+	long mtime_nsec;
+	off_t file_size;
+	int width;
+	int height;
+	qbool uploaded;
+}
+hapax_driftfield_state_t;
+static hapax_driftfield_state_t hapax_driftfield_state;
+
+static void R_HapaxDriftField_Update(void)
+{
+	const char *path;
+	int width;
+	int height;
+	size_t size;
+	struct stat st;
+	time_t mtime_sec;
+	long mtime_nsec;
+	hapax_driftfield_state_t *state = &hapax_driftfield_state;
+
+	if (!hapax_driftfield_enable.integer || cls.state == ca_dedicated)
+		return;
+
+	path = hapax_driftfield_path.string;
+	width = hapax_driftfield_width.integer;
+	height = hapax_driftfield_height.integer;
+	if (!path[0] || width <= 0 || height <= 0 || width > 4096 || height > 4096)
+		return;
+
+	size = (size_t)width * (size_t)height * 4;
+	if (stat(path, &st) != 0)
+		return;
+	if ((size_t)st.st_size != size) // torn-frame/size reject: must be exactly w*h*4
+		return;
+	mtime_sec = st.st_mtim.tv_sec;
+	mtime_nsec = st.st_mtim.tv_nsec;
+	if (state->uploaded && r_hapax_driftfield_texture &&
+		state->file_size == st.st_size && state->mtime_sec == mtime_sec && state->mtime_nsec == mtime_nsec)
+		return;
+	if (state->pixels_size != size || !state->pixels)
+	{
+		if (state->pixels)
+			Mem_Free(state->pixels);
+		state->pixels = (unsigned char *)Mem_Alloc(r_main_mempool, size);
+		state->pixels_size = size;
+	}
+	if (!state->pixels)
+		return;
+	if (!R_HapaxLiveTexture_ReadFrame(path, state->pixels, size)) // second torn-frame guard (short read)
+		return;
+
+	if (!r_hapax_driftfield_texture || state->width != width || state->height != height)
+	{
+		r_hapax_driftfield_texture = R_LoadTexture2D(
+			r_main_texturepool,
+			"hapax_driftfield",
+			width,
+			height,
+			state->pixels,
+			TEXTYPE_BGRA,
+			TEXF_FORCELINEAR | TEXF_CLAMP | TEXF_PERSISTENT | TEXF_ALLOWUPDATES,
+			-1,
+			NULL);
+		state->width = width;
+		state->height = height;
+		if (!r_hapax_driftfield_texture)
+			return;
+	}
+	else
+		R_UpdateTexture(r_hapax_driftfield_texture, state->pixels, 0, 0, 0, width, height, 1, 0);
+
+	state->file_size = st.st_size;
+	state->mtime_sec = mtime_sec;
+	state->mtime_nsec = mtime_nsec;
+	state->uploaded = true;
+}
