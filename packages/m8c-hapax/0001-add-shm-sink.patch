+
     draw_waveform(&osccmd);
     return 1;
   }
@@ -146,7 +149,7 @@
       return 0;
     }

-    // nothing is done with joypad key pressed packets for now
+    shm_sink_publish_buttons(recv_buf[1], recv_buf[2]);
     return 1;
