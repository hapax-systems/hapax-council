@@ -176,6 +179,7 @@
     }

     renderer_set_font_mode(recv_buf[5]);
+    shm_sink_publish_info(recv_buf[1], recv_buf[2], recv_buf[3], recv_buf[4], recv_buf[5]);

     return 1;
