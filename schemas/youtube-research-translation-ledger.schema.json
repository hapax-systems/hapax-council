{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hapax.council/schemas/youtube-research-translation-ledger.schema.json",
  "title": "YouTube Research Translation Ledger",
  "description": "Machine-readable public-aperture ledger for translating ResearchVehiclePublicEvent evidence into YouTube metadata, captions, cuepoints, chapters, Shorts, sections, quota, and suitability policy.",
  "type": "object",
  "required": [
    "schema_version",
    "ledger_id",
    "generated_at",
    "source_refs",
    "authority",
    "global_policy",
    "official_sources",
    "surface_rows",
    "child_task_splits"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "ledger_id": {
      "type": "string",
      "pattern": "^youtube_research_translation_ledger:[a-z0-9_.:-]+$"
    },
    "generated_at": {"type": "string", "format": "date-time"},
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "authority": {
      "type": "object",
      "required": [
        "public_event_contract",
        "egress_state_contract",
        "substrate_contract",
        "closed_reconcile_ledger"
      ],
      "additionalProperties": false,
      "properties": {
        "public_event_contract": {"type": "string", "minLength": 1},
        "egress_state_contract": {"type": "string", "minLength": 1},
        "substrate_contract": {"type": "string", "minLength": 1},
        "closed_reconcile_ledger": {"type": "string", "minLength": 1}
      }
    },
    "global_policy": {
      "type": "object",
      "required": [
        "default_public_claim_allowed",
        "default_monetization_claim_allowed",
        "metadata_may_infer_live_state",
        "most_restrictive_policy_wins",
        "blocked_reason_codes"
      ],
      "additionalProperties": false,
      "properties": {
        "default_public_claim_allowed": {"type": "boolean", "const": false},
        "default_monetization_claim_allowed": {"type": "boolean", "const": false},
        "metadata_may_infer_live_state": {"type": "boolean", "const": false},
        "most_restrictive_policy_wins": {"type": "boolean", "const": true},
        "blocked_reason_codes": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "uniqueItems": true
        }
      }
    },
    "official_sources": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/official_source"},
      "uniqueItems": true
    },
    "surface_rows": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/surface_row"}
    },
    "child_task_splits": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/child_task"}
    }
  },
  "$defs": {
    "official_source": {
      "type": "object",
      "required": ["source_id", "url", "observed_at", "key_facts"],
      "additionalProperties": false,
      "properties": {
        "source_id": {"type": "string", "pattern": "^[a-z][a-z0-9_.:-]+$"},
        "url": {"type": "string", "format": "uri"},
        "observed_at": {"type": "string", "format": "date-time"},
        "key_facts": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "surface_row": {
      "type": "object",
      "required": [
        "surface_id",
        "display_name",
        "publication_surface",
        "current_status",
        "public_event_inputs",
        "content_substrate_refs",
        "existing_task_anchors",
        "evidence_requirements",
        "claim_policy",
        "quota_policy",
        "suitability_policy",
        "fallback",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "surface_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "display_name": {"type": "string", "minLength": 1},
        "publication_surface": {"type": "boolean"},
        "current_status": {
          "type": "string",
          "enum": [
            "wired_private",
            "legacy_live_unverified",
            "dry_run",
            "dormant",
            "unavailable",
            "policy_only",
            "quota_only"
          ]
        },
        "public_event_inputs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "content_substrate_refs": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "uniqueItems": true
        },
        "existing_task_anchors": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "evidence_requirements": {
          "type": "object",
          "required": ["required_refs", "freshness_refs", "public_blockers"],
          "additionalProperties": false,
          "properties": {
            "required_refs": {
              "type": "array",
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "freshness_refs": {
              "type": "array",
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "public_blockers": {
              "type": "array",
              "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
              "uniqueItems": true
            }
          }
        },
        "claim_policy": {
          "type": "object",
          "required": [
            "allowed_claims",
            "forbidden_claims",
            "default_public_claim_allowed",
            "default_monetization_claim_allowed",
            "requires_human_review"
          ],
          "additionalProperties": false,
          "properties": {
            "allowed_claims": {
              "type": "array",
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "forbidden_claims": {
              "type": "array",
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "default_public_claim_allowed": {"type": "boolean", "const": false},
            "default_monetization_claim_allowed": {"type": "boolean", "const": false},
            "requires_human_review": {"type": "boolean"}
          }
        },
        "quota_policy": {
          "type": "object",
          "required": [
            "endpoint",
            "units_per_call",
            "official_source_id",
            "local_budget_ref",
            "quota_write_allowed"
          ],
          "additionalProperties": false,
          "properties": {
            "endpoint": {"type": ["string", "null"]},
            "units_per_call": {"type": ["integer", "null"], "minimum": 0},
            "official_source_id": {"type": ["string", "null"]},
            "local_budget_ref": {"type": ["string", "null"]},
            "quota_write_allowed": {"type": "boolean", "const": false}
          }
        },
        "suitability_policy": {
          "type": "object",
          "required": ["posture", "requires_review_reason"],
          "additionalProperties": false,
          "properties": {
            "posture": {
              "type": "string",
              "enum": ["requires_review", "not_applicable"]
            },
            "requires_review_reason": {"type": ["string", "null"]}
          }
        },
        "fallback": {
          "type": "object",
          "required": ["mode", "reason"],
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "dry_run",
                "private_only",
                "chapter_only",
                "hold_last_safe",
                "operator_review",
                "deny"
              ]
            },
            "reason": {"type": "string", "minLength": 1}
          }
        },
        "notes": {"type": "string", "minLength": 1}
      }
    },
    "child_task": {
      "type": "object",
      "required": ["task_id", "owner_scope", "unblocks", "blocked_until"],
      "additionalProperties": false,
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "owner_scope": {"type": "string", "minLength": 1},
        "unblocks": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "blocked_until": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    }
  }
}
