{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hapax.council/schemas/world-surface-temporal-perceptual-health.schema.json",
  "title": "WorldSurfaceTemporalPerceptualHealthFixtures",
  "description": "Temporal-band, PerceptualField, stimmung, narration-context, and impingement evidence fixtures projected into WorldSurfaceHealthRecord rows without granting public claim authority.",
  "type": "object",
  "required": [
    "schema_version",
    "fixture_set_id",
    "schema_ref",
    "generated_from",
    "declared_at",
    "producer",
    "required_observation_categories",
    "required_temporal_bands",
    "fail_closed_policy",
    "metrics_refs",
    "rows"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "fixture_set_id": {"type": "string", "minLength": 1},
    "schema_ref": {
      "type": "string",
      "const": "schemas/world-surface-temporal-perceptual-health.schema.json"
    },
    "generated_from": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "not": {"pattern": "^/home/"}}
    },
    "declared_at": {"type": "string", "format": "date-time"},
    "producer": {"type": "string", "minLength": 1},
    "required_observation_categories": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/observation_category"}
    },
    "required_temporal_bands": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/temporal_band"}
    },
    "fail_closed_policy": {
      "type": "object",
      "required": [
        "stale_temporal_band_allows_current_claim",
        "missing_temporal_band_allows_claim",
        "unknown_temporal_band_allows_claim",
        "unknown_perception_state_allows_public_live",
        "inferred_perceptual_data_satisfies_witness",
        "spanless_perceptual_data_satisfies_grounded_claim",
        "protention_satisfies_current_claim",
        "protention_as_fact_satisfies_current_claim",
        "stale_temporal_xml_allows_current_claim",
        "fresh_temporal_xml_without_evidence_refs_allows_claim",
        "stale_perceptual_field_allows_current_claim",
        "empty_real_provenance_satisfies_grounded_claim",
        "synthetic_only_provenance_satisfies_witness",
        "contradictory_epochs_allow_current_claim",
        "autonomous_narration_without_wcs_health_allowed",
        "impingement_without_witness_satisfies_claim"
      ],
      "additionalProperties": false,
      "properties": {
        "stale_temporal_band_allows_current_claim": {"type": "boolean", "const": false},
        "missing_temporal_band_allows_claim": {"type": "boolean", "const": false},
        "unknown_temporal_band_allows_claim": {"type": "boolean", "const": false},
        "unknown_perception_state_allows_public_live": {"type": "boolean", "const": false},
        "inferred_perceptual_data_satisfies_witness": {"type": "boolean", "const": false},
        "spanless_perceptual_data_satisfies_grounded_claim": {
          "type": "boolean",
          "const": false
        },
        "protention_satisfies_current_claim": {"type": "boolean", "const": false},
        "protention_as_fact_satisfies_current_claim": {
          "type": "boolean",
          "const": false
        },
        "stale_temporal_xml_allows_current_claim": {"type": "boolean", "const": false},
        "fresh_temporal_xml_without_evidence_refs_allows_claim": {
          "type": "boolean",
          "const": false
        },
        "stale_perceptual_field_allows_current_claim": {
          "type": "boolean",
          "const": false
        },
        "empty_real_provenance_satisfies_grounded_claim": {
          "type": "boolean",
          "const": false
        },
        "synthetic_only_provenance_satisfies_witness": {
          "type": "boolean",
          "const": false
        },
        "contradictory_epochs_allow_current_claim": {"type": "boolean", "const": false},
        "autonomous_narration_without_wcs_health_allowed": {
          "type": "boolean",
          "const": false
        },
        "impingement_without_witness_satisfies_claim": {"type": "boolean", "const": false}
      }
    },
    "metrics_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "rows": {
      "type": "array",
      "minItems": 6,
      "items": {"$ref": "#/$defs/health_row"}
    }
  },
  "$defs": {
    "observation_category": {
      "type": "string",
      "enum": [
        "temporal_band",
        "perception_state",
        "perceptual_field",
        "stimmung",
        "autonomous_narration_context",
        "impingement_evidence"
      ]
    },
    "temporal_band": {
      "type": "string",
      "enum": ["retention", "impression", "protention", "surprise", "nonclaimable_diagnostic"]
    },
    "health_status": {
      "type": "string",
      "enum": [
        "healthy",
        "degraded",
        "blocked",
        "unsafe",
        "stale",
        "missing",
        "unknown",
        "private_only",
        "dry_run",
        "quiet_off_air",
        "candidate"
      ]
    },
    "freshness_state": {
      "type": "string",
      "enum": ["fresh", "stale", "missing", "unknown", "not_applicable"]
    },
    "authority_ceiling": {
      "type": "string",
      "enum": [
        "no_claim",
        "internal_only",
        "speculative",
        "evidence_bound",
        "posterior_bound",
        "public_gate_required"
      ]
    },
    "privacy_state": {
      "type": "string",
      "enum": ["public_safe", "private_only", "dry_run", "archive_only", "blocked", "unknown"]
    },
    "rights_state": {
      "type": "string",
      "enum": [
        "public_clear",
        "private_only",
        "aggregate_only",
        "blocked",
        "missing",
        "unknown",
        "not_applicable"
      ]
    },
    "public_private_posture": {
      "type": "string",
      "enum": ["public_live", "private_only", "dry_run", "archive_only", "disabled", "blocked"]
    },
    "fallback_mode": {
      "type": "string",
      "enum": [
        "none",
        "hide",
        "no_op_explain",
        "dry_run_badge",
        "private_only",
        "archive_only",
        "hold_last_safe",
        "suppress",
        "degraded_status",
        "operator_prompt",
        "kill_switch",
        "block_public_claim",
        "correction_required"
      ]
    },
    "kill_switch_status": {
      "type": "string",
      "enum": ["clear", "triggered", "unknown", "not_applicable"]
    },
    "witness_policy": {
      "type": "string",
      "enum": [
        "witnessed",
        "inferred",
        "selected_only",
        "commanded_only",
        "fixture_only",
        "absent",
        "candidate"
      ]
    },
    "fixture_case": {
      "type": "string",
      "enum": [
        "healthy_witnessed",
        "degraded_witnessed",
        "blocked_with_reason",
        "unsafe_no_leak",
        "stale",
        "missing",
        "unknown",
        "private_only",
        "dry_run",
        "quiet_off_air",
        "candidate",
        "inferred",
        "selected_only",
        "commanded_only",
        "wrong_route",
        "leak",
        "unsupported_claim",
        "false_monetization"
      ]
    },
    "false_grounding_risk_cause": {
      "type": "string",
      "enum": [
        "stale_temporal_band",
        "missing_temporal_band",
        "unknown_temporal_band",
        "unknown_perception_state",
        "inferred_perceptual_data",
        "spanless_perceptual_data",
        "protention_as_current",
        "protention_as_fact",
        "surprise_as_current",
        "stale_temporal_xml",
        "fresh_temporal_xml_without_evidence_refs",
        "stale_perceptual_field",
        "empty_real_provenance",
        "synthetic_only_provenance",
        "contradictory_perception_temporal_epochs",
        "stale_stimmung",
        "missing_grounding_key",
        "autonomous_narration_ungated",
        "impingement_without_witness"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "non_empty_string_array": {
      "allOf": [
        {"$ref": "#/$defs/string_array"},
        {"minItems": 1}
      ]
    },
    "freshness": {
      "type": "object",
      "required": ["state", "ttl_s", "observed_age_s", "source_ref", "checked_at"],
      "additionalProperties": false,
      "properties": {
        "state": {"$ref": "#/$defs/freshness_state"},
        "ttl_s": {"type": ["integer", "null"], "minimum": 0},
        "observed_age_s": {"type": ["integer", "null"], "minimum": 0},
        "source_ref": {"type": ["string", "null"], "minLength": 1},
        "checked_at": {"type": "string", "format": "date-time"}
      }
    },
    "fallback": {
      "type": "object",
      "required": ["mode", "reason_code", "operator_visible_reason", "safe_state"],
      "additionalProperties": false,
      "properties": {
        "mode": {"$ref": "#/$defs/fallback_mode"},
        "reason_code": {"type": "string", "minLength": 1},
        "operator_visible_reason": {"type": "string", "minLength": 1},
        "safe_state": {"type": "string", "minLength": 1}
      }
    },
    "kill_switch_state": {
      "type": "object",
      "required": ["state", "evidence_refs"],
      "additionalProperties": false,
      "properties": {
        "state": {"$ref": "#/$defs/kill_switch_status"},
        "evidence_refs": {"$ref": "#/$defs/string_array"}
      }
    },
    "health_row": {
      "type": "object",
      "required": [
        "row_id",
        "display_name",
        "category",
        "temporal_band",
        "status",
        "freshness",
        "confidence",
        "authority_ceiling",
        "privacy_state",
        "rights_state",
        "public_private_posture",
        "source_refs",
        "producer_refs",
        "consumer_refs",
        "route_refs",
        "substrate_refs",
        "capability_refs",
        "evidence_envelope_refs",
        "witness_refs",
        "span_refs",
        "grounding_gate_refs",
        "public_event_refs",
        "grounding_key_paths",
        "false_grounding_risk_causes",
        "blocker_reason",
        "warnings",
        "fallback",
        "kill_switch_state",
        "owner",
        "next_probe_due_at",
        "witness_policy",
        "fixture_case"
      ],
      "additionalProperties": false,
      "properties": {
        "row_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z0-9_-]+)+$"},
        "display_name": {"type": "string", "minLength": 1},
        "category": {"$ref": "#/$defs/observation_category"},
        "temporal_band": {"$ref": "#/$defs/temporal_band"},
        "status": {"$ref": "#/$defs/health_status"},
        "freshness": {"$ref": "#/$defs/freshness"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "authority_ceiling": {"$ref": "#/$defs/authority_ceiling"},
        "privacy_state": {"$ref": "#/$defs/privacy_state"},
        "rights_state": {"$ref": "#/$defs/rights_state"},
        "public_private_posture": {"$ref": "#/$defs/public_private_posture"},
        "source_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "producer_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "consumer_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "route_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "substrate_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "capability_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "evidence_envelope_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "witness_refs": {"$ref": "#/$defs/string_array"},
        "span_refs": {"$ref": "#/$defs/string_array"},
        "grounding_gate_refs": {"$ref": "#/$defs/string_array"},
        "public_event_refs": {"$ref": "#/$defs/string_array"},
        "grounding_key_paths": {"$ref": "#/$defs/string_array"},
        "false_grounding_risk_causes": {
          "type": "array",
          "items": {"$ref": "#/$defs/false_grounding_risk_cause"}
        },
        "blocker_reason": {"type": ["string", "null"], "minLength": 1},
        "warnings": {"$ref": "#/$defs/string_array"},
        "fallback": {"$ref": "#/$defs/fallback"},
        "kill_switch_state": {"$ref": "#/$defs/kill_switch_state"},
        "owner": {"type": "string", "minLength": 1},
        "next_probe_due_at": {"type": "string", "format": "date-time"},
        "witness_policy": {"$ref": "#/$defs/witness_policy"},
        "fixture_case": {"$ref": "#/$defs/fixture_case"}
      }
    }
  }
}
