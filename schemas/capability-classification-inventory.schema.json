      "title": "AvailabilityProbeKind",
      "type": "string"
    },
    "AvailabilityState": {
      "enum": [
        "available",
        "private_only",
        "stale",
        "degraded",
        "blocked",
        "unavailable",
        "decommissioned"
      ],
      "title": "AvailabilityState",
      "type": "string"
    },
