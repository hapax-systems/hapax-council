        "alias": {
          "minLength": 1,
          "title": "Alias",
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/MigrationState"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "alias",
        "state",
        "reason"
      ],
      "title": "AliasMigration",
      "type": "object"
    },
    "AuthorityCeiling": {
      "enum": [
        "no_claim",
        "internal_only",
        "speculative",
        "evidence_bound",
        "posterior_bound",
        "public_gate_required"
      ],
      "title": "AuthorityCeiling",
      "type": "string"
    },
    "AvailabilityProbe": {
      "additionalProperties": false,
      "description": "Deterministic witness contract for one classification row.",
      "properties": {
        "probe_id": {
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
          "title": "Probe Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/AvailabilityProbeKind"
        },
        "expected_state": {
          "$ref": "#/$defs/AvailabilityState"
        },
        "witness_ref": {
          "minLength": 1,
          "title": "Witness Ref",
          "type": "string"
        },
        "stale_after_s": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stale After S"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        }
      },
      "required": [
        "probe_id",
        "kind",
        "expected_state",
        "witness_ref"
      ],
      "title": "AvailabilityProbe",
      "type": "object"
    },
    "AvailabilityProbeKind": {
      "enum": [
        "static_record",
        "import_symbol",
        "state_mtime",
        "device_present",
        "route_witness",
        "frame_witness",
        "health_endpoint",
        "container_health",
        "remote_query",
        "operator_gate",
        "decommission_evidence"
