{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hapax.council/schemas/director-scrim-gesture-adapter.schema.json",
  "title": "DirectorScrimGestureAdapterFixtureSet",
  "description": "Contract fixtures for projecting audited DirectorControlMove records into bounded ScrimStateEnvelope-compatible gesture records without expanding public claim authority.",
  "type": "object",
  "required": [
    "schema_version",
    "fixture_set_id",
    "schema_ref",
    "generated_from",
    "declared_at",
    "producer",
    "director_verbs",
    "audit_outcomes",
    "fail_closed_policy",
    "fixtures"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "fixture_set_id": {"type": "string", "minLength": 1},
    "schema_ref": {
      "type": "string",
      "const": "schemas/director-scrim-gesture-adapter.schema.json"
    },
    "generated_from": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "declared_at": {"type": "string", "format": "date-time"},
    "producer": {"type": "string", "minLength": 1},
    "director_verbs": {
      "type": "array",
      "items": {"$ref": "#/$defs/director_verb"},
      "uniqueItems": true
    },
    "audit_outcomes": {
      "type": "array",
      "items": {"$ref": "#/$defs/audit_outcome"},
      "uniqueItems": true
    },
    "fail_closed_policy": {"$ref": "#/$defs/fail_closed_policy"},
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/fixture"}
    }
  },
  "x-required_director_verbs": [
    "foreground",
    "background",
    "hold",
    "suppress",
    "transition",
    "crossfade",
    "intensify",
    "stabilize",
    "route_attention",
    "mark_boundary"
  ],
  "x-required_audit_outcomes": [
    "accepted",
    "rejected",
    "fallback",
    "stale",
    "private_only",
    "dry_run"
  ],
  "x-fail_closed_policy": {
    "scrim_grants_truth": false,
    "scrim_grants_rights": false,
    "scrim_grants_safety": false,
    "scrim_grants_public_status": false,
    "scrim_grants_live_control": false,
    "scrim_grants_monetization_status": false,
    "scrim_public_claim_scope_expansion_allowed": false,
    "blocked_targets_can_foreground": false,
    "blocked_targets_can_intensify": false,
    "blocked_targets_can_be_made_public": false
  },
  "$defs": {
    "director_verb": {
      "type": "string",
      "enum": [
        "foreground",
        "background",
        "hold",
        "suppress",
        "transition",
        "crossfade",
        "intensify",
        "stabilize",
        "route_attention",
        "mark_boundary"
      ]
    },
    "audit_outcome": {
      "type": "string",
      "enum": ["accepted", "rejected", "fallback", "stale", "private_only", "dry_run"]
    },
    "gesture_execution": {
      "type": "string",
      "enum": [
        "gesture",
        "no_op",
        "dry_run",
        "fallback",
        "hold_last_safe",
        "suppress",
        "operator_reason"
      ]
    },
    "target_type": {
      "type": "string",
      "enum": [
        "substrate",
        "spectacle_lane",
        "ward",
        "camera",
        "re_splay_device",
        "private_control",
        "cuepoint",
        "claim_binding",
        "programme",
        "egress_status"
      ]
    },
    "freshness_state": {
      "type": "string",
      "enum": ["fresh", "stale", "missing", "unknown", "not_applicable"]
    },
    "execution_state": {
      "type": "string",
      "enum": [
        "applied",
        "no_op",
        "dry_run",
        "fallback",
        "blocked",
        "operator_reason",
        "unavailable"
      ]
    },
    "fallback_mode": {
      "type": "string",
      "enum": [
        "no_op",
        "dry_run",
        "fallback",
        "operator_reason",
        "hold_last_safe",
        "suppress",
        "private_only",
        "degraded_status",
        "kill_switch"
      ]
    },
    "wcs_status": {
      "type": "string",
      "enum": [
        "mounted",
        "public",
        "private",
        "dry_run",
        "stale",
        "blocked",
        "unavailable",
        "blocked_hardware_no_op"
      ]
    },
    "wcs_evidence_status": {
      "type": "string",
      "enum": [
        "fresh",
        "stale",
        "missing",
        "unknown",
        "blocked",
        "private_only",
        "dry_run",
        "not_applicable"
      ]
    },
    "public_event_policy": {
      "type": "string",
      "enum": [
        "public_live_allowed",
        "public_gate_required",
        "archive_only",
        "dry_run",
        "blocked",
        "not_applicable"
      ]
    },
    "scrim_gesture_type": {
      "type": "string",
      "enum": [
        "soften",
        "thicken",
        "thin",
        "shimmer",
        "ripple",
        "clear_window",
        "mark_boundary",
        "conversion_glow",
        "refusal_dim",
        "correction_glint",
        "neutral_hold"
      ]
    },
    "scrim_gesture_effect": {
      "type": "string",
      "enum": [
        "soften",
        "thicken",
        "thin",
        "shimmer",
        "ripple",
        "clear_window",
        "mark_boundary",
        "conversion_glow",
        "refusal_dim",
        "correction_glint",
        "neutral_hold",
        "scrim.pierce"
      ]
    },
    "scrim_fallback_behavior": {
      "type": "string",
      "enum": [
        "no_op",
        "neutral_hold",
        "minimum_density",
        "suppress_public_cue",
        "dry_run_badge"
      ]
    },
    "ref_list": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "fail_closed_policy": {
      "type": "object",
      "required": [
        "scrim_grants_truth",
        "scrim_grants_rights",
        "scrim_grants_safety",
        "scrim_grants_public_status",
        "scrim_grants_live_control",
        "scrim_grants_monetization_status",
        "scrim_public_claim_scope_expansion_allowed",
        "blocked_targets_can_foreground",
        "blocked_targets_can_intensify",
        "blocked_targets_can_be_made_public"
      ],
      "additionalProperties": false,
      "properties": {
        "scrim_grants_truth": {"type": "boolean", "const": false},
        "scrim_grants_rights": {"type": "boolean", "const": false},
        "scrim_grants_safety": {"type": "boolean", "const": false},
        "scrim_grants_public_status": {"type": "boolean", "const": false},
        "scrim_grants_live_control": {"type": "boolean", "const": false},
        "scrim_grants_monetization_status": {"type": "boolean", "const": false},
        "scrim_public_claim_scope_expansion_allowed": {"type": "boolean", "const": false},
        "blocked_targets_can_foreground": {"type": "boolean", "const": false},
        "blocked_targets_can_intensify": {"type": "boolean", "const": false},
        "blocked_targets_can_be_made_public": {"type": "boolean", "const": false}
      }
    },
    "director_target": {
      "type": "object",
      "required": ["target_type", "target_id", "display_name", "source_refs"],
      "additionalProperties": false,
      "properties": {
        "target_type": {"$ref": "#/$defs/target_type"},
        "target_id": {"type": "string", "minLength": 1},
        "display_name": {"type": "string", "minLength": 1},
        "source_refs": {"$ref": "#/$defs/ref_list"}
      }
    },
    "director_freshness": {
      "type": "object",
      "required": ["state", "checked_at", "blocking_refs"],
      "additionalProperties": false,
      "properties": {
        "state": {"$ref": "#/$defs/freshness_state"},
        "checked_at": {"type": "string", "format": "date-time"},
        "blocking_refs": {"$ref": "#/$defs/ref_list"}
      }
    },
    "director_fallback": {
      "type": "object",
      "required": ["mode", "reason", "operator_facing"],
      "additionalProperties": false,
      "properties": {
        "mode": {"$ref": "#/$defs/fallback_mode"},
        "reason": {"type": "string", "minLength": 1},
        "operator_facing": {"type": "boolean"}
      }
    },
    "audit_event": {
      "type": "object",
      "required": ["event_type", "payload_ref", "health_ref"],
      "additionalProperties": false,
      "properties": {
        "event_type": {
          "type": "string",
          "enum": [
            "director.move.foreground",
            "director.move.background",
            "director.move.hold",
            "director.move.suppress",
            "director.move.transition",
            "director.move.crossfade",
            "director.move.intensify",
            "director.move.stabilize",
            "director.move.route_attention",
            "director.move.mark_boundary"
          ]
        },
        "payload_ref": {"type": "string", "minLength": 1},
        "health_ref": {"type": "string", "minLength": 1}
      }
    },
    "director_move": {
      "type": "object",
      "required": [
        "schema_version",
        "decision_id",
        "emitted_at",
        "director_tier",
        "condition_id",
        "programme_id",
        "verb",
        "target",
        "wcs_source_refs",
        "freshness",
        "execution_state",
        "fallback",
        "public_claim_allowed",
        "audit_event",
        "public_event_ref"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": {"type": "integer", "const": 1},
        "decision_id": {"type": "string", "minLength": 1},
        "emitted_at": {"type": "string", "format": "date-time"},
        "director_tier": {
          "type": "string",
          "enum": ["narrative", "structural", "programme", "operator_control", "adapter"]
        },
        "condition_id": {"type": "string", "minLength": 1},
        "programme_id": {"type": ["string", "null"]},
        "verb": {"$ref": "#/$defs/director_verb"},
        "target": {"$ref": "#/$defs/director_target"},
        "wcs_source_refs": {"$ref": "#/$defs/ref_list"},
        "freshness": {"$ref": "#/$defs/director_freshness"},
        "execution_state": {"$ref": "#/$defs/execution_state"},
        "fallback": {"$ref": "#/$defs/director_fallback"},
        "public_claim_allowed": {"type": "boolean"},
        "audit_event": {"$ref": "#/$defs/audit_event"},
        "public_event_ref": {"type": ["string", "null"]}
      }
    },
    "wcs_move": {
      "type": "object",
      "required": [
        "wcs_snapshot_ref",
        "move_id",
        "source_refs",
        "status",
        "evidence_status",
        "freshness_state",
        "fallback_mode",
        "public_claim_allowed",
        "public_event_policy",
        "blocked_reasons"
      ],
      "additionalProperties": false,
      "properties": {
        "wcs_snapshot_ref": {"type": "string", "minLength": 1},
        "move_id": {"type": "string", "minLength": 1},
        "source_refs": {"$ref": "#/$defs/ref_list"},
        "status": {"$ref": "#/$defs/wcs_status"},
        "evidence_status": {"$ref": "#/$defs/wcs_evidence_status"},
        "freshness_state": {"$ref": "#/$defs/freshness_state"},
        "fallback_mode": {"$ref": "#/$defs/fallback_mode"},
        "public_claim_allowed": {"type": "boolean"},
        "public_event_policy": {"$ref": "#/$defs/public_event_policy"},
        "blocked_reasons": {"$ref": "#/$defs/ref_list"}
      }
    },
    "expected": {
      "type": "object",
      "required": [
        "outcome",
        "execution",
        "gesture_type",
        "gesture_effect",
        "fallback_behavior",
        "public_claim_allowed",
        "reason_code"
      ],
      "additionalProperties": false,
      "properties": {
        "outcome": {"$ref": "#/$defs/audit_outcome"},
        "execution": {"$ref": "#/$defs/gesture_execution"},
        "gesture_type": {"$ref": "#/$defs/scrim_gesture_type"},
        "gesture_effect": {"$ref": "#/$defs/scrim_gesture_effect"},
        "fallback_behavior": {"$ref": "#/$defs/scrim_fallback_behavior"},
        "public_claim_allowed": {"type": "boolean"},
        "reason_code": {"type": "string", "minLength": 1}
      }
    },
    "fixture": {
      "type": "object",
      "required": [
        "fixture_id",
        "family",
        "director_move",
        "wcs",
        "scrim_state_ref",
        "health_ref",
        "target_lane_ref",
        "target_region_refs",
        "reason",
        "request_pierce",
        "requested_intensity",
        "expected"
      ],
      "additionalProperties": false,
      "properties": {
        "fixture_id": {"type": "string", "minLength": 1},
        "family": {"type": "string", "minLength": 1},
        "director_move": {"$ref": "#/$defs/director_move"},
        "wcs": {"$ref": "#/$defs/wcs_move"},
        "scrim_state_ref": {"type": "string", "minLength": 1},
        "health_ref": {"type": "string", "minLength": 1},
        "target_lane_ref": {"type": ["string", "null"]},
        "target_region_refs": {"$ref": "#/$defs/ref_list"},
        "reason": {"type": ["string", "null"]},
        "request_pierce": {"type": "boolean"},
        "requested_intensity": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "expected": {"$ref": "#/$defs/expected"}
      }
    }
  }
}
