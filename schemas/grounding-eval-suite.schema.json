{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hapax.council/schemas/grounding-eval-suite.schema.json",
  "title": "GroundingProviderEvalSuite",
  "description": "Machine-readable eval suite for grounding-provider route adoption.",
  "type": "object",
  "required": [
    "schema_version",
    "suite_id",
    "declared_at",
    "producer",
    "eval_items"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "suite_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_:-]*$"
    },
    "declared_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "eval_items": {
      "type": "array",
      "minItems": 30,
      "maxItems": 50,
      "items": {
        "$ref": "#/$defs/eval_item"
      }
    }
  },
  "$defs": {
    "eval_category": {
      "type": "string",
      "enum": [
        "current_model_release_scouting",
        "content_opportunity_discovery",
        "tier_list_react_video_evidence_packets",
        "local_only_obsidian_facts",
        "contradicted_sources",
        "stale_documentation",
        "public_rights_provenance_claims",
        "refusal_required_prompts",
        "tool_error_surfacing"
      ]
    },
    "provider_kind": {
      "type": "string",
      "enum": [
        "source_acquiring",
        "source_conditioned"
      ]
    },
    "public_claim_mode": {
      "type": "string",
      "enum": [
        "private",
        "dry_run",
        "public_archive_candidate",
        "public_live_candidate",
        "refusal_artifact"
      ]
    },
    "eval_item": {
      "type": "object",
      "required": [
        "eval_id",
        "category",
        "prompt",
        "requires_grounding",
        "allowed_provider_kinds",
        "fixture_refs",
        "expected_behaviors",
        "failure_modes",
        "public_claim_mode",
        "scoring_weights"
      ],
      "additionalProperties": false,
      "properties": {
        "eval_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_:-]*$"
        },
        "category": {
          "$ref": "#/$defs/eval_category"
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "requires_grounding": {
          "type": "boolean",
          "const": true
        },
        "allowed_provider_kinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/provider_kind"
          },
          "uniqueItems": true
        },
        "fixture_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "expected_behaviors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "failure_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "public_claim_mode": {
          "$ref": "#/$defs/public_claim_mode"
        },
        "scoring_weights": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}
