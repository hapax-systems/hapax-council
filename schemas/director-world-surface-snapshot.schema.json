{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hapax.council/schemas/director-world-surface-snapshot.schema.json",
  "title": "DirectorWorldSurfaceSnapshotFixtures",
  "description": "Fixture-backed DirectorWorldSurfaceSnapshot contract. Static prompt hints are visible as hints only and cannot satisfy availability or public/live claimability.",
  "type": "object",
  "required": [
    "schema_version",
    "fixture_set_id",
    "schema_ref",
    "declared_at",
    "generated_from",
    "producer",
    "move_statuses",
    "surface_families",
    "director_move_row_required_fields",
    "director_snapshot_required_fields",
    "snapshots",
    "fail_closed_policy"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "fixture_set_id": {"type": "string", "minLength": 1},
    "schema_ref": {
      "type": "string",
      "const": "schemas/director-world-surface-snapshot.schema.json"
    },
    "declared_at": {"type": "string", "minLength": 1},
    "generated_from": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "not": {"pattern": "^/home/"}},
      "uniqueItems": true,
      "minItems": 1
    },
    "producer": {"type": "string", "minLength": 1},
    "move_statuses": {
      "type": "array",
      "items": {"$ref": "#/$defs/move_status"},
      "uniqueItems": true,
      "minItems": 8
    },
    "surface_families": {
      "type": "array",
      "items": {"$ref": "#/$defs/surface_family"},
      "uniqueItems": true,
      "minItems": 8
    },
    "director_move_row_required_fields": {
      "type": "array",
      "items": {"$ref": "#/$defs/director_move_row_field"},
      "uniqueItems": true,
      "minItems": 31
    },
    "director_snapshot_required_fields": {
      "type": "array",
      "items": {"$ref": "#/$defs/director_snapshot_field"},
      "uniqueItems": true,
      "minItems": 28
    },
    "snapshots": {
      "type": "array",
      "items": {"$ref": "#/$defs/director_snapshot"},
      "minItems": 1
    },
    "fail_closed_policy": {
      "type": "object",
      "required": [
        "static_prompt_hint_satisfies_availability",
        "static_prompt_hint_satisfies_public_live",
        "stale_surface_claims_public_live",
        "private_surface_claims_public_live",
        "dry_run_surface_claims_public_live",
        "blocked_surface_executes_real_move",
        "unavailable_surface_executes_real_move",
        "blocked_hardware_uses_default_fallback",
        "monetization_without_public_live",
        "public_live_without_evidence_obligations"
      ],
      "additionalProperties": false,
      "properties": {
        "static_prompt_hint_satisfies_availability": {"type": "boolean", "const": false},
        "static_prompt_hint_satisfies_public_live": {"type": "boolean", "const": false},
        "stale_surface_claims_public_live": {"type": "boolean", "const": false},
        "private_surface_claims_public_live": {"type": "boolean", "const": false},
        "dry_run_surface_claims_public_live": {"type": "boolean", "const": false},
        "blocked_surface_executes_real_move": {"type": "boolean", "const": false},
        "unavailable_surface_executes_real_move": {"type": "boolean", "const": false},
        "blocked_hardware_uses_default_fallback": {"type": "boolean", "const": false},
        "monetization_without_public_live": {"type": "boolean", "const": false},
        "public_live_without_evidence_obligations": {"type": "boolean", "const": false}
      }
    }
  },
  "x-required_move_statuses": [
    "mounted",
    "public",
    "private",
    "dry_run",
    "stale",
    "blocked",
    "unavailable",
    "blocked_hardware_no_op"
