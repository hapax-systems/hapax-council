        "audit_refs"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": {"type": "integer", "const": 1},
        "snapshot_id": {"type": "string", "pattern": "^director-wcs-snapshot-[a-z0-9-]+$"},
        "generated_at": {"type": "string", "minLength": 1},
        "freshness_ttl_s": {"type": "integer", "minimum": 0},
        "mode": {"$ref": "#/$defs/snapshot_mode"},
        "programme_ref": {"type": ["string", "null"]},
        "condition_ref": {"type": ["string", "null"]},
        "egress_state_ref": {"type": "string", "minLength": 1},
        "audio_state_ref": {"type": "string", "minLength": 1},
        "rights_state_ref": {"type": "string", "minLength": 1},
        "privacy_state_ref": {"type": "string", "minLength": 1},
        "capability_refs": {"$ref": "#/$defs/string_array"},
        "substrate_refs": {"$ref": "#/$defs/string_array"},
        "route_refs": {"$ref": "#/$defs/string_array"},
        "lane_refs": {"$ref": "#/$defs/string_array"},
        "claim_refs": {"$ref": "#/$defs/string_array"},
        "public_event_refs": {"$ref": "#/$defs/string_array"},
        "available_moves": {"type": "array", "items": {"$ref": "#/$defs/move_row"}},
        "blocked_moves": {"type": "array", "items": {"$ref": "#/$defs/move_row"}},
        "dry_run_moves": {"type": "array", "items": {"$ref": "#/$defs/move_row"}},
        "private_only_moves": {"type": "array", "items": {"$ref": "#/$defs/move_row"}},
        "fallback_moves": {"type": "array", "items": {"$ref": "#/$defs/move_row"}},
        "eligible_programme_formats": {"$ref": "#/$defs/string_array"},
        "opportunity_refs": {"$ref": "#/$defs/string_array"},
        "evidence_obligations": {
