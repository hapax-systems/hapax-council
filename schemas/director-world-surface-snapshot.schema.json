        "public_live_claim_allowed",
        "private_claim_allowed",
        "archive_claim_allowed",
        "monetization_claim_allowed",
        "claim_refs",
        "blocker_reasons"
      ],
      "additionalProperties": false,
      "properties": {
        "authority_ceiling": {"$ref": "#/$defs/claim_authority_ceiling"},
        "public_claim_allowed": {"type": "boolean"},
        "public_live_claim_allowed": {"type": "boolean"},
        "private_claim_allowed": {"type": "boolean"},
        "archive_claim_allowed": {"type": "boolean"},
        "monetization_claim_allowed": {"type": "boolean"},
        "claim_refs": {"$ref": "#/$defs/string_array"},
        "blocker_reasons": {"$ref": "#/$defs/string_array"}
      }
    },
    "evidence_obligation": {
      "type": "object",
      "required": [
        "obligation_id",
        "dimension",
        "required_for",
        "evidence_refs",
        "satisfied",
        "missing_refs"
      ],
      "additionalProperties": false,
      "properties": {
        "obligation_id": {"type": "string", "pattern": "^obligation\\.[a-z0-9_.-]+$"},
        "dimension": {"$ref": "#/$defs/obligation_dimension"},
        "required_for": {"$ref": "#/$defs/string_array"},
        "evidence_refs": {"$ref": "#/$defs/string_array"},
        "satisfied": {"type": "boolean"},
        "missing_refs": {"$ref": "#/$defs/string_array"}
      }
    },
    "fallback": {
      "type": "object",
      "required": ["mode", "reason_code", "no_op", "operator_visible_reason", "target_surface_id"],
      "additionalProperties": false,
      "properties": {
        "mode": {"$ref": "#/$defs/fallback_mode"},
        "reason_code": {"type": "string", "minLength": 1},
        "no_op": {"type": "boolean"},
        "operator_visible_reason": {"type": "string", "minLength": 1},
        "target_surface_id": {"type": ["string", "null"]}
      }
    },
    "director_control_move_template": {
      "type": "object",
      "required": [
        "verb",
        "target",
        "execution_state",
        "public_claim_allowed",
        "emits_capability_outcome_envelope"
      ],
      "additionalProperties": false,
      "properties": {
        "verb": {"type": "string", "minLength": 1},
        "target": {"type": "string", "minLength": 1},
        "execution_state": {"type": "string", "minLength": 1},
        "public_claim_allowed": {"type": "boolean"},
        "emits_capability_outcome_envelope": {"type": "boolean", "const": true}
      }
    },
    "move_row": {
      "type": "object",
      "required": [
        "schema_version",
        "move_id",
        "surface_id",
        "status",
        "verb",
        "target_type",
        "target_id",
        "display_name",
        "source_refs",
        "generated_from",
        "intent_families",
        "surface_family",
        "surface_ids",
        "route_refs",
        "evidence_status",
        "freshness",
        "availability",
        "privacy_class",
        "rights_class",
        "monetization_state",
        "grounding_status",
        "claim_authority_ceiling",
        "claim_posture",
        "public_claim_allowed",
        "public_event_policy",
        "evidence_obligations",
        "required_witness_refs",
        "missing_witness_refs",
        "blocked_reasons",
        "blocker_reason",
        "fallback",
        "outcome_policy_ref",
        "director_control_move_template"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": {"type": "integer", "const": 1},
        "move_id": {"type": "string", "pattern": "^move\\.[a-z0-9_.-]+$"},
        "surface_id": {"type": "string", "minLength": 1},
        "status": {"$ref": "#/$defs/move_status"},
        "verb": {"type": "string", "minLength": 1},
        "target_type": {"$ref": "#/$defs/target_type"},
        "target_id": {"type": "string", "minLength": 1},
        "display_name": {"type": "string", "minLength": 1},
        "source_refs": {"$ref": "#/$defs/string_array"},
        "generated_from": {
          "type": "array",
          "items": {"$ref": "#/$defs/generated_from"},
          "uniqueItems": true,
          "minItems": 1
        },
        "intent_families": {"$ref": "#/$defs/string_array"},
        "surface_family": {"$ref": "#/$defs/surface_family"},
        "surface_ids": {"$ref": "#/$defs/string_array"},
        "route_refs": {"$ref": "#/$defs/string_array"},
        "evidence_status": {"$ref": "#/$defs/evidence_status"},
        "freshness": {"$ref": "#/$defs/freshness"},
        "availability": {"$ref": "#/$defs/availability"},
        "privacy_class": {"$ref": "#/$defs/privacy_class"},
        "rights_class": {"$ref": "#/$defs/rights_class"},
        "monetization_state": {"$ref": "#/$defs/monetization_state"},
        "grounding_status": {"$ref": "#/$defs/grounding_status"},
        "claim_authority_ceiling": {"$ref": "#/$defs/claim_authority_ceiling"},
        "claim_posture": {"$ref": "#/$defs/claim_posture"},
        "public_claim_allowed": {"type": "boolean"},
        "public_event_policy": {"$ref": "#/$defs/public_event_policy"},
        "evidence_obligations": {
          "type": "array",
          "items": {"$ref": "#/$defs/evidence_obligation"},
          "minItems": 1
        },
        "required_witness_refs": {"$ref": "#/$defs/string_array"},
        "missing_witness_refs": {"$ref": "#/$defs/string_array"},
        "blocked_reasons": {"$ref": "#/$defs/string_array"},
        "blocker_reason": {"type": ["string", "null"]},
        "fallback": {"$ref": "#/$defs/fallback"},
        "outcome_policy_ref": {"type": "string", "minLength": 1},
        "director_control_move_template": {"$ref": "#/$defs/director_control_move_template"}
      },
      "allOf": [
        {
          "if": {"properties": {"generated_from": {"const": ["static_prompt_hint"]}}},
          "then": {
            "properties": {
              "availability": {
                "properties": {
                  "available_to_attempt": {"const": false},
                  "available_to_render": {"const": false},
                  "available_to_observe": {"const": false},
                  "available_to_claim_private": {"const": false},
                  "available_to_claim_public_live": {"const": false},
                  "available_to_archive": {"const": false},
                  "available_to_monetize": {"const": false},
                  "available_to_convert": {"const": false}
                }
              },
              "public_claim_allowed": {"const": false}
            }
          }
        },
        {
          "if": {"properties": {"status": {"enum": ["stale", "blocked", "unavailable", "blocked_hardware_no_op"]}}},
          "then": {
            "properties": {
              "public_claim_allowed": {"const": false},
              "blocked_reasons": {"minItems": 1},
              "blocker_reason": {"type": "string", "minLength": 1}
            }
          }
        },
        {
          "if": {"properties": {"public_claim_allowed": {"const": true}}},
          "then": {
            "properties": {
              "status": {"const": "public"},
              "claim_authority_ceiling": {"const": "public_gate_required"},
              "required_witness_refs": {"minItems": 1},
              "missing_witness_refs": {"maxItems": 0},
              "blocked_reasons": {"maxItems": 0}
            }
          }
        },
        {
          "if": {"properties": {"status": {"const": "blocked_hardware_no_op"}}},
          "then": {
            "properties": {
              "target_type": {"const": "hardware_device"},
              "fallback": {
                "properties": {
                  "mode": {"const": "operator_reason"},
                  "no_op": {"const": true}
                }
              }
            }
          }
        }
      ]
    },
    "prompt_summary": {
      "type": "object",
      "required": ["checked_at", "mode", "available", "dry_run", "blocked", "private_only", "prompt_hint_refs"],
      "additionalProperties": false,
      "properties": {
