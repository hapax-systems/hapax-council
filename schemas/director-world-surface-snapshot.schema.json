        "substrate_refs",
        "route_refs",
        "lane_refs",
        "claim_refs",
        "public_event_refs",
        "available_moves",
        "blocked_moves",
        "dry_run_moves",
        "private_only_moves",
        "fallback_moves",
        "eligible_programme_formats",
        "opportunity_refs",
        "evidence_obligations",
        "refusal_or_correction_candidates",
        "prompt_summary",
        "audit_refs"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "freshness": {
      "type": "object",
      "required": ["state", "checked_at", "ttl_s", "observed_age_s", "source_ref"],
      "additionalProperties": false,
      "properties": {
        "state": {"$ref": "#/$defs/freshness_state"},
        "checked_at": {"type": "string", "minLength": 1},
        "ttl_s": {"type": ["integer", "null"], "minimum": 0},
        "observed_age_s": {"type": ["integer", "null"], "minimum": 0},
        "source_ref": {"type": ["string", "null"]}
      }
    },
    "availability": {
      "type": "object",
      "required": [
        "available_to_attempt",
        "available_to_render",
        "available_to_observe",
        "available_to_claim_private",
        "available_to_claim_public_live",
        "available_to_archive",
        "available_to_monetize",
        "available_to_convert"
      ],
      "additionalProperties": false,
      "properties": {
        "available_to_attempt": {"type": "boolean"},
        "available_to_render": {"type": "boolean"},
        "available_to_observe": {"type": "boolean"},
        "available_to_claim_private": {"type": "boolean"},
        "available_to_claim_public_live": {"type": "boolean"},
        "available_to_archive": {"type": "boolean"},
        "available_to_monetize": {"type": "boolean"},
        "available_to_convert": {"type": "boolean"}
      }
    },
    "claim_posture": {
      "type": "object",
