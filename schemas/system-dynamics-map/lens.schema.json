{
  "$id": "https://hapax.local/schema/system-dynamics-map/lens.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "aggregation": {
      "properties": {
        "lossy": {
          "type": "boolean"
        },
        "mode": {
          "minLength": 1,
          "type": "string"
        },
        "reversible": {
          "type": "boolean"
        }
      },
      "required": [
        "mode",
        "lossy",
        "reversible"
      ],
      "type": "object"
    },
    "hidden_edge_ids": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "hidden_node_ids": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "id": {
      "minLength": 1,
      "type": "string"
    },
    "label": {
      "minLength": 1,
      "type": "string"
    },
    "layout": {
      "minLength": 1,
      "type": "string"
    },
    "max_resolution": {
      "minimum": 1,
      "type": "integer"
    },
    "source_snapshot": {
      "minLength": 1,
      "type": "string"
    },
    "state_mode": {
      "minLength": 1,
      "type": "string"
    },
    "validation_status": {
      "minLength": 1,
      "type": "string"
    },
    "visible_edge_ids": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "visible_layers": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "visible_node_ids": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "visible_statuses": {
      "items": {
        "enum": [
          "asserted",
          "inferred",
          "observed",
          "simulated",
          "rendered",
          "candidate"
        ],
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "id",
    "label",
    "visible_layers",
    "visible_statuses",
    "max_resolution",
    "layout",
    "state_mode",
    "visible_node_ids",
    "visible_edge_ids",
    "hidden_node_ids",
    "hidden_edge_ids",
    "validation_status",
    "source_snapshot",
    "aggregation"
  ],
  "title": "System dynamics map lens",
  "type": "object"
}
