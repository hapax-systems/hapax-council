  "additionalProperties": false,
  "description": "Schema discipline for canonical WCS semantic recruitment rows and projection fixtures.",
  "properties": {
    "$schema": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
