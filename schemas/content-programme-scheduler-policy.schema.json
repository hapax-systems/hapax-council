{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hapax.council/schemas/content-programme-scheduler-policy.schema.json",
  "title": "ContentProgrammeSchedulerPolicy",
  "description": "Fail-closed scheduler policy for promoting discovered content opportunities into private, dry-run, public, archive, monetized, refusal, or correction routes.",
  "type": "object",
  "required": [
    "schema_version",
    "policy_id",
    "schema_ref",
    "default_discovery_source",
    "promotion_ladder",
    "routes",
    "public_routes",
    "hard_public_gates",
    "operator_boundary_policy",
    "default_exploration_budget",
    "cooldowns",
    "audit_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "policy_id": {"type": "string", "const": "content_programme_scheduler_policy"},
    "schema_ref": {
      "type": "string",
      "const": "schemas/content-programme-scheduler-policy.schema.json"
    },
    "default_discovery_source": {"type": "string", "const": "content_discovery_decision"},
    "promotion_ladder": {
      "type": "array",
      "prefixItems": [
        {"const": "discovered"},
        {"const": "scored"},
        {"const": "dry_run"},
        {"const": "private_archive"},
        {"const": "public_live"},
        {"const": "clipped_replayed"},
        {"const": "monetized"}
      ],
      "minItems": 7,
      "maxItems": 7
    },
    "routes": {
      "type": "array",
      "prefixItems": [
        {"const": "private"},
        {"const": "dry_run"},
        {"const": "public_live"},
        {"const": "public_archive"},
        {"const": "monetized"},
        {"const": "refusal"},
        {"const": "correction"}
      ],
      "minItems": 7,
      "maxItems": 7
    },
    "public_routes": {
      "type": "array",
      "prefixItems": [
        {"const": "public_live"},
        {"const": "public_archive"},
        {"const": "monetized"}
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "hard_public_gates": {
      "type": "array",
      "items": {"$ref": "#/$defs/hard_public_gate"},
      "contains": {"const": "no_expert_system"},
      "minItems": 11,
      "uniqueItems": true
    },
    "operator_boundary_policy": {"$ref": "#/$defs/operator_boundary_policy"},
    "default_exploration_budget": {"$ref": "#/$defs/exploration_budget"},
    "cooldowns": {"$ref": "#/$defs/cooldowns"},
    "audit_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "contains": {"const": "schemas/content-opportunity-model.schema.json"},
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "$defs": {
    "hard_public_gate": {
      "type": "string",
      "enum": [
        "no_expert_system",
        "rights",
        "provenance",
        "privacy",
        "monetization",
        "audio",
        "egress",
        "wcs_health",
        "evidence",
        "witness",
        "public_event"
      ]
    },
    "operator_boundary_policy": {
      "type": "object",
      "required": [
        "single_operator_only",
        "manual_calendar_allowed",
        "operator_nominated_default_allowed",
        "request_queue_allowed",
        "supporter_controlled_show_allowed",
        "community_moderation_allowed",
        "personalized_supporter_treatment_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "single_operator_only": {"type": "boolean", "const": true},
        "manual_calendar_allowed": {"type": "boolean", "const": false},
        "operator_nominated_default_allowed": {"type": "boolean", "const": false},
        "request_queue_allowed": {"type": "boolean", "const": false},
        "supporter_controlled_show_allowed": {"type": "boolean", "const": false},
        "community_moderation_allowed": {"type": "boolean", "const": false},
        "personalized_supporter_treatment_allowed": {"type": "boolean", "const": false}
      }
    },
    "exploration_budget": {
      "type": "object",
      "required": [
        "budget_window",
        "max_exploration_fraction",
        "used_fraction",
        "remaining_fraction",
        "private_first",
        "max_public_risk_tier"
      ],
      "additionalProperties": false,
      "properties": {
        "budget_window": {"type": "string", "enum": ["run", "daily", "weekly"]},
        "max_exploration_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "used_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "remaining_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "private_first": {"type": "boolean", "const": true},
        "max_public_risk_tier": {
          "type": "string",
          "enum": ["minimal", "low", "medium", "high"]
        }
      }
    },
    "cooldowns": {
      "type": "object",
      "required": [
        "format_cooldown_s",
        "source_cooldown_s",
        "subject_cluster_cooldown_s",
        "public_mode_cooldown_s",
        "refusal_cooldown_s"
      ],
      "additionalProperties": false,
      "properties": {
        "format_cooldown_s": {"type": "integer", "minimum": 0},
        "source_cooldown_s": {"type": "integer", "minimum": 0},
        "subject_cluster_cooldown_s": {"type": "integer", "minimum": 0},
        "public_mode_cooldown_s": {"type": "integer", "minimum": 0},
        "refusal_cooldown_s": {"type": "integer", "minimum": 0}
      }
    }
  }
}
