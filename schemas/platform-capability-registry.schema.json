{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hapax.local/schemas/platform-capability-registry.schema.json",
  "title": "PlatformCapabilityRegistry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_schema",
    "registry_id",
    "schema_ref",
    "declared_at",
    "capacity_invariant",
    "generated_from",
    "required_route_ids",
    "omitted_capability_shapes",
    "routes"
  ],
  "properties": {
    "registry_schema": {"const": 1},
    "registry_id": {"type": "string", "minLength": 1},
    "schema_ref": {"const": "schemas/platform-capability-registry.schema.json"},
    "declared_at": {"type": "string", "format": "date-time"},
    "capacity_invariant": {"type": "string", "minLength": 1},
    "generated_from": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "required_route_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[a-z0-9_]+\\.[a-z0-9_]+\\.[a-z0-9_]+$"}
    },
    "omitted_capability_shapes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/capability_shape_descriptor"}
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/platform_capability_route"}
    }
  },
  "$defs": {
    "platform": {
      "enum": ["agy", "api", "claude", "codex", "gemini", "glmcp", "local_tool", "vibe"]
    },
    "mode": {
      "enum": ["headless", "interactive", "local", "receipt_only", "review"]
    },
    "profile": {
      "enum": [
        "api_frontier",
        "deterministic",
        "direct",
        "flash",
        "full",
        "haiku",
        "jr",
        "lite",
        "openrouter",
        "opus",
        "provider_gateway",
        "sonnet",
        "spark",
        "worker"
      ]
    },
    "route_state": {
      "enum": ["active", "blocked"]
    },
    "capability_shape_class": {
      "enum": [
        "model_provider",
        "local_compute",
        "publication_bus",
        "money_rail",
        "mcp_connector",
        "orchestrator",
        "subagent",
        "cockpit_command",
        "cctv_runner",
        "self_inline"
      ]
    },
    "capability_shape_state": {
      "enum": ["evidence_only", "intake_required", "measurement_pending", "deprecated"]
    },
    "capability_shape_freshness_state": {
      "enum": ["fresh", "stale", "missing", "asserted_only", "contradictory"]
    },
    "auth_surface": {
      "enum": ["api_key", "local", "oauth", "operator_session", "subscription", "unknown", "vertex"]
    },
    "capacity_pool": {
      "enum": ["api_paid_spend", "bootstrap_budget", "local_compute", "subscription_quota"]
    },
    "authority_ceiling": {
      "enum": ["authoritative", "frontier_review_required", "read_only", "support_only"]
    },
    "filesystem_access": {
      "enum": ["none", "read_only", "read_write"]
    },
    "shell_access": {
      "enum": ["none", "read_only", "full"]
    },
    "privacy_posture": {
      "enum": [
        "local_private",
        "provider_private",
        "provider_training_unknown",
        "public_risk",
        "unknown"
      ]
    },
    "quality_floor": {
      "enum": ["deterministic_ok", "frontier_required", "frontier_review_required"]
    },
    "context_class": {
      "enum": ["small", "medium", "large", "very_large", "unknown"]
    },
    "quota_source": {
      "enum": ["cli", "cloud_monitoring", "ledger", "manual", "none", "otel", "provider_console", "unknown"]
    },
    "cost_source": {
      "enum": ["estimated", "ledger", "none", "otel", "provider_usage", "unknown"]
    },
    "resource_source": {
      "enum": ["infra_observation_spine", "local_probe", "none", "unknown"]
    },
    "approval_posture": {
      "enum": [
        "auto_edit_policy_firewalled",
        "default_deny_enable_latch",
        "ide_terminal_auto_approve",
        "no_ask_hooks_enforced",
        "plan_mode_read_only",
        "programmatic_auto_approve_task_scoped",
        "unknown"
      ]
    },
    "capability_tier": {
      "enum": [
        "audited_full_worker",
        "frontier_fallback",
        "frontier_full",
        "jr_plus",
        "read_only_support"
      ]
    },
    "worker_tier": {
      "enum": [
        "audited_full_worker",
        "bounded_worker",
        "fallback_worker",
        "full_worker",
        "read_only_sidecar"
      ]
    },
    "timestamp_or_null": {
      "anyOf": [
        {"type": "string", "format": "date-time"},
        {"type": "null"}
      ]
    },
    "duration": {
      "type": "string",
      "pattern": "^[1-9][0-9]*[smhd]$"
    },
    "freshness_surface_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_refs", "blocked_reasons"],
      "anyOf": [
        {"required": ["evidence_refs"], "properties": {"evidence_refs": {"minItems": 1}}},
        {"required": ["blocked_reasons"], "properties": {"blocked_reasons": {"minItems": 1}}}
      ],
      "properties": {
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "blocked_reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "freshness_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability", "quota", "resource", "provider_docs"],
      "properties": {
        "capability": {"$ref": "#/$defs/freshness_surface_evidence"},
        "quota": {"$ref": "#/$defs/freshness_surface_evidence"},
        "resource": {"$ref": "#/$defs/freshness_surface_evidence"},
        "provider_docs": {"$ref": "#/$defs/freshness_surface_evidence"}
      }
    },
    "score_confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "confidence", "evidence_refs", "observed_at", "stale_after"],
      "properties": {
        "score": {"type": "integer", "minimum": 0, "maximum": 5},
        "confidence": {"type": "integer", "minimum": 0, "maximum": 5},
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "observed_at": {"$ref": "#/$defs/timestamp_or_null"},
        "stale_after": {"$ref": "#/$defs/duration"}
      }
    },
    "capability_scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grounding",
        "governance_reasoning",
        "source_editing",
        "architecture",
        "ambiguity_resolution",
        "long_context",
        "current_docs_grounding",
        "multimodal_verification",
        "runtime_debugging",
        "test_authoring",
        "coordination_reliability",
        "privacy_safety",
        "public_claim_safety",
        "local_calibration"
      ],
      "properties": {
        "grounding": {"$ref": "#/$defs/score_confidence"},
        "governance_reasoning": {"$ref": "#/$defs/score_confidence"},
        "source_editing": {"$ref": "#/$defs/score_confidence"},
        "architecture": {"$ref": "#/$defs/score_confidence"},
        "ambiguity_resolution": {"$ref": "#/$defs/score_confidence"},
        "long_context": {"$ref": "#/$defs/score_confidence"},
        "current_docs_grounding": {"$ref": "#/$defs/score_confidence"},
        "multimodal_verification": {"$ref": "#/$defs/score_confidence"},
        "runtime_debugging": {"$ref": "#/$defs/score_confidence"},
        "test_authoring": {"$ref": "#/$defs/score_confidence"},
        "coordination_reliability": {"$ref": "#/$defs/score_confidence"},
        "privacy_safety": {"$ref": "#/$defs/score_confidence"},
        "public_claim_safety": {"$ref": "#/$defs/score_confidence"},
        "local_calibration": {"$ref": "#/$defs/score_confidence"}
      }
    },
    "benchmark_coverage_state": {
      "enum": ["unknown", "covered", "partial", "absent", "stale", "misleading"]
    },
    "benchmark_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coverage_state", "benchmark_refs", "gap_refs", "evidence_refs"],
      "properties": {
        "coverage_state": {"$ref": "#/$defs/benchmark_coverage_state"},
        "benchmark_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "gap_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "fixed_route_overhead": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixed_cost_score",
        "setup_seconds",
        "context_tokens",
        "coordination_steps",
        "evidence_refs",
        "projection_ref"
      ],
      "properties": {
        "fixed_cost_score": {"type": "integer", "minimum": 0, "maximum": 5},
        "setup_seconds": {"type": "integer", "minimum": 0},
        "context_tokens": {"type": "integer", "minimum": 0},
        "coordination_steps": {"type": "integer", "minimum": 0},
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "projection_ref": {
          "anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]
        }
      }
    },
    "local_calibration_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "posterior_receipt_refs", "evidence_refs", "observed_at", "stale_after"],
      "properties": {
        "source": {"type": "string", "minLength": 1},
        "posterior_receipt_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "observed_at": {"$ref": "#/$defs/timestamp_or_null"},
        "stale_after": {"$ref": "#/$defs/duration"}
      }
    },
    "historical_performance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "calibration_window",
        "evidence_refs",
        "class_posteriors",
        "benchmark_coverage",
        "fixed_route_overhead",
        "local_calibration_provenance"
      ],
      "properties": {
        "calibration_window": {"type": "string", "minLength": 1},
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "class_posteriors": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/score_confidence"}
        },
        "benchmark_coverage": {"$ref": "#/$defs/benchmark_coverage"},
        "fixed_route_overhead": {"$ref": "#/$defs/fixed_route_overhead"},
        "local_calibration_provenance": {"$ref": "#/$defs/local_calibration_provenance"}
      }
    },
    "tool_authority_use": {
      "enum": ["read", "write", "execute", "verify"]
    },
    "tool_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool_id", "available", "authority_use", "observed_at", "stale_after", "evidence_ref"],
      "properties": {
        "tool_id": {"type": "string", "minLength": 1},
        "available": {"type": "boolean"},
        "authority_use": {
          "type": "array",
          "items": {"$ref": "#/$defs/tool_authority_use"}
        },
        "observed_at": {"$ref": "#/$defs/timestamp_or_null"},
        "stale_after": {"$ref": "#/$defs/duration"},
        "evidence_ref": {"type": "string", "minLength": 1}
      }
    },
    "mutability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vault_docs", "source", "runtime", "public", "provider_spend"],
      "properties": {
        "vault_docs": {"type": "boolean"},
        "source": {"type": "boolean"},
        "runtime": {"type": "boolean"},
        "public": {"type": "boolean"},
        "provider_spend": {"type": "boolean"}
      }
    },
    "tool_access": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filesystem", "shell", "browser", "mcp"],
      "properties": {
        "filesystem": {"$ref": "#/$defs/filesystem_access"},
        "shell": {"$ref": "#/$defs/shell_access"},
        "browser": {"type": "boolean"},
        "mcp": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "quality_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eligible_quality_floors",
        "explicit_equivalence_records",
        "excluded_task_classes"
      ],
      "properties": {
        "eligible_quality_floors": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/quality_floor"}
        },
        "explicit_equivalence_records": {
          "type": "array",
          "items": {"type": "string"}
        },
        "excluded_task_classes": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "context_limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_context_class"],
      "properties": {
        "max_context_class": {"$ref": "#/$defs/context_class"}
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["quota_source", "cost_source", "resource_source"],
      "properties": {
        "quota_source": {"$ref": "#/$defs/quota_source"},
        "cost_source": {"$ref": "#/$defs/cost_source"},
        "resource_source": {"$ref": "#/$defs/resource_source"}
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_checked_at",
        "capability_stale_after",
        "quota_checked_at",
        "quota_stale_after",
        "resource_checked_at",
        "resource_stale_after",
        "provider_docs_checked_at",
        "provider_docs_stale_after",
        "evidence"
      ],
      "properties": {
        "capability_checked_at": {"$ref": "#/$defs/timestamp_or_null"},
        "capability_stale_after": {"$ref": "#/$defs/duration"},
        "quota_checked_at": {"$ref": "#/$defs/timestamp_or_null"},
        "quota_stale_after": {"$ref": "#/$defs/duration"},
        "resource_checked_at": {"$ref": "#/$defs/timestamp_or_null"},
        "resource_stale_after": {"$ref": "#/$defs/duration"},
        "provider_docs_checked_at": {"$ref": "#/$defs/timestamp_or_null"},
        "provider_docs_stale_after": {"$ref": "#/$defs/duration"},
        "evidence": {"$ref": "#/$defs/freshness_evidence"}
      }
    },
    "model_id": {
      "enum": [
        "claude-opus-4-8",
        "claude-opus-4-6",
        "claude-sonnet-4-6",
        "claude-haiku-4-5",
        "claude-fable-5",
        "gpt-5.5",
        "gpt-5.3-codex-spark",
        "gpt-oss-120b",
        "command-r-08-2024",
        "mistral-medium-3.5",
        "gemini-3.1-pro-preview",
        "gemini-3.5-flash",
        "z_ai-glm-5",
        "z_ai-glm-5.2",
        "unknown"
      ]
    },
    "effort": {
      "enum": ["none", "low", "medium", "high", "xhigh", "max"]
    },
    "context_mode": {
      "enum": ["standard", "extended_1m", "not_applicable"]
    },
    "fast_mode": {
      "enum": ["off", "fast", "not_applicable"]
    },
    "quantization": {
      "enum": ["none", "exl3_4_0bpw", "exl3_5_0bpw", "not_applicable"]
    },
    "execution_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_id", "effort", "context_mode", "fast_mode", "quantization"],
      "properties": {
        "model_id": {"$ref": "#/$defs/model_id"},
        "effort": {"$ref": "#/$defs/effort"},
        "context_mode": {"$ref": "#/$defs/context_mode"},
        "fast_mode": {"$ref": "#/$defs/fast_mode"},
        "quantization": {"$ref": "#/$defs/quantization"}
      }
    },
    "descriptor_variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variant_id"],
      "properties": {
        "variant_id": {"type": "string", "minLength": 1},
        "knobs_override": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "score_delta": {
          "type": "object",
          "additionalProperties": {"type": "integer"}
        },
        "scores_inherited_from": {
          "anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]
        },
        "blocked_reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "weakness_id": {
      "enum": [
        "W1",
        "W2",
        "W3",
        "W4",
        "W5",
        "W6",
        "W7",
        "W8",
        "W9",
        "W10",
        "W11",
        "W12",
        "W13",
        "W14",
        "W15",
        "W16",
        "W17",
        "W18"
      ]
    },
    "lever_id": {
      "enum": [
        "L1",
        "L2",
        "L3",
        "L4",
        "L5",
        "L6",
        "L7",
        "L8",
        "L9",
        "L10",
        "L11",
        "L12",
        "L13",
        "L14",
        "L15",
        "L16"
      ]
    },
    "weakness_applicability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weakness_id", "dominant", "evidence_refs"],
      "properties": {
        "weakness_id": {"$ref": "#/$defs/weakness_id"},
        "dominant": {"type": "boolean"},
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "notes": {
          "anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]
        }
      }
    },
    "implemented_lever": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lever_id", "evidence_refs"],
      "properties": {
        "lever_id": {"$ref": "#/$defs/lever_id"},
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "notes": {
          "anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]
        }
      }
    },
    "waived_lever": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weakness_id", "lever_id", "reason", "evidence_refs"],
      "properties": {
        "weakness_id": {"$ref": "#/$defs/weakness_id"},
        "lever_id": {"$ref": "#/$defs/lever_id"},
        "reason": {"type": "string", "minLength": 1},
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "capability_shape_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor_schema",
        "shape_id",
        "shape_class",
        "carrier_family",
        "summary",
        "harness_shape",
        "authority_ceiling",
        "shape_state",
        "demand_eligible",
        "route_ids",
        "weakness_applicability",
        "implemented_levers",
        "waived_levers",
        "resource_semantics",
        "spend_semantics",
        "observability",
        "failure_classes",
        "measurement_plan_refs",
        "remediation_refs",
        "surface_delta_signal",
        "observed_at",
        "stale_after",
        "freshness_state",
        "evidence_refs",
        "blocked_reasons"
      ],
      "properties": {
        "descriptor_schema": {"const": 1},
        "shape_id": {"type": "string", "minLength": 1},
        "shape_class": {"$ref": "#/$defs/capability_shape_class"},
        "carrier_family": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "harness_shape": {"type": "string", "minLength": 1},
        "authority_ceiling": {"$ref": "#/$defs/authority_ceiling"},
        "shape_state": {"$ref": "#/$defs/capability_shape_state"},
        "demand_eligible": {"const": false},
        "route_ids": {"type": "array", "maxItems": 0},
        "weakness_applicability": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/weakness_applicability"}
        },
        "implemented_levers": {
          "type": "array",
          "items": {"$ref": "#/$defs/implemented_lever"}
        },
        "waived_levers": {
          "type": "array",
          "items": {"$ref": "#/$defs/waived_lever"}
        },
        "resource_semantics": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "spend_semantics": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "observability": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "failure_classes": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "measurement_plan_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "remediation_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "surface_delta_signal": {"type": "string", "minLength": 1},
        "observed_at": {"$ref": "#/$defs/timestamp_or_null"},
        "stale_after": {"$ref": "#/$defs/duration"},
        "freshness_state": {"$ref": "#/$defs/capability_shape_freshness_state"},
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "blocked_reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "platform_capability_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_schema",
        "route_id",
        "platform",
        "mode",
        "profile",
        "launcher",
        "sanctioned_wrapper",
        "summary",
        "notes",
        "route_state",
        "blocked_reasons",
        "model_or_engine",
        "execution_descriptor",
        "approval_posture",
        "capability_tier",
        "worker_tier",
        "auth_surface",
        "capacity_pool",
        "mutability",
        "authority_ceiling",
        "tool_access",
        "privacy_posture",
        "weakness_applicability",
        "implemented_levers",
        "waived_levers",
