{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hapax.council/schemas/director-control-move-audit-log.schema.json",
  "title": "DirectorControlMoveAuditRecord",
  "description": "Persisted audit record for director control moves, including no-op, dry-run, unavailable, fallback, and mark-boundary projections.",
  "type": "object",
  "required": [
    "schema_version",
    "audit_id",
    "recorded_at",
    "decision_id",
    "programme_id",
    "run_id",
    "lane_id",
    "verb",
    "reason",
    "source_move",
    "execution_state",
    "result_state",
    "evidence",
    "gate_results",
    "fallback",
    "rendered_evidence",
    "mark_boundary_projection",
    "audit_trail",
    "metrics",
    "public_claim_allowed"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "audit_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_:-]*$"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "programme_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "lane_id": {
      "type": "string",
      "minLength": 1
    },
    "verb": {
      "$ref": "#/$defs/director_verb"
    },
    "reason": {
      "type": "object",
      "required": ["summary", "category", "source_refs"],
      "additionalProperties": false,
      "properties": {
        "summary": {"type": "string", "minLength": 1},
        "category": {
          "type": "string",
          "enum": [
            "programme_goal",
            "evidence_freshness",
            "gate_result",
            "operator_control",
            "fallback_policy",
            "unavailable_target",
            "mark_boundary",
            "adapter_request"
          ]
        },
        "source_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "source_move": {
      "type": "object",
      "required": ["director_move_ref", "director_tier", "target_type", "target_id"],
      "additionalProperties": false,
      "properties": {
        "director_move_ref": {"type": "string", "minLength": 1},
        "director_tier": {"type": "string", "minLength": 1},
        "target_type": {"type": "string", "minLength": 1},
        "target_id": {"type": "string", "minLength": 1}
      }
    },
    "execution_state": {
      "type": "string",
      "enum": ["applied", "no_op", "dry_run", "fallback", "blocked", "operator_reason", "unavailable"]
    },
    "result_state": {
      "type": "string",
      "enum": ["applied", "no_op", "dry_run", "fallback", "blocked", "unavailable"]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/evidence"}
    },
    "gate_results": {
      "type": "object",
      "required": [
        "no_expert_system",
        "public_claim",
        "rights",
        "privacy",
        "egress",
        "audio",
        "monetization",
        "archive",
        "cuepoint_chapter"
      ],
      "additionalProperties": false,
      "properties": {
        "no_expert_system": {"$ref": "#/$defs/gate_result"},
        "public_claim": {"$ref": "#/$defs/gate_result"},
        "rights": {"$ref": "#/$defs/gate_result"},
        "privacy": {"$ref": "#/$defs/gate_result"},
        "egress": {"$ref": "#/$defs/gate_result"},
        "audio": {"$ref": "#/$defs/gate_result"},
        "monetization": {"$ref": "#/$defs/gate_result"},
        "archive": {"$ref": "#/$defs/gate_result"},
        "cuepoint_chapter": {"$ref": "#/$defs/gate_result"}
      }
    },
    "fallback": {
      "type": "object",
      "required": ["mode", "reason", "applied", "operator_facing", "substitute_ref", "next_action"],
      "additionalProperties": false,
      "properties": {
        "mode": {"$ref": "#/$defs/fallback_mode"},
        "reason": {"type": "string", "minLength": 1},
        "applied": {"type": "boolean"},
        "operator_facing": {"type": "boolean"},
        "substitute_ref": {"type": ["string", "null"]},
        "next_action": {"type": ["string", "null"]}
      }
    },
    "rendered_evidence": {
      "type": "object",
      "required": ["summary", "payload_ref", "artifact_refs", "replay_ref", "scorecard_ref"],
      "additionalProperties": false,
      "properties": {
        "summary": {"type": "string", "minLength": 1},
        "payload_ref": {"type": "string", "minLength": 1},
        "artifact_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "replay_ref": {"type": ["string", "null"]},
        "scorecard_ref": {"type": ["string", "null"]}
      }
    },
    "mark_boundary_projection": {
      "type": "object",
      "required": [
        "is_mark_boundary",
        "programme_boundary_ref",
        "chapter_candidate",
        "clip_candidate",
        "public_event_ref",
        "force_publication"
      ],
      "additionalProperties": false,
      "properties": {
        "is_mark_boundary": {"type": "boolean"},
        "programme_boundary_ref": {"type": ["string", "null"]},
        "chapter_candidate": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/chapter_candidate"}]},
        "clip_candidate": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/clip_candidate"}]},
        "public_event_ref": {"type": ["string", "null"]},
        "force_publication": {"type": "boolean", "const": false}
      }
    },
    "audit_trail": {
      "type": "object",
      "required": ["sinks", "consumers", "duplicate_key", "jsonl_ref", "artifact_ref"],
      "additionalProperties": false,
      "properties": {
        "sinks": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/audit_sink"},
          "uniqueItems": true
        },
        "consumers": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/audit_consumer"},
          "uniqueItems": true
        },
        "duplicate_key": {"type": "string", "minLength": 1},
        "jsonl_ref": {"type": "string", "minLength": 1},
        "artifact_ref": {"type": "string", "minLength": 1}
      }
    },
    "metrics": {
      "type": "object",
      "required": ["counter_name", "labels", "outcome", "observed_value"],
      "additionalProperties": false,
      "properties": {
        "counter_name": {"type": "string", "minLength": 1},
        "labels": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "outcome": {"type": "string", "minLength": 1},
        "observed_value": {"type": "number"}
      }
    },
    "public_claim_allowed": {
      "type": "boolean"
    }
  },
  "$defs": {
    "director_verb": {
      "type": "string",
      "enum": [
        "foreground",
        "background",
        "hold",
        "suppress",
        "transition",
        "crossfade",
        "intensify",
        "stabilize",
        "route_attention",
        "mark_boundary"
      ]
    },
    "evidence_status": {
      "type": "string",
      "enum": ["fresh", "stale", "missing", "unknown", "not_applicable"]
    },
    "evidence": {
      "type": "object",
      "required": ["source_type", "ref", "status", "observed_at", "age_s", "ttl_s", "detail"],
      "additionalProperties": false,
      "properties": {
        "source_type": {"type": "string", "minLength": 1},
        "ref": {"type": "string", "minLength": 1},
        "status": {"$ref": "#/$defs/evidence_status"},
        "observed_at": {"type": ["string", "null"], "format": "date-time"},
        "age_s": {"type": ["number", "null"], "minimum": 0},
        "ttl_s": {"type": ["number", "null"], "minimum": 0},
        "detail": {"type": "string", "minLength": 1}
      }
    },
    "gate_state": {
      "type": "string",
      "enum": ["pass", "fail", "dry_run", "private_only", "unavailable", "not_applicable"]
    },
    "gate_result": {
      "type": "object",
      "required": ["gate", "state", "passed", "evidence_refs", "denial_reasons"],
      "additionalProperties": false,
      "properties": {
        "gate": {"type": "string", "minLength": 1},
        "state": {"$ref": "#/$defs/gate_state"},
        "passed": {"type": "boolean"},
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "denial_reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "fallback_mode": {
      "type": "string",
      "enum": [
        "no_op",
        "dry_run",
        "fallback",
        "operator_reason",
        "hold_last_safe",
        "suppress",
        "private_only",
        "degraded_status",
        "kill_switch",
        "unavailable",
        "archive_only",
        "chapter_only"
      ]
    },
    "chapter_candidate": {
      "type": "object",
      "required": ["candidate_id", "label", "timecode", "allowed", "unavailable_reasons"],
      "additionalProperties": false,
      "properties": {
        "candidate_id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "timecode": {"type": "string", "pattern": "^[0-9]{2}:[0-9]{2}(:[0-9]{2})?$"},
        "allowed": {"type": "boolean"},
        "unavailable_reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "clip_candidate": {
      "type": "object",
      "required": ["candidate_id", "start_s", "end_s", "allowed", "unavailable_reasons"],
      "additionalProperties": false,
      "properties": {
        "candidate_id": {"type": "string", "minLength": 1},
        "start_s": {"type": "number", "minimum": 0},
        "end_s": {"type": "number", "minimum": 0},
        "allowed": {"type": "boolean"},
        "unavailable_reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "audit_sink": {
      "type": "string",
      "enum": [
        "jsonl",
        "artifact_payload",
        "prometheus_counter",
        "replay_index",
        "grounding_scorecard",
        "public_event_adapter",
        "metrics_timeseries"
      ]
    },
    "audit_consumer": {
      "type": "string",
      "enum": [
        "replay",
        "metrics",
        "grounding_scorecard",
        "public_event_adapter",
        "archive",
        "dashboard"
      ]
    }
  }
}
