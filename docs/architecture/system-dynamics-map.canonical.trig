@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sd: <https://hapax.local/ns/system-dynamics-map#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://hapax.local/system-dynamics-map/v1/graph/asserted> {
<https://hapax.local/system-dynamics-map/v1/map>
  a sd:SystemDynamicsMap ;
  sd:mapId "system-dynamics-map-v1" ;
  sd:version "1.0.0" ;
  sd:defaultFocus <https://hapax.local/system-dynamics-map/v1/node/rdf-owl-kg> ;
  sd:nodeCount "35"^^xsd:integer ;
  sd:edgeCount "42"^^xsd:integer ;
  dcterms:description "Faithful rendering of system dynamics requires a source-neutral semantic graph backbone with provenance, temporal state overlays, validation contracts, and reproducible view manifests. Modeling notations, runtime telemetry, event logs, and rendered views are inputs or projections, not the center." ;
  prov:generatedAtTime "2026-06-18T00:00:00Z"^^xsd:dateTime .

<https://hapax.local/system-dynamics-map/v1/layer/source-models>
  a sd:Layer ;
  sd:stableId "source-models" ;
  rdfs:label "Source Models" ;
  dcterms:description "Modeling languages and architecture views that can be lifted into the semantic backbone." .

<https://hapax.local/system-dynamics-map/v1/layer/decision-modeling>
  a sd:Layer ;
  sd:stableId "decision-modeling" ;
  rdfs:label "Decision Modeling Source" ;
  dcterms:description "Decision modeling concepts are one source-model family, not the global map center." .

<https://hapax.local/system-dynamics-map/v1/layer/execution-surfaces>
  a sd:Layer ;
  sd:stableId "execution-surfaces" ;
  rdfs:label "Execution And Artifacts" ;
  dcterms:description "Interchange formats, model artifacts, rule/runtime targets, and callable service boundaries." .

<https://hapax.local/system-dynamics-map/v1/layer/semantic-backbone>
  a sd:Layer ;
  sd:stableId "semantic-backbone" ;
  rdfs:label "Semantic Backbone" ;
  dcterms:description "Canonical graph identity, validation, provenance, and exchange contracts." .

<https://hapax.local/system-dynamics-map/v1/layer/observation-state>
  a sd:Layer ;
  sd:stableId "observation-state" ;
  rdfs:label "Observation And State" ;
  dcterms:description "State machines, event logs, telemetry, traces, temporal evidence, and event envelopes." .

<https://hapax.local/system-dynamics-map/v1/layer/projection>
  a sd:Layer ;
  sd:stableId "projection" ;
  rdfs:label "Projection" ;
  dcterms:description "View manifests and visualization engines that project validated graph snapshots." .

<https://hapax.local/system-dynamics-map/v1/scale/overview>
  a sd:ViewScale ;
  sd:stableId "overview" ;
  sd:resolution "1"^^xsd:integer ;
  rdfs:label "Overview" ;
  dcterms:description "System-level purpose, backbone, and major modeling families." .

<https://hapax.local/system-dynamics-map/v1/scale/domain>
  a sd:ViewScale ;
  sd:stableId "domain" ;
  sd:resolution "2"^^xsd:integer ;
  rdfs:label "Domain" ;
  dcterms:description "Source-model families, runtime surfaces, and semantic contracts." .

<https://hapax.local/system-dynamics-map/v1/scale/artifact>
  a sd:ViewScale ;
  sd:stableId "artifact" ;
  sd:resolution "3"^^xsd:integer ;
  rdfs:label "Artifact" ;
  dcterms:description "Concrete model artifacts, interchange formats, and contracts." .

<https://hapax.local/system-dynamics-map/v1/scale/runtime>
  a sd:ViewScale ;
  sd:stableId "runtime" ;
  sd:resolution "4"^^xsd:integer ;
  rdfs:label "Runtime" ;
  dcterms:description "Execution surfaces, event streams, telemetry, and service boundaries." .

<https://hapax.local/system-dynamics-map/v1/scale/evidence>
  a sd:ViewScale ;
  sd:stableId "evidence" ;
  sd:resolution "5"^^xsd:integer ;
  rdfs:label "Evidence" ;
  dcterms:description "Observations, provenance, validation results, and rendered view records." .

<https://hapax.local/system-dynamics-map/v1/partition/asserted>
  a sd:ClaimPartition ;
  sd:status "asserted" ;
  sd:namedGraph <https://hapax.local/system-dynamics-map/v1/graph/asserted> .

<https://hapax.local/system-dynamics-map/v1/node/rdf-owl-kg>
  a sd:Node ;
  sd:stableId "rdf-owl-kg" ;
  rdfs:label "RDF / OWL Knowledge Graph" ;
  sd:kind "backbone" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/semantic-backbone> ;
  sd:resolution "1"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Canonical semantic backbone for system identity, topology, claims, and cross-source relationships." ;
  sd:context "RDF/OWL-style identity gives the map a source-neutral backbone. Source models, observations, simulations, and rendered views attach to shared identities without making any notation the center." ;
  sd:documentationLink <https://www.w3.org/TR/rdf12-concepts/>, <https://www.w3.org/TR/owl2-overview/> ;
  sd:hardeningNote "Use named graphs for asserted, inferred, observed, simulated, and rendered claims." ;
  sd:hardeningNote "Map source-model identifiers to stable IRIs." ;
  sd:alias "semantic backbone" ;
  sd:alias "knowledge graph" ;
  sd:tag "semantic-core" ;
  sd:tag "identity" .

<https://hapax.local/system-dynamics-map/v1/node/shacl-contracts>
  a sd:Node ;
  sd:stableId "shacl-contracts" ;
  rdfs:label "SHACL Contracts" ;
  sd:kind "validation" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/semantic-backbone> ;
  sd:resolution "2"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Graph validation shapes and quality gates." ;
  sd:context "SHACL constrains the graph before data or projections are treated as trustworthy." ;
  sd:documentationLink <https://www.w3.org/TR/shacl/>, <https://www.w3.org/TR/shacl12-core/> ;
  sd:hardeningNote "Validate relation vocabulary, required provenance, status values, temporal bounds, and render-manifest completeness." ;
  sd:alias "shape constraints" ;
  sd:tag "validation" ;
  sd:tag "contracts" .

<https://hapax.local/system-dynamics-map/v1/node/prov-o>
  a sd:Node ;
  sd:stableId "prov-o" ;
  rdfs:label "PROV-O" ;
  sd:kind "provenance" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/semantic-backbone> ;
  sd:resolution "2"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Provenance ontology for agents, activities, and entities." ;
  sd:context "PROV-O records where a claim came from, who or what generated it, and which source or transformation it depends on." ;
  sd:documentationLink <https://www.w3.org/TR/prov-o/> ;
  sd:hardeningNote "Require provenance for imports, inferred edges, simulated states, and rendered views." ;
  sd:alias "provenance ontology" ;
  sd:tag "provenance" ;
  sd:tag "evidence" .

<https://hapax.local/system-dynamics-map/v1/node/jsonld-trig>
  a sd:Node ;
  sd:stableId "jsonld-trig" ;
  rdfs:label "JSON-LD / TriG" ;
  sd:kind "exchange" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/semantic-backbone> ;
  sd:resolution "3"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Portable graph and named graph exchange formats." ;
  sd:context "JSON-LD is useful for web-facing exchange. TriG is useful when named graph partitions need to be serialized directly." ;
  sd:documentationLink <https://www.w3.org/TR/json-ld11/>, <https://www.w3.org/TR/rdf12-concepts/> ;
  sd:hardeningNote "Version contexts and keep view data derivable from canonical graph snapshots." ;
  sd:alias "graph exchange" ;
  sd:tag "exchange" ;
  sd:tag "serialization" .

<https://hapax.local/system-dynamics-map/v1/node/temporal-state-events>
  a sd:Node ;
  sd:stableId "temporal-state-events" ;
  rdfs:label "Temporal State / Events" ;
  sd:kind "modeling-pattern" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/observation-state> ;
  sd:resolution "2"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Pattern for representing state as time-bounded evidence." ;
  sd:context "Topology and state should not be conflated. Current state is derived from observations and events with timestamps, source, confidence, and expiry." ;
  sd:documentationLink <https://www.w3.org/TR/owl-time/> ;
  sd:hardeningNote "Represent state transitions and observed state separately from static model structure." ;
  sd:alias "state overlay" ;
  sd:alias "event overlay" ;
  sd:tag "state" ;
  sd:tag "time" .

<https://hapax.local/system-dynamics-map/v1/node/opentelemetry>
  a sd:Node ;
  sd:stableId "opentelemetry" ;
  rdfs:label "OpenTelemetry" ;
  sd:kind "telemetry" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/observation-state> ;
  sd:resolution "4"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Telemetry conventions for traces, metrics, logs, profiles, and resources." ;
  sd:context "OpenTelemetry gives runtime observation vocabulary. It should feed observed graph overlays, not overwrite the design graph." ;
  sd:documentationLink <https://opentelemetry.io/docs/concepts/semantic-conventions/> ;
  sd:hardeningNote "Attach telemetry to runtime identities with time bounds, resource identity, sampling metadata, and confidence." ;
  sd:alias "OTel" ;
  sd:tag "telemetry" ;
  sd:tag "observability" .

<https://hapax.local/system-dynamics-map/v1/node/trace-context>
  a sd:Node ;
  sd:stableId "trace-context" ;
  rdfs:label "Trace Context" ;
  sd:kind "standard" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/observation-state> ;
  sd:resolution "4"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Distributed trace propagation format." ;
  sd:context "Trace Context helps correlate observed runtime behavior across service boundaries." ;
  sd:documentationLink <https://www.w3.org/TR/trace-context/> ;
  sd:hardeningNote "Use trace IDs as evidence correlation keys, not canonical architectural identity." ;
  sd:alias "traceparent" ;
  sd:alias "tracestate" ;
  sd:tag "trace" ;
  sd:tag "observability" .

<https://hapax.local/system-dynamics-map/v1/node/cloudevents>
  a sd:Node ;
  sd:stableId "cloudevents" ;
  rdfs:label "CloudEvents" ;
  sd:kind "standard" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/observation-state> ;
  sd:resolution "4"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Common event metadata envelope." ;
  sd:context "CloudEvents-style envelopes can normalize event metadata flowing into the observation graph." ;
  sd:documentationLink <https://cloudevents.io/> ;
  sd:hardeningNote "Preserve original event payload, envelope attributes, source, subject, and schema references." ;
  sd:alias "event envelope" ;
  sd:tag "event" ;
  sd:tag "interoperability" .

<https://hapax.local/system-dynamics-map/v1/node/decision-service>
  a sd:Node ;
  sd:stableId "decision-service" ;
  rdfs:label "Decision Service" ;
  sd:kind "boundary" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/decision-modeling> ;
  sd:resolution "3"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "A callable packaging boundary for decisions." ;
  sd:context "Decision services expose decisions for invocation by process, case, application, or runtime architecture components." ;
  sd:documentationLink <https://www.omg.org/spec/DMN/1.5/About-DMN> ;
  sd:hardeningNote "Separate design-time decision service boundaries from deployed API endpoints." ;
  sd:alias "DMN decision service" ;
  sd:tag "decision" ;
  sd:tag "service" .

<https://hapax.local/system-dynamics-map/v1/node/decision-table>
  a sd:Node ;
  sd:stableId "decision-table" ;
  rdfs:label "Decision Table" ;
  sd:kind "artifact" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/decision-modeling> ;
  sd:resolution "3"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Tabular decision logic used by DMN." ;
  sd:context "Decision tables are common DMN logic artifacts and often become executable rule assets." ;
  sd:documentationLink <https://www.omg.org/spec/DMN/1.5/About-DMN> ;
  sd:hardeningNote "Track hit policy, type constraints, FEEL expressions, and test coverage." ;
  sd:alias "DMN table" ;
  sd:tag "decision" ;
  sd:tag "rules" .

<https://hapax.local/system-dynamics-map/v1/node/dmn>
  a sd:Node ;
  sd:stableId "dmn" ;
  rdfs:label "DMN" ;
  sd:kind "standard" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/decision-modeling> ;
  sd:resolution "2"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Decision Model and Notation as one decision-modeling source family." ;
  sd:context "DMN models decision requirements and executable decision logic. It is valuable as a source model for decision dependencies, but it is not the default focus, layout root, or universal representation for topology, state, telemetry, and provenance." ;
  sd:documentationLink <https://www.omg.org/spec/DMN/1.5/About-DMN>, <https://www.omg.org/spec/DMN/1.6/Beta1/About-DMN> ;
  sd:hardeningNote "Treat DMN decisions as one claim type in the graph, not as the global model." ;
  sd:hardeningNote "Preserve DMN version, namespace, source document, and import provenance." ;
  sd:alias "Decision Model and Notation" ;
  sd:tag "decision" .

<https://hapax.local/system-dynamics-map/v1/node/drd>
  a sd:Node ;
  sd:stableId "drd" ;
  rdfs:label "DRD / DRG" ;
  sd:kind "notation" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/decision-modeling> ;
  sd:resolution "2"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "DMN decision requirement diagrams and decision requirement graphs." ;
  sd:context "DRDs show dependency between decisions, input data, business knowledge, and knowledge sources. They are not runtime event graphs." ;
  sd:documentationLink <https://www.omg.org/spec/DMN/1.5/About-DMN> ;
  sd:hardeningNote "Do not infer process sequence or runtime causality from a DRD edge without evidence." ;
  sd:alias "Decision Requirements Diagram" ;
  sd:alias "Decision Requirements Graph" ;
  sd:tag "decision" ;
  sd:tag "dependency" .

<https://hapax.local/system-dynamics-map/v1/node/feel>
  a sd:Node ;
  sd:stableId "feel" ;
  rdfs:label "FEEL" ;
  sd:kind "language" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/decision-modeling> ;
  sd:resolution "3"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Friendly Enough Expression Language used by DMN." ;
  sd:context "FEEL is the expression language side of DMN. Runtime portability depends on precise FEEL support and version handling." ;
  sd:documentationLink <https://www.omg.org/spec/DMN/1.6/Beta1/About-DMN> ;
  sd:hardeningNote "Record FEEL dialect/version support for each runtime before marking a decision executable." ;
  sd:alias "Friendly Enough Expression Language" ;
  sd:tag "language" ;
  sd:tag "expression" .

<https://hapax.local/system-dynamics-map/v1/node/dmn-xml-di>
  a sd:Node ;
  sd:stableId "dmn-xml-di" ;
  rdfs:label "DMN XML / DI" ;
  sd:kind "interchange" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/execution-surfaces> ;
  sd:resolution "3"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "DMN interchange and diagram information for a decision-modeling source." ;
  sd:context "DMN XML and diagram interchange preserve model content and layout metadata across tools." ;
  sd:documentationLink <https://www.omg.org/spec/DMN/1.5/About-DMN> ;
  sd:hardeningNote "Preserve namespace, schema version, diagram coordinates, and original bytes hash." ;
  sd:alias "DMN interchange" ;
  sd:tag "interchange" ;
  sd:tag "execution-surface" .

<https://hapax.local/system-dynamics-map/v1/node/archimate>
  a sd:Node ;
  sd:stableId "archimate" ;
  rdfs:label "ArchiMate" ;
  sd:kind "standard" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/source-models> ;
  sd:resolution "2"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Enterprise architecture modeling language." ;
  sd:context "ArchiMate contributes business, application, technology, motivation, strategy, and implementation context to the semantic backbone." ;
  sd:documentationLink <https://www.opengroup.org/archimate-forum/archimate-overview>, <https://www.opengroup.org/archimate-licensed-downloads> ;
  sd:hardeningNote "Use ArchiMate for enterprise context, not for low-level runtime state." ;
  sd:alias "ArchiMate enterprise architecture" ;
  sd:tag "enterprise" ;
  sd:tag "source-model" .

<https://hapax.local/system-dynamics-map/v1/node/bpmn>
  a sd:Node ;
  sd:stableId "bpmn" ;
  rdfs:label "BPMN" ;
  sd:kind "standard" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/source-models> ;
  sd:resolution "2"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Business Process Model and Notation for process flow." ;
  sd:context "BPMN process models can invoke or route through decision services, produce event evidence, and supply process context for the semantic backbone." ;
  sd:documentationLink <https://www.omg.org/spec/BPMN/2.0.2/> ;
  sd:hardeningNote "Do not treat BPMN sequence flow as proof of actual runtime ordering without event evidence." ;
  sd:alias "Business Process Model and Notation" ;
  sd:tag "process" ;
  sd:tag "source-model" .

<https://hapax.local/system-dynamics-map/v1/node/cmmn>
  a sd:Node ;
  sd:stableId "cmmn" ;
  rdfs:label "CMMN" ;
  sd:kind "standard" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/source-models> ;
  sd:resolution "2"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Case Management Model and Notation for case plans." ;
  sd:context "CMMN covers less prescriptive, case-oriented work that can use decisions without fitting a strict process flow or becoming the global map center." ;
  sd:documentationLink <https://www.omg.org/spec/CMMN/1.1/About-CMMN> ;
  sd:hardeningNote "Represent discretionary case behavior separately from deterministic process paths." ;
  sd:alias "Case Management Model and Notation" ;
  sd:tag "case" ;
  sd:tag "source-model" .

<https://hapax.local/system-dynamics-map/v1/node/sysml-v2>
  a sd:Node ;
  sd:stableId "sysml-v2" ;
  rdfs:label "SysML v2" ;
  sd:kind "standard" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/source-models> ;
  sd:resolution "2"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Systems modeling language for MBSE." ;
  sd:context "SysML v2 contributes requirements, structure, behavior, analysis, and verification context to system dynamics views." ;
  sd:documentationLink <https://www.omg.org/spec/SysML/2.0/About-SysML> ;
  sd:hardeningNote "Keep engineering requirement/verification evidence distinct from business decision dependencies." ;
  sd:alias "OMG System Modeling Language" ;
  sd:tag "systems" ;
  sd:tag "source-model" .

<https://hapax.local/system-dynamics-map/v1/node/sdlc-intake>
  a sd:Node ;
  sd:stableId "sdlc-intake" ;
  rdfs:label "SDLC Intake" ;
  sd:kind "operating-slice" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/observation-state> ;
  sd:resolution "2"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Concrete Hapax operating slice for work intake, claim, review, PR, CI, and release state." ;
  sd:context "The v1 map needs at least one real operating slice, not just a standards taxonomy. SDLC intake is a useful slice because it has tasks, claim files, review dossiers, PR state, CI checks, merge evidence, and stale/drift concepts." ;
  sd:documentationLink <https://github.com/hapax-systems/hapax-council/blob/main/CLAUDE.md#cc-task-tracking> ;
  sd:hardeningNote "Treat SDLC state as observed evidence over task and PR sources, not as an authority writer." ;
  sd:alias "task intake" ;
  sd:alias "operating slice" ;
  sd:tag "sdlc" ;
  sd:tag "operating-slice" .

<https://hapax.local/system-dynamics-map/v1/node/cc-task-claim>
  a sd:Node ;
  sd:stableId "cc-task-claim" ;
  rdfs:label "cc-task Claim" ;
  sd:kind "state-transition" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/observation-state> ;
  sd:resolution "3"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Claim transition that binds a governed task to a lane/session before mutation." ;
  sd:context "A claim record turns operator intent into authorized implementation work. The graph should show claim state, claimant, timestamp, route evidence, and whether the claim is stale." ;
  sd:documentationLink <https://github.com/hapax-systems/hapax-council/blob/main/CLAUDE.md#cc-task-tracking> ;
  sd:hardeningNote "Observe claim state from task notes and claim files; do not infer authority from prose alone." ;
  sd:alias "claim gate" ;
  sd:alias "task claim" ;
  sd:tag "sdlc" ;
  sd:tag "claim" .

<https://hapax.local/system-dynamics-map/v1/node/review-dossier>
  a sd:Node ;
  sd:stableId "review-dossier" ;
  rdfs:label "Review Dossier" ;
  sd:kind "evidence-artifact" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/semantic-backbone> ;
  sd:resolution "3"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Structured review artifact that records reviewer findings, acceptance, escalation, and evidence." ;
  sd:context "Review dossiers are evidence-bearing artifacts. The map should expose which claim or PR they review, what accepted it, and whether any acceptance is degraded or stale." ;
  sd:documentationLink <https://github.com/hapax-systems/hapax-council/blob/main/scripts/review_team.py> ;
  sd:hardeningNote "Keep review verdict, acceptance receipt, and merge evidence as distinct claims." ;
  sd:alias "review receipt" ;
  sd:alias "acceptance dossier" ;
  sd:tag "review" ;
  sd:tag "evidence" .

<https://hapax.local/system-dynamics-map/v1/node/pr-ci-checks>
  a sd:Node ;
  sd:stableId "pr-ci-checks" ;
  rdfs:label "PR / CI Checks" ;
  sd:kind "release-signal" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/execution-surfaces> ;
  sd:resolution "3"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Pull request and CI check state used by release gates." ;
  sd:context "PR state and check runs provide observed release readiness signals. They must stay separate from the underlying task and review claims because they can lag or fail independently." ;
  sd:documentationLink <https://docs.github.com/en/pull-requests>, <https://docs.github.com/en/actions> ;
  sd:hardeningNote "Record check conclusion, head SHA, merge queue state, and observed time before treating release state as current." ;
  sd:alias "CI" ;
  sd:alias "pull request checks" ;
  sd:tag "sdlc" ;
  sd:tag "release" .

<https://hapax.local/system-dynamics-map/v1/node/merge-release>
  a sd:Node ;
  sd:stableId "merge-release" ;
  rdfs:label "Merge / Release Evidence" ;
  sd:kind "state-transition" ;
  sd:layer <https://hapax.local/system-dynamics-map/v1/layer/execution-surfaces> ;
  sd:resolution "3"^^xsd:integer ;
  sd:status "asserted" ;
  dcterms:description "Merged PR, release stage, and closure evidence that terminates a governed work slice." ;
  sd:context "A task is not durably complete until release evidence, merge state, acceptance receipt, and cc-close state converge." ;
  sd:documentationLink <https://docs.github.com/en/repositories/configuring-branches-and-merges-in-your-repository/configuring-pull-request-merges> ;
  sd:hardeningNote "Link merge commit, task close, acceptance receipt, and generated artifacts in one auditable path." ;
  sd:alias "release closure" ;
  sd:alias "merge evidence" ;
  sd:tag "sdlc" ;
  sd:tag "release" .

<https://hapax.local/system-dynamics-map/v1/edge/dmn-to-drd>
  a sd:Edge ;
