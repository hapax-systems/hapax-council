  sd:status "asserted" ;
  dcterms:description "Decision Model and Notation, the entry point for the map." ;
  sd:context "DMN models decision requirements and executable decision logic. It is valuable for decision dependencies, but it is too narrow to be the universal representation for topology, state, telemetry, and provenance." ;
  sd:documentationLink <https://www.omg.org/spec/DMN/1.5/About-DMN>, <https://www.omg.org/spec/DMN/1.6/Beta1/About-DMN> .

