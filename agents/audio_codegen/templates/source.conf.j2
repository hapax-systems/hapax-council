# PipeWire filter-chain conf for audio source: {{ source_id }}
#
# Generated by `agents.audio_codegen.spec_emitter` on operator request.
# Adjust the LADSPA chain to match the source's role; this stub
# wires a single fast_lookahead_limiter_1913 with the v1.1
# loudnorm defaults.

context.modules = [
    { name = libpipewire-module-filter-chain
        args = {
            node.description = "{{ description }}"
            media.name = "{{ pipewire_name }}"
            filter.graph = {
                nodes = [
                    {
                        type = ladspa
                        name = limit
                        plugin = fast_lookahead_limiter_1913
                        label = fastLookaheadLimiter
                        control = {
                            "Input gain (dB)" = {{ input_gain_db }}
                            "Limit (dB)" = {{ limit_db }}
                            "Release time (s)" = {{ release_s }}
                        }
                    }
                ]
            }
            capture.props = {
                node.name = "{{ pipewire_name }}-input"
                media.class = Audio/Sink
                audio.position = [ FL FR ]
            }
            playback.props = {
                node.name = "{{ pipewire_name }}"
                media.class = Audio/Source
                audio.position = [ FL FR ]
            }
        }
    }
]
