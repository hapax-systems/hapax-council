{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "description": "Programme manager lifecycle — active programme, dwell overshoot ratio, starts per role+show, soft-prior overrides (INVARIANT >0/stream), planned vs actual duration. Source: shared/programme_observability.py.",
  "uid": "hapax-programme-lifecycle",
  "title": "Hapax / Programme — lifecycle & dwell",
  "tags": ["hapax", "programme", "broadcast", "dwell"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active programme",
      "description": "Currently active programme (gauge ON for the active role+show). Reflects the labelled programme keeping the broadcast in shape.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "hapax_programme_active",
          "legendFormat": "{{role}} / {{show}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Dwell overshoot ratio",
      "description": "elapsed / planned for the active programme. >1.0 = running long; <1.0 = under planned duration. INVARIANT: per-stream there must be at least one soft-prior override (otherwise programme system is rigid).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "hapax_programme_dwell_overshoot_ratio",
          "legendFormat": "{{role}} / {{show}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 0.8 },
              { "color": "yellow", "value": 1.2 },
              { "color": "orange", "value": 1.5 },
              { "color": "red", "value": 2.0 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Programmes started — per role + show",
      "description": "Programme starts split by role and show. Cadence reflects the broadcast schedule.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (role, show) (rate(hapax_programme_start_total[5m]))",
          "legendFormat": "{{role}} / {{show}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Soft-prior overrides (per role)",
      "description": "Counts the cases where a soft prior was overridden by a stronger signal. INVARIANT: must be > 0 per stream — zero indicates the prior system is too rigid.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum by (role) (rate(hapax_programme_soft_prior_overridden_total[5m]))",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Planned vs actual duration (active programme)",
      "description": "Planned and actual elapsed seconds for the active programme. Divergence shows how often the system runs over/under plan.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "hapax_programme_duration_planned_seconds",
          "legendFormat": "planned — {{role}}/{{show}}",
          "refId": "A"
        },
        {
          "expr": "hapax_programme_duration_actual_seconds",
          "legendFormat": "actual — {{role}}/{{show}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "^planned —.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^actual —.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      }
    }
  ],
  "templating": { "list": [] }
}
