{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "description": "Studio compositor process & pipeline health — uptime, watchdog, cameras healthy/total, v4l2sink last-frame, pipeline-restart cadence, v4l2sink stalls/recoveries, RSS+VRAM, FD count, camera-rebuild cadence, per-source render p95, director intents + voice activity. Source: agents/studio_compositor/metrics.py. Complementary to compositor-surface-health.json (different metric scope: process/pipeline/v4l2 vs HOMAGE/face-obscure/follow-mode/ward/layout/broadcast).",
  "uid": "hapax-compositor-health",
  "title": "Hapax / Studio Compositor — process & pipeline health",
  "tags": ["hapax", "compositor", "studio", "v4l2", "process"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Uptime",
      "description": "Seconds since the studio compositor process started. Hard reset = unexpected restart (cross-check pipeline_restarts and journal).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "studio_compositor_uptime_seconds",
          "legendFormat": "uptime",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 600 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Watchdog (s since last fed)",
      "description": "Seconds since last WATCHDOG=1 sent to systemd. Approaching 60s = service is about to be killed by Type=notify watchdog.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "studio_compositor_watchdog_last_fed_seconds_ago",
          "legendFormat": "s since fed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cameras healthy / total",
      "description": "Cameras currently in HEALTHY state vs total registered. Mismatch = at least one camera is in fallback/recovery (cross-check the studio-cameras dashboard).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "studio_compositor_cameras_healthy",
          "legendFormat": "healthy",
          "refId": "A"
        },
        {
          "expr": "studio_compositor_cameras_total",
          "legendFormat": "total",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "text", "value": null }]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "v4l2sink last frame (s ago)",
      "description": "Seconds since the v4l2sink BUFFER probe last fired. >15s with HEALTHY cameras = downstream stall — OBS will see frozen video.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "studio_compositor_v4l2sink_last_frame_seconds_ago",
          "legendFormat": "s since frame",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pipeline restarts — by pipeline",
      "description": "Cumulative pipeline teardown + rebuild events. Spikes correlate with hot reload after preset changes; rising baseline = a pipeline is unstable.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (pipeline) (rate(studio_compositor_pipeline_restarts_total[15m])) * 60",
          "legendFormat": "{{pipeline}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "v4l2sink stalls / recoveries",
      "description": "Per-reason v4l2sink stalls and recovery attempts. Stalls without recoveries = the watchdog is failing to repair; recoveries without stalls = sentinels firing prematurely.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum by (reason) (rate(studio_compositor_v4l2sink_stall_total[5m]))",
          "legendFormat": "stall:{{reason}}",
          "refId": "A"
        },
        {
          "expr": "rate(studio_compositor_v4l2sink_recovery_total[5m])",
          "legendFormat": "recovery",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Memory & GPU footprint",
      "description": "Process RSS and GPU VRAM. Either rising unboundedly = leak. RSS plateau ~1-3GB, VRAM steady ~1-2GB during normal operation.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "studio_compositor_memory_footprint_bytes",
          "legendFormat": "RSS",
          "refId": "A"
        },
        {
          "expr": "studio_compositor_gpu_vram_bytes",
          "legendFormat": "GPU VRAM",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "FD count & v4l2sink throughput",
      "description": "Process file descriptors (rising = leak) and v4l2sink frames/sec (should track 30 fps).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 15 },
      "targets": [
        {
          "expr": "studio_compositor_process_fd_count",
          "legendFormat": "fd count",
          "refId": "A"
        },
        {
          "expr": "rate(studio_compositor_v4l2sink_frames_total[1m])",
          "legendFormat": "v4l2sink frames/sec",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Camera rebuild cadence (per role)",
      "description": "Cumulative per-role camera pipeline rebuilds. Spikes during USB hot-swap recovery; baseline rising = chronic flake on a specific role.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (role) (rate(studio_compositor_camera_rebuild_total[15m])) * 60",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Per-source render duration p95 (ms)",
      "description": "Per-CairoSourceRunner render time per frame, p95. Above the 33ms 30-fps budget = source is the bottleneck and the budget tracker will fire.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (source_id, le) (rate(studio_compositor_source_render_duration_ms_bucket[5m])))",
          "legendFormat": "{{source_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 16 },
              { "color": "orange", "value": 33 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Director intent + voice activity",
      "description": "Director intents emitted (rate) and voice-active gauge. Spike + voice = director responding to spoken signals; flat lines = director loop quiet.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 33 },
      "targets": [
        {
          "expr": "rate(studio_compositor_director_intent_total[5m])",
          "legendFormat": "director intents/sec",
          "refId": "A"
        },
        {
          "expr": "studio_compositor_voice_active",
          "legendFormat": "voice active",
          "refId": "B"
        },
        {
          "expr": "studio_compositor_music_ducked",
          "legendFormat": "music ducked",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      }
    }
  ],
  "templating": { "list": [] }
}
