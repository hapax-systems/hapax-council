{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "description": "Mood-engine observability for Phase D of logos-mood-bridge-calibration: posterior gauges for arousal, valence, and coherence plus observed and Bayesian-contributing signal counters per engine.",
  "uid": "hapax-mood-engines",
  "title": "Hapax / Mood Engines - posterior and signal contribution",
  "tags": ["hapax", "mood", "bayesian", "logos"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Mood posteriors",
      "description": "Current Bayesian posterior for the three mood engines. Flat lines at priors with observed signals but zero contribution mean current live signals are non-evidence under the engine LR semantics.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "mood_arousal_posterior_value",
          "legendFormat": "arousal",
          "refId": "A"
        },
        {
          "expr": "mood_valence_posterior_value",
          "legendFormat": "valence-negative",
          "refId": "B"
        },
        {
          "expr": "mood_coherence_posterior_value",
          "legendFormat": "coherence-low",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "min", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Signals per second",
      "description": "Observed counts track non-None bridge readings. Contributed counts track readings that affect Bayesian log-odds; positive-only false observations are observed but not contributed.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "sum by (engine) (rate(mood_engine_signals_contributed_total[5m]))",
          "legendFormat": "contributed {{engine}}",
          "refId": "A"
        },
        {
          "expr": "sum by (engine) (rate(mood_engine_signals_observed_total[5m]))",
          "legendFormat": "observed {{engine}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Signals observed and contributed in the last hour",
      "description": "Per-engine count of observed non-None readings and readings that actually changed Bayesian log-odds over the dashboard window.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        {
          "expr": "sum by (engine) (increase(mood_engine_signals_contributed_total[1h]))",
          "legendFormat": "contributed {{engine}}",
          "refId": "A"
        },
        {
          "expr": "sum by (engine) (increase(mood_engine_signals_observed_total[1h]))",
          "legendFormat": "observed {{engine}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 60 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value"
      }
    }
  ]
}
