{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "description": "Affordance pipeline observability — recruitment events per 6-domain taxonomy (perception/expression/recall/action/communication/regulation), outcome split, dispatch rate, winner-similarity p50/p95/p99, candidate-pool size, JSONL write-failure stat. Source: shared/affordance_pipeline.py + telemetry.",
  "uid": "hapax-affordance-pipeline",
  "title": "Hapax / Affordance Pipeline — recruitment & dispatch",
  "tags": ["hapax", "affordance", "recruitment", "semantic-pipeline"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Recruitment events — per 6-domain taxonomy",
      "description": "Affordance pipeline recruitment events labelled by domain (perception, expression, recall, action, communication, regulation). Sustained zero across all domains = pipeline stuck or stimmung suppressing recruitment.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (domain) (rate(hapax_affordance_recruitment_total[5m]))",
          "legendFormat": "{{domain}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": { "mode": "normal" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Outcome events — success vs failure",
      "description": "Recruitment outcome by terminal status. Sustained 'failure' or 'timeout' classes signal degraded execution downstream of the pipeline.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(hapax_affordance_outcome_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "(?i).*(error|fail|timeout).*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "(?i).*(ok|success|done).*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Dispatch rate (cross-modal activations/sec)",
      "description": "Cumulative dispatch events from the affordance pipeline to capability handlers. Pairs with recruitment count to expose the recruit-to-dispatch ratio.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "rate(hapax_affordance_dispatch_total[5m])",
          "legendFormat": "dispatches/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Winner similarity — p50 / p95 / p99",
      "description": "Cosine similarity of the selected affordance vs the impingement narrative embedding. Falling p50 = pipeline picking weaker matches; rising p99 = highly confident niche recruitments.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(hapax_affordance_winner_similarity_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(hapax_affordance_winner_similarity_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(hapax_affordance_winner_similarity_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 3,
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Candidate-pool size — p50 / p95",
      "description": "Number of capabilities surviving cosine + governance filtering for each impingement. Collapse to p95<=1 = pipeline narrowed to a single capability (loss of diversity).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(hapax_affordance_candidates_count_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(hapax_affordance_candidates_count_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "JSONL write failures (1h)",
      "description": "OSError-class failures appending to AffordancePipeline JSONL sinks (per-sink). Steady-state must be 0 — non-zero = persistent disk/permission issue eating recruitment audit trail.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "targets": [
        {
          "expr": "sum by (sink) (increase(hapax_affordance_jsonl_write_failures_total[1h]))",
          "legendFormat": "{{sink}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      }
    }
  ],
  "templating": { "list": [] }
}
